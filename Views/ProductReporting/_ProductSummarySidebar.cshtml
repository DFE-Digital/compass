@model Compass.Models.ProductDto

@if (Model == null)
{
    <div class="card mb-4">
        <div class="card-body">
            <p class="mb-0 text-muted">Product details are not available.</p>
        </div>
    </div>
}
else
{
    var categories = Model.CategoryValues?.Where(cv => !string.IsNullOrWhiteSpace(cv.Name)).Take(6).ToList() ?? new List<Compass.Models.CategoryValueDto>();
    var primaryContact = Model.ProductContacts?.FirstOrDefault(pc => !string.IsNullOrWhiteSpace(pc.ContactEmail) || !string.IsNullOrWhiteSpace(pc.ContactName) || pc.UsersPermissionsUser != null);

    <div class="card project-summary-card mb-4">
        <div class="card-header">
            <h3 class="card-title mb-0">Product overview</h3>
        </div>
        <div class="card-body p-0">
            <ul class="list-group list-group-flush project-summary-list">
                <li class="list-group-item">
                    <small class="text-muted d-block">Title</small>
                    @if (!string.IsNullOrWhiteSpace(Model.ProductUrl))
                    {
                        <a href="@Model.ProductUrl" target="_blank" rel="noopener noreferrer" class="font-weight-semibold">@Model.Title</a>
                    }
                    else
                    {
                        <span class="font-weight-semibold">@Model.Title</span>
                    }
                </li>
                <li class="list-group-item">
                    <small class="text-muted d-block">FIPS ID</small>
                    <span class="font-weight-medium">@Model.FipsId</span>
                </li>
                <li class="list-group-item">
                    <small class="text-muted d-block">State</small>
                    <span class="badge badge-light text-uppercase">@Model.State</span>
                </li>
                @if (!string.IsNullOrWhiteSpace(Model.Phase))
                {
                    <li class="list-group-item">
                        <small class="text-muted d-block">Phase</small>
                        <span>@Model.Phase</span>
                    </li>
                }
                @if (categories.Any())
                {
                    <li class="list-group-item">
                        <small class="text-muted d-block">Categories</small>
                        <ul class="list-unstyled mb-0">
                            @foreach (var category in categories)
                            {
                                <li>
                                    <span class="badge badge-secondary mr-1">@category.Name</span>
                                </li>
                            }
                        </ul>
                    </li>
                }
                @if (primaryContact != null)
                {
                    <li class="list-group-item">
                        <small class="text-muted d-block">Primary contact</small>
                        <div>@(primaryContact.ContactName ?? primaryContact.LegacyName ?? primaryContact.UsersPermissionsUser?.Username ?? "Not set")</div>
                        @if (!string.IsNullOrWhiteSpace(primaryContact.ContactEmail ?? primaryContact.UsersPermissionsUser?.Email))
                        {
                            var email = primaryContact.ContactEmail ?? primaryContact.UsersPermissionsUser?.Email;
                            <small><a href="mailto:@email">@email</a></small>
                        }
                    </li>
                }
            </ul>
        </div>
    </div>
}
