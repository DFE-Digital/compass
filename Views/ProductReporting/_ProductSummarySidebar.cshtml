@model Compass.Models.ProductDto
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    var fipsBaseUrl = Configuration["fipsProduct:baseUrl"] ?? "https://find-products-services-test.azurewebsites.net/";
    var productDocumentId = Model?.DocumentId ?? Model?.FipsId;
    var fipsProductUrl = !string.IsNullOrWhiteSpace(productDocumentId) 
        ? $"{fipsBaseUrl.TrimEnd('/')}/product?ref={Uri.EscapeDataString(productDocumentId)}" 
        : null;
}

@if (Model == null)
{
    <div class="card mb-4">
        <div class="card-body">
            <p class="mb-0 text-muted">Product details are not available.</p>
        </div>
    </div>
}
else
{
    var primaryContact = Model.ProductContacts?.FirstOrDefault(pc => !string.IsNullOrWhiteSpace(pc.ContactEmail) || !string.IsNullOrWhiteSpace(pc.ContactName) || pc.UsersPermissionsUser != null);

    <div class="card project-summary-card mb-4">
        <div class="card-header">
            <h3 class="card-title mb-0">Product overview</h3>
        </div>
        <div class="card-body p-0">
            <ul class="list-group list-group-flush project-summary-list">
                <li class="list-group-item">
                    <small class="text-muted d-block">Title</small>
                    @if (!string.IsNullOrWhiteSpace(fipsProductUrl))
                    {
                        <a href="@fipsProductUrl" target="_blank" rel="noopener noreferrer" class="font-weight-semibold">
                            @Model.Title
                        </a>
                    }
                    else
                    {
                        <span class="font-weight-semibold">@Model.Title</span>
                    }
                </li>
                @if (!string.IsNullOrWhiteSpace(Model.Phase))
                {
                    <li class="list-group-item">
                        <small class="text-muted d-block">Phase</small>
                        <span>@Model.Phase</span>
                    </li>
                }
                @if (primaryContact != null)
                {
                    var contactName = primaryContact.ContactName ?? primaryContact.LegacyName ?? primaryContact.UsersPermissionsUser?.Username ?? "Not set";
                    var contactEmail = primaryContact.ContactEmail ?? primaryContact.UsersPermissionsUser?.Email;
                    <li class="list-group-item">
                        <small class="text-muted d-block">Primary contact</small>
                        @if (!string.IsNullOrWhiteSpace(contactEmail))
                        {
                            <a href="mailto:@contactEmail" class="font-weight-semibold">@contactName</a>
                        }
                        else
                        {
                            <span class="font-weight-semibold">@contactName</span>
                        }
                    </li>
                }
            </ul>
        </div>
    </div>
}
