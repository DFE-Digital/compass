@model List<Compass.Models.PerformanceMetric>
@using System.Text.Json
@{
    ViewData["Title"] = "What you need to report";
    var metrics = ViewBag.Metrics as List<Compass.Models.PerformanceMetric> ?? new List<Compass.Models.PerformanceMetric>();
    var tasksCount = ViewBag.TasksCount as int? ?? 0;
    var yourProductsCount = ViewBag.YourProductsCount as int? ?? 0;
    var allProductsCount = ViewBag.AllProductsCount as int? ?? 0;
}

@{
    ViewBag.BrandText = "Performance reporting";
    ViewBag.NavLinks = new[]
    {
        new { Text = "Performance metrics", Action = "PerformanceMetrics", Controller = "ProductReporting", Url = (string)null, IsButton = false, IsActive = false }
    };
}
@await Html.PartialAsync("_ModuleNavbar")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0 pl-4 breadcrumb-standard">
            <li class="breadcrumb-item">
                <a href="/" class="breadcrumb-link-standard">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="ProductReporting" asp-action="PerformanceMetrics" class="breadcrumb-link-standard">Product performance metrics</a>
            </li>
            <li class="breadcrumb-item active breadcrumb-active-standard" aria-current="page">What you need to report</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">What you need to report</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <!-- Left Column: Navigation -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title">Navigation</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <a href="@Url.Action("PerformanceMetrics", new { view = "tasks" })"
                               class="list-group-item list-group-item-action">
                                Your tasks
                                @if (tasksCount > 0)
                                {
                                    <span class="badge badge-light float-right">@tasksCount</span>
                                }
                            </a>
                            <a href="@Url.Action("PerformanceMetrics", new { view = "products" })"
                               class="list-group-item list-group-item-action">
                                Your products
                                @if (yourProductsCount > 0)
                                {
                                    <span class="badge badge-light float-right">@yourProductsCount</span>
                                }
                            </a>
                            <a href="@Url.Action("PerformanceMetrics", new { view = "all" })"
                               class="list-group-item list-group-item-action">
                                All products
                                @if (allProductsCount > 0)
                                {
                                    <span class="badge badge-light float-right">@allProductsCount</span>
                                }
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Help Navigation Card -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title">Help</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <a href="@Url.Action("WhatYouNeedToReport", "ProductReporting")"
                               class="list-group-item list-group-item-action active">
                                What you need to report
                            </a>
                            <a href="@Url.Action("ReportingDates", "ProductReporting")"
                               class="list-group-item list-group-item-action">
                                Reporting dates
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Content -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <div class="mb-4">
                    <h3 class="mb-2">Performance metrics</h3>
                    <p class="text-muted">The following performance metrics may be required for your products, depending on their phase and type.</p>
                </div>
                
                @if (metrics != null && metrics.Any())
                {
                    @foreach (var metric in metrics)
                    {
                        // Parse validation rules
                        Compass.Models.ValidationRules? validationRules = null;
                        try
                        {
                            var options = new JsonSerializerOptions
                            {
                                PropertyNameCaseInsensitive = true
                            };
                            validationRules = JsonSerializer.Deserialize<Compass.Models.ValidationRules>(metric.ValidationRules, options);
                        }
                        catch
                        {
                            // If parsing fails, continue without validation rules display
                        }
                        
                        <div class="card mb-4">
                            <div class="card-body">
                                    <div class="d-flex align-items-start mb-3">
                                        <span class="badge badge-primary mr-2" style="font-size: 0.875rem; padding: 0.5rem 0.75rem;">@metric.Identifier</span>
                                        <h4 class="mb-0" style="font-size: 1.25rem; font-weight: 600;">@metric.Title</h4>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <p class="mb-0" style="color: #505a5f; line-height: 1.6;">@metric.Description</p>
                                    </div>
                                    
                                    <div class="row mt-3">
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <strong class="d-block mb-1" style="color: #0b0c0c; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px;">Value type</strong>
                                                <div style="color: #505a5f;">
                                                    @switch (metric.ValueType)
                                                    {
                                                        case Compass.Models.ValueType.Text:
                                                            <span>Text</span>
                                                            break;
                                                        case Compass.Models.ValueType.Number:
                                                            <span>Whole number</span>
                                                            break;
                                                        case Compass.Models.ValueType.Decimal:
                                                            <span>Decimal number</span>
                                                            break;
                                                        case Compass.Models.ValueType.Percentage:
                                                            <span>Percentage (0-100)</span>
                                                            break;
                                                    }
                                                </div>
                                            </div>
                                            
                                            <div class="mb-3">
                                                <strong class="d-block mb-1" style="color: #0b0c0c; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px;">Valid from</strong>
                                                <div style="color: #505a5f;">@(new DateTime(metric.ValidFromYear, metric.ValidFromMonth, 1).ToString("MMMM yyyy"))</div>
                                            </div>
                                        </div>
                                        
                                        <div class="col-md-6">
                                            <div class="mb-3">
                                                <strong class="d-block mb-1" style="color: #0b0c0c; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px;">Applies to phases</strong>
                                                <div>
                                                    @if (!string.IsNullOrEmpty(metric.ApplicablePhases))
                                                    {
                                                        var phases = metric.ApplicablePhases.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                                                        @foreach (var phase in phases)
                                                        {
                                                            <span class="badge badge-info mr-1 mb-1">@phase</span>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-light">All phases</span>
                                                    }
                                                </div>
                                            </div>
                                            
                                            <div class="mb-3">
                                                <strong class="d-block mb-1" style="color: #0b0c0c; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px;">Applies to product types</strong>
                                                <div>
                                                    @if (!string.IsNullOrEmpty(metric.ApplicableTypes))
                                                    {
                                                        var types = metric.ApplicableTypes.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                                                        @foreach (var type in types)
                                                        {
                                                            <span class="badge badge-success mr-1 mb-1">@type</span>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-light">All types</span>
                                                    }
                                                </div>
                                            </div>
                                            
                                            @if (metric.ConditionalOnMetricId.HasValue)
                                            {
                                                var conditionalMetric = metrics.FirstOrDefault(m => m.Id == metric.ConditionalOnMetricId.Value);
                                                <div class="mb-3">
                                                    <strong class="d-block mb-1" style="color: #0b0c0c; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px;">Conditional requirement</strong>
                                                    <div style="color: #505a5f;">
                                                        @if (conditionalMetric != null)
                                                        {
                                                            <span>Only required if <strong>@conditionalMetric.Identifier</strong> has a value</span>
                                                        }
                                                        else
                                                        {
                                                            <span>Only required if another metric has a value</span>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    
                                    @if (validationRules != null)
                                    {
                                        <div class="mt-3 pt-3 border-top">
                                            <strong class="d-block mb-2" style="color: #0b0c0c; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.5px;">Validation rules</strong>
                                            <div class="row">
                                                <div class="col-md-6">
                                                    <ul class="list-unstyled mb-0" style="color: #505a5f;">
                                                        @if (validationRules.Required)
                                                        {
                                                            <li class="mb-1">
                                                                <i class="fas fa-check-circle text-success mr-2"></i>
                                                                <strong>Required:</strong> Yes
                                                            </li>
                                                        }
                                                        else
                                                        {
                                                            <li class="mb-1">
                                                                <i class="fas fa-times-circle text-muted mr-2"></i>
                                                                <strong>Required:</strong> No
                                                            </li>
                                                        }
                                                        @if (validationRules.AllowNull)
                                                        {
                                                            <li class="mb-1">
                                                                <i class="fas fa-info-circle text-info mr-2"></i>
                                                                <strong>Allow null:</strong> Yes (can be marked as not captured)
                                                            </li>
                                                        }
                                                    </ul>
                                                </div>
                                                <div class="col-md-6">
                                                    <ul class="list-unstyled mb-0" style="color: #505a5f;">
                                                        @if (validationRules.MinimumValue.HasValue)
                                                        {
                                                            var minValue = validationRules.MinimumValue.Value;
                                                            var minFormatted = minValue % 1 == 0 ? minValue.ToString("N0") : minValue.ToString("N");
                                                            <li class="mb-1">
                                                                <i class="fas fa-arrow-down text-warning mr-2"></i>
                                                                <strong>Minimum value:</strong> @minFormatted
                                                            </li>
                                                        }
                                                        @if (validationRules.MaximumValue.HasValue)
                                                        {
                                                            var maxValue = validationRules.MaximumValue.Value;
                                                            var maxFormatted = maxValue % 1 == 0 ? maxValue.ToString("N0") : maxValue.ToString("N");
                                                            <li class="mb-1">
                                                                <i class="fas fa-arrow-up text-warning mr-2"></i>
                                                                <strong>Maximum value:</strong> @maxFormatted
                                                            </li>
                                                        }
                                                        @if (validationRules.DecimalPlaces.HasValue)
                                                        {
                                                            <li class="mb-1">
                                                                <i class="fas fa-hashtag text-info mr-2"></i>
                                                                <strong>Decimal places:</strong> @validationRules.DecimalPlaces.Value
                                                            </li>
                                                        }
                                                    </ul>
                                                </div>
                                            </div>
                                            @if (!validationRules.Required && !validationRules.AllowNull && !validationRules.MinimumValue.HasValue && !validationRules.MaximumValue.HasValue && !validationRules.DecimalPlaces.HasValue)
                                            {
                                                <p class="text-muted mb-0 mt-2"><em>No specific validation rules</em></p>
                                            }
                                        </div>
                                    }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="card">
                        <div class="card-body">
                            <div class="alert alert-info mb-0">
                                <p class="mb-0">No performance metrics are currently configured.</p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
