@model IEnumerable<Compass.Models.ServiceStandard>

@{
    ViewData["Title"] = "Service Standards";
    var totalStandards = ViewBag.TotalStandards as int? ?? Model.Count();
    var activeStandards = ViewBag.ActiveStandards as int? ?? Model.Count(s => s.IsActive);
    var standardsWithGuidance = ViewBag.StandardsWithGuidance as int? ?? Model.Count(s => s.PhaseGuidance.Any());
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <style>
        .breadcrumb a:hover {
            color: #003078 !important;
            text-decoration: underline !important;
        }
    </style>
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Service Standards</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        @{
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
            ViewBag.BrandText = "Service Standards";
            ViewBag.NavLinks = new[]
            {
                new { Text = "Service standards", Action = "Index", Controller = "ServiceStandards", Url = (string)null, IsButton = false, IsActive = currentAction == "Index" }
            };
        }
        @await Html.PartialAsync("_ModuleNavbar")

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <!-- Summary Cards -->
        <div class="row mb-4">
            <div class="col-md-4 mb-3">
                <div class="card border-left-primary shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Standards</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@totalStandards</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-list-alt fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card border-left-success shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Active Standards</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@activeStandards</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-check-circle fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card border-left-info shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-info text-uppercase mb-1">With Phase Guidance</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@standardsWithGuidance</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-book fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Service Standards List -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title mb-0">The 14 Service Standards</h3>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">Click on any standard to view details and manage phase-specific guidance.</p>
                <div class="standards-list">
                @foreach (var standard in Model.OrderBy(s => s.StandardNumber))
                {
                    var hasGuidance = standard.PhaseGuidance.Any();
                    var guidanceCount = standard.PhaseGuidance.Count;
                    var phasesWithGuidance = standard.PhaseGuidance.Select(pg => pg.Phase).ToList();
                    
                    <div class="standard-item @(standard.IsActive ? "" : "standard-item-inactive")">
                        <div class="standard-item-header">
                            <div class="standard-number-badge">@standard.StandardNumber</div>
                            <div class="standard-title-section">
                                <h3 class="standard-title">@standard.Title</h3>
                                @if (!standard.IsActive)
                                {
                                    <span class="badge badge-secondary ml-2">Inactive</span>
                                }
                            </div>
                        </div>
                        
                        <div class="standard-item-body">
                            @if (!string.IsNullOrEmpty(standard.Summary))
                            {
                                <p class="standard-summary">@standard.Summary</p>
                            }
                            else if (!string.IsNullOrEmpty(standard.Description))
                            {
                                <p class="standard-summary">@(standard.Description.Length > 250 ? standard.Description.Substring(0, 250) + "…" : standard.Description)</p>
                            }
                            
                            <div class="standard-meta">
                                @if (hasGuidance)
                                {
                                    <div class="standard-guidance-badge">
                                        <i class="fas fa-check-circle text-success"></i>
                                        <span>Guidance available for: @string.Join(", ", phasesWithGuidance)</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="standard-guidance-badge standard-guidance-missing">
                                        <i class="fas fa-exclamation-triangle text-warning"></i>
                                        <span>No phase guidance added yet</span>
                                    </div>
                                }
                                
                                @if (standard.ServiceStandardProfessions != null && standard.ServiceStandardProfessions.Any())
                                {
                                    <div class="mt-2">
                                        <small class="text-muted d-block mb-1"><strong>Applies to:</strong></small>
                                        <div>
                                            @foreach (var ssp in standard.ServiceStandardProfessions.OrderBy(ssp => ssp.DdatProfession.Name))
                                            {
                                                <span class="badge badge-primary mr-1 mb-1">@ssp.DdatProfession.Name</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                        
                        <div class="standard-item-actions">
                            <a asp-action="Details" asp-route-id="@standard.Id" class="btn btn-primary btn-sm">
                                <i class="fas fa-eye"></i> View Standard
                            </a>
                            <a asp-action="ManagePhaseGuidance" asp-route-id="@standard.Id" class="btn btn-outline-info btn-sm">
                                <i class="fas fa-book"></i> Manage Guidance
                            </a>
                            <a asp-action="Edit" asp-route-id="@standard.Id" class="btn btn-outline-secondary btn-sm">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                        </div>
                    </div>
                }
                </div>
                @if (!Model.Any())
                {
                    <div class="alert alert-info mt-3">
                        <h4><i class="fas fa-info-circle"></i> No Service Standards Found</h4>
                        <p class="mb-0">The 14 GOV.UK Service Standards need to be seeded into the database. Please contact an administrator to initialize the standards.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<style>
    .border-left-primary {
        border-left: 0.25rem solid #4e73df !important;
    }
    .border-left-success {
        border-left: 0.25rem solid #1cc88a !important;
    }
    .border-left-info {
        border-left: 0.25rem solid #36b9cc !important;
    }
    .text-xs {
        font-size: 0.7rem;
    }
    .text-gray-300 {
        color: #dddfeb !important;
    }
    .text-gray-800 {
        color: #5a5c69 !important;
    }
    .shadow {
        box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15) !important;
    }
</style>

