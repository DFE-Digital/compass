@model Compass.Models.ServiceStandard

@{
    ViewData["Title"] = $"Manage Phase Guidance - Standard {Model.StandardNumber}";
    var standard = ViewBag.Standard as Compass.Models.ServiceStandard ?? Model;
    var phases = ViewBag.Phases as string[] ?? new[] { "Discovery", "Alpha", "Beta", "Live" };
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "ServiceStandards")" style="color: #005ea5; text-decoration: none;">Service Standards</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Details", "ServiceStandards", new { id = Model.Id })" style="color: #005ea5; text-decoration: none;">Standard @Model.StandardNumber</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Phase Guidance</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }

        <!-- Dashboard Header -->
        <div class="dashboard-header">
            <h1>Manage Phase Guidance</h1>
            <p>Add or edit guidance for applying <strong>Standard @Model.StandardNumber: @Model.Title</strong> during each Agile phase of delivery.</p>
        </div>

        <div class="row">
            <div class="col-12">
                @foreach (var phase in phases)
                {
                    var existingGuidance = Model.PhaseGuidance?.FirstOrDefault(pg => pg.Phase == phase);
                    <div class="dashboard-section mb-4">
                        <div class="dashboard-section-header">
                            <h2><i class="fas fa-project-diagram"></i> @phase Phase</h2>
                        </div>
                        <div class="card">
                            <div class="card-body">
                                <form asp-action="SavePhaseGuidance" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="standardId" value="@Model.Id" />
                                    <input type="hidden" name="phase" value="@phase" />

                                    <div class="form-group">
                                        <label for="Guidance_@phase"><strong>Guidance</strong></label>
                                        <textarea name="Guidance" id="Guidance_@phase" class="form-control" rows="6" placeholder="Enter guidance for applying this standard during the @phase phase...">@(existingGuidance?.Guidance ?? "")</textarea>
                                        <small class="form-text text-muted">Main guidance content (markdown supported)</small>
                                    </div>

                                    <div class="form-group">
                                        <label for="KeyActivities_@phase"><strong>Key Activities</strong></label>
                                        <textarea name="KeyActivities" id="KeyActivities_@phase" class="form-control" rows="4" placeholder="Enter key activities to consider...">@(existingGuidance?.KeyActivities ?? "")</textarea>
                                        <small class="form-text text-muted">Key activities to consider in this phase (markdown supported)</small>
                                    </div>

                                    <div class="form-group">
                                        <label for="QuestionsToConsider_@phase"><strong>Questions to Consider</strong></label>
                                        <textarea name="QuestionsToConsider" id="QuestionsToConsider_@phase" class="form-control" rows="4" placeholder="Enter questions to consider...">@(existingGuidance?.QuestionsToConsider ?? "")</textarea>
                                        <small class="form-text text-muted">Questions to consider in this phase (markdown supported)</small>
                                    </div>

                                    <div class="form-group">
                                        <button type="submit" class="btn btn-primary">
                                            <i class="fas fa-save"></i> Save @phase Phase Guidance
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to Standard Details
                </a>
            </div>
        </div>
    </div>
</section>

