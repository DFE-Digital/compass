@{
    // All views under Views/Modern/ use the Compass2 shell (dfe-c / govuk-frontend, ~/modern/css/*).
    // Other areas keep the legacy Shared/_Layout.cshtml.
    var viewPath = ViewContext.View?.Path;
    var normalized = viewPath?.Replace('\\', '/') ?? "";
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var isModernViewPath = normalized.Contains("/Views/Modern/", StringComparison.OrdinalIgnoreCase);
    var isModernController = controller.StartsWith("Modern", StringComparison.OrdinalIgnoreCase);
    if (isModernViewPath || isModernController)
    {
        Layout = "~/Views/Modern/Shared/_Layout.cshtml";
    }
    else
    {
        Layout = "_Layout";
    }
}

