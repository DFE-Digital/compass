@model IEnumerable<Compass.Models.Milestone>
@{
    ViewData["Title"] = "Milestones";
    var objectiveTitle = ViewBag.ObjectiveTitle as string;
    var currentTab = ViewBag.CurrentTab as string ?? "active";
    var currentViewScope = ViewBag.CurrentViewScope as string ?? "assigned_to_me";
    var currentDimension = ViewBag.CurrentDimension as string;
    var currentBusinessArea = ViewBag.CurrentBusinessArea as string;
    var currentStatus = ViewBag.CurrentStatus as string;
    var currentProducts = ViewBag.CurrentProducts as string[] ?? Array.Empty<string>();
    var businessAreas = ViewBag.BusinessAreas as List<string> ?? new List<string>();
    var products = ViewBag.Products as List<Compass.Models.ProductDto> ?? new List<Compass.Models.ProductDto>();
    var userBusinessAreas = ViewBag.UserBusinessAreas as List<string> ?? new List<string>();
    var myMilestones = ViewBag.MyMilestones as List<Compass.Models.Milestone> ?? new List<Compass.Models.Milestone>();
    var openCount = ViewBag.OpenCount as int? ?? 0;
    var closedCount = ViewBag.ClosedCount as int? ?? 0;
    var overdueCount = ViewBag.OverdueCount as int? ?? 0;
    var assignedToMeCount = ViewBag.AssignedToMeCount as int? ?? 0;
    var myProductsCount = ViewBag.MyProductsCount as int? ?? 0;
    var organisationWideCount = ViewBag.OrganisationWideCount as int? ?? 0;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    @if (objectiveTitle != null)
                    {
                        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Objectives">Strategic objectives</a></li>
                        <li class="breadcrumb-item active">Milestones for @objectiveTitle</li>
                    }
                    else
                    {
                        <li class="breadcrumb-item active">Milestones</li>
                    }
                </ol>
                <h1 class="m-0">Milestones @(objectiveTitle != null ? $"for {objectiveTitle}" : "")</h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <div class="btn-group">
                        <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            Actions
                        </button>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" asp-action="Create" asp-route-objectiveId="@ViewBag.ObjectiveId">
                                Add milestone
                            </a>
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item export-placeholder" href="#">
                                Export to Excel
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }

        <div class="row">
            <!-- Left Column: View Options and Filters -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <!-- View Scope Options -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">View</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <a href="@Url.Action("Index", new { objectiveId = ViewBag.ObjectiveId, viewScope = "assigned_to_me" })" 
                               class="list-group-item list-group-item-action @(currentViewScope == "assigned_to_me" ? "active" : "")">
                                Assigned to me
                                <span class="badge badge-light float-right">@assignedToMeCount</span>
                            </a>
                            <a href="@Url.Action("Index", new { objectiveId = ViewBag.ObjectiveId, viewScope = "my_products" })" 
                               class="list-group-item list-group-item-action @(currentViewScope == "my_products" ? "active" : "")">
                                My products
                                <span class="badge badge-light float-right">@myProductsCount</span>
                            </a>
                            <a href="@Url.Action("Index", new { objectiveId = ViewBag.ObjectiveId, viewScope = "organisation_wide" })" 
                               class="list-group-item list-group-item-action @(currentViewScope == "organisation_wide" ? "active" : "")">
                                Organisation-wide
                                <span class="badge badge-light float-right">@organisationWideCount</span>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Filters -->
                <div class="card mt-3">
                    <div class="card-header">
                        <h3 class="card-title">Filters</h3>
                    </div>
                    <div class="card-body">
                        <form method="get" id="filterForm">
                            @if (ViewBag.ObjectiveId != null)
                            {
                                <input type="hidden" name="objectiveId" value="@ViewBag.ObjectiveId" />
                            }
                            <input type="hidden" name="viewScope" value="@currentViewScope" />
                            
                            <div class="form-group">
                                <label>Business area</label>
                                <select name="businessArea" class="form-control form-control-sm auto-submit">
                                    <option value="">All</option>
                                    @foreach (var ba in businessAreas)
                                    {
                                        <option value="@ba" selected="@(currentBusinessArea == ba)">@ba</option>
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Status</label>
                                <select name="status" class="form-control form-control-sm auto-submit">
                                    <option value="">All statuses</option>
                                    <option value="not_started" selected="@(currentStatus == "not_started")">Not started</option>
                                    <option value="on_track" selected="@(currentStatus == "on_track")">On track</option>
                                    <option value="at_risk" selected="@(currentStatus == "at_risk")">At risk</option>
                                    <option value="delayed" selected="@(currentStatus == "delayed")">Delayed</option>
                                    <option value="complete" selected="@(currentStatus == "complete")">Complete</option>
                                    <option value="cancelled" selected="@(currentStatus == "cancelled")">Cancelled</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Products</label>
                                <select name="products" class="form-control form-control-sm select2-multiple" multiple="multiple" data-placeholder="All products">
                                    @foreach (var product in products)
                                    {
                                        <option value="@product.FipsId" selected="@(((IEnumerable<string>)currentProducts).Contains(product.FipsId))">@product.Title</option>
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <button type="submit" class="btn btn-primary btn-sm btn-block">Apply filters</button>
                                <a href="@Url.Action("Index", new { objectiveId = ViewBag.ObjectiveId, viewScope = currentViewScope })" class="btn btn-default btn-sm btn-block">Clear filters</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Column: Content -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <!-- Active Milestones -->
                @{
                    var activeMilestones = Model?.Where(m => m.Status != "complete" && m.Status != "cancelled").ToList() ?? new List<Compass.Models.Milestone>();
                    var completedMilestones = Model?.Where(m => m.Status == "complete" || m.Status == "cancelled").ToList() ?? new List<Compass.Models.Milestone>();
                }
                
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Active milestones</h3>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover mb-0 sortable-table">
                            <thead>
                                <tr>
                                    <th class="sortable" data-column="Name" tabindex="0" role="button" aria-label="Sort by Name">Name</th>
                                    <th style="width: 120px;" class="sortable" data-column="Owner" tabindex="0" role="button" aria-label="Sort by Owner">Owner</th>
                                    <th style="width: 100px;" class="sortable" data-column="Progress" tabindex="0" role="button" aria-label="Sort by Progress">Progress</th>
                                    <th style="width: 120px;" class="sortable" data-column="Status" tabindex="0" role="button" aria-label="Sort by Status">Status</th>
                                    <th style="width: 120px;" class="sortable" data-column="DueDate" tabindex="0" role="button" aria-label="Sort by Due date">Due date</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (activeMilestones.Any())
                                {
                                    @foreach (var milestone in activeMilestones)
                                    {
                                        var isOverdue = milestone.DueDate < DateTime.Now;
                                        var productName = products.FirstOrDefault(p => p.FipsId == milestone.FipsId)?.Title ?? milestone.FipsId;
                                        <tr class="@(isOverdue ? "table-danger" : "")">
                                            <td>
                                                <a asp-action="Details" asp-route-id="@milestone.Id">@milestone.Name</a>
                                                @if (!string.IsNullOrEmpty(productName))
                                                {
                                                    <br><small class="text-muted">@productName</small>
                                                }
                                            </td>
                                            <td>@(milestone.OwnerEmail ?? "-")</td>
                                            <td>
                                                @if (milestone.ProgressPercent.HasValue)
                                                {
                                                    <text>@milestone.ProgressPercent%</text>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @switch (milestone.Status)
                                                {
                                                    case "not_started":
                                                        <span class="badge badge-secondary">Not started</span>
                                                        break;
                                                    case "on_track":
                                                        <span class="badge badge-success">On track</span>
                                                        break;
                                                    case "at_risk":
                                                        <span class="badge badge-warning">At risk</span>
                                                        break;
                                                    case "delayed":
                                                        <span class="badge badge-danger">Delayed</span>
                                                        break;
                                                    default:
                                                        <span class="badge badge-secondary">@milestone.Status</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                <span class="@(isOverdue ? "text-danger" : "")">
                                                    @milestone.DueDate.ToString("dd MMM yyyy")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-3">No active milestones found</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Completed Milestones -->
                @if (completedMilestones.Any())
                {
                    <div class="card mt-3">
                        <div class="card-header" data-toggle="collapse" data-target="#completedMilestonesCollapse" style="cursor: pointer;">
                            <h3 class="card-title">
                                Completed milestones
                                <span class="badge badge-secondary ml-2">@completedMilestones.Count</span>
                            </h3>
                            <div class="card-tools">
                                <button type="button" class="btn btn-tool">
                                    <i class="fas fa-chevron-down"></i>
                                </button>
                            </div>
                        </div>
                        <div id="completedMilestonesCollapse" class="collapse">
                            <div class="card-body table-responsive p-0">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th style="width: 120px;">Owner</th>
                                            <th style="width: 100px;">Progress</th>
                                            <th style="width: 120px;">Status</th>
                                            <th style="width: 120px;">Completed date</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var milestone in completedMilestones)
                                        {
                                            var productName = products.FirstOrDefault(p => p.FipsId == milestone.FipsId)?.Title ?? milestone.FipsId;
                                            <tr>
                                                <td>
                                                    <a asp-action="Details" asp-route-id="@milestone.Id">@milestone.Name</a>
                                                    @if (!string.IsNullOrEmpty(productName))
                                                    {
                                                        <br><small class="text-muted">@productName</small>
                                                    }
                                                </td>
                                                <td>@(milestone.OwnerEmail ?? "-")</td>
                                                <td>
                                                    @if (milestone.ProgressPercent.HasValue)
                                                    {
                                                        <text>@milestone.ProgressPercent%</text>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td>
                                                    @switch (milestone.Status)
                                                    {
                                                        case "complete":
                                                            <span class="badge badge-success">Complete</span>
                                                            break;
                                                        case "cancelled":
                                                            <span class="badge badge-dark">Cancelled</span>
                                                            break;
                                                        default:
                                                            <span class="badge badge-secondary">@milestone.Status</span>
                                                            break;
                                                    }
                                                </td>
                                                <td>
                                                    @if (milestone.ActualDate.HasValue)
                                                    {
                                                        @milestone.ActualDate.Value.ToString("dd MMM yyyy")
                                                    }
                                                    else
                                                    {
                                                        @milestone.DueDate.ToString("dd MMM yyyy")
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Initialize Select2
            $('.select2-multiple').select2({
                theme: 'bootstrap4',
                width: '100%'
            });

            $('.select2-multiple').on('change', function() {
                $('#filterForm').submit();
            });

            // Handle export placeholder click
            $('.export-placeholder').on('click', function(e) {
                e.preventDefault();
                alert('Export feature coming soon');
            });

            // Auto-submit form on filter change
            $('.auto-submit').on('change', function() {
                $(this).closest('form').submit();
            });

            // Rotate chevron icon on collapse
            $('#completedMilestonesCollapse').on('show.bs.collapse', function() {
                $(this).prev('.card-header').find('.fa-chevron-down').removeClass('fa-chevron-down').addClass('fa-chevron-up');
            }).on('hide.bs.collapse', function() {
                $(this).prev('.card-header').find('.fa-chevron-up').removeClass('fa-chevron-up').addClass('fa-chevron-down');
            });

            // Initialize sortable tables
            $('.sortable-table').each(function() {
                initializeSortableTable($(this));
            });
        });

        function initializeSortableTable(table) {
            var currentSort = { column: null, direction: 'asc' };

            table.find('.sortable').on('click keypress', function(e) {
                if (e.type === 'keypress' && e.which !== 13 && e.which !== 32) {
                    return;
                }
                
                var column = $(this).data('column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(table, column, direction);
                currentSort = { column: column, direction: direction };
            });

            function sortTable(table, column, direction) {
                var tbody = table.find('tbody');
                var rows = tbody.find('tr').toArray();
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var colIndex = table.find('thead th[data-column="' + column + '"]').index();
                    
                    if (column === 'DueDate') {
                        var aDate = $(a).find('td').eq(colIndex).text().trim();
                        var bDate = $(b).find('td').eq(colIndex).text().trim();
                        aVal = aDate === '-' ? new Date(9999, 11, 31) : new Date(aDate);
                        bVal = bDate === '-' ? new Date(9999, 11, 31) : new Date(bDate);
                    } else if (column === 'Progress') {
                        aVal = parseInt($(a).find('td').eq(colIndex).text().replace('%', '').trim()) || 0;
                        bVal = parseInt($(b).find('td').eq(colIndex).text().replace('%', '').trim()) || 0;
                    } else {
                        aVal = $(a).find('td').eq(colIndex).text().trim().toLowerCase();
                        bVal = $(b).find('td').eq(colIndex).text().trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.empty();
                rows.forEach(function(row) {
                    tbody.append(row);
                });
                
                updateSortIcons(table, column, direction);
            }

            function updateSortIcons(table, column, direction) {
                table.find('.sortable i').remove();
                var header = table.find('.sortable[data-column="' + column + '"]');
                var iconClass = direction === 'asc' ? 'fa-sort-up' : 'fa-sort-down';
                header.append(' <i class="fas ' + iconClass + '"></i>');
            }
        }
    </script>
}
