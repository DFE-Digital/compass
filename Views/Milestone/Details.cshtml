@using System.Text.Json
@model Compass.Models.Milestone
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Milestone details";
    var isOverdue = Model.DueDate.Date < DateTime.Today &&
                    Model.Status != "complete" && Model.Status != "cancelled";
    var products = ViewBag.Products as List<Compass.Models.ProductDto> ?? new List<Compass.Models.ProductDto>();
    var fipsBaseUrl = Configuration["fipsProduct:baseUrl"] ?? "https://find-products-services-test.azurewebsites.net/";
    
    // Parse external links
    List<(string text, string url)> externalLinks = new List<(string text, string url)>();
    if (!string.IsNullOrEmpty(Model.ExternalRef))
    {
        try
        {
            // Try to parse as JSON array
            var jsonLinks = JsonSerializer.Deserialize<List<Dictionary<string, string>>>(Model.ExternalRef);
            if (jsonLinks != null)
            {
                foreach (var link in jsonLinks)
                {
                    if (link.ContainsKey("text") && link.ContainsKey("url"))
                    {
                        externalLinks.Add((link["text"], link["url"]));
                    }
                }
            }
        }
        catch
        {
            // If parsing fails, treat as a plain URL
            externalLinks.Add(("External reference", Model.ExternalRef));
        }
    }
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Milestones</a></li>
                    <li class="breadcrumb-item active">Milestone</li>
                </ol>
                <h1 class="m-0">
                    @Model.Name 
                    <span class="text-muted font-weight-normal ml-2">#@Model.Id</span>
                    @if (isOverdue)
                    {
                        <span class="badge badge-danger ml-2">OVERDUE</span>
                    }
                </h1>
                @if (!string.IsNullOrEmpty(Model.FipsId))
                {
                    var product = products.FirstOrDefault(p => p.FipsId == Model.FipsId);
                    var productUrl = $"{fipsBaseUrl.TrimEnd('/')}/product/{Model.FipsId}";
                    <div class="mt-2">
                        @if (product != null)
                        {
                            <a href="@productUrl" target="_blank" class="text-primary h5">
                                @product.Title (@Model.FipsId) <i class="fas fa-external-link-alt ml-1" style="font-size: 0.75rem;"></i>
                            </a>
                        }
                        else
                        {
                            <a href="@productUrl" target="_blank" class="text-primary h5">
                                @Model.FipsId <i class="fas fa-external-link-alt ml-1" style="font-size: 0.75rem;"></i>
                            </a>
                        }
                    </div>
                }
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <div class="btn-group">
                        <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            Actions
                        </button>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" asp-action="Edit" asp-route-id="@Model.Id">
                                Edit milestone
                            </a>
                            <a class="dropdown-item" asp-controller="Action" asp-action="Create" asp-route-milestoneId="@Model.Id">
                                Add action
                            </a>
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item" asp-action="Delete" asp-route-id="@Model.Id">
                                Delete milestone
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <!-- Key Information Cards -->
        <div class="row mb-3">
            <div class="col-xxl-4 col-xl-4 col-lg-4 col-md-4 col-sm-12 col-12">
                <div class="small-box bg-primary">
                    <div class="inner">
                        <h3>@switch (Model.Status)
                        {
                            case "complete":
                                <text>Complete</text>
                                break;
                            case "on_track":
                                <text>On track</text>
                                break;
                            case "at_risk":
                                <text>At risk</text>
                                break;
                            case "delayed":
                                <text>Delayed</text>
                                break;
                            case "not_started":
                                <text>Not started</text>
                                break;
                            case "cancelled":
                                <text>Cancelled</text>
                                break;
                            default:
                                <text>@Model.Status</text>
                                break;
                        }</h3>
                        <p>Status</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-flag"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-4 col-xl-4 col-lg-4 col-md-4 col-sm-12 col-12">
                <div class="small-box bg-info">
                    <div class="inner">
                        <h3>@Model.DueDate.ToString("d MMM")</h3>
                        <p>Due date</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-calendar"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-4 col-xl-4 col-lg-4 col-md-4 col-sm-12 col-12">
                <div class="small-box bg-success">
                    <div class="inner">
                        <h3>@(Model.ProgressPercent?.ToString() ?? "0")%</h3>
                        <p>Progress</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-chart-line"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Main content area -->
            <div class="col-xxl-9 col-xl-9 col-lg-8 col-md-12 col-sm-12 col-12">
                <!-- Description -->
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0"><i class="fas fa-align-left"></i> Description</h5>
                        </div>
                        <div class="card-body">
                            <p class="mb-0">@Model.Description</p>
                        </div>
                    </div>
                }

                <!-- Notes -->
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0"><i class="fas fa-sticky-note"></i> Notes</h5>
                        </div>
                        <div class="card-body">
                            <p class="mb-0">@Model.Notes</p>
                        </div>
                    </div>
                }

                <!-- Related items -->
                @if ((Model.MilestoneRisks != null && Model.MilestoneRisks.Any()) ||
                     (Model.MilestoneIssues != null && Model.MilestoneIssues.Any()) ||
                     (Model.MilestoneActions != null && Model.MilestoneActions.Any()))
                {
                    <div class="row">
                        @if (Model.MilestoneRisks != null && Model.MilestoneRisks.Any())
                        {
                            <div class="col-xxl-6 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title mb-0">Related risks (@Model.MilestoneRisks.Count)</h5>
                                    </div>
                                    <div class="card-body p-0">
                                        <ul class="list-group list-group-flush">
                                            @foreach (var mr in Model.MilestoneRisks)
                                            {
                                                <li class="list-group-item">
                                                    <a asp-controller="Risk" asp-action="Details" asp-route-id="@mr.Risk.Id">
                                                        @mr.Risk.Title
                                                    </a>
                                                    <span class="badge @(mr.Risk.RiskScore >= 15 ? "badge-danger" : mr.Risk.RiskScore >= 10 ? "badge-warning" : "badge-success") float-right">
                                                        Score: @mr.Risk.RiskScore
                                                    </span>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        }

                        @if (Model.MilestoneIssues != null && Model.MilestoneIssues.Any())
                        {
                            <div class="col-xxl-6 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title mb-0">Related issues (@Model.MilestoneIssues.Count)</h5>
                                    </div>
                                    <div class="card-body p-0">
                                        <ul class="list-group list-group-flush">
                                            @foreach (var mi in Model.MilestoneIssues)
                                            {
                                                <li class="list-group-item">
                                                    <a asp-controller="Issue" asp-action="Details" asp-route-id="@mi.Issue.Id">
                                                        @mi.Issue.Title
                                                    </a>
                                                    <span class="badge @(mi.Issue.Severity == "critical" ? "badge-danger" : mi.Issue.Severity == "high" ? "badge-warning" : "badge-info") float-right">
                                                        @mi.Issue.Severity
                                                    </span>
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        }

                        @if (Model.MilestoneActions != null && Model.MilestoneActions.Any())
                        {
                            <div class="col-xxl-12 col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12">
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title mb-0">Related actions (@Model.MilestoneActions.Count)</h5>
                                    </div>
                                    <div class="card-body table-responsive p-0">
                                        <table class="table table-hover table-striped mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Title</th>
                                                    <th>Assigned to</th>
                                                    <th>Status</th>
                                                    <th>Due date</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var ma in Model.MilestoneActions)
                                                {
                                                    var actionOverdue = ma.Action.DueDate.HasValue && 
                                                                      ma.Action.DueDate.Value.Date < DateTime.Today &&
                                                                      ma.Action.Status != "done" && ma.Action.Status != "cancelled";
                                                    <tr>
                                                        <td>
                                                            <a asp-controller="Action" asp-action="Details" asp-route-id="@ma.Action.Id">
                                                                @ma.Action.Title
                                                            </a>
                                                        </td>
                                                        <td>
                                                            @if (!string.IsNullOrEmpty(ma.Action.AssignedToEmail))
                                                            {
                                                                <a href="mailto:@ma.Action.AssignedToEmail">@ma.Action.AssignedToEmail</a>
                                                            }
                                                            else
                                                            {
                                                                <span>-</span>
                                                            }
                                                        </td>
                                                        <td>
                                                            @switch (ma.Action.Status)
                                                            {
                                                                case "done":
                                                                    <span class="badge badge-success">Done</span>
                                                                    break;
                                                                case "in_progress":
                                                                    <span class="badge badge-primary">In progress</span>
                                                                    break;
                                                                case "blocked":
                                                                    <span class="badge badge-danger">Blocked</span>
                                                                    break;
                                                                case "not_started":
                                                                    <span class="badge badge-secondary">Not started</span>
                                                                    break;
                                                                case "cancelled":
                                                                    <span class="badge badge-dark">Cancelled</span>
                                                                    break;
                                                                default:
                                                                    <span class="badge badge-secondary">@ma.Action.Status</span>
                                                                    break;
                                                            }
                                                        </td>
                                                        <td>
                                                            @if (ma.Action.DueDate.HasValue)
                                                            {
                                                                <span class="@(actionOverdue ? "text-danger font-weight-bold" : "")">
                                                                    @ma.Action.DueDate.Value.ToString("d MMM yyyy")
                                                                </span>
                                                                @if (actionOverdue)
                                                                {
                                                                    <br /><small class="text-danger">Overdue</small>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <span>-</span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Right sidebar -->
            <div class="col-xxl-3 col-xl-3 col-lg-4 col-md-12 col-sm-12 col-12">
                <!-- Classification -->
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="card-title mb-0">Classification</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="font-weight-bold text-muted small">Business area</label>
                            <div>
                                @if (!string.IsNullOrEmpty(Model.BusinessArea))
                                {
                                    <a asp-action="Index" asp-route-businessArea="@Model.BusinessArea" class="text-primary">
                                        @Model.BusinessArea
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">Not specified</span>
                                }
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="font-weight-bold text-muted small">Strategic objective</label>
                            <div>
                                @if (Model.Objective != null)
                                {
                                    <a asp-action="Index" asp-route-objectiveId="@Model.Objective.Id" class="text-info">
                                        @Model.Objective.Title
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">Not linked</span>
                                }
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="font-weight-bold text-muted small">Owner</label>
                            <div>
                                @if (Model.OwnerUser != null)
                                {
                                    <div>@Model.OwnerUser.Name</div>
                                    @if (!string.IsNullOrEmpty(Model.OwnerUser.Email))
                                    {
                                        <small class="text-muted">
                                            <a href="mailto:@Model.OwnerUser.Email" class="text-muted">@Model.OwnerUser.Email</a>
                                        </small>
                                    }
                                }
                                else if (!string.IsNullOrEmpty(Model.OwnerEmail))
                                {
                                    <a href="mailto:@Model.OwnerEmail" class="text-dark">@Model.OwnerEmail</a>
                                }
                                else
                                {
                                    <span class="text-muted">Unassigned</span>
                                }
                            </div>
                        </div>

                        <div>
                            <label class="font-weight-bold text-muted small">Milestone ID</label>
                            <div class="text-dark">#@Model.Id</div>
                        </div>
                    </div>
                </div>

                <!-- External Links -->
                @if (externalLinks.Any())
                {
                    <div class="card">
                        <div class="card-header">
                            <h5 class="card-title mb-0">External links</h5>
                        </div>
                        <div class="card-body">
                            @foreach (var link in externalLinks)
                            {
                                <div class="@(link != externalLinks.Last() ? "mb-2" : "")">
                                    <a href="@link.url" target="_blank" class="text-primary" style="word-break: break-word;">
                                        <i class="fas fa-external-link-alt mr-1"></i>@link.text
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Timeline -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Timeline</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="font-weight-bold text-muted small">Due date</label>
                            <div class="@(isOverdue ? "text-danger font-weight-bold" : "")">
                                @Model.DueDate.ToString("d MMMM yyyy")
                                @if (isOverdue)
                                {
                                    var daysOverdue = (DateTime.Today - Model.DueDate.Date).Days;
                                    <br /><small class="text-danger">@daysOverdue days overdue</small>
                                }
                            </div>
                        </div>

                        @if (Model.BaselineDueDate.HasValue)
                        {
                            <div class="mb-3">
                                <label class="font-weight-bold text-muted small">Baseline due</label>
                                <div>@Model.BaselineDueDate.Value.ToString("d MMMM yyyy")</div>
                                @if (Model.DueDate != Model.BaselineDueDate)
                                {
                                    var daysDiff = (Model.DueDate - Model.BaselineDueDate.Value).Days;
                                    <small class="@(daysDiff > 0 ? "text-warning" : "text-info")">
                                        @(daysDiff > 0 ? $"+{daysDiff}" : daysDiff) days from baseline
                                    </small>
                                }
                            </div>
                        }

                        @if (Model.ActualDate.HasValue)
                        {
                            <div class="mb-3">
                                <label class="font-weight-bold text-muted small">Actual date</label>
                                <div>@Model.ActualDate.Value.ToString("d MMMM yyyy")</div>
                            </div>
                        }

                        <div>
                            <label class="font-weight-bold text-muted small">Last updated</label>
                            <div class="text-muted small">@Model.UpdatedAt.ToString("d MMM yyyy HH:mm")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Comments Section -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0"><i class="fas fa-comments"></i> Comments</h5>
                    </div>
                    <div class="card-body">
                        <div id="commentsContainer">
                            <p class="text-muted text-center">Loading comments...</p>
                        </div>
                        
                        <hr />
                        
                        <div class="form-group">
                            <label for="newComment" class="font-weight-bold">Add a comment</label>
                            <textarea id="newComment" class="form-control" rows="3" placeholder="Enter your comment..."></textarea>
                        </div>
                        <button type="button" class="btn btn-primary" id="addCommentBtn">
                            <i class="fas fa-plus"></i> Add comment
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@Html.AntiForgeryToken()

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            loadComments();
            
            function loadComments() {
                $.ajax({
                    url: '/api/comments/Milestone/@Model.Id',
                    type: 'GET',
                    success: function(data) {
                        displayComments(data);
                    },
                    error: function() {
                        $('#commentsContainer').html('<p class="text-danger">Failed to load comments</p>');
                    }
                });
            }
            
            function displayComments(comments) {
                if (!comments || comments.length === 0) {
                    $('#commentsContainer').html('<p class="text-muted">No comments yet</p>');
                    return;
                }
                
                var html = '';
                comments.forEach(function(comment) {
                    var date = new Date(comment.createdAt);
                    var dateStr = date.toLocaleString('en-GB', { 
                        day: 'numeric', 
                        month: 'short', 
                        year: 'numeric', 
                        hour: '2-digit', 
                        minute: '2-digit' 
                    });
                    
                    html += '<div class="border-bottom pb-3 mb-3">';
                    html += '<div class="d-flex justify-content-between align-items-start mb-2">';
                    html += '<strong>' + (comment.createdByUser ? comment.createdByUser.name : 'Unknown') + '</strong>';
                    html += '<small class="text-muted">' + dateStr + '</small>';
                    html += '</div>';
                    html += '<p class="mb-0">' + comment.commentText.replace(/\n/g, '<br>') + '</p>';
                    html += '</div>';
                });
                
                $('#commentsContainer').html(html);
            }
            
            $('#addCommentBtn').click(function() {
                var commentText = $('#newComment').val().trim();
                
                if (!commentText) {
                    alert('Please enter a comment');
                    return;
                }
                
                $.ajax({
                    url: '/api/comments',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        entityType: 'Milestone',
                        entityId: @Model.Id,
                        commentText: commentText
                    }),
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function() {
                        $('#newComment').val('');
                        loadComments();
                    },
                    error: function() {
                        alert('Failed to add comment');
                    }
                });
            });
        });
    </script>
}

