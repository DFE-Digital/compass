@model Compass.Models.Issue
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Issue details";
    var isOverdue = Model.TargetResolutionDate.HasValue && 
                    Model.TargetResolutionDate.Value.Date < DateTime.Today &&
                    Model.Status != "resolved" && Model.Status != "closed";
    var products = ViewBag.Products as List<Compass.Models.ProductDto> ?? new List<Compass.Models.ProductDto>();
    var fipsBaseUrl = Configuration["fipsProduct:baseUrl"] ?? "https://find-products-services-test.azurewebsites.net/";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Issues</a></li>
                    <li class="breadcrumb-item active">Issue details</li>
                </ol>
                <h1 class="m-0">@Model.Title</h1>
                <p class="text-muted">Issue #@Model.Id</p>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <div class="btn-group">
                        <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            Actions
                        </button>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" asp-action="Edit" asp-route-id="@Model.Id">Edit issue</a>
                            <a class="dropdown-item" asp-controller="Action" asp-action="Create" asp-route-issueId="@Model.Id">Add resolution action</a>
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item" asp-action="Delete" asp-route-id="@Model.Id">Delete issue</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <!-- Main content -->
            <div class="col-xxl-9 col-xl-9 col-lg-8 col-md-12 col-sm-12 col-12">
                <!-- Product link -->
                @if (!string.IsNullOrEmpty(Model.FipsId))
                {
                    var product = products.FirstOrDefault(p => p.FipsId == Model.FipsId);
                    var productUrl = $"{fipsBaseUrl.TrimEnd('/')}/product/{Model.FipsId}";
                    <div class="card">
                        <div class="card-body">
                            <strong>Product:</strong>
                            @if (product != null)
                            {
                                <a href="@productUrl" target="_blank" rel="noopener noreferrer">@product.Title (@Model.FipsId)</a>
                            }
                            else
                            {
                                <a href="@productUrl" target="_blank" rel="noopener noreferrer">@Model.FipsId</a>
                            }
                        </div>
                    </div>
                }

                <!-- Description -->
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Description</h3>
                        </div>
                        <div class="card-body">
                            <p class="mb-0">@Model.Description</p>
                        </div>
                    </div>
                }

                <!-- Workaround -->
                @if (!string.IsNullOrEmpty(Model.Workaround))
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Workaround</h3>
                        </div>
                        <div class="card-body">
                            <p class="mb-0">@Model.Workaround</p>
                        </div>
                    </div>
                }

                <!-- Resolution summary -->
                @if (!string.IsNullOrEmpty(Model.ResolutionSummary))
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Resolution summary</h3>
                        </div>
                        <div class="card-body">
                            <p class="mb-0">@Model.ResolutionSummary</p>
                        </div>
                    </div>
                }

                <!-- Related resolution actions -->
                @if (Model.IssueActions != null && Model.IssueActions.Any())
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Related resolution actions</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th style="width: 150px;">Assigned to</th>
                                        <th style="width: 120px;">Status</th>
                                        <th style="width: 120px;">Due date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ia in Model.IssueActions)
                                    {
                                        var actionOverdue = ia.Action.DueDate.HasValue && 
                                                          ia.Action.DueDate.Value.Date < DateTime.Today &&
                                                          ia.Action.Status != "done" && ia.Action.Status != "cancelled";
                                        <tr class="@(actionOverdue ? "table-danger" : "")">
                                            <td><a asp-controller="Action" asp-action="Details" asp-route-id="@ia.Action.Id">@ia.Action.Title</a></td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(ia.Action.AssignedToEmail))
                                                {
                                                    <small><a href="mailto:@ia.Action.AssignedToEmail">@ia.Action.AssignedToEmail</a></small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @switch (ia.Action.Status)
                                                {
                                                    case "done":
                                                        <span class="badge badge-success">Done</span>
                                                        break;
                                                    case "in_progress":
                                                        <span class="badge badge-primary">In progress</span>
                                                        break;
                                                    case "blocked":
                                                        <span class="badge badge-danger">Blocked</span>
                                                        break;
                                                    case "not_started":
                                                        <span class="badge badge-secondary">Not started</span>
                                                        break;
                                                    case "cancelled":
                                                        <span class="badge badge-dark">Cancelled</span>
                                                        break;
                                                    default:
                                                        <span class="badge badge-secondary">@ia.Action.Status</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                @if (ia.Action.DueDate.HasValue)
                                                {
                                                    <span class="@(actionOverdue ? "text-danger" : "")">
                                                        @ia.Action.DueDate.Value.ToString("dd MMM yyyy")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <!-- Comments Section -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Comments</h3>
                    </div>
                    <div class="card-body">
                        <div id="commentsContainer">
                            <p class="text-muted text-center">Loading comments...</p>
                        </div>
                        
                        <hr />
                        
                        <div class="form-group mb-0">
                            <label for="newComment">Add a comment</label>
                            <textarea id="newComment" class="form-control" rows="3" placeholder="Enter your comment..."></textarea>
                            <button type="button" class="btn btn-primary mt-2" id="addCommentBtn">Add comment</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-xxl-3 col-xl-3 col-lg-4 col-md-12 col-sm-12 col-12">
                <!-- Status & Owner -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Details</h3>
                    </div>
                    <div class="card-body">
                        <dl class="mb-0">
                            <dt>Status</dt>
                            <dd class="mb-3">
                                @switch (Model.Status)
                                {
                                    case "open":
                                        <span class="badge badge-danger">Open</span>
                                        break;
                                    case "in_progress":
                                        <span class="badge badge-primary">In progress</span>
                                        break;
                                    case "blocked":
                                        <span class="badge badge-danger">Blocked</span>
                                        break;
                                    case "resolved":
                                        <span class="badge badge-success">Resolved</span>
                                        break;
                                    case "closed":
                                        <span class="badge badge-secondary">Closed</span>
                                        break;
                                    default:
                                        <span class="badge badge-secondary">@Model.Status</span>
                                        break;
                                }
                            </dd>

                            <dt>Severity</dt>
                            <dd class="mb-3">
                                @switch (Model.Severity)
                                {
                                    case "critical":
                                        <span class="badge badge-danger">Critical</span>
                                        break;
                                    case "high":
                                        <span class="badge badge-warning">High</span>
                                        break;
                                    case "medium":
                                        <span class="badge badge-info">Medium</span>
                                        break;
                                    case "low":
                                        <span class="badge badge-secondary">Low</span>
                                        break;
                                    default:
                                        <span class="badge badge-secondary">@Model.Severity</span>
                                        break;
                                }
                            </dd>

                            <dt>Priority</dt>
                            <dd class="mb-3">
                                @switch (Model.Priority)
                                {
                                    case "high":
                                        <span class="badge badge-danger">High</span>
                                        break;
                                    case "medium":
                                        <span class="badge badge-warning">Medium</span>
                                        break;
                                    case "low":
                                        <span class="badge badge-info">Low</span>
                                        break;
                                    default:
                                        <span class="text-muted">@(Model.Priority ?? "Not set")</span>
                                        break;
                                }
                            </dd>

                            <dt>Blocked</dt>
                            <dd class="mb-3">
                                @if (Model.BlockedFlag)
                                {
                                    <span class="badge badge-danger">Yes</span>
                                }
                                else
                                {
                                    <span class="text-muted">No</span>
                                }
                            </dd>

                            <dt>Owner</dt>
                            <dd class="mb-3">
                                @if (Model.OwnerUser != null)
                                {
                                    <div>@Model.OwnerUser.Name</div>
                                    @if (!string.IsNullOrEmpty(Model.OwnerUser.Email))
                                    {
                                        <small><a href="mailto:@Model.OwnerUser.Email">@Model.OwnerUser.Email</a></small>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Unassigned</span>
                                }
                            </dd>

                            <dt>Business area</dt>
                            <dd class="mb-3">
                                @if (!string.IsNullOrEmpty(Model.BusinessArea))
                                {
                                    <a asp-action="Index" asp-route-businessArea="@Model.BusinessArea">@Model.BusinessArea</a>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </dd>

                            <dt>Strategic objective</dt>
                            <dd class="mb-3">
                                @if (Model.Objective != null)
                                {
                                    <a asp-action="Index" asp-route-objectiveId="@Model.Objective.Id">@Model.Objective.Title</a>
                                }
                                else
                                {
                                    <span class="text-muted">Not linked</span>
                                }
                            </dd>

                            <dt>Category</dt>
                            <dd class="mb-0">@(Model.Category ?? "-")</dd>
                        </dl>
                    </div>
                </div>

                <!-- Dates -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Timeline</h3>
                    </div>
                    <div class="card-body">
                        <dl class="mb-0">
                            <dt>Detected</dt>
                            <dd class="mb-3">@Model.DetectedDate.ToString("dd MMM yyyy")</dd>

                            <dt>Target resolution</dt>
                            <dd class="mb-3">
                                @if (Model.TargetResolutionDate.HasValue)
                                {
                                    <span class="@(isOverdue ? "text-danger" : "")">
                                        @Model.TargetResolutionDate.Value.ToString("dd MMM yyyy")
                                    </span>
                                    @if (isOverdue)
                                    {
                                        var daysOverdue = (DateTime.Today - Model.TargetResolutionDate.Value.Date).Days;
                                        <br><span class="text-danger small">@daysOverdue days overdue</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </dd>

                            <dt>Closed</dt>
                            <dd class="mb-3">@(Model.ClosedDate?.ToString("dd MMM yyyy") ?? "-")</dd>

                            <dt>Created</dt>
                            <dd class="mb-3">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</dd>

                            <dt>Last updated</dt>
                            <dd class="mb-0">@Model.UpdatedAt.ToString("dd MMM yyyy HH:mm")</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@Html.AntiForgeryToken()

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            loadComments();
            
            function loadComments() {
                $.ajax({
                    url: '/comments/Issue/@Model.Id',
                    type: 'GET',
                    success: function(data) {
                        displayComments(data);
                    },
                    error: function() {
                        $('#commentsContainer').html('<p class="text-danger">Failed to load comments</p>');
                    }
                });
            }
            
            function displayComments(comments) {
                if (!comments || comments.length === 0) {
                    $('#commentsContainer').html('<p class="text-muted">No comments yet</p>');
                    return;
                }
                
                var html = '';
                comments.forEach(function(comment) {
                    var date = new Date(comment.createdAt);
                    var dateStr = date.toLocaleString('en-GB', { 
                        day: 'numeric', 
                        month: 'short', 
                        year: 'numeric', 
                        hour: '2-digit', 
                        minute: '2-digit' 
                    });
                    
                    html += '<div class="border-bottom pb-3 mb-3">';
                    html += '<div class="d-flex justify-content-between mb-2">';
                    html += '<strong>' + (comment.createdByUser ? comment.createdByUser.name : 'Unknown') + '</strong>';
                    html += '<small class="text-muted">' + dateStr + '</small>';
                    html += '</div>';
                    html += '<p class="mb-0">' + comment.commentText.replace(/\n/g, '<br>') + '</p>';
                    html += '</div>';
                });
                
                $('#commentsContainer').html(html);
            }
            
            $('#addCommentBtn').click(function() {
                var commentText = $('#newComment').val().trim();
                
                if (!commentText) {
                    alert('Please enter a comment');
                    return;
                }
                
                $.ajax({
                    url: '/comments',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        entityType: 'Issue',
                        entityId: @Model.Id,
                        commentText: commentText
                    }),
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function() {
                        $('#newComment').val('');
                        loadComments();
                    },
                    error: function() {
                        alert('Failed to add comment');
                    }
                });
            });
        });
    </script>
}
