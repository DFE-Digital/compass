@model Compass.Models.Issue
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = string.IsNullOrWhiteSpace(Model.Title) ? "Issue details" : $"Issue – {Model.Title}";

    var products = ViewBag.Products as List<Compass.Models.ProductDto> ?? new List<Compass.Models.ProductDto>();
    var fipsBaseUrl = Configuration["fipsProduct:baseUrl"] ?? "https://find-products-services-test.azurewebsites.net/";
    var productUrl = !string.IsNullOrWhiteSpace(Model.FipsId)
        ? $"{fipsBaseUrl.TrimEnd('/')}/product/{Model.FipsId}"
        : null;
    var linkedProduct = !string.IsNullOrWhiteSpace(Model.FipsId)
        ? products.FirstOrDefault(p => p.FipsId == Model.FipsId)
        : null;

    var hasProject = Model.Project != null;
    var hasProduct = !string.IsNullOrWhiteSpace(Model.FipsId);
    var backLinkUrl = hasProject
        ? Url.Action("Details", "Project", new { id = Model.ProjectId, tab = "issues" })
        : Url.Action("Index");
    var backLinkText = hasProject ? "Back to work item" : "Back to issues";

    var textInfo = System.Globalization.CultureInfo.CurrentCulture.TextInfo;
    string ToTitle(string? value) => string.IsNullOrWhiteSpace(value)
        ? "Not set"
        : textInfo.ToTitleCase(value.Replace("_", " "));

    var statusLabel = ToTitle(Model.Status);
    var severityLabel = ToTitle(Model.Severity);
    var priorityLabel = ToTitle(Model.Priority);
    var blockedLabel = Model.BlockedFlag ? "Yes" : "No";

    var statusBoxClass = Model.Status switch
    {
        "resolved" => "bg-success",
        "closed" => "bg-secondary",
        "blocked" => "bg-danger",
        "in_progress" => "bg-info",
        _ => "bg-warning"
    };

    var statusBadgeClass = Model.Status switch
    {
        "open" => "badge-danger",
        "blocked" => "badge-danger",
        "in_progress" => "badge-primary",
        "resolved" => "badge-success",
        "closed" => "badge-secondary",
        _ => "badge-secondary"
    };

    var severityBoxClass = Model.Severity switch
    {
        "critical" => "bg-danger",
        "high" => "bg-warning",
        "medium" => "bg-info",
        "low" => "bg-secondary",
        _ => "bg-secondary"
    };

    var priorityBoxClass = Model.Priority switch
    {
        "high" => "bg-danger",
        "medium" => "bg-warning",
        "low" => "bg-info",
        _ => "bg-secondary"
    };

    var isOverdue = Model.TargetResolutionDate.HasValue &&
                    Model.TargetResolutionDate.Value.Date < DateTime.Today &&
                    Model.Status != "resolved" && Model.Status != "closed";

    var targetResolutionLabel = Model.TargetResolutionDate.HasValue
        ? Model.TargetResolutionDate.Value.ToString("d MMMM yyyy")
        : "Not set";
    var targetBoxClass = Model.TargetResolutionDate.HasValue
        ? (isOverdue ? "bg-danger" : "bg-primary")
        : "bg-secondary";

    var detectedDateLabel = Model.DetectedDate.ToString("d MMMM yyyy");
    var createdAtLabel = Model.CreatedAt.ToString("d MMMM yyyy HH:mm");
    var updatedAtLabel = Model.UpdatedAt.ToString("d MMMM yyyy HH:mm");
    var closedDateLabel = Model.ClosedDate?.ToString("d MMMM yyyy") ?? "-";

    Compass.ViewModels.ProjectSummaryViewModel? projectSummary = null;
    if (Model.Project != null)
    {
        projectSummary = new Compass.ViewModels.ProjectSummaryViewModel
        {
            Id = Model.Project.Id,
            Title = Model.Project.Title,
            ProjectCode = Model.Project.ProjectCode,
            Status = Model.Project.Status ?? string.Empty,
            RagStatus = Model.Project.RagStatus,
            Phase = Model.Project.Phase,
            BusinessArea = Model.Project.BusinessArea,
            StartDate = Model.Project.StartDate,
            TargetDeliveryDate = Model.Project.TargetDeliveryDate
        };
    }
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-3">
            <div class="col-12">
                <a class="btn btn-link px-0 mb-2" href="@backLinkUrl" aria-label="@backLinkText">
                    <i class="fas fa-arrow-left mr-2" aria-hidden="true"></i>@backLinkText
                </a>
                <h1 class="m-0">@Model.Title</h1>
                <p class="text-muted mb-0">Issue #@Model.Id</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row mb-4">
            <div class="col-lg-3 col-md-6 col-sm-12 mb-3 mb-lg-0">
                <div class="small-box @statusBoxClass">
                    <div class="inner">
                        <h3 class="text-capitalize">@statusLabel</h3>
                        <p>Status</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 col-sm-12 mb-3 mb-lg-0">
                <div class="small-box @severityBoxClass">
                    <div class="inner">
                        <h3 class="text-capitalize">@severityLabel</h3>
                        <p>Severity</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 col-sm-12 mb-3 mb-lg-0">
                <div class="small-box @targetBoxClass">
                    <div class="inner">
                        <h3>@targetResolutionLabel</h3>
                        <p>Target resolution</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 col-sm-12">
                <div class="small-box @priorityBoxClass">
                    <div class="inner">
                        <h3 class="text-capitalize">@priorityLabel</h3>
                        <p>Priority</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row align-items-center mb-4">
            <div class="col-12 d-flex flex-wrap gap-2">
                <a class="btn btn-primary mr-2 mb-2" asp-action="Edit" asp-route-id="@Model.Id">Edit issue</a>
                <a class="btn btn-outline-primary mr-2 mb-2" asp-controller="Project" asp-action="CreateDecision" asp-route-projectId="@Model.ProjectId" asp-route-issueId="@Model.Id">Record decision</a>
                <a class="btn btn-outline-primary mr-2 mb-2" asp-controller="Action" asp-action="Create" asp-route-issueId="@Model.Id">Add resolution action</a>
                <a class="btn btn-outline-danger mb-2" asp-action="Delete" asp-route-id="@Model.Id">Delete issue</a>
            </div>
        </div>

        <div class="row">
            <div class="col-xxl-3 col-xl-3 col-lg-4 col-md-5 mb-4">
                @if (projectSummary != null)
                {
                    <partial name="_ProjectSummarySidebar" model="projectSummary" />
                }
                else if (hasProduct)
                {
                    <div class="card mb-4">
                        <div class="card-header">
                            <h3 class="card-title mb-0">Linked product</h3>
                        </div>
                        <div class="card-body">
                            <dl class="definition-list mb-0">
                                <div class="definition-item">
                                    <dt>Title</dt>
                                    <dd>
                                        @if (linkedProduct != null)
                                        {
                                            @linkedProduct.Title
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not available</span>
                                        }
                                    </dd>
                                </div>
                                <div class="definition-item">
                                    <dt>FIPS ID</dt>
                                    <dd>
                                        @if (productUrl != null)
                                        {
                                            <a href="@productUrl" target="_blank" rel="noopener noreferrer">@Model.FipsId</a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">@Model.FipsId</span>
                                        }
                                    </dd>
                                </div>
                                <div class="definition-item">
                                    <dt>State</dt>
                                    <dd>@(linkedProduct?.State ?? "Unknown")</dd>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(linkedProduct?.Phase))
                                {
                                    <div class="definition-item">
                                        <dt>Phase</dt>
                                        <dd>@linkedProduct.Phase</dd>
                                    </div>
                                }
                                @if (linkedProduct?.CategoryValues?.Any() == true)
                                {
                                    var categories = linkedProduct.CategoryValues
                                        .Where(cv => !string.IsNullOrWhiteSpace(cv.Name))
                                        .OrderBy(cv => cv.SortOrder)
                                        .Select(cv => cv.Name)
                                        .ToList();
                                    if (categories.Any())
                                    {
                                        <div class="definition-item">
                                            <dt>Categories</dt>
                                            <dd>
                                                <ul class="list-unstyled mb-0">
                                                    @foreach (var category in categories.Take(5))
                                                    {
                                                        <li><span class="badge badge-light text-uppercase">@category</span></li>
                                                    }
                                                </ul>
                                            </dd>
                                        </div>
                                    }
                                }
                                @if (linkedProduct?.ProductContacts?.Any() == true)
                                {
                                    var contact = linkedProduct.ProductContacts.First();
                                    <div class="definition-item">
                                        <dt>Primary contact</dt>
                                        <dd>
                                            <div>@(contact.ContactName ?? contact.LegacyName ?? "Not set")</div>
                                            @if (!string.IsNullOrWhiteSpace(contact.ContactEmail))
                                            {
                                                <small><a href="mailto:@contact.ContactEmail">@contact.ContactEmail</a></small>
                                            }
                                        </dd>
                                    </div>
                                }
                            </dl>
                        </div>
                    </div>
                }

                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">People & links</h3>
                    </div>
                    <div class="card-body">
                        <dl class="definition-list mb-0">
                            <div class="definition-item">
                                <dt>Assigned to</dt>
                                <dd>
                                    <div class="definition-value">
                                        @if (Model.OwnerUser != null)
                                        {
                                            <div>@Model.OwnerUser.Name</div>
                                            @if (!string.IsNullOrEmpty(Model.OwnerUser.Email))
                                            {
                                                <small><a href="mailto:@Model.OwnerUser.Email">@Model.OwnerUser.Email</a></small>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">Unassigned</span>
                                        }
                                    </div>
                                </dd>
                            </div>
                            <div class="definition-item">
                                <dt>Business area</dt>
                                <dd>@(string.IsNullOrWhiteSpace(Model.BusinessArea) ? "Not set" : Model.BusinessArea)</dd>
                            </div>
                            <div class="definition-item">
                                <dt>Strategic objective</dt>
                                <dd>
                                    @if (Model.Objective != null)
                                    {
                                        <a asp-action="Index" asp-route-objectiveId="@Model.Objective.Id">@Model.Objective.Title</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not linked</span>
                                    }
                                </dd>
                            </div>
                            <div class="definition-item">
                                <dt>Source</dt>
                                <dd>
                                    @if (!string.IsNullOrWhiteSpace(Model.SourceType) || !string.IsNullOrWhiteSpace(Model.SourceReference))
                                    {
                                        <div><strong>@(Model.SourceType ?? "Source"):</strong> @(Model.SourceReference ?? "Not specified")</div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not recorded</span>
                                    }
                                </dd>
                            </div>
                            <div class="definition-item">
                                <dt>Blocked</dt>
                                <dd>@blockedLabel</dd>
                            </div>
                        </dl>
                    </div>
                </div>
            </div>

            <div class="col-xxl-9 col-xl-9 col-lg-8 col-md-7 col-sm-12 col-12">
                <div class="card mb-4" id="details">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Issue information</h3>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-borderless mb-0 issue-summary">
                            <tbody>
                                <tr>
                                    <td class="summary-label"><strong>Title</strong></td>
                                    <td class="summary-value">
                                        @(string.IsNullOrWhiteSpace(Model.Title) ? "Not set" : Model.Title)
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Status</strong></td>
                                    <td class="summary-value">
                                        <span class="badge badge-pill @statusBadgeClass">@statusLabel</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Severity</strong></td>
                                    <td class="summary-value">
                                        <span class="badge badge-light text-uppercase">@severityLabel</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Priority</strong></td>
                                    <td class="summary-value">
                                        <span class="badge badge-light text-uppercase">@priorityLabel</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Category</strong></td>
                                    <td class="summary-value">@(string.IsNullOrWhiteSpace(Model.Category) ? "-" : Model.Category)</td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Target resolution</strong></td>
                                    <td class="summary-value">
                                        @if (Model.TargetResolutionDate.HasValue)
                                        {
                                            <span class="@(isOverdue ? "text-danger font-weight-bold" : string.Empty)">@targetResolutionLabel</span>
                                            @if (isOverdue)
                                            {
                                                var daysOverdue = (DateTime.Today - Model.TargetResolutionDate.Value.Date).Days;
                                                <span class="d-block text-danger small">@daysOverdue day@(daysOverdue == 1 ? string.Empty : "s") overdue</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not set</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Linked project</strong></td>
                                    <td class="summary-value">
                                        @if (Model.Project != null)
                                        {
                                            <a asp-controller="Project" asp-action="Details" asp-route-id="@Model.ProjectId" asp-route-tab="issues">@Model.Project.Title</a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not linked</span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Linked product</strong></td>
                                    <td class="summary-value">
                                        @if (!string.IsNullOrWhiteSpace(Model.FipsId) && productUrl != null)
                                        {
                                            if (linkedProduct != null)
                                            {
                                                <a href="@productUrl" target="_blank" rel="noopener noreferrer">@linkedProduct.Title (@Model.FipsId)</a>
                                            }
                                            else
                                            {
                                                <a href="@productUrl" target="_blank" rel="noopener noreferrer">@Model.FipsId</a>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not linked</span>
                                        }
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h3 class="card-title mb-0">Narrative</h3>
                    </div>
                    <div class="card-body">
                        <div class="mb-4">
                            <h4 class="h6 text-uppercase text-muted">Description</h4>
                            <p class="mb-0">@(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)</p>
                        </div>
                        <div class="mb-4">
                            <h4 class="h6 text-uppercase text-muted">Workaround</h4>
                            <p class="mb-0">@(string.IsNullOrEmpty(Model.Workaround) ? "No workaround recorded." : Model.Workaround)</p>
                        </div>
                        <div class="mb-0">
                            <h4 class="h6 text-uppercase text-muted">Resolution summary</h4>
                            <p class="mb-0">@(string.IsNullOrEmpty(Model.ResolutionSummary) ? "No resolution summary recorded." : Model.ResolutionSummary)</p>
                        </div>
                    </div>
                </div>

                @if (Model.IssueActions != null && Model.IssueActions.Any())
                {
                    <div class="card mb-4">
                        <div class="card-header">
                            <h3 class="card-title mb-0">Related resolution actions</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th style="width: 160px;">Assigned to</th>
                                        <th style="width: 140px;">Status</th>
                                        <th style="width: 160px;">Due date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ia in Model.IssueActions)
                                    {
                                        var actionOverdue = ia.Action.DueDate.HasValue &&
                                                          ia.Action.DueDate.Value.Date < DateTime.Today &&
                                                          ia.Action.Status != "done" && ia.Action.Status != "cancelled";
                                        <tr class="@(actionOverdue ? "table-danger" : string.Empty)">
                                            <td><a asp-controller="Action" asp-action="Details" asp-route-id="@ia.Action.Id">@ia.Action.Title</a></td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(ia.Action.AssignedToEmail))
                                                {
                                                    <small><a href="mailto:@ia.Action.AssignedToEmail">@ia.Action.AssignedToEmail</a></small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @switch (ia.Action.Status)
                                                {
                                                    case "done":
                                                        <span class="badge badge-success">Done</span>
                                                        break;
                                                    case "in_progress":
                                                        <span class="badge badge-primary">In progress</span>
                                                        break;
                                                    case "blocked":
                                                        <span class="badge badge-danger">Blocked</span>
                                                        break;
                                                    case "not_started":
                                                        <span class="badge badge-secondary">Not started</span>
                                                        break;
                                                    case "cancelled":
                                                        <span class="badge badge-dark">Cancelled</span>
                                                        break;
                                                    default:
                                                        <span class="badge badge-secondary">@ToTitle(ia.Action.Status)</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                @if (ia.Action.DueDate.HasValue)
                                                {
                                                    <span class="@(actionOverdue ? "text-danger font-weight-semibold" : string.Empty)">
                                                        @ia.Action.DueDate.Value.ToString("d MMMM yyyy")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Not set</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Timeline</h3>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Detected</dt>
                            <dd class="col-sm-8 mb-3">@detectedDateLabel</dd>

                            <dt class="col-sm-4">Target resolution</dt>
                            <dd class="col-sm-8 mb-3">
                                @if (Model.TargetResolutionDate.HasValue)
                                {
                                    <span class="@(isOverdue ? "text-danger font-weight-bold" : string.Empty)">@targetResolutionLabel</span>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </dd>

                            <dt class="col-sm-4">Closed</dt>
                            <dd class="col-sm-8 mb-3">@closedDateLabel</dd>

                            <dt class="col-sm-4">Created</dt>
                            <dd class="col-sm-8 mb-3">@createdAtLabel</dd>

                            <dt class="col-sm-4">Last updated</dt>
                            <dd class="col-sm-8 mb-0">@updatedAtLabel</dd>
                        </dl>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Comments</h3>
                    </div>
                    <div class="card-body">
                        <div id="commentsContainer">
                            <p class="text-muted text-center">Loading comments...</p>
                        </div>
                        <hr />
                        <div class="form-group mb-0">
                            <label for="newComment">Add a comment</label>
                            <textarea id="newComment" class="form-control" rows="3" placeholder="Enter your comment..."></textarea>
                            <button type="button" class="btn btn-primary mt-2" id="addCommentBtn">Add comment</button>
                            <div id="commentError" class="text-danger mt-2 d-none" role="alert"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@Html.AntiForgeryToken()

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            const commentsContainer = $('#commentsContainer');
            const newCommentField = $('#newComment');
            const commentError = $('#commentError');

            loadComments();
            
            function showCommentError(message) {
                commentError.text(message).removeClass('d-none');
            }

            function clearCommentError() {
                commentError.text('').addClass('d-none');
            }

            function loadComments() {
                $.ajax({
                    url: '/api/comments/Issue/@Model.Id',
                    type: 'GET',
                    success: function(data) {
                        clearCommentError();
                        displayComments(data);
                    },
                    error: function() {
                        commentsContainer.html('<p class="text-danger mb-0" role="alert">We could not load comments. Please try again.</p>');
                    }
                });
            }
            
            function displayComments(comments) {
                if (!comments || comments.length === 0) {
                    commentsContainer.html('<p class="text-muted mb-0">No comments yet</p>');
                    return;
                }
                
                var html = '';
                comments.forEach(function(comment) {
                    var date = new Date(comment.createdAt);
                    var dateStr = date.toLocaleString('en-GB', { 
                        day: 'numeric', 
                        month: 'short', 
                        year: 'numeric', 
                        hour: '2-digit', 
                        minute: '2-digit' 
                    });
                    
                    html += '<div class="border-bottom pb-3 mb-3">';
                    html += '<div class="d-flex justify-content-between mb-2">';
                    html += '<strong>' + (comment.createdByUser ? comment.createdByUser.name : 'Unknown') + '</strong>';
                    html += '<small class="text-muted">' + dateStr + '</small>';
                    html += '</div>';
                    html += '<p class="mb-0">' + comment.commentText.replace(/\n/g, '<br>') + '</p>';
                    html += '</div>';
                });
                
                commentsContainer.html(html);
            }
            
            $('#addCommentBtn').click(function() {
                clearCommentError();
                var commentText = newCommentField.val().trim();
                
                if (!commentText) {
                    showCommentError('Enter a comment before submitting.');
                    newCommentField.focus();
                    return;
                }
                
                $.ajax({
                    url: '/api/comments',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        entityType: 'Issue',
                        entityId: @Model.Id,
                        commentText: commentText
                    }),
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function() {
                        newCommentField.val('');
                        loadComments();
                    },
                    error: function() {
                        showCommentError('We could not add your comment. Please try again.');
                    }
                });
            });
        });
    </script>
}
