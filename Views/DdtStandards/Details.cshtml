                        {
                                            <br />
                                            <small class="text-muted">@(relatedStandard.Summary.Length > 80 ? relatedStandard.Summary.Substring(0, 80) + "..." : relatedStandard.Summary)</small>
                                        }
                                        <div class="mt-2">
                                            <small class="text-muted">DDT-@relatedStandard.Id</small>
                                            @if (!string.IsNullOrWhiteSpace(relatedStandard.LegacyReference))
                                            {
                                                <small class="text-muted"> · @relatedStandard.LegacyReference</small>
                                            }
                                        </div>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- Approve Modal -->
@if (Model.Stage == "For Approval" && (ViewBag.IsStandardsManager as bool? ?? false))
{
    <div class="modal fade" id="approveModal" tabindex="-1" role="dialog" aria-labelledby="approveModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="approveModalLabel">
                        <i class="fas fa-check-circle mr-2"></i>Approve Standard
                    </h5>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <form asp-action="Approve" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <p>Are you sure you want to approve this standard?</p>
                        <p class="mb-3">Once approved, the standard will move to <strong>"Awaiting Publication"</strong> status and can be published by an Administrator.</p>
                        <div class="form-group">
                            <label for="approveComment">Approval Comment (optional):</label>
                            <textarea class="form-control" id="approveComment" name="comment" rows="3" placeholder="Add any comments about this approval..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-check-circle mr-2"></i>Approve Standard
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<!-- Reject Modal -->
@if (Model.Stage == "For Approval" && (ViewBag.IsStandardsManager as bool? ?? false))
{
    <div class="modal fade" id="rejectModal" tabindex="-1" role="dialog" aria-labelledby="rejectModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="rejectModalLabel">
                        <i class="fas fa-times-circle mr-2"></i>Reject Standard
                    </h5>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <form asp-action="Reject" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="modal-body">
                        <p>Are you sure you want to reject this standard?</p>
                        <p class="mb-3">Once rejected, the standard will be returned to <strong>"Draft"</strong> status with your rejection reason, allowing the owner to revise and resubmit.</p>
                        <div class="form-group">
                            <label for="rejectReason">Rejection Reason <span class="text-danger">*</span>:</label>
                            <textarea class="form-control" id="rejectReason" name="reason" rows="4" placeholder="Please provide a clear reason for rejection..." required></textarea>
                            <small class="form-text text-muted">This reason will be shown to the standard owner and will help them understand what needs to be changed.</small>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-times-circle mr-2"></i>Reject Standard
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}


@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Initialize sortable tables
            $('.sortable-table').each(function() {
                initializeSortableTable($(this));
            });
            
            function initializeSortableTable(table) {
                var currentSort = { column: null, direction: 'asc' };
                var tableId = table.attr('id');

                table.find('.sortable').on('click keypress', function(e) {
                    if (e.type === 'keypress' && e.which !== 13 && e.which !== 32) {
                        return;
                    }
                    
                    var column = $(this).data('column');
                    var direction = 'asc';
                    
                    if (currentSort.column === column && currentSort.direction === 'asc') {
                        direction = 'desc';
                    }
                    
                    sortTable(table, column, direction, tableId);
                    currentSort = { column: column, direction: direction };
                });

                function sortTable(table, column, direction, tableId) {
                    var tbody = table.find('tbody');
                    var rows = tbody.find('tr').toArray();
                    
                    rows.sort(function(a, b) {
                        var aVal, bVal;
                        var colIndex = table.find('thead th[data-column="' + column + '"]').index();
                        
                        // Get text value, handling nested elements
                        var aText = $(a).find('td').eq(colIndex).text().trim().toLowerCase();
                        var bText = $(b).find('td').eq(colIndex).text().trim().toLowerCase();
                        
                        // For email column, extract email from link
                        if (column === 'Email') {
                            var aEmail = $(a).find('td').eq(colIndex).find('a').attr('href') || aText;
                            var bEmail = $(b).find('td').eq(colIndex).find('a').attr('href') || bText;
                            aVal = aEmail.replace('mailto:', '').toLowerCase();
                            bVal = bEmail.replace('mailto:', '').toLowerCase();
                        } else {
                            aVal = aText;
                            bVal = bText;
                        }
                        
                        if (direction === 'asc') {
                            return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                        } else {
                            return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                        }
                    });
                    
                    tbody.empty();
                    rows.forEach(function(row) {
                        tbody.append(row);
                    });
                    
                    updateSortIcons(table, column, direction);
                }

                function updateSortIcons(table, column, direction) {
                    table.find('.sortable .fa-sort-up, .sortable .fa-sort-down').removeClass('fa-sort-up fa-sort-down').addClass('fa-sort');
                    var header = table.find('.sortable[data-column="' + column + '"]');
                    var iconClass = direction === 'asc' ? 'fa-sort-up' : 'fa-sort-down';
                    header.find('i').removeClass('fa-sort').addClass(iconClass);
                }
            }
        });
    </script>
}
