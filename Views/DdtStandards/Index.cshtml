@model Compass.ViewModels.DdtStandardsManageViewModel

@{
    ViewData["Title"] = "Manage DDT Standards";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Manage Standards</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h1 class="mb-0">Manage DDT Standards</h1>
                    <a href="@Url.Action("Create", "DdtStandards")" class="btn btn-primary">
                        <i class="fas fa-plus mr-2"></i>Create Standard
                    </a>
                </div>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <!-- Left Column: Navigation -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <!-- Navigation Card -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title">Navigation</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <a href="@Url.Action("Index", new { view = "drafts", search = Model.CurrentSearch, category = Model.CurrentCategory, creator = Model.CurrentCreator, owner = Model.CurrentOwner, contact = Model.CurrentContact, legalStandard = Model.CurrentLegalStandard })"
                               class="list-group-item list-group-item-action @(Model.ActiveView == "drafts" ? "active" : "") d-flex justify-content-between align-items-center">
                                <span>Drafts</span>
                                <span class="badge badge-secondary badge-pill">@(Model.MyDrafts.Count + Model.AllDrafts.Count)</span>
                            </a>
                            <a href="@Url.Action("Index", new { view = "in-review", search = Model.CurrentSearch, category = Model.CurrentCategory, creator = Model.CurrentCreator, owner = Model.CurrentOwner, contact = Model.CurrentContact, legalStandard = Model.CurrentLegalStandard })"
                               class="list-group-item list-group-item-action @(Model.ActiveView == "in-review" ? "active" : "") d-flex justify-content-between align-items-center">
                                <span>In review</span>
                                <span class="badge badge-secondary badge-pill">@(Model.MyInReview.Count + Model.AllInReview.Count)</span>
                            </a>
                            <a href="@Url.Action("Index", new { view = "for-approval", search = Model.CurrentSearch, category = Model.CurrentCategory, creator = Model.CurrentCreator, owner = Model.CurrentOwner, contact = Model.CurrentContact, legalStandard = Model.CurrentLegalStandard })"
                               class="list-group-item list-group-item-action @(Model.ActiveView == "for-approval" ? "active" : "") d-flex justify-content-between align-items-center">
                                <span>For approval</span>
                                <span class="badge badge-secondary badge-pill">@(Model.MyForApproval.Count + Model.AllForApproval.Count)</span>
                            </a>
                            <a href="@Url.Action("Index", new { view = "published", search = Model.CurrentSearch, category = Model.CurrentCategory, creator = Model.CurrentCreator, owner = Model.CurrentOwner, contact = Model.CurrentContact, legalStandard = Model.CurrentLegalStandard })"
                               class="list-group-item list-group-item-action @(Model.ActiveView == "published" ? "active" : "") d-flex justify-content-between align-items-center">
                                <span>Published</span>
                                <span class="badge badge-secondary badge-pill">@(Model.MyPublished.Count + Model.AllPublished.Count)</span>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Filters Card -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Filters</h3>
                    </div>
                    <div class="card-body">
                        <form method="get" id="filterForm">
                            <input type="hidden" name="view" value="@Model.ActiveView" />
                            <div class="form-group">
                                <label>Search</label>
                                <input type="text" name="search" class="form-control form-control-sm" placeholder="Search..." value="@Model.CurrentSearch" />
                            </div>

                            <div class="form-group">
                                <label>Category</label>
                                <select name="category" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @if (Model.Categories != null)
                                    {
                                        @foreach (var cat in Model.Categories)
                                        {
                                            <option value="@cat" selected="@(Model.CurrentCategory == cat)">@cat</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Creator</label>
                                <select name="creator" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @if (Model.Creators != null)
                                    {
                                        @foreach (var creator in Model.Creators)
                                        {
                                            <option value="@creator.Id" selected="@(Model.CurrentCreator == creator.Id)">@creator.Name</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Owner</label>
                                <select name="owner" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @if (Model.Owners != null)
                                    {
                                        @foreach (var owner in Model.Owners)
                                        {
                                            <option value="@owner.Id" selected="@(Model.CurrentOwner == owner.Id)">@owner.Name</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Contact</label>
                                <select name="contact" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @if (Model.Contacts != null)
                                    {
                                        @foreach (var contact in Model.Contacts)
                                        {
                                            <option value="@contact.Id" selected="@(Model.CurrentContact == contact.Id)">@contact.Name</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Legal Standard</label>
                                <select name="legalStandard" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    <option value="true" selected="@(Model.CurrentLegalStandard == true)">Yes</option>
                                    <option value="false" selected="@(Model.CurrentLegalStandard == false)">No</option>
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary btn-sm btn-block">Apply Filters</button>
                            <a href="@Url.Action("Index", new { view = Model.ActiveView })" class="btn btn-secondary btn-sm btn-block">Clear</a>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Column: Standards List -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                @if (Model.ActiveView == "drafts")
                {
                    <div class="mb-3">
                        @await Html.PartialAsync("_StandardsCard", new { Title = "My drafts", Standards = Model.MyDrafts, ShowCreatedBy = false })
                    </div>
                    <div class="mb-3">
                        @await Html.PartialAsync("_StandardsCard", new { Title = "All drafts", Standards = Model.AllDrafts, ShowCreatedBy = true })
                    </div>
                }
                else if (Model.ActiveView == "in-review")
                {
                    <div class="mb-3">
                        @await Html.PartialAsync("_StandardsCard", new { Title = "My in review", Standards = Model.MyInReview, ShowCreatedBy = false })
                    </div>
                    <div class="mb-3">
                        @await Html.PartialAsync("_StandardsCard", new { Title = "All in review", Standards = Model.AllInReview, ShowCreatedBy = true })
                    </div>
                }
                else if (Model.ActiveView == "for-approval")
                {
                    <div class="mb-3">
                        @await Html.PartialAsync("_StandardsCard", new { Title = "My for approval", Standards = Model.MyForApproval, ShowCreatedBy = false })
                    </div>
                    <div class="mb-3">
                        @await Html.PartialAsync("_StandardsCard", new { Title = "All for approval", Standards = Model.AllForApproval, ShowCreatedBy = true })
                    </div>
                }
                else if (Model.ActiveView == "published")
                {
                    <div class="mb-3">
                        @await Html.PartialAsync("_StandardsCard", new { Title = "My published", Standards = Model.MyPublished, ShowCreatedBy = false })
                    </div>
                    <div class="mb-3">
                        @await Html.PartialAsync("_StandardsCard", new { Title = "All published", Standards = Model.AllPublished, ShowCreatedBy = true })
                    </div>
                }
            </div>
        </div>
    </div>
</section>
