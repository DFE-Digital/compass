@inject Compass.Services.IPermissionService PermissionService

@{
    ViewData["Title"] = "Standards Updates";
    
    // Check if user is in Standards Managers group
    bool isStandardsManager = false;
    try
    {
        var userEmail = User.Identity?.Name 
            ?? User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
            ?? string.Empty;
        if (!string.IsNullOrEmpty(userEmail))
        {
            isStandardsManager = await PermissionService.IsInGroupAsync(userEmail, "Standards Managers");
        }
    }
    catch
    {
        // Non-blocking: section will not be shown
    }
}

@section Breadcrumbs {
    <style>
        .breadcrumb a:hover {
            color: #003078 !important;
            text-decoration: underline !important;
        }
    </style>
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "DdtStandards", new { view = "published" })" style="color: #005ea5; text-decoration: none;">Standards</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Updates</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        @{
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
            ViewBag.BrandText = "Standards";
            var navLinks = new List<object>
            {
                new { Text = "My standards", Action = "Index", Controller = "DdtStandards", Url = Url.Action("Index", "DdtStandards", new { view = "my" }), IsButton = false, IsActive = false },
                new { Text = "All standards", Action = "Index", Controller = "DdtStandards", Url = Url.Action("Index", "DdtStandards", new { view = "published" }), IsButton = false, IsActive = false },
                new { Text = "Updates", Action = "Updates", Controller = "DdtStandards", Url = default(string?), IsButton = false, IsActive = currentAction == "Updates" }
            };
            if (isStandardsManager)
            {
                navLinks.Add(new { Text = "Management", Action = "Management", Controller = "DdtStandards", Url = Url.Action("ApprovedProducts", "DdtStandards"), IsButton = false, IsActive = false });
            }
            ViewBag.NavLinks = navLinks;
        }
        @await Html.PartialAsync("_ModuleNavbar")

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row mb-4">
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Recent Changes (Last 30 Days)</h3>
                    </div>
                    <div class="card-body p-0">
                        @{
                            var recentChanges = ViewBag.RecentChanges as List<Compass.Models.DdtStandard> ?? new List<Compass.Models.DdtStandard>();
                        }
                        @if (recentChanges.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th style="width: 40%;">Title</th>
                                            <th style="width: 15%;">Version</th>
                                            <th style="width: 20%;">Stage</th>
                                            <th style="width: 25%;">Updated</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var standard in recentChanges.Take(10))
                                        {
                                            <tr>
                                                <td>
                                                    <a href="@Url.Action("Details", "DdtStandards", new { id = standard.Id })" style="font-weight: 600; color: #005ea5; text-decoration: none;">
                                                        @standard.Title
                                                    </a>
                                                </td>
                                                <td>@standard.Version</td>
                                                <td>
                                                    <span class="badge badge-@(standard.Stage == "Published" ? "success" : standard.Stage == "Draft" ? "secondary" : standard.Stage == "For Approval" ? "warning" : "info")">
                                                        @standard.Stage
                                                    </span>
                                                </td>
                                                <td>@standard.UpdatedAt.ToString("dd MMM yyyy")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            @if (recentChanges.Count > 10)
                            {
                                <div class="card-footer text-center">
                                    <small class="text-muted">Showing 10 of @recentChanges.Count recent changes</small>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="p-4 text-center">
                                <p class="text-muted mb-0">No recent changes in the last 30 days.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Recently Published (Last 30 Days)</h3>
                    </div>
                    <div class="card-body p-0">
                        @{
                            var recentPublished = ViewBag.RecentPublished as List<Compass.Models.DdtStandard> ?? new List<Compass.Models.DdtStandard>();
                        }
                        @if (recentPublished.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th style="width: 40%;">Title</th>
                                            <th style="width: 15%;">Version</th>
                                            <th style="width: 20%;">Published</th>
                                            <th style="width: 25%;">Updated</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var standard in recentPublished.Take(10))
                                        {
                                            <tr>
                                                <td>
                                                    <a href="@Url.Action("Details", "DdtStandards", new { id = standard.Id })" style="font-weight: 600; color: #005ea5; text-decoration: none;">
                                                        @standard.Title
                                                    </a>
                                                </td>
                                                <td>@standard.Version</td>
                                                <td>
                                                    @if (standard.PublishedAt.HasValue)
                                                    {
                                                        @standard.PublishedAt.Value.ToString("dd MMM yyyy")
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td>@standard.UpdatedAt.ToString("dd MMM yyyy")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            @if (recentPublished.Count > 10)
                            {
                                <div class="card-footer text-center">
                                    <small class="text-muted">Showing 10 of @recentPublished.Count recently published</small>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="p-4 text-center">
                                <p class="text-muted mb-0">No standards published in the last 30 days.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
