@model Compass.ViewModels.DdtStandardsManageViewModel
@inject Compass.Services.IPermissionService PermissionService

@{
    ViewData["Title"] = "Draft Standards";
    
    bool isStandardsManager = ViewBag.IsStandardsManager as bool? ?? false;
    var allDraftsCount = ViewBag.AllDraftsCount as int? ?? 0;
    var allInReviewCount = ViewBag.AllInReviewCount as int? ?? 0;
    var allForApprovalCount = ViewBag.AllForApprovalCount as int? ?? 0;
    var allPublishedCount = ViewBag.AllPublishedCount as int? ?? 0;
    var allUnpublishedCount = ViewBag.AllUnpublishedCount as int? ?? 0;
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="DdtStandards" asp-action="Dashboard" style="color: #005ea5; text-decoration: none;">DDT Standards</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Drafts</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Draft Standards</h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <a asp-controller="DdtStandards" asp-action="Dashboard" class="btn btn-secondary btn-sm mr-2">
                        <i class="fas fa-arrow-left"></i> Back to Dashboard
                    </a>
                    <a asp-controller="DdtStandards" asp-action="Create" class="btn btn-primary" id="createStandardBtn">
                        <i class="fas fa-plus"></i> Create Standard
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <!-- Left Column: Navigation -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <!-- Navigation Card -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title">Navigation</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <a href="@Url.Action("Dashboard")"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span><i class="fas fa-tachometer-alt mr-2"></i>Dashboard</span>
                            </a>
                            <a href="@Url.Action("Drafts", new { search = Model.CurrentSearch, category = Model.CurrentCategory, creator = Model.CurrentCreator, owner = Model.CurrentOwner, contact = Model.CurrentContact, legalStandard = Model.CurrentLegalStandard })"
                               class="list-group-item list-group-item-action active d-flex justify-content-between align-items-center">
                                <span>Drafts</span>
                                <span class="badge badge-secondary badge-pill">@allDraftsCount</span>
                            </a>
                            <a href="@Url.Action("Index", new { view = "in-review", search = Model.CurrentSearch, category = Model.CurrentCategory, creator = Model.CurrentCreator, owner = Model.CurrentOwner, contact = Model.CurrentContact, legalStandard = Model.CurrentLegalStandard })"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span>For Approval</span>
                                <span class="badge badge-secondary badge-pill">@allInReviewCount</span>
                            </a>
                            <a href="@Url.Action("Index", new { view = "for-approval", search = Model.CurrentSearch, category = Model.CurrentCategory, creator = Model.CurrentCreator, owner = Model.CurrentOwner, contact = Model.CurrentContact, legalStandard = Model.CurrentLegalStandard })"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span>Awaiting Publication</span>
                                <span class="badge badge-secondary badge-pill">@allForApprovalCount</span>
                            </a>
                            <a href="@Url.Action("Index", new { view = "published", search = Model.CurrentSearch, category = Model.CurrentCategory, creator = Model.CurrentCreator, owner = Model.CurrentOwner, contact = Model.CurrentContact, legalStandard = Model.CurrentLegalStandard })"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span>Published</span>
                                <span class="badge badge-secondary badge-pill">@allPublishedCount</span>
                            </a>
                            <a href="@Url.Action("Index", new { view = "unpublished", search = Model.CurrentSearch, category = Model.CurrentCategory, creator = Model.CurrentCreator, owner = Model.CurrentOwner, contact = Model.CurrentContact, legalStandard = Model.CurrentLegalStandard })"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span>Unpublished</span>
                                <span class="badge badge-secondary badge-pill">@allUnpublishedCount</span>
                            </a>
                        </div>
                    </div>
                </div>

                @if (isStandardsManager)
                {
                    <!-- Standards Management Card -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h3 class="card-title">Standards Management</h3>
                        </div>
                        <div class="card-body p-0">
                            <ul class="nav nav-pills flex-column">
                                <li class="nav-item">
                                    <a href="@Url.Action("ApprovedProducts", "DdtStandards")"
                                       class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "ApprovedProducts" ? "active" : "") d-flex justify-content-between align-items-center">
                                        <span>Manage approved products</span>
                                        <span class="badge badge-secondary badge-pill">@(ViewBag.ApprovedProductsCount ?? 0)</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("Exceptions", "DdtStandards")"
                                       class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Exceptions" ? "active" : "") d-flex justify-content-between align-items-center">
                                        <span>Manage Exceptions</span>
                                        <span class="badge badge-secondary badge-pill">@(ViewBag.ExceptionsCount ?? 0)</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                }

                <!-- Filters Card -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Filters</h3>
                    </div>
                    <div class="card-body">
                        <form method="get" id="filterForm">
                            <input type="hidden" name="view" value="drafts" />
                            <div class="form-group">
                                <label>Search</label>
                                <input type="text" name="search" class="form-control form-control-sm" placeholder="Search..." value="@Model.CurrentSearch" />
                            </div>

                            <div class="form-group">
                                <label>Category</label>
                                <select name="category" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @if (Model.Categories != null)
                                    {
                                        @foreach (var cat in Model.Categories)
                                        {
                                            <option value="@cat" selected="@(Model.CurrentCategory == cat)">@cat</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Creator</label>
                                <select name="creator" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @if (Model.Creators != null)
                                    {
                                        @foreach (var creator in Model.Creators)
                                        {
                                            <option value="@creator.Id" selected="@(Model.CurrentCreator == creator.Id)">@creator.Name</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Owner</label>
                                <select name="owner" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @if (Model.Owners != null)
                                    {
                                        @foreach (var owner in Model.Owners)
                                        {
                                            <option value="@owner.Id" selected="@(Model.CurrentOwner == owner.Id)">@owner.Name</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Contact</label>
                                <select name="contact" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @if (Model.Contacts != null)
                                    {
                                        @foreach (var contact in Model.Contacts)
                                        {
                                            <option value="@contact.Id" selected="@(Model.CurrentContact == contact.Id)">@contact.Name</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Legal Standard</label>
                                <select name="legalStandard" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    <option value="true" selected="@(Model.CurrentLegalStandard == true)">Yes</option>
                                    <option value="false" selected="@(Model.CurrentLegalStandard == false)">No</option>
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary btn-sm btn-block">Apply Filters</button>
                            <a href="@Url.Action("Drafts")" class="btn btn-secondary btn-sm btn-block">Clear</a>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Column: Standards List -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <div class="mb-3">
                    @await Html.PartialAsync("_StandardsCard", new { Title = "My drafts", Standards = Model.MyDrafts, ShowCreatedBy = false, ShowActions = false })
                </div>
                <div class="mb-3">
                    @await Html.PartialAsync("_StandardsCard", new { Title = "All drafts", Standards = Model.AllDrafts, ShowCreatedBy = true, ShowActions = false })
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    $(document).ready(function() {
        $('#createStandardBtn').on('click', function(e) {
            e.preventDefault();
            var createUrl = $(this).attr('href');
            if (confirm('Are you sure you want to start a new draft standard?')) {
                window.location.href = createUrl;
            }
        });
    });
</script>

