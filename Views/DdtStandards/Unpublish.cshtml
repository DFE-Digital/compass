@model Compass.Models.DdtStandard

@{
    ViewData["Title"] = "Unpublish Standard";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Details", "DdtStandards", new { id = Model.Id })" style="color: #005ea5; text-decoration: none;">@Model.Title</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Unpublish</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <h1 class="mb-3">Unpublish Standard</h1>
            </div>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-lg-8 col-md-10 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Standard Information</h3>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-3">Title:</dt>
                            <dd class="col-sm-9">@Model.Title</dd>
                            
                            <dt class="col-sm-3">Version:</dt>
                            <dd class="col-sm-9">@Model.Version</dd>
                            
                            <dt class="col-sm-3">Reference:</dt>
                            <dd class="col-sm-9">DDT-@Model.Id</dd>
                            
                            @if (!string.IsNullOrWhiteSpace(Model.LegacyReference))
                            {
                                <dt class="col-sm-3">Legacy Reference:</dt>
                                <dd class="col-sm-9">@Model.LegacyReference</dd>
                            }
                        </dl>
                    </div>
                </div>

                <div class="card mt-3">
                    <div class="card-header">
                        <h3 class="card-title">Unpublish Reason</h3>
                    </div>
                    <div class="card-body">
                        <form asp-action="Unpublish" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            
                            <div class="form-group">
                                <label for="reason">Reason for unpublishing <span class="text-danger">*</span></label>
                                <small class="form-text text-muted d-block mb-2">
                                    Please provide a clear reason for unpublishing this standard. This will be recorded in the audit log.
                                </small>
                                <textarea class="form-control" id="reason" name="reason" rows="5" required maxlength="2000" placeholder="Enter the reason for unpublishing this standard..."></textarea>
                            </div>

                            <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle mr-2"></i>
                                <strong>Warning:</strong> Unpublishing this standard will change its status to "Unpublished" and it will no longer appear in the published standards list. This action will be recorded in the audit log.
                            </div>

                            <div class="d-flex justify-content-between">
                                <a href="@Url.Action("Details", "DdtStandards", new { id = Model.Id })" class="btn btn-secondary">Cancel</a>
                                <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to unpublish this standard?');">
                                    <i class="fas fa-ban mr-2"></i>Unpublish Standard
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

