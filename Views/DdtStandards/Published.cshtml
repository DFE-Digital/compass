@model IEnumerable<Compass.Models.DdtStandard>

@{
    ViewData["Title"] = "Published DDT Standards";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Published Standards</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <h1 class="mb-3">Published DDT Standards</h1>
            </div>
        </div>

        <div class="row">
            <!-- Filters -->
            <div class="col-lg-3 col-md-4 col-12 mb-3">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Filters</h3>
                    </div>
                    <div class="card-body">
                        <form method="get" id="filterForm">
                            <div class="form-group">
                                <label>Search</label>
                                <input type="text" name="search" class="form-control form-control-sm" placeholder="Search..." value="@ViewBag.CurrentSearch" />
                            </div>

                            <div class="form-group">
                                <label>Category</label>
                                <select name="category" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @if (ViewBag.Categories != null)
                                    {
                                        @foreach (var cat in ViewBag.Categories)
                                        {
                                            <option value="@cat" selected="@(ViewBag.CurrentCategory == cat)">@cat</option>
                                        }
                                    }
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary btn-sm btn-block">Apply Filters</button>
                            <a href="@Url.Action("Published")" class="btn btn-secondary btn-sm btn-block">Clear</a>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Standards List -->
            <div class="col-lg-9 col-md-8 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Published Standards (@Model.Count())</h3>
                    </div>
                    <div class="card-body p-0">
                        @if (Model.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Title</th>
                                            <th>Version</th>
                                            <th>Categories</th>
                                            <th>Phases</th>
                                            <th>Published</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var standard in Model)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>
                                                        <a href="@Url.Action("Details", new { id = standard.Id })">@standard.Title</a>
                                                    </strong>
                                                    @if (!string.IsNullOrWhiteSpace(standard.Summary))
                                                    {
                                                        <br />
                                                        <small class="text-muted">@(standard.Summary.Length > 100 ? standard.Summary.Substring(0, 100) + "..." : standard.Summary)</small>
                                                    }
                                                </td>
                                                <td>@standard.Version</td>
                                                <td>
                                                    @if (standard.Categories.Any())
                                                    {
                                                        @foreach (var cat in standard.Categories.Take(2))
                                                        {
                                                            <span class="badge badge-light">@cat.Category.Name</span>
                                                        }
                                                        @if (standard.Categories.Count > 2)
                                                        {
                                                            <span class="badge badge-light">+@(standard.Categories.Count - 2)</span>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (standard.Phases.Any(p => p.Enabled))
                                                    {
                                                        @foreach (var phase in standard.Phases.Where(p => p.Enabled).Take(2))
                                                        {
                                                            <span class="badge badge-primary">@phase.PhaseLookup.Name</span>
                                                        }
                                                        @if (standard.Phases.Count(p => p.Enabled) > 2)
                                                        {
                                                            <span class="badge badge-primary">+@(standard.Phases.Count(p => p.Enabled) - 2)</span>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (standard.PublishedAt.HasValue)
                                                    {
                                                        <small>@standard.PublishedAt.Value.ToString("dd MMM yyyy")</small>
                                                    }
                                                </td>
                                                <td>
                                                    <a href="@Url.Action("Details", new { id = standard.Id })" class="btn btn-sm btn-info" title="View">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="p-4 text-center">
                                <p class="text-muted">No published standards found.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

