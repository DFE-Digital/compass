@model IEnumerable<Compass.Models.DdtStandard>

@{
    ViewData["Title"] = "Published DDT Standards";
    ViewBag.BrandText = "Standards";
    ViewBag.NavLinks = new object[0];
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Published Standards</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        @await Html.PartialAsync("_ModuleNavbar")

        <div class="row">
            <!-- Left Column: Filters -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <!-- Filters Card -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Filters</h3>
                    </div>
                    <div class="card-body">
                        <form method="get" id="filterForm">
                            <div class="form-group">
                                <label>Search</label>
                                <input type="text" name="search" class="form-control form-control-sm" placeholder="Search..." value="@ViewBag.CurrentSearch" />
                            </div>

                            <div class="form-group">
                                <label>Category</label>
                                <select name="category" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @if (ViewBag.Categories != null)
                                    {
                                        @foreach (var cat in ViewBag.Categories)
                                        {
                                            <option value="@cat" selected="@(ViewBag.CurrentCategory == cat)">@cat</option>
                                        }
                                    }
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary btn-sm btn-block">Apply Filters</button>
                            <a href="@Url.Action("Published")" class="btn btn-secondary btn-sm btn-block">Clear</a>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Column: Standards List -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                @{
                    var allPublished = ViewBag.AllPublished as List<Compass.Models.DdtStandard> ?? Model.ToList();
                }
                
                <div class="mb-3">
                    @await Html.PartialAsync("~/Views/DdtStandards/_StandardsCard.cshtml", new { Title = "All published", Standards = allPublished, ShowCreatedBy = true, ShowActions = false })
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Create Standard Confirmation Modal -->
<div class="modal fade" id="createStandardModal" tabindex="-1" role="dialog" aria-labelledby="createStandardModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createStandardModalLabel">Create new draft standard</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to start a new draft standard?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="confirmCreateStandard">Confirm</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            var createUrl = '';
            
            $('#createStandardBtn').on('click', function(e) {
                e.preventDefault();
                createUrl = $(this).attr('href');
                $('#createStandardModal').modal('show');
            });
            
            $('#confirmCreateStandard').on('click', function() {
                if (createUrl) {
                    window.location.href = createUrl;
                }
            });
        });
    </script>
}
