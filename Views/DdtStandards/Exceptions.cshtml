@model List<Compass.Models.DdtStandardException>
@inject Compass.Services.IPermissionService PermissionService
@{
    ViewData["Title"] = "Manage Exceptions";
    var standards = ViewBag.Standards as List<Compass.Models.DdtStandard> ?? new List<Compass.Models.DdtStandard>();
    var standardProducts = ViewBag.StandardProducts as List<Compass.Models.StandardProduct> ?? new List<Compass.Models.StandardProduct>();
    
    // Check if user is in Standards Managers group
    bool isStandardsManager = false;
    try
    {
        var userEmail = User.Identity?.Name 
            ?? User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
            ?? string.Empty;
        if (!string.IsNullOrEmpty(userEmail))
        {
            isStandardsManager = await PermissionService.IsInGroupAsync(userEmail, "Standards Managers");
        }
    }
    catch
    {
        // Non-blocking: section will not be shown
    }
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "DdtStandards")" style="color: #005ea5; text-decoration: none;">Manage Standards</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Exceptions</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Manage Exceptions</h1>
                <p class="text-muted mb-0">View, add, and manage known exceptions to standards</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <!-- Left Column: Navigation -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <!-- Navigation Card -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title">Navigation</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <a href="@Url.Action("Index", "DdtStandards", new { view = "drafts" })"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span>Drafts</span>
                                <span class="badge badge-secondary badge-pill">@(ViewBag.AllDraftsCount ?? 0)</span>
                            </a>
                            <a href="@Url.Action("Index", "DdtStandards", new { view = "in-review" })"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span>For Approval</span>
                                <span class="badge badge-secondary badge-pill">@(ViewBag.AllInReviewCount ?? 0)</span>
                            </a>
                            <a href="@Url.Action("Index", "DdtStandards", new { view = "for-approval" })"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span>Awaiting Publication</span>
                                <span class="badge badge-secondary badge-pill">@(ViewBag.AllForApprovalCount ?? 0)</span>
                            </a>
                            <a href="@Url.Action("Index", "DdtStandards", new { view = "published" })"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span>Published</span>
                                <span class="badge badge-secondary badge-pill">@(ViewBag.AllPublishedCount ?? 0)</span>
                            </a>
                            <a href="@Url.Action("Index", "DdtStandards", new { view = "unpublished" })"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span>Unpublished</span>
                                <span class="badge badge-secondary badge-pill">@(ViewBag.AllUnpublishedCount ?? 0)</span>
                            </a>
                        </div>
                    </div>
                </div>

                @if (isStandardsManager)
                {
                    <!-- Standards Management Card -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h3 class="card-title">Standards Management</h3>
                        </div>
                        <div class="card-body p-0">
                            <ul class="nav nav-pills flex-column">
                                <li class="nav-item">
                                    <a href="@Url.Action("ApprovedProducts", "DdtStandards")"
                                       class="nav-link d-flex justify-content-between align-items-center">
                                        <span>Manage approved products</span>
                                        <span class="badge badge-secondary badge-pill">@(ViewBag.ApprovedProductsCount ?? 0)</span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("Exceptions", "DdtStandards")"
                                       class="nav-link active d-flex justify-content-between align-items-center">
                                        <span>Manage Exceptions</span>
                                        <span class="badge badge-secondary badge-pill">@(ViewBag.ExceptionsCount ?? 0)</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                }
            </div>

            <!-- Right Column: Exceptions List -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Exceptions</h3>
                        <div class="card-tools">
                            <button type="button" class="btn btn-primary btn-sm" data-toggle="modal" data-target="#createExceptionModal">
                                <i class="fas fa-plus mr-1"></i>Add Exception
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table id="exceptionsTable" class="table table-hover mb-0 sortable-table">
                                <thead>
                                    <tr>
                                        <th class="sortable" data-column="Title" tabindex="0" role="button" aria-label="Sort by Title">Title <i class="fas fa-sort sort-icon"></i></th>
                                        <th class="sortable" data-column="Standard" tabindex="0" role="button" aria-label="Sort by Standard">Standard <i class="fas fa-sort sort-icon"></i></th>
                                        <th class="sortable" data-column="Product" tabindex="0" role="button" aria-label="Sort by Product">Product <i class="fas fa-sort sort-icon"></i></th>
                                        <th class="sortable" data-column="Status" tabindex="0" role="button" aria-label="Sort by Status">Status <i class="fas fa-sort sort-icon"></i></th>
                                        <th class="sortable" data-column="Granted" tabindex="0" role="button" aria-label="Sort by Granted">Granted <i class="fas fa-sort sort-icon"></i></th>
                                        <th class="sortable" data-column="Expires" tabindex="0" role="button" aria-label="Sort by Expires">Expires <i class="fas fa-sort sort-icon"></i></th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var exception in Model)
                                    {
                                        <tr class="@(exception.Status == "Expired" || exception.Status == "Revoked" ? "text-muted" : "")">
                                            <td>
                                                <strong>@exception.Title</strong>
                                                @if (!string.IsNullOrWhiteSpace(exception.Description))
                                                {
                                                    <br />
                                                    <small class="text-muted">@(exception.Description.Length > 100 ? exception.Description.Substring(0, 100) + "..." : exception.Description)</small>
                                                }
                                            </td>
                                            <td>@exception.DdtStandard.Title</td>
                                            <td>
                                                @if (exception.StandardProduct != null)
                                                {
                                                    @exception.StandardProduct.Name
                                                }
                                                else if (!string.IsNullOrWhiteSpace(exception.FipsProductId))
                                                {
                                                    <span class="text-muted">FIPS: @exception.FipsProductId</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (exception.Status == "Active")
                                                {
                                                    <span class="badge badge-success">Active</span>
                                                }
                                                else if (exception.Status == "Expired")
                                                {
                                                    <span class="badge badge-secondary">Expired</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-danger">Revoked</span>
                                                }
                                            </td>
                                            <td>
                                                <small>@exception.GrantedAt.ToString("dd MMM yyyy")</small>
                                                @if (exception.GrantedByUser != null)
                                                {
                                                    <br />
                                                    <small class="text-muted">by @exception.GrantedByUser.Name</small>
                                                }
                                            </td>
                                            <td>
                                                @if (exception.ExpiresAt.HasValue)
                                                {
                                                    <small>@exception.ExpiresAt.Value.ToString("dd MMM yyyy")</small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-link" data-toggle="modal" data-target="#editExceptionModal"
                                                        data-id="@exception.Id"
                                                        data-title="@exception.Title"
                                                        data-description="@(exception.Description ?? "")"
                                                        data-reason="@(exception.Reason ?? "")"
                                                        data-standardid="@exception.DdtStandardId"
                                                        data-productid="@(exception.StandardProductId?.ToString() ?? "")"
                                                        data-fipsproductid="@(exception.FipsProductId ?? "")"
                                                        data-status="@exception.Status"
                                                        data-grantedat="@exception.GrantedAt.ToString("yyyy-MM-dd")"
                                                        data-expiresat="@(exception.ExpiresAt?.ToString("yyyy-MM-dd") ?? "")"
                                                        data-notes="@(exception.Notes ?? "")">
                                                    <i class="fas fa-edit"></i>
                                                </button>
                                                <form asp-action="DeleteException" method="post" class="d-inline"
                                                      onsubmit="return confirm('Are you sure you want to delete this exception?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@exception.Id" />
                                                    <button type="submit" class="btn btn-sm btn-link text-danger">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                    @if (!Model.Any())
                                    {
                                        <tr>
                                            <td colspan="7" class="text-center text-muted py-4">No exceptions found.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Create Exception Modal -->
<div class="modal fade" id="createExceptionModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="CreateException" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Create Exception</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="exceptionTitle">Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="exceptionTitle" name="title" required maxlength="500" />
                    </div>
                    <div class="form-group">
                        <label for="exceptionStandardId">Standard <span class="text-danger">*</span></label>
                        <select class="form-control" id="exceptionStandardId" name="standardId" required>
                            <option value="">Select a standard...</option>
                            @foreach (var standard in standards)
                            {
                                <option value="@standard.Id">@standard.Title</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="exceptionDescription">Description</label>
                        <textarea class="form-control" id="exceptionDescription" name="description" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="exceptionReason">Reason</label>
                        <textarea class="form-control" id="exceptionReason" name="reason" rows="2" maxlength="2000"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="exceptionProductId">Product (Optional)</label>
                        <select class="form-control" id="exceptionProductId" name="productId">
                            <option value="">None</option>
                            @foreach (var product in standardProducts)
                            {
                                <option value="@product.Id">@product.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="exceptionFipsProductId">FIPS Product ID (Optional)</label>
                        <input type="text" class="form-control" id="exceptionFipsProductId" name="fipsProductId" maxlength="50" />
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="exceptionGrantedAt">Granted Date <span class="text-danger">*</span></label>
                                <input type="date" class="form-control" id="exceptionGrantedAt" name="grantedAt" required value="@DateTime.UtcNow.ToString("yyyy-MM-dd")" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="exceptionExpiresAt">Expires Date (Optional)</label>
                                <input type="date" class="form-control" id="exceptionExpiresAt" name="expiresAt" />
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="exceptionStatus">Status</label>
                        <select class="form-control" id="exceptionStatus" name="status">
                            <option value="Active">Active</option>
                            <option value="Expired">Expired</option>
                            <option value="Revoked">Revoked</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="exceptionNotes">Notes</label>
                        <textarea class="form-control" id="exceptionNotes" name="notes" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Exception Modal -->
<div class="modal fade" id="editExceptionModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form asp-action="UpdateException" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editExceptionId" />
                <div class="modal-header">
                    <h5 class="modal-title">Edit Exception</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="editExceptionTitle">Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="editExceptionTitle" name="title" required maxlength="500" />
                    </div>
                    <div class="form-group">
                        <label for="editExceptionStandardId">Standard <span class="text-danger">*</span></label>
                        <select class="form-control" id="editExceptionStandardId" name="standardId" required>
                            <option value="">Select a standard...</option>
                            @foreach (var standard in standards)
                            {
                                <option value="@standard.Id">@standard.Title</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="editExceptionDescription">Description</label>
                        <textarea class="form-control" id="editExceptionDescription" name="description" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="editExceptionReason">Reason</label>
                        <textarea class="form-control" id="editExceptionReason" name="reason" rows="2" maxlength="2000"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="editExceptionProductId">Product (Optional)</label>
                        <select class="form-control" id="editExceptionProductId" name="productId">
                            <option value="">None</option>
                            @foreach (var product in standardProducts)
                            {
                                <option value="@product.Id">@product.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="editExceptionFipsProductId">FIPS Product ID (Optional)</label>
                        <input type="text" class="form-control" id="editExceptionFipsProductId" name="fipsProductId" maxlength="50" />
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="editExceptionGrantedAt">Granted Date <span class="text-danger">*</span></label>
                                <input type="date" class="form-control" id="editExceptionGrantedAt" name="grantedAt" required />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="editExceptionExpiresAt">Expires Date (Optional)</label>
                                <input type="date" class="form-control" id="editExceptionExpiresAt" name="expiresAt" />
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="editExceptionStatus">Status</label>
                        <select class="form-control" id="editExceptionStatus" name="status">
                            <option value="Active">Active</option>
                            <option value="Expired">Expired</option>
                            <option value="Revoked">Revoked</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="editExceptionNotes">Notes</label>
                        <textarea class="form-control" id="editExceptionNotes" name="notes" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize sortable table
            var exceptionsTable = $('#exceptionsTable');
            if (exceptionsTable.length) {
                initializeSortableTable(exceptionsTable);
            }
            
            function initializeSortableTable(table) {
                var currentSort = { column: null, direction: 'asc' };
                var tableId = table.attr('id');

                table.find('.sortable').on('click keypress', function(e) {
                    if (e.type === 'keypress' && e.which !== 13 && e.which !== 32) {
                        return;
                    }
                    
                    var column = $(this).data('column');
                    var direction = 'asc';
                    
                    if (currentSort.column === column && currentSort.direction === 'asc') {
                        direction = 'desc';
                    }
                    
                    sortTable(table, column, direction, tableId);
                    currentSort = { column: column, direction: direction };
                });

                function sortTable(table, column, direction, tableId) {
                    var tbody = table.find('tbody');
                    var rows = tbody.find('tr').toArray();
                    
                    rows.sort(function(a, b) {
                        var aVal, bVal;
                        var colIndex = table.find('thead th[data-column="' + column + '"]').index();
                        
                        if (column === 'Granted' || column === 'Expires') {
                            // Parse date format "dd MMM yyyy"
                            var aDateText = $(a).find('td').eq(colIndex).find('small').first().text().trim();
                            var bDateText = $(b).find('td').eq(colIndex).find('small').first().text().trim();
                            aVal = parseDate(aDateText);
                            bVal = parseDate(bDateText);
                        } else if (column === 'Status') {
                            // Sort by status badge text
                            aVal = $(a).find('td').eq(colIndex).find('.badge').text().trim().toLowerCase();
                            bVal = $(b).find('td').eq(colIndex).find('.badge').text().trim().toLowerCase();
                        } else {
                            aVal = $(a).find('td').eq(colIndex).text().trim().toLowerCase();
                            bVal = $(b).find('td').eq(colIndex).text().trim().toLowerCase();
                        }
                        
                        if (direction === 'asc') {
                            return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                        } else {
                            return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                        }
                    });
                    
                    tbody.empty();
                    rows.forEach(function(row) {
                        tbody.append(row);
                    });
                    
                    updateSortIcons(table, column, direction);
                }

                function updateSortIcons(table, column, direction) {
                    table.find('.sortable .fa-sort-up, .sortable .fa-sort-down').removeClass('fa-sort-up fa-sort-down').addClass('fa-sort');
                    var header = table.find('.sortable[data-column="' + column + '"]');
                    var iconClass = direction === 'asc' ? 'fa-sort-up' : 'fa-sort-down';
                    header.find('i').removeClass('fa-sort').addClass(iconClass);
                }
                
                function parseDate(dateText) {
                    // Parse "dd MMM yyyy" format
                    var months = { 'jan': 0, 'feb': 1, 'mar': 2, 'apr': 3, 'may': 4, 'jun': 5, 'jul': 6, 'aug': 7, 'sep': 8, 'oct': 9, 'nov': 10, 'dec': 11 };
                    var parts = dateText.toLowerCase().split(' ');
                    if (parts.length === 3) {
                        var day = parseInt(parts[0]);
                        var month = months[parts[1]] || 0;
                        var year = parseInt(parts[2]);
                        return new Date(year, month, day);
                    }
                    return new Date(0);
                }
            }
            
            $('#editExceptionModal').on('show.bs.modal', function (event) {
            var button = $(event.relatedTarget);
            $('#editExceptionId').val(button.data('id'));
            $('#editExceptionTitle').val(button.data('title'));
            $('#editExceptionDescription').val(button.data('description'));
            $('#editExceptionReason').val(button.data('reason'));
            $('#editExceptionStandardId').val(button.data('standardid'));
            $('#editExceptionProductId').val(button.data('productid'));
            $('#editExceptionFipsProductId').val(button.data('fipsproductid'));
            $('#editExceptionStatus').val(button.data('status'));
            $('#editExceptionGrantedAt').val(button.data('grantedat'));
            $('#editExceptionExpiresAt').val(button.data('expiresat'));
            $('#editExceptionNotes').val(button.data('notes'));
        });
    </script>
}

