@model IEnumerable<Compass.Models.DdtStandard>

@{
    ViewData["Title"] = "Unpublished DDT Standards";
    var myUnpublished = ViewBag.MyUnpublished as List<Compass.Models.DdtStandard> ?? new List<Compass.Models.DdtStandard>();
    var allUnpublished = ViewBag.AllUnpublished as List<Compass.Models.DdtStandard> ?? Model.ToList();
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Unpublished Standards</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <h1 class="mb-3">Unpublished DDT Standards</h1>
            </div>
        </div>

        <div class="row">
            <!-- Left Column: Navigation and Filters -->
            <div class="col-lg-3 col-md-4 col-12 mb-3">
                <!-- Navigation Card -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title">Navigation</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <a href="@Url.Action("Index", "DdtStandards", new { view = "drafts" })"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span>Drafts</span>
                                <span class="badge badge-secondary badge-pill">@(ViewBag.AllDraftsCount ?? 0)</span>
                            </a>
                            <a href="@Url.Action("Index", "DdtStandards", new { view = "in-review" })"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span>For Approval</span>
                                <span class="badge badge-secondary badge-pill">@(ViewBag.AllInReviewCount ?? 0)</span>
                            </a>
                            <a href="@Url.Action("Index", "DdtStandards", new { view = "for-approval" })"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span>Awaiting Publication</span>
                                <span class="badge badge-secondary badge-pill">@(ViewBag.AllForApprovalCount ?? 0)</span>
                            </a>
                            <a href="/api/DdtStandards?view=published"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span>Published</span>
                                <span class="badge badge-secondary badge-pill">@(ViewBag.AllPublishedCount ?? 0)</span>
                            </a>
                            <a href="@Url.Action("Index", "DdtStandards", new { view = "unpublished" })"
                               class="list-group-item list-group-item-action active d-flex justify-content-between align-items-center">
                                <span>Unpublished</span>
                                <span class="badge badge-secondary badge-pill">@(ViewBag.AllUnpublishedCount ?? 0)</span>
                            </a>
                        </div>
                    </div>
                </div>
                
                <!-- Filters Card -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Filters</h3>
                    </div>
                    <div class="card-body">
                        <form method="get" id="filterForm">
                            <div class="form-group">
                                <label>Search</label>
                                <input type="text" name="search" class="form-control form-control-sm" placeholder="Search..." value="@ViewBag.CurrentSearch" />
                            </div>

                            <div class="form-group">
                                <label>Category</label>
                                <select name="category" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @if (ViewBag.Categories != null)
                                    {
                                        @foreach (var cat in ViewBag.Categories)
                                        {
                                            <option value="@cat" selected="@(ViewBag.CurrentCategory == cat)">@cat</option>
                                        }
                                    }
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary btn-sm btn-block">Apply Filters</button>
                            <a href="@Url.Action("Unpublished")" class="btn btn-secondary btn-sm btn-block">Clear</a>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Column: Standards List -->
            <div class="col-lg-9 col-md-8 col-12">
                @if (myUnpublished.Any())
                {
                    <div class="mb-3">
                        @await Html.PartialAsync("~/Views/DdtStandards/_StandardsCard.cshtml", new { Title = "My unpublished", Standards = myUnpublished, ShowCreatedBy = false, ShowActions = false })
                    </div>
                }
                
                <div class="mb-3">
                    @await Html.PartialAsync("~/Views/DdtStandards/_StandardsCard.cshtml", new { Title = "All unpublished", Standards = allUnpublished, ShowCreatedBy = true, ShowActions = false })
                </div>
            </div>
        </div>
    </div>
</section>

