@model Compass.Models.Action
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Action details";
    var isOverdue = Model.DueDate.HasValue && 
                    Model.DueDate.Value.Date < DateTime.Today &&
                    Model.Status != "done" && Model.Status != "cancelled";
    var products = ViewBag.Products as List<Compass.Models.ProductDto> ?? new List<Compass.Models.ProductDto>();
    var fipsBaseUrl = Configuration["fipsProduct:baseUrl"] ?? "https://find-products-services-test.azurewebsites.net/";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Actions</a></li>
                    <li class="breadcrumb-item active">Action details</li>
                </ol>
                <h1 class="m-0">@Model.Title</h1>
                <p class="text-muted">Action #@Model.Id</p>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <div class="btn-group">
                        <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            Actions
                        </button>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" asp-action="Edit" asp-route-id="@Model.Id">Edit action</a>
                            <a class="dropdown-item" asp-action="Create" asp-route-parentActionId="@Model.Id">Add sub-action</a>
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item" asp-action="Delete" asp-route-id="@Model.Id">Delete action</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <!-- Main content -->
            <div class="col-xxl-9 col-xl-9 col-lg-8 col-md-12 col-sm-12 col-12">
                <!-- Product link -->
                @if (!string.IsNullOrEmpty(Model.FipsId))
                {
                    var product = products.FirstOrDefault(p => p.FipsId == Model.FipsId);
                    var productUrl = $"{fipsBaseUrl.TrimEnd('/')}/product/{Model.FipsId}";
                    <div class="card">
                        <div class="card-body">
                            <strong>Product:</strong>
                            @if (product != null)
                            {
                                <a href="@productUrl" target="_blank" rel="noopener noreferrer">@product.Title (@Model.FipsId)</a>
                            }
                            else
                            {
                                <a href="@productUrl" target="_blank" rel="noopener noreferrer">@Model.FipsId</a>
                            }
                        </div>
                    </div>
                }

                <!-- Description -->
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Description</h3>
                        </div>
                        <div class="card-body">
                            <p class="mb-0">@Model.Description</p>
                        </div>
                    </div>
                }

                <!-- Notes -->
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Notes</h3>
                        </div>
                        <div class="card-body">
                            <p class="mb-0">@Model.Notes</p>
                        </div>
                    </div>
                }

                <!-- Evidence -->
                @if (!string.IsNullOrEmpty(Model.EvidenceUrl))
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Evidence</h3>
                        </div>
                        <div class="card-body">
                            <a href="@Model.EvidenceUrl" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary">View evidence</a>
                            <div class="mt-2"><small class="text-muted">@Model.EvidenceUrl</small></div>
                        </div>
                    </div>
                }

                <!-- Sub-actions -->
                @if (Model.SubActions != null && Model.SubActions.Any())
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Sub-actions</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th style="width: 150px;">Assigned to</th>
                                        <th style="width: 120px;">Status</th>
                                        <th style="width: 120px;">Due date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var subAction in Model.SubActions)
                                    {
                                        var subOverdue = subAction.DueDate.HasValue && 
                                                       subAction.DueDate.Value.Date < DateTime.Today &&
                                                       subAction.Status != "done" && subAction.Status != "cancelled";
                                        <tr class="@(subOverdue ? "table-danger" : "")">
                                            <td><a asp-action="Details" asp-route-id="@subAction.Id">@subAction.Title</a></td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(subAction.AssignedToEmail))
                                                {
                                                    <small><a href="mailto:@subAction.AssignedToEmail">@subAction.AssignedToEmail</a></small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @switch (subAction.Status)
                                                {
                                                    case "done":
                                                        <span class="badge badge-success">Done</span>
                                                        break;
                                                    case "in_progress":
                                                        <span class="badge badge-primary">In progress</span>
                                                        break;
                                                    case "blocked":
                                                        <span class="badge badge-danger">Blocked</span>
                                                        break;
                                                    case "not_started":
                                                        <span class="badge badge-secondary">Not started</span>
                                                        break;
                                                    case "cancelled":
                                                        <span class="badge badge-dark">Cancelled</span>
                                                        break;
                                                    default:
                                                        <span class="badge badge-secondary">@subAction.Status</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                @if (subAction.DueDate.HasValue)
                                                {
                                                    <span class="@(subOverdue ? "text-danger" : "")">
                                                        @subAction.DueDate.Value.ToString("dd MMM yyyy")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <!-- Related items -->
                @if ((Model.RiskActions != null && Model.RiskActions.Any()) || 
                     (Model.IssueActions != null && Model.IssueActions.Any()) || 
                     (Model.MilestoneActions != null && Model.MilestoneActions.Any()))
                {
                    @if (Model.RiskActions != null && Model.RiskActions.Any())
                    {
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Related risks</h3>
                            </div>
                            <div class="card-body p-0">
                                <ul class="list-group list-group-flush">
                                    @foreach (var ra in Model.RiskActions)
                                    {
                                        <li class="list-group-item">
                                            <a asp-controller="Risk" asp-action="Details" asp-route-id="@ra.Risk.Id">@ra.Risk.Title</a>
                                            <span class="badge @(ra.Risk.RiskScore >= 15 ? "badge-danger" : ra.Risk.RiskScore >= 10 ? "badge-warning" : "badge-success") float-right">
                                                Score: @ra.Risk.RiskScore
                                            </span>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    }

                    @if (Model.IssueActions != null && Model.IssueActions.Any())
                    {
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Related issues</h3>
                            </div>
                            <div class="card-body p-0">
                                <ul class="list-group list-group-flush">
                                    @foreach (var ia in Model.IssueActions)
                                    {
                                        <li class="list-group-item">
                                            <a asp-controller="Issue" asp-action="Details" asp-route-id="@ia.Issue.Id">@ia.Issue.Title</a>
                                            <span class="badge @(ia.Issue.Severity == "critical" ? "badge-danger" : ia.Issue.Severity == "high" ? "badge-warning" : "badge-info") float-right">
                                                @ia.Issue.Severity
                                            </span>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    }

                    @if (Model.MilestoneActions != null && Model.MilestoneActions.Any())
                    {
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Related milestones</h3>
                            </div>
                            <div class="card-body p-0">
                                <ul class="list-group list-group-flush">
                                    @foreach (var ma in Model.MilestoneActions)
                                    {
                                        <li class="list-group-item">
                                            <a asp-controller="Milestone" asp-action="Details" asp-route-id="@ma.Milestone.Id">@ma.Milestone.Name</a>
                                            <small class="text-muted float-right">Due: @ma.Milestone.DueDate.ToString("dd MMM yyyy")</small>
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    }
                }

                <!-- Comments Section -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Comments</h3>
                    </div>
                    <div class="card-body">
                        <div id="commentsContainer">
                            <p class="text-muted text-center">Loading comments...</p>
                        </div>
                        
                        <hr />
                        
                        <div class="form-group mb-0">
                            <label for="newComment">Add a comment</label>
                            <textarea id="newComment" class="form-control" rows="3" placeholder="Enter your comment..."></textarea>
                            <button type="button" class="btn btn-primary mt-2" id="addCommentBtn">Add comment</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-xxl-3 col-xl-3 col-lg-4 col-md-12 col-sm-12 col-12">
                <!-- Details -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Details</h3>
                    </div>
                    <div class="card-body">
                        <dl class="mb-0">
                            <dt>Status</dt>
                            <dd class="mb-3">
                                @switch (Model.Status)
                                {
                                    case "done":
                                        <span class="badge badge-success">Done</span>
                                        break;
                                    case "in_progress":
                                        <span class="badge badge-primary">In progress</span>
                                        break;
                                    case "blocked":
                                        <span class="badge badge-danger">Blocked</span>
                                        break;
                                    case "not_started":
                                        <span class="badge badge-secondary">Not started</span>
                                        break;
                                    case "cancelled":
                                        <span class="badge badge-dark">Cancelled</span>
                                        break;
                                    default:
                                        <span class="badge badge-secondary">@Model.Status</span>
                                        break;
                                }
                            </dd>

                            <dt>Priority</dt>
                            <dd class="mb-3">
                                @switch (Model.Priority)
                                {
                                    case "high":
                                        <span class="badge badge-danger">High</span>
                                        break;
                                    case "medium":
                                        <span class="badge badge-warning">Medium</span>
                                        break;
                                    case "low":
                                        <span class="badge badge-info">Low</span>
                                        break;
                                    default:
                                        <span class="text-muted">@(Model.Priority ?? "Not set")</span>
                                        break;
                                }
                            </dd>

                            <dt>Assigned to</dt>
                            <dd class="mb-3">
                                @if (!string.IsNullOrEmpty(Model.AssignedToEmail))
                                {
                                    <a href="mailto:@Model.AssignedToEmail">@Model.AssignedToEmail</a>
                                }
                                else
                                {
                                    <span class="text-muted">Unassigned</span>
                                }
                            </dd>

                            <dt>Business area</dt>
                            <dd class="mb-3">
                                @if (!string.IsNullOrEmpty(Model.BusinessArea))
                                {
                                    <a asp-action="Index" asp-route-businessArea="@Model.BusinessArea">@Model.BusinessArea</a>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </dd>

                            <dt>Strategic objective</dt>
                            <dd class="mb-3">
                                @if (Model.Objective != null)
                                {
                                    <a asp-action="Index" asp-route-objectiveId="@Model.Objective.Id">@Model.Objective.Title</a>
                                }
                                else
                                {
                                    <span class="text-muted">Not linked</span>
                                }
                            </dd>

                            <dt>Action source</dt>
                            <dd class="mb-3">
                                @if (Model.ActionSource != null)
                                {
                                    <div>@Model.ActionSource.Name</div>
                                    @if (!string.IsNullOrEmpty(Model.ActionSource.Summary))
                                    {
                                        <small class="text-muted">@Model.ActionSource.Summary</small>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </dd>

                            <dt>Parent action</dt>
                            <dd class="mb-0">
                                @if (Model.ParentAction != null)
                                {
                                    <a asp-action="Details" asp-route-id="@Model.ParentAction.Id">@Model.ParentAction.Title</a>
                                }
                                else
                                {
                                    <span class="text-muted">None</span>
                                }
                            </dd>
                        </dl>
                    </div>
                </div>

                <!-- Timeline -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Timeline</h3>
                    </div>
                    <div class="card-body">
                        <dl class="mb-0">
                            <dt>Start date</dt>
                            <dd class="mb-3">@(Model.StartDate?.ToString("dd MMM yyyy") ?? "-")</dd>

                            <dt>Due date</dt>
                            <dd class="mb-3">
                                @if (Model.DueDate.HasValue)
                                {
                                    <span class="@(isOverdue ? "text-danger" : "")">
                                        @Model.DueDate.Value.ToString("dd MMM yyyy")
                                    </span>
                                    @if (isOverdue)
                                    {
                                        var daysOverdue = (DateTime.Today - Model.DueDate.Value.Date).Days;
                                        <br><span class="text-danger small">@daysOverdue days overdue</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </dd>

                            <dt>Completed</dt>
                            <dd class="mb-3">@(Model.CompletedDate?.ToString("dd MMM yyyy") ?? "-")</dd>

                            <dt>Created</dt>
                            <dd class="mb-3">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</dd>

                            <dt>Last updated</dt>
                            <dd class="mb-0">@Model.UpdatedAt.ToString("dd MMM yyyy HH:mm")</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@Html.AntiForgeryToken()

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            loadComments();
            
            function loadComments() {
                $.ajax({
                    url: '/api/comments/Action/@Model.Id',
                    type: 'GET',
                    success: function(data) {
                        displayComments(data);
                    },
                    error: function() {
                        $('#commentsContainer').html('<p class="text-danger">Failed to load comments</p>');
                    }
                });
            }
            
            function displayComments(comments) {
                if (!comments || comments.length === 0) {
                    $('#commentsContainer').html('<p class="text-muted">No comments yet</p>');
                    return;
                }
                
                var html = '';
                comments.forEach(function(comment) {
                    var date = new Date(comment.createdAt);
                    var dateStr = date.toLocaleString('en-GB', { 
                        day: 'numeric', 
                        month: 'short', 
                        year: 'numeric', 
                        hour: '2-digit', 
                        minute: '2-digit' 
                    });
                    
                    html += '<div class="border-bottom pb-3 mb-3">';
                    html += '<div class="d-flex justify-content-between mb-2">';
                    html += '<strong>' + (comment.createdByUser ? comment.createdByUser.name : 'Unknown') + '</strong>';
                    html += '<small class="text-muted">' + dateStr + '</small>';
                    html += '</div>';
                    html += '<p class="mb-0">' + comment.commentText.replace(/\n/g, '<br>') + '</p>';
                    html += '</div>';
                });
                
                $('#commentsContainer').html(html);
            }
            
            $('#addCommentBtn').click(function() {
                var commentText = $('#newComment').val().trim();
                
                if (!commentText) {
                    alert('Please enter a comment');
                    return;
                }
                
                $.ajax({
                    url: '/api/comments',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        entityType: 'Action',
                        entityId: @Model.Id,
                        commentText: commentText
                    }),
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function() {
                        $('#newComment').val('');
                        loadComments();
                    },
                    error: function() {
                        alert('Failed to add comment');
                    }
                });
            });
        });
    </script>
}
