@model Compass.Models.Action
@{
    ViewData["Title"] = "Delete action";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Actions</a></li>
                    <li class="breadcrumb-item active">Delete</li>
                </ol>
                <h1 class="m-0">Delete action</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card card-danger">
            <div class="card-header">
                <h3 class="card-title">Confirm deletion</h3>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <h5><i class="icon fas fa-exclamation-triangle"></i> Warning</h5>
                    Are you sure you want to delete this action? This action cannot be undone.
                </div>

                <dl class="row">
                    <dt class="col-sm-3">Title</dt>
                    <dd class="col-sm-9">@Model.Title</dd>

                    <dt class="col-sm-3">Description</dt>
                    <dd class="col-sm-9">@(Model.Description ?? "-")</dd>

                    <dt class="col-sm-3">Objective</dt>
                    <dd class="col-sm-9">@(Model.Objective?.Title ?? "-")</dd>

                    <dt class="col-sm-3">Assigned to</dt>
                    <dd class="col-sm-9">@(Model.AssignedToEmail ?? "-")</dd>

                    <dt class="col-sm-3">Parent action</dt>
                    <dd class="col-sm-9">@(Model.ParentAction?.Title ?? "-")</dd>

                    <dt class="col-sm-3">Priority</dt>
                    <dd class="col-sm-9">@(Model.Priority ?? "-")</dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">@Model.Status</dd>

                    <dt class="col-sm-3">Due date</dt>
                    <dd class="col-sm-9">@(Model.DueDate?.ToString("dd/MM/yyyy") ?? "-")</dd>

                    <dt class="col-sm-3">Created</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
            </div>
            <div class="card-footer">
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">
                        Yes, delete this action
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        Cancel
                    </a>
                </form>
            </div>
        </div>
    </div>
</section>

