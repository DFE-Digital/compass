@model Compass.Models.ProductAccessibility

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Audit History</h3>
                <div class="card-tools">
                    <a href="#" data-toggle="modal" data-target="#addAuditModal">Add audit</a>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                @if (Model.AuditHistories.Where(a => !a.IsDeleted).Any())
                {
                    <table class="table table-hover text-nowrap">
                        <thead>
                            <tr>
                                <th>Audit Date</th>
                                <th>Type</th>
                                <th>Audited By</th>
                                <th>Cost</th>
                                <th>Report</th>
                                <th>Notes</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var audit in Model.AuditHistories.Where(a => !a.IsDeleted).OrderByDescending(a => a.AuditDate))
                            {
                                <tr>
                                    <td>@audit.AuditDate.ToString("dd MMM yyyy")</td>
                                    <td><span class="badge badge-@(audit.AuditType == "External" ? "primary" : "secondary")">@audit.AuditType</span></td>
                                    <td>@audit.AuditedBy</td>
                                    <td>
                                        @if (audit.Cost.HasValue)
                                        {
                                            <span>£@audit.Cost.Value.ToString("N2")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(audit.ReportUrl))
                                        {
                                            <a href="@audit.ReportUrl" target="_blank" rel="noopener noreferrer">View Report</a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(audit.Notes))
                                        {
                                            <a href="#" class="view-audit-link" 
                                               data-date="@audit.AuditDate.ToString("dd MMM yyyy")"
                                               data-type="@audit.AuditType"
                                               data-audited-by="@audit.AuditedBy"
                                               data-cost="@(audit.Cost.HasValue ? audit.Cost.Value.ToString("N2") : "")"
                                               data-notes="@audit.Notes"
                                               data-report-url="@audit.ReportUrl">View</a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        <form asp-action="DeleteAudit" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@audit.Id" />
                                            <input type="hidden" name="fipsId" value="@Model.FipsId" />
                                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this audit record?')">
                                                Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center p-4">
                        <p class="text-muted">No audit records found.</p>
                        <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#addAuditModal">
                            Add first audit
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Add Audit Modal -->
<div class="modal fade" id="addAuditModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add Audit Record</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="AddAudit" method="post">
                <input type="hidden" name="productAccessibilityId" value="@Model.Id" />
                <input type="hidden" name="fipsId" value="@Model.FipsId" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="auditDate">Audit Date *</label>
                        <input type="date" class="form-control" id="auditDate" name="auditDate" required />
                    </div>
                    
                    <div class="form-group">
                        <label for="auditType">Audit Type *</label>
                        <select class="form-control" id="auditType" name="auditType" required>
                            <option value="">Select type...</option>
                            <option value="Internal">Internal</option>
                            <option value="External">External</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="auditedBy">Audited By *</label>
                        <input type="text" class="form-control" id="auditedBy" name="auditedBy" placeholder="Name or organization" required />
                    </div>
                    
                    <div class="form-group">
                        <label for="cost">Cost (£)</label>
                        <input type="number" step="0.01" min="0" class="form-control" id="cost" name="cost" placeholder="0.00" />
                        <small class="form-text text-muted">Optional: Cost of the audit in GBP</small>
                    </div>
                    
                    <div class="form-group">
                        <label for="reportUrl">Report URL</label>
                        <input type="url" class="form-control" id="reportUrl" name="reportUrl" placeholder="https://..." />
                    </div>
                    
                    <div class="form-group">
                        <label for="auditNotes">Notes</label>
                        <textarea class="form-control preserve-formatting" id="auditNotes" name="notes" rows="3" placeholder="Optional notes about the audit"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add Audit</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- View Audit Details Modal -->
<div class="modal fade" id="viewAuditModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Audit Details</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <dl class="row">
                    <dt class="col-sm-4">Audit Date</dt>
                    <dd class="col-sm-8" id="viewAuditDate"></dd>
                    
                    <dt class="col-sm-4">Type</dt>
                    <dd class="col-sm-8" id="viewAuditType"></dd>
                    
                    <dt class="col-sm-4">Audited By</dt>
                    <dd class="col-sm-8" id="viewAuditedBy"></dd>
                    
                    <dt class="col-sm-4">Cost</dt>
                    <dd class="col-sm-8" id="viewAuditCost"></dd>
                    
                    <dt class="col-sm-4">Report</dt>
                    <dd class="col-sm-8" id="viewAuditReport"></dd>
                    
                    <dt class="col-sm-4">Notes</dt>
                    <dd class="col-sm-8"><div id="viewAuditNotes" class="preserve-formatting"></div></dd>
                </dl>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
(function() {
    $(document).on('click', '.view-audit-link', function(e) {
        e.preventDefault();
        var $link = $(this);
        
        $('#viewAuditDate').text($link.data('date'));
        $('#viewAuditType').html('<span class="badge badge-' + ($link.data('type') === 'External' ? 'primary' : 'secondary') + '">' + $link.data('type') + '</span>');
        $('#viewAuditedBy').text($link.data('audited-by'));
        
        if ($link.data('cost')) {
            $('#viewAuditCost').text('£' + $link.data('cost'));
        } else {
            $('#viewAuditCost').html('<span class="text-muted">Not specified</span>');
        }
        
        if ($link.data('report-url')) {
            $('#viewAuditReport').html('<a href="' + $link.data('report-url') + '" target="_blank" rel="noopener noreferrer">View Report</a>');
        } else {
            $('#viewAuditReport').html('<span class="text-muted">Not provided</span>');
        }
        
        $('#viewAuditNotes').text($link.data('notes'));
        
        $('#viewAuditModal').modal('show');
    });
})();
</script>


