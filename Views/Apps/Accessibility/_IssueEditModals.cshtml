@model Compass.Models.AccessibilityIssue

<!-- Close Issue Modal -->
<div class="modal fade" id="closeIssueModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Close Issue</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="CloseIssue" method="post">
                <input type="hidden" id="closeIssueId" name="id" />
                <div class="modal-body">
                    <p class="mb-3">Close this issue by providing a closure date and explanation.</p>
                    
                    <div class="form-group">
                        <label for="closureDate">Date Closed *</label>
                        <input type="date" class="form-control" id="closureDate" name="closureDate" required value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        <small class="form-text text-muted">The date this issue was closed</small>
                    </div>

                    <div class="form-group">
                        <label for="closureExplanation">Closure Explanation *</label>
                        <textarea class="form-control preserve-formatting" id="closureExplanation" name="closureExplanation" rows="5" placeholder="Explain why this issue is being closed..." required></textarea>
                        <small class="form-text text-muted">Provide a clear explanation for closing this issue</small>
                    </div>

                    <div class="form-group">
                        <label for="changeNote">Change Note (Optional)</label>
                        <input type="text" class="form-control" id="changeNote" name="changeNote" placeholder="Optional note about this change..." />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Close Issue</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Request Retest Modal -->
<div class="modal fade" id="requestRetestModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Request Retest</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="RequestRetest" method="post">
                <input type="hidden" id="requestRetestIssueId" name="issueId" />
                <div class="modal-body">
                    <p class="mb-3">Submit a request for an administrator to retest this accessibility issue.</p>
                    
                    <div class="form-group">
                        <label for="requestorEmail">Your Email Address</label>
                        <input type="email" class="form-control" id="requestorEmail" name="requestorEmail" value="@User.Identity?.Name" />
                        <small class="form-text text-muted">Email address to receive retest confirmation and results</small>
                    </div>

                    <div class="form-group">
                        <label for="requestNotes">Notes (Optional)</label>
                        <textarea class="form-control" id="requestNotes" name="requestNotes" rows="3" placeholder="Any additional information about why you're requesting a retest..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">Submit Request</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Description Modal -->
<div class="modal fade" id="editDescriptionModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
