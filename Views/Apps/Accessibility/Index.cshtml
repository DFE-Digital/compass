@model IEnumerable<Compass.Models.ProductAccessibility>

@{
    ViewData["Title"] = "Accessibility Management";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <nav aria-label="Breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                        <li class="breadcrumb-item">Apps</li>
                        <li class="breadcrumb-item active" aria-current="page">Accessibility Issues and Statements</li>
                    </ol>
                </nav>
                <h1 class="m-0">Accessibility Issues and Statements</h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#enrollProductModal">
                        Enrol Product
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        @{
            var totalOpenIssues = Model.Sum(p => p.Issues.Count(i => i.Status != "resolved" && !i.IsDeleted));
            var totalResolvedIssues = Model.Sum(p => p.Issues.Count(i => i.Status == "resolved" && !i.IsDeleted));
            var totalVerifiedStatements = Model.Count(p => p.StatementInstalled && p.VerifiedAt.HasValue);
            var totalAuditSpend = Model.Sum(p => p.AuditHistories.Where(a => !a.IsDeleted && a.Cost.HasValue).Sum(a => a.Cost.Value));
        }

        <!-- Summary Cards -->
        <div class="row">
            <div class="col-lg-3 col-12">
                <div class="info-box">
                    <span class="info-box-icon bg-warning"><i class="fas fa-exclamation-triangle"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">Open Issues</span>
                        <span class="info-box-number">@totalOpenIssues</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-12">
                <div class="info-box">
                    <span class="info-box-icon bg-success"><i class="fas fa-check-circle"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">Resolved Issues</span>
                        <span class="info-box-number">@totalResolvedIssues</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-12">
                <div class="info-box">
                    <span class="info-box-icon bg-info"><i class="fas fa-file-contract"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">Verified Statements</span>
                        <span class="info-box-number">@totalVerifiedStatements / @Model.Count()</span>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-12">
                <div class="info-box">
                    <span class="info-box-icon bg-primary"><i class="fas fa-pound-sign"></i></span>
                    <div class="info-box-content">
                        <span class="info-box-text">Total Audit Spend</span>
                        <span class="info-box-number">£@totalAuditSpend.ToString("N2")</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Left Column: Filters -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Filters</h3>
                    </div>
                    <div class="card-body">
                        <form method="get" id="filterForm">
                            <div class="form-group">
                                <label>Search</label>
                                <input type="text" name="search" class="form-control form-control-sm" placeholder="Search products..." value="@ViewBag.CurrentSearch" />
                            </div>

                            <div class="form-group">
                                <label>Compliance Status</label>
                                <select name="status" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @if (ViewBag.CurrentStatus == "compliant")
                                    {
                                        <option value="compliant" selected>Compliant</option>
                                    }
                                    else
                                    {
                                        <option value="compliant">Compliant</option>
                                    }
                                    @if (ViewBag.CurrentStatus == "partially")
                                    {
                                        <option value="partially" selected>Partially Compliant</option>
                                    }
                                    else
                                    {
                                        <option value="partially">Partially Compliant</option>
                                    }
                                    @if (ViewBag.CurrentStatus == "non-compliant")
                                    {
                                        <option value="non-compliant" selected>Non-compliant</option>
                                    }
                                    else
                                    {
                                        <option value="non-compliant">Non-compliant</option>
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Issues</label>
                                <select name="issues" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @if (ViewBag.CurrentIssues == "with-issues")
                                    {
                                        <option value="with-issues" selected>With Open Issues</option>
                                    }
                                    else
                                    {
                                        <option value="with-issues">With Open Issues</option>
                                    }
                                    @if (ViewBag.CurrentIssues == "no-issues")
                                    {
                                        <option value="no-issues" selected>No Open Issues</option>
                                    }
                                    else
                                    {
                                        <option value="no-issues">No Open Issues</option>
                                    }
                                </select>
                            </div>
                            
                            <div class="form-group">
                                <label>Statement Status</label>
                                <select name="statement" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @if (ViewBag.CurrentStatement == "verified")
                                    {
                                        <option value="verified" selected>Verified</option>
                                    }
                                    else
                                    {
                                        <option value="verified">Verified</option>
                                    }
                                    @if (ViewBag.CurrentStatement == "not-verified")
                                    {
                                        <option value="not-verified" selected>Not Verified</option>
                                    }
                                    else
                                    {
                                        <option value="not-verified">Not Verified</option>
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <button type="submit" class="btn btn-primary btn-sm btn-block">Apply Filters</button>
                                <a asp-action="Index" class="btn btn-default btn-sm btn-block">Clear All Filters</a>
                            </div>
                        </form>
                        
                        @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch?.ToString()) || 
                             !string.IsNullOrEmpty(ViewBag.CurrentStatus?.ToString()) || 
                             !string.IsNullOrEmpty(ViewBag.CurrentIssues?.ToString()) || 
                             !string.IsNullOrEmpty(ViewBag.CurrentStatement?.ToString()))
                        {
                            <div class="mt-3 pt-3 border-top">
                                <strong class="d-block mb-2">Active Filters:</strong>
                                @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch?.ToString()))
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <strong>Search:</strong> @ViewBag.CurrentSearch
                                        <a href="@Url.Action("Index", new { status = ViewBag.CurrentStatus, issues = ViewBag.CurrentIssues, statement = ViewBag.CurrentStatement })" class="text-danger" title="Remove filter">
                                            <i class="fas fa-times"></i>
                                        </a>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(ViewBag.CurrentStatus?.ToString()))
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <strong>Status:</strong> @ViewBag.CurrentStatus
                                        <a href="@Url.Action("Index", new { search = ViewBag.CurrentSearch, issues = ViewBag.CurrentIssues, statement = ViewBag.CurrentStatement })" class="text-danger" title="Remove filter">
                                            <i class="fas fa-times"></i>
                                        </a>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(ViewBag.CurrentIssues?.ToString()))
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <strong>Issues:</strong> @ViewBag.CurrentIssues
                                        <a href="@Url.Action("Index", new { search = ViewBag.CurrentSearch, status = ViewBag.CurrentStatus, statement = ViewBag.CurrentStatement })" class="text-danger" title="Remove filter">
                                            <i class="fas fa-times"></i>
                                        </a>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(ViewBag.CurrentStatement?.ToString()))
                                {
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <strong>Statement:</strong> @ViewBag.CurrentStatement
                                        <a href="@Url.Action("Index", new { search = ViewBag.CurrentSearch, status = ViewBag.CurrentStatus, issues = ViewBag.CurrentIssues })" class="text-danger" title="Remove filter">
                                            <i class="fas fa-times"></i>
                                        </a>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Right Column: Products Table -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Enrolled Products (@Model.Count())</h3>
                    </div>
                    <div class="card-body table-responsive p-0">
                        @if (Model.Any())
                        {
                            <table class="table table-hover text-nowrap">
                                <thead>
                                    <tr>
                                        <th>Product Name</th>
                                        <th>FIPS ID</th>
                                        <th>Compliance Status</th>
                                        <th>Open Issues</th>
                                        <th>Last Audit</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var product in Model.OrderBy(p => p.ProductName))
                                    {
                                        var openIssues = product.Issues.Count(i => i.Status != "resolved" && !i.IsDeleted);
                                        var totalIssues = product.Issues.Count(i => !i.IsDeleted);
                                        var levelAAIssues = product.Issues.Count(i => !i.IsDeleted && (i.WcagLevel == "A" || i.WcagLevel == "AA") && i.Status != "resolved");
                                        
                                        var complianceStatus = "compliant";
                                        var complianceBadge = "badge-success";
                                        
                                        if (levelAAIssues > 0)
                                        {
                                            complianceStatus = "non-compliant";
                                            complianceBadge = "badge-danger";
                                        }
                                        else if (openIssues > 0)
                                        {
                                            complianceStatus = "partially compliant";
                                            complianceBadge = "badge-warning";
                                        }
                                        
                                        var lastAudit = product.AuditHistories.Where(a => !a.IsDeleted).OrderByDescending(a => a.AuditDate).FirstOrDefault();
                                        
                                        <tr>
                                            <td>
                                                <a href="@Url.Action("Details", new { fipsId = product.FipsId })">
                                                    <strong>@product.ProductName</strong>
                                                </a>
                                            </td>
                                            <td><span class="badge badge-info">@product.FipsId</span></td>
                                         
                                            <td>
                                                <span class="badge @complianceBadge">
                                                    @complianceStatus
                                                </span>
                                            </td>
                                            <td>
                                                @if (openIssues > 0)
                                                {
                                                    <span class="badge badge-warning">@openIssues open</span>
                                                    if (levelAAIssues > 0)
                                                    {
                                                        <small class="text-danger ml-1">(@levelAAIssues Level A/AA)</small>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">None</span>
                                                }
                                            </td>
                                           
                                            <td>
                                                @if (lastAudit != null)
                                                {
                                                    <small class="text-muted">
                                                        @lastAudit.AuditDate.ToString("dd MMM yyyy")<br>
                                                        <span class="badge badge-@(lastAudit.AuditType == "External" ? "primary" : "secondary")">@lastAudit.AuditType</span>
                                                    </small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">None</span>
                                                }
                                            </td>
                                           
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="text-center p-4">
                                <p class="text-muted">No products enrolled in accessibility management.</p>
                                <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#enrollProductModal">
                                    Enrol First Product
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Enroll Product Modal -->
<div class="modal fade" id="enrollProductModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Enrol Product</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="Enroll" method="get">
                <div class="modal-body">
                    <div class="form-group">
                        <label for="productSearch">Search for Product</label>
                        <input type="text" class="form-control product-autocomplete" id="productSearch" placeholder="Start typing product name, phase, or FIPS ID..." autocomplete="off" />
                        <small class="form-text text-muted">Search by product name, FIPS ID, or phase</small>
                    </div>
                    <div id="selectedProductDisplay" class="alert alert-success mt-3 d-none">
                        <strong>Selected Product:</strong><br>
                        <div id="selectedProductTitle"></div>
                        <small class="text-muted" id="selectedProductDetails"></small>
                    </div>
                    <input type="hidden" name="fipsId" id="selectedProductFipsId" />
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="enrollProductSubmitBtn" disabled>Continue to Enrol</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
(function() {
    var searchTimeout = null;
    var enrolledFipsIds = [@Html.Raw(string.Join(",", Model.Select(p => $"'{p.FipsId}'")))];

    function initEnrollProduct() {
        // Initialize product autocomplete
        var $input = $('#productSearch');
        var $resultsContainer = $('<div class="autocomplete-results"></div>');
        $input.after($resultsContainer);

        // Handle input with debounce
        $input.on('input', function() {
            clearTimeout(searchTimeout);
            var searchTerm = $(this).val();

            if (searchTerm.length < 2) {
                $resultsContainer.addClass('d-none').empty();
                $('#selectedProductDisplay').addClass('d-none');
                $('#enrollProductSubmitBtn').prop('disabled', true);
                return;
            }

            searchTimeout = setTimeout(function() {
                $.ajax({
                    url: '/api/products/search',
                    data: { q: searchTerm },
                    dataType: 'json',
                    success: function(data) {
                        displayProductResults(data.results, $resultsContainer);
                    },
                    error: function(xhr, status, error) {
                        console.error('Failed to search products:', status, error);
                        $resultsContainer.html('<div class="autocomplete-item no-results">Error searching products</div>');
                        $resultsContainer.removeClass('d-none');
                    }
                });
            }, 300);
        });

        // Hide results when clicking outside
        $(document).on('click', function(e) {
            if (!$(e.target).closest('.product-autocomplete').length && 
                !$(e.target).closest('.autocomplete-results').length) {
                $resultsContainer.addClass('d-none');
            }
        });

        // Keyboard navigation
        $input.on('keydown', function(e) {
            var $items = $resultsContainer.find('.autocomplete-item:not(.no-results):not(.disabled)');
            var $selected = $items.filter('.selected');

            if (!$resultsContainer.is(':visible') || $items.length === 0) {
                return;
            }

            if (e.key === 'ArrowDown') {
                e.preventDefault();
                if ($selected.length === 0) {
                    $items.first().addClass('selected');
                } else {
                    $selected.removeClass('selected');
                    var $next = $selected.next('.autocomplete-item:not(.disabled)');
                    if ($next.length) {
                        $next.addClass('selected');
                    } else {
                        $items.first().addClass('selected');
                    }
                }
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                if ($selected.length === 0) {
                    $items.last().addClass('selected');
                } else {
                    $selected.removeClass('selected');
                    var $prev = $selected.prev('.autocomplete-item:not(.disabled)');
                    if ($prev.length) {
                        $prev.addClass('selected');
                    } else {
                        $items.last().addClass('selected');
                    }
                }
            } else if (e.key === 'Enter') {
                if ($selected.length) {
                    e.preventDefault();
                    $selected.click();
                }
            } else if (e.key === 'Escape') {
                e.preventDefault();
                $resultsContainer.addClass('d-none');
            }
        });

        // Clear modal when closed
        $('#enrollProductModal').on('hidden.bs.modal', function() {
            $input.val('');
            $resultsContainer.addClass('d-none').empty();
            $('#selectedProductDisplay').addClass('d-none');
            $('#selectedProductFipsId').val('');
            $('#enrollProductSubmitBtn').prop('disabled', true);
        });
    }

    function displayProductResults(results, $resultsContainer) {
        $resultsContainer.empty();

        if (!results || results.length === 0) {
            $resultsContainer.html('<div class="autocomplete-item no-results">No products found</div>');
            $resultsContainer.removeClass('d-none');
            return;
        }

        results.forEach(function(product) {
            var isEnrolled = enrolledFipsIds.includes(product.fipsId);
            var $item = $('<div class="autocomplete-item"></div>');
            
            if (isEnrolled) {
                $item.addClass('disabled');
            }
            
            $item.html(
                '<div class="autocomplete-name">' + product.title + 
                (isEnrolled ? ' <span class="badge badge-success ml-2">Already enrolled</span>' : '') + 
                '</div>' +
                '<div class="autocomplete-details">' + product.fipsId + ' • ' + product.phase + '</div>'
            );

            if (!isEnrolled) {
                $item.on('click', function() {
                    selectProduct(product);
                    $resultsContainer.addClass('d-none').empty();
                });
            }

            $resultsContainer.append($item);
        });

        $resultsContainer.removeClass('d-none');
    }

    function selectProduct(product) {
        $('#productSearch').val(product.title);
        $('#selectedProductFipsId').val(product.fipsId);
        $('#selectedProductTitle').text(product.title);
        $('#selectedProductDetails').text(product.fipsId + ' • ' + product.phase);
        $('#selectedProductDisplay').removeClass('d-none');
        $('#enrollProductSubmitBtn').prop('disabled', false);
    }

    if (typeof jQuery !== 'undefined') {
        $(document).ready(initEnrollProduct);
    } else {
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof jQuery !== 'undefined') {
                $(document).ready(initEnrollProduct);
            }
        });
    }
})();
</script>

