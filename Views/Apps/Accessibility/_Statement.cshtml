@model Compass.Models.ProductAccessibility

@{
    var statementUrl = $"https://accessibility-statements.education.gov.uk/s/{Model.FipsId}";
    var cmsProduct = ViewBag.CmsProduct as Compass.Models.ProductDto;
    var hasProductUrl = cmsProduct != null && !string.IsNullOrWhiteSpace(cmsProduct.ProductUrl);
    var isNotVerified = !(Model.StatementInstalled && Model.VerifiedAt.HasValue);
    var showProductUrlAlert = !hasProductUrl && isNotVerified;
}

<div class="row">
    <div class="col-12">
        @if (showProductUrlAlert)
        {
            <div class="alert alert-warning mb-4">
                <strong>Product URL Required:</strong> You must update the Product URL before you can verify your statement is installed correctly.
            </div>
        }
        <!-- Statement URL -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Accessibility Statement</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-borderless mb-0 settings-table">
                    <tbody>
                        <tr>
                            <td class="summary-label"><strong>Product URL</strong></td>
                            <td class="summary-value">
                                @if (hasProductUrl)
                                {
                                    <a href="@cmsProduct.ProductUrl" target="_blank" rel="noopener noreferrer">@cmsProduct.ProductUrl</a>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                    <br>
                                    <small class="text-muted">Product URL is required for automatic verification</small>
                                }
                            </td>
                            <td class="summary-action text-right">
                                <a href="#" data-toggle="modal" data-target="#updateProductUrlModal">
                                    @(hasProductUrl ? "Change" : "Add") URL
                                </a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Statement URL</strong></td>
                            <td class="summary-value">
                                <a href="@statementUrl" target="_blank" rel="noopener noreferrer">@statementUrl</a>
                            </td>
                            <td class="summary-action text-right">
                                
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Installation status</strong></td>
                            <td class="summary-value">
                                @if (Model.StatementInstalled && Model.VerifiedAt.HasValue)
                                {
                                    <span class="badge badge-success">Verified</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger">Not verified</span>
                                }
                            </td>
                            <td class="summary-action text-right">
                                @if (User.IsInRole("AccessibilityAdministrator") || User.IsInRole("Admin") || User.IsInRole("Super admin"))
                                {
                                    @if (Model.StatementInstalled && Model.VerifiedAt.HasValue)
                                    {
                                        <a href="#" data-toggle="modal" data-target="#verifyStatementModal">Change</a>
                                    }
                                    else if (showProductUrlAlert)
                                    {
                                        <a href="#" data-toggle="modal" data-target="#updateProductUrlModal">Update product URL</a>
                                    }
                                    else
                                    {
                                        <a href="#" data-toggle="modal" data-target="#verifyStatementModal">Verify installation</a>
                                    }
                                }
                                else
                                {
                                    @if (showProductUrlAlert)
                                    {
                                        <a href="#" data-toggle="modal" data-target="#updateProductUrlModal">Update product URL</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
        
        <!-- Installation Instructions -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Installation Instructions</h3>
            </div>
            <div class="card-body">
                <p class="mb-4"><strong>Follow these steps to install the accessibility statement on your website:</strong></p>
                
                <!-- Timeline/Steps -->
                <div class="timeline-steps">
                    <div class="step-item mb-4">
                        <div class="step-number">1</div>
                        <div class="step-content">
                            <h5 class="mb-2">Locate your website footer</h5>
                            <p class="mb-0 text-muted">Navigate to the footer section of your website where accessibility links are typically placed.</p>
                        </div>
                    </div>
                    
                    <div class="step-item mb-4">
                        <div class="step-number">2</div>
                        <div class="step-content">
                            <h5 class="mb-2">Find or create the Accessibility link</h5>
                            <p class="mb-0 text-muted">Look for an existing "Accessibility" link in the footer. If one doesn't exist, create a new link.</p>
                        </div>
                    </div>
                    
                    <div class="step-item mb-4">
                        <div class="step-number">3</div>
                        <div class="step-content">
                            <h5 class="mb-2">Update the link URL</h5>
                            <p class="mb-0 text-muted">Replace the existing link URL (or set the new link URL) to:</p>
                            <div class="mt-2 mb-2">
                                <code class="p-2 bg-light d-block">@statementUrl</code>
                            </div>
                        </div>
                    </div>
                    
                    <div class="step-item mb-4">
                        <div class="step-number">4</div>
                        <div class="step-content">
                            <h5 class="mb-2">Set the link text</h5>
                            <p class="mb-0 text-muted">Ensure the link text reads "Accessibility" or "Accessibility Statement".</p>
                        </div>
                    </div>
                    
                    <div class="step-item mb-4">
                        <div class="step-number">5</div>
                        <div class="step-content">
                            <h5 class="mb-2">Publish your changes</h5>
                            <p class="mb-0 text-muted">Save and publish your changes so the accessibility statement is live on your website.</p>
                        </div>
                    </div>
                    
                    <div class="step-item mb-4">
                        <div class="step-number">6</div>
                        <div class="step-content">
                            <h5 class="mb-2">Request verification</h5>
                            <p class="mb-0 text-muted">Once the statement is installed and live, request verification from an administrator.</p>
                            <button type="button" 
                                    class="btn btn-primary btn-sm mt-2" 
                                    data-toggle="modal" 
                                    data-target="#requestVerificationModal">
                                <i class="fas fa-check-circle mr-1"></i>Request Verification
                            </button>
                        </div>
                    </div>
                </div>
                
                <div class="alert alert-info mt-4">
                    <strong>Note:</strong> Once the statement is installed, an Accessibility Administrator must verify it before it's marked as compliant.
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.timeline-steps {
    position: relative;
    padding-left: 0;
}

.step-item {
    display: flex;
    align-items: flex-start;
    position: relative;
}

.step-item:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 20px;
    top: 50px;
    width: 2px;
    height: calc(100% - 20px);
    background-color: #dee2e6;
}

.step-number {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: #005ea5;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 1.1rem;
    margin-right: 1.5rem;
    position: relative;
    z-index: 1;
}

.step-content {
    flex: 1;
    padding-top: 0.5rem;
}

.step-content h5 {
    color: #0b0c0c;
    font-weight: 600;
}
</style>

<!-- Request Verification Modal -->
<div class="modal fade" id="requestVerificationModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Request Verification</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="RequestVerification" method="post">
                @{
                    var productDocId = Model?.ProductDocumentId ?? Model?.FipsId ?? "";
                }
                <input type="hidden" name="documentId" value="@productDocId" />
                <div class="modal-body">
                    <p class="mb-3">Submit a request for an administrator to verify that your accessibility statement is correctly installed on your website.</p>
                    
                    <div class="alert alert-info">
                        <strong>Statement URL:</strong><br>
                        <code>@statementUrl</code>
                    </div>
                    
                    <div class="form-group">
                        <label for="verificationRequestNotes">Notes (Optional)</label>
                        <textarea class="form-control" id="verificationRequestNotes" name="requestNotes" rows="3" placeholder="Any additional information about the installation..."></textarea>
                        <small class="form-text text-muted">Provide any details that might help the administrator verify the installation.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success">Submit Request</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Update Product URL Modal -->
@{
    var cmsProductForModal = ViewBag.CmsProduct as Compass.Models.ProductDto;
    var hasProductUrlForModal = cmsProductForModal != null && !string.IsNullOrWhiteSpace(cmsProductForModal.ProductUrl);
}
<div class="modal fade" id="updateProductUrlModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@(hasProductUrlForModal ? "Update" : "Add") Product URL</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form action="/Admin/AccessibilityService/UpdateProductUrl" method="post">
                @{
                    var productDocId = Model?.ProductDocumentId ?? Model?.FipsId ?? "";
                }
                <input type="hidden" name="documentId" value="@productDocId" />
                <div class="modal-body">
                    <p class="mb-3">The Product URL is required for automatic verification. It should be the main URL of the product website.</p>
                    <p class="mb-3">The FIPS entry will be updated with the new Product URL immediately.</p>
                    <div class="form-group">
                        <label for="productUrl" class="form-label">Product URL *</label>
                        <input type="url" 
                               class="form-control" 
                               id="productUrl" 
                               name="productUrl" 
                               value="@cmsProductForModal?.ProductUrl"
                               placeholder="https://example.gov.uk" 
                               required />
                        <small class="form-text text-muted">
                            Enter the main URL of the product website (must start with http:// or https://)
                        </small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success">Save Product URL</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Verify Statement Installation Modal (Accessibility Administrators only) -->
@if (User.IsInRole("AccessibilityAdministrator") || User.IsInRole("Admin") || User.IsInRole("Super admin"))
{
    <div class="modal fade" id="verifyStatementModal" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Verify Statement Installation</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <form action="/Admin/AccessibilityService/VerifyStatement" method="post">
                    @{
                    var productDocId = Model?.ProductDocumentId ?? Model?.FipsId ?? "";
                }
                <input type="hidden" name="documentId" value="@productDocId" />
                    <input type="hidden" name="statementInstalled" value="true" />
                    <div class="modal-body">
                        <p>Please confirm that you have checked the product website and verified that the accessibility statement is correctly installed in the footer with the URL:</p>
                        
                        <div class="alert alert-info">
                            <strong>Statement URL:</strong><br>
                            <code>@statementUrl</code>
                        </div>
                        
                        @if (!hasProductUrlForModal)
                        {
                            <div class="alert alert-warning">
                                <strong>Product URL Required:</strong> A Product URL must be set before automatic verification can proceed. 
                                Please add a Product URL first.
                            </div>
                        }
                        
                        <div class="form-group">
                            <label>Verification Method *</label>
                            <select class="form-control" name="verificationMethod" id="verificationMethodSelect" required>
                                <option value="">— Select method —</option>
                                <option value="Manual">Manual</option>
                                @if (hasProductUrlForModal)
                                {
                                    <option value="Automatic">Automatic</option>
                                }
                                else
                                {
                                    <option value="Automatic" disabled>Automatic</option>
                                }
                            </select>
                            <small class="form-text text-muted">
                                @if (!hasProductUrlForModal)
                                {
                                    <span class="text-danger">Automatic verification requires a Product URL to be set first.</span>
                                }
                                else
                                {
                                    <span>Select whether the verification was done manually by an administrator or automatically by checking the product website.</span>
                                }
                            </small>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success" id="verifySubmitBtn" @(!hasProductUrlForModal ? "disabled" : "")>Save Verification</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
