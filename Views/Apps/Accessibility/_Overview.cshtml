@model Compass.Models.ProductAccessibility

@{
    var cmsProduct = ViewBag.CmsProduct as Compass.Models.ProductDto;
    var productDocumentId = Model?.ProductDocumentId ?? Model?.FipsId ?? cmsProduct?.DocumentId ?? cmsProduct?.FipsId ?? "";
    var openIssues = Model.Issues.Count(i => i.Status != "resolved" && !i.IsDeleted);
    var resolvedIssues = Model.Issues.Count(i => i.Status == "resolved" && !i.IsDeleted);
    var totalIssues = Model.Issues.Count(i => !i.IsDeleted);
    
    // Get compliance status from ViewBag (calculated in controller)
    var complianceStatus = ViewBag.ComplianceStatus as string ?? "Compliant";
    var complianceBadge = ViewBag.ComplianceBadge as string ?? "badge-success";
    var complianceBgClass = ViewBag.ComplianceBgClass as string ?? "bg-success";
    
    var statementStatus = (Model.StatementInstalled && Model.VerifiedAt.HasValue) ? "Verified" : "Not Verified";
    var statementBgClass = (Model.StatementInstalled && Model.VerifiedAt.HasValue) ? "bg-success" : "bg-warning";
}

<!-- Summary Cards -->
<div class="row mb-4">
    <div class="col-md-4 mb-3">
        @{
            var complianceBorderClass = complianceStatus == "Compliant" ? "border-left-success" : (complianceStatus == "Partially Compliant" ? "border-left-warning" : "border-left-danger");
        }
        <div class="card @complianceBorderClass shadow h-100">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-uppercase mb-1" style="color: @(complianceStatus == "Compliant" ? "#1cc88a" : complianceStatus == "Partially Compliant" ? "#f6c23e" : "#e74a3b");">Compliance Status</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@complianceStatus</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-clipboard-check fa-2x text-gray-300"></i>
                    </div>
                </div>
                <div class="mt-3 pt-3 border-top">
                    <a href="@Url.Action("Details", new { documentId = productDocumentId, tab = "settings" })" class="text-xs text-muted">View settings <i class="fas fa-arrow-circle-right"></i></a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        @{
            var issuesBorderClass = openIssues == 0 ? "border-left-success" : (openIssues < 5 ? "border-left-warning" : "border-left-danger");
            var issuesTextClass = openIssues == 0 ? "text-success" : (openIssues < 5 ? "text-warning" : "text-danger");
        }
        <div class="card @issuesBorderClass shadow h-100">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-uppercase mb-1" style="color: @(openIssues == 0 ? "#1cc88a" : openIssues < 5 ? "#f6c23e" : "#e74a3b");">Open Issues</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@openIssues</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas @(openIssues == 0 ? "fa-check-circle" : openIssues < 5 ? "fa-exclamation-triangle" : "fa-times-circle") fa-2x text-gray-300"></i>
                    </div>
                </div>
                <div class="mt-3 pt-3 border-top">
                    <a href="@Url.Action("Details", new { documentId = productDocumentId, tab = "issues" })" class="text-xs text-muted">View issues <i class="fas fa-arrow-circle-right"></i></a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        @{
            var statementBorderClass = statementStatus == "Verified" ? "border-left-success" : "border-left-warning";
        }
        <div class="card @statementBorderClass shadow h-100">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-uppercase mb-1" style="color: @(statementStatus == "Verified" ? "#1cc88a" : "#f6c23e");">Statement Status</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@statementStatus</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-file-contract fa-2x text-gray-300"></i>
                    </div>
                </div>
                <div class="mt-3 pt-3 border-top">
                    <a href="@Url.Action("Details", new { documentId = productDocumentId, tab = "statement" })" class="text-xs text-muted">View statement <i class="fas fa-arrow-circle-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .border-left-primary {
        border-left: 0.25rem solid #4e73df !important;
    }
    .border-left-success {
        border-left: 0.25rem solid #1cc88a !important;
    }
    .border-left-warning {
        border-left: 0.25rem solid #f6c23e !important;
    }
    .border-left-danger {
        border-left: 0.25rem solid #e74a3b !important;
    }
    .text-xs {
        font-size: 0.7rem;
    }
    .text-gray-300 {
        color: #dddfeb !important;
    }
    .text-gray-800 {
        color: #5a5c69 !important;
    }
    .shadow {
        box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15) !important;
    }
</style>

<div class="row">
    <!-- Left Column -->
    <div class="col-lg-8">
        <!-- Product Summary -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Product Summary</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-borderless mb-0 project-overview-summary">
                    <tbody>
                        <tr>
                            <td class="summary-label"><strong>Compliance Status</strong></td>
                            <td class="summary-value">
                                <span class="badge @complianceBadge">@complianceStatus</span>
                            </td>
                            <td>
                              
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>WCAG Compliance Level</strong></td>
                            <td class="summary-value">WCAG @Model.WcagVersion Level @Model.WcagLevel</td>
                            <td>
                              
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Enrolled</strong></td>
                            <td class="summary-value">@Model.EnrolledAt.ToString("dd MMM yyyy") by @Model.EnrolledBy</td>
                            <td>
                              
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Product URL</strong></td>
                            <td class="summary-value">
                                @if (cmsProduct != null && !string.IsNullOrWhiteSpace(cmsProduct.ProductUrl))
                                {
                                    <a href="@cmsProduct.ProductUrl" target="_blank" rel="noopener noreferrer">@cmsProduct.ProductUrl</a>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                              <td>
                               
                                    <a href="@Url.Action("Details", new { documentId = productDocumentId, tab = "statement" })">Manage</a>
                              
                               
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Installation status</strong></td>
                            <td class="summary-value">
                                @if (Model.StatementInstalled && Model.VerifiedAt.HasValue)
                                {
                                    <span class="badge badge-success">Verified</span>
                                }
                                else
                                {
                                    <span class="badge badge-danger">Not verified</span>
                                }
                            </td>
                            <td>
                               
                                    <a href="@Url.Action("Details", new { documentId = productDocumentId, tab = "statement" })">Manage</a>
                               
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Recent Changes to Issues -->
        <div class="card collapsed-card mb-4">
            <div class="card-header">
                <h3 class="card-title">Recent Changes to Issues</h3>
              <div class="card-tools">
                  <button type="button" class="btn btn-tool" style="color: black !important;" data-card-widget="collapse"><i class="fas fa-plus"></i>
                  </button>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                @{
                    // Get all issue activities (created, updated, resolved)
                    var recentActivities = new List<dynamic>();
                    
                    // Added issues
                    foreach (var issue in Model.Issues.Where(i => !i.IsDeleted))
                    {
                        recentActivities.Add(new {
                            Date = issue.CreatedAt,
                            Type = "Added",
                            TypeClass = "badge-info",
                            WcagCriteria = issue.WcagCriteria,
                            WcagLevel = issue.WcagLevel,
                            Status = issue.Status,
                            Description = $"Issue added for WCAG {issue.WcagCriteria}",
                            User = issue.CreatedBy
                        });
                    }
                    
                    // Resolved issues
                    foreach (var issue in Model.Issues.Where(i => !i.IsDeleted && i.Status == "resolved" && i.ActualResolutionDate.HasValue))
                    {
                        recentActivities.Add(new {
                            Date = issue.ActualResolutionDate.Value,
                            Type = "Resolved",
                            TypeClass = "badge-success",
                            WcagCriteria = issue.WcagCriteria,
                            WcagLevel = issue.WcagLevel,
                            Status = issue.Status,
                            Description = $"Issue resolved for WCAG {issue.WcagCriteria}",
                            User = issue.UpdatedBy
                        });
                    }
                    
                    // Updated issues from history
                    foreach (var issue in Model.Issues.Where(i => !i.IsDeleted))
                    {
                        foreach (var history in issue.History.OrderByDescending(h => h.ChangedAt).Take(1))
                        {
                            recentActivities.Add(new {
                                Date = history.ChangedAt,
                                Type = "Edited",
                                TypeClass = "badge-warning",
                                WcagCriteria = issue.WcagCriteria,
                                WcagLevel = issue.WcagLevel,
                                Status = issue.Status,
                                Description = $"Issue edited: {history.FieldChanged} changed",
                                User = history.ChangedBy
                            });
                        }
                    }
                    
                    var sortedActivities = recentActivities.OrderByDescending(a => a.Date).Take(10).ToList();
                }
                
                @if (sortedActivities.Any())
                {
                    <table class="table table-hover text-nowrap sortable-table mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Change Type</th>
                                <th>WCAG Criteria</th>
                                <th>Level</th>
                                <th>Description</th>
                                <th>By</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var activity in sortedActivities)
                            {
                                <tr>
                                    <td>@activity.Date.ToString("dd MMM yyyy")</td>
                                    <td><span class="badge @activity.TypeClass">@activity.Type</span></td>
                                    <td><strong>@activity.WcagCriteria</strong></td>
                                    <td><span class="badge badge-@(activity.WcagLevel == "AAA" ? "primary" : activity.WcagLevel == "AA" ? "info" : "secondary")">@activity.WcagLevel</span></td>
                                    <td>@activity.Description</td>
                                    <td><small class="text-muted">@(activity.User ?? "System")</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center p-4">
                        <p class="text-muted">No recent issue changes.</p>
                    </div>
                }
            </div>
        </div>
    </div>
    
    <!-- Right Column -->
    <div class="col-lg-4">
        <!-- Recent Audits -->
        @if (Model.AuditHistories.Any(a => !a.IsDeleted))
        {
            <div class="card mb-4">
                <div class="card-header">
                    <h3 class="card-title">Recent Audits</h3>
                    <div class="card-tools">
                        <a asp-action="Details" asp-route-documentId="@productDocumentId" asp-route-tab="audits">View all audits</a>
                    </div>
                </div>
                <div class="card-body p-0">
                    <table class="table table-borderless mb-0 project-overview-summary">
                        <tbody>
                            @foreach (var audit in Model.AuditHistories.Where(a => !a.IsDeleted).OrderByDescending(a => a.AuditDate).Take(3))
                            {
                                <tr>
                                    <td class="summary-label"><strong>@audit.AuditDate.ToString("dd MMM yyyy")</strong></td>
                                    <td class="summary-value">
                                        <span class="badge badge-@(audit.AuditType == "External" ? "primary" : "secondary")">@audit.AuditType</span>
                                    </td>
                                </tr>
                                @if (audit.Cost.HasValue)
                                {
                                    <tr>
                                        <td class="summary-label"><strong>Cost</strong></td>
                                        <td class="summary-value">£@audit.Cost.Value.ToString("N2")</td>
                                    </tr>
                                }
                                <tr>
                                    <td class="summary-label"><strong>Audited By</strong></td>
                                    <td class="summary-value"><small class="text-muted">@audit.AuditedBy</small></td>
                                </tr>
                                @if (audit != Model.AuditHistories.Where(a => !a.IsDeleted).OrderByDescending(a => a.AuditDate).Take(3).Last())
                                {
                                    <tr>
                                        <td colspan="2"><hr class="my-2"></td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>


