@{
    var recent = ViewBag.Recent as IEnumerable<dynamic> ?? new List<dynamic>();
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Recent responses (@recent.Count())</h3>
    </div>
    <div class="card-body table-responsive p-0">
        @if (recent.Any())
        {
            <table class="table table-hover text-nowrap">
                <thead>
                    <tr>
                        <th>Submitted</th>
                        <th>Channel</th>
                        <th>Region</th>
                        <th>USS</th>
                        <th>Band</th>
                        <th>Comment</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in recent)
                    {
                        <tr>
                            <td>@(((DateTime)r.SubmittedUtc).ToString("yyyy-MM-dd HH:mm"))</td>
                            <td>@(r.Channel ?? "—")</td>
                            <td>@(r.GeoRegion ?? "—")</td>
                            <td>@r.UssComputed</td>
                            <td>@(r.Band ?? "—")</td>
                            <td>@(string.IsNullOrWhiteSpace((string)r.FreeText) ? "—" : r.FreeText)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center p-4">
                <p class="text-muted">No responses yet.</p>
            </div>
        }
    </div>
</div>


