@{
    ViewData["Title"] = "Enrol Product";
    var fipsId = ViewBag.FipsId as string;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <nav aria-label="Breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Apps")">Apps</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "UserSatisfactionSurveys")">User satisfaction surveys</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Enrol Product</li>
                    </ol>
                </nav>
                <h1 class="m-0">Enrol Product</h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <a href="@Url.Action("Index", "UserSatisfactionSurveys")" class="btn btn-secondary">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-lg-8 offset-lg-2">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Product Enrollment</h3>
                    </div>
                    <div class="card-body">
                        @{ var product = ViewBag.Product as Compass.Models.ProductDto; }
                        @if (product != null)
                        {
                            <dl class="row">
                                <dt class="col-sm-3">Product</dt>
                                <dd class="col-sm-9">@product.Title</dd>
                                <dt class="col-sm-3">Phase</dt>
                                <dd class="col-sm-9">@(product.Phase ?? "—")</dd>
                                <dt class="col-sm-3">Business area</dt>
                                <dd class="col-sm-9">@(ViewBag.BusinessArea ?? "—")</dd>
                                <dt class="col-sm-3">FIPS ID</dt>
                                <dd class="col-sm-9">@fipsId</dd>
                            </dl>
                        }
                        else
                        {
                            <p class="mb-3">This product is not yet enrolled in the User Satisfaction Service.</p>
                        }
                        <form method="post" action="@Url.Action("Enroll", "UserSatisfactionSurveys")">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="fipsId" value="@fipsId" />
                            <button type="submit" class="btn btn-primary">Enrol Product</button>
                            <a href="@Url.Action("Index", "UserSatisfactionSurveys")" class="btn btn-secondary ml-2">Back to Products</a>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


