@{
    var fipsId = ViewBag.FipsId as string ?? "";
    var productTitle = ViewBag.ProductTitle as string ?? fipsId;
    var link = $"https://user-satisfaction.education.gov.uk/{fipsId}";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Share this link</h3>
    </div>
    <div class="card-body">
        <div class="alert alert-primary">
            <strong>@link</strong>
        </div>
        <p class="mb-3">Use this URL to invite users to complete the user satisfaction survey.</p>
        <ul>
            <li><strong>Completion pages</strong>: add the link to the confirmation/thank-you page after a journey completes.</li>
            <li><strong>Emails</strong>: include the link in completion or follow-up emails for transactions.</li>
            <li><strong>Support portals</strong>: surface the link in support or feedback areas after a task is finished.</li>
        </ul>
        <p class="mb-0 text-muted">Ensure the link is clearly labelled (e.g., “Give feedback on this service”).</p>
    </div>
</div>


