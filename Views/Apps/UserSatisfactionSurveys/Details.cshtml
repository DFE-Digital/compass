@{
    var currentTab = ViewBag.CurrentTab as string ?? "overview";
    var fipsId = ViewBag.FipsId as string ?? "";
    var displayName = (ViewBag.ProductTitle as string) ?? (ViewBag.DisplayName as string) ?? fipsId;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <nav aria-label="Breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Apps")">Apps</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "UserSatisfactionSurveys")">User satisfaction surveys</a></li>
                        <li class="breadcrumb-item active" aria-current="page">@displayName</li>
                    </ol>
                </nav>
                <h1 class="m-0">@displayName</h1>
                <p class="text-muted mb-0">@fipsId</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <!-- Left Navigation -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Navigation</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <a href="@Url.Action("Details", new { fipsId = fipsId, tab = "overview" })" class="list-group-item list-group-item-action @(currentTab == "overview" ? "active" : "")">Overview</a>
                            <a href="@Url.Action("Details", new { fipsId = fipsId, tab = "responses" })" class="list-group-item list-group-item-action @(currentTab == "responses" ? "active" : "")">Responses</a>
                            <a href="@Url.Action("Details", new { fipsId = fipsId, tab = "survey" })" class="list-group-item list-group-item-action @(currentTab == "survey" ? "active" : "")">Survey link</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Content -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                @switch (currentTab)
                {
                    case "responses":
                        @Html.Partial("~/Views/Apps/UserSatisfactionSurveys/_DetailsResponses.cshtml")
                        break;
                    case "survey":
                        @Html.Partial("~/Views/Apps/UserSatisfactionSurveys/_SurveyLink.cshtml")
                        break;
                    default:
                        @Html.Partial("~/Views/Apps/UserSatisfactionSurveys/_DetailsOverview.cshtml")
                        break;
                }
            </div>
        </div>
    </div>
</section>


