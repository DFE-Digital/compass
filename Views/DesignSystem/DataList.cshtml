@{
    ViewData["Title"] = "Data List - Design System";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="/">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "DesignSystem")">Design system</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active" aria-current="page">Data list</li>
        </ol>
    </nav>
}

<h1 class="ds-page-title">Data list</h1>
<p class="ds-page-lead">
    Data lists display information in a structured list format.
</p>

<h2>Simple list</h2>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <ul class="list-group">
        <li class="list-group-item">Item 1</li>
        <li class="list-group-item">Item 2</li>
        <li class="list-group-item">Item 3</li>
    </ul>
</div>

<h2>List with actions</h2>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <ul class="list-group">
        <li class="list-group-item d-flex justify-content-between align-items-center">
            Item 1
            <div>
                <button class="btn btn-sm btn-link">Edit</button>
                <button class="btn btn-sm btn-link text-danger">Delete</button>
            </div>
        </li>
        <li class="list-group-item d-flex justify-content-between align-items-center">
            Item 2
            <div>
                <button class="btn btn-sm btn-link">Edit</button>
                <button class="btn btn-sm btn-link text-danger">Delete</button>
            </div>
        </li>
    </ul>
</div>

<h2>Usage guidelines</h2>
<ul>
    <li>Use lists for structured data display</li>
    <li>Include actions when items can be modified</li>
    <li>Keep list items clear and concise</li>
    <li>Use appropriate spacing and styling</li>
</ul>

<h2>Accessibility</h2>
<ul>
    <li>Use semantic list elements</li>
    <li>Provide clear labels for action buttons</li>
    <li>Ensure keyboard navigation works</li>
</ul>
