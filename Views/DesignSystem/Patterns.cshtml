@{
    ViewData["Title"] = "Patterns - Design System";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4 dfe-adminui-breadcrumb">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="/" class="dfe-adminui-breadcrumb__link">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "DesignSystem")" class="dfe-adminui-breadcrumb__link">Design system</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active dfe-adminui-breadcrumb__item--active" aria-current="page">Patterns</li>
        </ol>
    </nav>
}

<h1 class="ds-page-title">Patterns</h1>
<p class="ds-page-lead">
    Common interaction patterns and workflows used throughout COMPASS. These patterns provide consistent user experiences across different features.
</p>

<h2>Filter a table</h2>
<p>
    Filtering allows users to narrow down table results based on specific criteria.
</p>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <div class="card mb-3">
        <div class="dfe-adminui-card__body">
            <div class="row mb-3">
                <div class="col-md-4">
                    <label for="statusFilter">Status</label>
                    <select class="form-control" id="statusFilter">
                        <option value="">All statuses</option>
                        <option value="active">Active</option>
                        <option value="pending">Pending</option>
                        <option value="completed">Completed</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="dateFilter">Date range</label>
                    <input type="date" class="form-control" id="dateFilter">
                </div>
                <div class="col-md-4">
                    <label for="searchFilter">Search</label>
                    <input type="text" class="form-control" id="searchFilter" placeholder="Search...">
                </div>
            </div>
            <button type="button" class="btn btn-primary">Apply filters</button>
            <button type="button" class="btn btn-secondary">Clear filters</button>
        </div>
    </div>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Status</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Item 1</td>
                <td><span class="dfe-adminui-badge dfe-adminui-badge--success">Active</span></td>
                <td>15 January 2025</td>
            </tr>
        </tbody>
    </table>
</div>

<h3>Filter pattern guidelines</h3>
<ul>
    <li>Place filters above the table in a clear, collapsible section</li>
    <li>Provide a "Clear filters" button to reset all filters</li>
    <li>Show active filter count or summary</li>
    <li>Use appropriate input types (dropdowns, date pickers, text inputs)</li>
    <li>Apply filters on user action (button click) or with debouncing for search</li>
</ul>

<h2>Dashboard</h2>
<p>
    Dashboards provide an overview of key metrics and information at a glance.
</p>
<div class="component-example">
    <div class="component-example-title">Example structure</div>
    <div class="card mb-3">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Dashboard title</h4>
        </div>
        <div class="dfe-adminui-card__body">
            <div class="row mb-3">
                <div class="col-md-3">
                    <div class="card bg-info text-white">
                        <div class="card-body text-center">
                            <h3>1,234</h3>
                            <p class="mb-0">Total items</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-success text-white">
                        <div class="card-body text-center">
                            <h3>567</h3>
                            <p class="mb-0">Active</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-warning text-white">
                        <div class="card-body text-center">
                            <h3>89</h3>
                            <p class="mb-0">Pending</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card bg-danger text-white">
                        <div class="card-body text-center">
                            <h3>12</h3>
                            <p class="mb-0">Issues</p>
                        </div>
                    </div>
                </div>
            </div>
            <h5>Recent activity</h5>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Activity 1</td>
                        <td><span class="dfe-adminui-badge dfe-adminui-badge--success">Complete</span></td>
                        <td>15 January 2025</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<h3>Dashboard pattern guidelines</h3>
<ul>
    <li>Start with a clear page title and brief description</li>
    <li>Display key metrics prominently using stat cards</li>
    <li>Organise content into logical sections</li>
    <li>Include recent activity or important updates</li>
    <li>Provide links to detailed views</li>
    <li>Ensure the dashboard is responsive and works on all screen sizes</li>
</ul>

<h2>Delete something</h2>
<p>
    Deleting items requires confirmation to prevent accidental data loss.
</p>
<div class="component-example">
    <div class="component-example-title">Example - Delete confirmation</div>
    <div class="dfe-adminui-alert dfe-adminui-alert--warning" role="alert">
        <i class="fas fa-exclamation-triangle mr-2" aria-hidden="true"></i>
        <strong>Warning:</strong> This action cannot be undone. Are you sure you want to delete this item?
    </div>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-danger">Delete</button>
        <button type="button" class="btn btn-secondary">Cancel</button>
    </div>
</div>

<h3>Delete pattern guidelines</h3>
<ul>
    <li>Always require explicit confirmation before deleting</li>
    <li>Show a clear warning message explaining the consequences</li>
    <li>Use a modal or confirmation dialog for important deletions</li>
    <li>Provide a "Cancel" option that is easily accessible</li>
    <li>Use destructive styling (red/danger) for delete buttons</li>
    <li>Consider soft deletes (marking as deleted) instead of hard deletes when possible</li>
</ul>

<h2>Download something</h2>
<p>
    Download functionality allows users to export data or files.
</p>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <div class="card">
        <div class="dfe-adminui-card__body">
            <h5 class="card-title">Export data</h5>
            <p class="card-text">Download the current data as a CSV file.</p>
            <button type="button" class="btn btn-primary">
                <i class="fas fa-download mr-2" aria-hidden="true"></i>
                Download CSV
            </button>
        </div>
    </div>
</div>

<h3>Download pattern guidelines</h3>
<ul>
    <li>Clearly label what will be downloaded</li>
    <li>Indicate the file format (CSV, PDF, Excel, etc.)</li>
    <li>Show file size if known</li>
    <li>Provide feedback when download starts (loading state)</li>
    <li>Use appropriate icons (download icon) to indicate the action</li>
    <li>Consider providing multiple format options when relevant</li>
</ul>

<h2>Submit something</h2>
<p>
    Form submission patterns ensure users can complete actions successfully.
</p>
<div class="component-example">
    <div class="component-example-title">Example - Form submission</div>
    <form>
        <div class="form-group">
            <label for="exampleInput">Input field</label>
            <input type="text" class="form-control" id="exampleInput" required>
        </div>
        <div class="form-group">
            <label for="exampleSelect">Select field</label>
            <select class="form-control" id="exampleSelect" required>
                <option value="">Choose an option</option>
                <option value="1">Option 1</option>
                <option value="2">Option 2</option>
            </select>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-check mr-2" aria-hidden="true"></i>
                Submit
            </button>
            <button type="button" class="btn btn-secondary">Cancel</button>
        </div>
    </form>
</div>

<h3>Submit pattern guidelines</h3>
<ul>
    <li>Provide clear submit button labels</li>
    <li>Show validation errors before submission</li>
    <li>Display loading state during submission</li>
    <li>Show success or error messages after submission</li>
    <li>Prevent double-submission (disable button after first click)</li>
    <li>Provide a cancel option when appropriate</li>
    <li>Use primary button styling for the main submit action</li>
</ul>

<h2>Check something</h2>
<p>
    Checking or verifying items allows users to review and confirm information.
</p>
<div class="component-example">
    <div class="component-example-title">Example - Checklist</div>
    <div class="card">
        <div class="dfe-adminui-card__body">
            <h5 class="card-title">Review checklist</h5>
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="check1" checked>
                <label class="form-check-label" for="check1">
                    Item 1 - Completed
                </label>
            </div>
            <div class="form-check mb-2">
                <input class="form-check-input" type="checkbox" id="check2">
                <label class="form-check-label" for="check2">
                    Item 2 - Pending
                </label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="check3">
                <label class="form-check-label" for="check3">
                    Item 3 - Pending
                </label>
            </div>
        </div>
    </div>
</div>

<h3>Check pattern guidelines</h3>
<ul>
    <li>Use checkboxes for multiple selections</li>
    <li>Use radio buttons for single selection from options</li>
    <li>Provide clear labels for each option</li>
    <li>Show completion status visually (checked/unchecked)</li>
    <li>Group related checkboxes logically</li>
    <li>Provide "Select all" option when appropriate</li>
</ul>

<h2>Search for a person</h2>
<p>
    Person search allows users to find and select people from a directory.
</p>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <div class="form-group">
        <label for="personSearch">Search for a person</label>
        <input type="text" class="form-control" id="personSearch" placeholder="Type a name or email..." autocomplete="off">
        <small class="form-text text-muted">Start typing to search</small>
    </div>
    <div id="searchResults" class="list-group" style="display: none;">
        <a href="#" class="list-group-item list-group-item-action">
            <div class="d-flex w-100 justify-content-between">
                <h6 class="mb-1">John Smith</h6>
            </div>
            <p class="mb-1">john.smith@example.com</p>
        </a>
        <a href="#" class="list-group-item list-group-item-action">
            <div class="d-flex w-100 justify-content-between">
                <h6 class="mb-1">Jane Doe</h6>
            </div>
            <p class="mb-1">jane.doe@example.com</p>
        </a>
    </div>
</div>

<h3>Person search pattern guidelines</h3>
<ul>
    <li>Provide autocomplete functionality as the user types</li>
    <li>Search by name, email, or other relevant identifiers</li>
    <li>Display results in a dropdown or list below the input</li>
    <li>Show person name and email in results</li>
    <li>Highlight matching text in results</li>
    <li>Handle "no results" state gracefully</li>
    <li>Support keyboard navigation (arrow keys, enter to select)</li>
    <li>Debounce search requests to avoid excessive API calls</li>
</ul>

<h2>Show someone's name</h2>
<p>
    Displaying person names consistently helps users identify people throughout COMPASS.
</p>
<div class="component-example">
    <div class="component-example-title">Example - Name display</div>
    <div class="card">
        <div class="dfe-adminui-card__body">
            <div class="d-flex align-items-center mb-3">
                <div class="mr-3">
                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                        <span class="dfe-adminui-font-weight-bold">JS</span>
                    </div>
                </div>
                <div>
                    <h5 class="mb-0">John Smith</h5>
                    <p class="text-muted mb-0">john.smith@example.com</p>
                </div>
            </div>
            <div class="mb-2">
                <strong>Role:</strong> Project Manager
            </div>
            <div>
                <strong>Department:</strong> Digital Services
            </div>
        </div>
    </div>
</div>

<h3>Name display pattern guidelines</h3>
<ul>
    <li>Use full name (First Last) in most contexts</li>
    <li>Include email address when relevant</li>
    <li>Show role or title when available</li>
    <li>Use consistent formatting across all pages</li>
    <li>Consider using avatars or initials for visual identification</li>
    <li>Make names clickable when linking to person details</li>
    <li>Respect user preferences for name display</li>
</ul>

<h2>Pattern best practices</h2>
<ul>
    <li>Maintain consistency across all COMPASS features</li>
    <li>Follow accessibility guidelines for each pattern</li>
    <li>Test patterns with keyboard navigation and screen readers</li>
    <li>Provide clear feedback for user actions</li>
    <li>Handle error states gracefully</li>
    <li>Ensure patterns work responsively on all screen sizes</li>
    <li>Use appropriate loading states for async operations</li>
</ul>
