@{
    ViewData["Title"] = "Typography - Design System";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="/">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "DesignSystem")">Design system</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active" aria-current="page">Typography</li>
        </ol>
    </nav>
}

<h1 class="ds-page-title">Typography</h1>
<p class="ds-page-lead">
    COMPASS uses the Inter typeface for all text, as specified by the GOV.UK Design System. 
    Inter provides excellent readability and is optimised for digital interfaces.
</p>

<h2>Font family</h2>
<p>
    The Inter typeface is used throughout COMPASS for consistent, readable typography.
</p>

<div class="component-example">
    <div class="component-example-title">Example</div>
    <p style="font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;">
        The quick brown fox jumps over the lazy dog. 1234567890
    </p>
</div>

<pre><code>font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;</code></pre>

<h2>Heading styles</h2>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <h1>Heading 1 - Page title (2.5rem, 700 weight)</h1>
    <h2>Heading 2 - Section title (1.875rem, 700 weight)</h2>
    <h3>Heading 3 - Subsection (1.5rem, 600 weight)</h3>
    <h4>Heading 4 - Minor heading (1.25rem, 600 weight)</h4>
    <h5>Heading 5 - Small heading (1.125rem, 600 weight)</h5>
</div>

<h2>Body text</h2>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <p>Body text uses 1rem (16px) font size with 1.75 line height for optimal readability.</p>
    <p><strong>Bold text</strong> is used for emphasis.</p>
    <p><em>Italic text</em> is used sparingly for citations or emphasis.</p>
</div>

<h2>Text sizes</h2>
<table>
    <thead>
        <tr>
            <th>Size</th>
            <th>Font size</th>
            <th>Line height</th>
            <th>Usage</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>Heading 1</td>
            <td>2.5rem (40px)</td>
            <td>1.2</td>
            <td>Page titles</td>
        </tr>
        <tr>
            <td>Heading 2</td>
            <td>1.875rem (30px)</td>
            <td>1.4</td>
            <td>Section headers</td>
        </tr>
        <tr>
            <td>Heading 3</td>
            <td>1.5rem (24px)</td>
            <td>1.4</td>
            <td>Subsections</td>
        </tr>
        <tr>
            <td>Body</td>
            <td>1rem (16px)</td>
            <td>1.75</td>
            <td>Body text, paragraphs</td>
        </tr>
        <tr>
            <td>Small</td>
            <td>0.875rem (14px)</td>
            <td>1.5</td>
            <td>Helper text, captions</td>
        </tr>
    </tbody>
</table>

<h2>Usage guidelines</h2>
<ul>
    <li>Use Inter typeface for all text in COMPASS</li>
    <li>Maintain consistent heading hierarchy (h1 → h2 → h3)</li>
    <li>Use appropriate font sizes for different contexts</li>
    <li>Ensure sufficient line height for readability</li>
    <li>Use bold for emphasis, italic sparingly</li>
</ul>
