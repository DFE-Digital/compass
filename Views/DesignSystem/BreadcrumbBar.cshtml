@{
    ViewData["Title"] = "Breadcrumb Bar - Design System";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="/">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "DesignSystem")">Design system</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active" aria-current="page">Breadcrumb bar</li>
        </ol>
    </nav>
}

<h1 class="ds-page-title">Breadcrumb bar</h1>
<p class="ds-page-lead">
    Breadcrumbs help users understand their location within COMPASS and navigate back to parent pages.
</p>

<h2>Standard breadcrumb</h2>
<p>
    The standard breadcrumb uses a light background with blue links and clear visual hierarchy.
</p>

<div class="component-example">
    <div class="component-example-title">Example</div>
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="#" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="#" style="color: #005ea5; text-decoration: none;">Design system</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active" aria-current="page" >Breadcrumb bar</li>
        </ol>
    </nav>
</div>

<pre><code>&lt;nav aria-label="Breadcrumb"&gt;
    &lt;ol class="dfe-adminui-breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;"&gt;
        &lt;li class="dfe-adminui-breadcrumb__item"&gt;
            &lt;a href="#" style="color: #005ea5; text-decoration: none;"&gt;Home&lt;/a&gt;
        &lt;/li&gt;
        &lt;li class="dfe-adminui-breadcrumb__item"&gt;
            &lt;a href="#" style="color: #005ea5; text-decoration: none;"&gt;Design system&lt;/a&gt;
        &lt;/li&gt;
        &lt;li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active" aria-current="page" &gt;Current page&lt;/li&gt;
    &lt;/ol&gt;
&lt;/nav&gt;</code></pre>

<h2>Usage guidelines</h2>
<ul>
    <li>Always include a breadcrumb on pages deeper than the home page</li>
    <li>Use the standard background colour (#f4f8fb) with rounded corners</li>
    <li>Link colours should be #005ea5 (primary blue)</li>
    <li>Active (current) page should be in dark text (#0b0c0c) with font-weight 600</li>
    <li>Include proper ARIA labels for accessibility</li>
    <li>Use the <code>aria-current="page"</code> attribute on the active item</li>
    <li>Keep breadcrumbs concise - typically 3-4 levels maximum</li>
</ul>

<h2>Accessibility</h2>
<ul>
    <li>Use semantic <code>&lt;nav&gt;</code> element with <code>aria-label="Breadcrumb"</code></li>
    <li>Use ordered list (<code>&lt;ol&gt;</code>) for proper screen reader navigation</li>
    <li>Mark the current page with <code>aria-current="page"</code></li>
    <li>Ensure sufficient colour contrast for all text and links</li>
    <li>Make all links keyboard accessible</li>
</ul>
