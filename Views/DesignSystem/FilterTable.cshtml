@{
    ViewData["Title"] = "Filter a Table - Design System";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="/">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "DesignSystem")">Design system</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active" aria-current="page">Filter a table</li>
        </ol>
    </nav>
}

<h1 class="ds-page-title">Filter a table</h1>
<p class="ds-page-lead">
    Filtering allows users to narrow down table results based on specific criteria. COMPASS supports both vertical and horizontal filter layouts.
</p>

<h2>Vertical filters</h2>
<p>
    <strong>Use vertical filters when filters are most likely to be used.</strong> Vertical filters are placed in a left sidebar column and remain visible, making them ideal for frequently used filters.
</p>
<div class="component-example">
    <div class="component-example-title">Example - Vertical filters (left sidebar)</div>
    <div class="row">
        <div class="col-md-3">
            <div class="card">
                <div class="dfe-adminui-card__header">
                    <h3 class="card-title">Filters</h3>
                </div>
                <div class="dfe-adminui-card__body">
                    <form method="get" id="filterForm">
                        <div class="form-group">
                            <label>Search</label>
                            <input type="text" name="search" class="form-control form-control-sm" placeholder="Search work items..." />
                        </div>
                        <div class="form-group">
                            <label for="ragStatus">RAG Status</label>
                            <select name="ragStatus" id="ragStatus" class="form-control form-control-sm">
                                <option value="">All</option>
                                <option value="green">Green</option>
                                <option value="amber">Amber</option>
                                <option value="red">Red</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="businessArea">Business Area</label>
                            <select name="businessArea" id="businessArea" class="form-control form-control-sm">
                                <option value="">All</option>
                                <option value="1">Digital Services</option>
                                <option value="2">Policy</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <button type="submit" class="btn btn-primary btn-sm btn-block">Apply filters</button>
                            <a href="#" class="btn btn-default btn-sm btn-block">Clear all filters</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-9">
            <div class="card">
                <div class="dfe-adminui-card__header">
                    <h3 class="card-title">All work items</h3>
                </div>
                <div class="card-body p-0">
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Item 1</td>
                                <td><span class="dfe-adminui-badge dfe-adminui-badge--success">Active</span></td>
                                <td>1 Jun 2026</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<h2>Horizontal filters</h2>
<p>
    <strong>Use horizontal filters when filters are optional or unlikely to be used as much.</strong> Horizontal filters are placed above the table in a collapsible section, allowing them to be hidden away when not needed.
</p>
<div class="component-example">
    <div class="component-example-title">Example - Horizontal filters (collapsible)</div>
    <div class="card mb-3">
        <div class="dfe-adminui-card__header">
            <h3 class="card-title">
                <a data-toggle="collapse" href="#filtersCollapse" role="button" aria-expanded="false" aria-controls="filtersCollapse" style="color: inherit; text-decoration: none;">
                    Filter products
                    <i class="fas fa-chevron-down float-right" id="filtersChevron"></i>
                </a>
            </h3>
        </div>
        <div class="collapse" id="filtersCollapse">
            <div class="dfe-adminui-card__body">
                <div class="row">
                    <div class="col-lg-4 col-md-6 col-12">
                        <div class="form-group">
                            <label for="searchInput">Search by product name</label>
                            <input type="text" class="form-control" id="searchInput" placeholder="Search products...">
                        </div>
                    </div>
                    <div class="col-lg-2 col-md-6 col-12">
                        <div class="form-group">
                            <label for="statusFilter">Status</label>
                            <select class="form-control" id="statusFilter">
                                <option value="">All</option>
                                <option value="active">Active</option>
                                <option value="pending">Pending</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-lg-2 col-md-6 col-12">
                        <div class="form-group">
                            <label>&nbsp;</label>
                            <button type="button" class="btn btn-primary btn-block">Apply</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Status</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Item 1</td>
                <td><span class="dfe-adminui-badge dfe-adminui-badge--success">Active</span></td>
                <td>1 Jun 2026</td>
            </tr>
        </tbody>
    </table>
</div>

<h2>When to use vertical vs horizontal filters</h2>
<ul>
    <li><strong>Vertical filters:</strong> Use when filters are most likely to be used frequently. Place in a left sidebar column (typically 2-3 columns wide) that remains visible.</li>
    <li><strong>Horizontal filters:</strong> Use when filters are optional or unlikely to be used as much. Place above the table in a collapsible card that can be hidden away.</li>
</ul>

<h2>Usage guidelines</h2>
<ul>
    <li>Provide a "Clear filters" button to reset all filters</li>
    <li>Show active filter count or summary when filters are applied</li>
    <li>Use appropriate input types (dropdowns, date pickers, text inputs)</li>
    <li>Apply filters on user action (button click) or with debouncing for search</li>
    <li>For horizontal filters, use a chevron icon that rotates when expanded/collapsed</li>
</ul>

<h2>Accessibility</h2>
<ul>
    <li>Provide clear labels for all filter inputs</li>
    <li>Ensure keyboard navigation works</li>
    <li>Announce filter changes to screen readers</li>
    <li>Provide clear feedback when filters are applied</li>
</ul>
