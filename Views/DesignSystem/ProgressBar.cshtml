<h1 class="ds-page-title">Progress bar</h1>
<p class="ds-page-lead">
    Progress bars indicate the completion status of a task or process. They provide visual feedback on progress and can include percentage text.
</p>

<h2>Standard progress bar</h2>
<p>
    The standard progress bar uses a coloured bar to show completion percentage with text overlay.
</p>

<div class="component-example">
    <div class="component-example-title">Example - With percentage text</div>
    <div class="progress" style="height: 30px; position: relative; background-color: #e9ecef; width: 100%; margin-bottom: 1rem;">
        <div class="progress-bar bg-success" 
             role="progressbar" 
             style="width: 75% !important; min-width: 0 !important; position: relative;"
             aria-valuenow="75" 
             aria-valuemin="0" 
             aria-valuemax="100">
        </div>
        <span style="position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); font-weight: bold; white-space: nowrap; pointer-events: none; z-index: 2; color: #fff;">
            75%
        </span>
    </div>
    
    <div class="progress" style="height: 30px; position: relative; background-color: #e9ecef; width: 100%; margin-bottom: 1rem;">
        <div class="progress-bar bg-warning" 
             role="progressbar" 
             style="width: 50% !important; min-width: 0 !important; position: relative;"
             aria-valuenow="50" 
             aria-valuemin="0" 
             aria-valuemax="100">
        </div>
        <span style="position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); font-weight: bold; white-space: nowrap; pointer-events: none; z-index: 2; color: #000;">
            50%
        </span>
    </div>
    
    <div class="progress" style="height: 30px; position: relative; background-color: #e9ecef; width: 100%;">
        <div class="progress-bar bg-danger" 
             role="progressbar" 
             style="width: 25% !important; min-width: 0 !important; position: relative;"
             aria-valuenow="25" 
             aria-valuemin="0" 
             aria-valuemax="100">
        </div>
        <span style="position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%); font-weight: bold; white-space: nowrap; pointer-events: none; z-index: 2; color: #000;">
            25%
        </span>
    </div>
</div>

<pre><code>&lt;div class="progress" style="height: 30px; position: relative; background-color: #e9ecef; width: 100%;"&gt;
    &lt;div class="progress-bar bg-success" 
         role="progressbar" 
         style="width: 75% !important; min-width: 0 !important; position: relative;"
         aria-valuenow="75" 
