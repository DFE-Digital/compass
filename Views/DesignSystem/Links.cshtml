@{
    ViewData["Title"] = "Links - Design System";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="/">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "DesignSystem")">Design system</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active" aria-current="page">Links</li>
        </ol>
    </nav>
}

<h1 class="ds-page-title">Links</h1>
<p class="ds-page-lead">
    Links should be clearly identifiable and follow consistent styling throughout COMPASS.
</p>

<h2>Link styles</h2>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <p>
        This is a <a href="#">standard link</a> in body text.
    </p>
    <p>
        <a href="#" class="btn btn-primary">Primary button link</a>
        <a href="#" class="btn btn-secondary">Secondary button link</a>
    </p>
</div>

<h2>Link guidelines</h2>
<ul>
    <li>Links use the primary blue colour (#1d70b8)</li>
    <li>Links should be underlined in body text</li>
    <li>Link text should be descriptive (avoid "click here")</li>
    <li>External links should open in a new tab with appropriate ARIA labels</li>
    <li>Visited links use a darker shade (#003078)</li>
</ul>

<h2>Accessibility</h2>
<ul>
    <li>Ensure sufficient colour contrast for all links</li>
    <li>Use descriptive link text</li>
    <li>Provide clear focus indicators</li>
    <li>Mark external links appropriately</li>
</ul>
