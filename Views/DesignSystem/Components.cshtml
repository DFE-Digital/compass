</p>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4 dfe-adminui-breadcrumb">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="#" class="dfe-adminui-breadcrumb__link">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="#" class="dfe-adminui-breadcrumb__link">Design system</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active dfe-adminui-breadcrumb__item--active" aria-current="page">Components</li>
        </ol>
