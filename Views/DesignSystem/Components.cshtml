<h2>Accordion</h2>
<p>
    Accordions allow users to expand and collapse sections of content, saving space on the page.
</p>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <div class="accordion" id="exampleAccordion">
        <div class="card">
            <div class="dfe-adminui-card__header" id="headingOne">
                <h5 class="mb-0">
                    <button class="btn btn-link" type="button" data-toggle="collapse" data-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                        Accordion item 1
                    </button>
                </h5>
            </div>
            <div id="collapseOne" class="collapse show" aria-labelledby="headingOne" data-parent="#exampleAccordion">
                <div class="dfe-adminui-card__body">
                    Content for accordion item 1.
                </div>
            </div>
        </div>
        <div class="card">
            <div class="dfe-adminui-card__header" id="headingTwo">
                <h5 class="mb-0">
                    <button class="btn btn-link collapsed" type="button" data-toggle="collapse" data-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                        Accordion item 2
                    </button>
                </h5>
            </div>
            <div id="collapseTwo" class="collapse" aria-labelledby="headingTwo" data-parent="#exampleAccordion">
                <div class="dfe-adminui-card__body">
                    Content for accordion item 2.
                </div>
            </div>
        </div>
    </div>
</div>

<h2>Toggle panel</h2>
<p>
    Toggle panels allow users to show or hide content sections.
</p>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <button class="btn btn-primary mb-2" type="button" data-toggle="collapse" data-target="#togglePanel" aria-expanded="false" aria-controls="togglePanel">
        Toggle panel
    </button>
    <div class="collapse" id="togglePanel">
        <div class="card card-body">
            This content can be toggled on and off.
        </div>
    </div>
</div>

<h2>Container (Card)</h2>
<p>
    Cards provide a container for related content with clear visual boundaries.
</p>
<div class="component-example">
    <div class="component-example-title">Example - Basic card</div>
    <div class="card">
        <div class="dfe-adminui-card__header">
            <h5 class="card-title mb-0">Card title</h5>
        </div>
        <div class="dfe-adminui-card__body">
            <p class="card-text">Card content goes here.</p>
        </div>
    </div>
</div>

<h3>Card with actions</h3>
<div class="component-example">
    <div class="component-example-title">Example - Card with actions</div>
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">Card with actions</h5>
            <div>
                <button class="btn btn-sm btn-link" type="button" data-toggle="collapse" data-target="#cardContent" aria-expanded="true">
                    <i class="fas fa-chevron-up" aria-hidden="true"></i>
                </button>
                <a href="#" class="btn btn-sm btn-link">
                    <i class="fas fa-external-link-alt" aria-hidden="true"></i>
                </a>
            </div>
        </div>
        <div class="collapse show" id="cardContent">
            <div class="dfe-adminui-card__body">
                <p>Card content that can be collapsed or expanded.</p>
            </div>
        </div>
    </div>
</div>

<h2>Stat card</h2>
<p>
    Stat cards display key metrics or numbers prominently.
</p>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <div class="row">
        <div class="col-md-4">
            <div class="card bg-primary text-white">
                <div class="dfe-adminui-card__body">
                    <h3 class="mb-0">1,234</h3>
                    <p class="mb-0">Total projects</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white">
                <div class="dfe-adminui-card__body">
                    <h3 class="mb-0">567</h3>
                    <p class="mb-0">Active projects</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-info text-white">
                <div class="dfe-adminui-card__body">
                    <h3 class="mb-0">89</h3>
                    <p class="mb-0">Pending tasks</p>
                </div>
            </div>
        </div>
    </div>
</div>

<h2>Navbar</h2>
<p>
    The navigation bar provides access to main sections and user account features.
</p>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <nav class="navbar navbar-expand-lg navbar-light bg-light mb-3">
        <a class="navbar-brand" href="#">COMPASS</a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarExample">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarExample">
            <ul class="navbar-nav mr-auto">
                <li class="nav-item active">
                    <a class="nav-link" href="#">Home</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">Features</a>
                </li>
            </ul>
        </div>
    </nav>
</div>

<h2>Badge</h2>
<p>
    Badges display status, counts, or labels in a compact format.
</p>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <p>
        <span class="dfe-adminui-badge dfe-adminui-badge--primary">Primary</span>
        <span class="dfe-adminui-badge dfe-adminui-badge--secondary">Secondary</span>
        <span class="dfe-adminui-badge dfe-adminui-badge--success">Success</span>
        <span class="dfe-adminui-badge dfe-adminui-badge--danger">Danger</span>
        <span class="dfe-adminui-badge dfe-adminui-badge--warning">Warning</span>
        <span class="dfe-adminui-badge dfe-adminui-badge--info">Info</span>
        <span class="badge badge-light">Light</span>
        <span class="badge badge-dark">Dark</span>
    </p>
    <p>
        <span class="badge badge-pill badge-primary">Pill badge</span>
        <span class="badge badge-pill badge-success">Active</span>
    </p>
</div>

<h2>Button</h2>
<p>
    Buttons trigger actions and should be clearly labelled.
</p>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <p>
        <button type="button" class="btn btn-primary">Primary</button>
        <button type="button" class="btn btn-secondary">Secondary</button>
        <button type="button" class="btn btn-success">Success</button>
        <button type="button" class="btn btn-danger">Danger</button>
        <button type="button" class="btn btn-warning">Warning</button>
        <button type="button" class="btn btn-info">Info</button>
    </p>
    <p>
        <button type="button" class="btn btn-outline-primary">Outline Primary</button>
        <button type="button" class="btn btn-outline-secondary">Outline Secondary</button>
    </p>
    <p>
        <button type="button" class="btn btn-sm btn-primary">Small</button>
        <button type="button" class="btn btn-primary">Default</button>
        <button type="button" class="btn btn-lg btn-primary">Large</button>
    </p>
</div>

<h2>Table</h2>
<p>
    Tables display structured data in rows and columns.
</p>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Status</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Project Alpha</td>
                <td><span class="dfe-adminui-badge dfe-adminui-badge--success">Active</span></td>
                <td>15 January 2025</td>
            </tr>
            <tr>
                <td>Project Beta</td>
                <td><span class="dfe-adminui-badge dfe-adminui-badge--warning">Pending</span></td>
                <td>20 January 2025</td>
            </tr>
        </tbody>
    </table>
</div>

<h2>Modal</h2>
<p>
    Modals display important information or actions in an overlay dialog.
</p>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#exampleModal">
        Open modal
    </button>
    <div class="modal fade" id="exampleModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Modal title</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    Modal content goes here.
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary">Save changes</button>
                </div>
            </div>
        </div>
    </div>
</div>

<h2>Data list</h2>
<p>
    Data lists display information in a structured list format.
</p>
<div class="component-example">
    <div class="component-example-title">Example - Simple list</div>
    <ul class="list-group">
        <li class="list-group-item">Item 1</li>
        <li class="list-group-item">Item 2</li>
        <li class="list-group-item">Item 3</li>
    </ul>
</div>

<h3>Data list with change options</h3>
<div class="component-example">
    <div class="component-example-title">Example - List with actions</div>
    <ul class="list-group">
        <li class="list-group-item d-flex justify-content-between align-items-center">
            Item 1
            <div>
                <button class="btn btn-sm btn-link">Edit</button>
                <button class="btn btn-sm btn-link text-danger">Delete</button>
            </div>
        </li>
        <li class="list-group-item d-flex justify-content-between align-items-center">
            Item 2
            <div>
                <button class="btn btn-sm btn-link">Edit</button>
                <button class="btn btn-sm btn-link text-danger">Delete</button>
            </div>
        </li>
    </ul>
</div>

<h2>Progress bar</h2>
<p>
    Progress bars indicate the completion status of a task or process.
</p>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <div class="progress mb-2">
        <div class="progress-bar" role="progressbar" style="width: 25%" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100">25%</div>
    </div>
    <div class="progress mb-2">
        <div class="progress-bar bg-success" role="progressbar" style="width: 50%" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100">50%</div>
    </div>
    <div class="progress mb-2">
        <div class="progress-bar bg-warning" role="progressbar" style="width: 75%" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100">75%</div>
    </div>
    <div class="progress">
        <div class="progress-bar bg-danger" role="progressbar" style="width: 100%" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">100%</div>
    </div>
</div>

