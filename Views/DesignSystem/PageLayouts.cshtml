@{
    ViewData["Title"] = "Page Layouts - Design System";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="/">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "DesignSystem")">Design system</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active" aria-current="page">Page layouts</li>
        </ol>
    </nav>
}

<h1 class="ds-page-title">Page layouts</h1>
<p class="ds-page-lead">
    COMPASS uses consistent page layouts to provide a familiar experience across all features.
</p>

<h2>Standard page structure</h2>
<div class="component-example">
    <div class="component-example-title">Example structure</div>
    <pre><code>&lt;div class="content-wrapper"&gt;
    &lt;div class="content-header"&gt;
        &lt;!-- Breadcrumbs --&gt;
    &lt;/div&gt;
    &lt;section class="content" id="main-content"&gt;
        &lt;div class="container-fluid"&gt;
            &lt;!-- Page content --&gt;
        &lt;/div&gt;
    &lt;/section&gt;
&lt;/div&gt;</code></pre>
</div>

<h2>Container widths</h2>
<ul>
    <li><strong>Full width:</strong> Use <code>container-fluid</code> for full-width layouts</li>
    <li><strong>Content area:</strong> Main content uses full width with appropriate padding</li>
    <li><strong>Cards:</strong> Use Bootstrap grid system for responsive layouts</li>
</ul>

<h2>Usage guidelines</h2>
<ul>
    <li>Maintain consistent page structure across all COMPASS features</li>
    <li>Always include breadcrumbs in the content-header</li>
    <li>Use semantic HTML structure</li>
    <li>Ensure responsive design for all screen sizes</li>
</ul>
