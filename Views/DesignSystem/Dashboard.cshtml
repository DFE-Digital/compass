@{
    ViewData["Title"] = "Dashboard - Design System";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4 breadcrumb-design-system">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "Home")">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "DesignSystem")">Design System</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Patterns", "DesignSystem")">Patterns</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active" aria-current="page">Dashboard</li>
        </ol>
    </nav>
}

<h1 class="ds-page-title">Dashboard</h1>
<p class="ds-page-lead">
    Dashboards provide an overview of key metrics and information at a glance. This example demonstrates how to combine multiple design system components to create a comprehensive dashboard.
</p>

<h2>Complete dashboard example</h2>
<div class="component-example">
    <div class="component-example-title">Example - Dashboard using design system components</div>
    
    <!-- Module Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light mb-3 navbar-module">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h6">Dashboard Example</span>
            <div class="navbar-nav d-flex flex-row align-items-center">
                <div class="nav-item active">
                    <a class="nav-link active" href="#">Overview</a>
                </div>
                <div class="nav-item">
                    <a class="nav-link" href="#">Reports</a>
                </div>
                <div class="nav-item">
                    <a class="nav-link" href="#">Analytics</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Stat Cards -->
    <div class="row mb-4">
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card dfe-adminui-border-left-primary shadow h-100">
                <div class="dfe-adminui-card__body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Projects</div>
                            <div class="h4 mb-0 font-weight-bold text-gray-800">123</div>
                            <small class="dfe-adminui-text-muted">Active and published</small>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-box fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card dfe-adminui-border-left-success shadow h-100">
                <div class="dfe-adminui-card__body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Completed</div>
                            <div class="h4 mb-0 font-weight-bold text-gray-800">89</div>
                            <small class="dfe-adminui-text-muted">Last updated: 1 June 2026</small>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-check-circle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card dfe-adminui-border-left-warning shadow h-100">
                <div class="dfe-adminui-card__body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">In Progress</div>
                            <div class="h4 mb-0 font-weight-bold text-gray-800">34</div>
                            <small class="dfe-adminui-text-muted">Due: 18 June 2026</small>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-spinner fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card dfe-adminui-border-left-danger shadow h-100">
                <div class="dfe-adminui-card__body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Issues</div>
                            <div class="h4 mb-0 font-weight-bold text-gray-800">12</div>
                            <small class="dfe-adminui-text-muted">Requiring attention</small>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-exclamation-triangle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Activity Table -->
    <div class="card mb-4">
        <div class="dfe-adminui-card__header">
            <h3 class="card-title">Recent activity</h3>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Project</th>
                            <th>Status</th>
                            <th>Last updated</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Project Alpha</td>
                            <td><span class="dfe-adminui-badge dfe-adminui-badge--success">Active</span></td>
                            <td>15 Jan 2025</td>
                            <td>
                                <a href="#" class="btn btn-sm btn-link">View</a>
                            </td>
                        </tr>
                        <tr>
                            <td>Project Beta</td>
                            <td><span class="dfe-adminui-badge dfe-adminui-badge--warning">Pending</span></td>
                            <td>20 Jan 2025</td>
                            <td>
                                <a href="#" class="btn btn-sm btn-link">View</a>
                            </td>
                        </tr>
                        <tr>
                            <td>Project Gamma</td>
                            <td><span class="dfe-adminui-badge dfe-adminui-badge--info">In progress</span></td>
                            <td>10 Jan 2025</td>
                            <td>
                                <a href="#" class="btn btn-sm btn-link">View</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Data List -->
    <div class="card mb-4">
        <div class="dfe-adminui-card__header">
            <h3 class="card-title">Quick links</h3>
        </div>
        <div class="card-body p-0">
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <a href="#">View all projects</a>
                    <span class="dfe-adminui-badge dfe-adminui-badge--primary">123</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <a href="#">Pending approvals</a>
                    <span class="dfe-adminui-badge dfe-adminui-badge--warning">5</span>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <a href="#">Reports</a>
                    <span class="dfe-adminui-badge dfe-adminui-badge--info">12</span>
                </li>
            </ul>
        </div>
    </div>
</div>

<h2>Components used in this dashboard</h2>
<ul>
    <li><strong>Module Navbar:</strong> Provides navigation between dashboard sections</li>
    <li><strong>Stat Cards:</strong> Display key metrics with icons and dates (using D MMMM YYYY format)</li>
    <li><strong>Table:</strong> Shows recent activity with status badges and dates (using D MMM YYYY format)</li>
    <li><strong>Data List:</strong> Provides quick links with badge counts</li>
    <li><strong>Badges:</strong> Indicate status (success, warning, info, danger)</li>
    <li><strong>Cards:</strong> Container components for grouping related content</li>
</ul>

<h2>Usage guidelines</h2>
<ul>
    <li>Start with a clear page title and brief description</li>
    <li>Use module navbar for section navigation</li>
    <li>Display key metrics prominently using stat cards</li>
    <li>Organise content into logical sections using cards</li>
    <li>Include recent activity or important updates in tables</li>
    <li>Provide quick links using data lists</li>
    <li>Ensure the dashboard is responsive and works on all screen sizes</li>
    <li>Use consistent date formatting (stat cards: D MMMM YYYY, tables: D MMM YYYY)</li>
</ul>

<h2>Accessibility</h2>
<ul>
    <li>Use semantic HTML structure</li>
    <li>Provide clear headings and labels</li>
    <li>Ensure all interactive elements are keyboard accessible</li>
    <li>Use appropriate ARIA labels for dynamic content</li>
    <li>Ensure sufficient colour contrast for all text and badges</li>
</ul>
