@{
    ViewData["Title"] = "Download Something - Design System";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="/">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "DesignSystem")">Design system</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active" aria-current="page">Download something</li>
        </ol>
    </nav>
}

<h1 class="ds-page-title">Download something</h1>
<p class="ds-page-lead">
    Download functionality allows users to export data or files.
</p>

<h2>Download pattern</h2>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <div class="card">
        <div class="dfe-adminui-card__body">
            <h5 class="card-title">Export data</h5>
            <p class="card-text">Download the current data as a CSV file.</p>
            <button type="button" class="btn btn-primary">
                <i class="fas fa-download mr-2" aria-hidden="true"></i>
                Download CSV
            </button>
        </div>
    </div>
</div>

<h2>Usage guidelines</h2>
<ul>
    <li>Clearly label what will be downloaded</li>
    <li>Indicate the file format (CSV, PDF, Excel, etc.)</li>
    <li>Show file size if known</li>
    <li>Provide feedback when download starts (loading state)</li>
    <li>Use appropriate icons (download icon) to indicate the action</li>
    <li>Consider providing multiple format options when relevant</li>
</ul>

<h2>Accessibility</h2>
<ul>
    <li>Provide clear labels for download buttons</li>
    <li>Ensure keyboard navigation works</li>
    <li>Provide feedback when downloads start</li>
    <li>Use descriptive link/button text</li>
</ul>
