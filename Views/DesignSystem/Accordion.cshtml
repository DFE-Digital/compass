@{
    ViewData["Title"] = "Accordion - Design System";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="/">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "DesignSystem")">Design system</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active" aria-current="page">Accordion</li>
        </ol>
    </nav>
}

<h1 class="ds-page-title">Accordion</h1>
<p class="ds-page-lead">
    Accordions allow users to expand and collapse sections of content, saving space on the page.
</p>

<h2>Standard accordion</h2>
<p>
    Accordions use Bootstrap's collapse component to show and hide content sections.
</p>

<div class="component-example">
    <div class="component-example-title">Example</div>
    <div class="accordion" id="exampleAccordion">
        <div class="card mb-2 border-0 border-bottom">
            <div class="card-header p-0 border-0 bg-white" id="headingOne">
                <button class="btn btn-block text-left p-3" type="button" data-toggle="collapse" data-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                    <div class="d-flex align-items-center justify-content-between w-100">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-plus-circle collapse-icon mr-3" style="width: 16px; font-size: 1.2rem;"></i>
                            <strong>Accordion item 1</strong>
                        </div>
                    </div>
                </button>
            </div>
            <div id="collapseOne" class="collapse show" aria-labelledby="headingOne" data-parent="#exampleAccordion">
                <div class="dfe-adminui-card__body">
                    Content for accordion item 1.
                </div>
            </div>
        </div>
        <div class="card mb-2 border-0 border-bottom">
            <div class="card-header p-0 border-0 bg-white" id="headingTwo">
                <button class="btn btn-block text-left p-3 collapsed" type="button" data-toggle="collapse" data-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                    <div class="d-flex align-items-center justify-content-between w-100">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-plus-circle collapse-icon mr-3" style="width: 16px; font-size: 1.2rem;"></i>
                            <strong>Accordion item 2</strong>
                        </div>
                    </div>
                </button>
            </div>
            <div id="collapseTwo" class="collapse" aria-labelledby="headingTwo" data-parent="#exampleAccordion">
                <div class="dfe-adminui-card__body">
                    Content for accordion item 2.
                </div>
            </div>
        </div>
    </div>
</div>

<h2>Usage guidelines</h2>
<ul>
    <li>Use accordions to organize related content into collapsible sections</li>
    <li>Keep accordion items focused on a single topic</li>
    <li>Use clear, descriptive headings for each accordion item</li>
    <li>Consider allowing multiple items to be open simultaneously</li>
    <li>Use icons to indicate expand/collapse state</li>
</ul>

<h2>Accessibility</h2>
<ul>
    <li>Use proper ARIA attributes: <code>aria-expanded</code>, <code>aria-controls</code>, <code>aria-labelledby</code></li>
    <li>Ensure keyboard navigation works (Enter/Space to toggle)</li>
    <li>Provide clear visual indicators for expanded/collapsed state</li>
    <li>Use semantic button elements for accordion headers</li>
</ul>
