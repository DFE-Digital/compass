<h1 class="ds-page-title">Search for a person</h1>
<p class="ds-page-lead">
    Person search allows users to find and select people from Entra ID (Azure AD). This pattern uses the user-picker component which provides autocomplete functionality with real-time search results.
</p>

<h2>Entra ID search pattern</h2>
<div class="component-example">
    <div class="component-example-title">Example - Entra ID user picker</div>
    <div class="form-group">
        <label class="control-label" for="personSearchExample">Search for a colleague</label>
        <small class="form-text text-muted">Start typing a name or email address to look up someone in Entra ID.</small>
        <div class="user-picker" data-user-picker data-search-url="/api/users/search" data-select-url="/api/users/select">
            <div class="position-relative">
                <input type="text"
                       class="form-control js-user-picker-input"
                       id="personSearchExample"
                       autocomplete="off"
                       placeholder="e.g. Alex Smith or alex.smith@education.gov.uk" />
                <span class="user-picker__spinner js-user-picker-spinner" aria-hidden="true">Searching…</span>
                <div class="user-picker__results js-user-picker-results" role="listbox" aria-live="polite"></div>
            </div>
            <p class="form-text text-muted js-user-picker-message">Type at least three characters to start searching.</p>
            <input type="hidden" class="js-user-picker-value" />
            <input type="hidden" class="js-user-picker-objectid" />
            <input type="hidden" class="js-user-picker-name" />
            <input type="hidden" class="js-user-picker-email" />
            <div class="user-picker__selected js-user-picker-summary" data-default-text="No user selected.">
                <p class="text-muted mb-0">No user selected.</p>
            </div>
        </div>
    </div>
</div>

<pre><code>&lt;div class="form-group"&gt;
    &lt;label class="control-label" for="personSearch"&gt;Search for a colleague&lt;/label&gt;
    &lt;small class="form-text text-muted"&gt;Start typing a name or email address to look up someone in Entra ID.&lt;/small&gt;
    &lt;div class="user-picker" 
         data-user-picker 
         data-search-url="/api/users/search" 
         data-select-url="/api/users/select"&gt;
        &lt;div class="position-relative"&gt;
            &lt;input type="text"
                   class="form-control js-user-picker-input"
                   id="personSearch"
                   autocomplete="off"
                   placeholder="e.g. Alex Smith or alex.smith@education.gov.uk" /&gt;
            &lt;span class="user-picker__spinner js-user-picker-spinner" aria-hidden="true"&gt;Searching…&lt;/span&gt;
            &lt;div class="user-picker__results js-user-picker-results" role="listbox" aria-live="polite"&gt;&lt;/div&gt;
        &lt;/div&gt;
        &lt;p class="form-text text-muted js-user-picker-message"&gt;Type at least three characters to start searching.&lt;/p&gt;
        &lt;input type="hidden" class="js-user-picker-value" /&gt;
        &lt;input type="hidden" class="js-user-picker-objectid" /&gt;
