@{
    ViewData["Title"] = "Navbar - Design System";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="/">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "DesignSystem")">Design system</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active" aria-current="page">Navbar</li>
        </ol>
    </nav>
}

<h1 class="ds-page-title">Navbar</h1>
<p class="ds-page-lead">
    Module navigation bars provide access to related sections within a feature area. They use the <code>navbar-module</code> class and display horizontally with a brand text and navigation links.
</p>

<h2>Module navbar</h2>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <nav class="navbar navbar-expand-lg navbar-light mb-3 navbar-module">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h6">Central Operations</span>
            <div class="navbar-nav d-flex flex-row align-items-center">
                <div class="nav-item">
                    <a class="nav-link" href="#">Summary overview</a>
                </div>
                <div class="nav-item">
                    <a class="nav-link" href="#">Monthly reporting</a>
                </div>
                <div class="nav-item">
                    <a class="nav-link" href="#">Performance reporting</a>
                </div>
                <div class="nav-item">
                    <a class="nav-link" href="#">RAG and Risk</a>
                </div>
                <div class="nav-item active">
                    <a class="nav-link active" href="#">All work</a>
                </div>
            </div>
        </div>
    </nav>
</div>

<pre><code>&lt;nav class="navbar navbar-expand-lg navbar-light mb-3 navbar-module"&gt;
    &lt;div class="container-fluid"&gt;
        &lt;span class="navbar-brand mb-0 h6"&gt;Module Name&lt;/span&gt;
        &lt;div class="navbar-nav d-flex flex-row align-items-center"&gt;
            &lt;div class="nav-item"&gt;
                &lt;a class="nav-link" href="#"&gt;Link 1&lt;/a&gt;
            &lt;/div&gt;
            &lt;div class="nav-item active"&gt;
                &lt;a class="nav-link active" href="#"&gt;Active Link&lt;/a&gt;
            &lt;/div&gt;
        &lt;/div&gt;
    &lt;/div&gt;
&lt;/nav&gt;</code></pre>

<h2>Usage guidelines</h2>
<ul>
    <li>Use navbar for primary navigation</li>
    <li>Keep navigation items clear and concise</li>
    <li>Ensure responsive behavior on mobile devices</li>
    <li>Highlight the current page/section</li>
</ul>

<h2>Accessibility</h2>
<ul>
    <li>Use semantic <code>&lt;nav&gt;</code> element</li>
    <li>Provide clear labels for all navigation items</li>
    <li>Ensure keyboard navigation works</li>
    <li>Mark current page appropriately</li>
</ul>
