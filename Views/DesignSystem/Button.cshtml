@{
    ViewData["Title"] = "Button - Design System";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="/">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "DesignSystem")">Design system</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active" aria-current="page">Button</li>
        </ol>
    </nav>
}

<h1 class="ds-page-title">Button</h1>
<p class="ds-page-lead">
    Buttons trigger actions and should be clearly labelled.
</p>

<h2>Button variants</h2>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <p>
        <button type="button" class="btn btn-primary">Primary</button>
        <button type="button" class="btn btn-secondary">Secondary</button>
        <button type="button" class="btn btn-success">Success</button>
        <button type="button" class="btn btn-danger">Danger</button>
        <button type="button" class="btn btn-warning">Warning</button>
        <button type="button" class="btn btn-info">Info</button>
    </p>
    <p>
        <button type="button" class="btn btn-outline-primary">Outline Primary</button>
        <button type="button" class="btn btn-outline-secondary">Outline Secondary</button>
    </p>
    <p>
        <button type="button" class="btn btn-sm btn-primary">Small</button>
        <button type="button" class="btn btn-primary">Default</button>
        <button type="button" class="btn btn-lg btn-primary">Large</button>
    </p>
</div>

<h2>Usage guidelines</h2>
<ul>
    <li>Use primary buttons for main actions</li>
    <li>Use secondary buttons for less important actions</li>
    <li>Use danger buttons for destructive actions</li>
    <li>Provide clear, action-oriented labels</li>
    <li>Ensure buttons are appropriately sized for their context</li>
</ul>

<h2>Accessibility</h2>
<ul>
    <li>Use semantic button elements</li>
    <li>Provide clear labels for all buttons</li>
    <li>Ensure keyboard navigation works</li>
    <li>Provide visible focus indicators</li>
</ul>
