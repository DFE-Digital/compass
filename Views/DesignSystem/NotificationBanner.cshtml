@{
    ViewData["Title"] = "Notification Banner - Design System";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="/">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "DesignSystem")">Design system</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active" aria-current="page">Notification banner</li>
        </ol>
    </nav>
}

<h1 class="ds-page-title">Notification banner</h1>
<p class="ds-page-lead">
    Notification banners alert users to important information or status updates.
</p>

<h2>Warning</h2>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <div class="dfe-adminui-alert dfe-adminui-alert--warning" role="alert">
        <i class="fas fa-exclamation-triangle mr-2" aria-hidden="true"></i>
        <strong>Warning:</strong> This action cannot be undone.
    </div>
</div>

<h2>Info</h2>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <div class="dfe-adminui-alert dfe-adminui-alert--info" role="alert">
        <i class="fas fa-info-circle mr-2" aria-hidden="true"></i>
        <strong>Information:</strong> Your changes have been saved.
    </div>
</div>

<h2>Success</h2>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <div class="dfe-adminui-alert dfe-adminui-alert--success" role="alert">
        <i class="fas fa-check-circle mr-2" aria-hidden="true"></i>
        <strong>Success:</strong> The operation completed successfully.
    </div>
</div>

<h2>Danger / Error</h2>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <div class="dfe-adminui-alert dfe-adminui-alert--danger" role="alert">
        <i class="fas fa-exclamation-circle mr-2" aria-hidden="true"></i>
        <strong>Error:</strong> An error occurred. Please try again.
    </div>
</div>

<h2>Usage guidelines</h2>
<ul>
    <li>Use appropriate alert types for different situations</li>
    <li>Keep messages clear and concise</li>
    <li>Include icons for visual clarity</li>
    <li>Make dismissible alerts dismissible when appropriate</li>
</ul>

<h2>Accessibility</h2>
<ul>
    <li>Use <code>role="alert"</code> for important notifications</li>
    <li>Ensure sufficient colour contrast</li>
    <li>Don't rely on colour alone to convey information</li>
    <li>Provide clear, descriptive text</li>
</ul>
