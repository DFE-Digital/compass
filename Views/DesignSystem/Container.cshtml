@{
    ViewData["Title"] = "Container - Design System";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4 breadcrumb-design-system">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "Home")">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "DesignSystem")">Design System</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Components", "DesignSystem")">Components</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active" aria-current="page">Container</li>
        </ol>
    </nav>
}

<h1 class="ds-page-title">Container</h1>
<p class="ds-page-lead">
    Containers (cards) provide a container for related content with clear visual boundaries.
</p>

<h2>Basic card</h2>
<div class="component-example">
    <div class="component-example-title">Example - Basic card</div>
    <div class="card">
        <div class="dfe-adminui-card__header">
            <h5 class="card-title mb-0">Card title</h5>
        </div>
        <div class="dfe-adminui-card__body">
            <p class="card-text">Card content goes here.</p>
        </div>
    </div>
</div>

<h2>Card with header link</h2>
<div class="component-example">
    <div class="component-example-title">Example - Card header with action link</div>
    <div class="card mb-4">
        <div class="dfe-adminui-card__header">
            <h3 class="card-title">Aim</h3>
            <div class="card-tools">
                <a href="#" data-toggle="modal" data-target="#editAimModal">Change</a>
            </div>
        </div>
        <div class="dfe-adminui-card__body">
            <p class="mb-0">This is the aim of the project. It clearly states the primary objective and purpose.</p>
        </div>
    </div>
</div>

<pre><code>&lt;div class="card"&gt;
    &lt;div class="dfe-adminui-card__header"&gt;
        &lt;h3 class="card-title"&gt;Aim&lt;/h3&gt;
        &lt;div class="card-tools"&gt;
            &lt;a href="#" data-toggle="modal" data-target="#editModal"&gt;Change&lt;/a&gt;
        &lt;/div&gt;
    &lt;/div&gt;
    &lt;div class="dfe-adminui-card__body"&gt;
        &lt;p&gt;Card content goes here.&lt;/p&gt;
    &lt;/div&gt;
&lt;/div&gt;</code></pre>

<h2>Card with actions</h2>
<div class="component-example">
    <div class="component-example-title">Example - Card with collapse/expand actions</div>
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">Card with actions</h5>
            <div>
                <button class="btn btn-sm btn-link" type="button" data-toggle="collapse" data-target="#cardContent" aria-expanded="true">
                    <i class="fas fa-chevron-up" aria-hidden="true"></i>
                </button>
                <a href="#" class="btn btn-sm btn-link">
                    <i class="fas fa-external-link-alt" aria-hidden="true"></i>
                </a>
            </div>
        </div>
        <div class="collapse show" id="cardContent">
            <div class="dfe-adminui-card__body">
                <p>Card content that can be collapsed or expanded.</p>
            </div>
        </div>
    </div>
</div>

<h2>Usage guidelines</h2>
<ul>
    <li>Use cards to group related content</li>
    <li>Include clear headers with titles</li>
    <li>Use card actions for common operations (collapse, expand, link)</li>
    <li>Maintain consistent card styling across COMPASS</li>
</ul>

<h2>Accessibility</h2>
<ul>
    <li>Use semantic HTML structure</li>
    <li>Provide clear labels for action buttons</li>
    <li>Ensure keyboard navigation works for all interactive elements</li>
</ul>
