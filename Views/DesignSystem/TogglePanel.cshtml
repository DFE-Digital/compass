@{
    ViewData["Title"] = "Toggle Panel - Design System";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="/">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "DesignSystem")">Design system</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active" aria-current="page">Toggle panel</li>
        </ol>
    </nav>
}

<h1 class="ds-page-title">Toggle panel</h1>
<p class="ds-page-lead">
    Toggle panels allow users to show or hide content sections.
</p>

<h2>Standard toggle panel</h2>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <button class="btn btn-primary mb-2" type="button" data-toggle="collapse" data-target="#togglePanel" aria-expanded="false" aria-controls="togglePanel">
        Toggle panel
    </button>
    <div class="collapse" id="togglePanel">
        <div class="card card-body">
            This content can be toggled on and off.
        </div>
    </div>
</div>

<h2>Usage guidelines</h2>
<ul>
    <li>Use toggle panels to show/hide optional or detailed content</li>
    <li>Provide clear button labels indicating the action</li>
    <li>Use appropriate ARIA attributes for accessibility</li>
    <li>Consider the default state (expanded or collapsed)</li>
</ul>

<h2>Accessibility</h2>
<ul>
    <li>Use <code>aria-expanded</code> to indicate state</li>
    <li>Use <code>aria-controls</code> to link button to content</li>
    <li>Ensure keyboard navigation works</li>
    <li>Provide clear visual indicators for state</li>
</ul>
