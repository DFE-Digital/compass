@{
    ViewData["Title"] = "Badge - Design System";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="dfe-adminui-breadcrumb mb-0 pl-4">
            <li class="dfe-adminui-breadcrumb__item">
                <a href="/">Home</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item">
                <a href="@Url.Action("Index", "DesignSystem")">Design system</a>
            </li>
            <li class="dfe-adminui-breadcrumb__item dfe-adminui-breadcrumb__item--active" aria-current="page">Badge</li>
        </ol>
    </nav>
}

<h1 class="ds-page-title">Badge</h1>
<p class="ds-page-lead">
    Badges display status, counts, or labels in a compact format.
</p>

<h2>Badge variants</h2>
<div class="component-example">
    <div class="component-example-title">Example</div>
    <p>
        <span class="dfe-adminui-badge dfe-adminui-badge--primary">Primary</span>
        <span class="dfe-adminui-badge dfe-adminui-badge--secondary">Secondary</span>
        <span class="dfe-adminui-badge dfe-adminui-badge--success">Success</span>
        <span class="dfe-adminui-badge dfe-adminui-badge--danger">Danger</span>
        <span class="dfe-adminui-badge dfe-adminui-badge--warning">Warning</span>
        <span class="dfe-adminui-badge dfe-adminui-badge--info">Info</span>
        <span class="badge badge-light">Light</span>
        <span class="badge badge-dark">Dark</span>
    </p>
    <p>
        <span class="badge badge-pill badge-primary">Pill badge</span>
        <span class="badge badge-pill badge-success">Active</span>
    </p>
</div>

<h2>Usage guidelines</h2>
<ul>
    <li>Use badges to show status, counts, or labels</li>
    <li>Choose appropriate colours for the context</li>
    <li>Use pill badges for a softer appearance</li>
    <li>Keep badge text concise</li>
</ul>

<h2>Accessibility</h2>
<ul>
    <li>Ensure sufficient colour contrast</li>
    <li>Don't rely on colour alone to convey information</li>
    <li>Use descriptive text in badges</li>
</ul>
