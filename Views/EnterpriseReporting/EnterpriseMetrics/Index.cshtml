@model List<Compass.Models.EnterpriseReturn>
@inject Compass.Services.IReturnStatusService ReturnStatusService
@{
    ViewData["Title"] = "Enterprise metrics";
}

<style nonce="@Context.Items["Nonce"]">
    .progress-min-width {
        min-width: 120px;
    }
</style>

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item active">Enterprise metrics</li>
                </ol>
                <h1 class="m-0">Enterprise metric returns</h1>
            </div>
            <div class="col-sm-6 text-right">
                <a href="@Url.Action("Index", "Documentation")#enterprise-metrics" class="btn btn-outline-info btn-sm">
                    View documentation
                </a>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        @{
            var currentReturns = Model?.Where(r => r.Status == Compass.Models.ReturnStatus.Due || r.Status == Compass.Models.ReturnStatus.Late).ToList() ?? new List<Compass.Models.EnterpriseReturn>();
            var upcomingReturns = Model?.Where(r => r.Status == Compass.Models.ReturnStatus.Upcoming).ToList() ?? new List<Compass.Models.EnterpriseReturn>();
            var submittedReturns = Model?.Where(r => r.Status == Compass.Models.ReturnStatus.Submitted).ToList() ?? new List<Compass.Models.EnterpriseReturn>();
        }

        <!-- Current Returns (Due/Late) -->
        @if (currentReturns.Any())
        {
            <div class="card card-warning">
                <div class="card-header">
                    <h3 class="card-title"><i class="fas fa-exclamation-triangle"></i> Current returns</h3>
                </div>
                <div class="card-body table-responsive p-0">
                    <table class="table table-hover text-nowrap">
                        <thead>
                            <tr>
                                <th class="col-period">Period</th>
                                <th class="col-date">Due date</th>
                                <th class="col-status">Status</th>
                                <th class="col-progress">Progress</th>
                                <th class="col-actions text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var return_item in currentReturns)
                            {
                                var dueDate = ReturnStatusService.GetReturnDueDate(return_item.Year, return_item.Month);
                                var totalMetrics = return_item.MetricValues?.Count ?? 0;
                                var completedMetrics = return_item.MetricValues?.Count(mv => mv.IsComplete) ?? 0;
                                
                                <tr>
                                    <td><strong>@(new DateTime(return_item.Year, return_item.Month, 1).ToString("MMMM yyyy"))</strong></td>
                                    <td>@dueDate.ToString("d MMM yyyy")</td>
                                    <td>
                                        @switch (return_item.Status)
                                        {
                                            case Compass.Models.ReturnStatus.Due:
                                                <span class="badge badge-warning">Due</span>
                                                break;
                                            case Compass.Models.ReturnStatus.Late:
                                                <span class="badge badge-danger">Late</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (totalMetrics > 0)
                                        {
                                            var percentage = (int)((double)completedMetrics / totalMetrics * 100);
                                            var progressBarWidth = $"width: {percentage}%";
                                            <div class="progress progress-min-width">
                                                <div class="progress-bar @(percentage == 100 ? "bg-success" : "bg-info")" role="progressbar" 
                                                     style="@progressBarWidth" aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100">
                                                    @completedMetrics/@totalMetrics
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not started</span>
                                        }
                                    </td>
                                    <td class="text-right">
                                        <a asp-action="SubmitEnterpriseMetrics" asp-route-year="@return_item.Year" asp-route-month="@return_item.Month" 
                                           class="btn btn-sm btn-primary">
                                            Enter data
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- Upcoming Returns -->
        @if (upcomingReturns.Any())
        {
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h3 class="card-title"><i class="fas fa-clock"></i> Upcoming returns</h3>
                </div>
                <div class="card-body table-responsive p-0">
                    <table class="table table-hover text-nowrap">
                        <thead>
                            <tr>
                                <th class="col-period">Period</th>
                                <th class="col-date">Due date</th>
                                <th class="col-status">Status</th>
                                <th class="col-actions text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var return_item in upcomingReturns)
                            {
                                var dueDate = ReturnStatusService.GetReturnDueDate(return_item.Year, return_item.Month);
                                
                                <tr>
                                    <td><strong>@(new DateTime(return_item.Year, return_item.Month, 1).ToString("MMMM yyyy"))</strong></td>
                                    <td>@dueDate.ToString("d MMM yyyy")</td>
                                    <td>
                                        <span class="badge badge-secondary">Upcoming</span>
                                    </td>
                                    <td class="text-right">
                                        <a asp-action="SubmitEnterpriseMetrics" asp-route-year="@return_item.Year" asp-route-month="@return_item.Month" 
                                           class="btn btn-sm btn-default">
                                            View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- Submitted Returns -->
        @if (submittedReturns.Any())
        {
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h3 class="card-title"><i class="fas fa-check-circle"></i> Submitted returns</h3>
                </div>
                <div class="card-body table-responsive p-0">
                    <table class="table table-hover text-nowrap">
                        <thead>
                            <tr>
                                <th class="col-period">Period</th>
                                <th class="col-date">Submitted</th>
                                <th class="col-status">Status</th>
                                <th class="col-actions text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var return_item in submittedReturns)
                            {
                                <tr>
                                    <td><strong>@(new DateTime(return_item.Year, return_item.Month, 1).ToString("MMMM yyyy"))</strong></td>
                                    <td>
                                        <span>@return_item.SubmittedDate.Value.ToString("d MMM yyyy")</span>
                                        <br />
                                        <small class="text-muted">by @return_item.SubmittedBy</small>
                                    </td>
                                    <td>
                                        <span class="badge badge-success"><i class="fas fa-check-circle"></i> Submitted</span>
                                    </td>
                                    <td class="text-right">
                                        <button type="button" class="btn btn-sm btn-default" data-toggle="modal" data-target="#viewModal_@return_item.Id">
                                            View
                                        </button>
                                        <button type="button" class="btn btn-sm btn-warning ml-1" data-toggle="modal" data-target="#unsubmitModal_@return_item.Id">
                                            Unsubmit
                                        </button>
                                        
                                        <!-- Unsubmit Confirmation Modal -->
                                        <div class="modal fade" id="unsubmitModal_@return_item.Id" tabindex="-1" role="dialog">
                                            <div class="modal-dialog" role="document">
                                                <div class="modal-content">
                                                    <div class="modal-header bg-warning">
                                                        <h5 class="modal-title">Unsubmit return</h5>
                                                        <button type="button" class="close" data-dismiss="modal">
                                                            <span>&times;</span>
                                                        </button>
                                                    </div>
                                                    <div class="modal-body text-left">
                                                        <p>Are you sure you want to unsubmit the return for <strong>@(new DateTime(return_item.Year, return_item.Month, 1).ToString("MMMM yyyy"))</strong>?</p>
                                                        <p class="text-warning"><i class="fas fa-exclamation-triangle"></i> This will make the return available for editing again.</p>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                                                        <form asp-action="UnsubmitEnterpriseReturn" method="post" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="returnId" value="@return_item.Id" />
                                                            <button type="submit" class="btn btn-warning">
                                                                Unsubmit return
                                                            </button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            
            <!-- Modals for viewing submitted returns -->
            @foreach (var return_item in submittedReturns)
            {
                <div class="modal fade" id="viewModal_@return_item.Id" tabindex="-1" role="dialog" aria-labelledby="viewModalLabel_@return_item.Id" aria-hidden="true">
                    <div class="modal-dialog modal-lg" role="document">
                        <div class="modal-content">
                            <div class="modal-header bg-success">
                                <h5 class="modal-title" id="viewModalLabel_@return_item.Id">
                                    <i class="fas fa-check-circle"></i> Submitted enterprise metrics - @(new DateTime(return_item.Year, return_item.Month, 1).ToString("MMMM yyyy"))
                                </h5>
                                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                            </div>
                            <div class="modal-body">
                                <div class="mb-3">
                                    <strong>Submitted:</strong> @return_item.SubmittedDate.Value.ToString("d MMM yyyy")<br/>
                                    <strong>By:</strong> @return_item.SubmittedBy
                                </div>
                                
                                <table class="table table-sm table-bordered">
                                    <thead>
                                        <tr>
                                            <th>Identifier</th>
                                            <th>Metric</th>
                                            <th>Value</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (return_item.MetricValues != null && return_item.MetricValues.Any())
                                        {
                                            @foreach (var metricValue in return_item.MetricValues.OrderBy(mv => mv.EnterpriseMetric?.Identifier))
                                            {
                                                <tr>
                                                    <td><strong>@metricValue.EnterpriseMetric?.Identifier</strong></td>
                                                    <td>
                                                        @metricValue.EnterpriseMetric?.Title
                                                        @if (!string.IsNullOrEmpty(metricValue.EnterpriseMetric?.Description))
                                                        {
                                                            <br/><small class="text-muted">@metricValue.EnterpriseMetric?.Description</small>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (!string.IsNullOrEmpty(metricValue.Value))
                                                        {
                                                            <strong>@metricValue.Value</strong>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">Unreported</span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="3" class="text-center text-muted">No metric values found</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</section>

