@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Objective details";
    var objective = ViewBag.Objective as Compass.Models.Objective;
    var risks = ViewBag.Risks as List<Compass.Models.Risk> ?? new List<Compass.Models.Risk>();
    var issues = ViewBag.Issues as List<Compass.Models.Issue> ?? new List<Compass.Models.Issue>();
    var objectiveActions = ViewBag.Actions as List<Compass.Models.Action> ?? new List<Compass.Models.Action>();
    var milestones = ViewBag.Milestones as List<Compass.Models.Milestone> ?? new List<Compass.Models.Milestone>();
    var projects = ViewBag.Projects as List<Compass.Models.Project> ?? new List<Compass.Models.Project>();
    var associatedProducts = ViewBag.AssociatedProducts as List<Compass.Models.ProductDto> ?? new List<Compass.Models.ProductDto>();
    var allProducts = ViewBag.Products as List<Compass.Models.ProductDto> ?? new List<Compass.Models.ProductDto>();
    var relatedObjectives = ViewBag.RelatedObjectives as List<Compass.Models.Objective> ?? new List<Compass.Models.Objective>();
    var fipsBaseUrl = Configuration["fipsProduct:baseUrl"] ?? "https://find-products-services-test.azurewebsites.net/";
    var currentView = ViewBag.CurrentView as string ?? "overview";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Objectives">Strategic objectives</a></li>
                    <li class="breadcrumb-item active">@objective.Title</li>
                </ol>
                <h1 class="m-0">@objective.Title</h1>
                @if (!string.IsNullOrEmpty(objective.Theme))
                {
                    <p class="text-muted mb-0">@objective.Theme</p>
                }
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <div class="btn-group">
                        <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            Actions
                        </button>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" asp-action="Edit" asp-route-id="@objective.Id">Edit objective</a>
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item" asp-controller="Risk" asp-action="Create" asp-route-objectiveId="@objective.Id">Add risk</a>
                            <a class="dropdown-item" asp-controller="Issue" asp-action="Create" asp-route-objectiveId="@objective.Id">Add issue</a>
                            <a class="dropdown-item" asp-controller="Action" asp-action="Create" asp-route-objectiveId="@objective.Id">Add action</a>
                            <a class="dropdown-item" asp-controller="Milestone" asp-action="Create" asp-route-objectiveId="@objective.Id">Add milestone</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <!-- Navigation Pills -->
        <ul class="nav nav-pills mb-3">
            <li class="nav-item">
                <a class="nav-link @(currentView == "overview" ? "active" : "")" href="?view=overview">Overview</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentView == "risks" ? "active" : "")" href="?view=risks">
                    Risks
                    @if (risks.Any())
                    {
                        <span class="badge badge-light ml-1">@risks.Count</span>
                    }
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentView == "issues" ? "active" : "")" href="?view=issues">
                    Issues
                    @if (issues.Any())
                    {
                        <span class="badge badge-light ml-1">@issues.Count</span>
                    }
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentView == "actions" ? "active" : "")" href="?view=actions">
                    Actions
                    @if (objectiveActions.Any())
                    {
                        <span class="badge badge-light ml-1">@objectiveActions.Count</span>
                    }
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentView == "milestones" ? "active" : "")" href="?view=milestones">
                    Milestones
                    @if (milestones.Any())
                    {
                        <span class="badge badge-light ml-1">@milestones.Count</span>
                    }
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentView == "projects" ? "active" : "")" href="?view=projects">
                    Projects
                    @if (projects.Any())
                    {
                        <span class="badge badge-light ml-1">@projects.Count</span>
                    }
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentView == "products" ? "active" : "")" href="?view=products">
                    Products
                    @if (associatedProducts.Any())
                    {
                        <span class="badge badge-light ml-1">@associatedProducts.Count</span>
                    }
                </a>
            </li>
        </ul>

        <div class="row">
            <!-- Main Content -->
            <div class="col-lg-9 col-md-8 col-12">
                <!-- Overview View -->
                @if (currentView == "overview")
                {
                    <div class="row">
                        <div class="col-lg-3 col-md-6 col-12">
                            <div class="card">
                                <div class="card-body">
                                    <h3 class="mb-1">@risks.Count</h3>
                                    <p class="text-muted mb-0">Risks</p>
                                    <a href="?view=risks" class="btn btn-sm btn-outline-primary mt-2">View</a>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 col-12">
                            <div class="card">
                                <div class="card-body">
                                    <h3 class="mb-1">@issues.Count</h3>
                                    <p class="text-muted mb-0">Issues</p>
                                    <a href="?view=issues" class="btn btn-sm btn-outline-primary mt-2">View</a>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 col-12">
                            <div class="card">
                                <div class="card-body">
                                    <h3 class="mb-1">@objectiveActions.Count</h3>
                                    <p class="text-muted mb-0">Actions</p>
                                    <a href="?view=actions" class="btn btn-sm btn-outline-primary mt-2">View</a>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 col-12">
                            <div class="card">
                                <div class="card-body">
                                    <h3 class="mb-1">@milestones.Count</h3>
                                    <p class="text-muted mb-0">Milestones</p>
                                    <a href="?view=milestones" class="btn btn-sm btn-outline-primary mt-2">View</a>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-3 col-md-6 col-12">
                            <div class="card">
                                <div class="card-body">
                                    <h3 class="mb-1">@projects.Count</h3>
                                    <p class="text-muted mb-0">Projects</p>
                                    <a href="?view=projects" class="btn btn-sm btn-outline-primary mt-2">View</a>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(objective.Description))
                    {
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Description</h3>
                            </div>
                            <div class="card-body">
                                <p class="mb-0">@objective.Description</p>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(objective.SuccessMeasures))
                    {
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Success measures</h3>
                            </div>
                            <div class="card-body">
                                <p class="mb-0">@objective.SuccessMeasures</p>
                            </div>
                        </div>
                    }

                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Key statistics</h3>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-4">
                                    <p class="text-muted mb-1">High risks</p>
                                    <h4 class="mb-0 text-danger">@risks.Count(r => r.RiskScore >= 15)</h4>
                                </div>
                                <div class="col-md-4">
                                    <p class="text-muted mb-1">Critical issues</p>
                                    <h4 class="mb-0 text-danger">@issues.Count(i => i.Severity == "critical")</h4>
                                </div>
                                <div class="col-md-4">
                                    <p class="text-muted mb-1">Overdue actions</p>
                                    <h4 class="mb-0 text-warning">@objectiveActions.Count(act => act.DueDate.HasValue && act.DueDate < DateTime.Today && act.Status != "done" && act.Status != "cancelled")</h4>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Risks View -->
                @if (currentView == "risks")
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Risks</h3>
                            <div class="card-tools">
                                <a asp-controller="Risk" asp-action="Create" asp-route-objectiveId="@objective.Id" class="btn btn-sm btn-success">Add risk</a>
                            </div>
                        </div>
                        <div class="card-body table-responsive p-0">
                            @if (risks.Any())
                            {
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Title</th>
                                            <th style="width: 100px;" class="text-center">Score</th>
                                            <th style="width: 100px;" class="text-center">Impact</th>
                                            <th style="width: 100px;" class="text-center">Likelihood</th>
                                            <th style="width: 120px;">Status</th>
                                            <th style="width: 150px;">Product</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var risk in risks)
                                        {
                                            var product = allProducts.FirstOrDefault(p => p.FipsId == risk.FipsId);
                                            <tr>
                                                <td><a asp-controller="Risk" asp-action="Details" asp-route-id="@risk.Id">@risk.Title</a></td>
                                                <td class="text-center">
                                                    <span class="badge @(risk.RiskScore >= 15 ? "badge-danger" : risk.RiskScore >= 10 ? "badge-warning" : "badge-info")">@risk.RiskScore</span>
                                                </td>
                                                <td class="text-center">@risk.ImpactRating</td>
                                                <td class="text-center">@risk.LikelihoodRating</td>
                                                <td>
                                                    @switch (risk.Status)
                                                    {
                                                        case "new":
                                                            <span class="badge badge-info">New</span>
                                                            break;
                                                        case "open":
                                                            <span class="badge badge-danger">Open</span>
                                                            break;
                                                        case "treating":
                                                            <span class="badge badge-warning">Treating</span>
                                                            break;
                                                        case "monitoring":
                                                            <span class="badge badge-primary">Monitoring</span>
                                                            break;
                                                        case "closed":
                                                            <span class="badge badge-secondary">Closed</span>
                                                            break;
                                                        default:
                                                            <span class="badge badge-secondary">@risk.Status</span>
                                                            break;
                                                    }
                                                </td>
                                                <td>@(product?.Title ?? risk.FipsId ?? "-")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="text-center text-muted py-4">
                                    <p class="mb-0">No risks recorded for this objective</p>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Issues View -->
                @if (currentView == "issues")
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Issues</h3>
                            <div class="card-tools">
                                <a asp-controller="Issue" asp-action="Create" asp-route-objectiveId="@objective.Id" class="btn btn-sm btn-success">Add issue</a>
                            </div>
                        </div>
                        <div class="card-body table-responsive p-0">
                            @if (issues.Any())
                            {
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Title</th>
                                            <th style="width: 150px;">Owner</th>
                                            <th style="width: 100px;">Severity</th>
                                            <th style="width: 120px;">Status</th>
                                            <th style="width: 150px;">Product</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var issue in issues)
                                        {
                                            var product = allProducts.FirstOrDefault(p => p.FipsId == issue.FipsId);
                                            <tr>
                                                <td>
                                                    <a asp-controller="Issue" asp-action="Details" asp-route-id="@issue.Id">@issue.Title</a>
                                                    @if (issue.BlockedFlag)
                                                    {
                                                        <br><span class="text-danger small">Blocked</span>
                                                    }
                                                </td>
                                                <td>@(issue.OwnerUser?.Name ?? "-")</td>
                                                <td>
                                                    <span class="badge @(issue.Severity == "critical" ? "badge-danger" : issue.Severity == "high" ? "badge-warning" : "badge-info")">@(issue.Severity ?? "-")</span>
                                                </td>
                                                <td>
                                                    @switch (issue.Status)
                                                    {
                                                        case "open":
                                                            <span class="badge badge-danger">Open</span>
                                                            break;
                                                        case "in_progress":
                                                            <span class="badge badge-primary">In progress</span>
                                                            break;
                                                        case "resolved":
                                                            <span class="badge badge-success">Resolved</span>
                                                            break;
                                                        case "closed":
                                                            <span class="badge badge-secondary">Closed</span>
                                                            break;
                                                        default:
                                                            <span class="badge badge-secondary">@issue.Status</span>
                                                            break;
                                                    }
                                                </td>
                                                <td>@(product?.Title ?? issue.FipsId ?? "-")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="text-center text-muted py-4">
                                    <p class="mb-0">No issues recorded for this objective</p>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Actions View -->
                @if (currentView == "actions")
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Actions</h3>
                            <div class="card-tools">
                                <a asp-controller="Action" asp-action="Create" asp-route-objectiveId="@objective.Id" class="btn btn-sm btn-success">Add action</a>
                            </div>
                        </div>
                        <div class="card-body table-responsive p-0">
                            @if (objectiveActions.Any())
                            {
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Title</th>
                                            <th style="width: 150px;">Assigned to</th>
                                            <th style="width: 100px;">Priority</th>
                                            <th style="width: 120px;">Status</th>
                                            <th style="width: 120px;">Due date</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var action in objectiveActions)
                                        {
                                            var isOverdue = action.DueDate.HasValue && action.DueDate < DateTime.Today && action.Status != "done" && action.Status != "cancelled";
                                            <tr class="@(isOverdue ? "table-danger" : "")">
                                                <td><a asp-controller="Action" asp-action="Details" asp-route-id="@action.Id">@action.Title</a></td>
                                                <td>@(action.AssignedToEmail ?? "-")</td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(action.Priority))
                                                    {
                                                        var priorityClass = action.Priority switch {
                                                            "high" => "badge-danger",
                                                            "medium" => "badge-warning",
                                                            "low" => "badge-secondary",
                                                            _ => "badge-secondary"
                                                        };
                                                        <span class="badge @priorityClass">@action.Priority</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td>
                                                    @switch (action.Status)
                                                    {
                                                        case "in_progress":
                                                            <span class="badge badge-primary">In progress</span>
                                                            break;
                                                        case "blocked":
                                                            <span class="badge badge-danger">Blocked</span>
                                                            break;
                                                        case "done":
                                                            <span class="badge badge-success">Done</span>
                                                            break;
                                                        case "not_started":
                                                            <span class="badge badge-secondary">Not started</span>
                                                            break;
                                                        default:
                                                            <span class="badge badge-secondary">@action.Status</span>
                                                            break;
                                                    }
                                                </td>
                                                <td>
                                                    @if (action.DueDate.HasValue)
                                                    {
                                                        <span class="@(isOverdue ? "text-danger" : "")">
                                                            @action.DueDate.Value.ToString("dd MMM yyyy")
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="text-center text-muted py-4">
                                    <p class="mb-0">No actions recorded for this objective</p>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Milestones View -->
                @if (currentView == "milestones")
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Milestones</h3>
                            <div class="card-tools">
                                <a asp-controller="Milestone" asp-action="Create" asp-route-objectiveId="@objective.Id" class="btn btn-sm btn-success">Add milestone</a>
                            </div>
                        </div>
                        <div class="card-body table-responsive p-0">
                            @if (milestones.Any())
                            {
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th style="width: 150px;">Owner</th>
                                            <th style="width: 100px;">Progress</th>
                                            <th style="width: 120px;">Status</th>
                                            <th style="width: 120px;">Due date</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var milestone in milestones)
                                        {
                                            var isOverdue = milestone.DueDate < DateTime.Today && milestone.Status != "complete" && milestone.Status != "cancelled";
                                            <tr class="@(isOverdue ? "table-danger" : "")">
                                                <td><a asp-controller="Milestone" asp-action="Details" asp-route-id="@milestone.Id">@milestone.Name</a></td>
                                                <td>@(milestone.OwnerEmail ?? "-")</td>
                                                <td>
                                                    @if (milestone.ProgressPercent.HasValue)
                                                    {
                                                        <text>@milestone.ProgressPercent%</text>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td>
                                                    @switch (milestone.Status)
                                                    {
                                                        case "complete":
                                                            <span class="badge badge-success">Complete</span>
                                                            break;
                                                        case "on_track":
                                                            <span class="badge badge-success">On track</span>
                                                            break;
                                                        case "at_risk":
                                                            <span class="badge badge-warning">At risk</span>
                                                            break;
                                                        case "delayed":
                                                            <span class="badge badge-danger">Delayed</span>
                                                            break;
                                                        default:
                                                            <span class="badge badge-secondary">@milestone.Status</span>
                                                            break;
                                                    }
                                                </td>
                                                <td>
                                                    <span class="@(isOverdue ? "text-danger" : "")">
                                                        @milestone.DueDate.ToString("dd MMM yyyy")
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="text-center text-muted py-4">
                                    <p class="mb-0">No milestones recorded for this objective</p>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Projects View -->
                @if (currentView == "projects")
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Associated Projects</h3>
                            <div class="card-tools">
                                <a asp-controller="Project" asp-action="Create" class="btn btn-sm btn-success">Add Project</a>
                            </div>
                        </div>
                        <div class="card-body table-responsive p-0">
                            @if (projects.Any())
                            {
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Project Code</th>
                                            <th>Title</th>
                                            <th style="width: 100px;">RAG Status</th>
                                            <th style="width: 120px;">Status</th>
                                            <th style="width: 120px;">Target Delivery</th>
                                            <th style="width: 100px;">Flagship</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var project in projects)
                                        {
                                            <tr>
                                                <td><span class="font-weight-bold text-primary">@project.ProjectCode</span></td>
                                                <td><a asp-controller="Project" asp-action="Details" asp-route-id="@project.Id">@project.Title</a></td>
                                                <td>
                                                    <span class="badge @(project.RagStatus == "Red" ? "badge-danger" : project.RagStatus == "Amber-Red" ? "badge-warning" : project.RagStatus == "Amber-Green" ? "badge-info" : "badge-success")">
                                                        @project.RagStatus
                                                    </span>
                                                </td>
                                                <td>
                                                    @switch (project.Status)
                                                    {
                                                        case "Active":
                                                            <span class="badge badge-success">@project.Status</span>
                                                            break;
                                                        case "Paused":
                                                            <span class="badge badge-warning">@project.Status</span>
                                                            break;
                                                        case "Completed":
                                                            <span class="badge badge-primary">@project.Status</span>
                                                            break;
                                                        case "Cancelled":
                                                            <span class="badge badge-danger">@project.Status</span>
                                                            break;
                                                        default:
                                                            <span class="badge badge-secondary">@project.Status</span>
                                                            break;
                                                    }
                                                </td>
                                                <td>@project.TargetDeliveryDate.ToString("dd MMM yyyy")</td>
                                                <td>@(project.IsFlagship ? "Yes" : "No")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="text-center text-muted py-4">
                                    <p class="mb-0">No projects associated with this objective</p>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Products View -->
                @if (currentView == "products")
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Associated products</h3>
                        </div>
                        <div class="card-body">
                            @if (associatedProducts.Any())
                            {
                                <div class="row">
                                    @foreach (var product in associatedProducts.OrderBy(p => p.Title))
                                    {
                                        <div class="col-lg-6 col-12 mb-3">
                                            <h5 class="mb-1">@product.Title</h5>
                                            <p class="text-muted mb-1"><small>@product.FipsId</small></p>
                                            <a href="@($"{fipsBaseUrl.TrimEnd('/')}/product/{product.FipsId}")" target="_blank" rel="noopener noreferrer" class="btn btn-sm btn-outline-primary">
                                                View in FIPS
                                            </a>
                                            <a asp-controller="Products" asp-action="Dashboard" asp-route-id="@product.FipsId" class="btn btn-sm btn-outline-primary">
                                                Dashboard
                                            </a>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-center text-muted py-4">
                                    <p class="mb-0">No products associated with this objective</p>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Sidebar -->
            <div class="col-lg-3 col-md-4 col-12">
                <!-- Objective Info -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Details</h3>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            @if (!string.IsNullOrEmpty(objective.Theme))
                            {
                                <dt class="col-sm-12 mb-1">Theme</dt>
                                <dd class="col-sm-12 mb-3">@objective.Theme</dd>
                            }
                            
                            @if (objective.OwnerUser != null)
                            {
                                <dt class="col-sm-12 mb-1">Owner</dt>
                                <dd class="col-sm-12 mb-3">
                                    @objective.OwnerUser.Name
                                    @if (!string.IsNullOrEmpty(objective.OwnerUser.Email))
                                    {
                                        <br><small><a href="mailto:@objective.OwnerUser.Email">@objective.OwnerUser.Email</a></small>
                                    }
                                </dd>
                            }
                            
                            @if (!string.IsNullOrEmpty(objective.Status))
                            {
                                <dt class="col-sm-12 mb-1">Status</dt>
                                <dd class="col-sm-12 mb-3">
                                    <span class="badge @(objective.Status == "active" ? "badge-success" : objective.Status == "completed" ? "badge-primary" : "badge-secondary")">
                                        @objective.Status
                                    </span>
                                </dd>
                            }
                            
                            @if (!string.IsNullOrEmpty(objective.RagStatus))
                            {
                                <dt class="col-sm-12 mb-1">RAG status</dt>
                                <dd class="col-sm-12 mb-3">
                                    <span class="badge @(objective.RagStatus == "red" ? "badge-danger" : objective.RagStatus == "amber" ? "badge-warning" : "badge-success")">
                                        @objective.RagStatus.ToUpper()
                                    </span>
                                </dd>
                            }
                            
                            @if (objective.ProgressPercent.HasValue)
                            {
                                <dt class="col-sm-12 mb-1">Progress</dt>
                                <dd class="col-sm-12 mb-3">@objective.ProgressPercent%</dd>
                            }
                        </dl>
                    </div>
                </div>

                <!-- Timeline -->
                @if (objective.StartDate.HasValue || objective.EndDate.HasValue)
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Timeline</h3>
                        </div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                @if (objective.StartDate.HasValue)
                                {
                                    <dt class="col-sm-12 mb-1">Start date</dt>
                                    <dd class="col-sm-12 mb-3">@objective.StartDate.Value.ToString("dd MMM yyyy")</dd>
                                }
                                
                                @if (objective.EndDate.HasValue)
                                {
                                    <dt class="col-sm-12 mb-1">End date</dt>
                                    <dd class="col-sm-12 mb-3">@objective.EndDate.Value.ToString("dd MMM yyyy")</dd>
                                }
                                
                                <dt class="col-sm-12 mb-1">Created</dt>
                                <dd class="col-sm-12 mb-3">@objective.CreatedAt.ToString("dd MMM yyyy")</dd>
                                
                                <dt class="col-sm-12 mb-1">Updated</dt>
                                <dd class="col-sm-12 mb-0">@objective.UpdatedAt.ToString("dd MMM yyyy")</dd>
                            </dl>
                        </div>
                    </div>
                }

                <!-- Related Objectives -->
                @if (relatedObjectives.Any())
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Related objectives</h3>
                        </div>
                        <div class="card-body">
                            <p class="text-muted mb-2"><small>Other objectives in <strong>@objective.Theme</strong></small></p>
                            <ul class="list-unstyled mb-0">
                                @foreach (var relatedObj in relatedObjectives)
                                {
                                    <li class="mb-2">
                                        <a asp-action="ObjectiveDetails" asp-route-id="@relatedObj.Id">@relatedObj.Title</a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>
