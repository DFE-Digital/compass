@using System.Linq

@{
    ViewData["Title"] = "Functional standards assessments";
    var standards = (ViewBag.Standards as IEnumerable<dynamic>)?.ToList() ?? new System.Collections.Generic.List<dynamic>();
    
    // Calculate summary statistics
    var totalStandards = standards.Count;
    var totalInProgress = standards.Sum(s => (int)s.InProgressAssessments);
    var totalCompleted = standards.Sum(s => (int)s.CompletedAssessments);
    var totalAssessments = totalInProgress + totalCompleted;
}

@section Breadcrumbs {
    <style>
        .breadcrumb a:hover {
            color: #003078 !important;
            text-decoration: underline !important;
        }
    </style>
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Functional standards</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        @{
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
            ViewBag.BrandText = "Functional Standards";
            ViewBag.NavLinks = new[]
            {
                new { Text = "Functional standards", Action = "FunctionalStandards", Controller = "EnterpriseReporting", Url = (string)null, IsButton = false, IsActive = currentAction == "FunctionalStandards" },
                new { Text = "Guidance", Action = "FunctionalStandardsGuidance", Controller = "EnterpriseReporting", Url = (string)null, IsButton = false, IsActive = currentAction == "FunctionalStandardsGuidance" }
            };
        }
        @await Html.PartialAsync("_ModuleNavbar")

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <!-- Summary Cards -->
        <div class="row mb-4">
            <div class="col-md-6 col-lg-3 mb-3">
                <div class="card border-left-info shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Total Standards</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@totalStandards</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-list-alt fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-3">
                <div class="card border-left-primary shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Assessments</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@totalAssessments</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-clipboard-check fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-3">
                <div class="card border-left-warning shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">In Progress</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@totalInProgress</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-spinner fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-lg-3 mb-3">
                <div class="card border-left-success shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Completed</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@totalCompleted</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-check-circle fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                @await Html.PartialAsync("_StandardsNavigation", "Functional")
            </div>

            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Functional standards</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            @if (standards.Any())
                            {
                                <table class="table table-hover text-nowrap sortable-table mb-0 standards-table">
                                    <thead>
                                        <tr>
                                            <th scope="col" class="sortable" data-column="Standard" tabindex="0" role="button" aria-label="Sort by standard">Standard <i class="fas fa-sort sort-icon"></i></th>
                                            <th scope="col" class="sortable text-center" data-column="Criteria" tabindex="0" role="button" aria-label="Sort by criteria">Criteria <i class="fas fa-sort sort-icon"></i></th>
                                            <th scope="col" class="sortable text-center" data-column="InProgress" tabindex="0" role="button" aria-label="Sort by in progress assessments">In progress <i class="fas fa-sort sort-icon"></i></th>
                                            <th scope="col" class="sortable text-center" data-column="Completed" tabindex="0" role="button" aria-label="Sort by completed assessments">Completed <i class="fas fa-sort sort-icon"></i></th>
                                            <th scope="col" class="sortable text-center" data-column="Total" tabindex="0" role="button" aria-label="Sort by total assessments">Total assessments <i class="fas fa-sort sort-icon"></i></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in standards)
                                        {
                                            Compass.Models.FunctionalStandard standard = item.Standard;
                                            int criteriaCount = item.CriteriaCount;
                                            int inProgressAssessments = item.InProgressAssessments;
                                            int completedAssessments = item.CompletedAssessments;
                                            int standardTotalAssessments = inProgressAssessments + completedAssessments;
                                            string description = standard.Description;
                                            string truncatedDescription = string.IsNullOrWhiteSpace(description)
                                                ? null
                                                : (description.Length > 200 ? description.Substring(0, 200).TrimEnd() + "…" : description);

                                            <tr>
                                                <td>
                                                    <strong><a class="text-body" asp-action="SelectStandard" asp-route-standardId="@standard.Id">@standard.Title</a></strong>
                                                    @if (!string.IsNullOrEmpty(truncatedDescription))
                                                    {
                                                        <div class="text-muted small mt-1">@truncatedDescription</div>
                                                    }
                                                </td>
                                                <td class="text-center">@criteriaCount</td>
                                                <td class="text-center">
                                                    @if (inProgressAssessments > 0)
                                                    {
                                                        <span class="badge badge-warning">@inProgressAssessments</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">0</span>
                                                    }
                                                </td>
                                                <td class="text-center">
                                                    @if (completedAssessments > 0)
                                                    {
                                                        <span class="badge badge-success">@completedAssessments</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">0</span>
                                                    }
                                                </td>
                                                <td class="text-center">
                                                    <strong>@standardTotalAssessments</strong>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="p-4 text-center">
                                    <p class="text-muted mb-0">No functional standards found.</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .border-left-primary {
        border-left: 0.25rem solid #4e73df !important;
    }
    .border-left-success {
        border-left: 0.25rem solid #1cc88a !important;
    }
    .border-left-warning {
        border-left: 0.25rem solid #f6c23e !important;
    }
    .border-left-info {
        border-left: 0.25rem solid #36b9cc !important;
    }
    .text-xs {
        font-size: 0.7rem;
    }
    .text-gray-300 {
        color: #dddfeb !important;
    }
    .text-gray-800 {
        color: #5a5c69 !important;
    }
    .shadow {
        box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15) !important;
    }
</style>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function () {
            $('.sortable-table').each(function () {
                initialiseFunctionalStandardsTable($(this));
            });
        });

        function initialiseFunctionalStandardsTable(table) {
            var currentSort = { column: null, direction: 'asc' };

            table.find('.sortable').on('click keypress', function (e) {
                if (e.type === 'keypress' && e.which !== 13 && e.which !== 32) {
                    return;
                }

                var column = $(this).data('column');
                var direction = currentSort.column === column && currentSort.direction === 'asc' ? 'desc' : 'asc';

                sortTable(table, column, direction);
                currentSort = { column: column, direction: direction };
            });

            function sortTable(table, column, direction) {
                var tbody = table.find('tbody');
                var rows = tbody.find('tr').toArray();

                rows.sort(function (a, b) {
                    var aValue = getCellValue(a, column, table);
                    var bValue = getCellValue(b, column, table);

                    if (aValue > bValue) {
                        return direction === 'asc' ? 1 : -1;
                    }
                    if (aValue < bValue) {
                        return direction === 'asc' ? -1 : 1;
                    }
                    return 0;
                });

                tbody.empty();
                rows.forEach(function (row) {
                    tbody.append(row);
                });

                updateSortIcons(table, column, direction);
            }

            function getCellValue(row, column, table) {
                var colIndex = table.find('thead th[data-column="' + column + '"]').index();
                var text = $(row).find('td').eq(colIndex).text().trim();

                switch (column) {
                    case 'Criteria':
                    case 'InProgress':
                    case 'Completed':
                    case 'Total':
                        return parseInt(text, 10) || 0;
                    default:
                        return text.toLowerCase();
                }
            }

            function updateSortIcons(table, column, direction) {
                table.find('.sortable i').removeClass('fa-sort-up fa-sort-down').addClass('fa-sort');
                var iconClass = direction === 'asc' ? 'fa-sort-up' : 'fa-sort-down';
                table.find('.sortable[data-column="' + column + '"] i').removeClass('fa-sort').addClass(iconClass);
            }
        }
    </script>
}
