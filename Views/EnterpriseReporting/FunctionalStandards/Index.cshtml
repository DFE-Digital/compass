@{
    ViewData["Title"] = "Functional standards assessments";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item active">Functional standards</li>
                </ol>
                <h1 class="m-0">Functional standards assessments</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            @{
                var standards = ViewBag.Standards as System.Collections.IEnumerable;
                bool hasStandards = false;
                if (standards != null)
                {
                    foreach (dynamic item in standards)
                    {
                        hasStandards = true;
                        Compass.Models.FunctionalStandard standard = item.Standard;
                        int criteriaCount = item.CriteriaCount;
                        int inProgressAssessments = item.InProgressAssessments;
                        int completedAssessments = item.CompletedAssessments;
                        int totalAssessments = inProgressAssessments + completedAssessments;
                        
                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="card h-100 shadow-sm" style="transition: all 0.3s ease;">
                                <div class="card-header bg-primary text-white">
                                    <h5 class="card-title mb-0 font-weight-bold">@standard.Title</h5>
                                </div>
                                <div class="card-body">
                                    @if (!string.IsNullOrEmpty(standard.Description))
                                    {
                                        <p class="text-muted mb-3" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.5;">
                                            @standard.Description
                                        </p>
                                    }
                                    
                                    <div class="row text-center mb-3">
                                        <div class="col-4">
                                            <div class="border rounded p-2">
                                                <div class="h4 mb-0 text-primary">@criteriaCount</div>
                                                <small class="text-muted d-block">Criteria</small>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="border rounded p-2">
                                                <div class="h4 mb-0 text-warning">@inProgressAssessments</div>
                                                <small class="text-muted d-block">In Progress</small>
                                            </div>
                                        </div>
                                        <div class="col-4">
                                            <div class="border rounded p-2">
                                                <div class="h4 mb-0 text-success">@completedAssessments</div>
                                                <small class="text-muted d-block">Completed</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-footer bg-transparent border-top">
                                    <a asp-action="SelectStandard" asp-route-standardId="@standard.Id" class="btn btn-primary">
                                        View standard
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                }
                if (!hasStandards)
                {
                    <div class="col-12">
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle mr-2"></i>No functional standards found
                        </div>
                    </div>
                }
            }
        </div>
        
        <style>
            .card:hover {
                transform: translateY(-5px);
                box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
            }
            .card .border {
                background-color: #f8f9fa;
            }
        </style>
    </div>
</section>

