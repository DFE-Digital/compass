@{
    ViewData["Title"] = "Functional standards assessments";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item active">Functional standards</li>
                </ol>
                <h1 class="m-0">Functional standards assessments</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            @{
                var standards = ViewBag.Standards as System.Collections.IEnumerable;
                bool hasStandards = false;
                if (standards != null)
                {
                    foreach (dynamic item in standards)
                    {
                        hasStandards = true;
                        Compass.Models.FunctionalStandard standard = item.Standard;
                        int criteriaCount = item.CriteriaCount;
                        int inProgressAssessments = item.InProgressAssessments;
                        int completedAssessments = item.CompletedAssessments;
                        
                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="card h-100">
                                <div class="card-header">
                                    <h5 class="card-title mb-0">@standard.Title</h5>
                                </div>
                                <div class="card-body">
                                    @if (!string.IsNullOrEmpty(standard.Description))
                                    {
                                        <p class="mb-3">@standard.Description</p>
                                    }
                                    <dl class="mb-0">
                                        <dt>Published:</dt>
                                        <dd>
                                            @if (standard.PublishedDate.HasValue)
                                            {
                                                @standard.PublishedDate.Value.ToString("d MMM yyyy")
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not published</span>
                                            }
                                        </dd>
                                        <dt>Criteria:</dt>
                                        <dd>@criteriaCount</dd>
                                        <dt>Assessments in progress:</dt>
                                        <dd>@inProgressAssessments</dd>
                                        <dt>Completed assessments:</dt>
                                        <dd>@completedAssessments</dd>
                                    </dl>
                                </div>
                                <div class="card-footer">
                                    <a asp-action="SelectStandard" asp-route-standardId="@standard.Id" class="btn btn-primary btn-sm">
                                        View standard
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                }
                if (!hasStandards)
                {
                    <div class="col-12">
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> No functional standards found
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

