@{
    ViewData["Title"] = "Functional standards assessments";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item active">Functional standards</li>
                </ol>
                <h1 class="m-0">Functional standards assessments</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Available functional standards</h3>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th style="width: 40%;">Title</th>
                            <th style="width: 15%;">Published</th>
                            <th style="width: 15%;">Criteria</th>
                            <th style="width: 15%;">Assessments in progress</th>
                            <th style="width: 15%;">Completed assessments</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.Standards != null)
                        {
                            @foreach (dynamic item in ViewBag.Standards)
                            {
                                Compass.Models.FunctionalStandard standard = item.Standard;
                                int criteriaCount = item.CriteriaCount;
                                int inProgressAssessments = item.InProgressAssessments;
                                int completedAssessments = item.CompletedAssessments;
                                
                                <tr>
                                    <td>
                                        <a asp-action="SelectStandard" asp-route-standardId="@standard.Id" class="font-weight-bold">
                                            @standard.Title
                                        </a>
                                    </td>
                                    <td>
                                        @if (standard.PublishedDate.HasValue)
                                        {
                                            @standard.PublishedDate.Value.ToString("d MMM yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not published</span>
                                        }
                                    </td>
                                    <td>@criteriaCount</td>
                                    <td>@inProgressAssessments</td>
                                    <td>@completedAssessments</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">No functional standards found</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

