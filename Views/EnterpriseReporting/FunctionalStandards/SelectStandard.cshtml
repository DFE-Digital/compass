@{
    ViewData["Title"] = "Start assessment";
    var standard = ViewBag.Standard as Compass.Models.FunctionalStandard;
    var inProgressAssessments = ViewBag.InProgressAssessments as List<dynamic>;
    var submittedAssessments = ViewBag.SubmittedAssessments as List<dynamic>;
}

@section Breadcrumbs {
    <style>
        .breadcrumb a:hover {
            color: #003078 !important;
            text-decoration: underline !important;
        }
    </style>
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4 breadcrumb-standard">
            <li class="breadcrumb-item">
                <a href="/" class="breadcrumb-link-standard">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="FunctionalStandards" class="breadcrumb-link-standard">Functional standards</a>
            </li>
            <li class="breadcrumb-item active breadcrumb-active-standard" aria-current="page">Standard overview</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">@standard.Title</h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    @{
                        var hasInProgress = ViewBag.HasInProgressAssessment as bool? ?? false;
                    }
                    @if (hasInProgress)
                    {
                        <button type="button" class="btn btn-success" data-toggle="modal" data-target="#inProgressWarningModal">
                            Start new assessment
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-success" data-toggle="modal" data-target="#startAssessmentModal">
                            Start new assessment
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">In progress assessments</h3>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th class="col-width-40">Assessment name</th>
                            <th class="col-width-20">Started by</th>
                            <th class="col-width-20">Started</th>
                            <th class="col-width-20">Criteria</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (inProgressAssessments != null && inProgressAssessments.Any())
                        {
                            @foreach (dynamic item in inProgressAssessments)
                            {
                                Compass.Models.FunctionalStandardAssessment assessment = item.Assessment;
                                int completedCount = item.CompletedCount;
                                int totalCount = item.TotalCount;
                                bool isComplete = item.IsComplete;
                                string userName = item.UserName ?? assessment.AssessedBy;
                                
                                <tr>
                                    <td>
                                        <a asp-action="ConductAssessment" asp-route-assessmentId="@assessment.Id" class="font-weight-bold">
                                            @assessment.AssessmentName
                                        </a>
                                    </td>
                                    <td>@userName</td>
                                    <td>@assessment.AssessmentDate.ToString("d MMM yyyy HH:mm")</td>
                                    <td>
                                        @completedCount of @totalCount <span class="sr-only">criteria completed</span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">No assessments in progress</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Submitted assessments</h3>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th class="col-width-50">Assessment name</th>
                            <th class="col-width-25">Submitted</th>
                            <th class="col-width-25">Assessed by</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (submittedAssessments != null && submittedAssessments.Any())
                        {
                            @foreach (dynamic item in submittedAssessments)
                            {
                                Compass.Models.FunctionalStandardAssessment assessment = item.Assessment;
                                
                                <tr>
                                    <td>
                                        <a asp-action="ViewAssessmentSummary" asp-route-assessmentId="@assessment.Id" class="font-weight-bold">
                                            @assessment.AssessmentName
                                        </a>
                                    </td>
                                    <td>@assessment.SubmittedAt?.ToString("d MMM yyyy HH:mm")</td>
                                    <td>@assessment.AssessedBy</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted">No submitted assessments</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<!-- In Progress Warning Modal -->
<div class="modal fade" id="inProgressWarningModal" tabindex="-1" role="dialog" aria-labelledby="inProgressWarningModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title" id="inProgressWarningModalLabel">Cannot start new assessment</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>You cannot start a new assessment as one is already in progress.</p>
                <p class="mb-0">Please complete or submit the existing assessment before starting a new one.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Start Assessment Modal -->
<div class="modal fade" id="startAssessmentModal" tabindex="-1" role="dialog" aria-labelledby="startAssessmentModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="startAssessmentModalLabel">Start new assessment</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>Create a new assessment for <strong>@standard.Title</strong>.</p>
                <p class="text-muted">
                    @if (standard.Themes != null)
                    {
                        var totalCriteria = standard.Themes.Sum(t => t.PracticeAreas?.Sum(pa => pa.Criteria?.Count ?? 0) ?? 0);
                        <span>This assessment includes @totalCriteria criteria across @standard.Themes.Count themes.</span>
                    }
                </p>
                <form asp-action="StartAssessment" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="standardId" value="@standard.Id" />
                    <div class="form-group">
                        <label for="assessmentName">Assessment name</label>
                        <input type="text" id="assessmentName" name="assessmentName" class="form-control" placeholder="e.g., Q4 2025 Assessment" required />
                        <small class="form-text text-muted">Provide a name to identify this assessment</small>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">
                            Start assessment
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

