@{
    ViewData["Title"] = "Functional Standards - Guidance";
}

@section Breadcrumbs {
    <style>
        .breadcrumb a:hover {
            color: #003078 !important;
            text-decoration: underline !important;
        }
    </style>
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="FunctionalStandards" style="color: #005ea5; text-decoration: none;">Functional standards</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Guidance</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        @{
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
            ViewBag.BrandText = "Functional Standards";
            ViewBag.NavLinks = new[]
            {
                new { Text = "Functional standards", Action = "FunctionalStandards", Controller = "EnterpriseReporting", Url = default(string?), IsButton = false, IsActive = currentAction == "FunctionalStandards" },
                new { Text = "Guidance", Action = "FunctionalStandardsGuidance", Controller = "EnterpriseReporting", Url = default(string?), IsButton = false, IsActive = currentAction == "FunctionalStandardsGuidance" }
            };
        }
        @await Html.PartialAsync("_ModuleNavbar")

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-12">
                <!-- What are Functional Standards -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title mb-0">What are Functional Standards?</h3>
                    </div>
                    <div class="card-body">
                        <p>
                            Functional standards define the expected capabilities and maturity levels for specific functional areas within the organisation. They provide a structured framework for assessing how well teams and functions are performing against defined best practices and requirements.
                        </p>
                        <p>
                            Each functional standard is organised into themes, which are further broken down into practice areas and specific criteria. These criteria help you evaluate your current state and identify areas for improvement.
                        </p>
                        <p class="mb-0">
                            Functional standards support continuous improvement by providing clear benchmarks and helping teams understand what "good" looks like in their functional area.
                        </p>
                    </div>
                </div>

                <!-- How to Use Functional Standards -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title mb-0">How to Use Functional Standards</h3>
                    </div>
                    <div class="card-body">
                        <h5 class="mb-3">1. Select a Standard</h5>
                        <p>
                            Start by selecting a functional standard that is relevant to your area of work. Each standard covers a specific functional domain and contains criteria organised by themes and practice areas.
                        </p>

                        <h5 class="mb-3 mt-4">2. Start an Assessment</h5>
                        <p>
                            Create a new assessment for the standard you want to evaluate. Give your assessment a clear name (e.g., "Q4 2025 Assessment" or "Team Capability Review") to help you track different assessment cycles.
                        </p>

                        <h5 class="mb-3 mt-4">3. Assess Capability and Maturity</h5>
                        <p>
                            For each criterion in the standard, assess your current capability and maturity level. Consider:
                        </p>
                        <ul>
                            <li><strong>Current state:</strong> Where are you now?</li>
                            <li><strong>Evidence:</strong> What evidence supports your assessment?</li>
                            <li><strong>Gaps:</strong> What needs to improve?</li>
                            <li><strong>Maturity level:</strong> How mature is this capability?</li>
                        </ul>

                        <h5 class="mb-3 mt-4">4. Track Progress</h5>
                        <p>
                            You can save your assessment as you work through it and return to complete it later. The system tracks your progress, showing how many criteria you've completed.
                        </p>

                        <h5 class="mb-3 mt-4">5. Submit Your Assessment</h5>
                        <p class="mb-0">
                            Once you've completed all criteria, submit your assessment. Submitted assessments provide a record of your capability and maturity at that point in time, which you can use to track improvement over time.
                        </p>
                    </div>
                </div>

                <!-- Assessment Tips -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Assessment Tips</h3>
                    </div>
                    <div class="card-body">
                        <ul class="mb-0">
                            <li><strong>Be honest:</strong> Accurate assessments help identify real improvement opportunities</li>
                            <li><strong>Provide evidence:</strong> Support your assessments with concrete examples and evidence</li>
                            <li><strong>Involve your team:</strong> Consider getting input from team members for a more complete picture</li>
                            <li><strong>Review regularly:</strong> Re-assess periodically to track progress and identify new areas for improvement</li>
                            <li><strong>Use for planning:</strong> Assessment results can inform your improvement plans and priorities</li>
                            <li><strong>Compare over time:</strong> Review previous assessments to see how your capability has evolved</li>
                        </ul>
                    </div>
                </div>

                <!-- Getting Started -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Getting Started</h3>
                    </div>
                    <div class="card-body">
                        <p>
                            Ready to start your first assessment? Return to the <a asp-action="FunctionalStandards">Functional standards</a> page to browse available standards and begin your assessment.
                        </p>
                        <p class="mb-0">
                            <a asp-action="FunctionalStandards" class="btn btn-primary">
                                <i class="fas fa-arrow-left mr-2" aria-hidden="true"></i>Back to Functional Standards
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
