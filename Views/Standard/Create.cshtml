@{
    ViewData["Title"] = "Publish a Standard";
}

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Published", "Standard")">Published Standards</a></li>
                    <li class="breadcrumb-item active">Publish a Standard</li>
                </ol>
                <h1 class="mb-3">Publish a Standard</h1>
            </div>
        </div>
        
        <div class="row">
            <div class="col-lg-3 col-md-4 col-12">
                @await Html.PartialAsync("_StandardsNavigation", "Create")
            </div>

            <div class="col-lg-9 col-md-8 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Create a new standard</h3>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info">
                            <h5><i class="icon fas fa-info-circle"></i> Standards are managed in the DfE standards CMS</h5>
                            <p>To create and publish a new standard, you need to access the Strapi admin interface for the DfE standards CMS.</p>
                            @if (ViewBag.AdminUrl != null)
                            {
                                <p class="mb-0">
                                    <a href="@ViewBag.AdminUrl" target="_blank" class="btn btn-primary">
                                        <i class="fas fa-external-link-alt mr-2"></i>
                                        Open standards CMS admin
                                    </a>
                                </p>
                            }
                            else if (ViewBag.BaseUrl != null)
                            {
                                <p class="mb-0">
                                    <a href="@ViewBag.BaseUrl/admin" target="_blank" class="btn btn-primary">
                                        <i class="fas fa-external-link-alt mr-2"></i>
                                        Open standards CMS admin
                                    </a>
                                </p>
                            }
                            else
                            {
                                <p class="mb-0">
                                    <small>Please contact your administrator for access to the standards CMS admin interface.</small>
                                </p>
                            }
                        </div>

                        <h5>Instructions:</h5>
                        <ol>
                            <li>Click the button above to open the standards CMS admin interface</li>
                            <li>Log in with your credentials</li>
                            <li>Navigate to Content Manager → Standard</li>
                            <li>Click "Create new entry"</li>
                            <li>Fill in all required fields for your standard</li>
                            <li>Save as draft first to review</li>
                            <li>Once ready, publish the standard</li>
                            <li>Published standards will appear in the "Published standards" view</li>
                        </ol>

                        <div class="mt-4">
                            <a asp-action="Published" class="btn btn-secondary">
                                <i class="fas fa-arrow-left mr-2"></i>
                                Back to published standards
                            </a>
                            <a asp-action="Draft" class="btn btn-secondary">
                                <i class="fas fa-file-alt mr-2"></i>
                                View draft standards
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

