@model IEnumerable<Compass.ViewModels.StandardLandingSectionViewModel>
@using System.Linq

@{
    ViewData["Title"] = "Standards";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Standards</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Standards</h1>
            </div>
        </div>
    </div>
</div>

<section class="content standards-landing">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xl-3 col-lg-4 col-md-5 mb-4">
                @await Html.PartialAsync("_StandardsNavigation", "Index")
            </div>
            <div class="col-xl-9 col-lg-8 col-md-7">
                <p class="lead text-muted mb-4">
                    Explore every way Compass helps you work with standards — from browsing the published catalogue to managing drafts, creating new entries, focusing on service standards, or running Cabinet Office functional standard assessments.
                </p>

                <div class="row">
                    @foreach (var card in Model)
                    {
                        <div class="col-xl-6 col-lg-12 mb-4 d-flex">
                            <div class="card standard-landing-card w-100 h-100" data-standard-key="@card.Key">
                                <div class="card-body d-flex flex-column">
                                    <div class="standard-landing-card__icon" aria-hidden="true">
                                        <i class="@card.IconClass"></i>
                                    </div>
                                    <div class="standard-landing-card__content">
                                        <p class="standard-landing-card__eyebrow mb-1 text-uppercase text-muted">@card.Key</p>
                                        <h3 class="h5 mb-1">@card.Title</h3>
                                        @if (!string.IsNullOrWhiteSpace(card.Subtitle))
                                        {
                                            <p class="text-muted mb-3">@card.Subtitle</p>
                                        }
                                        <p class="mb-3">@card.Description</p>

                                        @if (card.Highlights?.Any() == true)
                                        {
                                            <ul class="standard-landing-card__highlights">
                                                @foreach (var highlight in card.Highlights)
                                                {
                                                    <li>@highlight</li>
                                                }
                                            </ul>
                                        }
                                    </div>

                                    <div class="mt-auto pt-3">
                                        <a class="btn btn-primary btn-block mb-2"
                                           href="@card.ActionUrl"
                                           aria-label="@card.ActionAriaLabel">
                                            @card.ActionText
                                        </a>
                                        @if (!string.IsNullOrWhiteSpace(card.SecondaryLinkText) && !string.IsNullOrWhiteSpace(card.SecondaryLinkUrl))
                                        {
                                            <a class="standard-landing-card__secondary-link"
                                               href="@card.SecondaryLinkUrl">
                                                @card.SecondaryLinkText
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
