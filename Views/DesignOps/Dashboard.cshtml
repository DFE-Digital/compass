@{
    ViewData["Title"] = "Design Operations Dashboard";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="DesignOps" asp-action="Dashboard" style="color: #005ea5; text-decoration: none;">Design Operations</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        @{
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
            ViewBag.BrandText = "Design Operations";
            ViewBag.NavLinks = new[]
            {
                new { Text = "Dashboard", Action = "Dashboard", Controller = "DesignOps", Url = default(string?), IsButton = false, IsActive = currentAction == "Dashboard" },
                new { Text = "Accessibility oversight", Action = "AccessibilityOversight", Controller = "DesignOps", Url = default(string?), IsButton = false, IsActive = currentAction == "AccessibilityOversight" }
            };
        }
        @await Html.PartialAsync("_ModuleNavbar")

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }
    </div>
</section>


