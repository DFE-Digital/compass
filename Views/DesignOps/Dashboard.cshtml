@{
    ViewData["Title"] = "Design Operations Dashboard";
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="DesignOps" asp-action="Dashboard" style="color: #005ea5; text-decoration: none;">Design Operations</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
            </div>
        </div>
    </div>
</div>

<!-- Dashboard Header -->
<div class="dashboard-header">
    <h1>Design Operations</h1>
    <p>Accessibility training, retest requests, and product enrollment overview</p>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <!-- Summary Cards -->
        <div class="dashboard-summary-cards">
            <a href="/Admin/AccessibilityService/RetestRequests" class="dashboard-card bg-warning" style="text-decoration: none; color: inherit;">
                <div class="dashboard-card-value">@(ViewBag.PendingRetestCount ?? 0)</div>
                <div class="dashboard-card-label">Open Retest Requests</div>
                <div class="dashboard-card-icon"><i class="fas fa-clipboard-check"></i></div>
            </a>
            <a href="/Apps/Accessibility" class="dashboard-card @((ViewBag.OpenIssuesCount ?? 0) == 0 ? "bg-success" : (ViewBag.OpenIssuesCount ?? 0) < 10 ? "bg-warning" : "bg-danger")" style="text-decoration: none; color: inherit;">
                <div class="dashboard-card-value">@(ViewBag.OpenIssuesCount ?? 0)</div>
                <div class="dashboard-card-label">Open Accessibility Issues</div>
                <div class="dashboard-card-icon"><i class="fas fa-exclamation-triangle"></i></div>
            </a>
            <a href="/Admin/AccessibilityService" class="dashboard-card bg-info" style="text-decoration: none; color: inherit;">
                <div class="dashboard-card-value">@(ViewBag.EnrolledProductsCount ?? 0)<small style="font-size: 1.2rem;"> / @(ViewBag.TotalProducts ?? 0)</small></div>
                <div class="dashboard-card-label">Enrolled Products (@(ViewBag.EnrollmentPercentage ?? 0)%)</div>
                <div class="dashboard-card-icon"><i class="fas fa-check-circle"></i></div>
            </a>
            <div class="dashboard-card bg-primary">
                <div class="dashboard-card-value">@(ViewBag.TotalTrainingSessions ?? 0)</div>
                <div class="dashboard-card-label">Training Sessions</div>
                <div class="dashboard-card-icon"><i class="fas fa-graduation-cap"></i></div>
                <div style="margin-top: 0.5rem; font-size: 0.875rem; opacity: 0.9;">
                        @(ViewBag.CompletedSessions ?? 0) completed (@(ViewBag.CompletionRate ?? 0)%)
                </div>
            </div>
        </div>

        <!-- Accessibility Training Metrics -->
        <div class="dashboard-section">
            <div class="dashboard-section-header">
                <h2><i class="fas fa-graduation-cap"></i> Accessibility Training Metrics</h2>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-3 col-6">
                                <div class="info-box">
                                    <span class="info-box-icon bg-info elevation-1"><i class="fas fa-book"></i></span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Total Answers</span>
                                        <span class="info-box-number">@(ViewBag.TotalAnswers ?? 0)</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 col-6">
                                <div class="info-box">
                                    <span class="info-box-icon bg-success elevation-1"><i class="fas fa-check"></i></span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Correct Answers</span>
                                        <span class="info-box-number">@(ViewBag.CorrectAnswers ?? 0)</span>
                                        <span class="info-box-text">@(ViewBag.CorrectAnswerRate ?? 0)% correct rate</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 col-6">
                                <div class="info-box">
                                    <span class="info-box-icon bg-danger elevation-1"><i class="fas fa-times"></i></span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Incorrect Answers</span>
                                        <span class="info-box-number">@(ViewBag.IncorrectAnswers ?? 0)</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3 col-6">
                                <div class="info-box">
                                    <span class="info-box-icon bg-warning elevation-1"><i class="fas fa-envelope"></i></span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Codes Sent</span>
                                        <span class="info-box-number">@(ViewBag.CodesSent ?? 0)</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        @{
                            var mostDifficultQuestions = ViewBag.MostDifficultQuestions as System.Collections.IEnumerable ?? new List<object>();
                            var difficultQuestionsCount = 0;
                            try { difficultQuestionsCount = (mostDifficultQuestions as System.Collections.ICollection)?.Count ?? 0; } catch { }
                        }
                        
                        @if (difficultQuestionsCount > 0)
                        {
                            <div class="mt-4">
                                <h5>Most Difficult Questions (Lowest Correct Answer Rates)</h5>
                                <div class="table-responsive">
                                    <table class="table table-bordered table-striped">
                                        <thead>
                                            <tr>
                                                <th>Question #</th>
                                                <th>Type</th>
                                                <th>Total Answers</th>
                                                <th>Correct</th>
                                                <th>Incorrect</th>
                                                <th>Correct %</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (dynamic question in mostDifficultQuestions)
                                            {
                                                <tr>
                                                    <td>@(question?.QuestionNumber ?? "N/A")</td>
                                                    <td>@(question?.QuestionType ?? "N/A")</td>
                                                    <td>@(question?.TotalAnswers ?? 0)</td>
                                                    <td>@(question?.CorrectAnswers ?? 0)</td>
                                                    <td>@(question?.IncorrectAnswers ?? 0)</td>
                                                    <td>
                                                        @{
                                                            var correctPercentage = question?.CorrectPercentage ?? 0.0;
                                                            var badgeClass = correctPercentage < 50 ? "badge-danger" : correctPercentage < 70 ? "badge-warning" : "badge-success";
                                                        }
                                                        <span class="badge @badgeClass">
                                                            @correctPercentage%
                                                        </span>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Enhanced Accessibility Training Analytics -->
        <div class="dashboard-section">
            <div class="dashboard-section-header">
                <h2><i class="fas fa-chart-line"></i> Completed Training Sessions by Day (Last 30 Days)</h2>
                    </div>
                    <div class="card-body">
                        <canvas id="dailySessionsChart" height="80"></canvas>
            </div>
        </div>
        
        <!-- Monthly Sessions Chart -->
        <div class="dashboard-section">
            <div class="dashboard-section-header">
                <h2><i class="fas fa-chart-bar"></i> Completed Training Sessions by Month</h2>
                    </div>
                    <div class="card-body">
                        <canvas id="monthlySessionsChart" height="80"></canvas>
            </div>
        </div>

        <!-- Operational Reporting Summaries -->
        <div class="row">
            <div class="col-lg-6">
                <div class="dashboard-section">
                    <div class="dashboard-section-header">
                        <h2><i class="fas fa-exclamation-circle"></i> Products with Null Satisfaction Score (perf-1)</h2>
                    </div>
                    <div class="card-body">
                        @{
                            var nullPerf1Products = ViewBag.ProductsWithNullPerf1 as System.Collections.IEnumerable ?? new List<object>();
                            var nullPerf1Count = 0;
                            try { nullPerf1Count = (nullPerf1Products as System.Collections.ICollection)?.Count ?? 0; } catch { }
                        }
                        @if (nullPerf1Count > 0)
                        {
                            <p class="text-muted">@nullPerf1Count product(s) have declared a null return on their Satisfaction score metric:</p>
                            <ul class="list-group">
                                @foreach (dynamic product in nullPerf1Products)
                                {
                                    <li class="list-group-item">
                                        <strong>@(product?.FipsId ?? "Unknown")</strong> - @(product?.ProductName ?? "Unknown")
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted">No products found with null satisfaction score returns.</p>
                        }
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="dashboard-section">
                    <div class="dashboard-section-header">
                        <h2><i class="fas fa-check-circle"></i> Products with 0 Open Accessibility Issues (perf-8)</h2>
                    </div>
                    <div class="card-body">
                        @{
                            var zeroIssuesProducts = ViewBag.ProductsWithZeroIssues as System.Collections.IEnumerable ?? new List<object>();
                            var zeroIssuesCount = 0;
                            try { zeroIssuesCount = (zeroIssuesProducts as System.Collections.ICollection)?.Count ?? 0; } catch { }
                        }
                        @if (zeroIssuesCount > 0)
                        {
                            <p class="text-muted">@zeroIssuesCount product(s) have declared 0 total open accessibility issues:</p>
                            <ul class="list-group">
                                @foreach (dynamic product in zeroIssuesProducts)
                                {
                                    <li class="list-group-item">
                                        <strong>@(product?.FipsId ?? "Unknown")</strong> - @(product?.ProductName ?? "Unknown")
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted">No products found with 0 open accessibility issues declared.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js" nonce="@Context.Items["Nonce"]"></script>
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Daily Sessions Chart (Last 30 Days)
            @{
                var dailySessions = ViewBag.DailySessions as System.Collections.IEnumerable ?? new List<object>();
            }
            
            @if (dailySessions != null)
            {
                <text>
                var dailySessionsData = @Html.Raw(Json.Serialize(dailySessions));
                
                if (dailySessionsData && dailySessionsData.length > 0) {
                    var ctx = document.getElementById('dailySessionsChart');
                    if (ctx) {
                        new Chart(ctx.getContext('2d'), {
                            type: 'line',
                            data: {
                                labels: dailySessionsData.map(function(d) {
                                    if (d.dateString) {
                                        var date = new Date(d.dateString);
                                        return date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
                                    }
                                    return '';
                                }),
                                datasets: [
                                    {
                                        label: 'Completed Sessions',
                                        data: dailySessionsData.map(function(d) { return d.completedSessions || 0; }),
                                        backgroundColor: 'rgba(40, 167, 69, 0.2)',
                                        borderColor: 'rgba(40, 167, 69, 1)',
                                        borderWidth: 2,
                                        fill: true,
                                        tension: 0.4
                                    },
                                    {
                                        label: 'Total Sessions',
                                        data: dailySessionsData.map(function(d) { return d.totalSessions || 0; }),
                                        backgroundColor: 'rgba(23, 162, 184, 0.2)',
                                        borderColor: 'rgba(23, 162, 184, 1)',
                                        borderWidth: 2,
                                        fill: true,
                                        tension: 0.4
                                    }
                                ]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: true,
                                scales: {
                                    y: {
                                        beginAtZero: true,
                                        ticks: {
                                            stepSize: 1
                                        }
                                    }
                                },
                                plugins: {
                                    legend: {
                                        display: true,
                                        position: 'top'
                                    },
                                    tooltip: {
                                        mode: 'index',
                                        intersect: false
                                    }
                                }
                            }
                        });
                    }
                }
                </text>
            }
            
            // Monthly Sessions Chart
            @{
                var monthlySessions = ViewBag.MonthlySessions as System.Collections.IEnumerable ?? new List<object>();
            }
            
            @if (monthlySessions != null)
            {
                <text>
                var monthlySessionsData = @Html.Raw(Json.Serialize(monthlySessions));
                
                if (monthlySessionsData && monthlySessionsData.length > 0) {
                    var ctx = document.getElementById('monthlySessionsChart');
                    if (ctx) {
                        new Chart(ctx.getContext('2d'), {
                            type: 'bar',
                            data: {
                                labels: monthlySessionsData.map(function(d) {
                                    if (d.yearMonth) {
                                        var parts = d.yearMonth.split('-');
                                        var date = new Date(parts[0], parts[1] - 1, 1);
                                        return date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' });
                                    }
                                    return d.yearMonth || '';
                                }),
                                datasets: [
                                    {
                                        label: 'Completed Sessions',
                                        data: monthlySessionsData.map(function(d) { return d.completedSessions || 0; }),
                                        backgroundColor: 'rgba(40, 167, 69, 0.8)',
                                        borderColor: 'rgba(40, 167, 69, 1)',
                                        borderWidth: 1
                                    },
                                    {
                                        label: 'Total Sessions',
                                        data: monthlySessionsData.map(function(d) { return d.totalSessions || 0; }),
                                        backgroundColor: 'rgba(23, 162, 184, 0.6)',
                                        borderColor: 'rgba(23, 162, 184, 1)',
                                        borderWidth: 1
                                    }
                                ]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: true,
                                scales: {
                                    y: {
                                        beginAtZero: true,
                                        ticks: {
                                            stepSize: 1
                                        }
                                    }
                                },
                                plugins: {
                                    legend: {
                                        display: true,
                                        position: 'top'
                                    },
                                    tooltip: {
                                        mode: 'index',
                                        intersect: false
                                    }
                                }
                            }
                        });
                    }
                }
                </text>
            }
        });
    </script>
}

