@{
    ViewData["Title"] = "Accessibility Retest Requests - Oversight";
    
    var retestRequests = ViewBag.RetestRequests as List<Compass.Models.AccessibilityRetestRequest> ?? new List<Compass.Models.AccessibilityRetestRequest>();
    var retestRequestsCount = ViewBag.RetestRequestsCount as int? ?? 0;
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Dashboard", "DesignOps")" style="color: #005ea5; text-decoration: none;">Design Operations</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("AccessibilityOversight", "DesignOps")" style="color: #005ea5; text-decoration: none;">Accessibility Issues and Statements</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Retest Requests</li>
        </ol>
    </nav>
}

<div class="dashboard-header">
    <h1>Accessibility Retest Requests</h1>
    <p>Pending retest requests requiring action</p>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="dashboard-section mb-4">
            <div class="dashboard-section-header">
                <h2><i class="fas fa-redo"></i> Pending Retest Requests</h2>
                <p class="dashboard-section-description">Total: @retestRequestsCount requests</p>
            </div>
            @if (retestRequests.Any())
            {
                <div class="card">
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Issue</th>
                                    <th>Requested By</th>
                                    <th>Requested Date</th>
                                    <th>Request Notes</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var request in retestRequests)
                                {
                                    <tr>
                                        <td>
                                            <strong>@request.AccessibilityIssue.ProductAccessibility.ProductName</strong><br>
                                            <small class="text-muted">@request.AccessibilityIssue.ProductAccessibility.FipsId</small>
                                        </td>
                                        <td>
                                            @if (request.AccessibilityIssue.WcagCriteriaLinks.Any())
                                            {
                                                var firstLink = request.AccessibilityIssue.WcagCriteriaLinks.First();
                                                <strong>@firstLink.WcagCriterion.Criterion</strong>
                                                @if (request.AccessibilityIssue.WcagCriteriaLinks.Count > 1)
                                                {
                                                    <text> +@(request.AccessibilityIssue.WcagCriteriaLinks.Count - 1) more</text>
                                                }
                                            }
                                            else if (!string.IsNullOrEmpty(request.AccessibilityIssue.IssueTitle))
                                            {
                                                <text>@request.AccessibilityIssue.IssueTitle</text>
                                            }
                                            else if (!string.IsNullOrEmpty(request.AccessibilityIssue.WcagCriteria))
                                            {
                                                <text>WCAG @request.AccessibilityIssue.WcagCriteria</text>
                                            }
                                            else
                                            {
                                                <text>Issue #@request.AccessibilityIssue.Id</text>
                                            }
                                        </td>
                                        <td>
                                            @request.RequestedBy
                                            @if (!string.IsNullOrEmpty(request.RequestorEmail))
                                            {
                                                <br><small class="text-muted">@request.RequestorEmail</small>
                                            }
                                        </td>
                                        <td>@request.RequestedAt.ToString("dd MMM yyyy HH:mm")</td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(request.RequestNotes))
                                            {
                                                <text>@(request.RequestNotes.Length > 100 ? request.RequestNotes.Substring(0, 100) + "..." : request.RequestNotes)</text>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Details", "Accessibility", new { fipsId = request.AccessibilityIssue.ProductAccessibility.FipsId, tab = "issues" })" class="btn btn-sm btn-primary">
                                                <i class="fas fa-eye"></i> View Issue
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-body">
                        <p class="text-muted mb-0">No pending retest requests.</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

