@{
    ViewData["Title"] = "Accessibility Issues and Statements - Oversight";
    
    var totalProducts = ViewBag.TotalProducts as int? ?? 0;
    var enrolledCount = ViewBag.EnrolledCount as int? ?? 0;
    var notEnrolledCount = ViewBag.NotEnrolledCount as int? ?? 0;
    var enrollmentProgress = ViewBag.EnrollmentProgress as double? ?? 0;
    var enrollmentTarget = ViewBag.EnrollmentTarget as double? ?? 100;
    var targetDate = ViewBag.TargetDate as DateTime? ?? new DateTime(2026, 3, 31);
    var daysRemaining = ViewBag.DaysRemaining as int? ?? 0;
    var productsNeeded = ViewBag.ProductsNeeded as int? ?? 0;
    
    var validatedStatements = ViewBag.ValidatedStatements as int? ?? 0;
    var notValidatedStatements = ViewBag.NotValidatedStatements as int? ?? 0;
    
    var issuesByWcagCriteria = ViewBag.IssuesByWcagCriteria as List<dynamic> ?? new List<dynamic>();
    var totalOpenIssues = ViewBag.TotalOpenIssues as int? ?? 0;
    
    var retestRequests = ViewBag.RetestRequests as List<Compass.Models.AccessibilityRetestRequest> ?? new List<Compass.Models.AccessibilityRetestRequest>();
    var retestRequestsCount = ViewBag.RetestRequestsCount as int? ?? 0;
    
    var issuesWithUpcomingDueDates = ViewBag.IssuesWithUpcomingDueDates as List<Compass.Models.AccessibilityIssue> ?? new List<Compass.Models.AccessibilityIssue>();
    var issuesWithUpcomingDueDatesCount = ViewBag.IssuesWithUpcomingDueDatesCount as int? ?? 0;
    
    var issuesNotBeingResolved = ViewBag.IssuesNotBeingResolved as List<Compass.Models.AccessibilityIssue> ?? new List<Compass.Models.AccessibilityIssue>();
    var issuesNotBeingResolvedCount = ViewBag.IssuesNotBeingResolvedCount as int? ?? 0;
    
    var businessAreaRisk = ViewBag.BusinessAreaRisk as List<dynamic> ?? new List<dynamic>();
    
    var productsWithValidatedStatements = ViewBag.ProductsWithValidatedStatements as List<dynamic> ?? new List<dynamic>();
    var productsWithoutValidatedStatements = ViewBag.ProductsWithoutValidatedStatements as List<dynamic> ?? new List<dynamic>();
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Dashboard", "DesignOps")" style="color: #005ea5; text-decoration: none;">Design Operations</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Accessibility Issues and Statements</li>
        </ol>
    </nav>
}

<div class="dashboard-header">
    <h1>Accessibility Issues and Statements - Oversight</h1>
    <p>Central operations oversight of accessibility compliance across all products and services</p>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <!-- Enrollment Progress Section -->
        <div class="dashboard-section mb-4">
            <div class="dashboard-section-header">
                <h2><i class="fas fa-chart-line"></i> Enrollment Progress</h2>
                <p class="dashboard-section-description">Target: 100% of Products enrolled by @targetDate.ToString("dd MMMM yyyy")</p>
            </div>
            <div class="card">
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h4>Current Status</h4>
                            <div class="progress mb-2" style="height: 30px;">
                                <div class="progress-bar @(enrollmentProgress >= 100 ? "bg-success" : enrollmentProgress >= 75 ? "bg-info" : enrollmentProgress >= 50 ? "bg-warning" : "bg-danger")" 
                                     role="progressbar" 
                                     style="width: @(Math.Min(enrollmentProgress, 100))%" 
                                     aria-valuenow="@enrollmentProgress" 
                                     aria-valuemin="0" 
                                     aria-valuemax="100">
                                    <strong>@enrollmentProgress.ToString("F1")%</strong>
                                </div>
                            </div>
                            <p class="mb-1"><strong>@enrolledCount</strong> of <strong>@totalProducts</strong> products enrolled</p>
                            <p class="mb-0 text-muted">@productsNeeded products still need to be enrolled</p>
                        </div>
                        <div class="col-md-6">
                            <h4>Target Progress</h4>
                            <p><strong>Target Date:</strong> @targetDate.ToString("dd MMMM yyyy")</p>
                            <p><strong>Days Remaining:</strong> <span class="badge @(daysRemaining > 180 ? "badge-success" : daysRemaining > 90 ? "badge-warning" : "badge-danger")">@daysRemaining days</span></p>
                            @if (daysRemaining > 0 && productsNeeded > 0)
                            {
                                var productsPerDay = (double)productsNeeded / daysRemaining;
                                <p><strong>Required Rate:</strong> @productsPerDay.ToString("F2") products per day</p>
                            }
                        </div>
                    </div>
                    <div class="dashboard-summary-cards">
                        <div class="dashboard-card bg-primary">
                            <div class="dashboard-card-value">@totalProducts</div>
                            <div class="dashboard-card-label">Total Products</div>
                            <div class="dashboard-card-icon"><i class="fas fa-box"></i></div>
                        </div>
                        <div class="dashboard-card bg-success">
                            <div class="dashboard-card-value">@enrolledCount</div>
                            <div class="dashboard-card-label">Enrolled</div>
                            <div class="dashboard-card-icon"><i class="fas fa-check-circle"></i></div>
                        </div>
                        <div class="dashboard-card bg-warning">
                            <div class="dashboard-card-value">@notEnrolledCount</div>
                            <div class="dashboard-card-label">Not Enrolled</div>
                            <div class="dashboard-card-icon"><i class="fas fa-exclamation-triangle"></i></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Issues and Statements -->
        <div class="dashboard-section mb-4">
            <div class="dashboard-section-header">
                <h2><i class="fas fa-file-check"></i> Issues and Statements</h2>
                <p class="dashboard-section-description">Status of accessibility issues and statement installation and verification</p>
            </div>
            <div class="dashboard-summary-cards mb-3">
                <a href="@Url.Action("ValidatedStatements", "DesignOps")" class="dashboard-card bg-success" style="text-decoration: none; color: inherit; display: block;">
                    <div class="dashboard-card-value">@validatedStatements</div>
                    <div class="dashboard-card-label">Validated Statements</div>
                    <div class="dashboard-card-icon"><i class="fas fa-check-circle"></i></div>
                </a>
                <a href="@Url.Action("RetestRequests", "DesignOps")" class="dashboard-card bg-info" style="text-decoration: none; color: inherit; display: block;">
                    <div class="dashboard-card-value">@retestRequestsCount</div>
                    <div class="dashboard-card-label">Issue Retest Requests</div>
                    <div class="dashboard-card-icon"><i class="fas fa-redo"></i></div>
                </a>
                <a href="@Url.Action("OpenIssues", "DesignOps")" class="dashboard-card bg-warning" style="text-decoration: none; color: inherit; display: block;">
                    <div class="dashboard-card-value">@totalOpenIssues</div>
                    <div class="dashboard-card-label">Open Issues</div>
                    <div class="dashboard-card-icon"><i class="fas fa-exclamation-circle"></i></div>
                </a>
            </div>
            @if (productsWithoutValidatedStatements.Any())
            {
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Products Without Validated Statements</h5>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Product Name</th>
                                    <th>FIPS ID</th>
                                    <th>Statement Installed</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in productsWithoutValidatedStatements.Take(20))
                                {
                                    <tr>
                                        <td><strong>@product.ProductName</strong></td>
                                        <td><code>@product.FipsId</code></td>
                                        <td>
                                            @if (product.StatementInstalled)
                                            {
                                                <span class="badge badge-info">Installed</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-danger">Not installed</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Details", "Accessibility", new { fipsId = product.FipsId, tab = "statement" })" class="btn btn-sm btn-primary">
                                                <i class="fas fa-eye"></i> View
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>

        <!-- Issues by WCAG Criteria -->
        @if (issuesByWcagCriteria.Any())
        {
            <div class="dashboard-section mb-4">
                <div class="dashboard-section-header">
                    <h2><i class="fas fa-list-alt"></i> Issues by WCAG Criteria</h2>
                    <p class="dashboard-section-description">Breakdown of open issues by WCAG criterion</p>
                </div>
                <div class="card">
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>WCAG Criterion</th>
                                    <th>Level</th>
                                    <th>Version</th>
                                    <th>Issue Count</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var criterion in issuesByWcagCriteria)
                                {
                                    <tr>
                                        <td><strong>@criterion.Criterion</strong></td>
                                        <td><span class="badge badge-info">@criterion.Level</span></td>
                                        <td>@criterion.Version</td>
                                        <td><span class="badge badge-warning">@criterion.Count</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Retest Requests -->
        @if (retestRequests.Any())
        {
            <div class="dashboard-section mb-4">
                <div class="dashboard-section-header">
                    <h2><i class="fas fa-redo"></i> Retest Requests</h2>
                    <p class="dashboard-section-description">Pending retest requests requiring action</p>
                </div>
                <div class="card">
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Requested By</th>
                                    <th>Requested Date</th>
                                    <th>Issue</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var request in retestRequests.Take(20))
                                {
                                    <tr>
                                        <td><strong>@request.AccessibilityIssue.ProductAccessibility.ProductName</strong></td>
                                        <td>@request.RequestedBy</td>
                                        <td>@request.RequestedAt.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(request.AccessibilityIssue.IssueTitle))
                                            {
                                                <text>@request.AccessibilityIssue.IssueTitle</text>
                                            }
                                            else if (!string.IsNullOrEmpty(request.AccessibilityIssue.WcagCriteria))
                                            {
                                                <text>WCAG @request.AccessibilityIssue.WcagCriteria</text>
                                            }
                                            else
                                            {
                                                <text>Issue #@request.AccessibilityIssue.Id</text>
                                            }
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Details", "Accessibility", new { fipsId = request.AccessibilityIssue.ProductAccessibility.FipsId, tab = "issues" })" class="btn btn-sm btn-primary">
                                                <i class="fas fa-eye"></i> View
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Issues with Upcoming Due Dates -->
        @if (issuesWithUpcomingDueDates.Any())
        {
            <div class="dashboard-section mb-4">
                <div class="dashboard-section-header">
                    <h2><i class="fas fa-calendar-alt"></i> Issues with Upcoming Due Dates</h2>
                    <p class="dashboard-section-description">Issues with planned resolution dates in the next 30 days</p>
                </div>
                <div class="card">
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Issue</th>
                                    <th>Due Date</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var issue in issuesWithUpcomingDueDates.Take(20))
                                {
                                    <tr>
                                        <td><strong>@issue.ProductAccessibility.ProductName</strong></td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(issue.IssueTitle))
                                            {
                                                <text>@issue.IssueTitle</text>
                                            }
                                            else if (!string.IsNullOrEmpty(issue.WcagCriteria))
                                            {
                                                <text>WCAG @issue.WcagCriteria</text>
                                            }
                                            else
                                            {
                                                <text>Issue #@issue.Id</text>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge @((issue.PlannedResolutionDate!.Value - DateTime.UtcNow).Days <= 7 ? "badge-danger" : "badge-warning")">
                                                @issue.PlannedResolutionDate.Value.ToString("dd MMM yyyy")
                                            </span>
                                        </td>
                                        <td><span class="badge badge-info">@issue.Status</span></td>
                                        <td>
                                            <a href="@Url.Action("Details", "Accessibility", new { fipsId = issue.ProductAccessibility.FipsId, tab = "issues" })" class="btn btn-sm btn-primary">
                                                <i class="fas fa-eye"></i> View
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Issues Not Being Resolved -->
        @if (issuesNotBeingResolved.Any())
        {
            <div class="dashboard-section mb-4">
                <div class="dashboard-section-header">
                    <h2><i class="fas fa-exclamation-circle"></i> Issues Not Being Resolved</h2>
                    <p class="dashboard-section-description">Open issues without planned resolution dates or past their due dates</p>
                </div>
                <div class="card">
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Issue</th>
                                    <th>Status</th>
                                    <th>Planned Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var issue in issuesNotBeingResolved.Take(20))
                                {
                                    <tr>
                                        <td><strong>@issue.ProductAccessibility.ProductName</strong></td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(issue.IssueTitle))
                                            {
                                                <text>@issue.IssueTitle</text>
                                            }
                                            else if (!string.IsNullOrEmpty(issue.WcagCriteria))
                                            {
                                                <text>WCAG @issue.WcagCriteria</text>
                                            }
                                            else
                                            {
                                                <text>Issue #@issue.Id</text>
                                            }
                                        </td>
                                        <td><span class="badge badge-warning">@issue.Status</span></td>
                                        <td>
                                            @if (issue.PlannedResolutionDate.HasValue)
                                            {
                                                <span class="badge badge-danger">Overdue: @issue.PlannedResolutionDate.Value.ToString("dd MMM yyyy")</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-secondary">No date set</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Details", "Accessibility", new { fipsId = issue.ProductAccessibility.FipsId, tab = "issues" })" class="btn btn-sm btn-primary">
                                                <i class="fas fa-eye"></i> View
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Business Area Risk Analysis -->
        @if (businessAreaRisk.Any())
        {
            <div class="dashboard-section mb-4">
                <div class="dashboard-section-header">
                    <h2><i class="fas fa-chart-pie"></i> Business Area Risk Analysis</h2>
                    <p class="dashboard-section-description">Risk assessment by business area based on enrollment, issues, and overdue items</p>
                </div>
                <div class="card">
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Business Area</th>
                                    <th>Total Products</th>
                                    <th>Enrolled</th>
                                    <th>Not Enrolled</th>
                                    <th>Enrollment Rate</th>
                                    <th>Total Issues</th>
                                    <th>Overdue Issues</th>
                                    <th>Risk Level</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var area in businessAreaRisk)
                                {
                                    var riskBadgeClass = area.RiskLevel == "high" ? "badge-danger" : 
                                                        area.RiskLevel == "medium" ? "badge-warning" : "badge-success";
                                    <tr class="@(area.RiskLevel == "high" ? "table-danger" : area.RiskLevel == "medium" ? "table-warning" : "")">
                                        <td><strong>@area.BusinessArea</strong></td>
                                        <td>@area.TotalProducts</td>
                                        <td>@area.EnrolledProducts</td>
                                        <td>
                                            @if (area.NotEnrolledProducts > 0)
                                            {
                                                <span class="badge badge-warning">@area.NotEnrolledProducts</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">0</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="progress" style="height: 20px;">
                                                <div class="progress-bar @(area.EnrollmentRate >= 75 ? "bg-success" : area.EnrollmentRate >= 50 ? "bg-warning" : "bg-danger")" 
                                                     style="width: @area.EnrollmentRate%">
                                                    @area.EnrollmentRate.ToString("F1")%
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            @if (area.TotalIssues > 0)
                                            {
                                                <span class="badge badge-warning">@area.TotalIssues</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">0</span>
                                            }
                                        </td>
                                        <td>
                                            @if (area.OverdueIssues > 0)
                                            {
                                                <span class="badge badge-danger">@area.OverdueIssues</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">0</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge @riskBadgeClass">@area.RiskLevel.ToUpper()</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

