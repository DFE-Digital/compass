@model List<Compass.Models.ProductDto>
@{
    ViewData["Title"] = "FIPS role management";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var currentSearch = ViewBag.CurrentSearch as string ?? "";
    var currentState = ViewBag.CurrentState as string ?? "";
    var availableStates = ViewBag.AvailableStates as List<string> ?? new List<string>();
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="DesignOps" asp-action="Dashboard" style="color: #005ea5; text-decoration: none;">Design Operations</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">FIPS role management</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        @{
            ViewBag.BrandText = "Design Operations";
            ViewBag.NavLinks = new[]
            {
                new { Text = "Dashboard", Action = "Dashboard", Controller = "DesignOps", Url = (string)null, IsButton = false, IsActive = currentAction == "Dashboard" },
                new { Text = "Accessibility oversight", Action = "AccessibilityOversight", Controller = "DesignOps", Url = (string)null, IsButton = false, IsActive = currentAction == "AccessibilityOversight" },
                new { Text = "FIPS role management", Action = "FipsRoleManagement", Controller = "DesignOps", Url = (string)null, IsButton = false, IsActive = currentAction == "FipsRoleManagement" }
            };
        }
        @await Html.PartialAsync("_ModuleNavbar")

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="card mb-3">
            <div class="card-header">
                <h3 class="card-title">Filter FIPS entries</h3>
            </div>
            <div class="card-body">
                <form method="get" asp-action="FipsRoleManagement">
                    <div class="form-row">
                        <div class="form-group col-md-8">
                            <label for="search">Search</label>
                            <input id="search" name="search" value="@currentSearch" class="form-control" placeholder="Search by FIPS ID or title" />
                        </div>
                        <div class="form-group col-md-4">
                            <label for="state">State</label>
                            <select id="state" name="state" class="form-control">
                                <option value="">All states</option>
                                @foreach (var state in availableStates)
                                {
                                    <option value="@state" selected="@(string.Equals(currentState, state, StringComparison.OrdinalIgnoreCase))">@state</option>
                                }
                            </select>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary btn-sm">Apply filters</button>
                    <a asp-action="FipsRoleManagement" class="btn btn-secondary btn-sm">Clear</a>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">FIPS entries (@Model.Count)</h3>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover table-sm mb-0">
                    <thead>
                        <tr>
                            <th style="min-width: 260px;">FIPS entry</th>
                            <th>Service owner</th>
                            <th>Product manager</th>
                            <th>Delivery manager</th>
                            <th>Information asset owner</th>
                            <th>Reporting user</th>
                            <th>Senior responsible officer</th>
                            <th>Service designs</th>
                            <th>User researchers</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model)
                        {
                            var fipsId = product.FipsId ?? "";

                            string FormatUsers(List<Compass.Models.EntraUserDto>? users)
                            {
                                if (users == null || !users.Any())
                                {
                                    return "Not set";
                                }

                                var labels = users
                                    .Select(u => !string.IsNullOrWhiteSpace(u.DisplayName) ? u.DisplayName : u.EmailAddress)
                                    .Where(u => !string.IsNullOrWhiteSpace(u))
                                    .Select(u => u!)
                                    .ToList();

                                return labels.Any() ? string.Join(", ", labels) : "Not set";
                            }

                            <tr>
                                <td>
                                    <div class="font-weight-bold">@product.Title</div>
                                    <div class="text-muted small">@fipsId</div>
                                </td>
                                <td>
                                    <div class="small mb-1">@FormatUsers(product.ServiceOwners)</div>
                                    <button type="button" class="btn btn-outline-primary btn-xs js-open-set-role-modal" data-toggle="modal" data-target="#setRoleModal" data-fips-id="@fipsId" data-role-field="service_owner" data-role-display="Service owner">Set</button>
                                </td>
                                <td>
                                    <div class="small mb-1">@FormatUsers(product.ProductManagers)</div>
                                    <button type="button" class="btn btn-outline-primary btn-xs js-open-set-role-modal" data-toggle="modal" data-target="#setRoleModal" data-fips-id="@fipsId" data-role-field="product_manager" data-role-display="Product manager">Set</button>
                                </td>
                                <td>
                                    <div class="small mb-1">@FormatUsers(product.DeliveryManagers)</div>
                                    <button type="button" class="btn btn-outline-primary btn-xs js-open-set-role-modal" data-toggle="modal" data-target="#setRoleModal" data-fips-id="@fipsId" data-role-field="delivery_manager" data-role-display="Delivery manager">Set</button>
                                </td>
                                <td>
                                    <div class="small mb-1">@FormatUsers(product.InformationAssetOwners)</div>
                                    <button type="button" class="btn btn-outline-primary btn-xs js-open-set-role-modal" data-toggle="modal" data-target="#setRoleModal" data-fips-id="@fipsId" data-role-field="Information_asset_owner" data-role-display="Information asset owner">Set</button>
                                </td>
                                <td>
                                    <div class="small mb-1">@FormatUsers(product.ReportingUsers)</div>
                                    <button type="button" class="btn btn-outline-primary btn-xs js-open-set-role-modal" data-toggle="modal" data-target="#setRoleModal" data-fips-id="@fipsId" data-role-field="reporting_user" data-role-display="Reporting user">Set</button>
                                </td>
                                <td>
                                    <div class="small mb-1">@FormatUsers(product.SeniorResponsibleOfficers)</div>
                                    <button type="button" class="btn btn-outline-primary btn-xs js-open-set-role-modal" data-toggle="modal" data-target="#setRoleModal" data-fips-id="@fipsId" data-role-field="senior_responsible_officer" data-role-display="Senior responsible officer">Set</button>
                                </td>
                                <td>
                                    <div class="small mb-1">@FormatUsers(product.ServiceDesigns)</div>
                                    <button type="button" class="btn btn-outline-primary btn-xs js-open-set-role-modal" data-toggle="modal" data-target="#setRoleModal" data-fips-id="@fipsId" data-role-field="service_designs" data-role-display="Service designs">Set</button>
                                </td>
                                <td>
                                    <div class="small mb-1">@FormatUsers(product.UserResearchers)</div>
                                    <button type="button" class="btn btn-outline-primary btn-xs js-open-set-role-modal" data-toggle="modal" data-target="#setRoleModal" data-fips-id="@fipsId" data-role-field="user_researchers" data-role-display="User researchers">Set</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="setRoleModal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Set role</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateFipsRole" method="post" id="setRoleForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="fipsId" id="modalFipsId" />
                <input type="hidden" name="roleFieldName" id="modalRoleFieldName" />
                <input type="hidden" name="roleDisplayName" id="modalRoleDisplayName" />
                <input type="hidden" name="returnUrl" value="@returnUrl" />
                <div class="modal-body">
                    <p class="mb-2"><strong>FIPS entry:</strong> <span id="modalFipsIdDisplay"></span></p>
                    <p class="mb-3"><strong>Role:</strong> <span id="modalRoleDisplayNameText"></span></p>

                    <div class="form-group">
                        <label class="control-label" for="roleUserSearch">Search for a colleague</label>
                        <small class="form-text text-muted">Search Entra ID and pick a user. The user is created in CMS automatically if needed.</small>
                        <div class="user-picker" data-user-picker data-search-url="/api/users/search" data-select-url="/api/users/select">
                            <div class="position-relative">
                                <input type="text"
                                       class="form-control js-user-picker-input"
                                       id="roleUserSearch"
                                       autocomplete="off"
                                       placeholder="e.g. Alex Smith or alex.smith@education.gov.uk" />
                                <span class="user-picker__spinner js-user-picker-spinner" aria-hidden="true">Searching…</span>
                                <div class="user-picker__results js-user-picker-results" role="listbox" aria-live="polite"></div>
                            </div>
                            <p class="form-text text-muted js-user-picker-message"></p>
                            <input type="hidden" name="entraUserObjectId" class="js-user-picker-objectid" id="roleUserObjectId" />
                            <input type="hidden" name="entraUserEmail" class="js-user-picker-email" id="roleUserEmail" />
                            <input type="hidden" name="entraUserName" class="js-user-picker-name" id="roleUserName" />
                            <div class="user-picker__selected js-user-picker-summary" data-default-text="No user selected.">
                                <span class="text-muted">No user selected.</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save role</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/js/user-picker.js" asp-append-version="true"></script>
<script nonce="@Context.Items["Nonce"]">
    (function () {
        var modal = document.getElementById('setRoleModal');
        var form = document.getElementById('setRoleForm');

        if (!modal || !form) {
            return;
        }

        document.querySelectorAll('.js-open-set-role-modal').forEach(function (button) {
            button.addEventListener('click', function () {
                var fipsId = button.getAttribute('data-fips-id') || '';
                var roleFieldName = button.getAttribute('data-role-field') || '';
                var roleDisplayName = button.getAttribute('data-role-display') || '';

                document.getElementById('modalFipsId').value = fipsId;
                document.getElementById('modalRoleFieldName').value = roleFieldName;
                document.getElementById('modalRoleDisplayName').value = roleDisplayName;
                document.getElementById('modalFipsIdDisplay').textContent = fipsId;
                document.getElementById('modalRoleDisplayNameText').textContent = roleDisplayName;

                document.getElementById('roleUserSearch').value = '';
                document.getElementById('roleUserObjectId').value = '';
                document.getElementById('roleUserEmail').value = '';
                document.getElementById('roleUserName').value = '';

                if (window.initializeUserPickers) {
                    window.initializeUserPickers();
                }
            });
        });
    })();
</script>
