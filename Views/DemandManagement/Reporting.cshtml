@model IEnumerable<Compass.Models.DemandRequest>
@using Microsoft.AspNetCore.Routing
@using System.Linq
@using System.Text.Json

@functions {
    private static int ParseTierNumber(string? tier) => string.IsNullOrWhiteSpace(tier)
        ? 5
        : tier.StartsWith("Tier 1", StringComparison.OrdinalIgnoreCase) ? 1
        : tier.StartsWith("Tier 2", StringComparison.OrdinalIgnoreCase) ? 2
        : tier.StartsWith("Tier 3", StringComparison.OrdinalIgnoreCase) ? 3
        : tier.StartsWith("Tier 4", StringComparison.OrdinalIgnoreCase) ? 4
        : 5;

    private static string FormatTierShort(string? tier) => string.IsNullOrWhiteSpace(tier)
        ? "Unprioritised"
        : tier.Split('–')[0].Trim();
}

@{
    ViewData["Title"] = "Demand reporting";

    var jsonOptions = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var requests = Model?.ToList() ?? new List<Compass.Models.DemandRequest>();
    var prioritisedRequests = requests.Where(r => r.Prioritisation != null).ToList();

    string ScoreBucket(double score) => score >= 8 ? "High" : score >= 5 ? "Medium" : "Low";

    string? NormaliseTriLevel(string? level)
    {
        if (string.IsNullOrWhiteSpace(level))
        {
            return null;
        }

        var trimmed = level.Trim();

        if (trimmed.Equals("High", StringComparison.OrdinalIgnoreCase) || trimmed.Equals("H", StringComparison.OrdinalIgnoreCase) || trimmed == "3")
        {
            return "High";
        }

        if (trimmed.Equals("Medium", StringComparison.OrdinalIgnoreCase) || trimmed.Equals("Med", StringComparison.OrdinalIgnoreCase) || trimmed.Equals("M", StringComparison.OrdinalIgnoreCase) || trimmed == "2")
        {
            return "Medium";
        }

        if (trimmed.Equals("Low", StringComparison.OrdinalIgnoreCase) || trimmed.Equals("L", StringComparison.OrdinalIgnoreCase) || trimmed == "1")
        {
            return "Low";
        }

        return null;
    }

    string ResolveRiskBucket(Compass.Models.DemandRequest request)
    {
        return NormaliseTriLevel(request.RiskLevelOverride)
            ?? NormaliseTriLevel(request.PredictedRiskLevel)
            ?? ScoreBucket(request.Prioritisation?.RiskUrgencyTotal ?? 0);
    }

    string ResolveImpactBucket(Compass.Models.DemandRequest request)
    {
        return NormaliseTriLevel(request.ImpactLevel)
            ?? ScoreBucket(request.Prioritisation?.UserImpactTotal ?? 0);
    }

    string? ResolveEffectiveRiskLevel(Compass.Models.DemandRequest request) =>
        NormaliseTriLevel(request.RiskLevelOverride) ?? NormaliseTriLevel(request.PredictedRiskLevel);

    string? ResolveImpactLevel(Compass.Models.DemandRequest request) => NormaliseTriLevel(request.ImpactLevel);

    var bucketOrder = new[] { "High", "Medium", "Low" };
    var heatmapCells = new Dictionary<string, List<Compass.Models.DemandRequest>>();

    foreach (var request in prioritisedRequests)
    {
        var impactBucket = ResolveImpactBucket(request);
        var riskBucket = ResolveRiskBucket(request);
        var key = $"{riskBucket}|{impactBucket}";
        if (!heatmapCells.TryGetValue(key, out var list))
        {
            list = new List<Compass.Models.DemandRequest>();
            heatmapCells[key] = list;
        }
        list.Add(request);
    }

    var heatmapPayload = heatmapCells.ToDictionary(
        kvp => kvp.Key,
        kvp => kvp.Value
            .OrderBy(r => ParseTierNumber(r.Prioritisation?.PriorityTier))
            .ThenByDescending(r => r.Prioritisation?.TotalPriorityScore ?? 0)
            .Select(r => new
            {
                id = r.Id,
                reference = r.ReferenceNumber,
                title = r.ProposedTitle,
                priorityTier = string.IsNullOrWhiteSpace(r.Prioritisation?.PriorityTier) ? "Unprioritised" : r.Prioritisation!.PriorityTier,
                totalScore = r.Prioritisation?.TotalPriorityScore ?? 0,
                impactScore = r.Prioritisation?.UserImpactTotal ?? 0,
                riskScore = r.Prioritisation?.RiskUrgencyTotal ?? 0,
                riskBucket = ResolveRiskBucket(r),
                effectiveRiskLevel = ResolveEffectiveRiskLevel(r),
                predictedRiskLevel = NormaliseTriLevel(r.PredictedRiskLevel),
                riskLevelOverride = NormaliseTriLevel(r.RiskLevelOverride),
                impactBucket = ResolveImpactBucket(r),
                impactLevel = ResolveImpactLevel(r),
                impactSummary = string.IsNullOrWhiteSpace(r.ImpactSummary) ? null : r.ImpactSummary,
                businessArea = string.IsNullOrWhiteSpace(r.BusinessArea) ? "Not specified" : r.BusinessArea,
                portfolio = string.IsNullOrWhiteSpace(r.PortfolioName) ? "Not assigned" : r.PortfolioName
            })
            .ToList()
    );
    var heatmapJson = JsonSerializer.Serialize(heatmapPayload, jsonOptions);

    var tierDefinitions = new[]
    {
        new { Key = "Tier 1 – Critical", Label = "Tier 1 – Critical", Short = "Tier 1", Color = "#D92D20" },
        new { Key = "Tier 2 – High",      Label = "Tier 2 – High",      Short = "Tier 2", Color = "#F79009" },
        new { Key = "Tier 3 – Medium",    Label = "Tier 3 – Medium",    Short = "Tier 3", Color = "#2E90FA" },
        new { Key = "Tier 4 – Low",       Label = "Tier 4 – Low",       Short = "Tier 4", Color = "#667085" }
    };

    int GetBagValue(object value, int fallback)
    {
        return value switch
        {
            int i => i,
            long l => (int)l,
            _ => fallback
        };
    }

    double GetBagDouble(object value, double fallback)
    {
        return value switch
        {
            double d => d,
            float f => f,
            int i => i,
            long l => l,
            decimal m => (double)m,
            _ => fallback
        };
    }

    var totalRequests = GetBagValue(ViewBag.TotalRequests, requests.Count);
    var submittedRequests = GetBagValue(ViewBag.SubmittedRequests, requests.Count(r => string.Equals(r.Status, "Submitted", StringComparison.OrdinalIgnoreCase)));
    var underReviewRequests = GetBagValue(ViewBag.UnderReviewRequests, requests.Count(r => string.Equals(r.Status, "Under Review", StringComparison.OrdinalIgnoreCase)));
    var approvedRequests = GetBagValue(ViewBag.ApprovedRequests, requests.Count(r => string.Equals(r.Status, "Approved", StringComparison.OrdinalIgnoreCase)));
    var draftRequests = GetBagValue(ViewBag.DraftRequests, requests.Count(r => string.Equals(r.Status, "Draft", StringComparison.OrdinalIgnoreCase)));
    var deferredRequests = GetBagValue(ViewBag.DeferredRequests, requests.Count(r => string.Equals(r.Status, "Deferred", StringComparison.OrdinalIgnoreCase)));
    var rejectedRequests = GetBagValue(ViewBag.RejectedRequests, requests.Count(r => string.Equals(r.Status, "Rejected", StringComparison.OrdinalIgnoreCase)));
    var averageResponseDays = GetBagDouble(ViewBag.AverageResponseTimeDays, 0);

    var summaryStats = new[]
    {
        new { Label = "Total requests", Value = totalRequests, Subtext = "All demand submissions" },
        new { Label = "Submitted", Value = submittedRequests, Subtext = "Awaiting review or triage" },
        new { Label = "Under review", Value = underReviewRequests, Subtext = "In active assessment" },
        new { Label = "Approved", Value = approvedRequests, Subtext = "Cleared for prioritisation" }
    };

    var statusCounts = new[]
    {
        new { Label = "Draft", Value = draftRequests, Color = "#667085" },
        new { Label = "Submitted", Value = submittedRequests, Color = "#2E90FA" },
        new { Label = "Under review", Value = underReviewRequests, Color = "#F79009" },
        new { Label = "Approved", Value = approvedRequests, Color = "#12B76A" },
        new { Label = "Deferred", Value = deferredRequests, Color = "#98A2B3" },
        new { Label = "Rejected", Value = rejectedRequests, Color = "#D92D20" }
    };

    var tierChart = new
    {
        Labels = tierDefinitions.Select(t => t.Label).Append("Unprioritised"),
        Data = tierDefinitions.Select(t => prioritisedRequests.Count(r => string.Equals(r.Prioritisation?.PriorityTier, t.Key, StringComparison.OrdinalIgnoreCase)))
                              .Append(totalRequests - prioritisedRequests.Count),
        Colors = tierDefinitions.Select(t => t.Color).Append("#E4E7EC")
    };
    var tierChartJson = JsonSerializer.Serialize(tierChart, jsonOptions);

    var statusChart = new
    {
        Labels = statusCounts.Select(s => s.Label),
        Data = statusCounts.Select(s => s.Value),
        Colors = statusCounts.Select(s => s.Color)
    };
    var statusChartJson = JsonSerializer.Serialize(statusChart, jsonOptions);

    var portfolioGroups = prioritisedRequests
        .GroupBy(r => string.IsNullOrWhiteSpace(r.PortfolioName) ? "Not assigned" : r.PortfolioName)
        .OrderBy(g => g.Key)
        .ToList();

    var portfolioChart = new
    {
        Labels = portfolioGroups.Select(g => g.Key),
        Datasets = tierDefinitions.Select(t => new
        {
            label = t.Short,
            backgroundColor = t.Color,
            data = portfolioGroups.Select(g => g.Count(r => string.Equals(r.Prioritisation?.PriorityTier, t.Key, StringComparison.OrdinalIgnoreCase)))
        })
    };
    var portfolioChartJson = JsonSerializer.Serialize(portfolioChart, jsonOptions);

    var tierClassLookup = new Dictionary<int, string>
    {
        { 1, "heatmap-tier-1" },
        { 2, "heatmap-tier-2" },
        { 3, "heatmap-tier-3" },
        { 4, "heatmap-tier-4" }
    };
    var tierDisplayLookup = tierDefinitions.ToDictionary(t => ParseTierNumber(t.Key), t => t.Label);

    var impactCounts = bucketOrder.ToDictionary(bucket => bucket, bucket => prioritisedRequests.Count(r => ResolveImpactBucket(r) == bucket));
    var riskCounts = bucketOrder.ToDictionary(bucket => bucket, bucket => prioritisedRequests.Count(r => ResolveRiskBucket(r) == bucket));
    int impactTotal = impactCounts.Values.Sum();
    int riskTotal = riskCounts.Values.Sum();

    string FormatDistribution(int count, int total) => total <= 0 ? "0" : $"{count} ({Math.Round((double)count / total * 100)}%)";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item active">Demand reporting</li>
                </ol>
                <h1 class="m-0">Demand reporting dashboard</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            @foreach (var stat in summaryStats)
            {
                <div class="col-sm-6 col-lg-3">
                    <div class="card summary-card mb-3">
                        <div class="card-body">
                            <div class="summary-label">@stat.Label</div>
                            <div class="summary-value">@stat.Value</div>
                            <div class="summary-subtext">@stat.Subtext</div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="row">
            <div class="col-xl-6 col-lg-12">
                <div class="card distribution-card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h3 class="card-title mb-0">Impact distribution</h3>
                        <span class="text-muted small">@impactTotal prioritised</span>
                    </div>
                    <div class="card-body">
                        <ul class="distribution-list">
                            @foreach (var bucket in bucketOrder)
                            {
                                <li>
                                    <span class="distribution-label">@bucket impact</span>
                                    <span class="distribution-value">@FormatDistribution(impactCounts[bucket], impactTotal)</span>
                                </li>
                            }
                        </ul>
                        @if (impactTotal == 0)
                        {
                            <p class="text-muted small mb-0">No prioritised requests have a recorded impact score yet.</p>
                        }
                    </div>
                </div>
            </div>
            <div class="col-xl-6 col-lg-12">
                <div class="card distribution-card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h3 class="card-title mb-0">Risk distribution</h3>
                        <span class="text-muted small">@riskTotal prioritised</span>
                    </div>
                    <div class="card-body">
                        <ul class="distribution-list">
                            @foreach (var bucket in bucketOrder)
                            {
                                <li>
                                    <span class="distribution-label">@bucket risk</span>
                                    <span class="distribution-value">@FormatDistribution(riskCounts[bucket], riskTotal)</span>
                                </li>
                            }
                        </ul>
                        @if (riskTotal == 0)
                        {
                            <p class="text-muted small mb-0">No prioritised requests have a recorded risk score yet.</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card heatmap-card mb-4">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Risk vs impact heatmap</h3>
                    </div>
                    <div class="card-body">
                        <div class="heatmap-grid table-responsive">
                            <table class="table heatmap-table">
                                <thead>
                                    <tr>
                                        <th class="align-middle text-muted">Risk ▸</th>
                                        @foreach (var impact in bucketOrder)
                                        {
                                            <th class="text-center">@impact impact</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var risk in bucketOrder)
                                    {
                                        <tr>
                                            <th scope="row" class="text-muted">@risk risk</th>
                                            @foreach (var impact in bucketOrder)
                                            {
                                                var key = $"{risk}|{impact}";
                                                var cellRequests = heatmapCells.TryGetValue(key, out var list) ? list : new List<Compass.Models.DemandRequest>();
                                                var count = cellRequests.Count;
                                                var tierNumber = count > 0 ? cellRequests.Min(r => ParseTierNumber(r.Prioritisation?.PriorityTier)) : 0;
                                                var tierClass = tierClassLookup.TryGetValue(tierNumber, out var className) ? className : "heatmap-tier-empty";
                                                var tierLabel = tierDisplayLookup.TryGetValue(tierNumber, out var display) ? display : "Unprioritised";
                                                var tierShort = tierNumber >= 1 && tierNumber <= 4 ? tierDefinitions[tierNumber - 1].Short : "Unprioritised";
                                                var tooltip = $"{count} {(count == 1 ? "request" : "requests")} · {tierLabel}";

                                                if (count == 0)
                                                {
                                                    <td class="heatmap-cell heatmap-tier-empty" title="No prioritised requests in this cell">
                                                        <span class="heatmap-count">—</span>
                                                    </td>
                                                }
                                                else
                                                {
                                                    <td class="heatmap-cell @tierClass" data-heatmap-key="@key" title="@tooltip">
                                                        <span class="heatmap-count">@count</span>
                                                        <span class="badge heatmap-badge">@tierShort</span>
                                                    </td>
                                                }
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="heatmap-legend d-flex align-items-center mt-3">
                            <span class="text-muted small mr-2">Legend:</span>
                            @foreach (var tier in tierDefinitions)
                            {
                                var number = ParseTierNumber(tier.Key);
                                <span class="heatmap-legend-item">
                                    <span class="heatmap-legend-swatch heatmap-tier-@number"></span>
                                    <span class="small">@tier.Label</span>
                                </span>
                            }
                            <span class="heatmap-legend-item">
                                <span class="heatmap-legend-swatch heatmap-tier-empty"></span>
                                <span class="small">No prioritised requests</span>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Priority tier distribution</h3>
                    </div>
                    <div class="card-body">
                        <canvas id="tierChart" aria-label="Bar chart of requests by priority tier" role="img"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Status breakdown</h3>
                    </div>
                    <div class="card-body">
                        <canvas id="statusChart" aria-label="Doughnut chart of request status" role="img"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Priorities by portfolio</h3>
                    </div>
                    <div class="card-body">
                        @if (portfolioGroups.Any())
                        {
                            <canvas id="portfolioChart" aria-label="Stacked bar chart of priorities by portfolio" role="img"></canvas>
                        }
                        else
                        {
                            <p class="text-muted mb-0">No prioritised requests are assigned to portfolios yet.</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Recently updated requests</h3>
                    </div>
                    <div class="card-body table-responsive p-0">
                        @if (requests.Any())
                        {
                            <table class="table table-hover text-nowrap">
                                <thead>
                                    <tr>
                                        <th>Request</th>
                                        <th>Requestor</th>
                                        <th>Status</th>
                                        <th>Priority</th>
                                        <th>Updated</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var request in requests.OrderByDescending(r => r.UpdatedAt).Take(10))
                                    {
                                        <tr>
                                            <td>
                                                <a asp-action="Details" asp-route-id="@request.Id" class="font-weight-semibold">@request.ProposedTitle</a>
                                                <div class="text-muted small">Reference @request.ReferenceNumber</div>
                                            </td>
                                            <td>
                                                <div class="font-weight-semibold">@request.ApplicantName</div>
                                                <div class="text-muted small">@request.ApplicantEmail</div>
                                            </td>
                                            <td>
                                                <span class="badge badge-soft">@request.Status</span>
                                            </td>
                                            <td>
                                                @if (request.Prioritisation != null)
                                                {
                                                    var tier = request.Prioritisation.PriorityTier;
                                                    <span class="badge badge-soft-tier">@FormatTierShort(tier)</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Unprioritised</span>
                                                }
                                            </td>
                                            <td class="text-muted">@request.UpdatedAt.ToString("dd MMM yyyy HH:mm")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="p-4 text-center text-muted">
                                <p>No demand requests have been recorded yet.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="heatmapModal" tabindex="-1" role="dialog" aria-labelledby="heatmapModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="heatmapModalTitle">Requests in selection</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div id="heatmapModalBody">
                    <p class="text-muted mb-0">Select a cell in the heatmap to inspect the underlying requests.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script nonce="@Context.Items["Nonce"]">
        (function () {
            const detailsUrlTemplate = '@Url.Action("Details", new { id = "__id__" })';
            const heatmapData = @Html.Raw(heatmapJson);
            const tierChartData = @Html.Raw(tierChartJson);
            const statusChartData = @Html.Raw(statusChartJson);
            const portfolioChartData = @Html.Raw(portfolioChartJson);

            const heatmapModal = $('#heatmapModal');
            const heatmapModalBody = document.getElementById('heatmapModalBody');
            const heatmapModalTitle = document.getElementById('heatmapModalTitle');

            document.querySelectorAll('[data-heatmap-key]').forEach(cell => {
                cell.addEventListener('click', () => {
                    const key = cell.dataset.heatmapKey;
                    const items = heatmapData[key] || [];
                    if (!items.length) {
                        return;
                    }

                    const [risk, impact] = key.split('|');
                    heatmapModalTitle.textContent = `${risk} risk · ${impact} impact`;

                    const list = document.createElement('div');
                    list.className = 'list-group heatmap-modal-list';

                    items.forEach(item => {
                        const anchor = document.createElement('a');
                        anchor.className = 'list-group-item list-group-item-action';
                        anchor.href = detailsUrlTemplate.replace('__id__', item.id);

                        const riskLabel = item.effectiveRiskLevel || item.riskBucket || 'Not set';
                        const impactLabel = item.impactLevel || item.impactBucket || 'Not set';
                        const impactSummaryHtml = item.impactSummary ? `<div class="text-muted small">Impact summary: ${item.impactSummary}</div>` : '';

                        anchor.innerHTML = `
                            <div class="d-flex w-100 justify-content-between align-items-center">
                                <h5 class="mb-1 font-weight-semibold">${item.title}</h5>
                                <span class="badge badge-soft-tier">${item.priorityTier.split('–')[0].trim()}</span>
                            </div>
                            <p class="mb-1 text-muted small">Reference ${item.reference} · Score ${item.totalScore}</p>
                            <div class="text-muted small">Risk: ${riskLabel} · Impact: ${impactLabel}</div>
                            <div class="text-muted small">Business area: ${item.businessArea} · Portfolio: ${item.portfolio}</div>
                            ${impactSummaryHtml}
                        `;

                        list.appendChild(anchor);
                    });

                    heatmapModalBody.innerHTML = '';
                    heatmapModalBody.appendChild(list);
                    heatmapModal.modal('show');
                });
            });

            const tierCtx = document.getElementById('tierChart');
            if (tierCtx) {
                const tierConfig = {
                    type: 'bar',
                    data: {
                        labels: tierChartData.labels,
                        datasets: [{
                            label: 'Requests',
                            data: tierChartData.data,
                            backgroundColor: tierChartData.colors
                        }]
                    },
                    options: {
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    precision: 0
                                }
                            }
                        },
                        plugins: {
                            legend: { display: false }
                        }
                    }
                };
                new Chart(tierCtx, tierConfig);
            }

            const statusCtx = document.getElementById('statusChart');
            if (statusCtx) {
                const statusConfig = {
                    type: 'doughnut',
                    data: {
                        labels: statusChartData.labels,
                        datasets: [{
                            data: statusChartData.data,
                            backgroundColor: statusChartData.colors
                        }]
                    },
                    options: {
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom'
                            }
                        }
                    }
                };
                new Chart(statusCtx, statusConfig);
            }

            const portfolioCtx = document.getElementById('portfolioChart');
            if (portfolioCtx && portfolioChartData.labels.length) {
                const datasets = portfolioChartData.datasets.map(dataset => ({
                    label: dataset.label,
                    data: dataset.data,
                    backgroundColor: dataset.backgroundColor,
                    borderWidth: 1,
                    borderColor: '#fff'
                }));

                const portfolioConfig = {
                    type: 'bar',
                    data: {
                        labels: portfolioChartData.labels,
                        datasets
                    },
                    options: {
                        maintainAspectRatio: false,
                        responsive: true,
                        scales: {
                            x: {
                                stacked: true
                            },
                            y: {
                                stacked: true,
                                beginAtZero: true,
                                ticks: {
                                    precision: 0
                                }
                            }
                        }
                    }
                };

                new Chart(portfolioCtx, portfolioConfig);
            }
        })();
    </script>
}

<style>
    .summary-card {
        border: 1px solid #edf2f7;
    }

    .summary-card .card-body {
        padding: 1.25rem;
    }

    .summary-label {
        font-size: 0.9rem;
        color: #475467;
        text-transform: uppercase;
        letter-spacing: .08em;
        margin-bottom: .25rem;
    }

    .summary-value {
        font-size: 2rem;
        font-weight: 600;
        color: #0c1d3e;
        line-height: 1.1;
    }

    .summary-subtext {
        margin-top: .25rem;
        color: #98a2b3;
        font-size: 0.85rem;
    }

    .distribution-card {
        border: 1px solid #e4e9f2;
    }

    .distribution-card .card-body {
        padding: 1.25rem 1.5rem;
    }

    .distribution-list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .distribution-list li {
