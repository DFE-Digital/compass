@model Compass.ViewModels.DemandManagement.CsvImportViewModel
@{
    ViewData["Title"] = "Map CSV fields";
    var databaseFields = ViewBag.DatabaseFields as List<string> ?? new List<string>();
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Requests", "DemandManagement")" style="color: #005ea5; text-decoration: none;">Demand requests</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("ImportCsv", "DemandManagement")" style="color: #005ea5; text-decoration: none;">Import CSV</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Map fields</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Map CSV fields to database</h1>
                <p class="text-muted mb-0">Select which database field each CSV column should map to</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (Model.SampleRows.Any())
        {
            <div class="card mb-4">
                <div class="card-header">
                    <h3 class="card-title">Sample data (first @Model.SampleRows.Count rows)</h3>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered table-sm">
                            <thead>
                                <tr>
                                    @foreach (var column in Model.CsvColumns)
                                    {
                                        <th style="white-space: nowrap; font-size: 0.875rem;">@column</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.SampleRows)
                                {
                                    <tr>
                                        @foreach (var column in Model.CsvColumns)
                                        {
                                            <td style="font-size: 0.875rem; max-width: 200px; overflow: hidden; text-overflow: ellipsis;" title="@(row.ContainsKey(column) ? row[column] : "")">
                                                @(row.ContainsKey(column) ? (row[column].Length > 50 ? row[column].Substring(0, 50) + "..." : row[column]) : "")
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <form asp-action="ProcessCsvImport" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="TempFilePath" value="@Model.TempFilePath" />
            
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Field mappings</h3>
                </div>
                <div class="card-body">
                    <p class="text-muted">Select the database field for each CSV column. Leave blank to skip a column.</p>
                    
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th style="width: 40%;">CSV Column</th>
                                    <th style="width: 60%;">Database Field</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.CsvColumns.Count; i++)
                                {
                                    var csvColumn = Model.CsvColumns[i];
                                    var currentMapping = Model.FieldMappings.ContainsKey(csvColumn) ? Model.FieldMappings[csvColumn] : "";
                                    <tr>
                                        <td>
                                            <strong>@csvColumn</strong>
                                        </td>
                                        <td>
                                            <select name="FieldMappings[@csvColumn]" class="form-control">
                                                <option value="">-- Skip this column --</option>
                                                @foreach (var dbField in databaseFields)
                                                {
                                                    <option value="@dbField" selected="@(currentMapping == dbField)">@dbField</option>
                                                }
                                            </select>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">Import data</button>
                    <a href="@Url.Action("ImportCsv", "DemandManagement")" class="btn btn-secondary">Cancel</a>
                </div>
            </div>
        </form>
    </div>
</section>

