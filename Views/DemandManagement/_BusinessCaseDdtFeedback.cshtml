@model Compass.Models.BusinessCase
@using Compass.Models
@using System.Linq

<div class="card mb-4">
    <div class="card-header">
        <h3 class="card-title">DDT feedback</h3>
        <div class="card-tools">
            <a href="#" data-toggle="modal" data-target="#addDdtFeedbackModal">Add DDT feedback</a>
        </div>
    </div>
    <div class="card-body">
        @if (Model.DdtFeedbacks != null && Model.DdtFeedbacks.Any())
        {
            @foreach (var feedback in Model.DdtFeedbacks.OrderByDescending(f => f.CreatedAt))
            {
                <div class="card mb-3" id="feedback-@feedback.Id">
                    <div class="card-body">
                        <div style="white-space: pre-wrap;" class="mb-2">@feedback.Feedback</div>
                        <div class="text-muted small">
                            <span>@(feedback.FeedbackProviderName ?? feedback.FeedbackProviderEmail ?? "Unknown")</span>
                            <span class="mx-2">•</span>
                            <span>@feedback.CreatedAt.ToString("dd MMM yyyy 'at' HH:mm")</span>
                            <span class="mx-2">•</span>
                            <button type="button" class="btn btn-sm btn-link p-0 text-muted edit-feedback-btn" 
                                    data-toggle="modal" 
                                    data-target="#editDdtFeedbackModal" 
                                    data-feedback-id="@feedback.Id"
                                    data-feedback-text="@(feedback.Feedback?.Replace("\"", "&quot;").Replace("'", "&#39;") ?? "")"
                                    data-provider-name="@(feedback.FeedbackProviderName?.Replace("\"", "&quot;").Replace("'", "&#39;") ?? "")"
                                    data-provider-email="@(feedback.FeedbackProviderEmail?.Replace("\"", "&quot;").Replace("'", "&#39;") ?? "")"
                                    style="text-decoration: none; vertical-align: baseline;">
                                <i class="fas fa-edit"></i> Edit
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="alert alert-info">
                <i class="fas fa-info-circle mr-2"></i>No DDT feedback has been provided yet. Click "Add DDT feedback" to add the first feedback.
            </div>
        }
    </div>
</div>

<!-- Edit DDT Feedback Modal -->
<div class="modal fade" id="editDdtFeedbackModal" tabindex="-1" role="dialog" aria-labelledby="editDdtFeedbackModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editDdtFeedbackModalLabel">Edit DDT feedback</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="EditDdtFeedback" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="businessCaseId" value="@Model.Id" />
                <input type="hidden" name="feedbackId" id="editFeedbackId" />
                <div class="modal-body">
                    <div class="form-group">
                        <label class="control-label" for="editDdtFeedbackProviderSearch">Feedback provider</label>
                        <small class="form-text text-muted">Search for a colleague in Entra ID to set as the feedback provider. The user will be automatically added to the CMS if they don't already exist.</small>
                        <div class="user-picker" data-user-picker data-search-url="/api/users/search" data-select-url="/api/users/select">
                            <div class="position-relative">
                                <input type="text"
                                       class="form-control js-user-picker-input"
                                       id="editDdtFeedbackProviderSearch"
                                       name="editDdtFeedbackProviderSearch"
                                       autocomplete="off"
                                       placeholder="e.g. Alex Smith or alex.smith@education.gov.uk" />
                                <span class="user-picker__spinner js-user-picker-spinner" aria-hidden="true">Searching…</span>
                                <div class="user-picker__results js-user-picker-results" role="listbox" aria-live="polite"></div>
                            </div>
                            <p class="form-text text-muted js-user-picker-message"></p>
                            <input type="hidden" name="entraUserObjectId" class="js-user-picker-objectid" id="editDdtFeedbackProviderObjectId" />
                            <input type="hidden" name="entraUserEmail" class="js-user-picker-email" id="editDdtFeedbackProviderEmail" />
                            <input type="hidden" name="entraUserName" class="js-user-picker-name" id="editDdtFeedbackProviderName" />
                            <div class="user-picker__selected js-user-picker-summary" data-default-text="No feedback provider selected.">
                                <span class="text-muted">No feedback provider selected.</span>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="editFeedbackText">Feedback <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="editFeedbackText" name="feedback" rows="8" maxlength="4000" required placeholder="Enter DDT feedback here..."></textarea>
                        <small class="form-text text-muted">Maximum 4000 characters</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update feedback</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add DDT Feedback Modal -->
<div class="modal fade" id="addDdtFeedbackModal" tabindex="-1" role="dialog" aria-labelledby="addDdtFeedbackModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addDdtFeedbackModalLabel">Add DDT feedback</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="AddDdtFeedback" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="businessCaseId" value="@Model.Id" />
                <div class="modal-body">
                    <div class="form-group">
                        <label class="control-label" for="ddtFeedbackProviderSearch">Feedback provider</label>
                        <small class="form-text text-muted">Search for a colleague in Entra ID to set as the feedback provider. The user will be automatically added to the CMS if they don't already exist.</small>
                        <div class="user-picker" data-user-picker data-search-url="/api/users/search" data-select-url="/api/users/select">
                            <div class="position-relative">
                                <input type="text"
                                       class="form-control js-user-picker-input"
                                       id="ddtFeedbackProviderSearch"
                                       name="ddtFeedbackProviderSearch"
                                       autocomplete="off"
                                       placeholder="e.g. Alex Smith or alex.smith@education.gov.uk" />
                                <span class="user-picker__spinner js-user-picker-spinner" aria-hidden="true">Searching…</span>
                                <div class="user-picker__results js-user-picker-results" role="listbox" aria-live="polite"></div>
                            </div>
                            <p class="form-text text-muted js-user-picker-message"></p>
                            <input type="hidden" name="entraUserObjectId" class="js-user-picker-objectid" id="ddtFeedbackProviderObjectId" />
                            <input type="hidden" name="entraUserEmail" class="js-user-picker-email" id="ddtFeedbackProviderEmail" />
                            <input type="hidden" name="entraUserName" class="js-user-picker-name" id="ddtFeedbackProviderName" />
                            <div class="user-picker__selected js-user-picker-summary" data-default-text="No feedback provider selected.">
                                <span class="text-muted">No feedback provider selected.</span>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="feedbackText">Feedback <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="feedbackText" name="feedback" rows="8" maxlength="4000" required placeholder="Enter DDT feedback here..."></textarea>
                        <small class="form-text text-muted">Maximum 4000 characters</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Add feedback</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/js/user-picker.js" asp-append-version="true"></script>
<script nonce="@Context.Items["Nonce"]">
    (function() {
        // Wait for DOM and user-picker to be ready
        function initDdtFeedbackUserPicker() {
            if (typeof window.initializeUserPickers !== 'function') {
                setTimeout(initDdtFeedbackUserPicker, 100);
                return;
            }
            
            // Initialize user picker
            window.initializeUserPickers();
            
            // Setup add modal handlers
            const addModal = document.getElementById('addDdtFeedbackModal');
            if (addModal) {
                addModal.addEventListener('shown.bs.modal', function() {
                    setTimeout(function() {
                        const pickerRoot = addModal.querySelector('[data-user-picker]');
                        if (pickerRoot && typeof window.initializeUserPickers === 'function') {
                            pickerRoot.removeAttribute('data-picker-initialized');
                            window.initializeUserPickers();
                        }
                        const pickerInput = document.getElementById('ddtFeedbackProviderSearch');
                        if (pickerInput) {
                            pickerInput.focus();
                        }
                    }, 200);
                });
                
                addModal.addEventListener('hidden.bs.modal', function() {
                    const form = addModal.querySelector('form');
                    if (form) {
                        form.reset();
                    }
                    const pickerRoot = addModal.querySelector('[data-user-picker]');
                    if (pickerRoot) {
                        const objectIdInput = pickerRoot.querySelector('.js-user-picker-objectid');
                        const emailInput = pickerRoot.querySelector('.js-user-picker-email');
                        const nameInput = pickerRoot.querySelector('.js-user-picker-name');
                        const searchInput = pickerRoot.querySelector('.js-user-picker-input');
                        const summary = pickerRoot.querySelector('.js-user-picker-summary');
                        
                        if (objectIdInput) objectIdInput.value = '';
                        if (emailInput) emailInput.value = '';
                        if (nameInput) nameInput.value = '';
                        if (searchInput) searchInput.value = '';
                        if (summary) {
                            summary.innerHTML = '<span class="text-muted">No feedback provider selected.</span>';
                        }
                    }
                });
            }
            
            // Setup edit modal handlers
            const editModal = document.getElementById('editDdtFeedbackModal');
            if (editModal) {
                // Handle edit button clicks to populate modal
                document.addEventListener('click', function(e) {
                    const editBtn = e.target.closest('.edit-feedback-btn');
                    if (editBtn) {
                        const feedbackId = editBtn.getAttribute('data-feedback-id');
                        let feedbackText = editBtn.getAttribute('data-feedback-text') || '';
                        let providerName = editBtn.getAttribute('data-provider-name') || '';
                        let providerEmail = editBtn.getAttribute('data-provider-email') || '';
                        
                        // Decode HTML entities
                        feedbackText = feedbackText.replace(/&quot;/g, '"').replace(/&#39;/g, "'");
                        providerName = providerName.replace(/&quot;/g, '"').replace(/&#39;/g, "'");
                        providerEmail = providerEmail.replace(/&quot;/g, '"').replace(/&#39;/g, "'");
                        
                        // Populate form fields
                        const feedbackIdInput = document.getElementById('editFeedbackId');
                        const feedbackTextInput = document.getElementById('editFeedbackText');
                        if (feedbackIdInput) feedbackIdInput.value = feedbackId || '';
                        if (feedbackTextInput) feedbackTextInput.value = feedbackText;
                        
                        // Set user picker values
                        const editPickerRoot = editModal.querySelector('[data-user-picker]');
                        if (editPickerRoot) {
                            const objectIdInput = editPickerRoot.querySelector('.js-user-picker-objectid');
                            const emailInput = editPickerRoot.querySelector('.js-user-picker-email');
                            const nameInput = editPickerRoot.querySelector('.js-user-picker-name');
                            const searchInput = editPickerRoot.querySelector('.js-user-picker-input');
                            const summary = editPickerRoot.querySelector('.js-user-picker-summary');
                            
                            if (emailInput) emailInput.value = providerEmail;
                            if (nameInput) nameInput.value = providerName;
                            if (searchInput) searchInput.value = providerName;
                            
                            if (summary && providerName) {
                                summary.innerHTML = `
                                    <div class="user-picker__selected-card">
                                        <div class="user-picker__selected-name">${escapeHtml(providerName)}</div>
                                        <div class="user-picker__selected-meta">${escapeHtml(providerEmail)}</div>
                                        <button type="button" class="btn btn-link btn-sm js-user-picker-clear">Remove</button>
                                    </div>
                                `;
                            } else if (summary) {
                                summary.innerHTML = '<span class="text-muted">No feedback provider selected.</span>';
                            }
                        }
                    }
                });
                
                editModal.addEventListener('shown.bs.modal', function() {
                    setTimeout(function() {
                        const pickerRoot = editModal.querySelector('[data-user-picker]');
                        if (pickerRoot && typeof window.initializeUserPickers === 'function') {
                            pickerRoot.removeAttribute('data-picker-initialized');
                            window.initializeUserPickers();
                        }
                        const pickerInput = document.getElementById('editDdtFeedbackProviderSearch');
                        if (pickerInput) {
                            pickerInput.focus();
                        }
                    }, 200);
                });
                
                editModal.addEventListener('hidden.bs.modal', function() {
                    const form = editModal.querySelector('form');
                    if (form) {
                        form.reset();
                    }
                    const pickerRoot = editModal.querySelector('[data-user-picker]');
                    if (pickerRoot) {
                        const objectIdInput = pickerRoot.querySelector('.js-user-picker-objectid');
                        const emailInput = pickerRoot.querySelector('.js-user-picker-email');
                        const nameInput = pickerRoot.querySelector('.js-user-picker-name');
                        const searchInput = pickerRoot.querySelector('.js-user-picker-input');
                        const summary = pickerRoot.querySelector('.js-user-picker-summary');
                        
                        if (objectIdInput) objectIdInput.value = '';
                        if (emailInput) emailInput.value = '';
                        if (nameInput) nameInput.value = '';
                        if (searchInput) searchInput.value = '';
                        if (summary) {
                            summary.innerHTML = '<span class="text-muted">No feedback provider selected.</span>';
                        }
                    }
                });
            }
        }
        
        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }
        
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initDdtFeedbackUserPicker);
        } else {
            initDdtFeedbackUserPicker();
        }
    })();
</script>
