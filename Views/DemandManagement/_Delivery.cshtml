@model Compass.ViewModels.DemandManagement.DemandSectionDetailViewModel

@functions {
    public static string FormatBoolean(bool? value) => value.HasValue ? (value.Value ? "Yes" : "No") : "Not answered";
}

@{
    var request = Model.Request;
    var status = Model.Status;
    var sectionKey = "Delivery";
    var timescalesDisplay = string.IsNullOrWhiteSpace(request.DeliveryTimescales) ? "Not specified" : request.DeliveryTimescales;
    var hasTargetDisplay = FormatBoolean(request.HasTargetDeliveryDate);
    var targetDateDisplay = request.TargetDeliveryDate.HasValue ? request.TargetDeliveryDate.Value.ToString("dd MMM yyyy") : "Not set";
    var hasTargetRadioValue = request.HasTargetDeliveryDate.HasValue ? request.HasTargetDeliveryDate.Value.ToString().ToLowerInvariant() : string.Empty;
    var modalPrefix = "delivery";
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0">Delivery</h3>
    </div>
    <div class="card-body">
        <dl class="definition-list">
            <div class="definition-item">
                <dt>Timescales</dt>
                <dd>
                    <div class="definition-value">@timescalesDisplay</div>
                    <div class="definition-actions">
                        <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#@modalPrefix-Timescales-Modal">Change</button>
                    </div>
                </dd>
            </div>

            <div class="definition-item">
                <dt>Has target delivery date</dt>
                <dd>
                    <div class="definition-value">@hasTargetDisplay</div>
                    <div class="definition-actions">
                        <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#@modalPrefix-Target-Modal">Change</button>
                    </div>
                </dd>
            </div>

            <div class="definition-item">
                <dt>Target delivery date</dt>
                <dd>
                    <div class="definition-value">@targetDateDisplay</div>
                    <div class="definition-actions">
                        <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#@modalPrefix-Target-Modal">Change</button>
                    </div>
                </dd>
            </div>
        </dl>
    </div>
</div>

<!-- Timescales modal -->
<div class="modal fade" id="@modalPrefix-Timescales-Modal" tabindex="-1" role="dialog" aria-labelledby="@modalPrefix-Timescales-Label" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="@modalPrefix-Timescales-Label">Update timescales</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateSectionField" asp-route-id="@status.DemandRequestId" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="sectionKey" value="@sectionKey" />
                <input type="hidden" name="fieldKey" value="Timescales" />
                <input type="hidden" name="returnUrl" value="@status.ReturnUrl" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="@modalPrefix-Timescales-Input">Describe the timescales</label>
                        <textarea id="@modalPrefix-Timescales-Input"
                                  name="stringValue"
                                  class="form-control"
                                  rows="5"
                                  required>@request.DeliveryTimescales</textarea>
                        <small class="form-text text-muted">Provide a summary of the delivery timeframe.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Target delivery date modal -->
<div class="modal fade" id="@modalPrefix-Target-Modal" tabindex="-1" role="dialog" aria-labelledby="@modalPrefix-Target-Label" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="@modalPrefix-Target-Label">Update target delivery date</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateSectionField" asp-route-id="@status.DemandRequestId" method="post" id="@modalPrefix-Target-Form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="sectionKey" value="@sectionKey" />
                <input type="hidden" name="fieldKey" value="TargetDeliveryDate" />
                <input type="hidden" name="returnUrl" value="@status.ReturnUrl" />
                <div class="modal-body">
                    <fieldset>
                        <legend class="h6">Is there a target delivery date?</legend>
                        <div class="custom-control custom-radio">
                            <input class="custom-control-input"
                                   type="radio"
                                   name="boolValue"
                                   id="@modalPrefix-Target-Yes"
                                   value="true"
                                   @(hasTargetRadioValue == "true" ? "checked" : null) />
                            <label class="custom-control-label" for="@modalPrefix-Target-Yes">Yes</label>
                        </div>
                        <div class="custom-control custom-radio">
                            <input class="custom-control-input"
                                   type="radio"
                                   name="boolValue"
                                   id="@modalPrefix-Target-No"
                                   value="false"
                                   @(hasTargetRadioValue == "false" ? "checked" : null) />
                            <label class="custom-control-label" for="@modalPrefix-Target-No">No</label>
                        </div>
                    </fieldset>

                    <div class="form-group mt-3" id="@modalPrefix-Target-DateGroup">
                        <label for="@modalPrefix-Target-Date">Target delivery date</label>
                        <input type="date"
                               class="form-control"
                               id="@modalPrefix-Target-Date"
                               name="dateValue"
                               value="@request.TargetDeliveryDate?.ToString("yyyy-MM-dd")" />
                        <small class="form-text text-muted">Provide the expected delivery date.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
    (function () {
        const modal = document.getElementById('@modalPrefix-Target-Modal');
        if (!modal) {
            return;
        }

        const dateGroup = modal.querySelector('#@modalPrefix-Target-DateGroup');
        const form = modal.querySelector('#@modalPrefix-Target-Form');
        const yesRadio = modal.querySelector('#@modalPrefix-Target-Yes');
        const noRadio = modal.querySelector('#@modalPrefix-Target-No');

        function toggleDateGroup() {
            const show = yesRadio && yesRadio.checked;
            if (dateGroup) {
                dateGroup.style.display = show ? 'block' : 'none';
                const dateInput = dateGroup.querySelector('input[name="dateValue"]');
                if (dateInput) {
                    dateInput.required = show;
                }
            }
        }

        if (yesRadio && noRadio) {
            yesRadio.addEventListener('change', toggleDateGroup);
            noRadio.addEventListener('change', toggleDateGroup);
        }

        toggleDateGroup();

        form?.addEventListener('submit', function () {
            const hiddenReturn = form.querySelector('input[name="returnUrl"]');
            if (hiddenReturn) {
                hiddenReturn.value = window.location.pathname + window.location.search;
            }
        });
    })();
</script>
