@model Compass.Models.BusinessCase
@using Compass.Models

@{
    var businessAreas = ViewBag.BusinessAreas as List<string> ?? new List<string>();
    var statuses = ViewBag.Statuses as List<BusinessCaseStatusLookup> ?? new List<BusinessCaseStatusLookup>();
}

<div class="card mb-4 project-summary-card">
    <div class="card-header">
        <h3 class="card-title">Business case information</h3>
    </div>
    <div class="card-body p-0">
        <table class="table table-borderless mb-0 project-overview-summary">
            <tbody>
                <tr>
                    <td class="summary-label"><strong>Title</strong></td>
                    <td class="summary-value">@Model.Title</td>
                    <td class="text-right">
                        <a href="#" data-toggle="modal" data-target="#editTitleModal">Change</a>
                    </td>
                </tr>
                <tr>
                    <td class="summary-label"><strong>Business case ID</strong></td>
                    <td class="summary-value">
                        <span class="text-monospace">@Model.BusinessCaseId</span>
                    </td>
                    <td class="text-right">
                        <a href="#" data-toggle="modal" data-target="#editBusinessCaseIdModal">Change</a>
                    </td>
                </tr>
                <tr>
                    <td class="summary-label"><strong>Description</strong></td>
                    <td class="summary-value">
                        @if (!string.IsNullOrWhiteSpace(Model.Description))
                        {
                            <div class="text-muted" style="white-space: pre-wrap;">@Model.Description</div>
                        }
                        else
                        {
                            <span class="text-muted">No description provided</span>
                        }
                    </td>
                    <td class="text-right">
                        <a href="#" data-toggle="modal" data-target="#editDescriptionModal">Change</a>
                    </td>
                </tr>
                <tr>
                    <td class="summary-label"><strong>Business area</strong></td>
                    <td class="summary-value">
                        @if (!string.IsNullOrEmpty(Model.BusinessArea))
                        {
                            @Model.BusinessArea
                        }
                        else
                        {
                            <span class="text-muted">Not set</span>
                        }
                    </td>
                    <td class="text-right">
                        <a href="#" data-toggle="modal" data-target="#editBusinessAreaModal">Change</a>
                    </td>
                </tr>
                <tr>
                    <td class="summary-label"><strong>Requestor</strong></td>
                    <td class="summary-value">
                        @if (!string.IsNullOrWhiteSpace(Model.RequestorEmail))
                        {
                            <a href="mailto:@Model.RequestorEmail">@(Model.RequestorName ?? Model.RequestorEmail)</a>
                        }
                        else
                        {
                            <span class="text-muted">Not set</span>
                        }
                    </td>
                    <td class="text-right">
                        <a href="#" data-toggle="modal" data-target="#editRequestorModal">Change</a>
                    </td>
                </tr>
                <tr>
                    <td class="summary-label"><strong>Status</strong></td>
                    <td class="summary-value">
                        @{
                            var statusName = Model.StatusLookup?.Name ?? Model.Status;
                            var statusCssClass = Model.StatusLookup?.CssClass;
                        }
                        @if (!string.IsNullOrWhiteSpace(statusName))
                        {
                            <span class="badge @(statusCssClass ?? "badge-secondary")">@statusName</span>
                        }
                        else
                        {
                            <span class="text-muted">Not set</span>
                        }
                    </td>
                    <td class="text-right">
                        <a href="#" data-toggle="modal" data-target="#editStatusModal">Change</a>
                    </td>
                </tr>
                <tr>
                    <td class="summary-label"><strong>Date</strong></td>
                    <td class="summary-value">
                        @if (Model.Date.HasValue)
                        {
                            @Model.Date.Value.ToString("dd MMMM yyyy")
                        }
                        else
                        {
                            <span class="text-muted">Not set</span>
                        }
                    </td>
                    <td class="text-right"></td>
                </tr>
                <tr>
                    <td class="summary-label"><strong>Created</strong></td>
                    <td class="summary-value">
                        <span class="text-muted">@Model.CreatedAt.ToString("dd MMMM yyyy 'at' HH:mm")</span>
                    </td>
                    <td class="text-right"></td>
                </tr>
                <tr>
                    <td class="summary-label"><strong>Last updated</strong></td>
                    <td class="summary-value">
                        <span class="text-muted">@Model.UpdatedAt.ToString("dd MMMM yyyy 'at' HH:mm")</span>
                    </td>
                    <td class="text-right"></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@if (Model.Reviewers != null && Model.Reviewers.Any())
{
    <div class="card mb-4">
        <div class="card-header">
            <h3 class="card-title">Reviewers</h3>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Role</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var reviewer in Model.Reviewers)
                        {
                            <tr>
                                <td>@(reviewer.ReviewerName ?? "Not set")</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(reviewer.ReviewerEmail))
                                    {
                                        <a href="mailto:@reviewer.ReviewerEmail">@reviewer.ReviewerEmail</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not set</span>
                                    }
                                </td>
                                <td>@(reviewer.ReviewerRole ?? "Not set")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<!-- Edit Title Modal -->
<div class="modal fade" id="editTitleModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Title</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateBusinessCaseField" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="field" value="title" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="titleValue">Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="titleValue" name="value" value="@Model.Title" maxlength="255" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Business Case ID Modal -->
<div class="modal fade" id="editBusinessCaseIdModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Business Case ID</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateBusinessCaseField" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="field" value="businessCaseId" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="businessCaseIdValue">Business Case ID <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="businessCaseIdValue" name="value" value="@Model.BusinessCaseId" maxlength="50" required />
                        <small class="form-text text-muted">Enter the business case ID from your external system.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Description Modal -->
<div class="modal fade" id="editDescriptionModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Description</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateBusinessCaseField" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="field" value="description" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="descriptionValue">Description</label>
                        <textarea class="form-control" id="descriptionValue" name="value" rows="8">@Model.Description</textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Business Area Modal -->
<div class="modal fade" id="editBusinessAreaModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Business Area</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateBusinessCaseField" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="field" value="businessArea" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="businessAreaValue">Business Area</label>
                        <select class="form-control" id="businessAreaValue" name="value">
                            <option value="">Select business area...</option>
                            @foreach (var area in businessAreas)
                            {
                                @if (Model.BusinessArea == area)
                                {
                                    <option value="@area" selected>@area</option>
                                }
                                else
                                {
                                    <option value="@area">@area</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Requestor Modal -->
<div class="modal fade" id="editRequestorModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Requestor</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateBusinessCaseField" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="field" value="requestor" />
                <div class="modal-body">
                    <div class="form-group">
                        <label class="control-label" for="requestorSearch">Requestor</label>
                        <small class="form-text text-muted">Search for a colleague in Entra ID to set as the requestor for this business case.</small>
                        <div class="user-picker" data-user-picker data-search-url="/api/users/search" data-select-url="/api/users/select">
                            <div class="position-relative">
                                <input type="text"
                                       class="form-control js-user-picker-input"
                                       id="requestorSearch"
                                       autocomplete="off"
                                       placeholder="e.g. Alex Smith or alex.smith@education.gov.uk" />
                                <span class="user-picker__spinner js-user-picker-spinner" aria-hidden="true">Searching…</span>
                                <div class="user-picker__results js-user-picker-results" role="listbox" aria-live="polite"></div>
                            </div>
                            <p class="form-text text-muted js-user-picker-message"></p>
                            <input type="hidden" name="entraUserObjectId" class="js-user-picker-objectid" id="requestorObjectId" />
                            <input type="hidden" name="entraUserEmail" class="js-user-picker-email" id="requestorEmail" />
                            <input type="hidden" name="entraUserName" class="js-user-picker-name" id="requestorName" />
                            <div class="user-picker__selected js-user-picker-summary" data-default-text="No requestor selected.">
                                @if (!string.IsNullOrWhiteSpace(Model.RequestorName))
                                {
                                    <span>@Model.RequestorName (@Model.RequestorEmail)</span>
                                }
                                else
                                {
                                    <span class="text-muted">No requestor selected.</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Status Modal -->
<div class="modal fade" id="editStatusModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Status</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateBusinessCaseField" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="field" value="status" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="statusValue">Status</label>
                        <select class="form-control" id="statusValue" name="value">
                            <option value="">Select status...</option>
                            @foreach (var status in statuses)
                            {
                                @if (Model.StatusLookupId == status.Id)
                                {
                                    <option value="@status.Id" selected>@status.Name</option>
                                }
                                else
                                {
                                    <option value="@status.Id">@status.Name</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/user-picker.js" asp-append-version="true"></script>
}
