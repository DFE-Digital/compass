@model Compass.ViewModels.DemandManagement.DemandSectionDetailViewModel
@using System.Linq

@functions {
    public static string FormatBooleanWithUnsure(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "Not answered";
        }

        return value switch
        {
            "Yes" => "Yes",
            "No" => "No",
            _ => "Unsure"
        };
    }

    public static string FormatBoolean(bool? value) => value.HasValue ? (value.Value ? "Yes" : "No") : "Not answered";
}

@{
    var request = Model.Request;
    var status = Model.Status;
    var missionList = (Model.MissionPillars ?? Enumerable.Empty<string>()).ToList();
    var objectiveList = (Model.StrategicObjectives ?? Enumerable.Empty<string>()).ToList();
    var selectedMissions = string.IsNullOrWhiteSpace(request.OpportunityMissionPillars)
        ? Array.Empty<string>()
        : request.OpportunityMissionPillars.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(v => v.Trim()).ToArray();
    var selectedObjectives = string.IsNullOrWhiteSpace(request.DdatStrategicThemes)
        ? Array.Empty<string>()
        : request.DdatStrategicThemes.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(v => v.Trim()).ToArray();
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0">Strategic alignment</h3>
    </div>
    <div class="card-body">
        <dl class="definition-list">
            <div class="definition-item">
                <dt>Manifesto or statutory commitment</dt>
                <dd>
                    <div class="definition-value">
                        <div>@FormatBooleanWithUnsure(request.IsManifestoOrStatutory)</div>
                        @if (!string.IsNullOrWhiteSpace(request.ManifestoStatutoryDetails))
                        {
                            <div class="text-muted small mt-1">@request.ManifestoStatutoryDetails</div>
                        }
                    </div>
                    <div class="definition-actions">
                        <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#strategic-manifesto-modal">Change</button>
                    </div>
                </dd>
            </div>

            <div class="definition-item">
                <dt>Supports mission pillar</dt>
                <dd>
                    <div class="definition-value">
                        <div>@FormatBoolean(request.SupportsOpportunityMissionPillar)</div>
                        @if (selectedMissions.Any())
                        {
                            <ul class="mb-0 mt-1 pl-3">
                                @foreach (var pillar in selectedMissions)
                                {
                                    <li>@pillar</li>
                                }
                            </ul>
                        }
                    </div>
                    <div class="definition-actions">
                        <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#strategic-mission-modal">Change</button>
                    </div>
                </dd>
            </div>

            <div class="definition-item">
                <dt>Supports DDaT strategic theme</dt>
                <dd>
                    <div class="definition-value">
                        <div>@FormatBoolean(request.SupportsDdatStrategicTheme)</div>
                        @if (selectedObjectives.Any())
                        {
                            <ul class="mb-0 mt-1 pl-3">
                                @foreach (var theme in selectedObjectives)
                                {
                                    <li>@theme</li>
                                }
                            </ul>
                        }
                    </div>
                    <div class="definition-actions">
                        <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#strategic-theme-modal">Change</button>
                    </div>
                </dd>
            </div>
        </dl>
    </div>
</div>

<!-- Manifesto modal -->
<div class="modal fade" id="strategic-manifesto-modal" tabindex="-1" role="dialog" aria-labelledby="strategic-manifesto-label" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="strategic-manifesto-label">Update manifesto or statutory commitment</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateSectionField" asp-route-id="@request.Id" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="sectionKey" value="StrategicAlignment" />
                <input type="hidden" name="fieldKey" value="Manifesto" />
                <input type="hidden" name="returnUrl" value="@status.ReturnUrl" />
                <div class="modal-body">
                    <fieldset>
                        <legend class="h6">Is this essential for a manifesto or statutory commitment?</legend>
                        <div class="custom-control custom-radio">
                            <input class="custom-control-input" type="radio" name="manifestoChoice" id="manifesto-yes" value="Yes" @(string.Equals(request.IsManifestoOrStatutory, "Yes", StringComparison.OrdinalIgnoreCase) ? "checked" : null) />
                            <label class="custom-control-label" for="manifesto-yes">Yes</label>
                        </div>
                        <div class="custom-control custom-radio">
                            <input class="custom-control-input" type="radio" name="manifestoChoice" id="manifesto-no" value="No" @(string.Equals(request.IsManifestoOrStatutory, "No", StringComparison.OrdinalIgnoreCase) ? "checked" : null) />
                            <label class="custom-control-label" for="manifesto-no">No</label>
                        </div>
                        <div class="custom-control custom-radio">
                            <input class="custom-control-input" type="radio" name="manifestoChoice" id="manifesto-unsure" value="Unsure" @(string.Equals(request.IsManifestoOrStatutory, "Unsure", StringComparison.OrdinalIgnoreCase) ? "checked" : null) />
                            <label class="custom-control-label" for="manifesto-unsure">Unsure</label>
                        </div>
                    </fieldset>
                    <div class="form-group mt-3" id="manifesto-details-group">
                        <label for="manifesto-details-input">What is the commitment?</label>
                        <textarea id="manifesto-details-input" name="secondaryValue" class="form-control" rows="4">@request.ManifestoStatutoryDetails</textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Mission pillar modal -->
<div class="modal fade" id="strategic-mission-modal" tabindex="-1" role="dialog" aria-labelledby="strategic-mission-label" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="strategic-mission-label">Update Secretary of State Opportunity Mission Pillars</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateSectionField" asp-route-id="@request.Id" method="post" id="mission-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="sectionKey" value="StrategicAlignment" />
                <input type="hidden" name="fieldKey" value="Mission" />
                <input type="hidden" name="returnUrl" value="@status.ReturnUrl" />
                <input type="hidden" name="stringValue" id="mission-selected" value="@request.OpportunityMissionPillars" />
                <div class="modal-body">
                    <fieldset>
                        <legend class="h6">Does this support a mission pillar?</legend>
                        <div class="custom-control custom-radio">
                            <input class="custom-control-input" type="radio" name="boolValue" id="mission-support-yes" value="true" @(request.SupportsOpportunityMissionPillar == true ? "checked" : null) />
                            <label class="custom-control-label" for="mission-support-yes">Yes</label>
                        </div>
                        <div class="custom-control custom-radio">
                            <input class="custom-control-input" type="radio" name="boolValue" id="mission-support-no" value="false" @(request.SupportsOpportunityMissionPillar == false ? "checked" : null) />
                            <label class="custom-control-label" for="mission-support-no">No</label>
                        </div>
                    </fieldset>

                    <div class="form-group mt-3" id="mission-pillar-group">
                        <label>Select applicable mission pillars</label>
                        <div class="mission-checkbox-list">
                            @foreach (var pillar in missionList)
                            {
                                var id = $"mission-pillars-{pillar.GetHashCode()}";
                                <div class="custom-control custom-checkbox">
                                    <input type="checkbox" class="custom-control-input mission-checkbox" id="@id" value="@pillar" @(selectedMissions.Contains(pillar) ? "checked" : null) />
                                    <label class="custom-control-label" for="@id">@pillar</label>
                                </div>
                            }
                        </div>
                        <small class="form-text text-muted">Select all that apply.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Strategic theme modal -->
<div class="modal fade" id="strategic-theme-modal" tabindex="-1" role="dialog" aria-labelledby="strategic-theme-label" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="strategic-theme-label">Update DDaT strategic themes</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateSectionField" asp-route-id="@request.Id" method="post" id="theme-form">
                @Html.AntiForgeryToken()
                <input type="hidden" name="sectionKey" value="StrategicAlignment" />
                <input type="hidden" name="fieldKey" value="StrategicTheme" />
                <input type="hidden" name="returnUrl" value="@status.ReturnUrl" />
                <input type="hidden" name="stringValue" id="theme-selected" value="@request.DdatStrategicThemes" />
                <div class="modal-body">
                    <fieldset>
                        <legend class="h6">Does this support a DDaT strategic theme?</legend>
                        <div class="custom-control custom-radio">
                            <input class="custom-control-input" type="radio" name="boolValue" id="theme-support-yes" value="true" @(request.SupportsDdatStrategicTheme == true ? "checked" : null) />
                            <label class="custom-control-label" for="theme-support-yes">Yes</label>
                        </div>
                        <div class="custom-control custom-radio">
                            <input class="custom-control-input" type="radio" name="boolValue" id="theme-support-no" value="false" @(request.SupportsDdatStrategicTheme == false ? "checked" : null) />
                            <label class="custom-control-label" for="theme-support-no">No</label>
                        </div>
                    </fieldset>

                    <div class="form-group mt-3" id="theme-objective-group">
                        <label>Select applicable themes</label>
                        <div class="mission-checkbox-list">
                            @foreach (var objective in objectiveList)
                            {
                                var id = $"strategic-theme-{objective.GetHashCode()}";
                                <div class="custom-control custom-checkbox">
                                    <input type="checkbox" class="custom-control-input theme-checkbox" id="@id" value="@objective" @(selectedObjectives.Contains(objective) ? "checked" : null) />
                                    <label class="custom-control-label" for="@id">@objective</label>
                                </div>
                            }
                        </div>
                        <small class="form-text text-muted">Select all that apply.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
    (function () {
        const manifestoModal = document.getElementById('strategic-manifesto-modal');
        if (manifestoModal) {
            const yes = manifestoModal.querySelector('#manifesto-yes');
            const detailsGroup = manifestoModal.querySelector('#manifesto-details-group');
            function toggleDetails() {
                if (!detailsGroup) {
                    return;
                }
                const show = yes && yes.checked;
                detailsGroup.style.display = show ? 'block' : 'none';
                const textarea = detailsGroup.querySelector('textarea');
                if (textarea) {
                    textarea.required = show;
                }
            }
            manifestoModal.addEventListener('change', (event) => {
                if (event.target && event.target.matches('input[name="manifestoChoice"]')) {
                    toggleDetails();
                }
            });
            toggleDetails();
        }

        const missionForm = document.getElementById('mission-form');
        if (missionForm) {
            const checkboxSelector = '.mission-checkbox';
            const hiddenInput = missionForm.querySelector('#mission-selected');
            const group = missionForm.querySelector('#mission-pillar-group');
            const yes = missionForm.querySelector('#mission-support-yes');
            const no = missionForm.querySelector('#mission-support-no');

            function syncHidden() {
                const values = Array.from(missionForm.querySelectorAll(checkboxSelector))
                    .filter(cb => cb.checked)
                    .map(cb => cb.value.trim());
                if (hiddenInput) {
                    hiddenInput.value = values.join(", ");
                }
            }

            function toggleList() {
                if (!group) {
                    return;
                }
                const show = yes && yes.checked;
                group.style.display = show ? 'block' : 'none';
                if (!show) {
                    Array.from(missionForm.querySelectorAll(checkboxSelector)).forEach(cb => cb.checked = false);
                    syncHidden();
                }
            }

            missionForm.addEventListener('change', syncHidden);
            missionForm.addEventListener('change', toggleList);
            toggleList();
            syncHidden();
        }

        const themeForm = document.getElementById('theme-form');
        if (themeForm) {
            const checkboxSelector = '.theme-checkbox';
            const hiddenInput = themeForm.querySelector('#theme-selected');
            const group = themeForm.querySelector('#theme-objective-group');
            const yes = themeForm.querySelector('#theme-support-yes');

            function syncHidden() {
                const values = Array.from(themeForm.querySelectorAll(checkboxSelector))
                    .filter(cb => cb.checked)
                    .map(cb => cb.value.trim());
                if (hiddenInput) {
                    hiddenInput.value = values.join(", ");
                }
            }

            function toggleList() {
                if (!group) {
                    return;
                }
                const show = yes && yes.checked;
                group.style.display = show ? 'block' : 'none';
                if (!show) {
                    Array.from(themeForm.querySelectorAll(checkboxSelector)).forEach(cb => cb.checked = false);
                    syncHidden();
                }
            }

            themeForm.addEventListener('change', syncHidden);
            themeForm.addEventListener('change', toggleList);
            toggleList();
            syncHidden();
        }
    })();
</script>
