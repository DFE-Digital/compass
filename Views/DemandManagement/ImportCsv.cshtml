@{
    ViewData["Title"] = "Import demand requests from CSV";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Requests", "DemandManagement")" style="color: #005ea5; text-decoration: none;">Demand requests</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Import CSV</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Import demand requests from CSV</h1>
                <p class="text-muted mb-0">Upload a CSV file and map columns to database fields</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Upload CSV file</h3>
            </div>
            <div class="card-body">
                <form asp-action="UploadCsv" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="form-group">
                        <label for="csvFile">Select CSV file</label>
                        <input type="file" class="form-control-file" id="csvFile" name="csvFile" accept=".csv" required />
                        <small class="form-text text-muted">The CSV file should have headers in the first row.</small>
                    </div>
                    <button type="submit" class="btn btn-primary">Upload and map fields</button>
                    <a href="@Url.Action("Requests", "DemandManagement")" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header">
                <h3 class="card-title">Instructions</h3>
            </div>
            <div class="card-body">
                <ol>
                    <li>Upload your CSV file using the form above</li>
                    <li>Review the CSV columns and sample data</li>
                    <li>Map each CSV column to the corresponding database field</li>
                    <li>Review the mappings and click "Import" to process the file</li>
                </ol>
                <p class="text-muted mt-3">
                    <strong>Note:</strong> The system will attempt to match names to Entra ID users automatically. 
                    If a match is found, the email address will be populated automatically.
                </p>
            </div>
        </div>
    </div>
</section>

