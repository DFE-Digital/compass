@model Compass.ViewModels.DemandManagement.DemandWorkflowViewModel
@using System.Linq
@using System.Collections.Generic
@using Compass.ViewModels.DemandManagement
@using Compass.Models

@{
    ViewData["Title"] = "Request details";
    var request = Model.Request;
    var tasksByGroup = Model.Tasks
        .GroupBy(t => t.Group)
        .OrderBy(g => g.Key switch
        {
            "Request" => 0,
            "Assessment" => 1,
            "Outcome" => 2,
            _ => 3
        })
        .ToList();

    var sectionCompletions = request.SectionCompletions?.ToDictionary(sc => sc.SectionName, sc => sc) ?? new Dictionary<string, DemandRequestSectionCompletion>();
    var requestSections = new[]
    {
        new { Key = "StrategicAlignment", Name = "Strategic alignment" },
        new { Key = "ImpactAndRisk", Name = "Impact and risk" },
        new { Key = "FundingAndHeadcount", Name = "Funding and headcount" },
        new { Key = "DeliveryPlanning", Name = "Delivery planning" }
    };

    var assessmentSections = new[]
    {
        new { Key = "ResearchAndEvidence", Name = "Research and evidence" },
        new { Key = "NeedsAssessment", Name = "Needs assessment" },
        new { Key = "Recommendations", Name = "Recommendations" },
        new { Key = "Notes", Name = "Notes" },
        new { Key = "PrioritisationAssessment", Name = "Prioritisation assessment" },
        new { Key = "Outcome", Name = "Outcome" }
    };

    var triageMeetings = Model.TriageMeetings ?? Array.Empty<TriageMeeting>();
    var isSubmittedForTriage = request.IsSubmittedToTriage ?? false;
    var assignedMeetingId = request.TriageMeetingId;
    var assignedMeeting = triageMeetings.FirstOrDefault(m => m.Id == assignedMeetingId);

    string GetStatusBadgeClass(string status) => status switch
    {
        "Draft" => "badge badge-secondary",
        "Submitted" => "badge badge-info",
        "Explore" => "badge badge-info",
        "Prioritisation" => "badge badge-primary",
        "Triage" => "badge badge-warning",
        "Delivery" => "badge badge-success",
        "Run" => "badge badge-success",
        "Deferred" => "badge badge-secondary",
        "Rejected" => "badge badge-danger",
        _ => "badge badge-light"
    };

    string GetSectionStatusLabel(string status) => status switch
    {
        "Completed" => "Completed",
        "InProgress" => "In progress",
        _ => "To do"
    };

    string GetSectionStatusBadgeClass(string status) => status switch
    {
        "Completed" => "badge badge-success",
        "InProgress" => "badge badge-warning",
        _ => "badge badge-secondary"
    };

    string FormatPersonName(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return string.Empty;
        }

        var parts = name.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 2)
        {
            return $"{parts[1]} {parts[0]}".Trim();
        }

        return name.Trim();
    }

    var activeSection = Model.ActiveSectionKey;
    var isAssessmentSection = assessmentSections.Any(s => s.Key == activeSection);
    var sectionCompletion = sectionCompletions.GetValueOrDefault(activeSection);
    var sectionStatusValue = sectionCompletion?.CompletionStatus ?? "ToDo";
    var sectionDisplayName = requestSections.Concat(assessmentSections)
        .FirstOrDefault(s => s.Key == activeSection)?.Name ?? activeSection;
    var editUrl = !isAssessmentSection ? Url.Action("Edit", new { id = request.Id }) + $"#{activeSection.ToLowerInvariant()}" : null;
    var currentView = Model.IsDocumentView ? "document" : "details";

    ViewBag.DemandStageName = Model.CurrentStageName;
    ViewBag.DemandStageSummary = Model.CurrentStageSummary;

    var applicantDisplayName = FormatPersonName(request.ApplicantName);
    var hasApplicantName = !string.IsNullOrWhiteSpace(applicantDisplayName);
    if (!hasApplicantName)
    {
        applicantDisplayName = "Not provided";
    }
    var applicantHasEmail = !string.IsNullOrWhiteSpace(request.ApplicantEmail) && hasApplicantName;

    var assignedDisplayName = FormatPersonName(request.AssignedToName);
    var hasAssignedName = !string.IsNullOrWhiteSpace(assignedDisplayName);
    var assignedHasEmail = !string.IsNullOrWhiteSpace(request.AssignedToEmail);
    var hasAssignment = hasAssignedName || assignedHasEmail;

    var latestActivity = Model.Activity?.FirstOrDefault();
    var rawLastUpdatedActor = latestActivity?.Actor
        ?? request.ReviewedBy
        ?? request.AssignedToName
        ?? request.AssignedToEmail;
    var formattedLastUpdatedActor = FormatPersonName(rawLastUpdatedActor);
    var hasLastUpdatedActor = !string.IsNullOrWhiteSpace(formattedLastUpdatedActor);
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-3 align-items-center">
            <div class="col-sm-12">
                <ol class="breadcrumb mb-2 mb-sm-1">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Requests">Demand requests</a></li>
                    <li class="breadcrumb-item active">@request.ReferenceNumber</li>
                </ol>
                <h1 class="m-0">Demand request</h1>
                <p class="text-muted mb-0">
                    Reference @request.ReferenceNumber
                    @if (!string.IsNullOrWhiteSpace(request.BusinessArea))
                    {
                        <text>&middot; @request.BusinessArea</text>
                    }
                </p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] is string success)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                @success
            </div>
        }
        @if (TempData["ErrorMessage"] is string error)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                @error
            </div>
        }

        <div class="row">
            <div class="col-xl-3 col-lg-4 order-2 order-lg-1">
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h3 class="card-title mb-0">Request summary</h3>
                    </div>
                    <div class="card-body">
                        <dl class="definition-list">
                            <div class="definition-item">
                                <dt>Title</dt>
                                <dd>@(string.IsNullOrWhiteSpace(request.ProposedTitle) ? "Untitled" : request.ProposedTitle)</dd>
                            </div>
                            <div class="definition-item">
                                <dt>Business area</dt>
                                <dd>@(string.IsNullOrWhiteSpace(request.BusinessArea) ? "Not specified" : request.BusinessArea)</dd>
                            </div>
                            <div class="definition-item">
                                <dt>Status</dt>
                                <dd>
                                    <span class="badge badge-pill @GetStatusBadgeClass(request.Status)">@request.Status</span>
                                </dd>
                            </div>
                            <div class="definition-item">
                                <dt>Assigned to</dt>
                                <dd>
                                    @if (hasAssignment)
                                    {
                                        <div>
                                            @if (assignedHasEmail)
                                            {
                                                var displayName = hasAssignedName ? assignedDisplayName : request.AssignedToEmail;
                                                <a href="mailto:@request.AssignedToEmail" class="font-weight-semibold">@displayName</a>
                                                @if (hasAssignedName && !string.Equals(displayName, request.AssignedToEmail, StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <div class="text-muted small">@request.AssignedToEmail</div>
                                                }
                                            }
                                            else
                                            {
                                                <span class="font-weight-semibold">@assignedDisplayName</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not assigned</span>
                                    }
                                    <div class="mt-2">
                                        <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#assignRequestModal">
                                            @(hasAssignment ? "Change" : "Assign")
                                        </button>
                                    </div>
                                </dd>
                            </div>
                            <div class="definition-item">
                                <dt>Requestor</dt>
                                <dd>
                                    @if (applicantHasEmail)
                                    {
                                        <a href="mailto:@request.ApplicantEmail" class="font-weight-semibold">@applicantDisplayName</a>
                                    }
                                    else
                                    {
                                        <span class="font-weight-semibold">@applicantDisplayName</span>
                                    }
                                </dd>
                            </div>
                            <div class="definition-item">
                                <dt>Submitted</dt>
                                <dd>
                                    @(request.SubmittedAt.HasValue
                                        ? request.SubmittedAt.Value.ToString("dd MMM yyyy HH:mm")
                                        : "Not submitted")
                                </dd>
                            </div>
                            <div class="definition-item">
                                <dt>Last updated</dt>
                                <dd>
                                    <div class="definition-value">@request.UpdatedAt.ToString("dd MMM yyyy HH:mm")</div>
                                    @if (hasLastUpdatedActor)
                                    {
                                        <div class="text-muted small">by @formattedLastUpdatedActor</div>
                                    }
                                </dd>
                            </div>
                        </dl>
                    </div>
                </div>
                <!-- Removed stage badge summary -->

            </div>

            <div class="col-xl-9 col-lg-8 order-1 order-lg-2">
                @if (Model.IsDocumentView)
                {
                    @await Html.PartialAsync("_DocumentView", request)
                }
                else
                {
                    var completionPercent = Model.TotalTaskCount == 0
                        ? 0
                        : Math.Round((double)Model.CompletedTaskCount / Model.TotalTaskCount * 100);

                    var requestTaskGroup = tasksByGroup.FirstOrDefault(g => string.Equals(g.Key, "Request", StringComparison.OrdinalIgnoreCase));
                    var assessmentTaskGroup = tasksByGroup.FirstOrDefault(g => string.Equals(g.Key, "Assessment", StringComparison.OrdinalIgnoreCase));
                    var additionalTaskGroups = tasksByGroup
                        .Where(g => !string.Equals(g.Key, "Request", StringComparison.OrdinalIgnoreCase)
                            && !string.Equals(g.Key, "Assessment", StringComparison.OrdinalIgnoreCase))
                        .ToList();
                    var workflowTriageStatus = assignedMeeting != null
                        ? $"Assigned to triage meeting on {assignedMeeting.StartAt:dd MMM yyyy HH:mm}"
                        : "Not assigned to triage meeting";

                    <div class="card mb-4 workflow-task-card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h3 class="card-title mb-0">Workflow progress</h3>
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <span class="text-muted small d-block">Current stage</span>
                                    <span class="font-weight-semibold d-block">@Model.CurrentStageName</span>
                                    @if (!string.IsNullOrWhiteSpace(Model.CurrentStageSummary))
                                    {
                                        <span class="text-muted small d-block">@Model.CurrentStageSummary</span>
                                    }
                                </div>
                                <div class="text-right">
                                    <span class="text-muted small d-block">Completed</span>
                                    <span class="font-weight-semibold d-block">@Model.CompletedTaskCount / @Model.TotalTaskCount</span>
                                    <span class="text-muted small">@completionPercent% complete</span>
                                </div>
                            </div>
                            <div class="d-flex align-items-center mt-3 workflow-triage-status">
                                <i class="fas fa-users mr-2 text-muted" aria-hidden="true"></i>
                                <span class="text-muted small">@workflowTriageStatus</span>
                            </div>
                            <div class="progress progress-sm mt-3">
                                <div class="progress-bar" role="progressbar" style="width: @completionPercent%"></div>
                            </div>
                        </div>
                    </div>

                    @if (requestTaskGroup != null && requestTaskGroup.Any())
                    {
                        <div class="card mb-4">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h3 class="card-title mb-0">Request tasks</h3>
                            </div>
                            <div class="card-body p-0">
                                <div class="list-group list-group-flush demand-task-list">
                                    @foreach (var task in requestTaskGroup.OrderBy(t => t.Title))
                                    {
                                        var url = Url.Action("Section", new { id = request.Id, s = task.Key });
                                        <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                           href="@url"
                                           data-section="@task.Key">
                                            <div class="task-label">
                                                <span class="font-weight-semibold d-block">@task.Title</span>
                                                <span class="text-muted small d-none d-md-inline">View section</span>
                                            </div>
                                            <span class="badge badge-pill @GetSectionStatusBadgeClass(task.Status) demand-task-badge">@GetSectionStatusLabel(task.Status)</span>
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    @if (assessmentTaskGroup != null && assessmentTaskGroup.Any())
                    {
                        <div class="card mb-4">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h3 class="card-title mb-0">Assessment tasks</h3>
                            </div>
                            <div class="card-body p-0">
                                <div class="list-group list-group-flush demand-task-list">
                                    @foreach (var task in assessmentTaskGroup.OrderBy(t => t.Title))
                                    {
                                        var url = Url.Action("Section", new { id = request.Id, s = task.Key });
                                        <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                           href="@url"
                                           data-section="@task.Key">
                                            <div class="task-label">
                                                <span class="font-weight-semibold d-block">@task.Title</span>
                                                <span class="text-muted small d-none d-md-inline">View section</span>
                                            </div>
                                            <span class="badge badge-pill @GetSectionStatusBadgeClass(task.Status) demand-task-badge">@GetSectionStatusLabel(task.Status)</span>
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <div class="card mb-4">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h3 class="card-title mb-0">Triage</h3>
                        </div>
                        <div class="card-body">
                            @if (isSubmittedForTriage)
                            {
                                <p class="mb-3 text-muted">
                                    Submitted to triage @if (request.TriageSubmittedAt.HasValue)
                                    {
                                        <text>@request.TriageSubmittedAt.Value.ToString("dd MMM yyyy HH:mm")</text>
                                    }
                                    else
                                    {
                                        <text>recently</text>
                                    }
                                    @if (assignedMeeting != null)
                                    {
                                        <text> for the meeting on @assignedMeeting.StartAt.ToString("dd MMM yyyy HH:mm").</text>
                                    }
                                </p>
                            }
                            else
                            {
                                <p class="mb-3 text-muted">Select a triage meeting and put this request forward for discussion.</p>
                            }

                            @if (triageMeetings.Any())
                            {
                                <form asp-action="SubmitToTriage" method="post" class="mb-3">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@request.Id" />
                                    <input type="hidden" name="returnSection" value="@Model.ActiveSectionKey" />
                                    <input type="hidden" name="returnView" value="details" />

                                    <div class="form-group">
                                        <label for="triageMeetingId" class="font-weight-semibold">Triage meeting</label>
                                        <select id="triageMeetingId" name="triageMeetingId" class="form-control" required>
                                            <option value="">Select a meeting</option>
                                            @foreach (var meeting in triageMeetings)
                                            {
                                                var displayText = $"{meeting.StartAt:dd MMM yyyy HH:mm} ({(meeting.IsActive ? "Active" : "Inactive")})";
                                                if (assignedMeetingId == meeting.Id)
                                                {
                                                    <option value="@meeting.Id" selected>@displayText</option>
                                                }
                                                else
                                                {
                                                    <option value="@meeting.Id">@displayText</option>
                                                }
                                            }
                                        </select>
                                        <small class="form-text text-muted">Meeting times use UK local time.</small>
                                    </div>

                                    <div class="form-group">
                                        <label for="triageNotes" class="font-weight-semibold">Notes for the triage pack</label>
                                        <textarea id="triageNotes" name="triageNotes" class="form-control" rows="3" maxlength="1000">@request.TriageNotes</textarea>
                                    </div>

                                    <button type="submit" class="btn btn-primary">
                                        @(isSubmittedForTriage ? "Update triage details" : "Put forward for triage")
                                    </button>
                                </form>
                            }
                            else
                            {
                                <div class="alert alert-info" role="alert">
                                    No triage meetings are scheduled. Add meeting dates in the admin section.
                                </div>
                            }

                            @if (isSubmittedForTriage)
                            {
                                <form asp-action="RemoveFromTriage" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@request.Id" />
                                    <input type="hidden" name="returnSection" value="@Model.ActiveSectionKey" />
                                    <input type="hidden" name="returnView" value="details" />
                                    <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Remove this request from the triage meeting?');">
                                        Remove from triage
                                    </button>
                                </form>
                            }

                            <hr />

                            @if (request.ConvertedProjectId.HasValue)
                            {
                                <p class="mb-0">
                                    Converted to delivery project <a asp-controller="Project" asp-action="Details" asp-route-id="@request.ConvertedProjectId">view project</a> on @request.ConvertedToProjectAt?.ToString("dd MMM yyyy HH:mm").
                                </p>
                            }
                            else
                            {
                                <form asp-action="ConvertToProject" method="post" class="mt-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@request.Id" />
                                    <button type="submit" class="btn btn-success" onclick="return confirm('Create a delivery project from this request?');">
                                        Create delivery project
                                    </button>
                                </form>
                            }
                        </div>
                    </div>

                    @foreach (var group in additionalTaskGroups)
                    {
                        if (!group.Any())
                        {
                            continue;
                        }

                        var heading = $"{group.Key} tasks";
                        <div class="card mb-4">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h3 class="card-title mb-0">@heading</h3>
                            </div>
                            <div class="card-body p-0">
                                <div class="list-group list-group-flush demand-task-list">
                                    @foreach (var task in group.OrderBy(t => t.Title))
                                    {
                                        var url = Url.Action("Section", new { id = request.Id, s = task.Key });
                                        <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                           href="@url"
                                           data-section="@task.Key">
                                            <div class="task-label">
                                                <span class="font-weight-semibold d-block">@task.Title</span>
                                                <span class="text-muted small d-none d-md-inline">View section</span>
                                            </div>
                                            <span class="badge badge-pill @GetSectionStatusBadgeClass(task.Status) demand-task-badge">@GetSectionStatusLabel(task.Status)</span>
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    @*
                    Removed Overview section rendering; sections are handled via dedicated views.
                    *@
                }

                @*
                Activity card removed per workflow redesign.
                *@
            </div>
        </div>
    </div>
</section>

<!-- Assign Request Modal -->
<div class="modal fade" id="assignRequestModal" tabindex="-1" role="dialog" aria-labelledby="assignRequestModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="assignRequestModalLabel">Assign request</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateAssignment" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@request.Id" />
                <input type="hidden" name="currentSection" value="@activeSection" />
                <input type="hidden" name="currentView" value="@currentView" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="assignmentName">Name <span class="text-muted small">(optional)</span></label>
                        <input type="text" class="form-control" id="assignmentName" name="assignedToName" value="@request.AssignedToName" autocomplete="off" />
                    </div>
                    <div class="form-group">
                        <label for="assignmentEmail">Email</label>
                        <input type="email" class="form-control" id="assignmentEmail" name="assignedToEmail" value="@request.AssignedToEmail" placeholder="name@example.com" autocomplete="off" />
                        <small class="form-text text-muted">We'll notify them when this request changes.</small>
                    </div>
                </div>
                <div class="modal-footer d-flex justify-content-between align-items-center">
                    <button type="submit" class="btn btn-link text-danger" name="clearAssignment" value="true" @(hasAssignment ? string.Empty : "disabled")>Clear assignment</button>
                    <div>
                        <button type="button" class="btn btn-secondary mr-2" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save assignment</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Update Status Modal -->
<div class="modal fade" id="updateStatusModal" tabindex="-1" role="dialog" aria-labelledby="updateStatusModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="updateStatusModalLabel">Update status</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateStatus" method="post" id="updateStatusForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@request.Id" />
                <input type="hidden" name="currentSection" value="@Model.ActiveSectionKey" />
                <input type="hidden" name="currentView" value="@(Model.IsDocumentView ? "document" : "details")" />
                <div class="modal-body">
                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label for="workflowStatusSelect">New status</label>
                            <select class="form-control" id="workflowStatusSelect" name="status" required>
                                @foreach (var option in new[] { "Draft", "Submitted", "Explore", "Prioritisation", "Triage", "Delivery", "Run", "Deferred", "Rejected" })
                                {
                                    if (string.Equals(option, request.Status, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <option value="@option" selected>@option</option>
                                    }
                                    else
                                    {
                                        <option value="@option">@option</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="form-group col-md-6" id="nextReviewContainer" style="display:@(request.Status == "Deferred" && request.NextReviewDate.HasValue ? "block" : "none")">
                            <label for="workflowNextReview">Next review date</label>
                            <input type="date" class="form-control" id="workflowNextReview" name="nextReviewDate" value="@request.NextReviewDate?.ToString("yyyy-MM-dd")" />
                        </div>
                    </div>
                    <div class="form-group" id="decisionReasonContainer" style="display:none;">
                        <label for="workflowStatusReason">Decision reason</label>
                        <textarea class="form-control" id="workflowStatusReason" name="statusReason" rows="4" placeholder="Explain why this status is being set"></textarea>
                        <small class="form-text text-muted">Reason is required when changing status.</small>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(request.StatusChangeReason))
                    {
                        <div class="alert alert-light border mb-0">
                            <strong>Latest decision reason:</strong>
                            <div class="mt-2">@request.StatusChangeReason</div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update status</button>
                </div>
            </form>
        </div>
    </div>
</div>



<script nonce="@Context.Items["Nonce"]">
    (function () {
        const requestId = '@request.Id';
        const statusSelect = document.getElementById('workflowStatusSelect');
        const statusReasonContainer = document.getElementById('decisionReasonContainer');
        const statusReasonInput = document.getElementById('workflowStatusReason');
        const nextReviewContainer = document.getElementById('nextReviewContainer');
        const nextReviewInput = document.getElementById('workflowNextReview');
        const originalStatus = '@request.Status';
        const antiForgeryTokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
        const antiForgeryToken = antiForgeryTokenElement ? antiForgeryTokenElement.value : '';

        function toggleReasonVisibility() {
            if (!statusSelect) return;
            const newStatus = statusSelect.value;
            const statusChanged = newStatus !== originalStatus;
            if (statusReasonContainer) {
                statusReasonContainer.style.display = statusChanged ? 'block' : 'none';
            }
            if (statusReasonInput) {
                statusReasonInput.required = statusChanged;
            }

            const shouldShowReview = newStatus === 'Deferred';
            if (nextReviewContainer) {
                nextReviewContainer.style.display = shouldShowReview ? 'block' : 'none';
            }
            if (nextReviewInput) {
                nextReviewInput.required = shouldShowReview;
            }
        }

        statusSelect?.addEventListener('change', toggleReasonVisibility);
        toggleReasonVisibility();

        function updateSectionStatus(sectionKey, status, panel) {
            const message = panel?.querySelector('.status-message');
            const badge = document.querySelector(`.section-status-indicator[data-section="${sectionKey}"]`);

            if (!antiForgeryToken) {
                if (message) {
                    message.textContent = 'Unable to update status.';
                }
                return Promise.resolve(false);
            }

            const body = new URLSearchParams({
                demandRequestId: requestId,
                sectionName: sectionKey,
                completionStatus: status,
                __RequestVerificationToken: antiForgeryToken
            });

            return fetch('@Url.Action("UpdateSection", "DemandManagement")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': antiForgeryToken
                },
                body: body.toString()
            })
                .then(response => response.ok ? response.json() : { success: false })
                .then(result => {
                    if (result?.success) {
                        if (badge) {
                            badge.textContent = status === 'Completed' ? 'Completed' : status === 'InProgress' ? 'In progress' : 'To do';
                            badge.className = `section-status-indicator ${status === 'Completed' ? 'badge badge-success' : status === 'InProgress' ? 'badge badge-warning' : 'badge badge-secondary'}`;
                        }
                        if (message) {
                            message.textContent = 'Status updated.';
                            setTimeout(() => message.textContent = '', 2500);
                        }
                        return true;
                    }
                    if (message) {
                        message.textContent = 'Unable to update status.';
                    }
                    return false;
                })
                .catch(() => {
                    if (message) {
                        message.textContent = 'Unable to update status.';
                    }
                    return false;
                });
        }

        function initializeSectionInteractions(root) {
            const sectionSelects = root.querySelectorAll('.section-status-select');
            sectionSelects.forEach(select => {
                select.addEventListener('change', function () {
                    updateSectionStatus(this.dataset.section, this.value, this.closest('.section-status-panel'));
                });
            });

            const completeButtons = root.querySelectorAll('.mark-section-complete');
            completeButtons.forEach(button => {
                button.addEventListener('click', function () {
                    const sectionKey = this.dataset.section;
                    const panel = this.closest('.section-status-panel');
                    const select = root.querySelector(`.section-status-select[data-section="${sectionKey}"]`) || document.querySelector(`.section-status-select[data-section="${sectionKey}"]`);
                    updateSectionStatus(sectionKey, 'Completed', panel).then(success => {
                        if (success && select) {
                            select.value = 'Completed';
                        }
                    });
                });
            });
        }

        initializeSectionInteractions(document);
    })();
</script>

<style>
    .workflow-triage-status {
        background-color: #f8fafc;
        border: 1px solid #dce3f2;
        border-radius: 0.5rem;
        padding: 0.5rem 0.75rem;
        color: #475467;
    }

    .workflow-triage-status .fas {
        color: #5d72a4;
    }
</style>

