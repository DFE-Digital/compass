}



<section class="content">
    <div class="container-fluid">
        @await Html.PartialAsync("_DemandManagementNavigation")

        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                @successMessage
            </div>
        }
        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <button type="button" class="close" data-dismiss="alert" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                @errorMessage
            </div>
        }

        @{
            var meetingDate = selectedMeeting?.StartAt;
            var meetingTime = selectedMeeting?.StartAt;
            var chairName = selectedMeeting?.ChairName ?? "Not specified";
            var meetingMonthYear = selectedMeeting != null ? selectedMeeting.StartAt.ToString("MMMM yyyy", UkCulture) : "No meeting selected";
            var meetingItemsCount = selectedMeeting?.TotalRequests ?? 0;
            var priorityItemsCount = (selectedMeeting?.TierOneCount ?? 0) + (selectedMeeting?.TierTwoCount ?? 0) + (selectedMeeting?.TierThreeCount ?? 0);
        }

        <!-- Summary Cards -->
        @if (selectedMeeting != null)
        {
            <div class="row mb-4">
                <!-- Card 1: Date, Time, and Chair -->
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card border-left-primary shadow h-100">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Triage Meeting</div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">@FormatDate(meetingDate)</div>
                                    <div class="text-muted mb-2">@(meetingTime?.ToString("HH:mm", UkCulture) ?? "Time not set")</div>
                                    <div class="text-muted">
                                        <strong>Chair:</strong> @chairName
                                    </div>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-calendar-check fa-2x text-gray-300"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card 2: Month/Year and Items Count -->
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card border-left-success shadow h-100">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Meeting Period</div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">@meetingMonthYear</div>
                                    <small class="text-muted">@meetingItemsCount item@(meetingItemsCount != 1 ? "s" : "") in this meeting</small>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-list fa-2x text-gray-300"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Card 3: Priority Items -->
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card border-left-info shadow h-100">
                        <div class="card-body">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Priority Items</div>
                                    <div class="h5 mb-0 font-weight-bold text-gray-800">@priorityItemsCount</div>
                                    <small class="text-muted">P1, P2, P3 items</small>
                                </div>
                                <div class="col-auto">
                                    <i class="fas fa-exclamation-triangle fa-2x text-gray-300"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="row">
            <!-- Left Column: Meeting Navigation -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title">Triage meetings</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            @if (meetings.Any())
                            {
                                @foreach (var meeting in meetings)
                                {
                                    var isActive = selectedMeetingId.HasValue && meeting.Id == selectedMeetingId.Value;
                                    var navMeetingDate = FormatDate(meeting.StartAt);
                                    <a href="@Url.Action("Triage", new { meetingId = meeting.Id, month = Model.SelectedMonthKey })"
                                       class="list-group-item list-group-item-action @(isActive ? "active" : string.Empty)">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <div class="flex-grow-1">
                                                <div class="font-weight-semibold">@navMeetingDate</div>
                                            </div>
                                            @if (meeting.TotalRequests > 0)
                                            {
                                                <span class="badge badge-light">@meeting.TotalRequests</span>
                                            }
                                        </div>
                                    </a>
                                }
                            }
                            else
                            {
                                <div class="list-group-item">
                                    <div class="text-muted small text-center py-3">No meetings scheduled</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Main Content -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
        @if (!hasMeetings)
        {
            <div class="card mb-4">
                <div class="card-body text-center py-5">
                    <h3 class="mb-3">No triage meetings scheduled</h3>
                    <p class="text-muted mb-0">Add meeting dates in the admin section to begin scheduling requests for review.</p>
                </div>
            </div>
        }

        <div class="row">
            <div class="col-12">
                @if (selectedMeeting != null)
                {
                   
                    <div class="card mb-4">
                        <div class="card-header">
                            <h3 class="card-title mb-0">Requests in this meeting</h3>
                        </div>
                        <div class="card-body p-0">
                            @if (meetingRequests.Any())
                            {
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead>
                                            <tr>
                                                <th style="width: 40%;">Title</th>
                                                <th style="width: 20%;">Requestor</th>
                                                <th style="width: 20%;">Prioritisation outcome</th>
                                                <th style="width: 20%;">Submitted date</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var request in meetingRequests)
                                            {
                                                var requestorName = FormatPersonName(request.ApplicantName);
                                                var hasRequestorEmail = !string.IsNullOrWhiteSpace(request.ApplicantEmail) && !string.IsNullOrWhiteSpace(requestorName);
                                                var priorityTier = request.Prioritisation?.PriorityTier;
                                                var priorityBadgeClass = GetPriorityBadgeClass(priorityTier);
                                                var priorityShort = GetPriorityShortLabel(priorityTier);
                                                var totalScore = request.Prioritisation?.TotalPriorityScore;
                                                var submittedDate = request.TriageSubmittedAt ?? request.SubmittedAt;
                                                
                                                <tr>
                                                    <td>
                                                        <a href="@Url.Action("TriageRequest", new { id = request.Id, meetingId = Model.SelectedMeetingId })" class="font-weight-semibold" style="color: #005ea5; text-decoration: none;">
                                                            @request.ProposedTitle
                                                        </a>
                                                        <br />
                                                        <small class="text-muted">@request.ReferenceNumber</small>
                                                    </td>
                                                    <td>
                                                        @if (hasRequestorEmail)
                                                        {
                                                            <a href="mailto:@request.ApplicantEmail" style="color: #005ea5; text-decoration: none;">@requestorName</a>
                                                        }
                                                        else if (!string.IsNullOrWhiteSpace(requestorName))
                                                        {
                                                            @requestorName
                                                        }
                                                        else if (!string.IsNullOrWhiteSpace(request.ApplicantEmail))
                                                        {
                                                            <a href="mailto:@request.ApplicantEmail" style="color: #005ea5; text-decoration: none;">@request.ApplicantEmail</a>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">Not set</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (!string.IsNullOrWhiteSpace(priorityShort))
                                                        {
                                                            <span class="@priorityBadgeClass">@priorityShort</span>
                                                            @if (totalScore.HasValue)
                                                            {
                                                                <br />
                                                                <small class="text-muted">Score: @totalScore</small>
                                                            }
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">Not prioritised</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @FormatDate(submittedDate)
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="p-3">
                                    <p class="text-muted mb-0">No requests have been scheduled for this meeting yet.</p>
                                </div>
                            }
                        </div>
                    </div>
                }
                else if (hasMeetings)
                {
                    <div class="card mb-4">
                        <div class="card-body text-center py-5">
                            <h3 class="mb-3">Select a meeting</h3>
                            <p class="text-muted mb-0">Choose a meeting from the table above to review the requests, assessments, and scoring prepared for triage.</p>
                        </div>
                    </div>
                }
            </div>
        </div>
            </div>
        </div>
    </div>
</section>

