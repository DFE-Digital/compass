@model Compass.ViewModels.DemandManagement.TriageViewModel
@using System
@using System.Collections.Generic
@using System.Globalization
@using System.Linq
@using Compass.Models
@using Compass.ViewModels.DemandManagement

@functions {
    private static readonly CultureInfo UkCulture = CultureInfo.GetCultureInfo("en-GB");

    private static string FormatPersonName(string? name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return string.Empty;
        }

        var parts = name.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 2)
        {
            return $"{parts[1]} {parts[0]}".Trim();
        }

        return name.Trim();
    }

    private static string FormatBoolean(bool? value) => value.HasValue ? (value.Value ? "Yes" : "No") : "Not answered";

    private static string FormatCurrency(decimal? value) => value.HasValue ? value.Value.ToString("C0", UkCulture) : "Not specified";

    private static string FormatNumber(int? value) => value.HasValue ? value.Value.ToString(UkCulture) : "Not specified";

    private static string FormatNullableString(string? value, string fallback = "Not specified") => string.IsNullOrWhiteSpace(value) ? fallback : value!;

    private static string FormatDate(DateTime? value) => value.HasValue ? value.Value.ToString("dd MMM yyyy", UkCulture) : "Not set";

    private static string FormatDateTime(DateTime? value) => value.HasValue ? value.Value.ToString("dd MMM yyyy HH:mm", UkCulture) : "Not recorded";

    private static IReadOnlyList<string> SplitCommaSeparated(string? value) => string.IsNullOrWhiteSpace(value)
        ? Array.Empty<string>()
        : value.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
               .Select(item => item.Trim())
               .Where(item => !string.IsNullOrWhiteSpace(item))
               .ToArray();

    private static string GetAssessmentContent(IEnumerable<DemandRequestAssessment>? assessments, string type)
    {
        if (assessments == null)
        {
            return "Not recorded";
        }

        var match = assessments.FirstOrDefault(a => string.Equals(a.AssessmentType, type, StringComparison.OrdinalIgnoreCase));
        return string.IsNullOrWhiteSpace(match?.AssessmentContent) ? "Not recorded" : match!.AssessmentContent!;
    }

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "Draft" => "badge badge-secondary",
        "Submitted" => "badge badge-info",
        "Explore" => "badge badge-info",
        "Prioritisation" => "badge badge-primary",
        "Triage" => "badge badge-warning",
        "Delivery" => "badge badge-success",
        "Run" => "badge badge-success",
        "Deferred" => "badge badge-secondary",
        "Rejected" => "badge badge-danger",
        _ => "badge badge-light"
    };

    private static string GetPriorityBadgeClass(string? tier) => tier switch
    {
        "Tier 1 – Critical" => "badge badge-danger",
        "Tier 2 – High" => "badge badge-warning",
        "Tier 3 – Medium" => "badge badge-info",
        "Tier 4 – Low" => "badge badge-secondary",
        _ => "badge badge-light"
    };

    private static string GetPriorityShortLabel(string? tier) => string.IsNullOrWhiteSpace(tier)
        ? "Unprioritised"
        : tier.Split('–')[0].Trim();

    private static string GetMeetingStateLabel(TriageMeetingSummaryViewModel meeting) => meeting.IsUpcoming ? "Upcoming" : "Completed";

    private sealed class PriorityFactor
    {
        public string Label { get; init; } = string.Empty;
        public int Score { get; init; }
    }

    private sealed class PriorityCategory
    {
        public string Label { get; init; } = string.Empty;
        public int Total { get; init; }
        public IReadOnlyList<PriorityFactor> Factors { get; init; } = Array.Empty<PriorityFactor>();
    }

    private static string FormatYesNo(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "Not answered";
        }

        if (value.Equals("Yes", StringComparison.OrdinalIgnoreCase))
        {
            return "Yes";
        }

        if (value.Equals("No", StringComparison.OrdinalIgnoreCase))
        {
            return "No";
        }

        if (value.Equals("Unsure", StringComparison.OrdinalIgnoreCase))
        {
            return "Unsure";
        }

        return value;
    }

    private static string DescribeWeightedScore(int score)
    {
        if (score >= 16)
        {
            return "High";
        }

        if (score >= 9)
        {
            return "Medium";
        }

        if (score > 0)
        {
            return "Low";
        }

        return "Not scored";
    }

    private static string Summarize(string? value, int maxLength = 140)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "Not recorded";
        }

        var sanitized = value.Replace("\r", " ").Replace("\n", " ").Trim();
        if (sanitized.Length <= maxLength)
        {
            return sanitized;
        }

        return sanitized.Substring(0, maxLength).TrimEnd() + "...";
    }

    private static IReadOnlyList<PriorityCategory> BuildPriorityCategories(DemandRequestPrioritisation? prioritisation)
    {
        if (prioritisation == null)
        {
            return Array.Empty<PriorityCategory>();
        }

        return new[]
        {
            new PriorityCategory
            {
                Label = "Strategic alignment",
                Total = prioritisation.StrategicAlignmentTotal,
                Factors = new[]
                {
                    new PriorityFactor { Label = "Statutory or manifesto commitment", Score = prioritisation.StatutoryManifestoScore },
                    new PriorityFactor { Label = "Mission pillar support", Score = prioritisation.OpportunityMissionScore },
                    new PriorityFactor { Label = "Strategic framework theme", Score = prioritisation.DdatStrategicThemeScore }
                }
            },
            new PriorityCategory
            {
                Label = "User impact",
                Total = prioritisation.UserImpactTotal,
                Factors = new[]
                {
                    new PriorityFactor { Label = "Scale of users", Score = prioritisation.ScaleOfUsersScore },
                    new PriorityFactor { Label = "Evidence of user need", Score = prioritisation.EvidenceOfUserNeedScore }
                }
            },
            new PriorityCategory
            {
                Label = "Risk and urgency",
                Total = prioritisation.RiskUrgencyTotal,
                Factors = new[]
                {
                    new PriorityFactor { Label = "Risk if not delivered", Score = prioritisation.RiskIfNotDeliveredScore },
                    new PriorityFactor { Label = "Delivery urgency", Score = prioritisation.TargetDeliveryUrgencyScore }
                }
            },
            new PriorityCategory
            {
                Label = "Feasibility",
                Total = prioritisation.FeasibilityTotal,
                Factors = new[]
                {
                    new PriorityFactor { Label = "Funding available", Score = prioritisation.FundingAvailableScore },
                    new PriorityFactor { Label = "Headcount available", Score = prioritisation.HeadcountAvailableScore },
                    new PriorityFactor { Label = "Portfolio fit", Score = prioritisation.PortfolioFitScore }
                }
            },
            new PriorityCategory
            {
                Label = "Value and outcome",
                Total = prioritisation.ValueOutcomeTotal,
                Factors = new[]
                {
                    new PriorityFactor { Label = "Expected benefits", Score = prioritisation.ExpectedBenefitsScore }
                }
            }
        };
    }

    private static string FormatLevel(int? score)
    {
        if (!score.HasValue || score.Value <= 0)
        {
            return "Not scored";
        }

        return score.Value switch
        {
            >= 4 => "High",
            3 => "Medium",
            _ => "Low"
        };
    }

    private static string Summarise(string? value, int maxLength = 160)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "Not recorded";
        }

        var trimmed = value.Trim();
        if (trimmed.Length <= maxLength)
        {
            return trimmed;
        }

        var shortened = trimmed.Substring(0, Math.Min(trimmed.Length, maxLength)).TrimEnd();
        return shortened.EndsWith("...", StringComparison.Ordinal) ? shortened : shortened + "...";
    }
}

@{
    ViewData["Title"] = "Triage";
    var meetings = Model.Meetings ?? Array.Empty<TriageMeetingSummaryViewModel>();
    var months = Model.Months?.OrderBy(m => m.Month).ToList() ?? new List<TriageMonthSummaryViewModel>();
    var selectedMeetingId = Model.SelectedMeetingId;
    var selectedMeeting = Model.SelectedMeeting;
    var meetingRequests = Model.MeetingRequests ?? Array.Empty<DemandRequest>();
    var awaitingRequests = Model.AwaitingScheduling?.OrderByDescending(r => r.TriageSubmittedAt ?? r.UpdatedAt).ToList() ?? new List<DemandRequest>();
    var hasMeetings = meetings.Any();
    var awaitingCount = awaitingRequests.Count;
    var selectedMonth = months.FirstOrDefault(m => string.Equals(m.Key, Model.SelectedMonthKey, StringComparison.OrdinalIgnoreCase));
    var selectedMonthIndex = selectedMonth != null ? months.IndexOf(selectedMonth) : -1;
    var previousMonth = selectedMonthIndex > 0 ? months[selectedMonthIndex - 1] : null;
    var nextMonth = selectedMonthIndex >= 0 && selectedMonthIndex < months.Count - 1 ? months[selectedMonthIndex + 1] : null;
    var assessmentDefinitions = new[]
    {
        new { Key = "ResearchAndEvidence", Label = "Research and evidence" },
        new { Key = "NeedsAssessment", Label = "Needs assessment" },
        new { Key = "Recommendations", Label = "Recommendations" },
        new { Key = "PrioritisationAssessment", Label = "Prioritisation assessment" },
        new { Key = "Outcome", Label = "Outcome" }
    };
}

