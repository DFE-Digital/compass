</style>

@section Scripts {
    @if (ViewBag.IsCentralOpsAdmin == true)
    {
        <script src="~/js/user-picker.js" asp-append-version="true"></script>
    }
}

<script nonce="@Context.Items["Nonce"]">
    (function () {
        const meetingSelect = document.getElementById('triageMeetingSelect');
        if (!meetingSelect) {
            return;
        }

        meetingSelect.addEventListener('change', function () {
            if (!this.value) {
                return;
            }

            const destination = new URL('@Url.Action("Triage", "DemandManagement")', window.location.origin);
            destination.searchParams.set('meetingId', this.value);

            const selectedMonthKey = '@(Model.SelectedMonthKey ?? string.Empty)';
            if (selectedMonthKey) {
                destination.searchParams.set('month', selectedMonthKey);
            }

            window.location.href = destination.toString();
        });
    })();

    function resetMeetingForm() {
        window.location.href = '@Url.Action("Triage", new { month = Model.SelectedMonthKey })';
    }
</script>

