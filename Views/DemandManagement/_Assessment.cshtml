@using Compass.Models
@using System.Collections.Generic
@model dynamic

@{
    var demandRequest = Model.Model as DemandRequest;
    var assessmentType = Model.AssessmentType as string;
    var sectionStatus = Model.SectionStatus as Compass.ViewModels.DemandManagement.SectionStatusPanelViewModel ?? new Compass.ViewModels.DemandManagement.SectionStatusPanelViewModel();
    var assessment = demandRequest?.Assessments?.FirstOrDefault(a => a.AssessmentType == assessmentType);

    var assessmentNames = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        { "ResearchAndEvidence", "Research and evidence" },
        { "NeedsAssessment", "Needs assessment" },
        { "Recommendations", "Recommendations" },
        { "PrioritisationAssessment", "Prioritisation assessment" },
        { "Outcome", "Outcome" }
    };

    var displayName = assessmentNames.TryGetValue(assessmentType ?? string.Empty, out var mapped) ? mapped : assessmentType ?? "Assessment";
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0">@displayName</h3>
    </div>
    <div class="card-body">
        @if (string.Equals(assessmentType, "PrioritisationAssessment", StringComparison.OrdinalIgnoreCase))
        {
            if (demandRequest?.Prioritisation != null)
            {
                var prioritisation = demandRequest.Prioritisation;
                <div class="table-responsive">
                    <table class="table table-sm table-bordered">
                        <thead class="thead-light">
                            <tr>
                                <th>Category</th>
                                <th class="text-center" style="width: 120px;">Weight</th>
                                <th style="width: 280px;">Criteria</th>
                                <th class="text-center" style="width: 140px;">Raw score (1-5)</th>
                                <th class="text-center" style="width: 150px;">Weighted total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var breakdown = new[]
                                {
                                    new
                                    {
                                        Title = "Strategic alignment",
                                        Weight = 2,
                                        Weighted = prioritisation.StrategicAlignmentTotal,
                                        Rows = new[]
                                        {
                                            new { Label = "Statutory / manifesto requirement", Score = prioritisation.StatutoryManifestoScore },
                                            new { Label = "Opportunity mission pillar", Score = prioritisation.OpportunityMissionScore },
                                            new { Label = "DDaT strategic theme", Score = prioritisation.DdatStrategicThemeScore }
                                        }
                                    },
                                    new
                                    {
                                        Title = "User impact",
                                        Weight = 2,
                                        Weighted = prioritisation.UserImpactTotal,
                                        Rows = new[]
                                        {
                                            new { Label = "Scale of users affected", Score = prioritisation.ScaleOfUsersScore },
                                            new { Label = "Evidence of user need", Score = prioritisation.EvidenceOfUserNeedScore }
                                        }
                                    },
                                    new
                                    {
                                        Title = "Risk & urgency",
                                        Weight = 2,
                                        Weighted = prioritisation.RiskUrgencyTotal,
                                        Rows = new[]
                                        {
                                            new { Label = "Risk if not delivered", Score = prioritisation.RiskIfNotDeliveredScore },
                                            new { Label = "Target delivery urgency", Score = prioritisation.TargetDeliveryUrgencyScore }
                                        }
                                    },
                                    new
                                    {
                                        Title = "Feasibility",
                                        Weight = 1,
                                        Weighted = prioritisation.FeasibilityTotal,
                                        Rows = new[]
                                        {
                                            new { Label = "Funding available", Score = prioritisation.FundingAvailableScore },
                                            new { Label = "Headcount available", Score = prioritisation.HeadcountAvailableScore },
                                            new { Label = "Portfolio fit", Score = prioritisation.PortfolioFitScore }
                                        }
                                    },
                                    new
                                    {
                                        Title = "Value & outcome",
                                        Weight = 1,
                                        Weighted = prioritisation.ValueOutcomeTotal,
                                        Rows = new[]
                                        {
                                            new { Label = "Expected benefits", Score = prioritisation.ExpectedBenefitsScore }
                                        }
                                    }
                                }; }

                            @foreach (var category in breakdown)
                            {
                                var rowCount = category.Rows.Length;
                                for (var i = 0; i < rowCount; i++)
                                {
                                    var row = category.Rows[i];
                                    <tr>
                                        @if (i == 0)
                                        {
                                            <td rowspan="@rowCount"><strong>@category.Title</strong></td>
                                            <td class="text-center align-middle" rowspan="@rowCount">×@category.Weight</td>
                                        }
                                        <td>@row.Label</td>
                                        <td class="text-center">@row.Score</td>
                                        @if (i == 0)
                                        {
                                            <td class="text-center align-middle" rowspan="@rowCount">
                                                <strong>@category.Weighted</strong>
                                            </td>
                                        }
                                    </tr>
                                }
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-secondary">
                                <td colspan="4" class="text-right font-weight-bold">Total priority score</td>
                                <td class="text-center">
                                    <strong>@prioritisation.TotalPriorityScore</strong><span class="text-muted"> / 100</span>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="4" class="text-right font-weight-bold">Priority tier</td>
                                <td class="text-center">
                                    <span class="badge badge-info">@prioritisation.PriorityTier</span>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                var lastScored = prioritisation.ScoredAt ?? prioritisation.UpdatedAt;
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mt-3">
                    <div class="text-muted small">
                        Last scored @lastScored.ToString("dd MMM yyyy HH:mm")
                        @if (!string.IsNullOrWhiteSpace(prioritisation.ScoredBy))
                        {
                            <span>by @prioritisation.ScoredBy</span>
                        }
                    </div>
                    <a asp-action="ScoreRequest" asp-route-id="@demandRequest!.Id" class="btn btn-outline-primary btn-sm mt-2 mt-md-0">Update prioritisation score</a>
                </div>
            }
            else
            {
                <p class="text-muted mb-3">This request has not been scored yet.</p>
                <a asp-action="ScoreRequest" asp-route-id="@demandRequest!.Id" class="btn btn-primary btn-sm">Start prioritisation scoring</a>
            }
        }
        else
        {
            <dl class="definition-list">
                <div class="definition-item">
                    <dt>Notes</dt>
                    <dd>
                        <div class="definition-value">@(string.IsNullOrWhiteSpace(assessment?.AssessmentContent) ? "Not provided" : assessment.AssessmentContent)</div>
                        <div class="definition-actions">
                            <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#assessment-modal-@assessmentType">Change</button>
                        </div>
                    </dd>
                </div>
            </dl>
        }
    </div>
</div>

@if (!string.Equals(assessmentType, "PrioritisationAssessment", StringComparison.OrdinalIgnoreCase))
{
    <div class="modal fade" id="assessment-modal-@assessmentType" tabindex="-1" role="dialog" aria-labelledby="assessment-modal-label-@assessmentType" aria-hidden="true">
        <div class="modal-dialog modal-lg" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="assessment-modal-label-@assessmentType">Update @displayName notes</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <form asp-action="UpdateAssessment" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="demandRequestId" value="@demandRequest!.Id" />
                    <input type="hidden" name="assessmentType" value="@assessmentType" />
                    <input type="hidden" name="returnUrl" value="@sectionStatus.ReturnUrl" />
                    <div class="modal-body">
                        <div class="form-group">
                            <label for="assessment-content-@assessmentType">Notes</label>
                            <textarea id="assessment-content-@assessmentType" name="assessmentContent" class="form-control" rows="10" placeholder="Capture findings or recommendations...">@assessment?.AssessmentContent</textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success">Save changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

