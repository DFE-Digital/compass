@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var isCentralOpsAdmin = ViewBag.IsCentralOpsAdmin as bool? ?? false;
    
    var navLinks = new List<object>
    {
        new { Text = "Requests", Action = "Requests", Controller = "DemandManagement", IsActive = currentAction == "Requests" },
        new { Text = "Prioritisation", Action = "Prioritisation", Controller = "DemandManagement", IsActive = currentAction == "Prioritisation" },
        new { Text = "Triage", Action = "Triage", Controller = "DemandManagement", IsActive = currentAction == "Triage" },
        new { Text = "Reporting", Action = "Reporting", Controller = "DemandManagement", IsActive = currentAction == "Reporting" }
    };
    
    if (isCentralOpsAdmin)
            {
        navLinks.Add(new { Text = "Manage meetings", Action = "ManageMeetings", Controller = "DemandManagement", IsActive = currentAction == "ManageMeetings" });
    }
    
    navLinks.Add(new { Text = "Create new request", Action = "CreateRequest", Controller = "DemandManagement", IsButton = true });
    
    ViewBag.BrandText = "Demand Management";
    ViewBag.NavLinks = navLinks;
    }
@await Html.PartialAsync("_ModuleNavbar")

