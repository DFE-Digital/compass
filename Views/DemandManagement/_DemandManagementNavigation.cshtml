@using Compass.Models
@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var isCentralOpsAdmin = ViewBag.IsCentralOpsAdmin as bool? ?? false;
    var currentView = ViewBag.CurrentView as string ?? "mine";
    var assignedToMeCount = ViewBag.AssignedToMeCount as int? ?? 0;
    
    var navLinks = new List<object>
    {
        new { 
            Text = "Overview", 
            Action = "Overview", 
            Controller = "DemandManagement", 
            IsActive = currentAction == "Overview"
        },
        new { 
            Text = "Business cases", 
            Action = "BusinessCases", 
            Controller = "DemandManagement", 
            IsActive = currentAction == "BusinessCases" || currentAction == "BusinessCaseDetails" || currentAction == "CreateBusinessCase" || currentAction == "EditBusinessCase"
        },
        new { 
            Text = "DDT Demand", 
            Action = "Requests", 
            Controller = "DemandManagement", 
            IsActive = currentAction == "Requests" && !string.Equals(currentView, "assigned", StringComparison.OrdinalIgnoreCase)
        }
    };
    
    // Add "Assigned to me" to top navbar if we're in Requests view
    if (currentAction == "Requests")
    {
        navLinks.Add(new 
        { 
            Text = "Assigned to me", 
            Action = "Requests", 
            Controller = "DemandManagement",
            RouteValues = new { view = "assigned" },
            Count = assignedToMeCount,
            IsActive = string.Equals(currentView, "assigned", StringComparison.OrdinalIgnoreCase)
        });
    }
    
    navLinks.Add(new { Text = "Prioritisation", Action = "Prioritisation", Controller = "DemandManagement", IsActive = currentAction == "Prioritisation" });
    navLinks.Add(new { Text = "Triage", Action = "Triage", Controller = "DemandManagement", IsActive = currentAction == "Triage" });
    navLinks.Add(new { Text = "Reporting", Action = "Reporting", Controller = "DemandManagement", IsActive = currentAction == "Reporting" });
    
    if (isCentralOpsAdmin)
    {
        navLinks.Add(new { Text = "Manage meetings", Action = "ManageMeetings", Controller = "DemandManagement", IsActive = currentAction == "ManageMeetings" });
    }
    
    navLinks.Add(new { Text = "Create new request", Action = "CreateRequest", Controller = "DemandManagement", IsButton = true });
    
    ViewBag.BrandText = "Planning and demand";
    ViewBag.NavLinks = navLinks;
}
@await Html.PartialAsync("_ModuleNavbar")

