@model Compass.ViewModels.DemandManagement.DemandSectionDetailViewModel

@functions {
    public static string FormatBoolean(bool? value) => value.HasValue ? (value.Value ? "Yes" : "No") : "Not answered";
}

@{
    var request = Model.Request;
    var status = Model.Status;
    var sectionKey = "FundingAndHeadcount";
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0">Funding and headcount</h3>
    </div>
    <div class="card-body">
        <h4 class="h6 text-uppercase text-muted mb-3">Funding</h4>
        <dl class="definition-list">
            <div class="definition-item">
                <dt>Does this request come with funding?</dt>
                <dd>
                    <div class="definition-value">@FormatBoolean(request.HasFunding)</div>
                    <div class="definition-actions">
                        <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#funding-has-modal">Change</button>
                    </div>
                </dd>
            </div>

            <div class="definition-item">
                <dt>Funding amount</dt>
                <dd>
                    <div class="definition-value">@(request.FundingAmount.HasValue ? $"£{request.FundingAmount.Value:N2}" : "Not specified")</div>
                    <div class="definition-actions">
                        <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#funding-amount-modal">Change</button>
                    </div>
                </dd>
            </div>

            <div class="definition-item">
                <dt>Funding source</dt>
                <dd>
                    <div class="definition-value">@(string.IsNullOrWhiteSpace(request.FundingSource) ? "Not specified" : request.FundingSource)</div>
                    <div class="definition-actions">
                        <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#funding-source-modal">Change</button>
                    </div>
                </dd>
            </div>

            <div class="definition-item">
                <dt>Funding duration</dt>
                <dd>
                    <div class="definition-value">@(string.IsNullOrWhiteSpace(request.FundingDuration) ? "Not specified" : request.FundingDuration)</div>
                    <div class="definition-actions">
                        <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#funding-duration-modal">Change</button>
                    </div>
                </dd>
            </div>

            <div class="definition-item">
                <dt>Funding notes</dt>
                <dd>
                    <div class="definition-value">@(string.IsNullOrWhiteSpace(request.FundingNotes) ? "Not provided" : request.FundingNotes)</div>
                    <div class="definition-actions">
                        <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#funding-notes-modal">Change</button>
                    </div>
                </dd>
            </div>
        </dl>

        <h4 class="h6 text-uppercase text-muted mt-4 mb-3">Headcount</h4>
        <dl class="definition-list">
            <div class="definition-item">
                <dt>Does this request come with headcount?</dt>
                <dd>
                    <div class="definition-value">@FormatBoolean(request.HasHeadcount)</div>
                    <div class="definition-actions">
                        <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#headcount-has-modal">Change</button>
                    </div>
                </dd>
            </div>

            <div class="definition-item">
                <dt>FTE provided</dt>
                <dd>
                    <div class="definition-value">@(request.NumberOfFTE.HasValue ? request.NumberOfFTE.Value.ToString() : "Not specified")</div>
                    <div class="definition-actions">
                        <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#headcount-fte-modal">Change</button>
                    </div>
                </dd>
            </div>

            <div class="definition-item">
                <dt>Roles provided</dt>
                <dd>
                    <div class="definition-value">@(string.IsNullOrWhiteSpace(request.RolesProvided) ? "Not specified" : request.RolesProvided)</div>
                    <div class="definition-actions">
                        <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#headcount-roles-modal">Change</button>
                    </div>
                </dd>
            </div>

            <div class="definition-item">
                <dt>Headcount duration</dt>
                <dd>
                    <div class="definition-value">@(string.IsNullOrWhiteSpace(request.HeadcountDuration) ? "Not specified" : request.HeadcountDuration)</div>
                    <div class="definition-actions">
                        <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#headcount-duration-modal">Change</button>
                    </div>
                </dd>
            </div>

            <div class="definition-item">
                <dt>Headcount notes</dt>
                <dd>
                    <div class="definition-value">@(string.IsNullOrWhiteSpace(request.HeadcountNotes) ? "Not provided" : request.HeadcountNotes)</div>
                    <div class="definition-actions">
                        <button type="button" class="btn btn-link btn-sm p-0" data-toggle="modal" data-target="#headcount-notes-modal">Change</button>
                    </div>
                </dd>
            </div>
        </dl>
    </div>
</div>

<!-- Funding modals -->
<div class="modal fade" id="funding-has-modal" tabindex="-1" role="dialog" aria-labelledby="funding-has-label" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="funding-has-label">Does this request come with funding?</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateSectionField" asp-route-id="@request.Id" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="sectionKey" value="@sectionKey" />
                <input type="hidden" name="fieldKey" value="HasFunding" />
                <input type="hidden" name="returnUrl" value="@status.ReturnUrl" />
                <div class="modal-body">
                    <div class="custom-control custom-radio">
                        <input class="custom-control-input" type="radio" name="boolValue" id="funding-has-yes" value="true" @(request.HasFunding == true ? "checked" : null) />
                        <label class="custom-control-label" for="funding-has-yes">Yes</label>
                    </div>
                    <div class="custom-control custom-radio">
                        <input class="custom-control-input" type="radio" name="boolValue" id="funding-has-no" value="false" @(request.HasFunding == false ? "checked" : null) />
                        <label class="custom-control-label" for="funding-has-no">No</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="funding-amount-modal" tabindex="-1" role="dialog" aria-labelledby="funding-amount-label" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="funding-amount-label">Update funding amount</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateSectionField" asp-route-id="@request.Id" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="sectionKey" value="@sectionKey" />
                <input type="hidden" name="fieldKey" value="FundingAmount" />
                <input type="hidden" name="returnUrl" value="@status.ReturnUrl" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="funding-amount-input">Funding amount</label>
                        <input type="number" step="0.01" min="0" id="funding-amount-input" name="decimalValue" class="form-control" value="@(request.FundingAmount?.ToString() ?? string.Empty)" />
                        <small class="form-text text-muted">Leave blank if not specified.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

