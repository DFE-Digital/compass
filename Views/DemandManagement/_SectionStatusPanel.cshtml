@model Compass.ViewModels.DemandManagement.SectionStatusPanelViewModel

@{
    string statusLabel = Model.Status switch
    {
        "Completed" => "Completed",
        "InProgress" => "In progress",
        _ => "Not started"
    };

    string badgeClass = Model.Status switch
    {
        "Completed" => "badge badge-success",
        "InProgress" => "badge badge-info",
        _ => "badge badge-secondary"
    };

    var lastUpdated = Model.Completion?.UpdatedAt ?? Model.Completion?.CreatedAt;
    var lastUpdatedBy = Model.Completion?.CompletedByName ?? Model.Completion?.CompletedByEmail;
    var missingFields = Model.MissingFields ?? Array.Empty<string>();
    var canComplete = Model.CanMarkComplete && !missingFields.Any();
    var returnUrl = Model.ReturnUrl ?? $"{Context.Request.Path}{Context.Request.QueryString}";
    var completionNotes = Model.Completion?.CompletionNotes ?? string.Empty;
}

<div class="card section-status-panel mt-3" data-section="@(Model.SectionKey)">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0">@Model.SectionName progress</h3>
    </div>
    <div class="card-body">
        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
        }

        <form asp-action="CompleteSection" method="post" class="section-status-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.DemandRequestId" />
            <input type="hidden" name="sectionKey" value="@Model.SectionKey" />
            <input type="hidden" name="returnUrl" value="@returnUrl" />

            <div class="form-group">
                <label for="section-notes-@(Model.SectionKey)">Notes for this section</label>
                <textarea id="section-notes-@(Model.SectionKey)" name="notes" class="form-control" rows="4">@completionNotes</textarea>
                <small class="form-text text-muted">Use notes to capture outstanding actions or evidence for this section.</small>
            </div>

            @if (missingFields.Any())
            {
                <div class="alert alert-warning" role="alert">
                    <strong>To complete this section, add:</strong>
                    <ul class="mb-0">
                        @foreach (var field in missingFields)
                        {
                            <li>@field</li>
                        }
                    </ul>
                </div>
            }

            <div class="d-flex flex-column flex-md-row align-items-stretch align-items-md-center justify-content-md-start">
                <div class="btn-group flex-wrap mr-md-3">
                    <button type="submit" class="btn btn-outline-primary btn-sm mr-2 mb-2" name="submitAction" value="save">Save notes</button>
                    @if (string.Equals(Model.Status, "Completed", StringComparison.OrdinalIgnoreCase))
                    {
                        <button type="submit" class="btn btn-warning btn-sm mr-2 mb-2" name="submitAction" value="reopen">Reopen section</button>
                    }
                    <button type="submit" class="btn btn-success btn-sm mb-2" name="submitAction" value="complete" @(canComplete ? null : "disabled")>Mark section complete</button>
                </div>
                <div class="text-muted small mb-2 mb-md-0">
                    @if (lastUpdated.HasValue)
                    {
                        <span>Last updated @lastUpdated.Value.ToString("dd MMM yyyy HH:mm")</span>
                        @if (!string.IsNullOrWhiteSpace(lastUpdatedBy))
                        {
                            <span> by @lastUpdatedBy</span>
                        }
                    }
                    else
                    {
                        <span>No updates recorded yet.</span>
                    }
                </div>
            </div>
        </form>
    </div>
</div>