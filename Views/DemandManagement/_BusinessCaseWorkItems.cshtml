@model Compass.Models.BusinessCase
@using Compass.Models
@using System.Linq

<div class="card mb-4">
    <div class="card-header">
        <h3 class="card-title">Linked work items</h3>
        <div class="card-tools">
            <a href="#" data-toggle="modal" data-target="#linkProjectModal">Link existing work item</a>
            <a asp-action="CreateProjectFromBusinessCase" asp-route-businessCaseId="@Model.Id">Create new work item</a>
        </div>
    </div>
    <div class="card-body p-0" style="overflow-x: auto; max-width: 100%;">
        @if (Model.BusinessCaseProjects != null && Model.BusinessCaseProjects.Any())
        {
            <div class="table-responsive" style="max-width: 100%;">
                <table class="table table-hover text-nowrap mb-0" style="width: 100%; margin-bottom: 0;">
                    <thead>
                        <tr>
                            <th style="width: 15%; min-width: 120px;">Project code</th>
                            <th style="width: 30%; min-width: 250px;">Title</th>
                            <th style="width: 20%; min-width: 150px;">Business area</th>
                            <th style="width: 15%; min-width: 120px;">Status</th>
                            <th style="width: 20%; min-width: 180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var projectLink in Model.BusinessCaseProjects)
                        {
                            <tr>
                                <td data-label="Project code">
                                    @if (projectLink.Project != null)
                                    {
                                        <span class="text-monospace">@projectLink.Project.ProjectCode</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td data-label="Title">
                                    @if (projectLink.Project != null)
                                    {
                                        <a asp-controller="Project" asp-action="Details" asp-route-id="@projectLink.Project.Id">
                                            @projectLink.Project.Title
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td data-label="Business area">@(projectLink.Project?.BusinessArea ?? "Not set")</td>
                                <td data-label="Status">
                                    @if (projectLink.Project != null && !string.IsNullOrWhiteSpace(projectLink.Project.Status))
                                    {
                                        <span class="badge badge-secondary">@projectLink.Project.Status</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not set</span>
                                    }
                                </td>
                                <td data-label="Actions">
                                    @if (projectLink.Project != null)
                                    {
                                        <a asp-controller="Project" asp-action="Details" asp-route-id="@projectLink.Project.Id" class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                        <button type="button" class="btn btn-sm btn-danger unlink-project-btn" 
                                                data-project-id="@projectLink.Project.Id"
                                                data-project-title="@(projectLink.Project.Title ?? "Unknown")"
                                                data-project-code="@(projectLink.Project.ProjectCode ?? "")"
                                                data-business-case-id="@Model.Id"
                                                data-business-case-project-id="@projectLink.Id">
                                            <i class="fas fa-unlink"></i> Unlink
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info m-3">
                <i class="fas fa-info-circle mr-2"></i>No work items are linked to this business case. You can link an existing work item or create a new one.
            </div>
        }
    </div>
</div>

<!-- Unlink Project Confirmation Modal -->
<div class="modal fade" id="unlinkProjectModal" tabindex="-1" role="dialog" aria-labelledby="unlinkProjectModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="unlinkProjectModalLabel">Confirm unlink work item</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UnlinkProject" method="post" id="unlinkProjectForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="businessCaseId" id="unlinkBusinessCaseId" value="@Model.Id" />
                <input type="hidden" name="businessCaseProjectId" id="unlinkBusinessCaseProjectId" />
                <div class="modal-body">
                    <p>Are you sure you want to unlink the work item <strong id="unlinkProjectTitle"></strong> from this business case?</p>
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle mr-2"></i>
                        <strong>Note:</strong> This will remove the link between the business case and the work item, but the work item itself will not be deleted.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-unlink mr-2"></i>Unlink work item
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Link Project Modal -->
<div class="modal fade" id="linkProjectModal" tabindex="-1" role="dialog" aria-labelledby="linkProjectModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="linkProjectModalLabel">Link existing work item</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="LinkProject" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="businessCaseId" value="@Model.Id" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="projectId">Select work item <span class="text-danger">*</span></label>
                        <select class="form-control" id="projectId" name="projectId" required>
                            <option value="">-- Select a work item --</option>
                        </select>
                        <small class="form-text text-muted">Select an active work item to link to this business case.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Link work item</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
    (function() {
        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        async function loadActiveProjects() {
            const projectIdSelect = document.getElementById('projectId');
            if (!projectIdSelect) {
                console.error('Project select element not found');
                return;
            }

            // Show loading state
            projectIdSelect.innerHTML = '<option value="">Loading active work items...</option>';
            projectIdSelect.disabled = true;

            try {
                // Get business case ID from the hidden input in the modal
                const businessCaseIdInput = document.querySelector('#linkProjectModal input[name="businessCaseId"]');
                const businessCaseId = businessCaseIdInput ? businessCaseIdInput.value : null;
                
                // Build URL with query parameter using Razor URL helper
                let url = '@Url.Action("GetActiveProjects", "DemandManagement")';
                if (businessCaseId) {
                    url += `?businessCaseId=${encodeURIComponent(businessCaseId)}`;
                }
                
                console.log('Fetching projects from:', url);
                const response = await fetch(url, {
                    method: 'GET',
                    headers: {
                        'Accept': 'application/json'
                    },
                    credentials: 'same-origin'
                });
                
                console.log('Response status:', response.status, response.statusText);
                
                if (!response.ok) {
                    const errorText = await response.text();
                    console.error('Failed to load active projects:', response.status, errorText);
                    
                    if (response.status === 403) {
                        projectIdSelect.innerHTML = '<option value="">You do not have access to load work items.</option>';
                    } else if (response.status === 404) {
                        projectIdSelect.innerHTML = '<option value="">Demand Management is not enabled.</option>';
                    } else {
                        projectIdSelect.innerHTML = `<option value="">Error: ${response.status} - ${errorText}</option>`;
                    }
                    return;
                }
                
                const projects = await response.json();
                console.log('Loaded projects:', projects.length, projects);
                
                // Clear and populate select
                projectIdSelect.innerHTML = '<option value="">-- Select a work item --</option>';
                
                if (!Array.isArray(projects)) {
                    console.error('Invalid response format:', projects);
                    projectIdSelect.innerHTML = '<option value="">Error: Invalid response format</option>';
                    return;
                }
                
                if (projects.length === 0) {
                    projectIdSelect.innerHTML += '<option value="" disabled>No active work items available</option>';
                } else {
                    projects.forEach(function(project) {
                        const option = document.createElement('option');
                        option.value = project.id;
                        const displayText = project.code 
                            ? `${escapeHtml(project.title || 'Untitled')} (${escapeHtml(project.code)})`
                            : escapeHtml(project.title || 'Untitled');
                        option.textContent = displayText;
                        projectIdSelect.appendChild(option);
                    });
                }
            } catch (error) {
                console.error('Error loading active projects:', error);
                projectIdSelect.innerHTML = '<option value="">Error loading work items. Please check the console and try again.</option>';
            } finally {
                projectIdSelect.disabled = false;
            }
        }

        // Setup modal handler when DOM is ready
        function setupModalHandler() {
            const linkProjectModal = document.getElementById('linkProjectModal');
            if (!linkProjectModal) {
                setTimeout(setupModalHandler, 100);
                return;
            }

            // Check if handler already attached
            if (linkProjectModal.dataset.handlerAttached === 'true') {
                return;
            }

            // Mark as attached
            linkProjectModal.dataset.handlerAttached = 'true';

            // Add event listener for Bootstrap modal shown event
            linkProjectModal.addEventListener('shown.bs.modal', function () {
                console.log('Modal shown, loading projects...');
                loadActiveProjects();
            });

            // Also support jQuery if available
            if (typeof jQuery !== 'undefined') {
                jQuery(linkProjectModal).on('shown.bs.modal', function () {
                    console.log('Modal shown (jQuery), loading projects...');
                    loadActiveProjects();
                });
            }
        }

        // Initialize when DOM is ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', setupModalHandler);
        } else {
            setupModalHandler();
        }

        // Setup unlink confirmation modal
        function setupUnlinkModal() {
            var defaultBusinessCaseId = @Model.Id;
            
            // Use click handler on buttons
            document.addEventListener('click', function(e) {
                const unlinkBtn = e.target.closest('.unlink-project-btn');
                if (unlinkBtn) {
                    e.preventDefault();
                    e.stopPropagation();
                    
                    const projectTitle = unlinkBtn.getAttribute('data-project-title') || 'Unknown';
                    const projectCode = unlinkBtn.getAttribute('data-project-code') || '';
                    const businessCaseId = unlinkBtn.getAttribute('data-business-case-id');
                    const businessCaseProjectId = unlinkBtn.getAttribute('data-business-case-project-id');
                    
                    console.log('Unlink button clicked:', { businessCaseId, businessCaseProjectId, projectTitle, projectCode, defaultBusinessCaseId });
                    
                    // Update modal content
                    const titleElement = document.getElementById('unlinkProjectTitle');
                    if (titleElement) {
                        const displayText = projectCode 
                            ? `${escapeHtml(projectTitle)} (${escapeHtml(projectCode)})`
                            : escapeHtml(projectTitle);
                        titleElement.textContent = displayText;
                    }
                    
                    // Update form hidden inputs - use defaultBusinessCaseId as fallback
                    const businessCaseIdInput = document.getElementById('unlinkBusinessCaseId');
                    const businessCaseProjectIdInput = document.getElementById('unlinkBusinessCaseProjectId');
                    if (businessCaseIdInput) {
                        businessCaseIdInput.value = businessCaseId || defaultBusinessCaseId.toString();
                        console.log('Setting businessCaseId to:', businessCaseIdInput.value);
                    }
                    if (businessCaseProjectIdInput) {
                        businessCaseProjectIdInput.value = businessCaseProjectId || '';
                        console.log('Setting businessCaseProjectId to:', businessCaseProjectIdInput.value);
                    }
                    
                    // Show modal using jQuery if available, otherwise Bootstrap
                    if (typeof jQuery !== 'undefined') {
                        jQuery('#unlinkProjectModal').modal('show');
                    } else {
                        const modal = document.getElementById('unlinkProjectModal');
                        if (modal) {
                            // Try Bootstrap 5 first, then Bootstrap 4
                            if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
                                const bsModal = new bootstrap.Modal(modal);
                                bsModal.show();
                            } else {
                                modal.style.display = 'block';
                                modal.classList.add('show');
                                document.body.classList.add('modal-open');
                            }
                        }
                    }
                }
            });
            
            // Also support Bootstrap modal event for compatibility
            const unlinkModal = document.getElementById('unlinkProjectModal');
            if (unlinkModal) {
                unlinkModal.addEventListener('show.bs.modal', function (event) {
                    const button = event.relatedTarget;
                    if (button && button.classList.contains('unlink-project-btn')) {
                        const projectTitle = button.getAttribute('data-project-title') || 'Unknown';
                        const projectCode = button.getAttribute('data-project-code') || '';
                        const businessCaseId = button.getAttribute('data-business-case-id');
                        const businessCaseProjectId = button.getAttribute('data-business-case-project-id');
                        
                        console.log('Modal show event:', { businessCaseId, businessCaseProjectId });
                        
                        // Update modal content
                        const titleElement = document.getElementById('unlinkProjectTitle');
                        if (titleElement) {
                            const displayText = projectCode 
                                ? `${escapeHtml(projectTitle)} (${escapeHtml(projectCode)})`
                                : escapeHtml(projectTitle);
                            titleElement.textContent = displayText;
                        }
                        
                        // Update form hidden inputs
                        const businessCaseIdInput = document.getElementById('unlinkBusinessCaseId');
                        const businessCaseProjectIdInput = document.getElementById('unlinkBusinessCaseProjectId');
                        if (businessCaseIdInput && businessCaseId) {
                            businessCaseIdInput.value = businessCaseId;
                            console.log('Setting businessCaseId to:', businessCaseIdInput.value);
                        }
                        if (businessCaseProjectIdInput && businessCaseProjectId) {
                            businessCaseProjectIdInput.value = businessCaseProjectId;
                            console.log('Setting businessCaseProjectId to:', businessCaseProjectIdInput.value);
                        }
                    }
                });
            }
        }
        
        // Initialize unlink modal handler when DOM is ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', setupUnlinkModal);
        } else {
            setupUnlinkModal();
        }
    })();
</script>
