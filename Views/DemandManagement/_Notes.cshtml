@model Compass.ViewModels.DemandManagement.DemandSectionDetailViewModel
@using System
@using System.Collections.Generic
@using Compass.Models

@{
    var request = Model.Request;
    var notes = request.Notes?.OrderByDescending(n => n.CreatedAt).ToList() ?? new List<DemandRequestNote>();
    string FormatName(DemandRequestNote note)
    {
        if (!string.IsNullOrWhiteSpace(note.CreatedByName))
        {
            return note.CreatedByName;
        }
        if (!string.IsNullOrWhiteSpace(note.CreatedByEmail))
        {
            return note.CreatedByEmail;
        }
        return "Team member";
    }

    string FormatTimestamp(DateTime timestamp) => timestamp.ToLocalTime().ToString("dd MMM yyyy HH:mm");
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0">Notes</h3>
    </div>
    <div class="card-body">
        <form asp-action="AddNote" method="post" class="mb-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="demandRequestId" value="@request.Id" />
            <input type="hidden" name="returnSection" value="@Model.ActiveSectionKey" />
            <input type="hidden" name="returnView" value="section" />
            <div class="form-group">
                <label for="notes-add-text">Add a note</label>
                <textarea id="notes-add-text"
                          name="noteText"
                          class="form-control"
                          rows="4"
                          required
                          maxlength="4000"
                          placeholder="Capture updates, decisions or questions for the team."></textarea>
                <small class="form-text text-muted">Notes are visible to everyone working on this request.</small>
            </div>
            <button type="submit" class="btn btn-success btn-sm">Save note</button>
        </form>

        @if (notes.Any())
        {
            <ul class="list-unstyled demand-notes-list mb-0">
                @foreach (var note in notes)
                {
                    <li class="border rounded p-3 mb-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <span class="font-weight-semibold d-block">@FormatName(note)</span>
                                @if (!string.IsNullOrWhiteSpace(note.CreatedByEmail) && !string.Equals(note.CreatedByEmail, note.CreatedByName, StringComparison.OrdinalIgnoreCase))
                                {
                                    <span class="text-muted small d-block">@note.CreatedByEmail</span>
                                }
                            </div>
                            <span class="text-muted small">@FormatTimestamp(note.CreatedAt)</span>
                        </div>
                        <p class="mb-0 mt-3" style="white-space: pre-wrap;">@note.NoteText</p>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="text-muted mb-0">No notes have been added yet.</p>
        }
    </div>
</div>
