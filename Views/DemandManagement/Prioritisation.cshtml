@model IEnumerable<Compass.Models.DemandRequest>
@using Microsoft.AspNetCore.Routing
@using System.Linq

@{
    ViewData["Title"] = "Prioritisation";

    var tierDisplayOrder = new List<(string Key, string Label)>
    {
        ("Tier 1 – Critical", "Tier 1 – Critical"),
        ("Tier 2 – High", "Tier 2 – High"),
        ("Tier 3 – Medium", "Tier 3 – Medium"),
        ("Tier 4 – Low", "Tier 4 – Low")
    };

    var tierCounts = tierDisplayOrder.ToDictionary(
        tier => tier.Key,
        tier => Model.Count(r => r.Prioritisation?.PriorityTier == tier.Key));

    var unprioritisedCount = Model.Count(r => r.Prioritisation == null);

    var currentTier = ViewBag.CurrentTier as string ?? string.Empty;
    var currentBusinessArea = ViewBag.CurrentBusinessArea as string;
    var currentObjectives = (IEnumerable<string>)(ViewBag.CurrentObjectives ?? Enumerable.Empty<string>());
    var currentMissions = (IEnumerable<string>)(ViewBag.CurrentMissions ?? Enumerable.Empty<string>());
    var currentImpact = ViewBag.CurrentImpact as string ?? string.Empty;
    var currentRisk = ViewBag.CurrentRisk as string ?? string.Empty;
    var currentFeasibility = ViewBag.CurrentFeasibility as string ?? string.Empty;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item active">Prioritisation</li>
                </ol>
                <h1 class="m-0">Demand prioritisation</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }

        <!-- Summary Cards -->
        <div class="row">
            <div class="col-md-3">
                <div class="small-box bg-danger">
                    <div class="inner">
                        <h3>@Model.Count(r => r.Prioritisation != null && r.Prioritisation.PriorityTier == "Tier 1 – Critical")</h3>
                        <p>Tier 1 – Critical</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-exclamation-circle"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="small-box bg-warning">
                    <div class="inner">
                        <h3>@Model.Count(r => r.Prioritisation != null && r.Prioritisation.PriorityTier == "Tier 2 – High")</h3>
                        <p>Tier 2 – High</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-arrow-up"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="small-box bg-info">
                    <div class="inner">
                        <h3>@Model.Count(r => r.Prioritisation != null && r.Prioritisation.PriorityTier == "Tier 3 – Medium")</h3>
                        <p>Tier 3 – Medium</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-equals"></i>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="small-box bg-secondary">
                    <div class="inner">
                        <h3>@Model.Count(r => r.Prioritisation != null && r.Prioritisation.PriorityTier == "Tier 4 – Low")</h3>
                        <p>Tier 4 – Low</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-arrow-down"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Left Column: Filters -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <div class="card mb-3">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Priority tiers</h3>
                    </div>
                    <div class="card-body p-0">
                        @{
                            var navRouteValues = new RouteValueDictionary
                            {
                                ["businessArea"] = currentBusinessArea,
                                ["impact"] = currentImpact,
                                ["risk"] = currentRisk,
                                ["feasibility"] = currentFeasibility
                            };
                            if (currentObjectives.Any())
                            {
                                navRouteValues["objectives"] = currentObjectives.ToArray();
                            }
                            if (currentMissions.Any())
                            {
                                navRouteValues["missions"] = currentMissions.ToArray();
                            }
                        }
                        <div class="list-group list-group-flush">
                            <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(string.IsNullOrWhiteSpace(currentTier) ? "active" : string.Empty)" href="@Url.Action("Prioritisation", navRouteValues)">
                                <span>All</span>
                                <span class="badge badge-secondary">@Model.Count()</span>
                            </a>
                            @foreach (var tier in tierDisplayOrder)
                            {
                                var linkValues = new RouteValueDictionary(navRouteValues)
                                {
                                    ["tier"] = tier.Key
                                };
                                var isActive = string.Equals(currentTier, tier.Key, StringComparison.OrdinalIgnoreCase);
                                <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(isActive ? "active" : string.Empty)" href="@Url.Action("Prioritisation", linkValues)">
                                    <span>@tier.Label</span>
                                    <span class="badge badge-secondary">@tierCounts.GetValueOrDefault(tier.Key)</span>
                                </a>
                            }
                            @{
                                var unprioritisedValues = new RouteValueDictionary(navRouteValues)
                                {
                                    ["tier"] = "Unprioritised"
                                };
                            }
                            <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(string.Equals(currentTier, "Unprioritised", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)" href="@Url.Action("Prioritisation", unprioritisedValues)">
                                <span>Unprioritised</span>
                                <span class="badge badge-secondary">@unprioritisedCount</span>
                            </a>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Filters</h3>
                    </div>
                    <div class="card-body">
                        <form method="get">
                            <div class="form-group">
                                <label>Priority tier</label>
                                <select name="tier" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @foreach (var tier in tierDisplayOrder)
                                    {
                                        var isSelectedTier = string.Equals(tier.Key, currentTier, StringComparison.OrdinalIgnoreCase);
                                        if (isSelectedTier)
                                        {
                                            <option value="@tier.Key" selected>@tier.Label</option>
                                        }
                                        else
                                        {
                                            <option value="@tier.Key">@tier.Label</option>
                                        }
                                    }
                                    if (string.Equals(currentTier, "Unprioritised", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <option value="Unprioritised" selected>Unprioritised</option>
                                    }
                                    else
                                    {
                                        <option value="Unprioritised">Unprioritised</option>
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Business area</label>
                                <select name="businessArea" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @foreach (var area in ViewBag.BusinessAreas as IEnumerable<string> ?? Enumerable.Empty<string>())
                                    {
                                        var isSelectedArea = string.Equals(area, currentBusinessArea, StringComparison.OrdinalIgnoreCase);
                                        if (isSelectedArea)
                                        {
                                            <option value="@area" selected>@area</option>
                                        }
                                        else
                                        {
                                            <option value="@area">@area</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Strategic objectives</label>
                                <select name="objectives" class="form-control form-control-sm" multiple>
                                    @foreach (var objective in ViewBag.Objectives as IEnumerable<string> ?? Enumerable.Empty<string>())
                                    {
                                        var isSelectedObjective = currentObjectives.Contains(objective);
                                        if (isSelectedObjective)
                                        {
                                            <option value="@objective" selected>@objective</option>
                                        }
                                        else
                                        {
                                            <option value="@objective">@objective</option>
                                        }
                                    }
                                </select>
                                <small class="form-text text-muted">Hold Ctrl (Windows) or ⌘ (Mac) to select multiple objectives.</small>
                            </div>

                            <div class="form-group">
                                <label>Mission pillars</label>
                                <select name="missions" class="form-control form-control-sm" multiple>
                                    @foreach (var mission in ViewBag.Missions as IEnumerable<string> ?? Enumerable.Empty<string>())
                                    {
                                        var isSelectedMission = currentMissions.Contains(mission);
                                        if (isSelectedMission)
                                        {
                                            <option value="@mission" selected>@mission</option>
                                        }
                                        else
                                        {
                                            <option value="@mission">@mission</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Impact score</label>
                                <select name="impact" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @if (currentImpact == "High")
                                    {
                                        <option value="High" selected>High (8-10)</option>
                                    }
                                    else
                                    {
                                        <option value="High">High (8-10)</option>
                                    }
                                    @if (currentImpact == "Medium")
                                    {
                                        <option value="Medium" selected>Medium (5-7)</option>
                                    }
                                    else
                                    {
                                        <option value="Medium">Medium (5-7)</option>
                                    }
                                    @if (currentImpact == "Low")
                                    {
                                        <option value="Low" selected>Low (0-4)</option>
                                    }
                                    else
                                    {
                                        <option value="Low">Low (0-4)</option>
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Risk score</label>
                                <select name="risk" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @if (currentRisk == "High")
                                    {
                                        <option value="High" selected>High (8-10)</option>
                                    }
                                    else
                                    {
                                        <option value="High">High (8-10)</option>
                                    }
                                    @if (currentRisk == "Medium")
                                    {
                                        <option value="Medium" selected>Medium (5-7)</option>
                                    }
                                    else
                                    {
                                        <option value="Medium">Medium (5-7)</option>
                                    }
                                    @if (currentRisk == "Low")
                                    {
                                        <option value="Low" selected>Low (0-4)</option>
                                    }
                                    else
                                    {
                                        <option value="Low">Low (0-4)</option>
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Feasibility score</label>
                                <select name="feasibility" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    @if (currentFeasibility == "High")
                                    {
                                        <option value="High" selected>High (8-10)</option>
                                    }
                                    else
                                    {
                                        <option value="High">High (8-10)</option>
                                    }
                                    @if (currentFeasibility == "Medium")
                                    {
                                        <option value="Medium" selected>Medium (5-7)</option>
                                    }
                                    else
                                    {
                                        <option value="Medium">Medium (5-7)</option>
                                    }
                                    @if (currentFeasibility == "Low")
                                    {
                                        <option value="Low" selected>Low (0-4)</option>
                                    }
                                    else
                                    {
                                        <option value="Low">Low (0-4)</option>
                                    }
                                </select>
                            </div>

                            <button type="submit" class="btn btn-sm btn-block btn-primary">Apply filters</button>
                            <a href="@Url.Action("Prioritisation")" class="btn btn-sm btn-block btn-secondary">Clear filters</a>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Column: Content -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header d-flex align-items-center justify-content-between">
                        <h3 class="card-title mb-0">Requests</h3>
                    </div>
                    <div class="card-body table-responsive p-0">
                        @if (Model.Any())
                        {
                            <table class="table table-hover text-nowrap">
                                <thead>
                                    <tr>
                                        <th>Request</th>
                                        <th>Business area</th>
                                        <th>Priority tier</th>
                                        <th>Score</th>
                                        <th>Strategic</th>
                                        <th>User impact</th>
                                        <th>Risk</th>
                                        <th>Feasibility</th>
                                        <th>Value</th>
                                        <th>Submitted</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var request in Model)
                                    {
                                        <tr>
                                            <td>
                                                @{
                                                    var title = request.ProposedTitle ?? "Untitled";
                                                    var truncatedTitle = title.Length > 78 ? $"{title.Substring(0, 75)}…" : title;
                                                }
                                                <a asp-action="Details" asp-route-id="@request.Id" class="font-weight-bold">@truncatedTitle</a>
                                                <div class="text-muted small">Reference @request.ReferenceNumber</div>
                                            </td>
                                            <td>@(string.IsNullOrWhiteSpace(request.BusinessArea) ? "Not specified" : request.BusinessArea)</td>
                                            <td>
                                                @if (request.Prioritisation != null)
                                                {
                                                    @if (request.Prioritisation.PriorityTier == "Tier 1 – Critical")
                                                    {
                                                        <span class="badge badge-danger">Tier 1</span>
                                                    }
                                                    else if (request.Prioritisation.PriorityTier == "Tier 2 – High")
                                                    {
                                                        <span class="badge badge-warning">Tier 2</span>
                                                    }
                                                    else if (request.Prioritisation.PriorityTier == "Tier 3 – Medium")
                                                    {
                                                        <span class="badge badge-info">Tier 3</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-secondary">Tier 4</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (request.Prioritisation != null)
                                                {
                                                    <strong>@request.Prioritisation.TotalPriorityScore</strong><span class="text-muted">/100</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (request.Prioritisation != null)
                                                {
                                                    @request.Prioritisation.StrategicAlignmentTotal
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (request.Prioritisation != null)
                                                {
                                                    @request.Prioritisation.UserImpactTotal
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (request.Prioritisation != null)
                                                {
                                                    @request.Prioritisation.RiskUrgencyTotal
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (request.Prioritisation != null)
                                                {
                                                    @request.Prioritisation.FeasibilityTotal
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (request.Prioritisation != null)
                                                {
                                                    @request.Prioritisation.ValueOutcomeTotal
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (request.SubmittedAt.HasValue)
                                                {
                                                    @request.SubmittedAt.Value.ToString("dd MMM yyyy")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="p-4 text-center text-muted">
                                <i class="fas fa-inbox fa-3x mb-3"></i>
                                <p>No requests available for prioritisation.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<style>
    .list-group-item.active {
        background-color: #005eb8;
        border-color: #005eb8;
        color: #fff;
    }

    .list-group-item.active .badge {
        background-color: rgba(255, 255, 255, 0.2);
        color: #fff;
    }
</style>

