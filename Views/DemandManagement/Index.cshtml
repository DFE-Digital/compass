@{
    ViewData["Title"] = "Demand Request";
    var myRequestsCount = ViewBag.MyRequestsCount as int? ?? 0;
}

@section Breadcrumbs {
    <style>
        .breadcrumb a:hover {
            color: #003078 !important;
            text-decoration: underline !important;
        }
    </style>
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Demand Request</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Demand Request</h1>
                <p class="text-muted mb-0">Submit and track your demand requests</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-12">
                <!-- Introduction Card -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title">About the Demand Triage Process</h3>
                    </div>
                    <div class="card-body">
                        <p class="lead">
                            The demand triage process helps us understand, prioritise, and manage requests for new work across the department.
                        </p>
                        <p>
                            When you submit a demand request, it goes through several stages:
                        </p>
                        <ol>
                            <li><strong>Submission</strong> - Your request is submitted and reviewed</li>
                            <li><strong>Explore</strong> - Initial assessment and exploration of the request</li>
                            <li><strong>Prioritisation</strong> - Requests are scored and prioritised against other demands</li>
                            <li><strong>Triage</strong> - Detailed review and decision-making by the triage team</li>
                            <li><strong>Delivery</strong> - Approved requests move into delivery</li>
                            <li><strong>Run</strong> - Completed work moves into operational run</li>
                        </ol>
                        <p>
                            Throughout this process, you can track the progress of your requests and see updates as they move through each stage.
                        </p>
                    </div>
                </div>

                <!-- Call to Action Cards -->
                <div class="row">
                    <div class="col-md-6 mb-4">
                        <div class="card h-100">
                            <div class="card-body text-center">
                                <i class="fas fa-plus-circle fa-3x text-primary mb-3" aria-hidden="true"></i>
                                <h4 class="card-title">Submit a Request</h4>
                                <p class="card-text">
                                    Have a new work request? Submit it through our demand request form and we'll review it as part of our triage process.
                                </p>
                                <a href="@Url.Action("CreateRequest", "DemandManagement")" class="btn btn-primary btn-lg">
                                    <i class="fas fa-plus mr-2" aria-hidden="true"></i>Submit a Request
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 mb-4">
                        <div class="card h-100">
                            <div class="card-body text-center">
                                <i class="fas fa-list-check fa-3x text-success mb-3" aria-hidden="true"></i>
                                <h4 class="card-title">View Your Requests</h4>
                                <p class="card-text">
                                    Track the progress of your submitted requests and see their current status in the triage process.
                                </p>
                                <a href="@Url.Action("Requests", "DemandManagement", new { view = "mine" })" class="btn btn-success btn-lg">
                                    <i class="fas fa-list mr-2" aria-hidden="true"></i>View My Requests
                                    @if (myRequestsCount > 0)
                                    {
                                        <span class="badge badge-light ml-2">@myRequestsCount</span>
                                    }
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Additional Information Card -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Need Help?</h3>
                    </div>
                    <div class="card-body">
                        <p>
                            If you need assistance with submitting a demand request or have questions about the triage process, please contact the Central Operations team or refer to the help documentation.
                        </p>
                        <p class="mb-0">
                            <a href="@Url.Action("Index", "Help")" class="btn btn-outline-primary">
                                <i class="fas fa-question-circle mr-2" aria-hidden="true"></i>View Help
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
