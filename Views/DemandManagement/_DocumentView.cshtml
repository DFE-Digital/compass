@model Compass.Models.DemandRequest
@using System.Linq

@functions {
    public static string FormatBoolean(bool? value) => value.HasValue ? (value.Value ? "Yes" : "No") : "Not answered";
    
    public static IEnumerable<string> SplitCommaSeparated(string? value) =>
        string.IsNullOrWhiteSpace(value)
            ? Enumerable.Empty<string>()
            : value.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(v => v.Trim());

    public static string GetStatusBadgeClass(string status) => status switch
    {
        "Draft" => "badge badge-secondary",
        "Submitted" => "badge badge-info",
        "Explore" => "badge badge-info",
        "Prioritisation" => "badge badge-primary",
        "Triage" => "badge badge-warning",
        "Delivery" => "badge badge-success",
        "Run" => "badge badge-success",
        "Deferred" => "badge badge-secondary",
        "Rejected" => "badge badge-danger",
        _ => "badge badge-light"
    };
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title mb-0">Document view</h3>
        <span class="badge @GetStatusBadgeClass(Model.Status)">@Model.Status</span>
    </div>
    <div class="card-body">
        <h2 class="mb-1">@Model.ProposedTitle</h2>
        <p class="text-muted">Reference: @Model.ReferenceNumber</p>
        
        <hr />
        
        <h3>Overview</h3>
        <dl class="row">
            <dt class="col-md-3">Business area</dt>
            <dd class="col-md-9">@Model.BusinessArea</dd>
            
            <dt class="col-md-3">Requestor</dt>
            <dd class="col-md-9">@Model.ApplicantName (@Model.ApplicantEmail)</dd>
            
            <dt class="col-md-3">Senior responsible officer</dt>
            <dd class="col-md-9">@Model.SeniorResponsibleOfficer</dd>
        </dl>
        
        <h3>Request description</h3>
        <p>@Model.OverviewAndBusinessNeed</p>
        
        <h3>Expected outcome</h3>
        <p>@Model.ExpectedBenefits</p>
        
        <h3>Risk if not delivered</h3>
        <p>@Model.RiskIfNotDelivered</p>
        
        <h3>Strategic alignment</h3>
        <dl class="row">
            <dt class="col-md-3">Manifesto or statutory commitment</dt>
            <dd class="col-md-9">@Model.IsManifestoOrStatutory</dd>
            
            @if (!string.IsNullOrWhiteSpace(Model.ManifestoStatutoryDetails))
            {
                <dt class="col-md-3">Details</dt>
                <dd class="col-md-9">@Model.ManifestoStatutoryDetails</dd>
            }
        </dl>
        
        <h3>Timescales</h3>
        <p>@(string.IsNullOrWhiteSpace(Model.DeliveryTimescales) ? "Not specified" : Model.DeliveryTimescales)</p>
        
        @if (Model.Prioritisation != null)
        {
            <h3>Prioritisation</h3>
            <dl class="row">
                <dt class="col-md-3">Priority score</dt>
                <dd class="col-md-9">@Model.Prioritisation.TotalPriorityScore / 100</dd>
                
                <dt class="col-md-3">Priority tier</dt>
                <dd class="col-md-9">@Model.Prioritisation.PriorityTier</dd>
            </dl>
        }
        
        @if (Model.Assessments != null && Model.Assessments.Any())
        {
            <h3>Assessments</h3>
            @foreach (var assessment in Model.Assessments.OrderBy(a => a.AssessmentType))
            {
                <h4>@assessment.AssessmentType</h4>
                <p>@assessment.AssessmentContent</p>
            }
        }
        
        @if (Model.Notes != null && Model.Notes.Any())
        {
            <h3>Notes</h3>
            @foreach (var note in Model.Notes.OrderBy(n => n.CreatedAt))
            {
                <div class="border-left pl-3 mb-3">
                    <p><strong>@(note.CreatedByName ?? note.CreatedByEmail ?? "Unknown")</strong> - @note.CreatedAt.ToString("dd MMM yyyy HH:mm")</p>
                    <p>@note.NoteText</p>
                </div>
            }
        }
    </div>
</div>

