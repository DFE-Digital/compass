@model Compass.ViewModels.DemandManagement.CsvImportResultViewModel
@{
    ViewData["Title"] = "Import results";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Requests", "DemandManagement")" style="color: #005ea5; text-decoration: none;">Demand requests</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("ImportCsv", "DemandManagement")" style="color: #005ea5; text-decoration: none;">Import CSV</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Import results</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Import results</h1>
                <p class="text-muted mb-0">CSV import completed</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Total rows</h5>
                        <p class="card-text" style="font-size: 2rem; font-weight: bold;">@Model.TotalRows</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-left-success">
                    <div class="card-body">
                        <h5 class="card-title text-success">Successful</h5>
                        <p class="card-text text-success" style="font-size: 2rem; font-weight: bold;">@Model.SuccessfulImports</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-left-danger">
                    <div class="card-body">
                        <h5 class="card-title text-danger">Failed</h5>
                        <p class="card-text text-danger" style="font-size: 2rem; font-weight: bold;">@Model.FailedImports</p>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.CreatedRequestIds.Any())
        {
            <div class="card mt-4">
                <div class="card-header">
                    <h3 class="card-title">Successfully imported requests</h3>
                </div>
                <div class="card-body">
                    <p>The following demand requests were created:</p>
                    <ul>
                        @foreach (var id in Model.CreatedRequestIds)
                        {
                            <li>
                                <a href="@Url.Action("Details", "DemandManagement", new { id = id })">Request #@id</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        }

        @if (Model.Errors.Any())
        {
            <div class="card mt-4">
                <div class="card-header bg-danger">
                    <h3 class="card-title text-white">Import errors</h3>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Row</th>
                                    <th>Demand ID</th>
                                    <th>Error</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var error in Model.Errors)
                                {
                                    <tr>
                                        <td>@error.RowNumber</td>
                                        <td>@(error.DemandId ?? "N/A")</td>
                                        <td class="text-danger">@error.ErrorMessage</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <div class="mt-4">
            <a href="@Url.Action("Requests", "DemandManagement")" class="btn btn-primary">View all requests</a>
            <a href="@Url.Action("ImportCsv", "DemandManagement")" class="btn btn-secondary">Import another file</a>
        </div>
    </div>
</section>

<style nonce="@Context.Items["Nonce"]">
    .border-left-success {
        border-left: 0.25rem solid #1cc88a !important;
    }
    .border-left-danger {
        border-left: 0.25rem solid #e74a3b !important;
    }
</style>

