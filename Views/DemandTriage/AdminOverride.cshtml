@model Compass.ViewModels.DemandTriage.AdminOverrideViewModel

@{
    ViewData["Title"] = $"Admin override — {Model.RequestReference}";
    var allStatuses = ViewBag.AllStatuses as IEnumerable<string> ?? Enumerable.Empty<string>();
}

@await Html.PartialAsync("_DemandTriageStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb" class="govuk-breadcrumbs">
        <ol class="govuk-breadcrumbs__list">
            <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="/">Home</a></li>
            <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" asp-action="Index" asp-controller="DemandTriage">Demand triage</a></li>
            <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" asp-action="Detail" asp-controller="DemandTriage" asp-route-id="@Model.DemandTriageRequestId">@Model.RequestReference</a></li>
            <li class="govuk-breadcrumbs__list-item" aria-current="page">Admin override</li>
        </ol>
    </nav>
}

<!-- ── Header ────────────────────────────────────────────────────────────── -->
<div class="dt-header">
    <div class="dt-header-inner">
        <div>
            <div class="dt-breadcrumb">
                <a href="@Url.Action("Index","DemandTriage")">Demand triage</a>
                <span>/</span>
                <a href="@Url.Action("Detail","DemandTriage", new{id=Model.DemandTriageRequestId})">@Model.RequestReference</a>
                <span>/</span> Admin override
            </div>
            <h1><i class="fas fa-shield-alt mr-2" aria-hidden="true"></i>Admin override</h1>
            <p>@Model.RequestReference — current status: <strong>@Model.CurrentStatus</strong></p>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid pt-3">
        <div class="row justify-content-center">
            <div class="col-lg-7">

                <!-- Danger notice -->
                <div class="dt-notice dt-notice--danger mb-3">
                    <i class="fas fa-exclamation-circle"></i>
                    <div>
                        <strong>Admin action — use with caution.</strong>
                        <p class="mb-0 mt-1">
                            This action bypasses normal workflow transitions and will force the
                            request into the selected status regardless of its current state.
                            A mandatory reason is required and will be permanently recorded in
                            the audit log alongside your identity and timestamp.
                        </p>
                    </div>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="dt-notice dt-notice--danger mb-3">
                        <i class="fas fa-exclamation-circle"></i>
                        <div>
                            <strong>Please fix the following:</strong>
                            <ul class="mb-0 mt-1">
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            </ul>
                        </div>
                    </div>
                }

                <form asp-action="AdminOverride" asp-controller="DemandTriage"
                      asp-route-id="@Model.DemandTriageRequestId" method="post" novalidate>
                    @Html.AntiForgeryToken()

                    <div class="dt-form-section">
                        <div class="dt-form-section-header">
                            <div class="dt-section-num">1</div>
                            <h3>Override details</h3>
                        </div>
                        <div class="dt-form-section-body">

                            <!-- Current status display -->
                            <div class="dt-form-group">
                                <div class="dt-label" style="margin-bottom:0.3rem;">Current status</div>
                                <div style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.4rem 0.75rem;background:#f8f9fa;border:1px solid #dee2e6;border-radius:6px;font-size:0.85rem;font-weight:600;color:#495057;">
                                    <i class="fas fa-circle" style="font-size:0.5rem;color:#6c757d;" aria-hidden="true"></i>
                                    @Model.CurrentStatus
                                </div>
                            </div>

                            <div class="dt-form-group">
                                <label asp-for="NewStatus" class="dt-label">
                                    New status <span class="text-danger">*</span>
                                </label>
                                <span class="dt-label-hint">Select the status to force this request into</span>
                                <select asp-for="NewStatus" class="dt-input" style="max-width:360px">
                                    <option value="">— Select a status —</option>
                                    @foreach (var s in allStatuses)
                                    {
                                        <option value="@s">@s.Replace("_", " ")</option>
                                    }
                                </select>
                                <span asp-validation-for="NewStatus" class="text-danger small"></span>
                            </div>

                            <div class="dt-form-group">
                                <label asp-for="Reason" class="dt-label">
                                    Reason for override <span class="text-danger">*</span>
                                </label>
                                <span class="dt-label-hint">
                                    Provide a clear, detailed reason for this admin override. This will be
                                    permanently recorded in the audit log and cannot be changed.
                                </span>
                                <textarea asp-for="Reason" class="dt-input" rows="5"
                                          placeholder="Provide a clear reason for this admin override, including any relevant context or authorisation"></textarea>
                                <span asp-validation-for="Reason" class="text-danger small"></span>
                            </div>

                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        <button type="submit" class="dt-action-btn dt-action-btn--danger" style="width:auto;padding:0.65rem 1.5rem;"
                                onclick="return confirm('Apply admin override? This action will bypass normal workflow and will be permanently recorded in the audit log.')">
                            <i class="fas fa-shield-alt" aria-hidden="true"></i>
                            <span>Apply override</span>
                        </button>
                        <a asp-action="Detail" asp-controller="DemandTriage" asp-route-id="@Model.DemandTriageRequestId"
                           class="dt-action-btn dt-action-btn--secondary" style="width:auto;padding:0.65rem 1.25rem;">
                            <i class="fas fa-times" aria-hidden="true"></i>
                            <span>Cancel</span>
                        </a>
                    </div>

                </form>

            </div>
        </div>
    </div>
</section>
