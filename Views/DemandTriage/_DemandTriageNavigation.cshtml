@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var isCentralOpsAdmin = ViewBag.IsCentralOpsAdmin as bool? ?? false;
    var isDemandManagement = ViewBag.IsDemandManagement as bool? ?? false;

    var navLinks = new List<object>
    {
        new {
            Text = "Demand register",
            Action = "Index",
            Controller = "DemandTriage",
            IsActive = currentAction == "Index"
        },
        new {
            Text = "Create new request",
            Action = "Create",
            Controller = "DemandTriage",
            IsButton = true
        }
    };

    ViewBag.BrandText = "Demand triage";
    ViewBag.NavLinks = navLinks;
}
@await Html.PartialAsync("_ModuleNavbar")
