@{
    ViewData["Title"] = "COMPASS Roadmap";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Roadmap</li>
        </ol>
    </nav>
}

<h1 class="doc-page-title">COMPASS Roadmap</h1>
<p class="doc-page-lead">Find out what's new and upcoming on the COMPASS roadmap.</p>

<div class="row mt-4">
    <!-- What's New Section -->
    <div class="col-lg-6 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                <h2 class="h5 mb-0">What's New</h2>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <h3 class="h6 mb-2" style="font-weight: 600;">Recent Updates</h3>
                    <p class="text-muted mb-3">Stay up to date with the latest features and improvements to COMPASS.</p>
                    <ul class="list-unstyled">
                        <li class="mb-3 pb-3 border-bottom">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h4 class="h6 mb-1" style="font-weight: 600;">Enhanced User Management</h4>
                                    <p class="text-muted mb-0 small">Improved user, group, and permissions management with a more intuitive interface.</p>
                                </div>
                                <span class="badge badge-primary">New</span>
                            </div>
                        </li>
                        <li class="mb-3 pb-3 border-bottom">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h4 class="h6 mb-1" style="font-weight: 600;">Functional Standards Assessment</h4>
                                    <p class="text-muted mb-0 small">New assessment workflow with progress tracking and export capabilities.</p>
                                </div>
                                <span class="badge badge-primary">New</span>
                            </div>
                        </li>
                        <li class="mb-3 pb-3 border-bottom">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h4 class="h6 mb-1" style="font-weight: 600;">Reporting Improvements</h4>
                                    <p class="text-muted mb-0 small">Enhanced reporting features with better visualisation and data export options.</p>
                                </div>
                                <span class="badge badge-success">Updated</span>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Upcoming Section -->
    <div class="col-lg-6 mb-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-info text-white">
                <h2 class="h5 mb-0">Upcoming</h2>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <h3 class="h6 mb-2" style="font-weight: 600;">Coming Soon</h3>
                    <p class="text-muted mb-3">Explore planned features and enhancements that are on the horizon for COMPASS.</p>
                    <ul class="list-unstyled">
                        <li class="mb-3 pb-3 border-bottom">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h4 class="h6 mb-1" style="font-weight: 600;">Advanced Analytics Dashboard</h4>
                                    <p class="text-muted mb-0 small">Interactive dashboards with real-time data visualisation and custom reporting.</p>
                                </div>
                                <span class="badge badge-info">Q2 2024</span>
                            </div>
                        </li>
                        <li class="mb-3 pb-3 border-bottom">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h4 class="h6 mb-1" style="font-weight: 600;">Mobile App</h4>
                                    <p class="text-muted mb-0 small">Native mobile application for iOS and Android to access COMPASS on the go.</p>
                                </div>
                                <span class="badge badge-info">Q3 2024</span>
                            </div>
                        </li>
                        <li class="mb-3 pb-3 border-bottom">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h4 class="h6 mb-1" style="font-weight: 600;">API Enhancements</h4>
                                    <p class="text-muted mb-0 small">Extended API capabilities with webhooks and improved integration options.</p>
                                </div>
                                <span class="badge badge-info">Q3 2024</span>
                            </div>
                        </li>
                        <li class="mb-3 pb-3 border-bottom">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h4 class="h6 mb-1" style="font-weight: 600;">Automated Workflows</h4>
                                    <p class="text-muted mb-0 small">Configure automated workflows and notifications to streamline your processes.</p>
                                </div>
                                <span class="badge badge-info">Q4 2024</span>
                            </div>
                        </li>
                        <li class="mb-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h4 class="h6 mb-1" style="font-weight: 600;">Enhanced Collaboration Tools</h4>
                                    <p class="text-muted mb-0 small">Improved team collaboration features with comments, mentions, and activity feeds.</p>
                                </div>
                                <span class="badge badge-info">Q4 2024</span>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="alert alert-info mt-4">
    <h3 class="h6">Have a suggestion?</h3>
    <p class="mb-0">If you have ideas for features or improvements you'd like to see in COMPASS, please share your feedback with the team.</p>
</div>

