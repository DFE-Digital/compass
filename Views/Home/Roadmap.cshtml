@using System
@using System.Collections.Generic
@using System.Linq

@{
    ViewData["Title"] = "Compass roadmap";

    var roadmapEntries = new List<(string Title, string Area, string Status, DateTime? Date, string Summary)>
    {
        ("Dashboard overhaul", "User experience", "Delivered", new DateTime(2024, 11, 15), "Complete redesign of the dashboard with horizontal navigation, inline filters, smart summary cards, and priority items section for better visibility of key information."),
        ("Filtering and dimensions", "User experience", "Delivered", new DateTime(2024, 11, 10), "Comprehensive filtering system across Risks, Issues, Actions, and Milestones with dimension views, summary cards, and tabbed active/closed views."),
        ("Reports dashboard", "Reporting", "Delivered", new DateTime(2024, 11, 8), "Power BI-style reporting dashboard with role-based standard reports, custom report builder, and sharing functionality for Permanent Secretary, Director General, C-Level, and Deputy Director views."),
        ("Settings and lookups management", "Administration", "Delivered", new DateTime(2024, 11, 3), "Centralized settings interface with full CRUD operations for business areas, phases, action sources, and other lookup tables with user preferences support."),
        ("Staff role returns", "Reporting", "Delivered", new DateTime(2024, 11, 2), "New reporting module for staff role returns with annual submission tracking, validation, and management interface."),
        ("Performance reporting management", "Reporting", "Delivered", new DateTime(2024, 11, 1), "Enhanced performance reporting with conditional metrics, period exclusions, business area configurations, and product-level exclusions for flexible reporting requirements.")
    };

    var recentUpdates = roadmapEntries
        .Where(e => string.Equals(e.Status, "Delivered", StringComparison.OrdinalIgnoreCase))
        .OrderByDescending(e => e.Date ?? DateTime.MaxValue)
        .ThenBy(e => e.Title)
        .ToList();

    var workingOn = roadmapEntries
        .Where(e => string.Equals(e.Status, "In progress", StringComparison.OrdinalIgnoreCase))
        .OrderBy(e => e.Date ?? DateTime.MaxValue)
        .ThenBy(e => e.Title)
        .ToList();

    var planned = roadmapEntries
        .Where(e => string.Equals(e.Status, "Planned", StringComparison.OrdinalIgnoreCase)
                    || string.Equals(e.Status, "Discovery", StringComparison.OrdinalIgnoreCase))
        .OrderBy(e => e.Date ?? DateTime.MaxValue)
        .ThenBy(e => e.Title)
        .ToList();
}

@section Breadcrumbs {
    <style>
        .breadcrumb a:hover {
            color: #003078 !important;
            text-decoration: underline !important;
        }
    </style>
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4 breadcrumb-standard">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" class="breadcrumb-link-standard">Home</a>
            </li>
            <li class="breadcrumb-item active breadcrumb-active-standard" aria-current="page">Compass roadmap</li>
        </ol>
    </nav>
}


<section class="content">
    <div class="container-fluid roadmap-container">
        <div class="row mb-4">
            <div class="col-12">
                <h1 class="mb-3">Compass roadmap</h1>
                <p class="text-muted mb-0">Track delivered improvements and see what is coming next for Compass. Dates show when changes were released or the target delivery month for upcoming work.</p>
            </div>
        </div>

        <div class="row">
            <aside class="col-12 col-lg-3 roadmap-sidebar">
                <nav class="nav nav-pills flex-column roadmap-nav" aria-label="Roadmap navigation">
                    <a class="nav-link active" aria-current="page" href="#recent-updates">Recent updates</a>
                    <a class="nav-link" href="#working-on">Working on</a>
                    <a class="nav-link" href="#planned">Planned</a>
                    <a class="nav-link" href="#suggest-feature">Suggest a feature</a>
                </nav>
            </aside>
            <div class="col-12 col-lg-9">
                <section id="recent-updates" class="roadmap-section mb-5">
                    <h2 class="h3 mb-4">Recent updates</h2>
                    @if (!recentUpdates.Any())
                    {
                        <div class="roadmap-empty-state">
                            <div class="roadmap-empty-state__icon">
                                <i class="fas fa-inbox"></i>
                            </div>
                            <p>We will publish the latest releases here shortly.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var entry in recentUpdates)
                        {
                            <div class="roadmap-card">
                                <div class="roadmap-card__header">
                                    <h3 class="roadmap-card__title">@entry.Title</h3>
                                    <div class="roadmap-card__badges">
                                        <span class="roadmap-badge roadmap-badge--area">@entry.Area</span>
                                        <span class="roadmap-badge roadmap-badge--date">
                                            <i class="fas fa-calendar-alt mr-1 font-size-075rem"></i>
                                            @(entry.Date.HasValue ? entry.Date.Value.ToString("MMM yyyy") : "TBC")
                                        </span>
                                    </div>
                                </div>
                                <p class="roadmap-card__summary">@entry.Summary</p>
                            </div>
                        }
                    }
                </section>

                <section id="working-on" class="roadmap-section mb-5">
                    <h2 class="h3 mb-4">Working on</h2>
                    @if (!workingOn.Any())
                    {
                        <div class="roadmap-empty-state">
                            <div class="roadmap-empty-state__icon">
                                <i class="fas fa-tasks"></i>
                            </div>
                            <p>In-flight initiatives will appear here once confirmed.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var entry in workingOn)
                        {
                            <div class="roadmap-card">
                                <div class="roadmap-card__header">
                                    <h3 class="roadmap-card__title">@entry.Title</h3>
                                    <div class="roadmap-card__badges">
                                        <span class="roadmap-badge roadmap-badge--area">@entry.Area</span>
                                        <span class="roadmap-badge roadmap-badge--date">
                                            <i class="fas fa-calendar-alt mr-1 font-size-075rem"></i>
                                            @(entry.Date.HasValue ? entry.Date.Value.ToString("MMM yyyy") : "TBC")
                                        </span>
                                    </div>
                                </div>
                                <p class="roadmap-card__summary">@entry.Summary</p>
                            </div>
                        }
                    }
                </section>

                <section id="planned" class="roadmap-section mb-5">
                    <h2 class="h3 mb-4">Planned</h2>
                    @if (!planned.Any())
                    {
                        <div class="roadmap-empty-state">
                            <div class="roadmap-empty-state__icon">
                                <i class="fas fa-lightbulb"></i>
                            </div>
                            <p>Future roadmap themes will be shared here.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var entry in planned)
                        {
                            <div class="roadmap-card">
                                <div class="roadmap-card__header">
                                    <h3 class="roadmap-card__title">@entry.Title</h3>
                                    <div class="roadmap-card__badges">
                                        <span class="roadmap-badge roadmap-badge--area">@entry.Area</span>
                                        <span class="roadmap-badge roadmap-badge--date">
                                            <i class="fas fa-calendar-alt mr-1 font-size-075rem"></i>
                                            @(entry.Date.HasValue ? entry.Date.Value.ToString("MMM yyyy") : "TBC")
                                        </span>
                                    </div>
                                </div>
                                <p class="roadmap-card__summary">@entry.Summary</p>
                            </div>
                        }
                    }
                </section>

                <section id="suggest-feature" class="roadmap-section mb-0">
                    <div class="suggest-feature-card">
                        <h2 class="suggest-feature-card__title">Suggest a feature</h2>
                        <p class="suggest-feature-card__description">The roadmap is shaped by feedback from Compass teams and partners. Share your needs so we can prioritise accordingly.</p>
                        <a class="btn btn-primary" href="mailto:compass-product@education.gov.uk">
                            <i class="fas fa-envelope mr-2"></i>Email the team
                        </a>
                    </div>
                </section>
            </div>
        </div>
    </div>
</section>

<script nonce="@Context.Items["Nonce"]">
    (function() {
        // Update active nav link on scroll
        const sections = document.querySelectorAll('.roadmap-section');
        const navLinks = document.querySelectorAll('.roadmap-nav .nav-link');
        
        function updateActiveNav() {
            let current = '';
            const scrollPosition = window.pageYOffset + 150;
            
            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                const sectionHeight = section.clientHeight;
                if (scrollPosition >= sectionTop && scrollPosition < sectionTop + sectionHeight) {
                    current = section.getAttribute('id');
                }
            });
            
            navLinks.forEach(link => {
                link.classList.remove('active');
                if (link.getAttribute('href') === '#' + current) {
                    link.classList.add('active');
                }
            });
        }
        
        window.addEventListener('scroll', updateActiveNav);
        
        // Handle click on nav links
        navLinks.forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                const targetId = this.getAttribute('href').substring(1);
                const targetSection = document.getElementById(targetId);
                if (targetSection) {
                    const offsetTop = targetSection.offsetTop - 100;
                    window.scrollTo({
                        top: offsetTop,
                        behavior: 'smooth'
                    });
                    // Update active state
                    navLinks.forEach(l => l.classList.remove('active'));
                    this.classList.add('active');
                }
            });
        });
    })();
</script>

