                {
                        <div class="hp-empty">
                            <div class="hp-empty-ico"><i class="fas fa-eye"></i></div>
                        <h3>No watched projects</h3>
                            <p>Add projects to your watchlist to track them here.</p>
                    </div>
                }
                else
                {
                        <div class="hp-rows">
                            @foreach (var p in Model.WatchedProjects.Take(12))
                            {
                                var rag = p.RagStatusLookup?.Name ?? p.RagStatus ?? "";
                                var rowCls = (rag == "Red" || rag == "Amber-Red") ? "r-red" : "";
                                var upcoming = p.Milestones?.Count(m => !m.IsDeleted && m.DueDate >= DateTime.Today && m.DueDate <= DateTime.Today.AddDays(14)) ?? 0;
                                <a href="@Url.Action("Details","Project", new { id = p.Id })" class="hp-row @rowCls">
                                    <div class="hp-ico i-slate"><i class="fas fa-eye" aria-hidden="true"></i></div>
                                    <div class="hp-row-body">
                                        <div class="hp-row-title">@p.Title</div>
                                        <div class="hp-row-sub">@(p.BusinessArea ?? "–")</div>
                                            </div>
                                    <div class="hp-row-meta">
                                        @if (!string.IsNullOrEmpty(rag)) { <span class="@RagBadgeClass(rag)">@rag</span> }
                                        @if (upcoming > 0) { <span class="badge badge-info"><i class="fas fa-flag" aria-hidden="true"></i> @upcoming</span> }
                                    </div>
                                </a>
                                        }
                        </div>
                        @if (Model.WatchedProjects.Count > 12)
                                        {
                            <div class="hp-more mt-2">
                                <a href="@Url.Action("Index","Project")">View all @Model.WatchedProjects.Count watched projects <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
                                            </div>
                        }
                                        }
                                    </div>

                <!-- Products -->
                <div id="hp-tab-products" class="hp-pane" role="tabpanel">
                    @if (!hasProducts)
                    {
                        <div class="hp-empty">
                            <div class="hp-empty-ico"><i class="fas fa-box"></i></div>
                            <h3>No products assigned</h3>
                            <p>You're not currently listed as a contact for any products.</p>
                                        </div>
                                    }
                    else
                    {
                        <div class="hp-rows">
                            @foreach (var prod in Model.MyProducts.Take(12))
                            {
                                var needsReturn = Model.ProductsNeedingReturns.Any(r => r.Product.FipsId == prod.FipsId);
                                <a href="@Url.Action("Dashboard","Products", new { id = prod.FipsId })" class="hp-row @(needsReturn ? "r-amber" : "")">
                                    <div class="hp-ico @(needsReturn ? "i-amber" : "i-teal")"><i class="fas fa-box" aria-hidden="true"></i></div>
                                    <div class="hp-row-body">
                                        <div class="hp-row-title">@prod.Title</div>
                                        <div class="hp-row-sub">
                                            @if (!string.IsNullOrEmpty(prod.Phase)) { <span>@prod.Phase</span> }
                                            @if (!string.IsNullOrEmpty(prod.FipsId)) { <span class="ml-1">· @prod.FipsId</span> }
                                            </div>
                                        </div>
                                    <div class="hp-row-meta">
                                        @if (needsReturn) { <span class="badge badge-warning">Return due</span> }
                                        @if (!string.IsNullOrEmpty(prod.State)) { <span class="badge badge-light border" style="font-size:0.7rem;">@prod.State</span> }
                                </div>
                            </a>
                        }
                    </div>
                        @if (Model.MyProducts.Count > 12)
                        {
                            <div class="hp-more mt-2">
                                <a href="@Url.Action("Index","Products")">View all @Model.MyProducts.Count products <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
                            </div>
                        }
                    }
                    </div>

                <!-- Standards -->
                @if (hasStandards)
                {
                    <div id="hp-tab-standards" class="hp-pane" role="tabpanel">
                        <div class="hp-rows">
                            @foreach (var s in Model.MyDdtStandards.Take(10))
                            {
                                var isOwner = Model.MyOwnedDdtStandards.Any(x => x.Id == s.Id);
                                <a href="@Url.Action("Details","DdtStandards", new { id = s.Id })" class="hp-row">
                                    <div class="hp-ico i-purple"><i class="fas fa-book" aria-hidden="true"></i></div>
                                    <div class="hp-row-body">
                                        <div class="hp-row-title">@s.Title</div>
                                        <div class="hp-row-sub">@(s.Categories.Any() ? string.Join(", ", s.Categories.Take(2).Select(c => c.Category?.Name)) : "–")</div>
                        </div>
                                    <div class="hp-row-meta">
                                        @if (s.IsPublished) { <span class="badge badge-success">Published</span> }
                                        else { <span class="badge badge-warning">@s.Stage</span> }
                                        @if (isOwner) { <span class="badge badge-primary">Owner</span> }
                                    </div>
                                </a>
                }
            </div>
                        @if (Model.MyDdtStandards.Count > 10)
                        {
                            <div class="hp-more mt-2">
                                <a href="@Url.Action("Index","DdtStandards")">View all @Model.MyDdtStandards.Count standards <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
                    </div>
                }
                    </div>
                }

                <!-- Commission reporting -->
                @if (commissionCount > 0)
                {
                    <div id="hp-tab-commission" class="hp-pane" role="tabpanel">
                        <div class="hp-rows">
                            @foreach (var item in Model.ProductsNeedingCommissionReporting.Take(10))
                            {
                                var isLate = item.Status == CommissionSubmissionStatus.Late;
                                <a href="@Url.Action("SubmitCommission","ProductReporting", new { documentId = item.Product.DocumentId ?? item.Product.FipsId, commissionId = item.Commission.Id })" class="hp-row @(isLate ? "r-red" : "r-amber")">
                                    <div class="hp-ico @(isLate ? "i-red" : "i-amber")"><i class="fas fa-clipboard-list" aria-hidden="true"></i></div>
                                    <div class="hp-row-body">
                                        <div class="hp-row-title">@item.Product.Title</div>
                                        <div class="hp-row-sub">@item.Commission.Name</div>
                                            </div>
                                    <div class="hp-row-meta">
                                        <span class="badge @(isLate ? "badge-danger" : item.Status == CommissionSubmissionStatus.InProgress ? "badge-warning" : "badge-info")">
                                            @(isLate ? "Late" : item.Status == CommissionSubmissionStatus.InProgress ? "In progress" : "Due")
                                        </span>
                                        <span class="text-muted" style="font-size:0.72rem;">@item.DueDate.ToString("d MMM")</span>
                                </div>
                            </a>
                        }
                    </div>
                        @if (commissionCount > 10)
                        {
                            <div class="hp-more mt-2">
                                <a href="@Url.Action("Commission","ProductReporting")">View all @commissionCount tasks <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
                            </div>
                        }
                    </div>
                }

                <!-- Successes -->
                @if (Model.RecentSuccesses.Any())
                {
                    <div id="hp-tab-successes" class="hp-pane" role="tabpanel">
                        <div style="font-size:0.78rem; color:#6b7280; margin-bottom:0.75rem;">Recent wins from the last 30 days</div>
                        @foreach (var s in Model.RecentSuccesses.Take(10))
                        {
                            <div class="hp-success">
                                <div class="hp-success-dot" aria-hidden="true"></div>
                                <div class="hp-success-body">
                                    <div class="hp-success-title">@s.SuccessDescription</div>
                                    @if (s.Project != null)
                                    {
                                        <div class="hp-success-proj">
                                            <a href="@Url.Action("Details","Project", new { id = s.ProjectId })" style="color:#6b7280; text-decoration:none;">@s.Project.Title</a>
                                            · @s.RecordedAt.ToString("d MMM")
                        </div>
                    }
                                </div>
                            </div>
                }
            </div>
                }

            </div>

        <!-- Right sidebar -->
        <div>

            <!-- At-risk projects -->
            @if (Model.AtRiskProjects.Any())
            {
                <div class="hp-widget">
                    <div class="hp-widget-head">
                        <h3><i class="fas fa-exclamation-triangle" style="color:#d4351c;" aria-hidden="true"></i>At-risk projects</h3>
                        <a href="@Url.Action("Index","Project")">View all</a>
                    </div>
                    <div class="hp-widget-body">
                        @foreach (var p in Model.AtRiskProjects.Take(6))
                        {
                            var rag = p.RagStatusLookup?.Name ?? p.RagStatus ?? "–";
                            <div class="hp-mini-row">
                                <span class="@RagBadgeClass(rag)" style="flex-shrink:0;">@rag</span>
                                <a href="@Url.Action("Details","Project", new { id = p.Id })">@p.Title</a>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- Milestones due this week -->
            @if (Model.MilestonesDueThisWeek.Any())
            {
                <div class="hp-widget">
                    <div class="hp-widget-head">
                        <h3><i class="fas fa-calendar-alt" aria-hidden="true"></i>Due this week</h3>
                        <a href="@Url.Action("Index","Project")">View all</a>
                    </div>
                    <div class="hp-widget-body">
                        @foreach (var m in Model.MilestonesDueThisWeek.Take(6))
                    {
                            <div class="hp-mini-row">
                                <span class="hp-mini-date">@m.DueDate.ToString("d MMM")</span>
                                <a href="@Url.Action("MilestoneDetails","Project", new { id = m.Id })">@m.Name</a>
                        </div>
                }
            </div>
                </div>
            }

            <!-- Unmonitored risks -->
            @if (Model.UnmonitoredRisks.Any())
            {
                <div class="hp-widget">
                    <div class="hp-widget-head">
                        <h3><i class="fas fa-shield-alt" style="color:#d4351c;" aria-hidden="true"></i>Risks needing review</h3>
                        <a href="@Url.Action("Index","Raid", new { viewType = "risks" })">View all</a>
                    </div>
                    <div class="hp-widget-body">
                        @foreach (var r in Model.UnmonitoredRisks.Take(5))
                        {
                            <div class="hp-mini-row">
                                <span class="badge badge-warning" style="flex-shrink:0;">Risk</span>
                                <a href="@Url.Action("Details","Risk", new { id = r.Id })">@r.Title</a>
                            </div>
                        }
                        @if (Model.UnmonitoredRisks.Count > 5)
                        {
                            <div class="hp-more"><a href="@Url.Action("Index","Raid", new { viewType = "risks" })">+@(Model.UnmonitoredRisks.Count - 5) more</a></div>
                        }
                    </div>
                </div>
            }

            </div>
        </div>

    </div>
</section>
</div>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
    (function () {
            // Tab switching
        document.querySelectorAll('.hp-tab').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var tab = this.getAttribute('data-tab');
                document.querySelectorAll('.hp-tab').forEach(function (b) {
                    b.classList.remove('active');
                    b.setAttribute('aria-selected', 'false');
                });
                document.querySelectorAll('.hp-pane').forEach(function (p) {
                    p.classList.remove('active');
                });
                    this.classList.add('active');
                this.setAttribute('aria-selected', 'true');
                var pane = document.getElementById('hp-tab-' + tab);
                if (pane) pane.classList.add('active');
                });
            });

        // Stat cards that jump to a tab
        document.querySelectorAll('[data-jump]').forEach(function (card) {
            card.addEventListener('click', function (e) {
                e.preventDefault();
                var tab = this.getAttribute('data-jump');
                var btn = document.querySelector('.hp-tab[data-tab="' + tab + '"]');
                if (btn) {
                    btn.click();
                    var tabBar = document.querySelector('.hp-tabs');
                    if (tabBar) {
                        var top = tabBar.getBoundingClientRect().top + window.pageYOffset - 80;
                        window.scrollTo({ top: top, behavior: 'smooth' });
                    }
                }
            });
        });
        })();
    </script>
}
