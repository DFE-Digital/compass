    <!-- ── Main layout ─────────────────────────────────────────────────────── -->
    <div class="hp-layout">

        <!-- Left: tabbed work area -->
        <div>
            <div class="hp-card" style="padding: 0;">
                <div class="hp-card-head" style="padding-bottom: 0; border-bottom: none;">
