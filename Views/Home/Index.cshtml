@model HomeDashboardViewModel
@using Compass.Models
@using Compass.Services
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostEnvironment

@{
    ViewData["Title"] = "COMPASS Dashboard";
    var currentUser = Model.CurrentUser;
    var hasProjects = Model.MyProjects.Any();
    var hasProducts = Model.MyProducts.Any();
    var hasStandards = Model.MyDdtStandards.Any();
    var totalItems = Model.MyProjects.Count + Model.MyProducts.Count + Model.MyDdtStandards.Count;
    var taskCount = Model.OverdueMilestones.Count + Model.AssignedActions.Count + Model.HighPriorityIssues.Count + Model.ProjectsNeedingMonthlyUpdates.Count + Model.ProductsNeedingReturns.Count + Model.ProductsNeedingCommissionReporting.Count;
}

@await Html.PartialAsync("_DashboardStyles")

@functions {
    string GetTimeBasedGreeting()
    {
        var hour = DateTime.Now.Hour;
        if (hour < 12)
            return "Good morning";
        else if (hour < 17)
            return "Good afternoon";
        else
            return "Good evening";
    }

    string GetRagBadgeClass(string ragStatus)
    {
        if (string.IsNullOrWhiteSpace(ragStatus))
            return "badge badge-secondary";
        
        var normalized = ragStatus.Trim()
            .Replace(" / ", "-")
            .Replace("/", "-")
            .Replace(" /", "-")
            .Replace("/ ", "-");
        
        return normalized switch
        {
            "Green" => "badge badge-success",
            "Amber-Green" => "badge badge-warning",
            "Amber" => "badge badge-warning",
            "Amber-Red" => "badge badge-danger",
            "Red" => "badge badge-danger",
            _ => "badge badge-secondary"
        };
    }

    string GetPriorityBadgeClass(string priorityName)
    {
        if (string.IsNullOrWhiteSpace(priorityName))
            return "badge badge-secondary";

        var normalized = priorityName.Trim().ToLowerInvariant();
        return normalized switch
        {
            "high" => "badge badge-danger",
            "medium" => "badge badge-warning",
            "low" => "badge badge-success",
            _ => "badge badge-secondary"
        };
    }

    bool IsOpenStatus(string? status)
    {
        return !string.Equals(status, "closed", StringComparison.OrdinalIgnoreCase) &&
               !string.Equals(status, "resolved", StringComparison.OrdinalIgnoreCase) &&
               !string.Equals(status, "complete", StringComparison.OrdinalIgnoreCase) &&
               !string.Equals(status, "cancelled", StringComparison.OrdinalIgnoreCase);
    }

    string GetRoleBadgeClass(LeadershipRoleTier role)
    {
        return role switch
        {
            LeadershipRoleTier.PermanentSecretary => "badge badge-primary",
            LeadershipRoleTier.DirectorGeneral => "badge badge-info",
            LeadershipRoleTier.CLevel => "badge badge-info",
            LeadershipRoleTier.DeputyDirectorOrSro => "badge badge-success",
            LeadershipRoleTier.HeadOfProfession => "badge badge-success",
            LeadershipRoleTier.PortfolioLead => "badge badge-secondary",
            _ => "badge badge-secondary"
        };
    }

    string GetRoleLabel(LeadershipRoleTier role)
    {
        return role switch
        {
            LeadershipRoleTier.PermanentSecretary => "Permanent Secretary",
            LeadershipRoleTier.DirectorGeneral => "Director General",
            LeadershipRoleTier.CLevel => "C-Level",
            LeadershipRoleTier.DeputyDirectorOrSro => "Deputy Director / SRO",
            LeadershipRoleTier.HeadOfProfession => "Head of Profession",
            LeadershipRoleTier.PortfolioLead => "Portfolio Lead / G6",
            _ => role.ToString()
        };
    }

    string GetBusinessAreaOverviewTitle()
    {
        if (!Model.HighestLeadershipRole.HasValue)
        {
            return "Business area overview";
        }

        return Model.HighestLeadershipRole.Value switch
        {
            LeadershipRoleTier.HeadOfProfession => "Head of profession",
            LeadershipRoleTier.CLevel => !string.IsNullOrWhiteSpace(Model.CurrentUser.JobTitle) 
                ? Model.CurrentUser.JobTitle 
                : "C-level",
            LeadershipRoleTier.DeputyDirectorOrSro => Model.LeadershipBusinessAreas.Any()
                ? string.Join(", ", Model.LeadershipBusinessAreas.Take(3))
                : "Deputy director",
            LeadershipRoleTier.PortfolioLead => "Portfolio lead",
            LeadershipRoleTier.DirectorGeneral => "Director general",
            LeadershipRoleTier.PermanentSecretary => "Permanent secretary",
            _ => "Business area overview"
        };
    }
}

<style>
    /* GOV.UK link styling for task cards */
    .work-item-card h4 {
        color: #005ea5;
        text-decoration: underline;
        font-weight: 400;
    }
    
    .work-item-card:hover h4 {
        color: #003078;
    }
    
    /* GOV.UK link styling for task table links */
    .work-items-table a {
        color: #005ea5;
        text-decoration: underline;
    }
    
    .work-items-table a:hover {
        color: #003078;
    }
    
    .work-items-table a:visited {
        color: #4c2c92;
    }
</style>

<section class="content mt-4">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

    

        <!-- Dashboard Header -->
        <div class="dashboard-header">
            <h1>@GetTimeBasedGreeting(), @Model.FirstName!</h1>
            <p>Here's an overview of your work, assignments, and responsibilities.</p>
        </div>

        <!-- Quick Stats -->
        <div class="dashboard-summary-cards">
            @if (Model.OverdueMilestones.Any())
            {
                <a href="@Url.Action("Index", "Project")" class="dashboard-card bg-danger">
                    <div class="dashboard-card-value">@(Model.OverdueMilestones?.Count ?? 0)</div>
                    <div class="dashboard-card-label">Overdue Milestones</div>
                    <div class="dashboard-card-icon"><i class="fas fa-exclamation-triangle"></i></div>
                </a>
            }
            
            @if (Model.AssignedActions.Any())
            {
                <a href="@Url.Action("Index", "Raid", new { viewType = "actions" })" class="dashboard-card bg-warning">
                    <div class="dashboard-card-value">@(Model.AssignedActions?.Count ?? 0)</div>
                    <div class="dashboard-card-label">Assigned Actions</div>
                    <div class="dashboard-card-icon"><i class="fas fa-tasks"></i></div>
                </a>
            }
            
            @if (Model.HighPriorityIssues.Any())
            {
                <a href="@Url.Action("Index", "Raid", new { viewType = "issues" })" class="dashboard-card bg-danger">
                    <div class="dashboard-card-value">@(Model.HighPriorityIssues?.Count ?? 0)</div>
                    <div class="dashboard-card-label">High Priority Issues</div>
                    <div class="dashboard-card-icon"><i class="fas fa-bug"></i></div>
                </a>
            }
            
            @if (Model.MyProjects.Any())
            {
                <a href="@Url.Action("Index", "Project")" class="dashboard-card bg-primary">
                    <div class="dashboard-card-value">@(Model.MyProjects?.Count ?? 0)</div>
                    <div class="dashboard-card-label">My Projects</div>
                    <div class="dashboard-card-icon"><i class="fas fa-project-diagram"></i></div>
                </a>
            }
            
            @if (Model.WatchedProjects.Any())
            {
                <a href="@Url.Action("Index", "Project")" class="dashboard-card bg-info">
                    <div class="dashboard-card-value">@(Model.WatchedProjects?.Count ?? 0)</div>
                    <div class="dashboard-card-label">Watched Projects</div>
                    <div class="dashboard-card-icon"><i class="fas fa-eye"></i></div>
                </a>
            }
            
            @if (Model.MyProducts.Any())
            {
                <a href="@Url.Action("Index", "Products")" class="dashboard-card bg-primary">
                    <div class="dashboard-card-value">@(Model.MyProducts?.Count ?? 0)</div>
                    <div class="dashboard-card-label">My Products</div>
                    <div class="dashboard-card-icon"><i class="fas fa-box"></i></div>
                </a>
            }
            
            @if (Model.MyDdtStandards.Any())
            {
                <a href="@Url.Action("Dashboard", "DdtStandards")" class="dashboard-card bg-primary">
                    <div class="dashboard-card-value">@(Model.MyDdtStandards?.Count ?? 0)</div>
                    <div class="dashboard-card-label">My DDT Standards</div>
                    <div class="dashboard-card-icon"><i class="fas fa-book"></i></div>
                </a>
            }
        </div>

        <!-- Leadership Views -->
        @if (Model.IsEnterpriseLeader || Model.IsBusinessAreaLeader)
        {
            @if (Model.IsEnterpriseLeader)
            {
                <div class="dashboard-section">
                    <div class="dashboard-section-header">
                        <h2><i class="fas fa-building"></i> Enterprise Overview</h2>
                    </div>
                    <div class="row mb-4">
                        <div class="col-md-3 mb-3">
                            <div class="metric-pill">
                                <strong>@Model.EnterpriseMetrics.TotalAtRiskProjects</strong>
                                <span>At Risk Projects</span>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="metric-pill">
                                <strong>@Model.EnterpriseMetrics.TotalOpenIssues</strong>
                                <span>Open Issues</span>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="metric-pill">
                                <strong>@Model.EnterpriseMetrics.TotalOpenRisks</strong>
                                <span>Open Risks</span>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="metric-pill">
                                <strong>@Model.EnterpriseMetrics.ActiveMissionsCount</strong>
                                <span>Active Missions</span>
                            </div>
                        </div>
                    </div>
                    @if (Model.EnterpriseAtRiskProjects.Any())
                    {
                        <div class="alert alert-danger">
                            <strong><i class="fas fa-exclamation-triangle mr-2"></i>@Model.EnterpriseAtRiskProjects.Count At Risk Projects</strong>
                            <a href="#at-risk-projects" class="ml-2">View details →</a>
                        </div>
                    }
                </div>
            }

        }

        <!-- My Work Section -->
        <div class="dashboard-section">
            <div class="dashboard-section-header">
                <h2><i class="fas fa-briefcase"></i> My work</h2>
                <div class="view-toggle">
                    <button class="view-toggle-btn active" data-view="cards" title="Card view">
                        <i class="fas fa-th"></i> Cards
                    </button>
                    <button class="view-toggle-btn" data-view="list" title="List view">
                        <i class="fas fa-list"></i> List
                    </button>
                </div>
            </div>

            <div class="tabs-container">
                <button class="tab-button active" data-tab="tasks">Tasks (@taskCount)</button>
                <button class="tab-button" data-tab="projects">Projects (@Model.MyProjects.Count)</button>
                <button class="tab-button" data-tab="watching">Watching (@Model.WatchedProjects.Count)</button>
                <button class="tab-button" data-tab="products">Products (@Model.MyProducts.Count)</button>
                <button class="tab-button" data-tab="standards">DDT Standards (@Model.MyDdtStandards.Count)</button>
                <button class="tab-button" data-tab="commission">Performance reporting (@Model.ProductsNeedingCommissionReporting.Count)</button>
            </div>

            <!-- Tasks Tab -->
            <div id="tab-tasks" class="tab-content active">
                @if (!Model.AssignedActions.Any() && !Model.OverdueMilestones.Any() && !Model.HighPriorityIssues.Any() && !Model.ProjectsNeedingMonthlyUpdates.Any() && !Model.ProductsNeedingReturns.Any() && !Model.ProductsNeedingCommissionReporting.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">✅</div>
                        <h3>No tasks</h3>
                        <p>You're all caught up! There are no outstanding tasks or reporting requirements.</p>
                    </div>
                }
                else
                {
                    <!-- Cards View -->
                    <div class="work-items-grid active" data-view="cards">
                        @foreach (var milestone in Model.OverdueMilestones.Take(10))
                        {
                            <a href="@Url.Action("MilestoneDetails", "Project", new { id = milestone.Id })" class="work-item-card">
                                <h4>@milestone.Name</h4>
                                @if (milestone.Project != null)
                                {
                                    <p class="work-item-project">@milestone.Project.Title</p>
                                }
                                <div class="work-item-meta">
                                    <div class="work-item-meta-row">
                                        <span class="badge badge-danger">Overdue milestone</span>
                                        <span class="text-muted">Due: @milestone.DueDate.ToString("dd MMMM yyyy")</span>
                                    </div>
                                </div>
                            </a>
                        }

                        @foreach (var action in Model.AssignedActions.Take(10))
                        {
                            <a href="@Url.Action("Details", "Action", new { id = action.Id })" class="work-item-card">
                                <h4>@action.Title</h4>
                                @if (action.Project != null)
                                {
                                    <p class="work-item-project">@action.Project.Title</p>
                                }
                                <div class="work-item-meta">
                                    <div class="work-item-meta-row">
                                        <span class="badge badge-warning">Action</span>
                                        @if (action.PriorityLookup != null)
                                        {
                                            <span class="@GetPriorityBadgeClass(action.PriorityLookup.Label)">@action.PriorityLookup.Label</span>
                                        }
                                        @if (action.DueDate.HasValue)
                                        {
                                            <span class="text-muted">Due: @action.DueDate.Value.ToString("dd MMMM yyyy")</span>
                                        }
                                    </div>
                                </div>
                            </a>
                        }

                        @foreach (var issue in Model.HighPriorityIssues.Take(10))
                        {
                            <a href="@Url.Action("Details", "Issue", new { id = issue.Id })" class="work-item-card">
                                <h4>@issue.Title</h4>
                                @if (issue.Project != null)
                                {
                                    <p class="work-item-project">@issue.Project.Title</p>
                                }
                                <div class="work-item-meta">
                                    <div class="work-item-meta-row">
                                        <span class="badge badge-danger">High priority issue</span>
                                        @if (!string.IsNullOrEmpty(issue.Severity))
                                        {
                                            <span class="badge badge-danger">@issue.Severity</span>
                                        }
                                    </div>
                                </div>
                            </a>
                        }

                        @foreach (var item in Model.ProjectsNeedingMonthlyUpdates.Take(10))
                        {
                            var updateYear = item.DueDate.Month == 1 ? item.DueDate.Year - 1 : item.DueDate.Year;
                            var updateMonth = item.DueDate.Month == 1 ? 12 : item.DueDate.Month - 1;
                            <a href="@Url.Action("EditUpdate", "MilestonesUpdatesSuccesses", new { projectId = item.Project.Id, year = updateYear, month = updateMonth })" class="work-item-card">
                                <h4>Complete monthly update</h4>
                                <p class="work-item-project">@item.Project.Title</p>
                                <div class="work-item-meta">
                                    <div class="work-item-meta-row">
                                        <span class="badge @(item.Status == UpdateSubmissionStatus.Late ? "badge-danger" : "badge-warning")">Monthly update @(item.Status == UpdateSubmissionStatus.Late ? "late" : "due")</span>
                                        <span class="text-muted">Due: @item.DueDate.ToString("dd MMMM yyyy")</span>
                                    </div>
                                </div>
                            </a>
                        }

                        @foreach (var item in Model.ProductsNeedingReturns.Take(10))
                        {
                            var metricsYear = item.DueDate.Month == 1 ? item.DueDate.Year - 1 : item.DueDate.Year;
                            var metricsMonth = item.DueDate.Month == 1 ? 12 : item.DueDate.Month - 1;
                            <a href="@Url.Action("SubmitMetrics", "ProductReporting", new { documentId = item.Product.FipsId, year = metricsYear, month = metricsMonth })" class="work-item-card">
                                <h4>Complete performance reporting</h4>
                                <p class="work-item-project">@item.Product.Title</p>
                                <div class="work-item-meta">
                                    <div class="work-item-meta-row">
                                        <span class="badge @(item.Status == ReturnStatus.Late ? "badge-danger" : "badge-warning")">Performance @(item.Status == ReturnStatus.Late ? "late" : "due")</span>
                                        <span class="text-muted">Due: @item.DueDate.ToString("dd MMMM yyyy")</span>
                                    </div>
                                </div>
                            </a>
                        }

                        @foreach (var item in Model.ProductsNeedingCommissionReporting.Take(10))
                        {
                            <a href="@Url.Action("SubmitCommission", "ProductReporting", new { documentId = item.Product.DocumentId ?? item.Product.FipsId, commissionId = item.Commission.Id })" class="work-item-card">
                                <h4>Complete performance reporting</h4>
                                <p class="work-item-project">@item.Product.Title</p>
                                <div class="work-item-meta">
                                    <div class="work-item-meta-row">
                                        <span class="badge @(item.Status == CommissionSubmissionStatus.Late ? "badge-danger" : item.Status == CommissionSubmissionStatus.InProgress ? "badge-warning" : "badge-info")">Commission @(item.Status == CommissionSubmissionStatus.Late ? "late" : item.Status == CommissionSubmissionStatus.InProgress ? "in progress" : "due")</span>
                                        <span class="text-muted">Due: @item.DueDate.ToString("dd MMMM yyyy")</span>
                                    </div>
                                    <div class="work-item-meta-row">
                                        <span class="text-muted">@item.Commission.Name</span>
                                    </div>
                                </div>
                            </a>
                        }
                    </div>

                    <!-- List View -->
                    <div class="work-items-list" data-view="list">
                        <table class="work-items-table">
                            <thead>
                                <tr>
                                    <th>Task</th>
                                    <th>Item</th>
                                    <th>Type</th>
                                    <th>Due Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var milestone in Model.OverdueMilestones.Take(10))
                                {
                                    <tr>
                                        <td><a href="@Url.Action("MilestoneDetails", "Project", new { id = milestone.Id })">Review overdue milestone</a></td>
                                        <td>@(milestone.Project?.Title ?? "-")</td>
                                        <td>Work reporting</td>
                                        <td>@milestone.DueDate.ToString("dd MMMM yyyy")</td>
                                        <td><span class="badge badge-danger">Overdue</span></td>
                                    </tr>
                                }
                                @foreach (var action in Model.AssignedActions.Take(10))
                                {
                                    <tr>
                                        <td><a href="@Url.Action("Details", "Action", new { id = action.Id })">@action.Title</a></td>
                                        <td>@(action.Project?.Title ?? "-")</td>
                                        <td>Work reporting</td>
                                        <td>@(action.DueDate?.ToString("dd MMMM yyyy") ?? "-")</td>
                                        <td>@if (action.PriorityLookup != null) { <span class="@GetPriorityBadgeClass(action.PriorityLookup.Label)">@action.PriorityLookup.Label</span> }</td>
                                    </tr>
                                }
                                @foreach (var issue in Model.HighPriorityIssues.Take(10))
                                {
                                    <tr>
                                        <td><a href="@Url.Action("Details", "Issue", new { id = issue.Id })">@issue.Title</a></td>
                                        <td>@(issue.Project?.Title ?? "-")</td>
                                        <td>Work reporting</td>
                                        <td>-</td>
                                        <td>@if (!string.IsNullOrEmpty(issue.Severity)) { <span class="badge badge-danger">@issue.Severity</span> }</td>
                                    </tr>
                                }
                                @foreach (var item in Model.ProjectsNeedingMonthlyUpdates.Take(10))
                                {
                                    var updateYear = item.DueDate.Month == 1 ? item.DueDate.Year - 1 : item.DueDate.Year;
                                    var updateMonth = item.DueDate.Month == 1 ? 12 : item.DueDate.Month - 1;
                                    <tr>
                                        <td><a href="@Url.Action("EditUpdate", "MilestonesUpdatesSuccesses", new { projectId = item.Project.Id, year = updateYear, month = updateMonth })">Complete monthly update</a></td>
                                        <td>@item.Project.Title</td>
                                        <td>Work reporting</td>
                                        <td>@item.DueDate.ToString("dd MMMM yyyy")</td>
                                        <td><span class="badge @(item.Status == UpdateSubmissionStatus.Late ? "badge-danger" : "badge-warning")">@(item.Status == UpdateSubmissionStatus.Late ? "Late" : "Due")</span></td>
                                    </tr>
                                }
                                @foreach (var item in Model.ProductsNeedingReturns.Take(10))
                                {
                                    var metricsYear = item.DueDate.Month == 1 ? item.DueDate.Year - 1 : item.DueDate.Year;
                                    var metricsMonth = item.DueDate.Month == 1 ? 12 : item.DueDate.Month - 1;
                                    <tr>
                                        <td><a href="@Url.Action("SubmitMetrics", "ProductReporting", new { documentId = item.Product.FipsId, year = metricsYear, month = metricsMonth })">Complete performance reporting</a></td>
                                        <td>@item.Product.Title</td>
                                        <td>Operational reporting</td>
                                        <td>@item.DueDate.ToString("dd MMMM yyyy")</td>
                                        <td><span class="badge @(item.Status == ReturnStatus.Late ? "badge-danger" : "badge-warning")">@(item.Status == ReturnStatus.Late ? "Late" : "Due")</span></td>
                                    </tr>
                                }
                                @foreach (var item in Model.ProductsNeedingCommissionReporting.Take(10))
                                {
                                    <tr>
                                        <td><a href="@Url.Action("SubmitCommission", "ProductReporting", new { documentId = item.Product.DocumentId ?? item.Product.FipsId, commissionId = item.Commission.Id })">Complete performance reporting</a></td>
                                        <td>@item.Product.Title</td>
                                        <td>Performance reporting</td>
                                        <td>@item.DueDate.ToString("dd MMMM yyyy")</td>
                                        <td>
                                            @switch (item.Status)
                                            {
                                                case CommissionSubmissionStatus.Late:
                                                    <span class="badge badge-danger">Late</span>
                                                    break;
                                                case CommissionSubmissionStatus.InProgress:
                                                    <span class="badge badge-warning">In progress</span>
                                                    break;
                                                default:
                                                    <span class="badge badge-info">Due</span>
                                                    break;
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (taskCount > 10)
                    {
                        <div class="text-center mt-3">
                            <a href="@Url.Action("Index", "Raid")" class="btn btn-outline-primary">View all @taskCount tasks →</a>
                        </div>
                    }
                }
            </div>

            <!-- Projects Tab -->
            <div id="tab-projects" class="tab-content">
                @if (!hasProjects)
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">📊</div>
                        <h3>No projects assigned</h3>
                        <p>You're not currently listed on any project teams.</p>
                        <a href="@Url.Action("Index", "Project")" class="btn btn-primary mt-2">Browse Projects</a>
                    </div>
                }
                else
                {
                    <!-- Cards View -->
                    <div class="work-items-grid active" data-view="cards">
                        @foreach (var project in Model.MyProjects.Take(10))
                        {
                            <a href="@Url.Action("Details", "Project", new { id = project.Id })" class="work-item-card">
                                <h4>
                                    @project.Title
                                    @if (project.IsFlagship)
                                    {
                                        <span class="badge badge-info ml-2">Flagship</span>
                                    }
                                </h4>
                                <div class="work-item-meta">
                                    <div class="work-item-meta-row">
                                        @if (!string.IsNullOrEmpty(project.RagStatus))
                                        {
                                            <div class="work-item-meta-item">
                                                <span class="work-item-meta-label">RAG Status</span>
                                                <span class="@GetRagBadgeClass(project.RagStatus)">@project.RagStatus</span>
                                            </div>
                                        }
                                        @if (project.DeliveryPriority != null)
                                        {
                                            <div class="work-item-meta-item">
                                                <span class="work-item-meta-label">Priority</span>
                                                <span class="@GetPriorityBadgeClass(project.DeliveryPriority.Name)">@project.DeliveryPriority.Name</span>
                                            </div>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(project.BusinessArea))
                                    {
                                        <div class="work-item-meta-row">
                                            <div class="work-item-meta-item">
                                                <span class="work-item-meta-label">Business Area</span>
                                                <span class="text-muted">@project.BusinessArea</span>
                                            </div>
                                        </div>
                                    }
                                    @{
                                        var upcomingCount = project.Milestones?.Count(m => !m.IsDeleted && m.DueDate >= DateTime.Today && m.DueDate <= DateTime.Today.AddDays(14)) ?? 0;
                                    }
                                    @if (upcomingCount > 0)
                                    {
                                        <div class="work-item-meta-row">
                                            <div class="work-item-meta-item">
