@model HomeDashboardViewModel
@using Compass.Models

@{
    ViewData["Title"] = "Compass control centre";
}

@section Styles {
    <style>
        .dashboard-static {
            margin-bottom: 1.5rem;
        }

        .metric-pill {
            border-radius: 14px;
            border: 1px solid rgba(15, 30, 90, 0.12);
            background: linear-gradient(145deg, #ffffff, #f8f9ff);
            padding: 1.25rem;
            height: 100%;
            box-shadow: 0 10px 18px rgba(12, 25, 64, 0.06);
        }

        .metric-pill strong {
            display: block;
            font-size: 2rem;
            line-height: 1.2;
        }

        .metric-pill span {
            color: #5c6480;
            font-size: 0.95rem;
        }

        .static-table thead th {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #7a819b;
            border-top: 0;
        }

        .static-table td {
            vertical-align: middle;
        }

        .leadership-panel {
            border-radius: 16px;
            border: 1px solid rgba(15, 30, 90, 0.12);
            padding: 1.5rem;
            background: linear-gradient(160deg, rgba(39, 76, 255, 0.08), rgba(39, 76, 255, 0));
        }

        .leadership-panel .badge {
            text-transform: none;
            font-weight: 500;
        }
    </style>
}

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        @{
            var staticMetrics = new[]
            {
                (Label: "Assigned actions", Count: Model.AssignedActions?.Count ?? 0),
                (Label: "Critical issues", Count: Model.HighPriorityIssues?.Count ?? 0),
                (Label: "Unreviewed risks", Count: Model.UnmonitoredRisks?.Count ?? 0),
                (Label: "Milestones this fortnight", Count: Model.MilestonesDueThisWeek?.Count ?? 0)
            };
            var myProjectRows = (Model.MyProjects ?? Array.Empty<Project>()).Take(6).ToList();
            var leadershipRows = (Model.OversightProjects ?? Array.Empty<Project>()).Take(6).ToList();
            var hasLeadershipScope = Model.LeadershipAssignments?.Any() ?? false;
            var highestRoleLabel = Model.HighestLeadershipRole switch
            {
                LeadershipRoleTier.PermanentSecretary => "Permanent Secretary",
                LeadershipRoleTier.DirectorGeneral => "Director General",
                LeadershipRoleTier.CLevel => "C-Level",
                LeadershipRoleTier.DeputyDirectorOrSro => "Deputy Director / SRO",
                LeadershipRoleTier.PortfolioLead => "Portfolio lead / G6",
                _ => "Leadership overview"
            };
        }

        <div class="card shadow-sm mb-4 dashboard-static">
            <div class="card-body">
                <div class="row">
                    @foreach (var metric in staticMetrics)
                    {
                        <div class="col-sm-6 col-lg-3 mb-3">
                            <div class="metric-pill">
                                <strong>@metric.Count</strong>
                                <span>@metric.Label</span>
                            </div>
                        </div>
                    }
                </div>

                <div class="row align-items-stretch">
                    <div class="col-lg-7">
                        <h3 class="h6 text-uppercase text-muted mt-2">My projects</h3>
                        @if (!myProjectRows.Any())
                        {
                            <p class="text-muted mb-0">You are not listed on any project teams yet.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm static-table">
                                    <thead>
                                        <tr>
                                            <th scope="col">Project</th>
                                            <th scope="col">RAG</th>
                                            <th scope="col">Business area</th>
                                            <th scope="col">Next milestone</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var project in myProjectRows)
                                        {
                                            var nextMilestone = project.Milestones?
                                                .Where(m => !m.IsDeleted && m.DueDate >= DateTime.Today)
                                                .OrderBy(m => m.DueDate)
                                                .FirstOrDefault();
                                            <tr>
                                                <td>@project.Title</td>
                                                <td>
                                                    <span class="badge badge-pill badge-light">@project.RagStatus</span>
                                                </td>
                                                <td>@project.BusinessArea</td>
                                                <td>
                                                    @if (nextMilestone != null)
                                                    {
                                                        @($"{nextMilestone.Name} – {nextMilestone.DueDate:dd MMM}")
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">No upcoming milestone</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                    <div class="col-lg-5 mt-4 mt-lg-0">
                        @if (hasLeadershipScope)
                        {
                            <div class="leadership-panel h-100 d-flex flex-column">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <h3 class="h6 text-uppercase text-muted mb-1">Business area oversight</h3>
                                        <strong>@highestRoleLabel</strong>
                                    </div>
                                    <div>
                                        @foreach (var area in Model.LeadershipBusinessAreas)
                                        {
                                            <span class="badge badge-primary mr-1 mb-1">@area</span>
                                        }
                                    </div>
                                </div>
                                @if (!leadershipRows.Any())
                                {
                                    <p class="text-muted mb-0">No live projects found in your business areas.</p>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm static-table mb-0">
                                            <thead>
                                                <tr>
                                                    <th scope="col">Project</th>
                                                    <th scope="col">RAG</th>
                                                    <th scope="col">Issues</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var project in leadershipRows)
                                                {
                                                    var openIssues = project.Issues?.Count(i => !i.IsDeleted && !string.Equals(i.Status, "closed", StringComparison.OrdinalIgnoreCase)) ?? 0;
                                                    <tr>
                                                        <td>@project.Title</td>
                                                        <td><span class="badge badge-light">@project.RagStatus</span></td>
                                                        <td>@openIssues</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="leadership-panel h-100 d-flex align-items-center">
                                <p class="mb-0 text-muted">When a user is given business area responsibility, their leadership overview will appear here.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
