@model HomeDashboardViewModel
@using Compass.Models
@using Compass.Services
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostEnvironment

@{
    ViewData["Title"] = "My dashboard";
    var hasProjects  = Model.MyProjects.Any();
    var hasProducts  = Model.MyProducts.Any();
    var hasStandards = Model.MyDdtStandards.Any();
    var hasOversight = Model.OversightProjects.Any();

    var overdueCount     = Model.OverdueMilestones.Count;
    var highIssueCount   = Model.HighPriorityIssues.Count;
    var atRiskCount      = Model.AtRiskProjects.Count;
    var updatesDueCount  = Model.ProjectsNeedingMonthlyUpdates.Count;
    var returnsDueCount  = Model.ProductsNeedingReturns.Count;
    var commissionCount  = Model.ProductsNeedingCommissionReporting.Count;
    var unmonRisksCount  = Model.UnmonitoredRisks.Count;
    var actionCount      = Model.AssignedActions.Count;

    var urgentCount = overdueCount + highIssueCount + atRiskCount;
    var taskCount   = overdueCount + highIssueCount + updatesDueCount + returnsDueCount + commissionCount + actionCount;
    var hasUrgent   = urgentCount > 0;

    // RAG breakdown of my projects
    var ragGroups = Model.MyProjects
        .GroupBy(p => p.RagStatusLookup?.Name ?? "Not set")
        .ToDictionary(g => g.Key, g => g.Count());
    int RagCount(string k) => ragGroups.TryGetValue(k, out var v) ? v : 0;

    // Phase breakdown
    var phaseGroups = Model.MyProjects
        .GroupBy(p => p.Phase ?? "Not set")
        .OrderBy(g => g.Key)
        .ToList();
}

@functions {
    string Greeting()
    {
        var h = DateTime.Now.Hour;
        return h < 12 ? "Good morning" : h < 17 ? "Good afternoon" : "Good evening";
    }

    string RagBadge(string? rag) => (rag ?? "") switch
    {
        "Green"       => "rag-green",
        "Amber-Green" => "rag-amber-green",
        "Amber"       => "rag-amber",
        "Amber-Red"   => "rag-amber-red",
        "Red"         => "rag-red",
        _             => "rag-not-set"
    };

    string RagBadgeClass(string? rag) => (rag ?? "") switch
    {
        "Green"       => "badge badge-success",
            "Amber-Green" => "badge badge-warning",
        "Amber"       => "badge badge-warning",
        "Amber-Red"   => "badge badge-danger",
        "Red"         => "badge badge-danger",
        _             => "badge badge-secondary"
    };

    string PriBadge(string? p) => (p?.ToLowerInvariant() ?? "") switch
    {
        "high"   => "badge badge-danger",
        "medium" => "badge badge-warning",
        "low"    => "badge badge-success",
        _        => "badge badge-secondary"
    };

    string RoleLabel(LeadershipRoleTier r) => r switch
    {
        LeadershipRoleTier.PermanentSecretary  => "Permanent Secretary",
        LeadershipRoleTier.DirectorGeneral     => "Director General",
        LeadershipRoleTier.CLevel              => "C-Level",
        LeadershipRoleTier.DeputyDirectorOrSro => "Deputy Director / SRO",
        LeadershipRoleTier.HeadOfProfession    => "Head of Profession",
        LeadershipRoleTier.PortfolioLead       => "Portfolio Lead / G6",
        _                                      => r.ToString()
    };
}

<style>
/* ── Reset / base ─────────────────────────────────────────────────────────── */
.hp { font-family: 'Inter', system-ui, sans-serif; color: #1f2937; }

/* ── Header ───────────────────────────────────────────────────────────────── */
.hp-header {
    background: linear-gradient(135deg, #003078 0%, #005ea5 55%, #1d70b8 100%);
    border-radius: 14px;
    padding: 1.75rem 2rem;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    box-shadow: 0 4px 20px rgba(0,48,120,0.18);
}
.hp-header-left h1 {
    color: white;
    font-size: 1.65rem;
    font-weight: 700;
    margin: 0 0 0.3rem;
    line-height: 1.2;
}
.hp-header-left p {
    color: rgba(255,255,255,0.8);
    margin: 0;
    font-size: 0.88rem;
}
.hp-header-pills {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
    margin-top: 0.25rem;
}
.hp-pill {
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 20px;
    padding: 0.3rem 0.85rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: white;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
}
.hp-pill:hover { background: rgba(255,255,255,0.28); color: white; text-decoration: none; }
.hp-pill i { margin-right: 0.3rem; }

/* ── Urgent banner ────────────────────────────────────────────────────────── */
.hp-urgent {
    background: #fff7ed;
    border: 1px solid #fed7aa;
    border-left: 4px solid #ea580c;
    border-radius: 10px;
    padding: 0.85rem 1.25rem;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.875rem;
}
.hp-urgent i { color: #ea580c; font-size: 1rem; margin-top: 0.1rem; flex-shrink: 0; }
.hp-urgent strong { color: #9a3412; }
.hp-urgent-items { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.35rem; }
.hp-urgent-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: #fee2e2;
    color: #b91c1c;
    border-radius: 20px;
    padding: 0.2rem 0.65rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.1s;
}
.hp-urgent-chip:hover { background: #fecaca; color: #991b1b; text-decoration: none; }
.hp-urgent-chip.amber { background: #fef3c7; color: #92400e; }
.hp-urgent-chip.amber:hover { background: #fde68a; color: #78350f; }

/* ── Stat row ─────────────────────────────────────────────────────────────── */
.hp-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.875rem;
    margin-bottom: 1.5rem;
}
.hp-stat {
    border-radius: 12px;
    padding: 1rem 1.1rem;
    color: white;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    display: block;
    transition: transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
}
.hp-stat:hover { transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,0.16); color: white; text-decoration: none; }
.hp-stat-val  { font-size: 1.9rem; font-weight: 700; line-height: 1; }
.hp-stat-lbl  { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; opacity: 0.9; margin-top: 0.2rem; }
.hp-stat-sub  { font-size: 0.72rem; opacity: 0.72; margin-top: 0.15rem; }
.hp-stat-ico  { position: absolute; right: 0.9rem; top: 50%; transform: translateY(-50%); font-size: 2.2rem; opacity: 0.13; }
.c-blue   { background: linear-gradient(135deg, #005ea5, #003078); }
.c-red    { background: linear-gradient(135deg, #d4351c, #aa2a12); }
.c-amber  { background: linear-gradient(135deg, #b45309, #d97706); }
.c-green  { background: linear-gradient(135deg, #00703c, #005a30); }
.c-teal   { background: linear-gradient(135deg, #0f766e, #0d9488); }
.c-purple { background: linear-gradient(135deg, #4a1d96, #7c3aed); }
.c-slate  { background: linear-gradient(135deg, #475569, #334155); }
.c-indigo { background: linear-gradient(135deg, #3730a3, #4f46e5); }

/* ── Two-column layout ────────────────────────────────────────────────────── */
.hp-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 1.25rem;
    align-items: start;
}
@@media (max-width: 1080px) { .hp-layout { grid-template-columns: 1fr; } }

/* ── Section card ─────────────────────────────────────────────────────────── */
.hp-card {
    background: white;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    margin-bottom: 1.25rem;
    overflow: hidden;
}
.hp-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid #f3f4f6;
}
.hp-card-head h2 {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 700;
    color: #1f2937;
    display: flex;
    align-items: center;
    gap: 0.45rem;
}
.hp-card-head h2 i { color: #005ea5; font-size: 0.85rem; }
.hp-card-head a { font-size: 0.78rem; color: #005ea5; text-decoration: none; font-weight: 500; }
.hp-card-head a:hover { text-decoration: underline; }
.hp-card-body { padding: 0.75rem 1.25rem; }

/* ── Tabs ─────────────────────────────────────────────────────────────────── */
.hp-tabs {
    display: flex;
    gap: 0;
    border-bottom: 2px solid #f3f4f6;
    overflow-x: auto;
    scrollbar-width: none;
    padding: 0 1.25rem;
}
.hp-tabs::-webkit-scrollbar { display: none; }
.hp-tab {
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    margin-bottom: -2px;
    padding: 0.6rem 0.9rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #6b7280;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.12s, border-color 0.12s;
}
.hp-tab:hover { color: #005ea5; }
.hp-tab.active { color: #005ea5; border-bottom-color: #005ea5; }
.hp-tab .cnt {
    display: inline-block;
    background: #f3f4f6;
    color: #374151;
    border-radius: 10px;
    font-size: 0.68rem;
    padding: 0.05rem 0.4rem;
    margin-left: 0.25rem;
    font-weight: 700;
}
.hp-tab.active .cnt { background: #dbeafe; color: #1d4ed8; }
.hp-tab .cnt.hot { background: #fee2e2; color: #b91c1c; }
.hp-pane { display: none; padding: 1rem 1.25rem; }
.hp-pane.active { display: block; }

/* ── Item rows ────────────────────────────────────────────────────────────── */
.hp-rows { display: flex; flex-direction: column; gap: 0.5rem; }
.hp-row {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.65rem 0.8rem;
    border-radius: 8px;
    border: 1px solid #f3f4f6;
    background: white;
    text-decoration: none;
    color: inherit;
    transition: background 0.1s, border-color 0.1s;
}
.hp-row:hover { background: #f0f7ff; border-color: #bfdbfe; color: inherit; text-decoration: none; }
.hp-row.r-red    { border-left: 3px solid #d4351c; }
.hp-row.r-amber  { border-left: 3px solid #f47738; }
.hp-row.r-green  { border-left: 3px solid #00703c; }
.hp-ico {
    width: 30px; height: 30px; border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.78rem; flex-shrink: 0; color: white;
}
.i-red    { background: #d4351c; }
.i-amber  { background: #f47738; }
.i-blue   { background: #005ea5; }
.i-green  { background: #00703c; }
.i-purple { background: #7c3aed; }
.i-teal   { background: #0d9488; }
.i-slate  { background: #475569; }
.i-indigo { background: #4f46e5; }
.hp-row-body { flex: 1; min-width: 0; }
.hp-row-title { font-weight: 600; font-size: 0.85rem; color: #1f2937; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.hp-row-sub   { font-size: 0.75rem; color: #6b7280; margin-top: 0.05rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.hp-row-meta  { display: flex; gap: 0.35rem; align-items: center; flex-shrink: 0; flex-wrap: wrap; }

/* ── View-all row ─────────────────────────────────────────────────────────── */
.hp-more {
    text-align: center;
    padding-top: 0.65rem;
    border-top: 1px solid #f3f4f6;
    margin-top: 0.35rem;
}
.hp-more a { font-size: 0.78rem; color: #005ea5; font-weight: 500; text-decoration: none; }
.hp-more a:hover { text-decoration: underline; }

/* ── Empty state ──────────────────────────────────────────────────────────── */
.hp-empty { text-align: center; padding: 2rem 1rem; color: #9ca3af; }
.hp-empty-ico { font-size: 2rem; margin-bottom: 0.5rem; }
.hp-empty h3 { font-size: 0.9rem; color: #6b7280; margin-bottom: 0.25rem; }
.hp-empty p  { font-size: 0.8rem; margin: 0; }

/* ── RAG mini-bar ─────────────────────────────────────────────────────────── */
.rag-bar { display: flex; height: 8px; border-radius: 4px; overflow: hidden; gap: 2px; margin: 0.5rem 0; }
.rag-seg { border-radius: 3px; transition: flex 0.3s; }
.rag-green      { background: #00703c; }
.rag-amber-green{ background: #85994b; }
.rag-amber      { background: #f47738; }
.rag-amber-red  { background: #d4351c; opacity: 0.7; }
.rag-red        { background: #d4351c; }
.rag-not-set    { background: #d1d5db; }

/* ── Sidebar widgets ──────────────────────────────────────────────────────── */
.hp-widget {
    background: white;
    border-radius: 12px;
    border: 1px solid #e5e7eb;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    margin-bottom: 1.1rem;
    overflow: hidden;
}
.hp-widget-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #f3f4f6;
    background: #fafafa;
}
.hp-widget-head h3 {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 700;
    color: #374151;
    display: flex;
    align-items: center;
    gap: 0.4rem;
}
.hp-widget-head h3 i { color: #005ea5; }
.hp-widget-head a { font-size: 0.75rem; color: #005ea5; text-decoration: none; }
.hp-widget-head a:hover { text-decoration: underline; }
.hp-widget-body { padding: 0.6rem 1rem; }

.hp-stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.38rem 0;
    border-bottom: 1px solid #f9fafb;
    font-size: 0.8rem;
}
.hp-stat-row:last-child { border-bottom: none; }
.hp-stat-row-lbl { color: #6b7280; }
.hp-stat-row-val { font-weight: 700; color: #1f2937; }

.hp-mini-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0;
    border-bottom: 1px solid #f9fafb;
    font-size: 0.8rem;
}
.hp-mini-row:last-child { border-bottom: none; }
.hp-mini-row a { color: #1f2937; font-weight: 600; text-decoration: none; flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.hp-mini-row a:hover { color: #005ea5; text-decoration: underline; }
.hp-mini-date { font-size: 0.72rem; color: #9ca3af; flex-shrink: 0; min-width: 38px; }

/* ── Reminder cards ───────────────────────────────────────────────────────── */
.hp-reminder {
    display: flex;
    gap: 0.65rem;
    padding: 0.65rem 0;
    border-bottom: 1px solid #f3f4f6;
    font-size: 0.8rem;
}
.hp-reminder:last-child { border-bottom: none; }
.hp-reminder-ico {
    width: 28px; height: 28px; border-radius: 6px;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem; flex-shrink: 0; color: white;
}
.hp-reminder-body { flex: 1; min-width: 0; }
.hp-reminder-title { font-weight: 600; color: #1f2937; margin-bottom: 0.1rem; }
.hp-reminder-desc  { color: #6b7280; font-size: 0.75rem; }
.hp-reminder-link  { font-size: 0.75rem; color: #005ea5; text-decoration: none; font-weight: 500; }
.hp-reminder-link:hover { text-decoration: underline; }
.hp-freq {
    display: inline-block;
    background: #f3f4f6;
    color: #6b7280;
    border-radius: 4px;
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.1rem 0.35rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    flex-shrink: 0;
    align-self: flex-start;
    margin-top: 0.15rem;
}

/* ── Success items ────────────────────────────────────────────────────────── */
.hp-success {
    display: flex;
    gap: 0.6rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid #f3f4f6;
    font-size: 0.8rem;
    align-items: flex-start;
}
.hp-success:last-child { border-bottom: none; }
.hp-success-dot { width: 8px; height: 8px; border-radius: 50%; background: #00703c; flex-shrink: 0; margin-top: 0.35rem; }
.hp-success-body { flex: 1; min-width: 0; }
.hp-success-title { font-weight: 600; color: #1f2937; }
.hp-success-proj  { font-size: 0.73rem; color: #6b7280; }

/* ── Oversight section ────────────────────────────────────────────────────── */
.hp-oversight-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 0.6rem;
    margin-bottom: 0.75rem;
}
.hp-oversight-metric {
    background: #f8fafc;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 0.65rem 0.85rem;
    text-align: center;
}
.hp-oversight-metric strong { display: block; font-size: 1.4rem; font-weight: 700; color: #1f2937; }
.hp-oversight-metric span   { font-size: 0.72rem; color: #6b7280; }

/* ── Quick actions ────────────────────────────────────────────────────────── */
.hp-actions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
}
.hp-action-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.75rem;
    border-radius: 8px;
    border: 1px solid #e5e7eb;
    background: white;
    font-size: 0.78rem;
    font-weight: 600;
    color: #374151;
    text-decoration: none;
    transition: background 0.1s, border-color 0.1s;
}
.hp-action-btn:hover { background: #f0f7ff; border-color: #93c5fd; color: #1d4ed8; text-decoration: none; }
.hp-action-btn i { color: #005ea5; font-size: 0.85rem; width: 16px; text-align: center; }

/* ── Path-to-green alert ──────────────────────────────────────────────────── */
.hp-ptg-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid #f9fafb;
    font-size: 0.8rem;
}
.hp-ptg-row:last-child { border-bottom: none; }
.hp-ptg-row a { color: #1f2937; font-weight: 600; text-decoration: none; flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.hp-ptg-row a:hover { color: #005ea5; text-decoration: underline; }
</style>

<div class="hp">
<section class="content mt-3">
    <div class="container-fluid">

        @if (TempData["SuccessMessage"] != null)
        {
        <div class="alert alert-success alert-dismissible fade show mb-3">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
        <div class="alert alert-danger alert-dismissible fade show mb-3">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

    <!-- ── Header ──────────────────────────────────────────────────────────── -->
    <div class="hp-header">
        <div class="hp-header-left">
            <h1>@Greeting(), @Model.FirstName</h1>
            <p>@DateTime.Today.ToString("dddd d MMMM yyyy")</p>
            <div class="hp-header-pills mt-2">
                @if (hasProjects)
                {
                    <a href="@Url.Action("Index","Project")" class="hp-pill"><i class="fas fa-project-diagram"></i>@Model.MyProjects.Count project@(Model.MyProjects.Count == 1 ? "" : "s")</a>
                }
                @if (hasProducts)
                {
                    <a href="@Url.Action("Index","Products")" class="hp-pill"><i class="fas fa-box"></i>@Model.MyProducts.Count product@(Model.MyProducts.Count == 1 ? "" : "s")</a>
                }
                @if (hasStandards)
                {
                    <a href="@Url.Action("Dashboard","DdtStandards")" class="hp-pill"><i class="fas fa-book"></i>@Model.MyDdtStandards.Count standard@(Model.MyDdtStandards.Count == 1 ? "" : "s")</a>
                }
                @if (Model.HighestLeadershipRole.HasValue)
                {
                    <span class="hp-pill"><i class="fas fa-user-tie"></i>@RoleLabel(Model.HighestLeadershipRole.Value)</span>
                }
            </div>
        </div>
        <div class="d-flex flex-column align-items-end gap-2">
            <a href="@Url.Action("Index","Reports")" class="hp-pill" style="font-size:0.82rem;">
                <i class="fas fa-chart-bar"></i> Reports
            </a>
            @if (taskCount > 0)
            {
                <span class="hp-pill" style="background:rgba(212,53,28,0.25); border-color:rgba(212,53,28,0.5);">
                    <i class="fas fa-bell"></i> @taskCount task@(taskCount == 1 ? "" : "s") need attention
                </span>
            }
        </div>
        </div>

    <!-- ── Urgent banner ───────────────────────────────────────────────────── -->
    @if (hasUrgent || updatesDueCount > 0 || returnsDueCount > 0 || commissionCount > 0)
    {
        <div class="hp-urgent" role="alert">
            <i class="fas fa-exclamation-circle" aria-hidden="true"></i>
            <div style="flex:1;">
                <strong>Needs your attention</strong>
                <div class="hp-urgent-items">
                    @if (overdueCount > 0)
                    {
                        <a href="@Url.Action("Index","Project")" class="hp-urgent-chip">
                            <i class="fas fa-flag-checkered" aria-hidden="true"></i>
                            @overdueCount overdue milestone@(overdueCount == 1 ? "" : "s")
                </a>
            }
                    @if (highIssueCount > 0)
                    {
                        <a href="@Url.Action("Index","Raid", new { viewType = "issues" })" class="hp-urgent-chip">
                            <i class="fas fa-bug" aria-hidden="true"></i>
                            @highIssueCount high-priority issue@(highIssueCount == 1 ? "" : "s")
                </a>
            }
                    @if (atRiskCount > 0)
                    {
                        <a href="@Url.Action("Index","Project")" class="hp-urgent-chip">
