                                            </td>
                                            <td>
                                                @if (milestone.ProgressPercent.HasValue)
                                                {
                                                    <div class="progress" style="height: 22px;">
                                                        <div class="progress-bar @progressClass" role="progressbar" 
                                                             style="width: @milestone.ProgressPercent%;" 
                                                             aria-valuenow="@milestone.ProgressPercent" 
                                                             aria-valuemin="0" 
                                                             aria-valuemax="100">
                                                            <small>@milestone.ProgressPercent%</small>
                                                        </div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Not set</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="@(isOverdue ? "text-danger font-weight-bold" : isUrgent ? "text-warning font-weight-bold" : "")">
                                                    @if (isOverdue)
                                                    {
                                                        <i class="fas fa-clock mr-1"></i>
                                                    }
                                                    @milestone.DueDate.ToString("dd MMM yyyy")
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <a href="/Milestone/Edit/@milestone.Id" class="btn btn-xs btn-outline-primary" title="Edit milestone">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="card-footer text-muted">
                            Showing @Model.MyMilestones.Count of @Model.TotalMilestones total milestone@(Model.TotalMilestones != 1 ? "s" : "")
                        </div>
                    </div>
                }
                @if (currentView == "milestones" && !Model.MyMilestones.Any())
                {
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <i class="fas fa-flag-checkered fa-4x text-muted mb-3"></i>
                            <h4>No milestones found</h4>
                            @if (!string.IsNullOrEmpty(statusFilter) || dateFilter != "all")
                            {
                                <p class="text-muted">No milestones match the current filters.</p>
                                <a href="/?view=milestones" class="btn btn-primary">
                                    <i class="fas fa-times mr-2"></i> Clear filters
                                </a>
                            }
                            else
                            {
                                <p class="text-muted">You don't have any milestones assigned to you.</p>
                                <a href="/Milestone/Create" class="btn btn-success">
                                    <i class="fas fa-plus mr-2"></i> Create your first milestone
                                </a>
                            }
                        </div>
                    </div>
                }

            </div> <!-- /col-12 -->
        </div> <!-- /row -->
    </div> <!-- /container-fluid -->
</section>

@* ====================================================================== *@
@* HELPER FUNCTIONS                                                       *@
@* Reusable methods for badge classes, date checks, etc.                 *@
@* ====================================================================== *@
@functions {
    // Badge class helpers
    string GetSeverityBadgeClass(string severity)
    {
        return severity switch
        {
            "critical" => "badge-danger",
            "high" => "badge-warning",
            "medium" => "badge-info",
            "low" => "badge-secondary",
            _ => "badge-secondary"
        };
    }

    string GetIssueStatusBadgeClass(string status)
    {
        return status switch
        {
            "open" => "badge-info",
            "in_progress" => "badge-primary",
            "blocked" => "badge-danger",
            "resolved" => "badge-success",
            "closed" => "badge-secondary",
            _ => "badge-secondary"
        };
    }

    string GetRiskScoreBadgeClass(int? score)
    {
        return score switch
        {
            >= 15 => "badge-danger",
            >= 10 => "badge-warning",
            >= 5 => "badge-info",
            _ => "badge-secondary"
        };
    }

    string GetRiskStatusBadgeClass(string status)
    {
        return status switch
        {
            "new" => "badge-info",
            "open" => "badge-warning",
            "treating" => "badge-primary",
            "monitoring" => "badge-secondary",
            "closed" => "badge-success",
            _ => "badge-secondary"
        };
    }

    string GetPriorityBadgeClass(string priority)
    {
        return priority switch
        {
            "high" => "badge-danger",
            "medium" => "badge-warning",
            "low" => "badge-secondary",
            _ => "badge-secondary"
        };
    }

    string GetActionStatusBadgeClass(string status)
    {
        return status switch
        {
            "not_started" => "badge-secondary",
            "in_progress" => "badge-primary",
            "blocked" => "badge-danger",
            "done" => "badge-success",
            "cancelled" => "badge-dark",
            _ => "badge-secondary"
        };
    }

    string GetMilestoneStatusBadgeClass(string status)
    {
        return status switch
        {
            "not_started" => "badge-secondary",
            "on_track" => "badge-success",
            "at_risk" => "badge-warning",
            "delayed" => "badge-danger",
            "complete" => "badge-primary",
            "cancelled" => "badge-dark",
            _ => "badge-secondary"
        };
    }

    string GetProgressBarClass(int? percent)
    {
        return percent switch
        {
            >= 75 => "bg-success",
            >= 50 => "bg-info",
            >= 25 => "bg-warning",
            _ => "bg-danger"
        };
    }

    // Date and status helpers
    bool IsOverdue(DateTime? targetDate, string status, string[] completedStatuses)
    {
        if (!targetDate.HasValue) return false;
        if (completedStatuses.Contains(status)) return false;
        return targetDate.Value < DateTime.UtcNow;
    }

    bool IsUrgent(DateTime? targetDate, string status, string[] completedStatuses, int daysThreshold = 7)
    {
        if (!targetDate.HasValue) return false;
        if (completedStatuses.Contains(status)) return false;
        return targetDate.Value <= DateTime.UtcNow.AddDays(daysThreshold);
    }
}

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Handle clickable boxes
            $('.clickable-box').on('click', function(e) {
                // Don't navigate if clicking on a link
                if (e.target.tagName !== 'A') {
                    window.location.href = $(this).data('href');
                }
            });

            // Auto-submit form on filter change
            $('.auto-submit').on('change', function() {
                $(this).closest('form').submit();
            });
        });
    </script>
}
