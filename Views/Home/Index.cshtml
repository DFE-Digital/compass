@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        (function() {
            // Get saved view preference or default to 'cards'
            function getViewPreference() {
                return localStorage.getItem('homeWorkViewPreference') || 'cards';
            }

            function saveViewPreference(view) {
                localStorage.setItem('homeWorkViewPreference', view);
            }

            function toggleView(view) {
                // Update toggle buttons
                document.querySelectorAll('.view-toggle-btn').forEach(function(btn) {
                    btn.classList.remove('active');
                    if (btn.getAttribute('data-view') === view) {
                        btn.classList.add('active');
                    }
                });

                // Update all tab views
                document.querySelectorAll('.tab-content').forEach(function(tab) {
                    var cardsView = tab.querySelector('.work-items-grid[data-view="cards"]');
                    var listView = tab.querySelector('.work-items-list[data-view="list"]');
                    
                    if (cardsView && listView) {
                        if (view === 'cards') {
                            cardsView.classList.add('active');
                            listView.classList.remove('active');
                        } else {
                            cardsView.classList.remove('active');
                            listView.classList.add('active');
                        }
                    }
                });

                saveViewPreference(view);
            }

            // Initialize view from preference
            var initialView = getViewPreference();
            toggleView(initialView);

            // View toggle buttons
            document.querySelectorAll('.view-toggle-btn').forEach(function(button) {
                button.addEventListener('click', function() {
                    var view = this.getAttribute('data-view');
                    toggleView(view);
                });
            });

            // Tab switching
            document.querySelectorAll('.tab-button').forEach(function(button) {
                button.addEventListener('click', function() {
                    var tabName = this.getAttribute('data-tab');
                    
                    // Remove active class from all buttons and tabs
                    document.querySelectorAll('.tab-button').forEach(function(btn) {
                        btn.classList.remove('active');
                    });
                    document.querySelectorAll('.tab-content').forEach(function(tab) {
                        tab.classList.remove('active');
                    });
                    
                    // Add active class to clicked button and corresponding tab
                    this.classList.add('active');
                    document.getElementById('tab-' + tabName).classList.add('active');
                });
            });

            // Test User Selector (Development Only)
            function loadTestUsers() {
                var testUserSelect = document.getElementById('testUserSelect');
                if (!testUserSelect) {
                    return;
                }

                fetch('@Url.Action("GetTestUsers", "Home")')
                    .then(function(response) {
                        if (!response.ok) {
                            console.warn('Test users endpoint returned status:', response.status);
                            return [];
                        }
                        return response.json();
                    })
                    .then(function(users) {
                        if (!users || users.length === 0) {
                            var option = document.createElement('option');
                            option.value = '0';
                            option.textContent = 'No users available';
                            option.disabled = true;
                            testUserSelect.appendChild(option);
                            return;
                        }

                        var currentTestUserId = '@(Context.Request.Cookies["TestDashboardUserId"])';
                        users.forEach(function(user) {
                            var option = document.createElement('option');
                            option.value = user.id;
                            option.textContent = user.name + ' (' + user.email + ')';
                            if (currentTestUserId && currentTestUserId === user.id.toString()) {
                                option.selected = true;
                            }
                            testUserSelect.appendChild(option);
                        });
                    })
                    .catch(function(error) {
                        console.error('Error loading test users:', error);
                        var option = document.createElement('option');
                        option.value = '0';
                        option.textContent = 'Unable to load users';
                        option.disabled = true;
                        testUserSelect.appendChild(option);
                    });
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', loadTestUsers);
            } else {
                loadTestUsers();
            }
        })();
    </script>
}
