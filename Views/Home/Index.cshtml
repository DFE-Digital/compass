@*
    Dashboard Home View - Overhauled for better usability
    
    Key features:
    - Horizontal tab navigation for space efficiency
    - Inline filters always visible
    - Quick action buttons for common tasks
    - Priority-based color coding
    - Search functionality
    - Better insights and summaries
    - Improved mobile responsiveness
*@
@model Compass.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var userName = Model.CurrentUser?.Name ?? User.Identity?.Name ?? "User";
    var userEmail = User.Identity?.Name ?? "";
    var currentView = ViewBag.CurrentView as string ?? "overview";
    var statusFilter = ViewBag.StatusFilter as string;
    var priorityFilter = ViewBag.PriorityFilter as string;
    var dateFilter = ViewBag.DateFilter as string ?? "all";
    
    // Calculate urgent items
    var overdueIssues = Model.MyIssues.Count(i => IsOverdue(i.TargetResolutionDate, i.Status, new[] { "resolved", "closed" }));
    var overdueActions = Model.MyActions.Count(a => IsOverdue(a.DueDate, a.Status, new[] { "done", "cancelled" }));
    var overdueRisks = Model.MyRisks.Count(r => IsOverdue(r.TargetDate, r.Status, new[] { "closed" }));
    var overdueMilestones = Model.MyMilestones.Count(m => IsOverdue(m.DueDate, m.Status, new[] { "complete", "cancelled" }));
    var totalOverdue = overdueIssues + overdueActions + overdueRisks + overdueMilestones;
}

<div class="content-header pb-2">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-sm-8">
                <h1 class="m-0">Dashboard</h1>
                <p class="text-muted mb-0">Welcome back, @userName</p>
            </div>
            <div class="col-sm-4 text-right">
                @if (totalOverdue > 0)
                {
                    <span class="badge badge-danger badge-lg px-3 py-2">
                        <i class="fas fa-exclamation-triangle mr-1"></i>
                        @totalOverdue overdue item@(totalOverdue != 1 ? "s" : "")
                    </span>
                }
                else if (Model.UrgentActions + Model.UrgentMilestones > 0)
                {
                    <span class="badge badge-warning badge-lg px-3 py-2">
                        <i class="fas fa-clock mr-1"></i>
                        @(Model.UrgentActions + Model.UrgentMilestones) urgent item@((Model.UrgentActions + Model.UrgentMilestones) != 1 ? "s" : "")
                    </span>
                }
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <!-- ============================================================ -->
        <!-- NAVIGATION TABS -->
        <!-- ============================================================ -->
        <div class="card card-tabs">
            <div class="card-header p-0 border-bottom-0">
                <ul class="nav nav-tabs" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link @(currentView == "overview" ? "active" : "")" href="/?view=overview">
                            <i class="fas fa-chart-line mr-1"></i>
                            Overview
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentView == "products" ? "active" : "")" href="/?view=products">
                            <i class="fas fa-box mr-1"></i>
                            Products
                            <span class="badge badge-info ml-1">@Model.TotalProducts</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentView == "issues" ? "active" : "")" href="/?view=issues">
                            <i class="fas fa-exclamation-triangle mr-1"></i>
                            Issues
                            @if (Model.OpenIssues > 0)
                            {
                                <span class="badge badge-warning ml-1">@Model.OpenIssues</span>
                            }
                            @if (overdueIssues > 0)
                            {
                                <span class="badge badge-danger ml-1"><i class="fas fa-clock"></i> @overdueIssues</span>
                            }
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentView == "risks" ? "active" : "")" href="/?view=risks">
                            <i class="fas fa-shield-alt mr-1"></i>
                            Risks
                            @if (Model.ActiveRisks > 0)
                            {
                                <span class="badge badge-danger ml-1">@Model.ActiveRisks</span>
                            }
                            @if (overdueRisks > 0)
                            {
                                <span class="badge badge-dark ml-1"><i class="fas fa-clock"></i> @overdueRisks</span>
                            }
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentView == "actions" ? "active" : "")" href="/?view=actions">
                            <i class="fas fa-tasks mr-1"></i>
                            Actions
                            @if (Model.UrgentActions > 0)
                            {
                                <span class="badge badge-warning ml-1">@Model.UrgentActions</span>
                            }
                            @if (overdueActions > 0)
                            {
                                <span class="badge badge-danger ml-1"><i class="fas fa-clock"></i> @overdueActions</span>
                            }
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentView == "milestones" ? "active" : "")" href="/?view=milestones">
                            <i class="fas fa-flag-checkered mr-1"></i>
                            Milestones
                            @if (Model.UrgentMilestones > 0)
                            {
                                <span class="badge badge-warning ml-1">@Model.UrgentMilestones</span>
                            }
                            @if (overdueMilestones > 0)
                            {
                                <span class="badge badge-danger ml-1"><i class="fas fa-clock"></i> @overdueMilestones</span>
                            }
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <!-- ============================================================ -->
        <!-- INLINE FILTERS (for non-overview views) -->
        <!-- ============================================================ -->
        @if (currentView != "overview" && currentView != "products")
        {
            <div class="card">
                <div class="card-body pb-2">
                    <form method="get" action="/" id="filterForm" class="form-inline">
                        <input type="hidden" name="view" value="@currentView" />
                        
                        <div class="form-group mr-2 mb-2">
                            <label class="mr-2 font-weight-bold">Filters:</label>
                        </div>

                        <!-- Date Filter -->
                        <div class="form-group mr-3 mb-2">
                            <label class="mr-2 text-muted"><small>Time period</small></label>
                            <select name="dateFilter" class="form-control form-control-sm auto-submit" style="width: auto;">
                                <option value="all" selected="@(dateFilter == "all")">All time</option>
                                <option value="overdue" selected="@(dateFilter == "overdue")">Overdue only</option>
                                <option value="today" selected="@(dateFilter == "today")">Due today</option>
                                <option value="week" selected="@(dateFilter == "week")">Due this week</option>
                                <option value="month" selected="@(dateFilter == "month")">Due this month</option>
                                <option value="next_month" selected="@(dateFilter == "next_month")">Due next month</option>
                            </select>
                        </div>

                        @if (currentView == "issues")
                        {
                            <div class="form-group mr-3 mb-2">
                                <label class="mr-2 text-muted"><small>Status</small></label>
                                <select name="statusFilter" class="form-control form-control-sm auto-submit" style="width: auto;">
                                    <option value="">All</option>
                                    <option value="open" selected="@(statusFilter == "open")">Open</option>
                                    <option value="in_progress" selected="@(statusFilter == "in_progress")">In progress</option>
                                    <option value="blocked" selected="@(statusFilter == "blocked")">Blocked</option>
                                    <option value="resolved" selected="@(statusFilter == "resolved")">Resolved</option>
                                    <option value="closed" selected="@(statusFilter == "closed")">Closed</option>
                                </select>
                            </div>
                            
                            <div class="form-group mr-3 mb-2">
                                <label class="mr-2 text-muted"><small>Severity</small></label>
                                <select name="priorityFilter" class="form-control form-control-sm auto-submit" style="width: auto;">
                                    <option value="">All</option>
                                    <option value="critical" selected="@(priorityFilter == "critical")">Critical</option>
                                    <option value="high" selected="@(priorityFilter == "high")">High</option>
                                    <option value="medium" selected="@(priorityFilter == "medium")">Medium</option>
                                    <option value="low" selected="@(priorityFilter == "low")">Low</option>
                                </select>
                            </div>
                        }

                        @if (currentView == "risks")
                        {
                            <div class="form-group mr-3 mb-2">
                                <label class="mr-2 text-muted"><small>Status</small></label>
                                <select name="statusFilter" class="form-control form-control-sm auto-submit" style="width: auto;">
                                    <option value="">All</option>
                                    <option value="new" selected="@(statusFilter == "new")">New</option>
                                    <option value="open" selected="@(statusFilter == "open")">Open</option>
                                    <option value="treating" selected="@(statusFilter == "treating")">Treating</option>
                                    <option value="monitoring" selected="@(statusFilter == "monitoring")">Monitoring</option>
                                    <option value="closed" selected="@(statusFilter == "closed")">Closed</option>
                                </select>
                            </div>
                            
                            <div class="form-group mr-3 mb-2">
                                <label class="mr-2 text-muted"><small>Risk score</small></label>
                                <select name="priorityFilter" class="form-control form-control-sm auto-submit" style="width: auto;">
                                    <option value="">All</option>
                                    <option value="critical" selected="@(priorityFilter == "critical")">Critical (15-25)</option>
                                    <option value="high" selected="@(priorityFilter == "high")">High (10-14)</option>
                                    <option value="medium" selected="@(priorityFilter == "medium")">Medium (5-9)</option>
                                    <option value="low" selected="@(priorityFilter == "low")">Low (1-4)</option>
                                </select>
                            </div>
                        }

                        @if (currentView == "actions")
                        {
                            <div class="form-group mr-3 mb-2">
                                <label class="mr-2 text-muted"><small>Status</small></label>
                                <select name="statusFilter" class="form-control form-control-sm auto-submit" style="width: auto;">
                                    <option value="">All</option>
                                    <option value="not_started" selected="@(statusFilter == "not_started")">Not started</option>
                                    <option value="in_progress" selected="@(statusFilter == "in_progress")">In progress</option>
                                    <option value="blocked" selected="@(statusFilter == "blocked")">Blocked</option>
                                    <option value="done" selected="@(statusFilter == "done")">Done</option>
                                    <option value="cancelled" selected="@(statusFilter == "cancelled")">Cancelled</option>
                                </select>
                            </div>
                            
                            <div class="form-group mr-3 mb-2">
                                <label class="mr-2 text-muted"><small>Priority</small></label>
                                <select name="priorityFilter" class="form-control form-control-sm auto-submit" style="width: auto;">
                                    <option value="">All</option>
                                    <option value="high" selected="@(priorityFilter == "high")">High</option>
                                    <option value="medium" selected="@(priorityFilter == "medium")">Medium</option>
                                    <option value="low" selected="@(priorityFilter == "low")">Low</option>
                                </select>
                            </div>
                        }

                        @if (currentView == "milestones")
                        {
                            <div class="form-group mr-3 mb-2">
                                <label class="mr-2 text-muted"><small>Status</small></label>
                                <select name="statusFilter" class="form-control form-control-sm auto-submit" style="width: auto;">
                                    <option value="">All</option>
                                    <option value="not_started" selected="@(statusFilter == "not_started")">Not started</option>
                                    <option value="on_track" selected="@(statusFilter == "on_track")">On track</option>
                                    <option value="at_risk" selected="@(statusFilter == "at_risk")">At risk</option>
                                    <option value="delayed" selected="@(statusFilter == "delayed")">Delayed</option>
                                    <option value="complete" selected="@(statusFilter == "complete")">Complete</option>
                                    <option value="cancelled" selected="@(statusFilter == "cancelled")">Cancelled</option>
                                </select>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(statusFilter) || !string.IsNullOrEmpty(priorityFilter) || dateFilter != "all")
                        {
                            <div class="form-group mb-2">
                                <a href="/?view=@currentView" class="btn btn-sm btn-default">
                                    <i class="fas fa-times mr-1"></i> Clear filters
                                </a>
                            </div>
                        }
                    </form>
                </div>
            </div>
        }

        <!-- Main content area -->
        <div class="row">
            <div class="col-12">

                <!-- ============================================================ -->
                <!-- OVERVIEW VIEW -->
                <!-- ============================================================ -->
                @if (currentView == "overview")
                {
                    <!-- Quick Stats Cards -->
                    <div class="row">
                        <div class="col-lg-3 col-md-6 col-12">
                            <div class="info-box clickable-box" style="cursor: pointer;" data-href="/?view=products">
                                <span class="info-box-icon bg-info"><i class="fas fa-box"></i></span>
                                <div class="info-box-content">
                                    <span class="info-box-text">My products</span>
                                    <span class="info-box-number">@Model.TotalProducts</span>
                                    <small class="text-muted">Product contact</small>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-lg-3 col-md-6 col-12">
                            <div class="info-box clickable-box" style="cursor: pointer;" data-href="/?view=issues">
                                <span class="info-box-icon bg-@(overdueIssues > 0 ? "danger" : Model.OpenIssues > 0 ? "warning" : "success")">
                                    <i class="fas fa-exclamation-triangle"></i>
                                </span>
                                <div class="info-box-content">
                                    <span class="info-box-text">My issues</span>
                                    <span class="info-box-number">
                                        @Model.OpenIssues <small class="text-muted">/ @Model.TotalIssues total</small>
                                    </span>
                                    @if (overdueIssues > 0)
                                    {
                                        <small class="text-danger"><i class="fas fa-clock"></i> @overdueIssues overdue</small>
                                    }
                                    else if (Model.OpenIssues > 0)
                                    {
                                        <small class="text-muted">@Model.OpenIssues open</small>
                                    }
                                    else
                                    {
                                        <small class="text-success">All resolved</small>
                                    }
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-lg-3 col-md-6 col-12">
                            <div class="info-box clickable-box" style="cursor: pointer;" data-href="/?view=risks">
                                <span class="info-box-icon bg-@(overdueRisks > 0 ? "danger" : Model.ActiveRisks > 0 ? "warning" : "success")">
                                    <i class="fas fa-shield-alt"></i>
                                </span>
                                <div class="info-box-content">
                                    <span class="info-box-text">My risks</span>
                                    <span class="info-box-number">
                                        @Model.ActiveRisks <small class="text-muted">/ @Model.TotalRisks total</small>
                                    </span>
                                    @if (overdueRisks > 0)
                                    {
                                        <small class="text-danger"><i class="fas fa-clock"></i> @overdueRisks overdue</small>
                                    }
                                    else if (Model.ActiveRisks > 0)
                                    {
                                        <small class="text-muted">@Model.ActiveRisks active</small>
                                    }
                                    else
                                    {
                                        <small class="text-success">All closed</small>
                                    }
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-lg-3 col-md-6 col-12">
                            <div class="info-box clickable-box" style="cursor: pointer;" data-href="/?view=actions">
                                <span class="info-box-icon bg-@(overdueActions > 0 ? "danger" : Model.UrgentActions > 0 ? "warning" : "success")">
                                    <i class="fas fa-tasks"></i>
                                </span>
                                <div class="info-box-content">
                                    <span class="info-box-text">My actions</span>
                                    <span class="info-box-number">
                                        @Model.MyActions.Count(a => a.Status != "done" && a.Status != "cancelled") <small class="text-muted">/ @Model.TotalActions total</small>
                                    </span>
                                    @if (overdueActions > 0)
                                    {
                                        <small class="text-danger"><i class="fas fa-clock"></i> @overdueActions overdue</small>
                                    }
                                    else if (Model.UrgentActions > 0)
                                    {
                                        <small class="text-warning">@Model.UrgentActions urgent</small>
                                    }
                                    else
                                    {
                                        <small class="text-success">On track</small>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Milestones Progress Bar -->
                    @if (Model.TotalMilestones > 0)
                    {
                        var completeMilestones = Model.MyMilestones.Count(m => m.Status == "complete");
                        var completionPercent = (int)((double)completeMilestones / Model.TotalMilestones * 100);
                        
                        <div class="card">
                            <div class="card-body">
                                <div class="row align-items-center">
                                    <div class="col-auto">
                                        <i class="fas fa-flag-checkered fa-2x text-primary"></i>
                                    </div>
                                    <div class="col">
                                        <h5 class="mb-1">Milestones progress</h5>
                                        <div class="progress" style="height: 25px;">
                                            <div class="progress-bar bg-success" role="progressbar" 
                                                 style="width: @completionPercent%;" 
                                                 aria-valuenow="@completionPercent" 
                                                 aria-valuemin="0" 
                                                 aria-valuemax="100">
                                                @completeMilestones / @Model.TotalMilestones complete (@completionPercent%)
                                            </div>
                                        </div>
                                        <small class="text-muted mt-1">
                                            @if (overdueMilestones > 0)
                                            {
                                                <span class="text-danger"><i class="fas fa-exclamation-circle"></i> @overdueMilestones overdue</span>
                                            }
                                            @if (Model.UrgentMilestones > 0)
                                            {
                                                <span class="text-warning ml-2"><i class="fas fa-clock"></i> @Model.UrgentMilestones urgent</span>
                                            }
                                        </small>
                                    </div>
                                    <div class="col-auto">
                                        <a href="/?view=milestones" class="btn btn-sm btn-outline-primary">
                                            View all <i class="fas fa-arrow-right ml-1"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Priority Items requiring attention -->
                    @{
                        var priorityItems = new List<(string Type, string Title, string Url, DateTime? Date, string Severity, bool IsOverdue)>();
                        
                        // Add overdue/urgent items
                        foreach (var issue in Model.MyIssues.Where(i => i.Status != "resolved" && i.Status != "closed").Take(5))
                        {
                            var isOverdue = IsOverdue(issue.TargetResolutionDate, issue.Status, new[] { "resolved", "closed" });
                            if (isOverdue || issue.Severity == "critical" || issue.Severity == "high")
                            {
                                priorityItems.Add(("Issue", issue.Title, $"/Issue/Edit/{issue.Id}", issue.TargetResolutionDate, issue.Severity, isOverdue));
                            }
                        }
                        
                        foreach (var action in Model.MyActions.Where(a => a.Status != "done" && a.Status != "cancelled").Take(5))
                        {
                            var isOverdue = IsOverdue(action.DueDate, action.Status, new[] { "done", "cancelled" });
                            if (isOverdue || action.Priority == "high")
                            {
                                priorityItems.Add(("Action", action.Title, $"/Action/Edit/{action.Id}", action.DueDate, action.Priority ?? "medium", isOverdue));
                            }
                        }
                        
                        foreach (var risk in Model.MyRisks.Where(r => r.Status != "closed" && r.RiskScore >= 10).Take(5))
                        {
                            var isOverdue = IsOverdue(risk.TargetDate, risk.Status, new[] { "closed" });
                            var severity = risk.RiskScore >= 15 ? "critical" : "high";
                            priorityItems.Add(("Risk", risk.Title, $"/Risk/Edit/{risk.Id}", risk.TargetDate, severity, isOverdue));
                        }
                        
                        priorityItems = priorityItems
                            .OrderByDescending(item => item.IsOverdue)
                            .ThenBy(item => item.Date ?? DateTime.MaxValue)
                            .Take(10)
                            .ToList();
                    }

                    @if (priorityItems.Any())
                    {
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">
                                    <i class="fas fa-exclamation-circle mr-2 text-danger"></i>
                                    Priority items requiring attention
                                </h3>
                                <div class="card-tools">
                                    <span class="badge badge-danger">@priorityItems.Count(i => i.IsOverdue) overdue</span>
                                </div>
                            </div>
                            <div class="card-body p-0">
                                <table class="table table-sm table-hover mb-0">
                                    <tbody>
                                        @foreach (var item in priorityItems)
                                        {
                                            var severityClass = GetSeverityBadgeClass(item.Severity);
                                            var typeIcon = item.Type == "Issue" ? "exclamation-triangle" : 
                                                          item.Type == "Risk" ? "shield-alt" : "tasks";
                                            var typeClass = item.Type == "Issue" ? "warning" : 
                                                           item.Type == "Risk" ? "danger" : "primary";
                                            
                                            <tr class="@(item.IsOverdue ? "table-danger" : "")">
                                                <td style="width: 50px;" class="text-center">
                                                    <i class="fas fa-@typeIcon text-@typeClass"></i>
                                                </td>
                                                <td>
                                                    <a href="@item.Url" class="font-weight-bold">@item.Title</a>
                                                    <br>
                                                    <small class="text-muted">
                                                        <span class="badge badge-sm @severityClass mr-1">@item.Severity.ToUpper()</span>
                                                        @item.Type
                                                    </small>
                                                </td>
                                                <td class="text-right" style="width: 150px;">
                                                    @if (item.Date.HasValue)
                                                    {
                                                        <span class="@(item.IsOverdue ? "text-danger font-weight-bold" : "")">
                                                            @if (item.IsOverdue)
                                                            {
                                                                <i class="fas fa-exclamation-circle mr-1"></i>
                                                            }
                                                            @item.Date.Value.ToString("dd MMM yyyy")
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">No date set</span>
                                                    }
                                                </td>
                                                <td style="width: 80px;" class="text-right">
                                                    <a href="@item.Url" class="btn btn-xs btn-outline-primary">
                                                        View
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                    @if (Model.TotalProducts == 0 && Model.TotalIssues == 0 && Model.TotalRisks == 0 && Model.TotalActions == 0 && Model.TotalMilestones == 0)
                    {
                        <div class="card">
                            <div class="card-body text-center py-5">
                                <i class="fas fa-inbox fa-4x text-muted mb-3"></i>
                                <h4>Welcome to your dashboard</h4>
                                <p class="text-muted">You don't have any items assigned to you yet.</p>
                                <p class="text-muted">When products, issues, risks, actions, or milestones are assigned to <strong>@userEmail</strong>, they will appear here.</p>
                                <hr class="my-4">
                                <p class="mb-2">Get started by:</p>
                                <div class="btn-group">
                                    <a href="/Products" class="btn btn-outline-primary"><i class="fas fa-box mr-1"></i> Browse products</a>
                                    <a href="/Issue/Create" class="btn btn-outline-warning"><i class="fas fa-plus mr-1"></i> Create issue</a>
                                    <a href="/Risk/Create" class="btn btn-outline-danger"><i class="fas fa-plus mr-1"></i> Create risk</a>
                                </div>
                            </div>
                        </div>
                    }
                }

                <!-- ============================================================ -->
                <!-- PRODUCTS VIEW -->
                <!-- ============================================================ -->
                @if (currentView == "products" && Model.MyProducts.Any())
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title"><i class="fas fa-box mr-2"></i>My products <span class="badge badge-info ml-2">@Model.TotalProducts</span></h3>
                            <div class="card-tools">
                                <a href="/ProductReporting" class="btn btn-sm btn-primary">
                                    <i class="fas fa-chart-bar mr-1"></i> Product reporting
                                </a>
                                <a href="/Products" class="btn btn-sm btn-outline-secondary">
                                    <i class="fas fa-external-link-alt mr-1"></i> All products
                                </a>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-hover mb-0">
                                <thead class="thead-light">
                                    <tr>
                                        <th style="width: 50px;"></th>
                                        <th>Product</th>
                                        <th style="width: 120px;">Phase</th>
                                        <th style="width: 200px;">My role</th>
                                        <th style="width: 200px;" class="text-center">Quick links</th>
                                    </tr>
