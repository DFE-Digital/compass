@model Compass.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var userName = Model.CurrentUser?.Name ?? User.Identity?.Name ?? "User";
    var userEmail = User.Identity?.Name ?? "";
    var currentView = ViewBag.CurrentView as string ?? "overview";
    var statusFilter = ViewBag.StatusFilter as string;
    var priorityFilter = ViewBag.PriorityFilter as string;
    var dateFilter = ViewBag.DateFilter as string ?? "all";
    
    // Calculate urgent items
    var overdueIssues = Model.MyIssues.Count(i => IsOverdue(i.TargetResolutionDate, i.Status, new[] { "resolved", "closed" }));
    var overdueMilestones = Model.MyMilestones.Count(m => IsOverdue(m.DueDate, m.Status, new[] { "complete", "cancelled" }));
    
    // Dashboard metrics
    var tasksDue = ViewBag.TasksDue ?? 0;
    var serviceHealthIssues = ViewBag.ServiceHealthIssues ?? 0;
    var projectHealthIssues = ViewBag.ProjectHealthIssues ?? 0;
    
    // Extract first name from full name
    var firstName = "User";
    if (!string.IsNullOrEmpty(userName))
    {
        var nameParts = userName.Split(' ');
        firstName = nameParts.Length > 0 ? nameParts[0] : userName;
    }
}

<style>
    .metric-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1) !important;
    }
</style>

<section class="content">
    <div class="container-fluid">
        <!-- Dashboard Header with Welcome and Metrics -->
        <div class="row mb-4" style="display: flex;">
            <!-- Left side: Welcome message and three metric cards -->
            <div class="col-lg-8" style="display: flex;">
                <!-- Welcome Banner -->
                <div class="card border-0 w-100" style="background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%); border-radius: 12px;">
                    <div class="card-body p-4">
                        <div class="row align-items-center" style="height: 100%;">
                            <div class="col-md-6">
                                <p class="text-muted mb-1" style="font-size: 0.9rem;">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
                                <h2 class="mb-2" style="font-weight: 600; color: #1976D2;">Hello, @firstName!</h2>
                                <p class="text-muted mb-0" style="font-size: 0.95rem;">Track & manage your team progress here</p>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex justify-content-start">
                                    <!-- Tasks Due Card -->
                                    <div style="flex: 0 0 33.333%; padding-right: 8px;">
                                        <div class="card border-0 shadow-sm metric-card" style="border-radius: 8px; transition: transform 0.2s, box-shadow 0.2s;">
                                            <div class="card-body p-3">
                                                <h3 class="mb-1 text-left" style="font-weight: 700; font-size: 1.8rem;">@tasksDue</h3>
                                                <p class="text-muted mb-0 text-left" style="font-size: 0.85rem;">Tasks due</p>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Service Health Card -->
                                    <div style="flex: 0 0 33.333%; padding-right: 8px;">
                                        <div class="card border-0 shadow-sm metric-card" style="border-radius: 8px; transition: transform 0.2s, box-shadow 0.2s;">
                                            <div class="card-body p-3">
                                                <h3 class="mb-1 text-left" style="font-weight: 700; font-size: 1.8rem;">@serviceHealthIssues</h3>
                                                <p class="text-muted mb-0 text-left" style="font-size: 0.85rem;">Service health</p>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Project Health Card -->
                                    <div style="flex: 0 0 33.333%;">
                                        <div class="card border-0 shadow-sm metric-card" style="border-radius: 8px; transition: transform 0.2s, box-shadow 0.2s;">
                                            <div class="card-body p-3">
                                                <h3 class="mb-1 text-left" style="font-weight: 700; font-size: 1.8rem;">@projectHealthIssues</h3>
                                                <p class="text-muted mb-0 text-left" style="font-size: 0.85rem;">Project health</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Right side: What's New card -->
            <div class="col-lg-4" style="display: flex;">
                <div class="card border-0 shadow-sm w-100 metric-card" style="border-radius: 12px; background: white; transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="card-body p-4">
                        <div style="height: 100%;">
                            <h5 class="mb-2" style="font-weight: 600;">What's new in COMPASS</h5>
                            <p class="text-muted mb-3" style="font-size: 0.9rem;">Dive into our advanced analytics and customizable reports—designed to streamline your workflow.</p>
                            <a href="@Url.Action("MyReports", "DdtReports")" class="btn" style="background: #FF6B35; color: white; border-radius: 6px; font-weight: 500;">
                                View My Reports
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
                            </div>
                        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
                            </div>
                        }

        <div class="row">
            <!-- Left Column: Vertical Navigation Pills -->
            <div class="col-lg-2 col-md-3 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Navigation</h3>
                            </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <a href="/?view=overview" class="list-group-item list-group-item-action @(currentView == "overview" ? "active" : "")">
                                Overview
                            </a>
                            <a href="/?view=products" class="list-group-item list-group-item-action @(currentView == "products" ? "active" : "")">
                                Products
                            </a>
                            <a href="/?view=issues" class="list-group-item list-group-item-action @(currentView == "issues" ? "active" : "")">
                                Issues
                            </a>
                            <a href="/?view=milestones" class="list-group-item list-group-item-action @(currentView == "milestones" ? "active" : "")">
                                Milestones
                                </a>
                            </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Main Content -->
            <div class="col-lg-10 col-md-9 col-12">
                @if (currentView == "overview")
                {
                    <!-- RAG Status Summary -->
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">RAG Status Overview</h3>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-lg-2 col-md-4 col-6">
                                    <div class="small-box bg-danger">
                                        <div class="inner text-center">
                                            <h3>@Model.RedProjects</h3>
                                            <p>Red</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-2 col-md-4 col-6">
                                    <div class="small-box" style="background-color: #FF9800;">
                                        <div class="inner text-center">
                                            <h3>@Model.AmberRedProjects</h3>
                                            <p>Amber-Red</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-2 col-md-4 col-6">
                                    <div class="small-box bg-warning">
                                        <div class="inner text-center">
                                            <h3>@Model.AmberProjects</h3>
                                            <p>Amber</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-2 col-md-4 col-6">
                                    <div class="small-box" style="background-color: #FFEB3B;">
                                        <div class="inner text-center">
                                            <h3>@Model.AmberGreenProjects</h3>
                                            <p>Amber-Green</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-2 col-md-4 col-6">
                                    <div class="small-box bg-success">
                                        <div class="inner text-center">
                                            <h3>@Model.GreenProjects</h3>
                                            <p>Green</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-2 col-md-4 col-6">
                                    <div class="small-box bg-secondary">
                                        <div class="inner text-center">
                                            <h3>@Model.ProjectsWithoutRAG</h3>
                                            <p>Not set</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Upcoming Milestones -->
                    @if (Model.UpcomingMilestones.Any())
                    {
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Upcoming Milestones</h3>
                                <div class="card-tools">
                                    <a href="/?view=milestones" class="btn btn-sm btn-outline-primary">View all</a>
                                </div>
                            </div>
                            <div class="card-body table-responsive p-0">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Milestone</th>
                                            <th style="width: 150px;">Project/Product</th>
                                            <th style="width: 120px;">Due Date</th>
                                            <th style="width: 100px;">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var milestone in Model.UpcomingMilestones)
                                        {
                                            var isOverdue = IsOverdue(milestone.DueDate, milestone.Status, new[] { "complete", "cancelled" });
                                            <tr class="@(isOverdue ? "table-danger" : "")">
                                                <td>
                                                    <a href="/Milestone/Edit/@milestone.Id">@milestone.Name</a>
                                                </td>
                                                <td>
                                                    @if (milestone.ProjectId.HasValue)
                                                    {
                                                        <a href="/Project/Details/@milestone.ProjectId">Project</a>
                                                    }
                                                    else
                                        {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td>
                                                    <span class="@(isOverdue ? "text-danger" : "")">
                                                        @milestone.DueDate.ToString("dd MMM yyyy")
                                                    </span>
                                                </td>
                                                <td>
                                                    <span class="badge badge-@(milestone.Status == "complete" ? "success" : milestone.Status == "at_risk" ? "warning" : "secondary")">
                                                        @milestone.Status.Replace("_", " ")
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                    <!-- Reports Status -->
                    @if (Model.Reports.Any())
                    {
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Required Reports - Current Period</h3>
                            </div>
                            <div class="card-body table-responsive p-0">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Report Type</th>
                                            <th style="width: 120px;">Period</th>
                                            <th style="width: 120px;">Due Date</th>
                                            <th style="width: 120px;">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var report in Model.Reports)
                                        {
                                            var statusClass = report.Status switch
                                            {
                                                "Late" => "danger",
                                                "Due" => "warning",
                                                "Submitted" => "success",
                                                _ => "secondary"
                                            };
                                            <tr class="@(report.Status == "Late" ? "table-danger" : "")">
                                                <td>@report.Type Report</td>
                                                <td>@report.Period</td>
                                                <td>
                                                    @if (report.DueDate.HasValue)
                                                    {
                                                        @report.DueDate.Value.ToString("dd MMM yyyy")
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td>
                                                    <span class="badge badge-@statusClass">@report.Status</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                    <!-- Highest Severity Issues -->
                    @if (Model.CriticalIssues.Any())
                    {
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Critical Issues</h3>
                                <div class="card-tools">
                                    <a href="/?view=issues" class="btn btn-sm btn-outline-primary">View all issues</a>
                                </div>
                            </div>
                            <div class="card-body table-responsive p-0">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Issue</th>
                                            <th style="width: 150px;">Project/Product</th>
                                            <th style="width: 120px;">Target Resolution</th>
                                            <th style="width: 100px;">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var issue in Model.CriticalIssues)
                                        {
                                            var isOverdue = IsOverdue(issue.TargetResolutionDate, issue.Status, new[] { "resolved", "closed" });
                                            <tr class="@(isOverdue ? "table-danger" : "")">
                                                <td>
                                                    <a href="/Issue/Edit/@issue.Id">@issue.Title</a>
                                                </td>
                                                <td>
                                                    @if (issue.ProjectId.HasValue)
                                                    {
                                                        <a href="/Project/Details/@issue.ProjectId">Project</a>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (issue.TargetResolutionDate.HasValue)
                                                    {
                                                        <span class="@(isOverdue ? "text-danger" : "")">
                                                            @issue.TargetResolutionDate.Value.ToString("dd MMM yyyy")
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">No date</span>
                                                    }
                                                </td>
                                                <td>
                                                    <span class="badge badge-@GetIssueStatusBadgeClass(issue.Status)">
                                                        @issue.Status.Replace("_", " ")
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                }

                <!-- PRODUCTS VIEW -->
                @if (currentView == "products" && Model.MyProducts.Any())
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">My Products</h3>
                            <div class="card-tools">
                                <a href="/Products" class="btn btn-sm btn-outline-primary">All products</a>
                            </div>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th style="width: 120px;">Phase</th>
                                        <th style="width: 200px;">Role</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var product in Model.MyProducts)
                                    {
                                        var myContacts = product.ProductContacts?
                                            .Where(pc => pc.UsersPermissionsUser?.Email?.Equals(userEmail, StringComparison.OrdinalIgnoreCase) == true)
                                            .ToList() ?? new List<ProductContactDto>();
                                        var roles = string.Join(", ", myContacts.Select(c => c.Role ?? "Contact"));
                                        
                                        <tr>
                                            <td>
                                                <a href="/Products/Dashboard/@product.FipsId">@product.Title</a>
                                                <br><small class="text-muted">@product.FipsId</small>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(product.Phase))
                                                {
                                                    @product.Phase
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td><small class="text-muted">@roles</small></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                @if (currentView == "products" && !Model.MyProducts.Any())
                {
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <h4>No products assigned</h4>
                            <p class="text-muted">You are not currently listed as a contact for any products.</p>
                            <a href="/Products" class="btn btn-primary mt-2">Browse all products</a>
                        </div>
                    </div>
                }

                <!-- ISSUES VIEW -->
                @if (currentView == "issues" && Model.MyIssues.Any())
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">My Issues</h3>
                            <div class="card-tools">
                                <a href="/Issue/Create" class="btn btn-sm btn-success">Add issue</a>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th style="width: 150px;">Project/Product</th>
                                        <th style="width: 100px;">Severity</th>
                                        <th style="width: 120px;">Status</th>
                                        <th style="width: 120px;">Due date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var issue in Model.MyIssues)
                                    {
                                        var isOverdue = IsOverdue(issue.TargetResolutionDate, issue.Status, new[] { "resolved", "closed" });
                                        var severityClass = GetSeverityBadgeClass(issue.Severity);
                                        var statusClass = GetIssueStatusBadgeClass(issue.Status);
                                        
                                        <tr class="@(isOverdue ? "table-danger" : "")">
                                            <td><a href="/Issue/Edit/@issue.Id">@issue.Title</a></td>
                                            <td>
                                                @if (issue.ProjectId.HasValue)
                                                {
                                                    <a href="/Project/Details/@issue.ProjectId">Project</a>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td><span class="badge @severityClass">@issue.Severity</span></td>
                                            <td>
                                                <span class="badge @statusClass">@issue.Status.Replace("_", " ")</span>
                                                @if (issue.BlockedFlag)
                                                {
                                                    <br><span class="text-danger small">Blocked</span>
                                                }
                                            </td>
                                            <td>
                                                @if (issue.TargetResolutionDate.HasValue)
                                                {
                                                    <span class="@(isOverdue ? "text-danger" : "")">
                                                        @issue.TargetResolutionDate.Value.ToString("dd MMM yyyy")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No date</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                @if (currentView == "issues" && !Model.MyIssues.Any())
                {
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <h4>No issues found</h4>
                                <p class="text-muted">You don't have any issues assigned to you.</p>
                                <a href="/Issue/Create" class="btn btn-success">Create issue</a>
                        </div>
                    </div>
                }

                <!-- MILESTONES VIEW -->
                @if (currentView == "milestones" && Model.MyMilestones.Any())
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">My Milestones</h3>
                            <div class="card-tools">
                                <a href="/Milestone/Create" class="btn btn-sm btn-success">Add milestone</a>
                            </div>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th style="width: 150px;">Project/Product</th>
                                        <th style="width: 120px;">Status</th>
                                        <th style="width: 100px;">Progress</th>
                                        <th style="width: 120px;">Due date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var milestone in Model.MyMilestones)
                                    {
                                        var isOverdue = IsOverdue(milestone.DueDate, milestone.Status, new[] { "complete", "cancelled" });
                                        var statusClass = GetMilestoneStatusBadgeClass(milestone.Status);
                                        
                                        <tr class="@(isOverdue ? "table-danger" : "")">
                                            <td><a href="/Milestone/Edit/@milestone.Id">@milestone.Name</a></td>
                                            <td>
                                                @if (milestone.ProjectId.HasValue)
                                                {
                                                    <a href="/Project/Details/@milestone.ProjectId">Project</a>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td><span class="badge @statusClass">@milestone.Status.Replace("_", " ")</span></td>
                                            <td>
                                                @if (milestone.ProgressPercent.HasValue)
                                                {
                                                    <text>@milestone.ProgressPercent%</text>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="@(isOverdue ? "text-danger" : "")">
                                                    @milestone.DueDate.ToString("dd MMM yyyy")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                @if (currentView == "milestones" && !Model.MyMilestones.Any())
                {
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <h4>No milestones found</h4>
                                <p class="text-muted">You don't have any milestones assigned to you.</p>
                                <a href="/Milestone/Create" class="btn btn-success">Create milestone</a>
                        </div>
                    </div>
                }

            </div>
        </div>
    </div>
</section>

@functions {
    // Badge class helpers
    string GetSeverityBadgeClass(string severity)
    {
        return severity switch
        {
            "critical" => "badge-danger",
            "high" => "badge-warning",
            "medium" => "badge-info",
            "low" => "badge-secondary",
            _ => "badge-secondary"
        };
    }

    string GetIssueStatusBadgeClass(string status)
    {
        return status switch
        {
            "open" => "badge-info",
            "in_progress" => "badge-primary",
            "blocked" => "badge-danger",
            "resolved" => "badge-success",
            "closed" => "badge-secondary",
            _ => "badge-secondary"
        };
    }

    string GetMilestoneStatusBadgeClass(string status)
    {
        return status switch
        {
            "not_started" => "badge-secondary",
            "on_track" => "badge-success",
            "at_risk" => "badge-warning",
            "delayed" => "badge-danger",
            "complete" => "badge-primary",
            "cancelled" => "badge-dark",
            _ => "badge-secondary"
        };
    }

    // Date and status helpers
    bool IsOverdue(DateTime? targetDate, string status, string[] completedStatuses)
    {
        if (!targetDate.HasValue) return false;
        if (completedStatuses.Contains(status)) return false;
        return targetDate.Value < DateTime.UtcNow;
    }

    bool IsOverdue(DateTime targetDate, string status, string[] completedStatuses)
    {
        if (completedStatuses.Contains(status)) return false;
        return targetDate < DateTime.UtcNow;
    }
}

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Auto-submit form on filter change
            $('.auto-submit').on('change', function() {
                $(this).closest('form').submit();
            });
        });
    </script>
}
