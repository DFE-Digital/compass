                <div class="hp-tabs" role="tablist">
                    <button class="hp-tab active" role="tab" aria-selected="true" data-tab="tasks">
                        Tasks <span class="cnt @(taskCount > 0 ? "hot" : "")">@taskCount</span>
                    </button>
                    <button class="hp-tab" role="tab" aria-selected="false" data-tab="projects">
                        Projects <span class="cnt">@Model.MyProjects.Count</span>
                    </button>
                    <button class="hp-tab" role="tab" aria-selected="false" data-tab="watching">
                        Watching <span class="cnt">@Model.WatchedProjects.Count</span>
                    </button>
                    <button class="hp-tab" role="tab" aria-selected="false" data-tab="products">
                        Products <span class="cnt">@Model.MyProducts.Count</span>
                    </button>
                    @if (hasStandards)
                    {
                        <button class="hp-tab" role="tab" aria-selected="false" data-tab="standards">
                            Standards <span class="cnt">@Model.MyDdtStandards.Count</span>
                        </button>
                    }
                    @if (commissionCount > 0)
                    {
                        <button class="hp-tab" role="tab" aria-selected="false" data-tab="commission">
                            Reporting <span class="cnt hot">@commissionCount</span>
                        </button>
                    }
                    @if (Model.RecentSuccesses.Any())
                    {
                        <button class="hp-tab" role="tab" aria-selected="false" data-tab="successes">
                            Successes <span class="cnt">@Model.RecentSuccesses.Count</span>
                        </button>
                                        }
                                    </div>

                <!-- Tasks -->
                <div id="hp-tab-tasks" class="hp-pane active" role="tabpanel">
                    @if (taskCount == 0)
                    {
                        <div class="hp-empty">
                            <div class="hp-empty-ico">✅</div>
                            <h3>All clear</h3>
                            <p>No outstanding tasks or reporting requirements.</p>
                                </div>
                    }
                    else
                    {
                        <div class="hp-rows">
                            @foreach (var m in Model.OverdueMilestones.Take(6))
                            {
                                <a href="@Url.Action("MilestoneDetails","Project", new { id = m.Id })" class="hp-row r-red">
                                    <div class="hp-ico i-red"><i class="fas fa-flag-checkered" aria-hidden="true"></i></div>
                                    <div class="hp-row-body">
                                        <div class="hp-row-title">@m.Name</div>
                                        <div class="hp-row-sub">@(m.Project?.Title ?? "–")</div>
                                    </div>
                                    <div class="hp-row-meta">
                                        <span class="badge badge-danger">Overdue</span>
                                        <span class="text-muted" style="font-size:0.72rem;">@m.DueDate.ToString("d MMM")</span>
                                    </div>
                                </a>
                            }
                            @foreach (var i in Model.HighPriorityIssues.Take(4))
                            {
                                <a href="@Url.Action("Details","Issue", new { id = i.Id })" class="hp-row r-red">
                                    <div class="hp-ico i-red"><i class="fas fa-bug" aria-hidden="true"></i></div>
                                    <div class="hp-row-body">
                                        <div class="hp-row-title">@i.Title</div>
                                        <div class="hp-row-sub">@(i.Project?.Title ?? "–")</div>
                                    </div>
                                    <div class="hp-row-meta">
                                        <span class="badge badge-danger">@(i.Severity ?? "High")</span>
                                </div>
                            </a>
                        }
                            @foreach (var item in Model.ProjectsNeedingMonthlyUpdates.Take(4))
                            {
                                var uy = item.DueDate.Month == 1 ? item.DueDate.Year - 1 : item.DueDate.Year;
                                var um = item.DueDate.Month == 1 ? 12 : item.DueDate.Month - 1;
                                var isLate = item.Status == UpdateSubmissionStatus.Late;
                                <a href="@Url.Action("EditUpdate","MilestonesUpdatesSuccesses", new { projectId = item.Project.Id, year = uy, month = um })" class="hp-row @(isLate ? "r-red" : "r-amber")">
                                    <div class="hp-ico @(isLate ? "i-red" : "i-amber")"><i class="fas fa-calendar-check" aria-hidden="true"></i></div>
                                    <div class="hp-row-body">
                                        <div class="hp-row-title">Monthly update @(isLate ? "late" : "due")</div>
                                        <div class="hp-row-sub">@item.Project.Title</div>
                                    </div>
                                    <div class="hp-row-meta">
                                        <span class="badge @(isLate ? "badge-danger" : "badge-warning")">@(isLate ? "Late" : "Due")</span>
                                        <span class="text-muted" style="font-size:0.72rem;">@item.DueDate.ToString("d MMM")</span>
                                </div>
                            </a>
                        }
                            @foreach (var item in Model.ProductsNeedingReturns.Take(4))
                            {
                                var my = item.DueDate.Month == 1 ? item.DueDate.Year - 1 : item.DueDate.Year;
                                var mm = item.DueDate.Month == 1 ? 12 : item.DueDate.Month - 1;
                                var isLate = item.Status == ReturnStatus.Late;
                                <a href="@Url.Action("SubmitMetrics","ProductReporting", new { documentId = item.Product.FipsId, year = my, month = mm })" class="hp-row @(isLate ? "r-red" : "r-amber")">
                                    <div class="hp-ico @(isLate ? "i-red" : "i-amber")"><i class="fas fa-chart-line" aria-hidden="true"></i></div>
                                    <div class="hp-row-body">
                                        <div class="hp-row-title">Performance return @(isLate ? "late" : "due")</div>
                                        <div class="hp-row-sub">@item.Product.Title</div>
                                    </div>
                                    <div class="hp-row-meta">
                                        <span class="badge @(isLate ? "badge-danger" : "badge-warning")">@(isLate ? "Late" : "Due")</span>
                                        <span class="text-muted" style="font-size:0.72rem;">@item.DueDate.ToString("d MMM")</span>
                                </div>
                            </a>
                        }
                            @foreach (var a in Model.AssignedActions.Take(4))
                            {
                                <a href="@Url.Action("Details","Action", new { id = a.Id })" class="hp-row">
                                    <div class="hp-ico i-indigo"><i class="fas fa-check-square" aria-hidden="true"></i></div>
                                    <div class="hp-row-body">
                                        <div class="hp-row-title">@a.Title</div>
                                        <div class="hp-row-sub">@(a.Project?.Title ?? "–")</div>
                                    </div>
                                    <div class="hp-row-meta">
                                        <span class="badge badge-secondary">Action</span>
                                        @if (a.DueDate.HasValue) { <span class="text-muted" style="font-size:0.72rem;">@a.DueDate.Value.ToString("d MMM")</span> }
                                </div>
                            </a>
                        }
                    </div>
                    @if (taskCount > 10)
                    {
                            <div class="hp-more mt-2">
                                <a href="@Url.Action("Index","Raid")">View all @taskCount tasks <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
                        </div>
                    }
                }
            </div>

                <!-- Projects -->
                <div id="hp-tab-projects" class="hp-pane" role="tabpanel">
                @if (!hasProjects)
                {
                        <div class="hp-empty">
                            <div class="hp-empty-ico"><i class="fas fa-project-diagram"></i></div>
                        <h3>No projects assigned</h3>
                        <p>You're not currently listed on any project teams.</p>
                    </div>
                }
                else
                {
                        @if (hasProjects)
                        {
                            var total = Model.MyProjects.Count;
                            var gCount = RagCount("Green");
                            var agCount = RagCount("Amber-Green");
                            var aCount = RagCount("Amber");
                            var arCount = RagCount("Amber-Red");
                            var rCount = RagCount("Red");
                            var nsCount = RagCount("Not set");
                            <div class="rag-bar mb-1" title="RAG breakdown" aria-label="RAG breakdown bar">
                                @if (gCount > 0)  { <div class="rag-seg rag-green"       style="flex:@gCount"  title="Green: @gCount"></div> }
                                @if (agCount > 0) { <div class="rag-seg rag-amber-green" style="flex:@agCount" title="Amber-Green: @agCount"></div> }
                                @if (aCount > 0)  { <div class="rag-seg rag-amber"       style="flex:@aCount"  title="Amber: @aCount"></div> }
                                @if (arCount > 0) { <div class="rag-seg rag-amber-red"   style="flex:@arCount" title="Amber-Red: @arCount"></div> }
                                @if (rCount > 0)  { <div class="rag-seg rag-red"         style="flex:@rCount"  title="Red: @rCount"></div> }
                                @if (nsCount > 0) { <div class="rag-seg rag-not-set"     style="flex:@nsCount" title="Not set: @nsCount"></div> }
                                            </div>
                            <div style="font-size:0.72rem; color:#9ca3af; margin-bottom:0.75rem;">
                                @if (gCount > 0)  { <span class="mr-2">🟢 @gCount green</span> }
                                @if (agCount > 0) { <span class="mr-2">🟡 @agCount amber-green</span> }
                                @if (aCount > 0)  { <span class="mr-2">🟠 @aCount amber</span> }
                                @if (arCount > 0) { <span class="mr-2">🔴 @arCount amber-red</span> }
                                @if (rCount > 0)  { <span class="mr-2">🔴 @rCount red</span> }
                                @if (nsCount > 0) { <span class="mr-2">⚪ @nsCount not set</span> }
                                            </div>
                                        }
                        <div class="hp-rows">
                            @foreach (var p in Model.MyProjects.Take(15))
                            {
                                var rag = p.RagStatusLookup?.Name ?? p.RagStatus ?? "";
                                var rowCls = (rag == "Red" || rag == "Amber-Red") ? "r-red" : (rag == "Amber" || rag == "Amber-Green") ? "r-amber" : rag == "Green" ? "r-green" : "";
                                var icoCls = (rag == "Red" || rag == "Amber-Red") ? "i-red" : rag == "Green" ? "i-green" : "i-blue";
                                var openR  = p.Risks?.Count(r => !r.IsDeleted) ?? 0;
                                var openI  = p.Issues?.Count(i => !i.IsDeleted && i.Status != "resolved" && i.Status != "closed") ?? 0;
                                var upcoming = p.Milestones?.Count(m => !m.IsDeleted && m.DueDate >= DateTime.Today && m.DueDate <= DateTime.Today.AddDays(14)) ?? 0;
                                <a href="@Url.Action("Details","Project", new { id = p.Id })" class="hp-row @rowCls">
                                    <div class="hp-ico @icoCls"><i class="fas fa-project-diagram" aria-hidden="true"></i></div>
                                    <div class="hp-row-body">
                                        <div class="hp-row-title">
                                            @p.Title
                                            @if (p.IsFlagship) { <i class="fas fa-star ml-1" style="color:#f59e0b; font-size:0.7rem;" title="Flagship" aria-label="Flagship"></i> }
                                            @if (p.IsAiInitiative) { <i class="fas fa-robot ml-1" style="color:#7c3aed; font-size:0.7rem;" title="AI initiative" aria-label="AI initiative"></i> }
                                            </div>
                                        <div class="hp-row-sub">@(p.BusinessArea ?? "–") @if (!string.IsNullOrEmpty(p.Phase)) { <span>· @p.Phase</span> }</div>
                                        </div>
                                    <div class="hp-row-meta">
                                        @if (!string.IsNullOrEmpty(rag)) { <span class="@RagBadgeClass(rag)">@rag</span> }
                                        @if (p.DeliveryPriority != null) { <span class="@PriBadge(p.DeliveryPriority.Name)">@p.DeliveryPriority.Name</span> }
                                        @if (upcoming > 0) { <span class="badge badge-info" title="Upcoming milestones"><i class="fas fa-flag" aria-hidden="true"></i> @upcoming</span> }
                                        @if (openR > 0) { <span class="badge badge-warning" title="Open risks">R:@openR</span> }
                                        @if (openI > 0) { <span class="badge badge-danger" title="Open issues">I:@openI</span> }
                                </div>
                            </a>
                        }
                    </div>
                        @if (Model.MyProjects.Count > 15)
                        {
                            <div class="hp-more mt-2">
                                <a href="@Url.Action("Index","Project")">View all @Model.MyProjects.Count projects <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
                            </div>
                        }
                        @if (Model.ProjectsNeedingPathToGreen.Any())
                        {
                            <div style="margin-top:1rem; padding-top:0.75rem; border-top:1px solid #f3f4f6;">
                                <div style="font-size:0.78rem; font-weight:700; color:#d4351c; margin-bottom:0.4rem;"><i class="fas fa-exclamation-triangle mr-1" aria-hidden="true"></i>Missing path to green</div>
                                @foreach (var p in Model.ProjectsNeedingPathToGreen.Take(3))
                                {
                                    <div class="hp-ptg-row">
                                        <span class="@RagBadgeClass(p.RagStatusLookup?.Name ?? "")" style="flex-shrink:0;">@(p.RagStatusLookup?.Name ?? "–")</span>
                                        <a href="@Url.Action("Details","Project", new { id = p.Id, tab = "rag" })">@p.Title</a>
                                    </div>
                                }
                        </div>
                    }
                }
            </div>

                <!-- Watching -->
                <div id="hp-tab-watching" class="hp-pane" role="tabpanel">
