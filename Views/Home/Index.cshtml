@model HomeDashboardViewModel
@using Compass.Models
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostEnvironment

@{
    ViewData["Title"] = "COMPASS Dashboard";
}

@section Styles {
    <style>
        .dashboard-static {
            margin-bottom: 1.5rem;
        }

        .metric-pill {
            border-radius: 14px;
            border: 1px solid rgba(15, 30, 90, 0.12);
            background: linear-gradient(145deg, #ffffff, #f8f9ff);
            padding: 1.25rem;
            height: 100%;
            box-shadow: 0 10px 18px rgba(12, 25, 64, 0.06);
        }

        .metric-pill strong {
            display: block;
            font-size: 2rem;
            line-height: 1.2;
        }

        .metric-pill span {
            color: #5c6480;
            font-size: 0.95rem;
        }

        .static-table thead th {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #7a819b;
            border-top: 0;
        }

        .static-table td {
            vertical-align: middle;
        }

        .leadership-panel {
            border-radius: 16px;
            border: 1px solid rgba(15, 30, 90, 0.12);
            padding: 1.5rem;
            background: linear-gradient(160deg, rgba(39, 76, 255, 0.08), rgba(39, 76, 255, 0));
        }

        .leadership-panel .badge {
            text-transform: none;
            font-weight: 500;
        }

        .enterprise-section {
            margin-bottom: 2rem;
        }

        .mission-card, .outcome-card {
            border: 1px solid rgba(15, 30, 90, 0.12);
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1rem;
            background: #ffffff;
        }

        .mission-card h5, .outcome-card h5 {
            margin-bottom: 0.5rem;
            font-size: 1rem;
        }

        .mission-card p, .outcome-card p {
            margin-bottom: 0.25rem;
            color: #5c6480;
            font-size: 0.9rem;
        }
    </style>
}

@functions {
    string GetRagBadgeClass(string ragStatus)
    {
        if (string.IsNullOrWhiteSpace(ragStatus))
        {
            return "badge badge-secondary";
        }
        
        // Normalize the status - handle both "Amber-Green" and "Amber/Green" formats
        var normalized = ragStatus.Trim()
            .Replace(" / ", "-")
            .Replace("/", "-")
            .Replace(" /", "-")
            .Replace("/ ", "-");
        
        return normalized switch
        {
            "Green" => "badge badge-green",
            "Amber-Green" => "badge badge-amber-green",
            "Amber" => "badge badge-amber",
            "Amber-Red" => "badge badge-amber-red",
            "Red" => "badge badge-red",
            _ => "badge badge-secondary"
        };
    }

    string GetPriorityBadgeClass(string priorityName)
    {
        if (string.IsNullOrWhiteSpace(priorityName))
        {
            return "badge badge-secondary";
        }

        var normalized = priorityName.Trim().ToLowerInvariant();
        return normalized switch
        {
            "high" => "badge badge-red",
            "medium" => "badge badge-amber",
            "low" => "badge badge-green",
            _ => "badge badge-secondary"
        };
    }

    bool IsOpenStatus(string? status)
    {
        return !string.Equals(status, "closed", StringComparison.OrdinalIgnoreCase) &&
               !string.Equals(status, "resolved", StringComparison.OrdinalIgnoreCase) &&
               !string.Equals(status, "complete", StringComparison.OrdinalIgnoreCase) &&
               !string.Equals(status, "cancelled", StringComparison.OrdinalIgnoreCase);
    }
}

<section class="content mt-4">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        @if (Context.RequestServices.GetRequiredService<Microsoft.AspNetCore.Hosting.IWebHostEnvironment>().IsDevelopment())
        {
            var currentTestRole = Context.Request.Cookies["TestDashboardRole"];
            var currentTestUserId = Context.Request.Cookies["TestDashboardUserId"];
            var isTestMode = !string.IsNullOrEmpty(currentTestRole) || !string.IsNullOrEmpty(currentTestUserId);
            <div class="alert alert-info alert-dismissible fade show mb-4" style="background-color: #e7f3ff; border-color: #b3d9ff;">
                <div class="d-flex justify-content-between align-items-center flex-wrap">
                    <div class="flex-grow-1 mb-2 mb-md-0">
                        <strong>🧪 Test mode:</strong> View dashboard as different user roles or users
                        @if (isTestMode)
                        {
                            <span class="badge badge-warning ml-2">
                                @if (!string.IsNullOrEmpty(currentTestRole))
                                {
                                    <span>Role: @currentTestRole</span>
                                }
                                @if (!string.IsNullOrEmpty(currentTestUserId))
                                {
                                    <span class="ml-1">User: @Model.CurrentUser.Name (@Model.CurrentUser.Email)</span>
                                }
                            </span>
                        }
                    </div>
                    <form method="get" action="@Url.Action("Index", "Home")" class="d-inline-flex align-items-center flex-wrap ml-3">
                        <select name="testRole" class="form-control form-control-sm mr-2 mb-2 mb-md-0" onchange="this.form.submit()" style="min-width: 200px;">
                            <option value="clear" selected="@(string.IsNullOrEmpty(currentTestRole))">Normal view (no role)</option>
                            <option value="PortfolioLead" selected="@(currentTestRole == "PortfolioLead")">Portfolio Lead / G6</option>
                            <option value="HeadOfProfession" selected="@(currentTestRole == "HeadOfProfession")">Head of Profession</option>
                            <option value="DeputyDirectorOrSro" selected="@(currentTestRole == "DeputyDirectorOrSro")">Deputy Director / SRO</option>
                            <option value="CLevel" selected="@(currentTestRole == "CLevel")">C-Level</option>
                            <option value="DirectorGeneral" selected="@(currentTestRole == "DirectorGeneral")">Director General</option>
                            <option value="PermanentSecretary" selected="@(currentTestRole == "PermanentSecretary")">Permanent Secretary</option>
                        </select>
                        <select name="testUserId" id="testUserSelect" class="form-control form-control-sm" onchange="this.form.submit()" style="min-width: 250px;">
                            <option value="0" selected="@(string.IsNullOrEmpty(currentTestUserId))">View as logged-in user</option>
                        </select>
                    </form>
                </div>
            </div>
        }

        @{
            var highestRoleLabel = Model.HighestLeadershipRole switch
            {
                LeadershipRoleTier.PermanentSecretary => "Permanent Secretary",
                LeadershipRoleTier.DirectorGeneral => "Director General",
                LeadershipRoleTier.CLevel => "C-Level",
                LeadershipRoleTier.DeputyDirectorOrSro => "Deputy Director / SRO",
                LeadershipRoleTier.HeadOfProfession => "Head of Profession",
                LeadershipRoleTier.PortfolioLead => "Portfolio lead / G6",
                _ => "Leadership overview"
            };
        }

        @if (Model.IsEnterpriseLeader)
        {
            <!-- Enterprise-wide view for Permanent Secretary, Director General, C-Level -->
            <div class="card shadow-sm mb-4 dashboard-static">
                <div class="card-body">
                    <h2 class="h4 mb-4">Enterprise overview</h2>
                    
                    <div class="row mb-4">
                        <div class="col-sm-6 col-lg-3 mb-3">
                            <div class="metric-pill">
                                <strong>@Model.EnterpriseMetrics.TotalOpenIssues</strong>
                                <span>Open issues</span>
                            </div>
                        </div>
                        <div class="col-sm-6 col-lg-3 mb-3">
                            <div class="metric-pill">
                                <strong>@Model.EnterpriseMetrics.TotalOpenRisks</strong>
                                <span>Open risks</span>
                            </div>
                        </div>
                        <div class="col-sm-6 col-lg-3 mb-3">
                            <div class="metric-pill">
                                <strong>@Model.EnterpriseMetrics.TotalOpenActions</strong>
                                <span>Open actions</span>
                            </div>
                        </div>
                        <div class="col-sm-6 col-lg-3 mb-3">
                            <div class="metric-pill">
                                <strong>@Model.EnterpriseMetrics.TotalAtRiskProjects</strong>
                                <span>At risk projects</span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-lg-6 mb-4">
                            <h3 class="h6 text-uppercase text-muted mb-3">Active missions</h3>
                            @if (Model.ActiveMissions.Any())
                            {
                                @foreach (var mission in Model.ActiveMissions.Take(10))
                                {
                                    <div class="mission-card">
                                        <h5>@mission.Title</h5>
                                        @if (!string.IsNullOrWhiteSpace(mission.Description))
                                        {
                                            <p>@mission.Description</p>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(mission.Theme))
                                        {
                                            <p><small class="text-muted">Theme: @mission.Theme</small></p>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted">No active missions found.</p>
                            }
                        </div>

                        <div class="col-lg-6 mb-4">
                            <h3 class="h6 text-uppercase text-muted mb-3">Priority outcomes</h3>
                            @if (Model.PriorityOutcomes.Any())
                            {
                                @foreach (var outcome in Model.PriorityOutcomes.Take(10))
                                {
                                    <div class="outcome-card">
                                        <h5>@outcome.Title</h5>
                                        @if (!string.IsNullOrWhiteSpace(outcome.Description))
                                        {
                                            <p>@outcome.Description</p>
                                        }
                                        @if (outcome.Mission != null)
                                        {
                                            <p><small class="text-muted">Mission: @outcome.Mission.Title</small></p>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(outcome.RagStatus))
                                        {
                                            <span class="badge badge-@(outcome.RagStatus.ToLower() == "red" ? "danger" : outcome.RagStatus.ToLower() == "amber" ? "warning" : "success")">@outcome.RagStatus</span>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted">No priority outcomes found.</p>
                            }
                        </div>
                    </div>

                    @if (Model.EnterpriseAtRiskProjects.Any())
                    {
                        <div class="row mt-4">
                            <div class="col-12">
                                <h3 class="h6 text-uppercase text-muted mb-3">At risk projects</h3>
                                <div class="table-responsive">
                                    <table class="table table-sm static-table">
                                        <thead>
                                            <tr>
                                                <th scope="col">Project</th>
                                                <th scope="col">RAG</th>
                                                <th scope="col">Business area</th>
                                                <th scope="col">Open issues</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var project in Model.EnterpriseAtRiskProjects.Take(10))
                                            {
                                                var openIssues = project.Issues?.Count(i => !i.IsDeleted && !string.Equals(i.Status, "closed", StringComparison.OrdinalIgnoreCase) && !string.Equals(i.Status, "resolved", StringComparison.OrdinalIgnoreCase)) ?? 0;
                                                <tr>
                                                    <td><a href="@Url.Action("Details", "Project", new { id = project.Id })">@project.Title</a></td>
                                                    <td>
                                                        <span class="badge badge-@(project.RagStatus == "Red" ? "danger" : "warning")">@project.RagStatus</span>
                                                    </td>
                                                    <td>@project.BusinessArea</td>
                                                    <td>@openIssues</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (Model.IsBusinessAreaLeader)
        {
            <!-- Business area leadership view for Deputy Director/SRO and Portfolio Lead/G6 -->
            <div class="card shadow-sm mb-4 dashboard-static">
                <div class="card-body"> <span class="text-muted">@highestRoleLabel</span>
                    <div class="d-flex justify-content-between align-items-center mb-4">
                   
                        <h1 class="h2 mb-0">Overview</h1>
                        @if (Model.LeadershipBusinessAreas.Any())
                        {
                            <div class="leadership-panel">
                                <small class="text-muted d-block mb-1">Business areas</small>
                                @{
                                    var visibleAreas = Model.LeadershipBusinessAreas.Take(2).ToList();
                                    var remainingCount = Model.LeadershipBusinessAreas.Count - 2;
                                }
                                @foreach (var area in visibleAreas)
                                {
                                    <span class="badge badge-primary mr-1">@area</span>
                                }
                                @if (remainingCount > 0)
                                {
                                    <span class="badge badge-secondary mr-1">+ @remainingCount more</span>
                                }
                            </div>
                        }
                    </div>
                    
                    <div class="row mb-4">
                        <div class="col-sm-6 col-lg-3 mb-3">
                            <div class="metric-pill">
                                <strong>@Model.LeadershipMetrics.OpenIssues</strong>
                                <span>Open issues</span>
                            </div>
                        </div>
                        <div class="col-sm-6 col-lg-3 mb-3">
                            <div class="metric-pill">
                                <strong>@Model.LeadershipMetrics.UnreviewedRisks</strong>
                                <span>Unreviewed risks</span>
                            </div>
                        </div>
                        <div class="col-sm-6 col-lg-3 mb-3">
                            <div class="metric-pill">
                                <strong>@Model.LeadershipMetrics.TasksDue</strong>
                                <span>Open actions</span>
                            </div>
                        </div>
                        <div class="col-sm-6 col-lg-3 mb-3">
                            <div class="metric-pill">
                                <strong>@Model.LeadershipMetrics.WatchedDeliverables</strong>
                                <span>Watched deliverables</span>
                            </div>
                        </div>
                    </div>

                    @{
                        var atRiskProjects = Model.OversightProjects
                            .Where(p => string.Equals(p.RagStatus, "Red", StringComparison.OrdinalIgnoreCase) ||
                                        string.Equals(p.RagStatus, "Amber-Red", StringComparison.OrdinalIgnoreCase))
                            .ToList();
                    }

                    @if (Model.OversightProjects.Any())
                    {
                        <div class="row">
                            <div class="col-12">
                                <div class="card mb-4 collapsed-card" id="oversight-projects-panel">
                                    <div class="card-header">
                                        <h3 class="card-title mb-0">@Model.OversightProjects.Count @(Model.OversightProjects.Count == 1 ? "deliverable" : "deliverables") in your business areas</h3>
                                        <div class="card-tools">
                                            <button type="button" class="btn btn-tool" data-card-widget="collapse">
                                                <i class="fas fa-plus" aria-hidden="true"></i>
                                                <span class="sr-only">Toggle deliverables</span>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="card-body p-0">
                                        <div class="table-responsive">
                                            <table class="table table-sm static-table sortable-table mb-0" id="oversight-projects-table">
                                                    <thead>
                                                        <tr>
                                                            <th style="width: 24%;" class="sortable" data-column="Project" tabindex="0" role="button" aria-label="Sort by Project">
                                                                Project
                                                                <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                                                            </th>
                                                            <th style="width: 11%;" class="sortable" data-column="Priority" tabindex="0" role="button" aria-label="Sort by Priority">
                                                                Priority
                                                                <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                                                            </th>
                                                            <th style="width: 9%;" class="sortable" data-column="RAG" tabindex="0" role="button" aria-label="Sort by RAG">
                                                                RAG
                                                                <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                                                            </th>
                                                            <th style="width: 14%;" class="sortable" data-column="BusinessArea" tabindex="0" role="button" aria-label="Sort by Business area">
                                                                Business area
                                                                <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                                                            </th>
                                                            <th style="width: 9%;" class="sortable text-right" data-column="OpenIssues" tabindex="0" role="button" aria-label="Sort by Open issues">
                                                                Open issues
                                                                <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                                                            </th>
                                                            <th style="width: 9%;" class="sortable text-right" data-column="OpenRisks" tabindex="0" role="button" aria-label="Sort by Open risks">
                                                                Open risks
                                                                <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                                                            </th>
                                                            <th style="width: 9%;" class="sortable text-right" data-column="OpenActions" tabindex="0" role="button" aria-label="Sort by Open actions">
                                                                Open actions
                                                                <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                                                            </th>
                                                            <th style="width: 12%;" class="sortable text-right" data-column="UpcomingMilestones" tabindex="0" role="button" aria-label="Sort by Milestones">
                                                                Milestones
                                                                <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                                                            </th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var project in Model.OversightProjects)
                                                        {
                                                            var openIssues = project.Issues?.Count(i => !i.IsDeleted && IsOpenStatus(i.Status)) ?? 0;
                                                            var openRisks = project.Risks?.Count(r => !r.IsDeleted && !string.Equals(r.Status, "closed", StringComparison.OrdinalIgnoreCase)) ?? 0;
                                                            var openActions = project.Actions?.Count(a => !a.IsDeleted && IsOpenStatus(a.Status)) ?? 0;
                                                            var upcomingMilestones = project.Milestones?.Count(m => !m.IsDeleted && m.DueDate >= DateTime.Today && m.DueDate <= DateTime.Today.AddDays(14)) ?? 0;
                                                            
                                                            <tr data-project-title="@project.Title" 
                                                                data-priority="@(project.DeliveryPriority?.Name ?? "Not set")"
                                                                data-rag="@(project.RagStatus ?? "Not set")"
                                                                data-business-area="@(project.BusinessArea ?? "")"
                                                                data-open-issues="@openIssues"
                                                                data-open-risks="@openRisks"
                                                                data-open-actions="@openActions"
                                                                data-upcoming-milestones="@upcomingMilestones">
                                                                <td><a href="@Url.Action("Details", "Project", new { id = project.Id })">@project.Title</a></td>
                                                                <td>
                                                                    @if (project.DeliveryPriority != null)
                                                                    {
                                                                        <span class="@GetPriorityBadgeClass(project.DeliveryPriority.Name)">@project.DeliveryPriority.Name</span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="text-muted">Not set</span>
                                                                    }
                                                                </td>
                                                                <td>
                                                                    @if (!string.IsNullOrEmpty(project.RagStatus))
                                                                    {
                                                                        <span class="@GetRagBadgeClass(project.RagStatus)">@project.RagStatus</span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="badge badge-secondary">Not set</span>
                                                                    }
                                                                </td>
                                                                <td>@project.BusinessArea</td>
                                                                <td class="text-right">@openIssues</td>
                                                                <td class="text-right">@openRisks</td>
                                                                <td class="text-right">@openActions</td>
                                                                <td class="text-right">@upcomingMilestones</td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                        </div>
                                        @if (Model.OversightProjects.Count > 10)
                                        {
                                            <div class="p-3 border-top">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div>
                                                        Showing <span id="oversightProjectsShowingStart">1</span> to <span id="oversightProjectsShowingEnd">@Math.Min(10, Model.OversightProjects.Count)</span> of <strong id="oversightProjectsTotalCount">@Model.OversightProjects.Count</strong> deliverables
                                                    </div>
                                                    <ul class="pagination pagination-sm m-0" id="oversightProjectsPaginationControls">
                                                        <!-- Pagination buttons will be generated by JavaScript -->
                                                    </ul>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>

                        @if (atRiskProjects.Any())
                        {
                            <div class="row mt-4">
                                <div class="col-12">
                                    <h3 class="h6 text-uppercase text-muted mb-3">At risk projects</h3>
                                    <div class="table-responsive">
                                        <table class="table table-sm static-table">
                                            <thead>
                                                <tr>
                                                    <th scope="col">Project</th>
                                                    <th scope="col">RAG</th>
                                                    <th scope="col">Business area</th>
                                                    <th scope="col">Open issues</th>
                                                    <th scope="col">Open risks</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var project in atRiskProjects.Take(10))
                                                {
                                                    var openIssues = project.Issues?.Count(i => !i.IsDeleted && IsOpenStatus(i.Status)) ?? 0;
                                                    var openRisks = project.Risks?.Count(r => !r.IsDeleted && !string.Equals(r.Status, "closed", StringComparison.OrdinalIgnoreCase)) ?? 0;
                                                    
                                                    <tr>
                                                        <td><a href="@Url.Action("Details", "Project", new { id = project.Id })">@project.Title</a></td>
                                                        <td>
                                                            <span class="badge badge-@(project.RagStatus == "Red" ? "danger" : "warning")">@project.RagStatus</span>
                                                        </td>
                                                        <td>@project.BusinessArea</td>
                                                        <td>@openIssues</td>
                                                        <td>@openRisks</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <p class="mb-0">No projects found in your assigned business areas.</p>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- All users: Assigned items summary -->
        <div class="card shadow-sm mb-4 dashboard-static">
            <div class="card-body">
                <h1 class="h4 mb-4">Assigned to me</h1>
                
                @{
                    var staticMetrics = new[]
                    {
                        (Label: "Assigned actions", Count: Model.AssignedActions?.Count ?? 0),
                        (Label: "Critical issues", Count: Model.HighPriorityIssues?.Count ?? 0),
                        (Label: "Unreviewed risks", Count: Model.UnmonitoredRisks?.Count ?? 0),
                        (Label: "Milestones this fortnight", Count: Model.MilestonesDueThisWeek?.Count ?? 0)
                    };
                    var myProjectRows = (Model.MyProjects ?? Array.Empty<Project>()).Take(6).ToList();
                }

                <div class="row mb-4">
                    @foreach (var metric in staticMetrics)
                    {
                        <div class="col-sm-6 col-lg-3 mb-3">
                            <div class="metric-pill">
                                <strong>@metric.Count</strong>
                                <span>@metric.Label</span>
                            </div>
                        </div>
                    }
                </div>

                <div class="row">
                    <div class="col-12">
                        <h3 class="h6 text-uppercase text-muted mb-3">My projects</h3>
                        @if (!myProjectRows.Any())
                        {
                            <p class="text-muted mb-0">You are not listed on any project teams yet.</p>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-sm static-table">
                                    <thead>
                                        <tr>
                                            <th scope="col">Project</th>
                                            <th scope="col">Priority</th>
                                            <th scope="col">RAG</th>
                                            <th scope="col">Business area</th>
                                            <th scope="col">Risks</th>
                                            <th scope="col">Actions</th>
                                            <th scope="col">Issues</th>
                                            <th scope="col">Decisions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var project in myProjectRows)
                                        {
                                            var activeRisks = project.Risks?.Count(r => !r.IsDeleted) ?? 0;
                                            var activeActions = project.Actions?.Count(a => !a.IsDeleted) ?? 0;
                                            var activeIssues = project.Issues?.Count(i => !i.IsDeleted) ?? 0;
                                            var activeDecisions = project.Decisions?.Count(d => !d.IsDeleted) ?? 0;
                                            <tr>
                                                <td><a href="@Url.Action("Details", "Project", new { id = project.Id })">@project.Title</a></td>
                                                <td>
                                                    @if (project.DeliveryPriority != null)
                                                    {
                                                        <span class="@GetPriorityBadgeClass(project.DeliveryPriority.Name)">@project.DeliveryPriority.Name</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Not set</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(project.RagStatus))
                                                    {
                                                        <span class="@GetRagBadgeClass(project.RagStatus)">@project.RagStatus</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-secondary">Not set</span>
                                                    }
                                                </td>
                                                <td>@project.BusinessArea</td>
                                                <td>@activeRisks</td>
                                                <td>@activeActions</td>
                                                <td>@activeIssues</td>
                                                <td>@activeDecisions</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        (function() {
            // ========================================
            // Table Sorting and Pagination
            // ========================================
            var pageSize = 10;
            var oversightProjectsCurrentPage = 1;
            var oversightProjectsAllRows = [];
            var currentSort = { column: null, direction: 'asc' };
            var oversightProjectsCount = @Model.OversightProjects.Count;
            
            function initOversightProjectsTable() {
                var table = document.getElementById('oversight-projects-table');
                if (!table) {
                    return;
                }
                
                var tbody = table.querySelector('tbody');
                if (!tbody) {
                    return;
                }
                
                oversightProjectsAllRows = Array.from(tbody.querySelectorAll('tr'));
                
                if (oversightProjectsAllRows.length === 0) {
                    return;
                }
                
                initSorting(table);
                
                // Only paginate if we have more than 10 projects
                if (oversightProjectsCount > 10) {
                    paginateOversightProjects();
                } else {
                    // Show all rows if 10 or fewer
                    oversightProjectsAllRows.forEach(function(row) {
                        row.style.display = '';
                    });
                }
            }
            
            function initSorting(table) {
                var sortableHeaders = table.querySelectorAll('.sortable');
                
                sortableHeaders.forEach(function(header) {
                    header.style.cursor = 'pointer';
                    
                    header.addEventListener('click', function(e) {
                        handleSort(e, header);
                    });
                    
                    header.addEventListener('keypress', function(e) {
                        if (e.which === 13 || e.which === 32) {
                            e.preventDefault();
                            handleSort(e, header);
                        }
                    });
                });
            }
            
            function handleSort(e, header) {
                var column = header.getAttribute('data-column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(column, direction);
                currentSort = { column: column, direction: direction };
            }
            
            function updateSortIcons(column, direction) {
                var table = document.getElementById('oversight-projects-table');
                var allHeaders = table.querySelectorAll('.sortable i');
                
                // Reset all icons
                allHeaders.forEach(function(icon) {
                    icon.className = 'fas fa-sort float-right';
                    icon.style.opacity = '0.3';
                });
                
                // Update active column icon
                var activeHeader = table.querySelector('.sortable[data-column="' + column + '"]');
                if (activeHeader) {
                    var icon = activeHeader.querySelector('i');
                    if (icon) {
                        icon.className = direction === 'asc' ? 'fas fa-sort-up float-right' : 'fas fa-sort-down float-right';
                        icon.style.opacity = '1';
                    }
                }
            }
            
            function paginateOversightProjects() {
                var totalProjects = oversightProjectsAllRows.length;
                var totalPages = Math.ceil(totalProjects / pageSize);
                
                // Reset to page 1 if current page is beyond total pages
                if (oversightProjectsCurrentPage > totalPages && totalPages > 0) {
                    oversightProjectsCurrentPage = 1;
                }
                
                // Hide all rows first
                oversightProjectsAllRows.forEach(function(row) {
                    row.style.display = 'none';
                });
                
                // Show only rows for current page
                var startIndex = (oversightProjectsCurrentPage - 1) * pageSize;
                var endIndex = Math.min(startIndex + pageSize, totalProjects);
                
                for (var i = startIndex; i < endIndex; i++) {
                    oversightProjectsAllRows[i].style.display = '';
                }
                
                // Update pagination info
                var showingStart = document.getElementById('oversightProjectsShowingStart');
                var showingEnd = document.getElementById('oversightProjectsShowingEnd');
                if (showingStart) {
                    showingStart.textContent = totalProjects > 0 ? startIndex + 1 : 0;
                }
                if (showingEnd) {
                    showingEnd.textContent = endIndex;
                }
                
                // Always generate pagination controls if we have more than 10 projects
                if (totalProjects > 10) {
                    generateOversightProjectsPagination(totalPages, totalProjects);
                }
            }
            
            function generateOversightProjectsPagination(totalPages, totalProjects) {
                var paginationControls = document.getElementById('oversightProjectsPaginationControls');
                if (!paginationControls) {
                    console.error('Pagination controls element not found');
                    return;
                }
                
                // Only generate pagination if we have more than one page
                if (totalPages <= 1) {
                    paginationControls.innerHTML = '';
                    return;
                }
                
                var paginationHtml = '';
                
                // Previous button
                paginationHtml += '<li class="page-item ' + (oversightProjectsCurrentPage === 1 ? 'disabled' : '') + '">';
                paginationHtml += '<a class="page-link" href="#" data-page="' + (oversightProjectsCurrentPage - 1) + '">Previous</a>';
                paginationHtml += '</li>';
                
                // Page numbers
                var startPage = Math.max(1, oversightProjectsCurrentPage - 2);
                var endPage = Math.min(totalPages, oversightProjectsCurrentPage + 2);
                
                if (startPage > 1) {
                    paginationHtml += '<li class="page-item"><a class="page-link" href="#" data-page="1">1</a></li>';
                    if (startPage > 2) {
                        paginationHtml += '<li class="page-item disabled"><span class="page-link">...</span></li>';
                    }
                }
                
                for (var i = startPage; i <= endPage; i++) {
                    paginationHtml += '<li class="page-item ' + (i === oversightProjectsCurrentPage ? 'active' : '') + '">';
                    paginationHtml += '<a class="page-link" href="#" data-page="' + i + '">' + i + '</a>';
                    paginationHtml += '</li>';
                }
                
                if (endPage < totalPages) {
                    if (endPage < totalPages - 1) {
                        paginationHtml += '<li class="page-item disabled"><span class="page-link">...</span></li>';
                    }
                    paginationHtml += '<li class="page-item"><a class="page-link" href="#" data-page="' + totalPages + '">' + totalPages + '</a></li>';
                }
                
                // Next button
                paginationHtml += '<li class="page-item ' + (oversightProjectsCurrentPage === totalPages ? 'disabled' : '') + '">';
                paginationHtml += '<a class="page-link" href="#" data-page="' + (oversightProjectsCurrentPage + 1) + '">Next</a>';
                paginationHtml += '</li>';
                
                paginationControls.innerHTML = paginationHtml;
                
                // Bind click events using event delegation (remove old listener first)
                var oldHandler = paginationControls._paginationHandler;
                if (oldHandler) {
                    paginationControls.removeEventListener('click', oldHandler);
                }
                
                var clickHandler = function(e) {
                    var link = e.target.closest('.page-link');
                    if (link && !link.closest('.disabled')) {
                        e.preventDefault();
                        var page = parseInt(link.getAttribute('data-page'));
                        var totalPages = Math.ceil(oversightProjectsAllRows.length / pageSize);
                        if (!isNaN(page) && page > 0 && page <= totalPages) {
                            oversightProjectsCurrentPage = page;
                            paginateOversightProjects();
                        }
                    }
                };
                
                paginationControls._paginationHandler = clickHandler;
                paginationControls.addEventListener('click', clickHandler);
            }
            
            function sortTable(column, direction) {
                var table = document.getElementById('oversight-projects-table');
                var tbody = table.querySelector('tbody');
                var colIndex = Array.from(table.querySelectorAll('thead th')).findIndex(function(th) {
                    return th.getAttribute('data-column') === column;
                });
                
                oversightProjectsAllRows.sort(function(a, b) {
                    var aVal, bVal;
                    var aCell = a.querySelectorAll('td')[colIndex];
                    var bCell = b.querySelectorAll('td')[colIndex];
                    
                    // Get values from data attributes for numeric columns
                    if (column === 'OpenIssues') {
                        aVal = parseInt(a.getAttribute('data-open-issues')) || 0;
                        bVal = parseInt(b.getAttribute('data-open-issues')) || 0;
                    } else if (column === 'OpenRisks') {
                        aVal = parseInt(a.getAttribute('data-open-risks')) || 0;
                        bVal = parseInt(b.getAttribute('data-open-risks')) || 0;
                    } else if (column === 'OpenActions') {
                        aVal = parseInt(a.getAttribute('data-open-actions')) || 0;
                        bVal = parseInt(b.getAttribute('data-open-actions')) || 0;
                    } else if (column === 'UpcomingMilestones') {
                        aVal = parseInt(a.getAttribute('data-upcoming-milestones')) || 0;
                        bVal = parseInt(b.getAttribute('data-upcoming-milestones')) || 0;
                    } else if (column === 'Project') {
                        // Sort by link text
                        var aLink = aCell.querySelector('a');
                        var bLink = bCell.querySelector('a');
                        aVal = aLink ? aLink.textContent.trim().toLowerCase() : aCell.textContent.trim().toLowerCase();
                        bVal = bLink ? bLink.textContent.trim().toLowerCase() : bCell.textContent.trim().toLowerCase();
                    } else if (column === 'Priority') {
                        // Sort by data attribute or badge text
                        aVal = a.getAttribute('data-priority') || aCell.textContent.trim();
                        bVal = b.getAttribute('data-priority') || bCell.textContent.trim();
                        aVal = aVal.toLowerCase();
                        bVal = bVal.toLowerCase();
                    } else if (column === 'RAG') {
                        // Sort by data attribute or badge text
                        aVal = a.getAttribute('data-rag') || aCell.textContent.trim();
                        bVal = b.getAttribute('data-rag') || bCell.textContent.trim();
                        aVal = aVal.toLowerCase();
                        bVal = bVal.toLowerCase();
                    } else if (column === 'BusinessArea') {
                        // Sort by data attribute or cell text
                        aVal = a.getAttribute('data-business-area') || aCell.textContent.trim();
                        bVal = b.getAttribute('data-business-area') || bCell.textContent.trim();
                        aVal = (aVal || '').toLowerCase();
                        bVal = (bVal || '').toLowerCase();
                    } else {
                        // Sort by cell text
                        aVal = aCell.textContent.trim().toLowerCase();
                        bVal = bCell.textContent.trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                // Rebuild tbody with sorted rows
                tbody.innerHTML = '';
                oversightProjectsAllRows.forEach(function(row) {
                    tbody.appendChild(row);
                });
                
                // Update sort icons
                updateSortIcons(column, direction);
                
                // Re-paginate if needed
                if (oversightProjectsCount > 10) {
                    oversightProjectsCurrentPage = 1;
                    paginateOversightProjects();
                }
            }
            
            // Initialize table when DOM is ready
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initOversightProjectsTable);
            } else {
                // DOM is already ready
                setTimeout(initOversightProjectsTable, 100);
            }

            // ========================================
            // Test User Selector (Development Only)
            // ========================================
            function loadTestUsers() {
                var testUserSelect = document.getElementById('testUserSelect');
                if (!testUserSelect) {
                    return;
                }

                fetch('@Url.Action("GetTestUsers", "Home")')
                    .then(function(response) {
                        if (!response.ok) {
                            // If the endpoint fails, just log and continue
                            console.warn('Test users endpoint returned status:', response.status);
                            return [];
                        }
                        return response.json();
                    })
                    .then(function(users) {
                        if (!users || users.length === 0) {
                            // If no users returned, add a disabled option
                            var option = document.createElement('option');
                            option.value = '0';
                            option.textContent = 'No users available';
                            option.disabled = true;
                            testUserSelect.appendChild(option);
                            return;
                        }

                        var currentTestUserId = '@(Context.Request.Cookies["TestDashboardUserId"])';
                        users.forEach(function(user) {
                            var option = document.createElement('option');
                            option.value = user.id;
                            option.textContent = user.name + ' (' + user.email + ')';
                            if (currentTestUserId && currentTestUserId === user.id.toString()) {
                                option.selected = true;
                            }
                            testUserSelect.appendChild(option);
                        });
                    })
                    .catch(function(error) {
                        console.error('Error loading test users:', error);
                        // Add a disabled option to indicate the error
                        var option = document.createElement('option');
                        option.value = '0';
                        option.textContent = 'Unable to load users';
                        option.disabled = true;
                        testUserSelect.appendChild(option);
                    });
            }

            // Load users when DOM is ready
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', loadTestUsers);
            } else {
                loadTestUsers();
            }
        })();
    </script>
}
