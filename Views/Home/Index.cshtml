            margin-top: 0.75rem;
            font-size: 0.875rem;
        }

        .work-item-meta-row {
            display: flex;
            flex-wrap: wrap;
            align-items: flex-start;
            gap: 1rem;
        }

        .work-item-meta-label {
            font-weight: 600;
            color: #6b7280;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 0.25rem;
            display: block;
        }

        .work-item-meta-item {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            min-width: 0;
        }

        .work-item-meta-item .badge {
            font-weight: 500;
            align-self: flex-start;
        }

        .work-item-meta-item .text-muted {
            align-self: flex-start;
        }

        .work-item-meta-item .text-muted {
            align-self: flex-start;
        }

        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
            color: #6b7280;
        }

        .empty-state-icon {
            font-size: 3rem;
            opacity: 0.3;
            margin-bottom: 1rem;
        }

        .task-item {
            display: flex;
            align-items: center;
            padding: 1rem;
            border-bottom: 1px solid #f3f4f6;
        }

        .task-item:last-child {
            border-bottom: none;
        }

        .task-item.priority-high {
            border-left: 4px solid #dc2626;
        }

        .task-item.priority-medium {
            border-left: 4px solid #d97706;
        }

        .task-item.priority-low {
            border-left: 4px solid #16a34a;
        }

        .task-content {
            flex: 1;
        }

        .task-title {
            font-weight: 600;
            margin-bottom: 0.25rem;
        }

        .task-title a {
            color: #1f2937;
            text-decoration: none;
        }

        .task-title a:hover {
            color: #667eea;
        }

        .task-meta {
            font-size: 0.875rem;
            color: #6b7280;
        }

        .tabs-container {
            border-bottom: 2px solid #f3f4f6;
            margin-bottom: 1.5rem;
        }

        .tab-button {
            background: none;
            border: none;
            padding: 0.75rem 1.5rem;
            cursor: pointer;
            font-weight: 500;
            color: #6b7280;
            border-bottom: 3px solid transparent;
            transition: all 0.2s;
        }

        .tab-button:hover {
            color: #667eea;
        }

        .tab-button.active {
            color: #667eea;
            border-bottom-color: #667eea;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        .leadership-panel {
            border-radius: 16px;
            border: 1px solid rgba(15, 30, 90, 0.12);
            padding: 1.5rem;
            background: linear-gradient(160deg, rgba(39, 76, 255, 0.08), rgba(39, 76, 255, 0));
            margin-bottom: 2rem;
        }

        .mission-card, .outcome-card {
            border: 1px solid rgba(15, 30, 90, 0.12);
            border-radius: 8px;
            padding: 1rem;
            margin-bottom: 1rem;
            background: #ffffff;
        }

        .metric-pill {
            border-radius: 14px;
            border: 1px solid rgba(15, 30, 90, 0.12);
            background: linear-gradient(145deg, #ffffff, #f8f9ff);
            padding: 1.25rem;
            height: 100%;
            box-shadow: 0 10px 18px rgba(12, 25, 64, 0.06);
        }

        .metric-pill strong {
            display: block;
            font-size: 2rem;
            line-height: 1.2;
        }

        .metric-pill span {
            color: #5c6480;
            font-size: 0.95rem;
        }

        @@media (max-width: 768px) {
            .quick-stats {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

@functions {
    string GetTimeBasedGreeting()
    {
        var hour = DateTime.Now.Hour;
        if (hour < 12)
            return "Good morning";
        else if (hour < 17)
            return "Good afternoon";
        else
            return "Good evening";
    }

    string GetRagBadgeClass(string ragStatus)
    {
        if (string.IsNullOrWhiteSpace(ragStatus))
            return "badge badge-secondary";
        
        var normalized = ragStatus.Trim()
            .Replace(" / ", "-")
            .Replace("/", "-")
            .Replace(" /", "-")
            .Replace("/ ", "-");
        
        return normalized switch
        {
            "Green" => "badge badge-success",
            "Amber-Green" => "badge badge-warning",
            "Amber" => "badge badge-warning",
            "Amber-Red" => "badge badge-danger",
            "Red" => "badge badge-danger",
            _ => "badge badge-secondary"
        };
    }

    string GetPriorityBadgeClass(string priorityName)
    {
        if (string.IsNullOrWhiteSpace(priorityName))
            return "badge badge-secondary";

        var normalized = priorityName.Trim().ToLowerInvariant();
        return normalized switch
        {
            "high" => "badge badge-danger",
            "medium" => "badge badge-warning",
            "low" => "badge badge-success",
            _ => "badge badge-secondary"
        };
    }

    bool IsOpenStatus(string? status)
    {
        return !string.Equals(status, "closed", StringComparison.OrdinalIgnoreCase) &&
               !string.Equals(status, "resolved", StringComparison.OrdinalIgnoreCase) &&
               !string.Equals(status, "complete", StringComparison.OrdinalIgnoreCase) &&
               !string.Equals(status, "cancelled", StringComparison.OrdinalIgnoreCase);
    }

    string GetRoleBadgeClass(LeadershipRoleTier role)
    {
        return role switch
        {
            LeadershipRoleTier.PermanentSecretary => "badge badge-primary",
            LeadershipRoleTier.DirectorGeneral => "badge badge-info",
            LeadershipRoleTier.CLevel => "badge badge-info",
            LeadershipRoleTier.DeputyDirectorOrSro => "badge badge-success",
            LeadershipRoleTier.HeadOfProfession => "badge badge-success",
            LeadershipRoleTier.PortfolioLead => "badge badge-secondary",
            _ => "badge badge-secondary"
        };
    }

    string GetRoleLabel(LeadershipRoleTier role)
    {
        return role switch
        {
            LeadershipRoleTier.PermanentSecretary => "Permanent Secretary",
            LeadershipRoleTier.DirectorGeneral => "Director General",
            LeadershipRoleTier.CLevel => "C-Level",
            LeadershipRoleTier.DeputyDirectorOrSro => "Deputy Director / SRO",
            LeadershipRoleTier.HeadOfProfession => "Head of Profession",
            LeadershipRoleTier.PortfolioLead => "Portfolio Lead / G6",
            _ => role.ToString()
        };
    }

    string GetBusinessAreaOverviewTitle()
    {
        if (!Model.HighestLeadershipRole.HasValue)
        {
            return "Business area overview";
        }

        return Model.HighestLeadershipRole.Value switch
        {
            LeadershipRoleTier.HeadOfProfession => "Head of profession",
            LeadershipRoleTier.CLevel => !string.IsNullOrWhiteSpace(Model.CurrentUser.JobTitle) 
                ? Model.CurrentUser.JobTitle 
                : "C-level",
            LeadershipRoleTier.DeputyDirectorOrSro => Model.LeadershipBusinessAreas.Any()
                ? string.Join(", ", Model.LeadershipBusinessAreas.Take(3))
                : "Deputy director",
            LeadershipRoleTier.PortfolioLead => "Portfolio lead",
            LeadershipRoleTier.DirectorGeneral => "Director general",
            LeadershipRoleTier.PermanentSecretary => "Permanent secretary",
            _ => "Business area overview"
        };
    }
}

<section class="content mt-4">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

    

        <!-- Dashboard Header -->
        <div class="dashboard-header">
            <h1>@GetTimeBasedGreeting(), @Model.FirstName!</h1>
            <p>Here's an overview of your work, assignments, and responsibilities.</p>
        </div>

        <!-- Quick Stats -->
        <div class="dashboard-summary-cards">
            @if (Model.OverdueMilestones.Any())
            {
                <a href="@Url.Action("Index", "Project")" class="dashboard-card bg-danger" style="text-decoration: none; color: inherit;">
                    <div class="dashboard-card-value">@(Model.OverdueMilestones?.Count ?? 0)</div>
                    <div class="dashboard-card-label">Overdue Milestones</div>
                    <div class="dashboard-card-icon"><i class="fas fa-exclamation-triangle"></i></div>
                </a>
            }
            
            @if (Model.AssignedActions.Any())
            {
                <a href="@Url.Action("Index", "Raid", new { viewType = "actions" })" class="dashboard-card bg-warning" style="text-decoration: none; color: inherit;">
                    <div class="dashboard-card-value">@(Model.AssignedActions?.Count ?? 0)</div>
                    <div class="dashboard-card-label">Assigned Actions</div>
                    <div class="dashboard-card-icon"><i class="fas fa-tasks"></i></div>
                </a>
            }
            
            @if (Model.HighPriorityIssues.Any())
            {
                <a href="@Url.Action("Index", "Raid", new { viewType = "issues" })" class="dashboard-card bg-danger" style="text-decoration: none; color: inherit;">
                    <div class="dashboard-card-value">@(Model.HighPriorityIssues?.Count ?? 0)</div>
                    <div class="dashboard-card-label">High Priority Issues</div>
                    <div class="dashboard-card-icon"><i class="fas fa-bug"></i></div>
                </a>
            }
            
            @if (Model.MyProjects.Any())
            {
                <a href="@Url.Action("Index", "Project")" class="dashboard-card bg-primary" style="text-decoration: none; color: inherit;">
                    <div class="dashboard-card-value">@(Model.MyProjects?.Count ?? 0)</div>
                    <div class="dashboard-card-label">My Projects</div>
                    <div class="dashboard-card-icon"><i class="fas fa-project-diagram"></i></div>
                </a>
            }
            
            @if (Model.WatchedProjects.Any())
            {
                <a href="@Url.Action("Index", "Project")" class="dashboard-card bg-info" style="text-decoration: none; color: inherit;">
                    <div class="dashboard-card-value">@(Model.WatchedProjects?.Count ?? 0)</div>
                    <div class="dashboard-card-label">Watched Projects</div>
                    <div class="dashboard-card-icon"><i class="fas fa-eye"></i></div>
                </a>
            }
            
            @if (Model.MyProducts.Any())
            {
                <a href="@Url.Action("Index", "Products")" class="dashboard-card bg-primary" style="text-decoration: none; color: inherit;">
                    <div class="dashboard-card-value">@(Model.MyProducts?.Count ?? 0)</div>
                    <div class="dashboard-card-label">My Products</div>
                    <div class="dashboard-card-icon"><i class="fas fa-box"></i></div>
                </a>
            }
            
            @if (Model.MyDdtStandards.Any())
            {
                <a href="@Url.Action("Dashboard", "DdtStandards")" class="dashboard-card bg-primary" style="text-decoration: none; color: inherit;">
                    <div class="dashboard-card-value">@(Model.MyDdtStandards?.Count ?? 0)</div>
                    <div class="dashboard-card-label">My DDT Standards</div>
                    <div class="dashboard-card-icon"><i class="fas fa-book"></i></div>
                </a>
            }
        </div>

        <!-- Leadership Views -->
        @if (Model.IsEnterpriseLeader || Model.IsBusinessAreaLeader)
        {
            @if (Model.IsEnterpriseLeader)
            {
                <div class="dashboard-section">
                    <div class="dashboard-section-header">
                        <h2><i class="fas fa-building"></i> Enterprise Overview</h2>
                    </div>
                    <div class="row mb-4">
                        <div class="col-md-3 mb-3">
                            <div class="metric-pill">
                                <strong>@Model.EnterpriseMetrics.TotalAtRiskProjects</strong>
                                <span>At Risk Projects</span>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="metric-pill">
                                <strong>@Model.EnterpriseMetrics.TotalOpenIssues</strong>
                                <span>Open Issues</span>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="metric-pill">
                                <strong>@Model.EnterpriseMetrics.TotalOpenRisks</strong>
                                <span>Open Risks</span>
                            </div>
                        </div>
                        <div class="col-md-3 mb-3">
                            <div class="metric-pill">
                                <strong>@Model.EnterpriseMetrics.ActiveMissionsCount</strong>
                                <span>Active Missions</span>
                            </div>
                        </div>
                    </div>
                    @if (Model.EnterpriseAtRiskProjects.Any())
                    {
                        <div class="alert alert-danger">
                            <strong><i class="fas fa-exclamation-triangle mr-2"></i>@Model.EnterpriseAtRiskProjects.Count At Risk Projects</strong>
                            <a href="#at-risk-projects" class="ml-2">View details →</a>
                        </div>
                    }
                </div>
            }

        }

        <!-- My Work Section -->
        <div class="dashboard-section">
            <div class="dashboard-section-header">
                <h2><i class="fas fa-briefcase"></i> My work</h2>
                <div class="view-toggle">
                    <button class="view-toggle-btn active" data-view="cards" title="Card view">
                        <i class="fas fa-th"></i> Cards
                    </button>
                    <button class="view-toggle-btn" data-view="list" title="List view">
                        <i class="fas fa-list"></i> List
                    </button>
                </div>
            </div>

            <div class="tabs-container">
                <button class="tab-button active" data-tab="tasks">Tasks (@taskCount)</button>
                <button class="tab-button" data-tab="projects">Projects (@Model.MyProjects.Count)</button>
                <button class="tab-button" data-tab="watching">Watching (@Model.WatchedProjects.Count)</button>
                <button class="tab-button" data-tab="products">Products (@Model.MyProducts.Count)</button>
                <button class="tab-button" data-tab="standards">DDT Standards (@Model.MyDdtStandards.Count)</button>
            </div>

            <!-- Tasks Tab -->
            <div id="tab-tasks" class="tab-content active">
                @if (!Model.AssignedActions.Any() && !Model.OverdueMilestones.Any() && !Model.HighPriorityIssues.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-icon">✅</div>
                        <h3>No tasks</h3>
                        <p>You're all caught up! There are no overdue milestones, assigned actions, or high priority issues.</p>
                    </div>
                }
                else
                {
                    <!-- Cards View -->
                    <div class="work-items-grid active" data-view="cards">
                        @foreach (var milestone in Model.OverdueMilestones.Take(10))
                        {
                            <a href="@Url.Action("MilestoneDetails", "Project", new { id = milestone.Id })" class="work-item-card">
                                <h4>@milestone.Name</h4>
                                @if (milestone.Project != null)
                                {
                                    <p class="work-item-project">@milestone.Project.Title</p>
                                }
                                <div class="work-item-meta">
                                    <div class="work-item-meta-row">
                                        <span class="badge badge-danger">Overdue milestone</span>
                                        <span class="text-muted">Due: @milestone.DueDate.ToString("dd MMMM yyyy")</span>
                                    </div>
                                </div>
                            </a>
                        }

                        @foreach (var action in Model.AssignedActions.Take(10))
                        {
                            <a href="@Url.Action("Details", "Action", new { id = action.Id })" class="work-item-card">
                                <h4>@action.Title</h4>
                                @if (action.Project != null)
                                {
                                    <p class="work-item-project">@action.Project.Title</p>
                                }
                                <div class="work-item-meta">
                                    <div class="work-item-meta-row">
                                        <span class="badge badge-warning">Action</span>
                                        @if (action.PriorityLookup != null)
                                        {
                                            <span class="@GetPriorityBadgeClass(action.PriorityLookup.Label)">@action.PriorityLookup.Label</span>
                                        }
                                        @if (action.DueDate.HasValue)
                                        {
