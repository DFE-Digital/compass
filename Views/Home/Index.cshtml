@model Compass.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var userName = Model.CurrentUser?.Name ?? User.Identity?.Name ?? "User";
    var userEmail = User.Identity?.Name ?? "";
    var currentView = ViewBag.CurrentView as string ?? "overview";
    var statusFilter = ViewBag.StatusFilter as string;
    var priorityFilter = ViewBag.PriorityFilter as string;
    var dateFilter = ViewBag.DateFilter as string ?? "all";
    
    // Calculate urgent items
    var overdueIssues = Model.MyIssues.Count(i => IsOverdue(i.TargetResolutionDate, i.Status, new[] { "resolved", "closed" }));
    var overdueActions = Model.MyActions.Count(a => IsOverdue(a.DueDate, a.Status, new[] { "done", "cancelled" }));
    var overdueRisks = Model.MyRisks.Count(r => IsOverdue(r.TargetDate, r.Status, new[] { "closed" }));
    var overdueMilestones = Model.MyMilestones.Count(m => IsOverdue(m.DueDate, m.Status, new[] { "complete", "cancelled" }));
    var totalOverdue = overdueIssues + overdueActions + overdueRisks + overdueMilestones;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Dashboard</h1>
                <p class="text-muted mb-0">Welcome back, @userName</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <!-- Navigation Tabs -->
        <ul class="nav nav-tabs mb-3" role="tablist">
            <li class="nav-item">
                <a class="nav-link @(currentView == "overview" ? "active" : "")" href="/?view=overview">Overview</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentView == "products" ? "active" : "")" href="/?view=products">Products</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentView == "issues" ? "active" : "")" href="/?view=issues">Issues</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentView == "risks" ? "active" : "")" href="/?view=risks">Risks</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentView == "actions" ? "active" : "")" href="/?view=actions">Actions</a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(currentView == "milestones" ? "active" : "")" href="/?view=milestones">Milestones</a>
            </li>
        </ul>

        <!-- ============================================================ -->
        <!-- INLINE FILTERS (for non-overview views) -->
        <!-- ============================================================ -->
        @if (currentView != "overview" && currentView != "products")
        {
            <div class="card">
                <div class="card-body pb-2">
                    <form method="get" action="/" id="filterForm" class="form-inline">
                        <input type="hidden" name="view" value="@currentView" />
                        
                        <div class="form-group mr-2 mb-2">
                            <label class="mr-2 font-weight-bold">Filters:</label>
                        </div>

                        <!-- Date Filter -->
                        <div class="form-group mr-3 mb-2">
                            <label class="mr-2 text-muted"><small>Time period</small></label>
                            <select name="dateFilter" class="form-control form-control-sm auto-submit" style="width: auto;">
                                <option value="all" selected="@(dateFilter == "all")">All time</option>
                                <option value="overdue" selected="@(dateFilter == "overdue")">Overdue only</option>
                                <option value="today" selected="@(dateFilter == "today")">Due today</option>
                                <option value="week" selected="@(dateFilter == "week")">Due this week</option>
                                <option value="month" selected="@(dateFilter == "month")">Due this month</option>
                                <option value="next_month" selected="@(dateFilter == "next_month")">Due next month</option>
                            </select>
                        </div>

                        @if (currentView == "issues")
                        {
                            <div class="form-group mr-3 mb-2">
                                <label class="mr-2 text-muted"><small>Status</small></label>
                                <select name="statusFilter" class="form-control form-control-sm auto-submit" style="width: auto;">
                                    <option value="">All</option>
                                    <option value="open" selected="@(statusFilter == "open")">Open</option>
                                    <option value="in_progress" selected="@(statusFilter == "in_progress")">In progress</option>
                                    <option value="blocked" selected="@(statusFilter == "blocked")">Blocked</option>
                                    <option value="resolved" selected="@(statusFilter == "resolved")">Resolved</option>
                                    <option value="closed" selected="@(statusFilter == "closed")">Closed</option>
                                </select>
                            </div>
                            
                            <div class="form-group mr-3 mb-2">
                                <label class="mr-2 text-muted"><small>Severity</small></label>
                                <select name="priorityFilter" class="form-control form-control-sm auto-submit" style="width: auto;">
                                    <option value="">All</option>
                                    <option value="critical" selected="@(priorityFilter == "critical")">Critical</option>
                                    <option value="high" selected="@(priorityFilter == "high")">High</option>
                                    <option value="medium" selected="@(priorityFilter == "medium")">Medium</option>
                                    <option value="low" selected="@(priorityFilter == "low")">Low</option>
                                </select>
                            </div>
                        }

                        @if (currentView == "risks")
                        {
                            <div class="form-group mr-3 mb-2">
                                <label class="mr-2 text-muted"><small>Status</small></label>
                                <select name="statusFilter" class="form-control form-control-sm auto-submit" style="width: auto;">
                                    <option value="">All</option>
                                    <option value="new" selected="@(statusFilter == "new")">New</option>
                                    <option value="open" selected="@(statusFilter == "open")">Open</option>
                                    <option value="treating" selected="@(statusFilter == "treating")">Treating</option>
                                    <option value="monitoring" selected="@(statusFilter == "monitoring")">Monitoring</option>
                                    <option value="closed" selected="@(statusFilter == "closed")">Closed</option>
                                </select>
                            </div>
                            
                            <div class="form-group mr-3 mb-2">
                                <label class="mr-2 text-muted"><small>Risk score</small></label>
                                <select name="priorityFilter" class="form-control form-control-sm auto-submit" style="width: auto;">
                                    <option value="">All</option>
                                    <option value="critical" selected="@(priorityFilter == "critical")">Critical (15-25)</option>
                                    <option value="high" selected="@(priorityFilter == "high")">High (10-14)</option>
                                    <option value="medium" selected="@(priorityFilter == "medium")">Medium (5-9)</option>
                                    <option value="low" selected="@(priorityFilter == "low")">Low (1-4)</option>
                                </select>
                            </div>
                        }

                        @if (currentView == "actions")
                        {
                            <div class="form-group mr-3 mb-2">
                                <label class="mr-2 text-muted"><small>Status</small></label>
                                <select name="statusFilter" class="form-control form-control-sm auto-submit" style="width: auto;">
                                    <option value="">All</option>
                                    <option value="not_started" selected="@(statusFilter == "not_started")">Not started</option>
                                    <option value="in_progress" selected="@(statusFilter == "in_progress")">In progress</option>
                                    <option value="blocked" selected="@(statusFilter == "blocked")">Blocked</option>
                                    <option value="done" selected="@(statusFilter == "done")">Done</option>
                                    <option value="cancelled" selected="@(statusFilter == "cancelled")">Cancelled</option>
                                </select>
                            </div>
                            
                            <div class="form-group mr-3 mb-2">
                                <label class="mr-2 text-muted"><small>Priority</small></label>
                                <select name="priorityFilter" class="form-control form-control-sm auto-submit" style="width: auto;">
                                    <option value="">All</option>
                                    <option value="high" selected="@(priorityFilter == "high")">High</option>
                                    <option value="medium" selected="@(priorityFilter == "medium")">Medium</option>
                                    <option value="low" selected="@(priorityFilter == "low")">Low</option>
                                </select>
                            </div>
                        }

                        @if (currentView == "milestones")
                        {
                            <div class="form-group mr-3 mb-2">
                                <label class="mr-2 text-muted"><small>Status</small></label>
                                <select name="statusFilter" class="form-control form-control-sm auto-submit" style="width: auto;">
                                    <option value="">All</option>
                                    <option value="not_started" selected="@(statusFilter == "not_started")">Not started</option>
                                    <option value="on_track" selected="@(statusFilter == "on_track")">On track</option>
                                    <option value="at_risk" selected="@(statusFilter == "at_risk")">At risk</option>
                                    <option value="delayed" selected="@(statusFilter == "delayed")">Delayed</option>
                                    <option value="complete" selected="@(statusFilter == "complete")">Complete</option>
                                    <option value="cancelled" selected="@(statusFilter == "cancelled")">Cancelled</option>
                                </select>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(statusFilter) || !string.IsNullOrEmpty(priorityFilter) || dateFilter != "all")
                        {
                            <div class="form-group mb-2">
                                <a href="/?view=@currentView" class="btn btn-sm btn-default">
                                    <i class="fas fa-times mr-1"></i> Clear filters
                                </a>
                            </div>
                        }
                    </form>
                </div>
            </div>
        }

        <!-- Main content area -->
        <div class="row">
            <div class="col-12">

                @if (currentView == "overview")
                {
                    <!-- Summary Stats -->
                    <div class="row">
                        <div class="col-lg-3 col-md-6 col-12">
                            <div class="small-box bg-info">
                                <div class="inner">
                                    <h3>@Model.TotalProducts</h3>
                                    <p>My products</p>
                                </div>
                                <a href="/?view=products" class="small-box-footer">View details</a>
                            </div>
                        </div>
                        
                        <div class="col-lg-3 col-md-6 col-12">
                            <div class="small-box @(overdueIssues > 0 ? "bg-danger" : Model.OpenIssues > 0 ? "bg-warning" : "bg-success")">
                                <div class="inner">
                                    <h3>@Model.OpenIssues</h3>
                                    <p>Open issues</p>
                                    @if (overdueIssues > 0)
                                    {
                                        <p class="mb-0"><small>@overdueIssues overdue</small></p>
                                    }
                                </div>
                                <a href="/?view=issues" class="small-box-footer">View details</a>
                            </div>
                        </div>
                        
                        <div class="col-lg-3 col-md-6 col-12">
                            <div class="small-box @(overdueRisks > 0 ? "bg-danger" : Model.ActiveRisks > 0 ? "bg-warning" : "bg-success")">
                                <div class="inner">
                                    <h3>@Model.ActiveRisks</h3>
                                    <p>Active risks</p>
                                    @if (overdueRisks > 0)
                                    {
                                        <p class="mb-0"><small>@overdueRisks overdue</small></p>
                                    }
                                </div>
                                <a href="/?view=risks" class="small-box-footer">View details</a>
                            </div>
                        </div>
                        
                        <div class="col-lg-3 col-md-6 col-12">
                            @{
                                var openActions = Model.MyActions.Count(a => a.Status != "done" && a.Status != "cancelled");
                            }
                            <div class="small-box @(overdueActions > 0 ? "bg-danger" : openActions > 0 ? "bg-primary" : "bg-success")">
                                <div class="inner">
                                    <h3>@openActions</h3>
                                    <p>Open actions</p>
                                    @if (overdueActions > 0)
                                    {
                                        <p class="mb-0"><small>@overdueActions overdue</small></p>
                                    }
                                </div>
                                <a href="/?view=actions" class="small-box-footer">View details</a>
                            </div>
                        </div>
                    </div>

                    <!-- Milestones Summary -->
                    @if (Model.TotalMilestones > 0)
                    {
                        int completeMilestones = Model.MyMilestones.Count(m => m.Status == "complete");
                        int completionPercent = (int)((double)completeMilestones / Model.TotalMilestones * 100);
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Milestones</h3>
                                <div class="card-tools">
                                    <a href="/?view=milestones" class="btn btn-sm btn-outline-primary">View all</a>
                                </div>
                            </div>
                            <div class="card-body">
                                <p class="text-muted mb-2">@completeMilestones of @Model.TotalMilestones completed (@completionPercent%)</p>
                                <div class="progress mb-3" style="height: 20px;">
                                    <div class="progress-bar bg-success" role="progressbar" 
                                         style="width: @completionPercent%;" 
                                         aria-valuenow="@completionPercent" 
                                         aria-valuemin="0" 
                                         aria-valuemax="100">
                                    </div>
                                </div>
                                @if (overdueMilestones > 0 || Model.UrgentMilestones > 0)
                                {
                                    <div class="row">
                                        @if (overdueMilestones > 0)
                                        {
                                            <div class="col-6">
                                                <span class="text-danger">@overdueMilestones overdue</span>
                                            </div>
                                        }
                                        @if (Model.UrgentMilestones > 0)
                                        {
                                            <div class="col-6">
                                                <span class="text-warning">@Model.UrgentMilestones urgent</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <!-- Priority Items requiring attention -->
                    var priorityItems = new List<(string Type, string Title, string Url, DateTime? Date, string Severity, bool IsOverdue)>();
                    
                    // Add overdue/urgent items
                    foreach (var issue in Model.MyIssues.Where(i => i.Status != "resolved" && i.Status != "closed").Take(5))
                    {
                        var isOverdue = IsOverdue(issue.TargetResolutionDate, issue.Status, new[] { "resolved", "closed" });
                        if (isOverdue || issue.Severity == "critical" || issue.Severity == "high")
                        {
                            priorityItems.Add(("Issue", issue.Title, $"/Issue/Edit/{issue.Id}", issue.TargetResolutionDate, issue.Severity, isOverdue));
                        }
                    }
                    
                    foreach (var action in Model.MyActions.Where(a => a.Status != "done" && a.Status != "cancelled").Take(5))
                    {
                        var isOverdue = IsOverdue(action.DueDate, action.Status, new[] { "done", "cancelled" });
                        if (isOverdue || action.Priority == "high")
                        {
                            priorityItems.Add(("Action", action.Title, $"/Action/Edit/{action.Id}", action.DueDate, action.Priority ?? "medium", isOverdue));
                        }
                    }
                    
                    foreach (var risk in Model.MyRisks.Where(r => r.Status != "closed" && r.RiskScore >= 10).Take(5))
                    {
                        var isOverdue = IsOverdue(risk.TargetDate, risk.Status, new[] { "closed" });
                        var severity = risk.RiskScore >= 15 ? "critical" : "high";
                        priorityItems.Add(("Risk", risk.Title, $"/Risk/Edit/{risk.Id}", risk.TargetDate, severity, isOverdue));
                    }
                    
                    priorityItems = priorityItems
                        .OrderByDescending(item => item.IsOverdue)
                        .ThenBy(item => item.Date ?? DateTime.MaxValue)
                        .Take(10)
                        .ToList();

                    @if (priorityItems.Any())
                    {
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Priority items</h3>
                            </div>
                            <div class="card-body p-0">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Item</th>
                                            <th style="width: 100px;">Type</th>
                                            <th style="width: 100px;">Severity</th>
                                            <th style="width: 120px;">Due date</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in priorityItems)
                                        {
                                            var severityClass = GetSeverityBadgeClass(item.Severity);
                                            
                                            <tr class="@(item.IsOverdue ? "table-danger" : "")">
                                                <td>
                                                    <a href="@item.Url">@item.Title</a>
                                                </td>
                                                <td>@item.Type</td>
                                                <td>
                                                    <span class="badge @severityClass">@item.Severity</span>
                                                </td>
                                                <td>
                                                    @if (item.Date.HasValue)
                                                    {
                                                        <span class="@(item.IsOverdue ? "text-danger" : "")">
                                                            @item.Date.Value.ToString("dd MMM yyyy")
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">No date</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                    @if (Model.TotalProducts == 0 && Model.TotalIssues == 0 && Model.TotalRisks == 0 && Model.TotalActions == 0 && Model.TotalMilestones == 0)
                    {
                        <div class="card">
                            <div class="card-body text-center py-5">
                                <h4>Welcome to Compass</h4>
                                <p class="text-muted">You don't have any items assigned to you yet.</p>
                                <div class="btn-group mt-3">
                                    <a href="/Products" class="btn btn-primary">Browse products</a>
                                    <a href="/Issue/Create" class="btn btn-outline-secondary">Create issue</a>
                                    <a href="/Risk/Create" class="btn btn-outline-secondary">Create risk</a>
                                </div>
                            </div>
                        </div>
                    }
                }

                <!-- PRODUCTS VIEW -->
                @if (currentView == "products" && Model.MyProducts.Any())
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">My products</h3>
                            <div class="card-tools">
                                <a href="/Products" class="btn btn-sm btn-outline-primary">All products</a>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th style="width: 120px;">Phase</th>
                                        <th style="width: 200px;">Role</th>
                                        <th style="width: 80px;" class="text-center">Risks</th>
                                        <th style="width: 80px;" class="text-center">Issues</th>
                                        <th style="width: 80px;" class="text-center">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var product in Model.MyProducts)
                                    {
                                        var myContacts = product.ProductContacts?
                                            .Where(pc => pc.UsersPermissionsUser?.Email?.Equals(userEmail, StringComparison.OrdinalIgnoreCase) == true)
                                            .ToList() ?? new List<ProductContactDto>();
                                        var roles = string.Join(", ", myContacts.Select(c => c.Role ?? "Contact"));
                                        
                                        // Count RAID items for this product
                                        var productRisks = Model.MyRisks.Count(r => r.FipsId == product.FipsId && r.Status != "closed");
                                        var productIssues = Model.MyIssues.Count(i => i.FipsId == product.FipsId && i.Status != "resolved" && i.Status != "closed");
                                        var productActions = Model.MyActions.Count(a => a.FipsId == product.FipsId && a.Status != "done" && a.Status != "cancelled");
                                        
                                        <tr>
                                            <td>
                                                <a href="/Products/Dashboard/@product.FipsId">@product.Title</a>
                                                <br><small class="text-muted">@product.FipsId</small>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(product.Phase))
                                                {
                                                    @product.Phase
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td><small class="text-muted">@roles</small></td>
                                            <td class="text-center">
                                                @if (productRisks > 0)
                                                {
                                                    <a href="/Risk?products=@product.FipsId">@productRisks</a>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">0</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (productIssues > 0)
                                                {
                                                    <a href="/Issue?products=@product.FipsId">@productIssues</a>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">0</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                @if (productActions > 0)
                                                {
                                                    <a href="/Action?products=@product.FipsId">@productActions</a>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">0</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                @if (currentView == "products" && !Model.MyProducts.Any())
                {
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <h4>No products assigned</h4>
                            <p class="text-muted">You are not currently listed as a contact for any products.</p>
                            <a href="/Products" class="btn btn-primary mt-2">Browse all products</a>
                        </div>
                    </div>
                }

                <!-- ISSUES VIEW -->
                @if (currentView == "issues" && Model.MyIssues.Any())
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">My issues</h3>
                            <div class="card-tools">
                                <a href="/Issue/Create" class="btn btn-sm btn-success">Add issue</a>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th style="width: 150px;">Product</th>
                                        <th style="width: 100px;">Severity</th>
                                        <th style="width: 120px;">Status</th>
                                        <th style="width: 120px;">Due date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var issue in Model.MyIssues)
                                    {
                                        var isOverdue = IsOverdue(issue.TargetResolutionDate, issue.Status, new[] { "resolved", "closed" });
                                        var severityClass = GetSeverityBadgeClass(issue.Severity);
                                        var statusClass = GetIssueStatusBadgeClass(issue.Status);
                                        
                                        <tr class="@(isOverdue ? "table-danger" : "")">
                                            <td><a href="/Issue/Edit/@issue.Id">@issue.Title</a></td>
                                            <td><small class="text-muted">@issue.FipsId</small></td>
                                            <td><span class="badge @severityClass">@issue.Severity</span></td>
                                            <td>
                                                <span class="badge @statusClass">@issue.Status.Replace("_", " ")</span>
                                                @if (issue.BlockedFlag)
                                                {
                                                    <br><span class="text-danger small">Blocked</span>
                                                }
                                            </td>
                                            <td>
                                                @if (issue.TargetResolutionDate.HasValue)
                                                {
                                                    <span class="@(isOverdue ? "text-danger" : "")">
                                                        @issue.TargetResolutionDate.Value.ToString("dd MMM yyyy")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No date</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                @if (currentView == "issues" && !Model.MyIssues.Any())
                {
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <h4>No issues found</h4>
                            @if (!string.IsNullOrEmpty(statusFilter) || !string.IsNullOrEmpty(priorityFilter) || dateFilter != "all")
                            {
                                <p class="text-muted">No issues match the current filters.</p>
                                <a href="/?view=issues" class="btn btn-primary">Clear filters</a>
                            }
                            else
                            {
                                <p class="text-muted">You don't have any issues assigned to you.</p>
                                <a href="/Issue/Create" class="btn btn-success">Create issue</a>
                            }
                        </div>
                    </div>
                }

                <!-- RISKS VIEW -->
                @if (currentView == "risks" && Model.MyRisks.Any())
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">My risks</h3>
                            <div class="card-tools">
                                <a href="/Risk/Create" class="btn btn-sm btn-success">Add risk</a>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th style="width: 150px;">Product</th>
                                        <th style="width: 80px;" class="text-center">Score</th>
                                        <th style="width: 80px;" class="text-center">Impact</th>
                                        <th style="width: 80px;" class="text-center">Likelihood</th>
                                        <th style="width: 120px;">Status</th>
                                        <th style="width: 120px;">Due date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var risk in Model.MyRisks)
                                    {
                                        var isOverdue = IsOverdue(risk.TargetDate, risk.Status, new[] { "closed" });
                                        var riskScoreClass = GetRiskScoreBadgeClass(risk.RiskScore);
                                        var statusClass = GetRiskStatusBadgeClass(risk.Status);
                                        
                                        <tr class="@(isOverdue ? "table-danger" : "")">
                                            <td><a href="/Risk/Edit/@risk.Id">@risk.Title</a></td>
                                            <td><small class="text-muted">@risk.FipsId</small></td>
                                            <td class="text-center"><span class="badge @riskScoreClass">@risk.RiskScore</span></td>
                                            <td class="text-center">@risk.ImpactRating</td>
                                            <td class="text-center">@risk.LikelihoodRating</td>
                                            <td><span class="badge @statusClass">@risk.Status.Replace("_", " ")</span></td>
                                            <td>
                                                @if (risk.TargetDate.HasValue)
                                                {
                                                    <span class="@(isOverdue ? "text-danger" : "")">
                                                        @risk.TargetDate.Value.ToString("dd MMM yyyy")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No date</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                @if (currentView == "risks" && !Model.MyRisks.Any())
                {
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <h4>No risks found</h4>
                            @if (!string.IsNullOrEmpty(statusFilter) || !string.IsNullOrEmpty(priorityFilter) || dateFilter != "all")
                            {
                                <p class="text-muted">No risks match the current filters.</p>
                                <a href="/?view=risks" class="btn btn-primary">Clear filters</a>
                            }
                            else
                            {
                                <p class="text-muted">You don't have any risks assigned to you.</p>
                                <a href="/Risk/Create" class="btn btn-success">Create risk</a>
                            }
                        </div>
                    </div>
                }

                <!-- ACTIONS VIEW -->
                @if (currentView == "actions" && Model.MyActions.Any())
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">My actions</h3>
                            <div class="card-tools">
                                <a href="/Action/Create" class="btn btn-sm btn-success">Add action</a>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th style="width: 150px;">Product</th>
                                        <th style="width: 100px;">Priority</th>
                                        <th style="width: 120px;">Status</th>
                                        <th style="width: 120px;">Due date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var action in Model.MyActions)
                                    {
                                        var completedStatuses = new[] { "done", "cancelled" };
                                        var isOverdue = IsOverdue(action.DueDate, action.Status, completedStatuses);
                                        var isUrgent = IsUrgent(action.DueDate, action.Status, completedStatuses);
                                        var priorityClass = GetPriorityBadgeClass(action.Priority);
                                        var statusClass = GetActionStatusBadgeClass(action.Status);
                                        
                                        <tr class="@(isOverdue ? "table-danger" : isUrgent ? "table-warning" : "")">
                                            <td><a href="/Action/Edit/@action.Id">@action.Title</a></td>
                                            <td><small class="text-muted">@action.FipsId</small></td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(action.Priority))
                                                {
                                                    <span class="badge @priorityClass">@action.Priority</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td><span class="badge @statusClass">@action.Status.Replace("_", " ")</span></td>
                                            <td>
                                                @if (action.DueDate.HasValue)
                                                {
                                                    <span class="@(isOverdue ? "text-danger" : isUrgent ? "text-warning" : "")">
                                                        @action.DueDate.Value.ToString("dd MMM yyyy")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No date</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                @if (currentView == "actions" && !Model.MyActions.Any())
                {
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <h4>No actions found</h4>
                            @if (!string.IsNullOrEmpty(statusFilter) || !string.IsNullOrEmpty(priorityFilter) || dateFilter != "all")
                            {
                                <p class="text-muted">No actions match the current filters.</p>
                                <a href="/?view=actions" class="btn btn-primary">Clear filters</a>
                            }
                            else
                            {
                                <p class="text-muted">You don't have any actions assigned to you.</p>
                                <a href="/Action/Create" class="btn btn-success">Create action</a>
                            }
                        </div>
                    </div>
                }

                <!-- MILESTONES VIEW -->
                @if (currentView == "milestones" && Model.MyMilestones.Any())
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">My milestones</h3>
                            <div class="card-tools">
                                <a href="/Milestone/Create" class="btn btn-sm btn-success">Add milestone</a>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th style="width: 150px;">Product</th>
                                        <th style="width: 120px;">Status</th>
                                        <th style="width: 100px;">Progress</th>
                                        <th style="width: 120px;">Due date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var milestone in Model.MyMilestones)
                                    {
                                        var completedStatuses = new[] { "complete", "cancelled" };
                                        var isOverdue = IsOverdue(milestone.DueDate, milestone.Status, completedStatuses);
                                        var isUrgent = IsUrgent(milestone.DueDate, milestone.Status, completedStatuses);
                                        var statusClass = GetMilestoneStatusBadgeClass(milestone.Status);
                                        
                                        <tr class="@(isOverdue ? "table-danger" : isUrgent ? "table-warning" : "")">
                                            <td><a href="/Milestone/Edit/@milestone.Id">@milestone.Name</a></td>
                                            <td><small class="text-muted">@milestone.FipsId</small></td>
                                            <td><span class="badge @statusClass">@milestone.Status.Replace("_", " ")</span></td>
                                            <td>
                                                @if (milestone.ProgressPercent.HasValue)
                                                {
                                                    <text>@milestone.ProgressPercent%</text>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="@(isOverdue ? "text-danger" : isUrgent ? "text-warning" : "")">
                                                    @milestone.DueDate.ToString("dd MMM yyyy")
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                @if (currentView == "milestones" && !Model.MyMilestones.Any())
                {
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <h4>No milestones found</h4>
                            @if (!string.IsNullOrEmpty(statusFilter) || dateFilter != "all")
                            {
                                <p class="text-muted">No milestones match the current filters.</p>
                                <a href="/?view=milestones" class="btn btn-primary">Clear filters</a>
                            }
                            else
                            {
                                <p class="text-muted">You don't have any milestones assigned to you.</p>
                                <a href="/Milestone/Create" class="btn btn-success">Create milestone</a>
                            }
                        </div>
                    </div>
                }

            </div> <!-- /col-12 -->
        </div> <!-- /row -->
    </div> <!-- /container-fluid -->
</section>

@* ====================================================================== *@
@* HELPER FUNCTIONS                                                       *@
@* Reusable methods for badge classes, date checks, etc.                 *@
@* ====================================================================== *@
@functions {
    // Badge class helpers
    string GetSeverityBadgeClass(string severity)
    {
        return severity switch
        {
            "critical" => "badge-danger",
            "high" => "badge-warning",
            "medium" => "badge-info",
            "low" => "badge-secondary",
            _ => "badge-secondary"
        };
    }

    string GetIssueStatusBadgeClass(string status)
    {
        return status switch
        {
            "open" => "badge-info",
            "in_progress" => "badge-primary",
            "blocked" => "badge-danger",
            "resolved" => "badge-success",
            "closed" => "badge-secondary",
            _ => "badge-secondary"
        };
    }

    string GetRiskScoreBadgeClass(int? score)
    {
        return score switch
        {
            >= 15 => "badge-danger",
            >= 10 => "badge-warning",
            >= 5 => "badge-info",
            _ => "badge-secondary"
        };
    }

    string GetRiskStatusBadgeClass(string status)
    {
        return status switch
        {
            "new" => "badge-info",
            "open" => "badge-warning",
            "treating" => "badge-primary",
            "monitoring" => "badge-secondary",
            "closed" => "badge-success",
            _ => "badge-secondary"
        };
    }

    string GetPriorityBadgeClass(string priority)
    {
        return priority switch
        {
            "high" => "badge-danger",
            "medium" => "badge-warning",
            "low" => "badge-secondary",
            _ => "badge-secondary"
        };
    }

    string GetActionStatusBadgeClass(string status)
    {
        return status switch
        {
            "not_started" => "badge-secondary",
            "in_progress" => "badge-primary",
            "blocked" => "badge-danger",
            "done" => "badge-success",
            "cancelled" => "badge-dark",
            _ => "badge-secondary"
        };
    }

    string GetMilestoneStatusBadgeClass(string status)
    {
        return status switch
        {
            "not_started" => "badge-secondary",
            "on_track" => "badge-success",
            "at_risk" => "badge-warning",
            "delayed" => "badge-danger",
            "complete" => "badge-primary",
            "cancelled" => "badge-dark",
            _ => "badge-secondary"
        };
    }

    string GetProgressBarClass(int? percent)
    {
        return percent switch
        {
            >= 75 => "bg-success",
            >= 50 => "bg-info",
            >= 25 => "bg-warning",
            _ => "bg-danger"
        };
    }

    // Date and status helpers
    bool IsOverdue(DateTime? targetDate, string status, string[] completedStatuses)
    {
        if (!targetDate.HasValue) return false;
        if (completedStatuses.Contains(status)) return false;
        return targetDate.Value < DateTime.UtcNow;
    }

    bool IsUrgent(DateTime? targetDate, string status, string[] completedStatuses, int daysThreshold = 7)
    {
        if (!targetDate.HasValue) return false;
        if (completedStatuses.Contains(status)) return false;
        return targetDate.Value <= DateTime.UtcNow.AddDays(daysThreshold);
    }
}

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Auto-submit form on filter change
            $('.auto-submit').on('change', function() {
                $(this).closest('form').submit();
            });
        });
    </script>
}
