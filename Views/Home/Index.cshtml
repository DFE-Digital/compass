        .work-item-project {
            margin: 0 0 0.75rem 0;
            font-size: 0.875rem;
            color: #6b7280;
            font-weight: 500;
            padding-right: 2rem;
        }

        .work-item-meta {
            display: flex;
            flex-direction: column;
