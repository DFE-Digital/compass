        }

        .work-items-table a {
            color: #1f2937;
            text-decoration: none;
            font-weight: 600;
        }

        .work-items-table a:hover {
            color: #005ea5;
            text-decoration: underline;
        }

        .work-item-card {
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 1.5rem;
