@model Compass.Models.Risk
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Risk details";
    var isOverdue = Model.ProximityDate.HasValue && 
                    Model.ProximityDate.Value.Date < DateTime.Today &&
                    Model.Status != "closed";
    var products = ViewBag.Products as List<Compass.Models.ProductDto> ?? new List<Compass.Models.ProductDto>();
    var fipsBaseUrl = Configuration["fipsProduct:baseUrl"] ?? "https://find-products-services-test.azurewebsites.net/";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Risks</a></li>
                    <li class="breadcrumb-item active">Risk details</li>
                </ol>
                <h1 class="m-0">@Model.Title</h1>
                <p class="text-muted">Risk #@Model.Id</p>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <div class="btn-group">
                        <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            Actions
                        </button>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" asp-action="Edit" asp-route-id="@Model.Id">Edit risk</a>
                            <a class="dropdown-item" asp-controller="Action" asp-action="Create" asp-route-riskId="@Model.Id">Add mitigation action</a>
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item" asp-action="Delete" asp-route-id="@Model.Id">Delete risk</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <!-- Main content -->
            <div class="col-xxl-9 col-xl-9 col-lg-8 col-md-12 col-sm-12 col-12">
                <!-- Product link -->
                @if (!string.IsNullOrEmpty(Model.FipsId))
                {
                    var product = products.FirstOrDefault(p => p.FipsId == Model.FipsId);
                    var productUrl = $"{fipsBaseUrl.TrimEnd('/')}/product/{Model.FipsId}";
                    <div class="card">
                        <div class="card-body">
                            <strong>Product:</strong>
                            @if (product != null)
                            {
                                <a href="@productUrl" target="_blank" rel="noopener noreferrer">@product.Title (@Model.FipsId)</a>
                            }
                            else
                            {
                                <a href="@productUrl" target="_blank" rel="noopener noreferrer">@Model.FipsId</a>
                            }
                        </div>
                    </div>
                }

                <!-- Description -->
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Description</h3>
                        </div>
                        <div class="card-body">
                            <p class="mb-0">@Model.Description</p>
                        </div>
                    </div>
                }

                <!-- Risk Types -->
                @if (Model.RiskRiskTypes != null && Model.RiskRiskTypes.Any())
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Risk types</h3>
                        </div>
                        <div class="card-body">
                            <ul class="list-unstyled mb-0">
                                @foreach (var rrt in Model.RiskRiskTypes)
                                {
                                    <li class="mb-2">
                                        <strong>@rrt.RiskType.Name</strong>
                                        @if (!string.IsNullOrEmpty(rrt.RiskType.Summary))
                                        {
                                            <br><small class="text-muted">@rrt.RiskType.Summary</small>
                                        }
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }

                <!-- Response Strategy -->
                @if (!string.IsNullOrEmpty(Model.Response) || Model.ResidualImpact.HasValue || Model.ResidualLikelihood.HasValue)
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Response strategy</h3>
                        </div>
                        <div class="card-body">
                            <dl class="mb-0">
                                <dt>Strategy</dt>
                                <dd class="mb-3">
                                    @if (!string.IsNullOrEmpty(Model.Response))
                                    {
                                        <span class="badge badge-info">@Model.Response</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not set</span>
                                    }
                                </dd>

                                <dt>Target date</dt>
                                <dd class="mb-3">@(Model.TargetDate?.ToString("dd MMM yyyy") ?? "-")</dd>

                                <dt>Residual risk</dt>
                                <dd class="mb-0">
                                    @if (Model.ResidualImpact.HasValue && Model.ResidualLikelihood.HasValue)
                                    {
                                        var residualScore = Model.ResidualImpact.Value * Model.ResidualLikelihood.Value;
                                        <span class="badge @(residualScore >= 15 ? "badge-danger" : residualScore >= 10 ? "badge-warning" : "badge-success")">
                                            @residualScore
                                        </span>
                                        <small class="text-muted ml-2">Impact: @Model.ResidualImpact × Likelihood: @Model.ResidualLikelihood</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not calculated</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                    </div>
                }

                <!-- Notes -->
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Notes</h3>
                        </div>
                        <div class="card-body">
                            <p class="mb-0">@Model.Notes</p>
                        </div>
                    </div>
                }

                <!-- Related Actions -->
                @if (Model.RiskActions != null && Model.RiskActions.Any())
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Related mitigation actions</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Title</th>
                                        <th style="width: 150px;">Assigned to</th>
                                        <th style="width: 120px;">Status</th>
                                        <th style="width: 120px;">Due date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var ra in Model.RiskActions)
                                    {
                                        var actionOverdue = ra.Action.DueDate.HasValue && 
                                                          ra.Action.DueDate.Value.Date < DateTime.Today &&
                                                          ra.Action.Status != "done" && ra.Action.Status != "cancelled";
                                        <tr class="@(actionOverdue ? "table-danger" : "")">
                                            <td><a asp-controller="Action" asp-action="Details" asp-route-id="@ra.Action.Id">@ra.Action.Title</a></td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(ra.Action.AssignedToEmail))
                                                {
                                                    <small><a href="mailto:@ra.Action.AssignedToEmail">@ra.Action.AssignedToEmail</a></small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @switch (ra.Action.Status)
                                                {
                                                    case "done":
                                                        <span class="badge badge-success">Done</span>
                                                        break;
                                                    case "in_progress":
                                                        <span class="badge badge-primary">In progress</span>
                                                        break;
                                                    case "blocked":
                                                        <span class="badge badge-danger">Blocked</span>
                                                        break;
                                                    case "not_started":
                                                        <span class="badge badge-secondary">Not started</span>
                                                        break;
                                                    case "cancelled":
                                                        <span class="badge badge-dark">Cancelled</span>
                                                        break;
                                                    default:
                                                        <span class="badge badge-secondary">@ra.Action.Status</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                @if (ra.Action.DueDate.HasValue)
                                                {
                                                    <span class="@(actionOverdue ? "text-danger" : "")">
                                                        @ra.Action.DueDate.Value.ToString("dd MMM yyyy")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <!-- Comments Section -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Comments</h3>
                    </div>
                    <div class="card-body">
                        <div id="commentsContainer">
                            <p class="text-muted text-center">Loading comments...</p>
                        </div>
                        
                        <hr />
                        
                        <div class="form-group mb-0">
                            <label for="newComment">Add a comment</label>
                            <textarea id="newComment" class="form-control" rows="3" placeholder="Enter your comment..."></textarea>
                            <button type="button" class="btn btn-primary mt-2" id="addCommentBtn">Add comment</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-xxl-3 col-xl-3 col-lg-4 col-md-12 col-sm-12 col-12">
                <!-- Risk Assessment -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Risk assessment</h3>
                    </div>
                    <div class="card-body">
                        <dl class="mb-0">
                            <dt>Risk score</dt>
                            <dd class="mb-3">
                                <span class="badge @(Model.RiskScore >= 15 ? "badge-danger" : Model.RiskScore >= 10 ? "badge-warning" : "badge-success")">@Model.RiskScore</span>
                                <small class="text-muted ml-2">Impact: @Model.ImpactRating × Likelihood: @Model.LikelihoodRating</small>
                            </dd>

                            <dt>Impact rating</dt>
                            <dd class="mb-3">@Model.ImpactRating / 5</dd>

                            <dt>Likelihood rating</dt>
                            <dd class="mb-0">@Model.LikelihoodRating / 5</dd>
                        </dl>
                    </div>
                </div>

                <!-- Details -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Details</h3>
                    </div>
                    <div class="card-body">
                        <dl class="mb-0">
                            <dt>Status</dt>
                            <dd class="mb-3">
                                @switch (Model.Status)
                                {
                                    case "new":
                                        <span class="badge badge-info">New</span>
                                        break;
                                    case "open":
                                        <span class="badge badge-danger">Open</span>
                                        break;
                                    case "treating":
                                        <span class="badge badge-warning">Treating</span>
                                        break;
                                    case "monitoring":
                                        <span class="badge badge-primary">Monitoring</span>
                                        break;
                                    case "closed":
                                        <span class="badge badge-secondary">Closed</span>
                                        break;
                                    default:
                                        <span class="badge badge-secondary">@Model.Status</span>
                                        break;
                                }
                            </dd>

                            <dt>Risk owner</dt>
                            <dd class="mb-3">
                                @if (!string.IsNullOrEmpty(Model.OwnerEmail))
                                {
                                    <a href="mailto:@Model.OwnerEmail">@Model.OwnerEmail</a>
                                }
                                else
                                {
                                    <span class="text-muted">Unassigned</span>
                                }
                            </dd>

                            <dt>Business area</dt>
                            <dd class="mb-3">
                                @if (!string.IsNullOrEmpty(Model.BusinessArea))
                                {
                                    <a asp-action="Index" asp-route-businessArea="@Model.BusinessArea">@Model.BusinessArea</a>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </dd>

                            <dt>Strategic objective</dt>
                            <dd class="mb-3">
                                @if (Model.Objective != null)
                                {
                                    <a asp-action="Index" asp-route-objectiveId="@Model.Objective.Id">@Model.Objective.Title</a>
                                }
                                else
                                {
                                    <span class="text-muted">Not linked</span>
                                }
                            </dd>

                            <dt>Risk tier</dt>
                            <dd class="mb-3">
                                @if (Model.RiskTier != null)
                                {
                                    <div>@Model.RiskTier.Name</div>
                                    @if (!string.IsNullOrEmpty(Model.RiskTier.Summary))
                                    {
                                        <small class="text-muted">@Model.RiskTier.Summary</small>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </dd>

                            <dt>Category</dt>
                            <dd class="mb-0">@(Model.Category ?? "-")</dd>
                        </dl>
                    </div>
                </div>

                <!-- Timeline -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Timeline</h3>
                    </div>
                    <div class="card-body">
                        <dl class="mb-0">
                            <dt>Proximity date</dt>
                            <dd class="mb-3">
                                @if (Model.ProximityDate.HasValue)
                                {
                                    <span class="@(isOverdue ? "text-danger" : "")">
                                        @Model.ProximityDate.Value.ToString("dd MMM yyyy")
                                    </span>
                                    @if (isOverdue)
                                    {
                                        var daysOverdue = (DateTime.Today - Model.ProximityDate.Value.Date).Days;
                                        <br><span class="text-danger small">@daysOverdue days overdue</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </dd>

                            <dt>Closed</dt>
                            <dd class="mb-3">@(Model.ClosedDate?.ToString("dd MMM yyyy") ?? "-")</dd>

                            <dt>Created</dt>
                            <dd class="mb-3">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</dd>

                            <dt>Last updated</dt>
                            <dd class="mb-0">@Model.UpdatedAt.ToString("dd MMM yyyy HH:mm")</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@Html.AntiForgeryToken()

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            loadComments();
            
            function loadComments() {
                $.ajax({
                    url: '/api/comments/Risk/@Model.Id',
                    type: 'GET',
                    success: function(data) {
                        displayComments(data);
                    },
                    error: function() {
                        $('#commentsContainer').html('<p class="text-danger">Failed to load comments</p>');
                    }
                });
            }
            
            function displayComments(comments) {
                if (!comments || comments.length === 0) {
                    $('#commentsContainer').html('<p class="text-muted">No comments yet</p>');
                    return;
                }
                
                var html = '';
                comments.forEach(function(comment) {
                    var date = new Date(comment.createdAt);
                    var dateStr = date.toLocaleString('en-GB', { 
                        day: 'numeric', 
                        month: 'short', 
                        year: 'numeric', 
                        hour: '2-digit', 
                        minute: '2-digit' 
                    });
                    
                    html += '<div class="border-bottom pb-3 mb-3">';
                    html += '<div class="d-flex justify-content-between mb-2">';
                    html += '<strong>' + (comment.createdByUser ? comment.createdByUser.name : 'Unknown') + '</strong>';
                    html += '<small class="text-muted">' + dateStr + '</small>';
                    html += '</div>';
                    html += '<p class="mb-0">' + comment.commentText.replace(/\n/g, '<br>') + '</p>';
                    html += '</div>';
                });
                
                $('#commentsContainer').html(html);
            }
            
            $('#addCommentBtn').click(function() {
                var commentText = $('#newComment').val().trim();
                
                if (!commentText) {
                    alert('Please enter a comment');
                    return;
                }
                
                $.ajax({
                    url: '/api/comments',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({
                        entityType: 'Risk',
                        entityId: @Model.Id,
                        commentText: commentText
                    }),
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function() {
                        $('#newComment').val('');
                        loadComments();
                    },
                    error: function() {
                        alert('Failed to add comment');
                    }
                });
            });
        });
    </script>
}
