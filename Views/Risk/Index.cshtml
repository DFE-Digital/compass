@model IEnumerable<Compass.Models.Risk>
@{
    ViewData["Title"] = "Risks";
    var objectiveTitle = ViewBag.ObjectiveTitle as string;
    var currentTab = ViewBag.CurrentTab as string ?? "active";
    var currentViewScope = ViewBag.CurrentViewScope as string ?? "assigned_to_me";
    var currentDimension = ViewBag.CurrentDimension as string;
    var currentBusinessArea = ViewBag.CurrentBusinessArea as string;
    var currentStatus = ViewBag.CurrentStatus as string;
    var currentProducts = ViewBag.CurrentProducts as string[] ?? Array.Empty<string>();
    var minRiskScore = ViewBag.MinRiskScore as int?;
    var maxRiskScore = ViewBag.MaxRiskScore as int?;
    var currentImpact = ViewBag.CurrentImpact as int?;
    var currentLikelihood = ViewBag.CurrentLikelihood as int?;
    var businessAreas = ViewBag.BusinessAreas as List<string> ?? new List<string>();
    var products = ViewBag.Products as List<Compass.Models.ProductDto> ?? new List<Compass.Models.ProductDto>();
    var userBusinessAreas = ViewBag.UserBusinessAreas as List<string> ?? new List<string>();
    var newCount = ViewBag.NewCount as int? ?? 0;
    var openCount = ViewBag.OpenCount as int? ?? 0;
    var closedCount = ViewBag.ClosedCount as int? ?? 0;
    var overdueCount = ViewBag.OverdueCount as int? ?? 0;
    var assignedToMeCount = ViewBag.AssignedToMeCount as int? ?? 0;
    var myProductsCount = ViewBag.MyProductsCount as int? ?? 0;
    var organisationWideCount = ViewBag.OrganisationWideCount as int? ?? 0;
    
    // Check if any filters are applied
    var hasFilters = !string.IsNullOrEmpty(currentDimension) || 
                     !string.IsNullOrEmpty(currentBusinessArea) || 
                     (!string.IsNullOrEmpty(currentStatus) && currentStatus != "closed") || 
                     currentProducts.Any() ||
                     minRiskScore.HasValue ||
                     maxRiskScore.HasValue ||
                     currentImpact.HasValue ||
                     currentLikelihood.HasValue;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    @if (objectiveTitle != null)
                    {
                        <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Objectives">Strategic objectives</a></li>
                        <li class="breadcrumb-item active">Risks for @objectiveTitle</li>
                    }
                    else
                    {
                        <li class="breadcrumb-item active">Risks</li>
                    }
                </ol>
                <h1 class="m-0">Risks @(objectiveTitle != null ? $"for {objectiveTitle}" : "")</h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <div class="btn-group">
                        <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            Actions
                        </button>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" asp-action="Create" asp-route-objectiveId="@ViewBag.ObjectiveId">
                                Add risk
                            </a>
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item export-placeholder" href="#">
                                Export to Excel
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }

        <div class="row">
            <!-- Left Column: View Options and Filters -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <!-- View Scope Options -->
                <div class="card">
                    <div class="card-body p-2">
                        <div class="nav flex-column nav-pills">
                            <a href="@Url.Action("Index", new { objectiveId = ViewBag.ObjectiveId, viewScope = "assigned_to_me", tab = currentTab })" 
                               class="nav-link @(currentViewScope == "assigned_to_me" ? "active" : "")">
                                Assigned to me
                                <span class="badge badge-primary float-right">@assignedToMeCount</span>
                            </a>
                            <a href="@Url.Action("Index", new { objectiveId = ViewBag.ObjectiveId, viewScope = "my_products", tab = currentTab })" 
                               class="nav-link @(currentViewScope == "my_products" ? "active" : "")">
                                My products
                                <span class="badge badge-info float-right">@myProductsCount</span>
                            </a>
                            <a href="@Url.Action("Index", new { objectiveId = ViewBag.ObjectiveId, viewScope = "organisation_wide", tab = currentTab })" 
                               class="nav-link @(currentViewScope == "organisation_wide" ? "active" : "")">
                                Organisation-wide
                                <span class="badge badge-secondary float-right">@organisationWideCount</span>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Filters -->
                <div class="card mt-3">
                    <div class="card-header">
                        <h3 class="card-title">Filters</h3>
                    </div>
                    <div class="card-body">
                        @if (hasFilters)
                        {
                            <div class="alert alert-info alert-sm p-2 mb-3">
                                <strong>Active filters</strong>
                            </div>
                        }
                        
                        <form method="get" id="filterForm">
                            @if (ViewBag.ObjectiveId != null)
                            {
                                <input type="hidden" name="objectiveId" value="@ViewBag.ObjectiveId" />
                            }
                            <input type="hidden" name="viewScope" value="@currentViewScope" />
                            <input type="hidden" name="tab" id="tabInput" value="@currentTab" />
                            
                            <!-- Business Area Filter -->
                            <div class="form-group">
                                <label>Business area</label>
                                <select name="businessArea" class="form-control form-control-sm auto-submit">
                                    <option value="">All</option>
                                    @foreach (var ba in businessAreas)
                                    {
                                        <option value="@ba" selected="@(currentBusinessArea == ba)">@ba</option>
                                    }
                                </select>
                            </div>

                            <!-- Status Filter -->
                            <div class="form-group">
                                <label>Status</label>
                                <select name="status" class="form-control form-control-sm" onchange="this.form.submit()">
                                    <option value="">All statuses</option>
                                    <option value="new" selected="@(currentStatus == "new")">New</option>
                                    <option value="open" selected="@(currentStatus == "open")">Open</option>
                                    <option value="treating" selected="@(currentStatus == "treating")">Treating</option>
                                    <option value="monitoring" selected="@(currentStatus == "monitoring")">Monitoring</option>
                                </select>
                            </div>

                            <!-- Products Filter -->
                            <div class="form-group">
                                <label>Products</label>
                                <select name="products" class="form-control form-control-sm select2-multiple" multiple="multiple" data-placeholder="All products">
                                    @foreach (var product in products)
                                    {
                                        <option value="@product.FipsId" selected="@(((IEnumerable<string>)currentProducts).Contains(product.FipsId))">@product.Title</option>
                                    }
                                </select>
                            </div>

                            <!-- Min Risk Score -->
                            <div class="form-group">
                                <label>Min risk score</label>
                                <input type="number" name="minRiskScore" class="form-control form-control-sm" min="1" max="25" value="@minRiskScore" placeholder="1-25" />
                            </div>

                            <!-- Max Risk Score -->
                            <div class="form-group">
                                <label>Max risk score</label>
                                <input type="number" name="maxRiskScore" class="form-control form-control-sm" min="1" max="25" value="@maxRiskScore" placeholder="1-25" />
                            </div>

                            <!-- Impact -->
                            <div class="form-group">
                                <label>Impact</label>
                                <select name="impact" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    <option value="1" selected="@(currentImpact == 1)">1 - Very low</option>
                                    <option value="2" selected="@(currentImpact == 2)">2 - Low</option>
                                    <option value="3" selected="@(currentImpact == 3)">3 - Medium</option>
                                    <option value="4" selected="@(currentImpact == 4)">4 - High</option>
                                    <option value="5" selected="@(currentImpact == 5)">5 - Very high</option>
                                </select>
                            </div>

                            <!-- Likelihood -->
                            <div class="form-group">
                                <label>Likelihood</label>
                                <select name="likelihood" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    <option value="1" selected="@(currentLikelihood == 1)">1 - Rare</option>
                                    <option value="2" selected="@(currentLikelihood == 2)">2 - Unlikely</option>
                                    <option value="3" selected="@(currentLikelihood == 3)">3 - Possible</option>
                                    <option value="4" selected="@(currentLikelihood == 4)">4 - Likely</option>
                                    <option value="5" selected="@(currentLikelihood == 5)">5 - Almost certain</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <button type="submit" class="btn btn-primary btn-sm btn-block">Apply filters</button>
                                <a href="@Url.Action("Index", new { objectiveId = ViewBag.ObjectiveId, viewScope = currentViewScope, tab = currentTab })" class="btn btn-default btn-sm btn-block">Clear filters</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Column: Tabs and Table -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <!-- Tabs -->
                <ul class="nav nav-tabs" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link @(currentTab == "active" ? "active" : "")" href="#" data-tab="active">
                            Active <span class="badge badge-primary">@openCount</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentTab == "closed" ? "active" : "")" href="#" data-tab="closed">
                            Closed <span class="badge badge-secondary">@closedCount</span>
                        </a>
                    </li>
                </ul>

                <!-- Table Content -->
                <div class="card mb-0" style="border-top: none; border-top-left-radius: 0;">
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Title</th>
                                    <th>Business area</th>
                                    <th>Risk score</th>
                                    <th>Impact</th>
                                    <th>Likelihood</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var risk in Model)
                                    {
                                        var borderColor = risk.RiskScore >= 15 ? "border-danger" : risk.RiskScore >= 10 ? "border-warning" : "";
                                        <tr class="@borderColor">
                                            <td>
                                                <a asp-action="Details" asp-route-id="@risk.Id">@risk.Title</a>
                                                @if (!string.IsNullOrEmpty(risk.FipsId))
                                                {
                                                    var product = products.FirstOrDefault(p => p.FipsId == risk.FipsId);
                                                    var productName = product?.Title ?? risk.FipsId;
                                                    <br /><small class="text-muted">@productName</small>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(risk.BusinessArea))
                                                {
                                                    <span class="badge badge-light">@risk.BusinessArea</span>
                                                }
                                            </td>
                                            <td>
                                                @{
                                                    var badgeClass = risk.RiskScore >= 15 ? "badge-danger" : risk.RiskScore >= 10 ? "badge-warning" : risk.RiskScore >= 5 ? "badge-info" : "badge-success";
                                                }
                                                <span class="badge @badgeClass" style="font-size: 14px; padding: 8px 12px;">@risk.RiskScore</span>
                                            </td>
                                            <td>
                                                @{
                                                    var impactClass = risk.ImpactRating >= 4 ? "badge-danger" : risk.ImpactRating >= 3 ? "badge-warning" : risk.ImpactRating >= 2 ? "badge-info" : "badge-success";
                                                }
                                                <span class="badge @impactClass" style="font-size: 14px; padding: 8px 12px;">@risk.ImpactRating</span>
                                            </td>
                                            <td>
                                                @{
                                                    var likelihoodClass = risk.LikelihoodRating >= 4 ? "badge-danger" : risk.LikelihoodRating >= 3 ? "badge-warning" : risk.LikelihoodRating >= 2 ? "badge-info" : "badge-success";
                                                }
                                                <span class="badge @likelihoodClass" style="font-size: 14px; padding: 8px 12px;">@risk.LikelihoodRating</span>
                                            </td>
                                            <td>
                                                @switch (risk.Status)
                                                {
                                                    case "new":
                                                        <span class="badge badge-warning">New</span>
                                                        break;
                                                    case "open":
                                                        <span class="badge badge-danger">Open</span>
                                                        break;
                                                    case "treating":
                                                        <span class="badge badge-warning">Treating</span>
                                                        break;
                                                    case "monitoring":
                                                        <span class="badge badge-info">Monitoring</span>
                                                        break;
                                                    case "closed":
                                                        <span class="badge badge-secondary">Closed</span>
                                                        break;
                                                    default:
                                                        <span class="badge badge-secondary">@risk.Status</span>
                                                        break;
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center py-4 text-muted">No risks found</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        function switchTab(tab) {
            document.getElementById('tabInput').value = tab;
            document.getElementById('filterForm').submit();
        }

        $(document).ready(function() {
            // Initialize Select2 for multiple product selection
            $('.select2-multiple').select2({
                theme: 'bootstrap4',
                width: '100%'
            });

            // Submit form when products change
            $('.select2-multiple').on('change', function() {
                $('#filterForm').submit();
            });

            // Handle tab clicks
            $('.nav-tabs a[data-tab]').on('click', function(e) {
                e.preventDefault();
                var tab = $(this).data('tab');
                switchTab(tab);
            });

            // Handle export placeholder click
            $('.export-placeholder').on('click', function(e) {
                e.preventDefault();
                alert('Export feature coming soon');
            });

            // Auto-submit form on filter change
            $('.auto-submit').on('change', function() {
                $(this).closest('form').submit();
            });
        });
    </script>
}
