@{
    ViewData["Title"] = "Outcomes & Satisfaction";
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Outcomes & Satisfaction</li>
        </ol>
    </nav>
}

<div class="dashboard-header">
    <div>
        <h1>Outcomes & Satisfaction</h1>
        <p>Training outcomes, completion rates, and satisfaction ratings</p>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <!-- Year Selector -->
        <div class="row mb-3">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <form method="get" class="form-inline">
                            <label for="year" class="mr-2">Financial Year:</label>
                            <select name="year" id="year" class="form-control mr-2" onchange="this.form.submit()">
                                @for (int y = DateTime.UtcNow.Year - 2; y <= DateTime.UtcNow.Year + 1; y++)
                                {
                                    <option value="@y" selected="@(y == ViewBag.Year)">@y/@(y+1)</option>
                                }
                            </select>
                            <a asp-action="Index" asp-route-year="@ViewBag.Year" class="btn btn-secondary">Back to Dashboard</a>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- KPI Cards -->
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card border-left-info shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Total Approved</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TotalApproved</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-check-circle fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-left-success shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Completed</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.Completed</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-graduation-cap fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-left-primary shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Completion Rate</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@(((double?)ViewBag.CompletionRate ?? 0).ToString("F1"))%</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-percentage fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Charts -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Outcome Ratings Distribution</h3>
                    </div>
                    <div class="card-body">
                        <canvas id="ratingsChart" height="250"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Average Rating by Profession</h3>
                    </div>
                    <div class="card-body">
                        <canvas id="professionRatingsChart" height="250"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Feedback Table -->
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Courses with Most Feedback</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover text-nowrap sortable-table mb-0">
                                <thead>
                                    <tr>
                                        <th>Course</th>
                                        <th>Feedback Count</th>
                                        <th>Average Rating</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var course in (dynamic)ViewBag.FeedbackCounts)
                                    {
                                        <tr>
                                            <td>@course.CourseTitle</td>
                                            <td>@course.FeedbackCount</td>
                                            <td>
                                                @if (course.AverageRating > 0)
                                                {
                                                    <span>@course.AverageRating.ToString("F1") / 5</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">N/A</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js" nonce="@Context.Items["Nonce"]"></script>
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            var ratingsData = @Html.Raw(Json.Serialize(ViewBag.Ratings));
            if (ratingsData && ratingsData.length > 0) {
                var ctx = document.getElementById('ratingsChart').getContext('2d');
                new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: ratingsData.map(r => r.rating + ' stars'),
                        datasets: [{
                            label: 'Count',
                            data: ratingsData.map(r => r.count),
                            backgroundColor: 'rgba(255, 206, 86, 0.8)',
                            borderColor: 'rgba(255, 206, 86, 1)',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true
                            }
                        }
                    }
                });
            }

            var professionRatingsData = @Html.Raw(Json.Serialize(ViewBag.ProfessionRatings));
            if (professionRatingsData && professionRatingsData.length > 0) {
                var ctx2 = document.getElementById('professionRatingsChart').getContext('2d');
                new Chart(ctx2, {
                    type: 'bar',
                    data: {
                        labels: professionRatingsData.map(p => p.profession),
                        datasets: [{
                            label: 'Average Rating',
                            data: professionRatingsData.map(p => p.averageRating),
                            backgroundColor: 'rgba(75, 192, 192, 0.8)',
                            borderColor: 'rgba(75, 192, 192, 1)',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true,
                                max: 5
                            }
                        }
                    }
                });
            }
        });
    </script>
}

<style>
    .border-left-primary { border-left: 0.25rem solid #4e73df !important; }
    .border-left-success { border-left: 0.25rem solid #1cc88a !important; }
    .border-left-info { border-left: 0.25rem solid #36b9cc !important; }
    .text-gray-800 { color: #5a5c69 !important; }
    .text-gray-300 { color: #dddfeb !important; }
</style>

