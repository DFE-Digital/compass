@model Compass.Models.TechnologyCodeOfPractice

@{
    ViewData["Title"] = $"Technology Code of Practice Point {Model.PointNumber}: {Model.Title}";
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "TechnologyCodeOfPractice")" style="color: #005ea5; text-decoration: none;">Technology Code of Practice</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Point @Model.PointNumber</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <!-- Dashboard Header -->
        <div class="dashboard-header">
            <h1>Technology Code of Practice Point @Model.PointNumber: @Model.Title</h1>
            <p>View details and guidance for this Technology Code of Practice point.</p>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <div class="dashboard-section">
                    <div class="dashboard-section-header">
                        <h2><i class="fas fa-info-circle"></i> Point Details</h2>
                    </div>
                    <div class="card">
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(Model.Summary))
                            {
                                <h5 class="mb-3">Summary</h5>
                                <p>@Model.Summary</p>
                            }

                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                <h5 class="mb-3">Description</h5>
                                <div>@Html.Raw(Compass.Helpers.MarkdownHelper.ToHtml(Model.Description))</div>
                            }

                            @if (!string.IsNullOrEmpty(Model.GuidanceUrl))
                            {
                                <div class="mt-4">
                                    <h5 class="mb-2">External Guidance</h5>
                                    <a href="@Model.GuidanceUrl" target="_blank" class="btn btn-outline-primary">
                                        <i class="fas fa-external-link-alt"></i> View guidance on GOV.UK
                                    </a>
                                </div>
                            }

                            <div class="mt-4">
                                <strong>Status:</strong>
                                @if (Model.IsActive)
                                {
                                    <span class="badge badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Inactive</span>
                                }
                            </div>

                            @if (Model.TechnologyCodeOfPracticeProfessions != null && Model.TechnologyCodeOfPracticeProfessions.Any())
                            {
                                <div class="mt-4">
                                    <strong>Applies to DDaT Professions:</strong>
                                    <div class="mt-2">
                                        @foreach (var tcp in Model.TechnologyCodeOfPracticeProfessions.OrderBy(tcp => tcp.DdatProfession.Name))
                                        {
                                            <span class="badge badge-primary mr-1 mb-1">@tcp.DdatProfession.Name</span>
                                        }
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="mt-4">
                                    <strong>Applies to DDaT Professions:</strong>
                                    <span class="text-muted">No professions assigned</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Phase Guidance -->
                <div class="dashboard-section mt-4">
                    <div class="dashboard-section-header">
                        <h2><i class="fas fa-book"></i> Phase Guidance</h2>
                        <a asp-action="ManagePhaseGuidance" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">
                            <i class="fas fa-edit"></i> Manage Phase Guidance
                        </a>
                    </div>
                    @if (Model.PhaseGuidance != null && Model.PhaseGuidance.Any())
                    {
                        @foreach (var phase in new[] { "Discovery", "Alpha", "Beta", "Live" })
                        {
                            var guidance = Model.PhaseGuidance.FirstOrDefault(pg => pg.Phase == phase);
                            <div class="card mb-3">
                                <div class="card-header bg-info text-white">
                                    <h5 class="mb-0"><i class="fas fa-project-diagram"></i> @phase Phase</h5>
                                </div>
                                <div class="card-body">
                                    @if (guidance != null)
                                    {
                                        @if (!string.IsNullOrEmpty(guidance.Guidance))
                                        {
                                            <h6>Guidance</h6>
                                            <div>@Html.Raw(Compass.Helpers.MarkdownHelper.ToHtml(guidance.Guidance))</div>
                                        }
                                        @if (!string.IsNullOrEmpty(guidance.KeyActivities))
                                        {
                                            <h6 class="mt-3">Key Activities</h6>
                                            <div>@Html.Raw(Compass.Helpers.MarkdownHelper.ToHtml(guidance.KeyActivities))</div>
                                        }
                                        @if (!string.IsNullOrEmpty(guidance.QuestionsToConsider))
                                        {
                                            <h6 class="mt-3">Questions to Consider</h6>
                                            <div>@Html.Raw(Compass.Helpers.MarkdownHelper.ToHtml(guidance.QuestionsToConsider))</div>
                                        }
                                    }
                                    else
                                    {
                                        <p class="text-muted mb-0">No guidance available for this phase yet.</p>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> No phase guidance has been added yet. <a asp-action="ManagePhaseGuidance" asp-route-id="@Model.Id">Add phase guidance</a> to help teams apply this point at different stages of delivery.
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Actions</h5>
                    </div>
                    <div class="card-body">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-block mb-2">
                            <i class="fas fa-edit"></i> Edit Point
                        </a>
                        <a asp-action="Index" class="btn btn-secondary btn-block">
                            <i class="fas fa-arrow-left"></i> Back to TCoP
                        </a>
                    </div>
                </div>

                <div class="card mt-3">
                    <div class="card-header">
                        <h5 class="mb-0">Information</h5>
                    </div>
                    <div class="card-body">
                        <p class="mb-2"><strong>Point Number:</strong> @Model.PointNumber</p>
                        <p class="mb-2"><strong>Slug:</strong> @Model.Slug</p>
                        <p class="mb-2"><strong>Display Order:</strong> @Model.DisplayOrder</p>
                        @if (Model.TechnologyCodeOfPracticeProfessions != null && Model.TechnologyCodeOfPracticeProfessions.Any())
                        {
                            <p class="mb-2"><strong>DDaT Professions:</strong></p>
                            <ul class="list-unstyled mb-2">
                                @foreach (var tcp in Model.TechnologyCodeOfPracticeProfessions.OrderBy(tcp => tcp.DdatProfession.Name))
                                {
                                    <li><span class="badge badge-primary">@tcp.DdatProfession.Name</span></li>
                                }
                            </ul>
                        }
                        @if (Model.CreatedByUser != null)
                        {
                            <p class="mb-2"><strong>Created by:</strong> @Model.CreatedByUser.Name</p>
                        }
                        <p class="mb-2"><strong>Created:</strong> @Model.CreatedAt.ToString("dd MMM yyyy")</p>
                        @if (Model.UpdatedByUser != null)
                        {
                            <p class="mb-2"><strong>Updated by:</strong> @Model.UpdatedByUser.Name</p>
                        }
                        <p class="mb-0"><strong>Last updated:</strong> @Model.UpdatedAt.ToString("dd MMM yyyy")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

