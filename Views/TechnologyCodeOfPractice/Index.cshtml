@model IEnumerable<Compass.Models.TechnologyCodeOfPractice>

@{
    ViewData["Title"] = "Technology Code of Practice";
    var totalPoints = ViewBag.TotalPoints as int? ?? Model.Count();
    var activePoints = ViewBag.ActivePoints as int? ?? Model.Count(p => p.IsActive);
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <style>
        .breadcrumb a:hover {
            color: #003078 !important;
            text-decoration: underline !important;
        }
    </style>
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Technology Code of Practice</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        @{
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
            ViewBag.BrandText = "Technology Code of Practice";
            ViewBag.NavLinks = new[]
            {
                new { Text = "Technology Code of Practice", Action = "Index", Controller = "TechnologyCodeOfPractice", Url = default(string?), IsButton = false, IsActive = currentAction == "Index" }
            };
        }
        @await Html.PartialAsync("_ModuleNavbar")

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <!-- Summary Cards -->
        <div class="row mb-4">
            <div class="col-md-6 mb-3">
                <div class="card border-left-primary shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Points</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@totalPoints</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-list-alt fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-3">
                <div class="card border-left-success shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Active Points</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@activePoints</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-check-circle fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TCoP Points List -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title mb-0">The 13 Technology Code of Practice Points</h3>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">
                    A set of criteria to help government design, build and buy technology. The TCoP is used for the Cabinet Office spend control process and the Local Digital Declaration. 
                    <a href="https://www.gov.uk/guidance/the-technology-code-of-practice" target="_blank" rel="noopener noreferrer" style="color: #005ea5;">View on GOV.UK <i class="fas fa-external-link-alt"></i></a>
                </p>
                <p class="text-muted mb-3">Click on any point to view details and manage guidance.</p>
                <div class="standards-list">
                @foreach (var point in Model.OrderBy(p => p.PointNumber))
                {
                    <div class="standard-item @(point.IsActive ? "" : "standard-item-inactive")">
                        <div class="standard-item-header">
                            <div class="standard-number-badge">@point.PointNumber</div>
                            <div class="standard-title-section">
                                <h3 class="standard-title">@point.Title</h3>
                                @if (!point.IsActive)
                                {
                                    <span class="badge badge-secondary ml-2">Inactive</span>
                                }
                            </div>
                        </div>
                        
                        <div class="standard-item-body">
                            @if (!string.IsNullOrEmpty(point.Summary))
                            {
                                <p class="standard-summary">@point.Summary</p>
                            }
                            else if (!string.IsNullOrEmpty(point.Description))
                            {
                                <p class="standard-summary">@(point.Description.Length > 250 ? point.Description.Substring(0, 250) + "…" : point.Description)</p>
                            }
                            
                            <div class="standard-meta">
                                @if (!string.IsNullOrEmpty(point.GuidanceUrl))
                                {
                                    <div class="standard-guidance-badge">
                                        <i class="fas fa-external-link-alt text-info"></i>
                                        <a href="@point.GuidanceUrl" target="_blank" style="color: inherit; text-decoration: none;">View guidance on GOV.UK</a>
                                    </div>
                                }
                                
                                @if (point.TechnologyCodeOfPracticeProfessions != null && point.TechnologyCodeOfPracticeProfessions.Any())
                                {
                                    <div class="mt-2">
                                        <small class="text-muted d-block mb-1"><strong>Applies to:</strong></small>
                                        <div>
                                            @foreach (var tcp in point.TechnologyCodeOfPracticeProfessions.OrderBy(tcp => tcp.DdatProfession.Name))
                                            {
                                                <span class="badge badge-primary mr-1 mb-1">@tcp.DdatProfession.Name</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                        
                        <div class="standard-item-actions">
                            <a asp-action="Details" asp-route-id="@point.Id" class="btn btn-primary btn-sm">
                                <i class="fas fa-eye"></i> View Point
                            </a>
                            <a asp-action="Edit" asp-route-id="@point.Id" class="btn btn-outline-secondary btn-sm">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                        </div>
                    </div>
                }
                </div>
                @if (!Model.Any())
                {
                    <div class="alert alert-info mt-3">
                        <h4><i class="fas fa-info-circle"></i> No Technology Code of Practice Points Found</h4>
                        <p class="mb-0">The 13 Technology Code of Practice points need to be seeded into the database. Please contact an administrator to initialize the points.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<style>
    .border-left-primary {
        border-left: 0.25rem solid #4e73df !important;
    }
    .border-left-success {
        border-left: 0.25rem solid #1cc88a !important;
    }
    .text-xs {
        font-size: 0.7rem;
    }
    .text-gray-300 {
        color: #dddfeb !important;
    }
    .text-gray-800 {
        color: #5a5c69 !important;
    }
    .shadow {
        box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15) !important;
    }
</style>

