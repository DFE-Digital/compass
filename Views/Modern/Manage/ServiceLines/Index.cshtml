@model Compass.ViewModels.Modern.ServiceLineListViewModel
@using Compass.ViewModels.Modern
@{
    ViewData["Title"] = "Service lines — Compass";
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("FipsDashboard", "ModernManage")">Service register</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Service lines</li>
}

@if (TempData["Success"] != null)
{
 <div class="govuk-notification-banner govuk-notification-banner--success" role="region" aria-labelledby="sl-success-title">
 <div class="govuk-notification-banner__header">
 <h2 class="govuk-notification-banner__title" id="sl-success-title">Success</h2>
        </div>
 <div class="govuk-notification-banner__content">
 <p class="govuk-notification-banner__heading">@TempData["Success"]</p>
        </div>
    </div>
}

@{
  Microsoft.AspNetCore.Html.IHtmlContent? slIndexActions = null;
  if (Model.CanEdit)
  {
    slIndexActions = await Html.PartialAsync("_ServiceLinesIndexHeaderActions", Model);
  }
}
@await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
  Caption = "Service Register",
  Title = "Service lines",
  Actions = slIndexActions
})

<p class="govuk-body govuk-!-margin-bottom-4">Group directorates, business areas, service register products, and work items for portfolio reporting.</p>

@if (Model.Rows.Count == 0)
{
 <p class="govuk-body">No service lines yet.</p>
}
else
{
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
 <table class="govuk-table">
 <caption class="govuk-visually-hidden">Service lines</caption>
                <thead class="govuk-table__head">
                    <tr class="govuk-table__row">
 <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Name</button>
        </th>
 <th scope="col" class="govuk-table__header govuk-!-text-align-centre" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Directorates</button>
        </th>
 <th scope="col" class="govuk-table__header govuk-!-text-align-centre" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Business areas</button>
        </th>
 <th scope="col" class="govuk-table__header govuk-!-text-align-centre" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Products</button>
        </th>
 <th scope="col" class="govuk-table__header govuk-!-text-align-centre" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Work items</button>
        </th>
 <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Updated</button>
        </th>
                    </tr>
                </thead>
                <tbody class="govuk-table__body">
                @foreach (var r in Model.Rows)
                {
                    <tr class="govuk-table__row">
                        <td class="govuk-table__cell">
 <a href="@Url.Action("ServiceLineDetail", "ModernManage", new { slug = r.Slug })" class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold">@r.Name</a>
                        </td>
                        <td class="govuk-table__cell govuk-!-text-align-centre">@r.Directorates</td>
                        <td class="govuk-table__cell govuk-!-text-align-centre">@r.BusinessAreas</td>
                        <td class="govuk-table__cell govuk-!-text-align-centre">@r.Products</td>
                        <td class="govuk-table__cell govuk-!-text-align-centre">@r.WorkItems</td>
                        <td class="govuk-body-s">@r.UpdatedAt.ToString("d MMM yyyy")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
}
