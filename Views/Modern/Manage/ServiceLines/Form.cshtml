@using System.Globalization
@model Compass.ViewModels.Modern.ServiceLineFormViewModel
@using Compass.ViewModels.Modern
@{
    ViewData["Title"] = (Model.IsNew ? "Add" : "Edit") + " service line — Compass";
    var divSelected = Model.SelectedDivisionIds.ToHashSet();
    var balSelected = Model.SelectedBusinessAreaLookupIds.ToHashSet();
    var nameErr = ViewData.ModelState["Name"]?.Errors.FirstOrDefault()?.ErrorMessage
        ?? ViewData.ModelState["input.Name"]?.Errors.FirstOrDefault()?.ErrorMessage;
    var formAction = Model.IsNew
        ? Url.Action("ServiceLineCreate", "ModernManage")
        : Url.Action("ServiceLineUpdate", "ModernManage", new { slug = Model.Slug });
    var pickProductsUrl = Url.Action("ServiceLinePickProducts", "ModernManage");
    var pickWorkUrl = Url.Action("ServiceLinePickWork", "ModernManage");
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("FipsDashboard", "ModernManage")">Service register</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("ServiceLines", "ModernManage")">Service lines</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">@(Model.IsNew ? "Add" : "Edit")</li>
}

@section Styles {
<style nonce="@(Context.Items["Nonce"]?.ToString() ?? "")">
  .service-line-pick { position: relative; }
  .service-line-pick__combo { position: relative; }
  .service-line-pick__results[hidden] { display: none !important; }
  .service-line-pick__results {
    position: absolute; left: 0; right: 0; top: 100%; z-index: 20;
    margin: 0.25rem 0 0; padding: 0.5rem; max-height: 16rem; overflow: auto;
    background: #fff; border: 2px solid #0b0c0c; box-shadow: 0 4px 8px rgba(0,0,0,.12);
  }
  .service-line-pick__results-list { margin: 0; padding: 0; list-style: none; }
  .service-line-pick__results-list li { margin: 0; border-bottom: 1px solid #b1b4b6; }
  .service-line-pick__results-list li:last-child { border-bottom: 0; }
  .service-line-pick__result-btn {
    display: block; width: 100%; text-align: left; padding: 0.5rem 0.25rem;
    background: transparent; border: 0; font: inherit; cursor: pointer;
  }
  .service-line-pick__result-btn:hover, .service-line-pick__result-btn:focus { background: #f3f2f1; outline: 3px solid #fd0; outline-offset: 0; }
  .rpt-aside h2 { font-size: 1.125rem; margin: 0 0 0.5rem; }
  .rpt-aside p:last-child { margin-bottom: 0; }
</style>
}

@await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
  Caption = "Service Register",
  Title = Model.IsNew ? "Add service line" : "Edit service line"
})

@if (!ViewData.ModelState.IsValid)
{
 <div class="govuk-error-summary" role="alert" data-module="govuk-error-summary" style="margin-bottom:1.5rem;" aria-labelledby="sl-error-title" tabindex="-1">
 <h2 class="govuk-error-summary__title" id="sl-error-title">There is a problem</h2>
 <div class="govuk-error-summary__body">
 <ul class="govuk-list govuk-error-summary__list">
 @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
 {
 <li>@err.ErrorMessage</li>
 }
            </ul>
        </div>
    </div>
}

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">

<form method="post" action="@formAction" novalidate id="form-service-line">
    @Html.AntiForgeryToken()
    <div class="govuk-form-group @(nameErr != null ? "govuk-form-group--error" : "")">
 <label class="govuk-label govuk-label--m" for="Name">Service name</label>
 @if (nameErr != null)
 {
 <p class="govuk-error-message" id="Name-error"><span class="govuk-visually-hidden">Error: </span>@nameErr</p>
 }
 <input class="govuk-input @(nameErr != null ? "govuk-input--error" : "")" id="Name" name="Name" type="text" maxlength="200" value="@Model.Name" @(nameErr != null ? "aria-describedby=\"Name-error\"" : "") autocomplete="off" />
    </div>

 <div class="govuk-form-group">
 <label class="govuk-label govuk-label--m" for="Description">Description</label>
 <div class="govuk-hint" id="Description-hint">Optional. Plain-language summary of this service line.</div>
 <textarea class="govuk-textarea" id="Description" name="Description" rows="5" aria-describedby="Description-hint">@Model.Description</textarea>
    </div>

 <fieldset class="govuk-fieldset govuk-!-margin-bottom-6" id="sl-directorates">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Directorates</legend>
 <div class="govuk-hint" id="div-hint">Select the directorates this service line covers.</div>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="div-hint">
 @foreach (var o in Model.DivisionOptions)
 {
 var id = int.Parse(o.Value, CultureInfo.InvariantCulture);
 var chk = divSelected.Contains(id);
    if (chk) {
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="div-@o.Value" name="DivisionIds" type="checkbox" value="@o.Value" checked />
 <label class="govuk-label govuk-checkboxes__label" for="div-@o.Value">@o.Text</label>
    </div>
    } else {
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="div-@o.Value" name="DivisionIds" type="checkbox" value="@o.Value" />
 <label class="govuk-label govuk-checkboxes__label" for="div-@o.Value">@o.Text</label>
    </div>
    }
 }
        </div>
    </fieldset>

 <fieldset class="govuk-fieldset govuk-!-margin-bottom-6" id="sl-business-areas">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Business areas</legend>
 <div class="govuk-hint" id="ba-hint">Select the business areas this line applies to.</div>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="ba-hint">
 @foreach (var o in Model.BusinessAreaOptions)
 {
 var id = int.Parse(o.Value, CultureInfo.InvariantCulture);
 var chk = balSelected.Contains(id);
    if (chk) {
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="ba-@o.Value" name="BusinessAreaLookupIds" type="checkbox" value="@o.Value" checked />
 <label class="govuk-label govuk-checkboxes__label" for="ba-@o.Value">@o.Text</label>
    </div>
    } else {
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="ba-@o.Value" name="BusinessAreaLookupIds" type="checkbox" value="@o.Value" />
 <label class="govuk-label govuk-checkboxes__label" for="ba-@o.Value">@o.Text</label>
    </div>
    }
 }
        </div>
    </fieldset>

  <h2 class="govuk-heading-m" id="sl-fips-heading">FIPS (service register) products</h2>
  <p class="govuk-hint govuk-!-margin-bottom-2">Search the in-app service register, then add each product. Remove opens a confirmation dialog.</p>
  <div class="js-service-line-pick service-line-pick govuk-!-margin-bottom-6"
       data-sl-search-url="@pickProductsUrl"
       data-sl-field-name="ProductIds"
       data-sl-id-kind="guid"
       data-sl-confirm-title="Remove product?"
       data-sl-confirm-body="This product will be removed from the service line. You can search and add it again before saving."
       data-module="">
 <div class="govuk-form-group govuk-!-margin-bottom-2">
        <label class="govuk-label" for="sl-fips-search">Add a FIPS product</label>
  <div class="govuk-hint" id="sl-fips-hint">Type at least 2 characters. Choose a result to add it to the table below.</div>
 <div class="service-line-pick__combo">
 <input class="govuk-input js-sl-search" id="sl-fips-search" name="sl_fips_query" type="search" aria-describedby="sl-fips-hint" aria-autocomplete="list" autocomplete="off" />
 <div class="js-sl-results service-line-pick__results" id="sl-fips-results" hidden></div>
        </div>
    </div>

 <h3 class="govuk-heading-s" id="sl-fips-sel-lbl">Selected FIPS products</h3>
 <p class="govuk-body-s dfe-c-text-muted govuk-!-margin-bottom-0" id="sl-fips-empty" style="@(Model.InitialProducts.Count > 0 ? "display:none" : null)">None added yet.</p>
 <div id="sl-fips-table-wrap" class="dfe-f-table-wrapper govuk-!-margin-bottom-0" data-module="dfe-f-table" style="@(Model.InitialProducts.Count == 0 ? "display:none" : null)">
 <table class="govuk-table govuk-table--small-text-until-tablet">
 <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">Selected FIPS products</caption>
 <thead class="govuk-table__head">
 <tr class="govuk-table__row">
 <th scope="col" class="govuk-table__header">Product</th>
 <th scope="col" class="govuk-table__header govuk-!-width-one-quarter govuk-!-text-align-right">Action</th>
 </tr>
 </thead>
 <tbody id="sl-fips-selected" class="govuk-table__body js-sl-selected" aria-labelledby="sl-fips-sel-lbl">
    @foreach (var p in Model.InitialProducts)
    {
 <tr data-id="@p.Id">
 <td class="govuk-table__cell">
  <input type="hidden" name="ProductIds" value="@p.Id" />
  @p.Label
 </td>
 <td class="govuk-table__cell govuk-!-text-align-right">
  <a href="#" class="govuk-link js-sl-remove govuk-link--no-visited-state" aria-label="Remove @p.Label">Remove</a>
 </td>
 </tr>
    }
 </tbody>
 </table>
 </div>
  </div>

  <h2 class="govuk-heading-m" id="sl-wrk-heading">Work items</h2>
  <p class="govuk-hint govuk-!-margin-bottom-2">Search by title or work code, then add each item. Remove opens a confirmation dialog.</p>
  <div class="js-service-line-pick service-line-pick govuk-!-margin-bottom-6"
       data-sl-search-url="@pickWorkUrl"
       data-sl-field-name="ProjectIds"
       data-sl-id-kind="int"
       data-sl-confirm-title="Remove work item?"
       data-sl-confirm-body="This work item will be removed from the service line. You can search and add it again before saving."
       data-module="">
 <div class="govuk-form-group govuk-!-margin-bottom-2">
  <label class="govuk-label" for="sl-wrk-search">Add a work item</label>
  <div class="govuk-hint" id="sl-wrk-hint">Type at least 2 characters.</div>
 <div class="service-line-pick__combo">
  <input class="govuk-input js-sl-search" id="sl-wrk-search" name="sl_wk_query" type="search" aria-describedby="sl-wrk-hint" aria-autocomplete="list" autocomplete="off" />
 <div class="js-sl-results service-line-pick__results" id="sl-wrk-results" hidden></div>
  </div>
  </div>

 <h3 class="govuk-heading-s" id="sl-wrk-sel-lbl">Selected work items</h3>
 <p class="govuk-body-s dfe-c-text-muted govuk-!-margin-bottom-0" id="sl-wrk-empty" style="@(Model.InitialWork.Count > 0 ? "display:none" : null)">None added yet.</p>
 <div id="sl-wrk-table-wrap" class="dfe-f-table-wrapper govuk-!-margin-bottom-0" data-module="dfe-f-table" style="@(Model.InitialWork.Count == 0 ? "display:none" : null)">
 <table class="govuk-table govuk-table--small-text-until-tablet">
 <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">Selected work items</caption>
 <thead class="govuk-table__head">
 <tr class="govuk-table__row">
 <th scope="col" class="govuk-table__header">Work item</th>
 <th scope="col" class="govuk-table__header govuk-!-width-one-quarter govuk-!-text-align-right">Action</th>
 </tr>
 </thead>
 <tbody id="sl-wrk-selected" class="govuk-table__body js-sl-selected" aria-labelledby="sl-wrk-sel-lbl">
    @foreach (var w in Model.InitialWork)
    {
 <tr data-id="@w.Id">
 <td class="govuk-table__cell">
  <input type="hidden" name="ProjectIds" value="@w.Id" />
  @w.Label
  @if (!string.IsNullOrWhiteSpace(w.Subtitle))
  {
   <div class="govuk-body-s dfe-c-text-muted modern-work-table__meta">@w.Subtitle</div>
  }
 </td>
 <td class="govuk-table__cell govuk-!-text-align-right">
  <a href="#" class="govuk-link js-sl-remove govuk-link--no-visited-state" aria-label="Remove @w.Label">Remove</a>
 </td>
 </tr>
    }
 </tbody>
 </table>
 </div>
  </div>

 <div class="govuk-button-group">
 <button type="submit" class="govuk-button" data-module="govuk-button">@(Model.IsNew ? "Create service line" : "Save changes")</button>
 @if (Model.IsNew)
 {
 <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("ServiceLines", "ModernManage")">Cancel</a>
 }
 else
 {
 <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("ServiceLineDetail", "ModernManage", new { slug = Model.Slug })">Cancel</a>
 }
    </div>
</form>

  </div>
  <div class="govuk-grid-column-one-third">
  <aside class="govuk-inset-text rpt-aside govuk-!-margin-top-0" aria-labelledby="sl-info-title">
  <h2 class="govuk-heading-s" id="sl-info-title">What is a service line?</h2>
  <p class="govuk-body-s">A service line groups <strong>directorates</strong> and <strong>business areas</strong> for reporting, and links FIPS (service register) products and <strong>work</strong> items in one place.</p>
  <h3 class="govuk-heading-s govuk-!-margin-top-4" id="sl-fips-title">FIPS products</h3>
  <p class="govuk-body-s">Only products stored in the Compass FIPS / service register can be added. Use search to find them; inactive or retired items may be excluded from search if configured.</p>
  <h3 class="govuk-heading-s govuk-!-margin-top-4">Work items</h3>
  <p class="govuk-body-s">Search by <strong>title</strong> or <strong>project code</strong>. Selected items show the work ID (for example <strong>WI-00000123</strong>) like the work register.</p>
  </aside>
  </div>
</div>

@section Scripts {
  <script src="~/modern/js/service-line-pickers.js" asp-append-version="true" nonce="@(Context.Items["Nonce"]?.ToString() ?? "")"></script>
  <script nonce="@(Context.Items["Nonce"]?.ToString() ?? "")">
    (function () {
      function setVis(emptyEl, tbodyEl, wrapEl) {
        if (!tbodyEl) return;
        var n = tbodyEl.querySelectorAll('tr').length;
        if (n === 0) {
          if (emptyEl) { emptyEl.style.display = ''; }
          if (wrapEl) { wrapEl.style.display = 'none'; }
        } else {
          if (emptyEl) { emptyEl.style.display = 'none'; }
          if (wrapEl) { wrapEl.style.display = ''; }
        }
      }
      var emptyF = document.getElementById('sl-fips-empty');
      var tbodyF = document.getElementById('sl-fips-selected');
      var wrapF = document.getElementById('sl-fips-table-wrap');
      var emptyW = document.getElementById('sl-wrk-empty');
      var tbodyW = document.getElementById('sl-wrk-selected');
      var wrapW = document.getElementById('sl-wrk-table-wrap');
      function wire(tbody, emptyLabel, wrap) {
        if (!tbody) return;
        var ro = new MutationObserver(function () { setVis(emptyLabel, tbody, wrap); });
        ro.observe(tbody, { childList: true, subtree: true });
      }
      wire(tbodyF, emptyF, wrapF);
      wire(tbodyW, emptyW, wrapW);
    })();
  </script>
}
