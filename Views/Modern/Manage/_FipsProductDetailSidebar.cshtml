@model FipsProductDetailViewModel
@{
  var showEditingHint = ViewData["ShowEditingHint"] as bool? == true;
}

@if (showEditingHint)
{
  <div class="govuk-inset-text govuk-!-margin-bottom-0">
    <p class="govuk-body-s govuk-!-margin-bottom-0">Save changes updates the FIPS service register. CMDB description and identifiers stay aligned with CMDB sync — use user description and classifications to add context for DDT.</p>
  </div>
}
