@model FipsProductDetailViewModel
@{
  var p = Model.Product;
  var tab = Model.ActiveDetailTab ?? "information";
  string TabHref(string t) =>
      Url.Action("FipsProduct", "ModernManage", new { id = p.Id, tab = t }) ?? "#";
  bool IsCurrent(string t) => string.Equals(tab, t, StringComparison.OrdinalIgnoreCase);
  var workLinkCount = Model.WorkItemsPanel?.Links?.Count ?? 0;
  const string navListId = "fips-product-side-nav-list";
}

<nav class="dfe-f-side-navigation fips-product-side-nav"
     aria-label="Product sections"
     data-module="dfe-f-side-navigation">
  <button type="button"
          class="dfe-f-side-navigation__toggle"
          aria-controls="@navListId"
          aria-expanded="false">
    Sections
  </button>
  <ul id="@navListId" class="dfe-f-side-navigation__list" hidden>
    <li class="dfe-f-side-navigation__item@(IsCurrent("information") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state"
         href="@TabHref("information")"
         id="fips-tab-details"@if (IsCurrent("information")) { <text> aria-current="page"</text> }>Details</a>
    </li>
    <li class="dfe-f-side-navigation__item@(IsCurrent("risks") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state"
         href="@TabHref("risks")"
         id="fips-tab-risks"@if (IsCurrent("risks")) { <text> aria-current="page"</text> }>Risk</a>
    </li>
    <li class="dfe-f-side-navigation__item@(IsCurrent("issues") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state"
         href="@TabHref("issues")"
         id="fips-tab-issues"@if (IsCurrent("issues")) { <text> aria-current="page"</text> }>Issues</a>
    </li>
    <li class="dfe-f-side-navigation__item@(IsCurrent("assumptions") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state"
         href="@TabHref("assumptions")"
         id="fips-tab-assumptions"@if (IsCurrent("assumptions")) { <text> aria-current="page"</text> }>Assumptions</a>
    </li>
    <li class="dfe-f-side-navigation__item@(IsCurrent("dependencies") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state"
         href="@TabHref("dependencies")"
         id="fips-tab-dependencies"@if (IsCurrent("dependencies")) { <text> aria-current="page"</text> }>Dependencies</a>
    </li>
    <li class="dfe-f-side-navigation__item@(IsCurrent("work") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state dfe-f-side-navigation__link--with-badge"
         href="@TabHref("work")"
         id="fips-tab-work"@if (IsCurrent("work")) { <text> aria-current="page"</text> }>
        <span class="dfe-f-side-navigation__link-text">Work items</span>
        @await Html.PartialAsync("~/Views/Modern/Shared/_SideNavCountBadge.cshtml", workLinkCount)
      </a>
    </li>
    <li class="dfe-f-side-navigation__item@(IsCurrent("accessibility") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state"
         href="@TabHref("accessibility")"
         id="fips-tab-accessibility"@if (IsCurrent("accessibility")) { <text> aria-current="page"</text> }>Accessibility</a>
    </li>
    <li class="dfe-f-side-navigation__item@(IsCurrent("assurance") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state"
         href="@TabHref("assurance")"
         id="fips-tab-assurance"@if (IsCurrent("assurance")) { <text> aria-current="page"</text> }>Assurance</a>
    </li>
  </ul>
</nav>
