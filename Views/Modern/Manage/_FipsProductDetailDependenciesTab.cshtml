@model FipsProductDetailViewModel
@{
  var addUrl = Url.Action("DependencyCreate", "ModernRaid");
}

<div id="d-fips-dependencies" class="tab-pane @(Model.ActiveDetailTab == "dependencies" ? "on" : "")" role="tabpanel">
  <div class="dfe-c-flex--between govuk-!-margin-bottom-3 govuk-!-padding-bottom-2" style="flex-wrap:wrap;gap:0.75rem;align-items:center;border-bottom:1px solid #b1b4b6;">
    <h2 class="govuk-heading-m govuk-!-margin-top-0 govuk-!-margin-bottom-0">Dependencies</h2>
    <a class="govuk-button govuk-!-margin-bottom-0" href="@addUrl">Add dependency</a>
  </div>
  <p class="govuk-body-s govuk-!-margin-bottom-4" style="color:#505a5f;">Dependencies linked to risks or issues associated with this product.</p>
  @if (Model.ProductDependencies.Count == 0)
  {
    <p class="govuk-body govuk-!-margin-bottom-0">No dependencies recorded for this product.</p>
  }
  else
  {
    <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
      <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
      <table class="govuk-table govuk-!-margin-bottom-0">
        <caption class="govuk-visually-hidden">Dependencies linked to this product</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">From</button></th>
            <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">To</button></th>
            <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Link type</button></th>
            <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Status</button></th>
            <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Updated</button></th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          @foreach (var d in Model.ProductDependencies)
          {
            var detailUrl = Url.Action("DependencyDetail", "ModernRaid", new { id = d.Id }) ?? "#";
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">@d.SourceLabel</td>
              <td class="govuk-table__cell">@d.TargetLabel</td>
              <td class="govuk-table__cell">@(d.LinkTypeLabel ?? "—")</td>
              <td class="govuk-table__cell">@(d.Status ?? "—")</td>
              <td class="govuk-table__cell"><a href="@detailUrl" class="govuk-link govuk-link--no-visited-state">@d.UpdatedAt.ToString("d MMM yyyy")</a></td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
</div>
