@model FipsProductDetailViewModel
@{
    ViewData["Title"] = Model.Product.Title + " — FIPS";
    var p = Model.Product;
    var detailTab = Model.ActiveDetailTab;
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Fips", "ModernManage")">Service Register</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Fips", "ModernManage")">FIPS</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">@p.Title</li>
}

<div class="dfe-c-flex--between dfe-c-mb-3" style="flex-wrap:wrap;gap:1rem;align-items:flex-end;">
 <div class="dfe-c-page-title" style="margin:0;">
 <div class="dfe-c-page-title__caption">Service Register</div>
 <h1 class="dfe-c-page-title__heading">@p.Title</h1>
    </div>
</div>

 <div class="tabs dfe-c-mb-3" role="tablist" aria-label="Product sections">
        <a href="@Url.Action("FipsProduct", "ModernManage", new { id = p.Id, tab = "information", edit = Model.EditMode })"
 class="tab @(detailTab =="information" ? "on" : "")" role="tab" aria-selected="@(detailTab == "information")" aria-controls="d-fips-information" id="tab-fips-information">Information</a>
        <a href="@Url.Action("FipsProduct", "ModernManage", new { id = p.Id, tab = "risks", edit = false })"
 class="tab @(detailTab =="risks" ? "on" : "")" role="tab" aria-selected="@(detailTab == "risks")" aria-controls="d-fips-risks" id="tab-fips-risks">Risks (@Model.ProductRisks.Count)</a>
        <a href="@Url.Action("FipsProduct", "ModernManage", new { id = p.Id, tab = "issues", edit = false })"
 class="tab @(detailTab =="issues" ? "on" : "")" role="tab" aria-selected="@(detailTab == "issues")" aria-controls="d-fips-issues" id="tab-fips-issues">Issues (@Model.ProductIssues.Count)</a>
        <a href="@Url.Action("FipsProduct", "ModernManage", new { id = p.Id, tab = "history", edit = false })"
 class="tab @(detailTab =="history" ? "on" : "")" role="tab" aria-selected="@(detailTab == "history")" aria-controls="d-fips-history" id="tab-fips-history">History</a>
    </div>

    @if (Model.EditMode && Model.CanManage && detailTab == "information")
    {
 <div class="dfe-c-form-layout">
 <div class="dfe-c-form-layout__main">
 <div id="d-fips-information" class="tab-pane on" role="tabpanel">
 <div class="dfe-c-card dfe-c-card--plain">
                        <form method="post" novalidate action="@Url.Action("FipsProductUpdate", "ModernManage", new { id = p.Id })">
                            @Html.AntiForgeryToken()

 <fieldset class="govuk-fieldset govuk-!-margin-bottom-6">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">CMDB reference</legend>
 <p class="govuk-body-s govuk-!-margin-bottom-3" style="color:#505a5f;">Synced from CMDB. Edit the user-facing fields below to improve the service register entry.</p>
 <dl class="govuk-summary-list govuk-!-margin-bottom-0">
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">CMDB description</dt>
 <dd class="govuk-summary-list__value">@(string.IsNullOrWhiteSpace(p.CMDBDescription) ? "—" : p.CMDBDescription)</dd>
                                    </div>
                                </dl>
                            </fieldset>

 <fieldset class="govuk-fieldset govuk-!-margin-bottom-6">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Product details</legend>

 <div class="govuk-form-group">
 <label class="govuk-label" for="userDescription">User description</label>
 <div class="govuk-hint" id="userDescription-hint">Plain-language description for colleagues and the service register.</div>
 <textarea class="govuk-textarea" id="userDescription" name="userDescription" rows="4" aria-describedby="userDescription-hint">@p.UserDescription</textarea>
                                </div>

 <div class="govuk-form-group">
 <label class="govuk-label" for="phaseId">Phase</label>
 <select class="govuk-select govuk-!-width-full" id="phaseId" name="phaseId">
                                        <option value="">— Select —</option>
                                        @foreach (var opt in Model.PhaseOptions)
                                        {
                                            var isPhaseSelected = opt.Id == p.PhaseId;
                                            if (isPhaseSelected)
                                            {
                                                <option value="@opt.Id" selected>@opt.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@opt.Id">@opt.Name</option>
                                            }
                                        }
                                    </select>
                                </div>

 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Business area</legend>
 <div class="govuk-hint" id="ba-hint">Select all that apply.</div>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="ba-hint">
                                            @foreach (var ba in Model.BusinessAreaLookupOptions)
                                            {
                                                var isChecked = Model.SelectedBusinessAreaLookupIds.Contains(ba.Id);
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="ba-lkp-@ba.Id" name="businessAreaLookupIds" type="checkbox" value="@ba.Id" @(isChecked ? "checked" : "")>
 <label class="govuk-label govuk-checkboxes__label" for="ba-lkp-@ba.Id">@ba.Name</label>
                                                </div>
                                            }
                                        </div>
                                    </fieldset>
                                </div>

 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Channel</legend>
 <div class="govuk-hint" id="ch-hint">Select all that apply.</div>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="ch-hint">
                                            @foreach (var ch in Model.ChannelOptions)
                                            {
                                                var isChecked = p.Channels.Any(x => x.FipsChannelId == ch.Id);
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="ch-@ch.Id" name="channelIds" type="checkbox" value="@ch.Id" @(isChecked ? "checked" : "")>
 <label class="govuk-label govuk-checkboxes__label" for="ch-@ch.Id">@ch.Name</label>
                                                </div>
                                            }
                                        </div>
                                    </fieldset>
                                </div>

 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">User group</legend>
 <div class="govuk-hint" id="ug-hint">Select all that apply.</div>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="ug-hint">
                                            @foreach (var ug in Model.UserGroupOptions)
                                            {
                                                var isChecked = p.UserGroups.Any(x => x.FipsUserGroupId == ug.Id);
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="ug-@ug.Id" name="userGroupIds" type="checkbox" value="@ug.Id" @(isChecked ? "checked" : "")>
 <label class="govuk-label govuk-checkboxes__label" for="ug-@ug.Id">@ug.Name</label>
                                                </div>
                                            }
                                        </div>
                                    </fieldset>
                                </div>

 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Type</legend>
 <div class="govuk-hint" id="tp-hint">Select all that apply.</div>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="tp-hint">
                                            @foreach (var tp in Model.TypeOptions)
                                            {
                                                var isChecked = p.Types.Any(x => x.FipsTypeId == tp.Id);
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="tp-@tp.Id" name="typeIds" type="checkbox" value="@tp.Id" @(isChecked ? "checked" : "")>
 <label class="govuk-label govuk-checkboxes__label" for="tp-@tp.Id">@tp.Name</label>
                                                </div>
                                            }
                                        </div>
                                    </fieldset>
                                </div>

                                @await Html.PartialAsync("~/Views/Modern/Shared/_FipsProductCategorisationFields.cshtml", Model)

 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Enterprise service</legend>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="isEnterpriseService" name="isEnterpriseService" type="checkbox" value="true" @(p.IsEnterpriseService ? "checked" : "")>
 <label class="govuk-label govuk-checkboxes__label" for="isEnterpriseService">Mark as enterprise service for reporting and integrations</label>
 </div>
 </div>
 </fieldset>
 </div>

 <div class="govuk-form-group govuk-!-margin-bottom-0">
 <label class="govuk-label" for="productURL">Product URL</label>
 <div class="govuk-hint" id="productURL-hint">Public or internal URL for the live product or service.</div>
 <input class="govuk-input govuk-!-width-full" id="productURL" name="productURL" type="url" value="@p.ProductURL" aria-describedby="productURL-hint">
                                </div>
                            </fieldset>

 <div class="govuk-button-group govuk-!-margin-top-6 govuk-!-margin-bottom-0">
 <button type="submit" class="govuk-button" data-module="govuk-button">Save changes</button>
                                <a href="@Url.Action("FipsProduct", "ModernManage", new { id = p.Id, tab = "information", edit = false })"
 class="govuk-button govuk-button--secondary">Cancel editing</a>
                            </div>
                        </form>
                    </div>

 <h2 class="govuk-heading-m govuk-!-margin-top-6">People</h2>
                    @if (p.Contacts.Count == 0)
                    {
 <p class="govuk-body">No contacts assigned.</p>
                    }
                    else
                    {
 <dl class="govuk-summary-list">
                            @foreach (var c in p.Contacts.OrderBy(c => c.FipsContactRole.DisplayOrder))
                            {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">@c.FipsContactRole.Name</dt>
 <dd class="govuk-summary-list__value">
                                        @if (!string.IsNullOrWhiteSpace(c.UserName))
                                        {
 <div class="govuk-body govuk-!-margin-bottom-1">@c.UserName</div>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(c.UserEmail))
                                        {
 <div class="govuk-body">
 <a href="mailto:@c.UserEmail" class="govuk-link govuk-link--no-visited-state">@c.UserEmail</a>
                                            </div>
                                        }
                                        else if (string.IsNullOrWhiteSpace(c.UserName))
                                        {
                                            <span>—</span>
                                        }
                                    </dd>
                                </div>
                            }
                        </dl>
                    }
                </div>
            </div>

 <div class="dfe-c-form-layout__aside">
 <div class="dfe-c-sidebar">
 <div class="dfe-c-scard govuk-!-margin-bottom-4">
 <div class="dfe-c-scard__title">Product record</div>
 <div class="govuk-!-margin-bottom-3">
 <p class="govuk-body-s govuk-!-margin-bottom-1" style="color:#505a5f;">Product ID</p>
 <p class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-0">@(p.UniqueID == 0 ? "—" : p.UniqueID.ToString())</p>
                        </div>
 <div class="govuk-!-margin-bottom-3">
 <p class="govuk-body-s govuk-!-margin-bottom-1" style="color:#505a5f;">Status</p>
 <p class="govuk-body govuk-!-margin-bottom-0"><span class="dfe-c-tag @ProductStatusDfeTagClass(p.Status)">@p.Status</span></p>
                        </div>
 <div>
 <p class="govuk-body-s govuk-!-margin-bottom-1" style="color:#505a5f;">Manage</p>
                            @if (Model.CanManage)
                            {
                                <a href="@Url.Action("FipsProduct", "ModernManage", new { id = p.Id, tab = "information", edit = true })"
                                   class="govuk-button govuk-!-margin-bottom-0">Edit entry</a>
                            }
                            else
                            {
 <p class="govuk-body-s govuk-!-margin-bottom-0">You cannot edit this as you are not a named service owner or product manager</p>
                            }
                        </div>
                    </div>
 <div class="dfe-c-scard">
 <div class="dfe-c-scard__title">Editing this entry</div>
                        <div style="font-size:0.8125rem;color:var(--grey-4);">Save changes updates the FIPS service register. CMDB description and identifiers stay aligned with CMDB sync — use user description and classifications to add context for DDT.</div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
 <div class="dfe-c-form-layout">
 <div class="dfe-c-form-layout__main">

 <div id="d-fips-information" class="tab-pane @(detailTab =="information" ? "on" : "")" role="tabpanel">
                @if (!Model.CanManage)
                {
 <h2 class="govuk-heading-m">Overview</h2>
                }
                else if (!Model.EditMode)
                {
 <h2 class="govuk-heading-m">Overview</h2>
                }

                @if (!Model.CanManage || !Model.EditMode)
                {
 <dl class="govuk-summary-list">
                        @{ var readOnlyFields = new (string Label, string? Value, bool IsUrl)[] {
                            ("CMDB description", p.CMDBDescription, false),
                            ("User description", p.UserDescription, false),
                            ("Phase", p.Phase?.Name, false),
                            ("Business area", Model.BusinessAreasDisplay, false),
                            ("Channel", Model.ChannelsDisplay, false),
                            ("User group", Model.UserGroupsDisplay, false),
                            ("Type", Model.TypesDisplay, false),
                            ("Enterprise service", p.IsEnterpriseService ? "Yes" : "No", false),
                            ("Product URL", p.ProductURL, true)
                        }; }
                        @foreach (var f in readOnlyFields)
                        {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">@f.Label</dt>
 <dd class="govuk-summary-list__value">
                                    @if (f.IsUrl && !string.IsNullOrWhiteSpace(f.Value))
                                    {
 <a href="@f.Value" class="govuk-link" target="_blank" rel="noopener">@f.Value</a>
                                    }
                                    else
                                    {
                                        @(string.IsNullOrWhiteSpace(f.Value) ? "—" : f.Value)
                                    }
                                </dd>
                            </div>
                        }
                        @foreach (var cat in Model.CategorisationSummaryLines)
                        {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">@cat.GroupName</dt>
 <dd class="govuk-summary-list__value">@cat.ItemsDisplay</dd>
                            </div>
                        }
                    </dl>
                }

 <h2 class="govuk-heading-m govuk-!-margin-top-6">People</h2>
                @if (p.Contacts.Count == 0)
                {
 <p class="govuk-body">No contacts assigned.</p>
                }
                else
                {
 <dl class="govuk-summary-list">
                        @foreach (var c in p.Contacts.OrderBy(c => c.FipsContactRole.DisplayOrder))
                        {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">@c.FipsContactRole.Name</dt>
 <dd class="govuk-summary-list__value">
                                    @if (!string.IsNullOrWhiteSpace(c.UserName))
                                    {
 <div class="govuk-body govuk-!-margin-bottom-1">@c.UserName</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(c.UserEmail))
                                    {
 <div class="govuk-body">
 <a href="mailto:@c.UserEmail" class="govuk-link govuk-link--no-visited-state">@c.UserEmail</a>
                                        </div>
                                    }
                                    else if (string.IsNullOrWhiteSpace(c.UserName))
                                    {
                                        <span>—</span>
                                    }
                                </dd>
                            </div>
                        }
                    </dl>
                }
            </div>

            <partial name="~/Views/Modern/Shared/_FipsProductRaidPanes.cshtml" model="Model" />

 <div id="d-fips-history" class="tab-pane @(detailTab =="history" ? "on" : "")" role="tabpanel">
 <h2 class="govuk-heading-m">Change history</h2>
                @if (Model.AuditHistory.Count == 0)
                {
 <p class="govuk-body">No changes recorded.</p>
                }
                else
                {
 <ul class="fips-audit-timeline govuk-!-margin-top-4">
                        @foreach (var row in Model.AuditHistory)
                        {
                            var fieldLabel = string.IsNullOrWhiteSpace(row.FieldName) ? "Record" : row.FieldName;
 <li class="fips-audit-timeline__item">
 <div class="fips-audit-timeline__meta">
                                    @row.ChangedAt.ToString("d MMM yyyy HH:mm")
                                    @if (!string.IsNullOrWhiteSpace(row.ChangedBy))
                                    {
                                        <span> · @row.ChangedBy</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(row.ChangeType))
                                    {
 <span class="govuk-tag govuk-tag--blue govuk-!-margin-left-1" style="font-size:0.75rem;">@row.ChangeType</span>
                                    }
                                </div>
 <h3 class="fips-audit-timeline__field">@fieldLabel</h3>
 <div class="fips-audit-timeline__diff">
                                    <div>
 <p class="govuk-body-s govuk-!-margin-bottom-1" style="color:#505a5f;">Previous</p>
 <div class="fips-audit-timeline__diff-box">@(string.IsNullOrWhiteSpace(row.PreviousValue) ? "—" : row.PreviousValue)</div>
                                    </div>
                                    <div>
 <p class="govuk-body-s govuk-!-margin-bottom-1" style="color:#505a5f;">New</p>
 <div class="fips-audit-timeline__diff-box">@(string.IsNullOrWhiteSpace(row.NewValue) ? "—" : row.NewValue)</div>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>

        </div>

 <div class="dfe-c-form-layout__aside">
 <div class="dfe-c-sidebar">
 <div class="dfe-c-scard govuk-!-margin-bottom-4">
 <div class="dfe-c-scard__title">Product record</div>
 <div class="govuk-!-margin-bottom-3">
 <p class="govuk-body-s govuk-!-margin-bottom-1" style="color:#505a5f;">Product ID</p>
 <p class="govuk-body govuk-!-font-weight-bold govuk-!-margin-bottom-0">@(p.UniqueID == 0 ? "—" : p.UniqueID.ToString())</p>
                </div>
 <div class="govuk-!-margin-bottom-3">
 <p class="govuk-body-s govuk-!-margin-bottom-1" style="color:#505a5f;">Status</p>
 <p class="govuk-body govuk-!-margin-bottom-0"><span class="dfe-c-tag @ProductStatusDfeTagClass(p.Status)">@p.Status</span></p>
                </div>
 <div>
 <p class="govuk-body-s govuk-!-margin-bottom-1" style="color:#505a5f;">Manage</p>
                    @if (Model.CanManage)
                    {
                        <a href="@Url.Action("FipsProduct", "ModernManage", new { id = p.Id, tab = "information", edit = true })"
                           class="govuk-button govuk-!-margin-bottom-0">Edit entry</a>
                    }
                    else
                    {
 <p class="govuk-body-s govuk-!-margin-bottom-0">You cannot edit this as you are not a named service owner or product manager</p>
                    }
                </div>
            </div>
            </div>
        </div>
    </div>
    }

@functions {
    string ProductStatusDfeTagClass(CMDBProductStatus status) => status switch
    {
        CMDBProductStatus.Active => "dfe-c-tag--green",
        CMDBProductStatus.New => "dfe-c-tag--blue",
        CMDBProductStatus.Inactive => "dfe-c-tag--grey",
        CMDBProductStatus.Rejected => "dfe-c-tag--red",
        _ => "dfe-c-tag--grey"
    };

    (CMDBProductStatus Status, string Label)[] StatusTransitions(CMDBProductStatus current) => current switch
    {
        CMDBProductStatus.New => new[] { (CMDBProductStatus.Active, "Set active") },
        CMDBProductStatus.Active => Array.Empty<(CMDBProductStatus, string)>(),
        CMDBProductStatus.Inactive => new[] { (CMDBProductStatus.Active, "Reactivate") },
        CMDBProductStatus.Rejected => new[] { (CMDBProductStatus.Active, "Set active") },
        _ => Array.Empty<(CMDBProductStatus, string)>()
    };
}
