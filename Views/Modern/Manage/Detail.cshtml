@model FipsProductDetailViewModel
@using Compass.ViewModels.Modern
@{
    ViewData["Title"] = Model.Product.Title + " — FIPS";
    var p = Model.Product;
    var detailTab = Model.ActiveDetailTab;
    var editInfoUrl = Url.Action("FipsProduct", "ModernManage", new { id = p.Id, tab = "information", edit = true }) ?? "#";
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("FipsDashboard", "ModernManage")">Service register</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("FipsDashboard", "ModernManage")">Active products</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">@p.Title</li>
}

@await Html.PartialAsync("~/Views/Modern/Manage/_FipsProductMasthead.cshtml", Model)
@await Html.PartialAsync("_PageDataAccessHint")

<div class="fips-product-detail">
<div class="govuk-grid-row fips-product-detail-layout govuk-!-margin-top-2">
<div class="govuk-grid-column-one-quarter-from-desktop fips-product-detail-layout__nav">
  <div class="dfe-f-u-sticky govuk-!-margin-bottom-4 fips-product-detail-layout__nav-inner" style="--dfe-f-sticky-top: 1rem;">
    @await Html.PartialAsync("~/Views/Modern/Manage/_FipsProductSideNav.cshtml", Model)
  </div>
</div>
<div class="govuk-grid-column-three-quarters-from-desktop">
@{
  var showEditSidebar = Model.EditMode && detailTab == "information";
}
<div class="govuk-grid-row">
<div class="@(showEditSidebar ? "govuk-grid-column-two-thirds" : "govuk-grid-column-full")">

    @if (Model.EditMode && Model.CanEditInformation && detailTab == "information")
    {
 <div id="d-fips-information" class="tab-pane on" role="tabpanel">
 <div class="dfe-c-card dfe-c-card--plain fips-product-detail__main-form">
                        <form method="post" novalidate action="@Url.Action("FipsProductUpdate", "ModernManage", new { id = p.Id })">
                            @Html.AntiForgeryToken()

 <fieldset class="govuk-fieldset govuk-!-margin-bottom-6">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Product details</legend>

 <div class="govuk-form-group">
 <label class="govuk-label" for="userDescription">Description</label>
 <div class="govuk-hint" id="userDescription-hint">Plain-language description for colleagues and the service register.</div>
 <textarea class="govuk-textarea" id="userDescription" name="userDescription" rows="4" aria-describedby="userDescription-hint">@p.UserDescription</textarea>
                                </div>

 <div class="govuk-form-group">
 <label class="govuk-label" for="phaseId">Phase</label>
 <select class="govuk-select govuk-!-width-full" id="phaseId" name="phaseId">
                                        <option value="">— Select —</option>
                                        @foreach (var opt in Model.PhaseOptions)
                                        {
                                            var isPhaseSelected = opt.Id == p.PhaseId;
                                            if (isPhaseSelected)
                                            {
                                                <option value="@opt.Id" selected>@opt.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@opt.Id">@opt.Name</option>
                                            }
                                        }
                                    </select>
                                </div>

 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Business area</legend>
 <div class="govuk-hint" id="ba-hint">Select all that apply.</div>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="ba-hint">
                                            @foreach (var ba in Model.BusinessAreaLookupOptions)
                                            {
                                                var isChecked = Model.SelectedBusinessAreaLookupIds.Contains(ba.Id);
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="ba-lkp-@ba.Id" name="businessAreaLookupIds" type="checkbox" value="@ba.Id" @(isChecked ? "checked" : "")>
 <label class="govuk-label govuk-checkboxes__label" for="ba-lkp-@ba.Id">@ba.Name</label>
                                                </div>
                                            }
                                        </div>
                                    </fieldset>
                                </div>

 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Channel</legend>
 <div class="govuk-hint" id="ch-hint">Select all that apply.</div>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="ch-hint">
                                            @foreach (var ch in Model.ChannelOptions)
                                            {
                                                var isChecked = p.Channels.Any(x => x.FipsChannelId == ch.Id);
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="ch-@ch.Id" name="channelIds" type="checkbox" value="@ch.Id" @(isChecked ? "checked" : "")>
 <label class="govuk-label govuk-checkboxes__label" for="ch-@ch.Id">@ch.Name</label>
                                                </div>
                                            }
                                        </div>
                                    </fieldset>
                                </div>

 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">User group</legend>
 <div class="govuk-hint" id="ug-hint">Select all that apply.</div>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="ug-hint">
                                            @foreach (var ug in Model.UserGroupTreeOptions)
                                            {
                                                var isChecked = p.UserGroups.Any(x => x.FipsUserGroupId == ug.Id);
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="ug-@ug.Id" name="userGroupIds" type="checkbox" value="@ug.Id" @(isChecked ? "checked" : "")>
 <label class="govuk-label govuk-checkboxes__label" for="ug-@ug.Id">@AdminFipsUserGroupTreeHelper.FormatIndentedLabel(ug.Name, ug.Depth)</label>
                                                </div>
                                            }
                                        </div>
                                    </fieldset>
                                </div>

 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Type</legend>
 <div class="govuk-hint" id="tp-hint">Select all that apply.</div>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="tp-hint">
                                            @foreach (var tp in Model.TypeOptions)
                                            {
                                                var isChecked = p.Types.Any(x => x.FipsTypeId == tp.Id);
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="tp-@tp.Id" name="typeIds" type="checkbox" value="@tp.Id" @(isChecked ? "checked" : "")>
 <label class="govuk-label govuk-checkboxes__label" for="tp-@tp.Id">@tp.Name</label>
                                                </div>
                                            }
                                        </div>
                                    </fieldset>
                                </div>

                                @await Html.PartialAsync("~/Views/Modern/Shared/_FipsProductCategorisationFields.cshtml", Model)

 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Enterprise service</legend>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="isEnterpriseService" name="isEnterpriseService" type="checkbox" value="true" @(p.IsEnterpriseService ? "checked" : "")>
 <label class="govuk-label govuk-checkboxes__label" for="isEnterpriseService">Mark as enterprise service for reporting and integrations</label>
 </div>
 </div>
 </fieldset>
 </div>

 <div class="govuk-form-group govuk-!-margin-bottom-0">
 <label class="govuk-label" for="productURL">Product URL</label>
 <div class="govuk-hint" id="productURL-hint">Public or internal URL for the live product or service.</div>
 <input class="govuk-input govuk-!-width-full" id="productURL" name="productURL" type="url" value="@p.ProductURL" aria-describedby="productURL-hint">
                                </div>
                            </fieldset>

 <div class="govuk-button-group govuk-!-margin-top-6 govuk-!-margin-bottom-0">
 <button type="submit" class="govuk-button" data-module="govuk-button">Save changes</button>
 <a href="@Url.Action("FipsProduct", "ModernManage", new { id = p.Id, tab = "information", edit = false })" class="govuk-button govuk-button--secondary">Cancel</a>
                            </div>
                        </form>
                    </div>

 <div class="govuk-summary-card fips-product-detail__card govuk-!-margin-top-6">
 <div class="govuk-summary-card__title-wrapper">
 <h2 class="govuk-summary-card__title">People</h2>
 </div>
 <div class="govuk-summary-card__content">
                    @if (p.Contacts.Count == 0)
                    {
 <p class="govuk-body govuk-!-margin-bottom-0">No contacts assigned.</p>
                    }
                    else
                    {
 <dl class="govuk-summary-list govuk-!-margin-bottom-0">
                            @foreach (var c in p.Contacts.OrderBy(c => c.FipsContactRole.DisplayOrder))
                            {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">@c.FipsContactRole.Name</dt>
 <dd class="govuk-summary-list__value">
   @{
     var em = c.UserEmail?.Trim();
     var nm = c.UserName?.Trim();
     var hasEm = !string.IsNullOrEmpty(em);
     var hasNm = !string.IsNullOrEmpty(nm);
   }
   @if (hasEm && hasNm)
   {
     <a href="mailto:@em" class="govuk-link govuk-link--no-visited-state">@nm</a>
   }
   else if (hasEm)
   {
     <a href="mailto:@em" class="govuk-link govuk-link--no-visited-state">@em</a>
   }
   else if (hasNm)
   {
     @nm
   }
   else
   {
     <span>—</span>
   }
 </dd>
                                </div>
                            }
                        </dl>
                    }
 </div>
 </div>
 </div>
    }
    else if (detailTab == "information")
    {
 <div id="d-fips-information" class="tab-pane on" role="tabpanel">
 <div class="govuk-summary-card fips-product-detail__card govuk-!-margin-bottom-6">
 <div class="govuk-summary-card__title-wrapper">
 <h2 class="govuk-summary-card__title">Product details</h2>
 </div>
 <div class="govuk-summary-card__content">
 <dl class="govuk-summary-list govuk-!-margin-bottom-0">
                        @{ var readOnlyFields = new (string Label, string? Value, bool IsUrl, string ChangeVisuallyHidden)[] {
                            ("Description", p.UserDescription, false, "description"),
                            ("Phase", p.Phase?.Name, false, "phase"),
                            ("Business area", Model.BusinessAreasDisplay, false, "business area"),
                            ("Channel", Model.ChannelsDisplay, false, "channel"),
                            ("User group", Model.UserGroupsDisplay, false, "user group"),
                            ("Type", Model.TypesDisplay, false, "type"),
                            ("Enterprise service", p.IsEnterpriseService ? "Yes" : "No", false, "enterprise service"),
                            ("Product URL", p.ProductURL, true, "product URL")
                        }; }
                        @foreach (var f in readOnlyFields)
                        {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">@f.Label</dt>
 <dd class="govuk-summary-list__value">
                                    @if (f.IsUrl && !string.IsNullOrWhiteSpace(f.Value))
                                    {
 <a href="@f.Value" class="govuk-link" target="_blank" rel="noopener">@f.Value</a>
                                    }
                                    else
                                    {
                                        @(string.IsNullOrWhiteSpace(f.Value) ? "—" : f.Value)
                                    }
                                </dd>
 @if (Model.CanEditInformation)
 {
 <dd class="govuk-summary-list__actions">
   <a class="govuk-link" href="@editInfoUrl">Change<span class="govuk-visually-hidden"> @f.ChangeVisuallyHidden</span></a>
 </dd>
 }
                            </div>
                        }
                        @foreach (var cat in Model.CategorisationSummaryLines)
                        {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">@cat.GroupName</dt>
 <dd class="govuk-summary-list__value">@cat.ItemsDisplay</dd>
 @if (Model.CanEditInformation)
 {
 <dd class="govuk-summary-list__actions">
   <a class="govuk-link" href="@editInfoUrl">Change<span class="govuk-visually-hidden"> @cat.GroupName</span></a>
 </dd>
 }
                            </div>
                        }
                    </dl>
 </div>
 </div>

 <div class="govuk-summary-card fips-product-detail__card">
 <div class="govuk-summary-card__title-wrapper">
 <h2 class="govuk-summary-card__title">People</h2>
 </div>
 <div class="govuk-summary-card__content">
                @if (p.Contacts.Count == 0)
                {
 <p class="govuk-body govuk-!-margin-bottom-0">No contacts assigned.</p>
                }
                else
                {
 <dl class="govuk-summary-list govuk-!-margin-bottom-0">
                        @foreach (var c in p.Contacts.OrderBy(c => c.FipsContactRole.DisplayOrder))
                        {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">@c.FipsContactRole.Name</dt>
 <dd class="govuk-summary-list__value">
   @{
     var emRo = c.UserEmail?.Trim();
     var nmRo = c.UserName?.Trim();
     var hasEmRo = !string.IsNullOrEmpty(emRo);
     var hasNmRo = !string.IsNullOrEmpty(nmRo);
   }
   @if (hasEmRo && hasNmRo)
   {
     <a href="mailto:@emRo" class="govuk-link govuk-link--no-visited-state">@nmRo</a>
   }
   else if (hasEmRo)
   {
     <a href="mailto:@emRo" class="govuk-link govuk-link--no-visited-state">@emRo</a>
   }
   else if (hasNmRo)
   {
     @nmRo
   }
   else
   {
     <span>—</span>
   }
 </dd>
                            </div>
                        }
                    </dl>
                }
 </div>
 </div>
            </div>

@* history tab removed from manage nav *@
 <div id="d-fips-history" class="tab-pane" hidden style="display:none !important;">
 <div class="govuk-summary-card fips-product-detail__card">
 <div class="govuk-summary-card__title-wrapper">
 <h2 class="govuk-summary-card__title">Change history</h2>
 </div>
 <div class="govuk-summary-card__content">
                @if (Model.AuditHistory.Count == 0)
                {
 <p class="govuk-body govuk-!-margin-bottom-0">No changes recorded.</p>
                }
                else
                {
 <ol class="dfe-f-timeline govuk-!-margin-0">
                        @foreach (var row in Model.AuditHistory)
                        {
                            var fieldLabel = string.IsNullOrWhiteSpace(row.FieldName) ? "Record" : row.FieldName;
                            var changedAtIso = row.ChangedAt.ToString("yyyy-MM-ddTHH:mm:ss");
 <li class="dfe-f-timeline__item">
 <p class="govuk-body govuk-!-margin-bottom-1">
 <strong>@fieldLabel</strong>
 @if (!string.IsNullOrWhiteSpace(row.ChangeType))
 {
   <span class="govuk-tag govuk-tag--blue govuk-!-margin-left-1 fips-product-detail__history-tag">@row.ChangeType</span>
 }
 </p>
 <p class="dfe-f-timeline__meta govuk-body-s govuk-!-margin-bottom-0">
 <time datetime="@changedAtIso">@row.ChangedAt.ToString("d MMM yyyy HH:mm")</time>
 @if (!string.IsNullOrWhiteSpace(row.ChangedBy))
 {
   <span> · @row.ChangedBy</span>
 }
 </p>
                            </li>
                        }
                    </ol>
                }
 </div>
 </div>
            </div>

    }

@await Html.PartialAsync("~/Views/Modern/Manage/_FipsProductWorkItemsTab.cshtml", Model)
<partial name="~/Views/Modern/Shared/_FipsProductRaidPanes.cshtml" model="Model" />
@await Html.PartialAsync("~/Views/Modern/Manage/_FipsProductDetailAssumptionsTab.cshtml", Model)
@await Html.PartialAsync("~/Views/Modern/Manage/_FipsProductDetailDependenciesTab.cshtml", Model)
@await Html.PartialAsync("~/Views/Modern/Manage/_FipsProductDetailAccessibilityTab.cshtml", Model)
@await Html.PartialAsync("~/Views/Modern/Manage/_FipsProductDetailAssuranceTab.cshtml", Model)

</div>
@if (showEditSidebar)
{
<div class="govuk-grid-column-one-third">
  @{
    ViewData["ShowEditingHint"] = true;
  }
  @await Html.PartialAsync("~/Views/Modern/Manage/_FipsProductDetailSidebar.cshtml", Model)
</div>
}
</div>
</div>
</div>
</div>

@section Styles {
<style nonce="@(Context.Items["Nonce"]?.ToString() ?? "")">
  .service-line-pick { position: relative; }
  .service-line-pick__combo { position: relative; }
  .service-line-pick__results[hidden] { display: none !important; }
  .service-line-pick__results {
    position: absolute; left: 0; right: 0; top: 100%; z-index: 20;
    margin: 0.25rem 0 0; padding: 0.5rem; max-height: 16rem; overflow: auto;
    background: #fff; border: 2px solid #0b0c0c; box-shadow: 0 4px 8px rgba(0,0,0,.12);
  }
  .service-line-pick__results-list { margin: 0; padding: 0; list-style: none; }
  .service-line-pick__results-list li { margin: 0; border-bottom: 1px solid #b1b4b6; }
  .service-line-pick__results-list li:last-child { border-bottom: 0; }
  .service-line-pick__result-btn {
    display: block; width: 100%; text-align: left; padding: 0.5rem 0.25rem;
    background: transparent; border: 0; font: inherit; cursor: pointer;
  }
  .service-line-pick__result-btn:hover, .service-line-pick__result-btn:focus { background: #f3f2f1; outline: 3px solid #fd0; outline-offset: 0; }
</style>
}

@section Scripts {
  <script src="~/modern/js/service-line-pickers.js" asp-append-version="true" nonce="@(Context.Items["Nonce"]?.ToString() ?? "")"></script>
}
