@model FipsProductDetailViewModel
@using Compass.Helpers
@using Compass.ViewModels.Modern
@{
  var p = Model.Product;
  var sa = Model.StrategicAlignment;
  if (sa == null)
  {
    return;
  }
  var canEdit = Model.CanEditInformation;
  var editStrategicUrl = Url.Action("FipsProductEditStrategicAlignment", "ModernManage", new { id = p.Id }) ?? "#";
  var editMultiDeptUrl = Url.Action("FipsProductEditMultiDeptCooperation", "ModernManage", new { id = p.Id }) ?? "#";
}

<div id="d-fips-strategic-alignment" class="tab-pane @(Model.ActiveDetailTab == "strategic-alignment" ? "on" : "")" role="tabpanel">
  <div class="govuk-summary-card govuk-!-margin-top-0">
    <div class="govuk-summary-card__title-wrapper">
      <h2 class="govuk-summary-card__title">Strategic alignment</h2>
      @if (canEdit)
      {
        <ul class="govuk-summary-card__actions">
          <li class="govuk-summary-card__action">
            <a href="@editStrategicUrl" class="govuk-link govuk-link--no-visited-state">Edit</a>
          </li>
        </ul>
      }
    </div>
    <div class="govuk-summary-card__content">
      <dl class="govuk-summary-list govuk-!-margin-bottom-0">
        <div class="govuk-summary-list__row@(canEdit ? "" : " govuk-summary-list__row--no-actions")">
          <dt class="govuk-summary-list__key">Priority outcomes</dt>
          <dd class="govuk-summary-list__value">
            @if (sa.PriorityOutcomeNames.Count == 0)
            {
              <span class="muted">—</span>
            }
            else
            {
              <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-0">
                @foreach (var name in sa.PriorityOutcomeNames)
                {
                  <li>@name</li>
                }
              </ul>
            }
          </dd>
          @if (canEdit)
          {
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link govuk-link--no-visited-state" href="@(editStrategicUrl)#edit-priority-outcomes">Change<span class="govuk-visually-hidden"> priority outcomes</span></a>
            </dd>
          }
        </div>
        <div class="govuk-summary-list__row@(canEdit ? "" : " govuk-summary-list__row--no-actions")">
          <dt class="govuk-summary-list__key">Mission pillars</dt>
          <dd class="govuk-summary-list__value">
            @if (sa.MissionPillarNames.Count == 0)
            {
              <span class="muted">—</span>
            }
            else
            {
              <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-0">
                @foreach (var name in sa.MissionPillarNames)
                {
                  <li>@name</li>
                }
              </ul>
            }
          </dd>
          @if (canEdit)
          {
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link govuk-link--no-visited-state" href="@(editStrategicUrl)#edit-mission-pillars">Change<span class="govuk-visually-hidden"> mission pillars</span></a>
            </dd>
          }
        </div>
        <div class="govuk-summary-list__row@(canEdit ? "" : " govuk-summary-list__row--no-actions")">
          <dt class="govuk-summary-list__key">Thematic tags</dt>
          <dd class="govuk-summary-list__value">
            @if (sa.Tags.Count == 0)
            {
              <span class="muted">—</span>
            }
            else
            {
              <ul class="govuk-list govuk-!-margin-bottom-0">
                @foreach (var tg in sa.Tags)
                {
                  <li>@tg.Name</li>
                }
              </ul>
            }
          </dd>
          @if (canEdit)
          {
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link govuk-link--no-visited-state" href="@(editStrategicUrl)#edit-flagship">Change<span class="govuk-visually-hidden"> thematic tags</span></a>
            </dd>
          }
        </div>
        <div class="govuk-summary-list__row@(canEdit ? "" : " govuk-summary-list__row--no-actions")">
          <dt class="govuk-summary-list__key">Multi-dept cooperation</dt>
          <dd class="govuk-summary-list__value">@(sa.GovernmentDepartmentNames.Count == 0 ? "—" : string.Join(", ", sa.GovernmentDepartmentNames))</dd>
          @if (canEdit)
          {
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link govuk-link--no-visited-state" href="@editMultiDeptUrl">Change<span class="govuk-visually-hidden"> multi-dept cooperation</span></a>
            </dd>
          }
        </div>
        <div class="govuk-summary-list__row@(canEdit ? "" : " govuk-summary-list__row--no-actions")">
          <dt class="govuk-summary-list__key">Subject to spend control</dt>
          <dd class="govuk-summary-list__value">@(sa.SubjectToSpendControl ? "Yes" : "No")</dd>
          @if (canEdit)
          {
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link govuk-link--no-visited-state" href="@(editStrategicUrl)#edit-spend-control">Change<span class="govuk-visually-hidden"> subject to spend control</span></a>
            </dd>
          }
        </div>
        <div class="govuk-summary-list__row@(canEdit ? "" : " govuk-summary-list__row--no-actions")">
          <dt class="govuk-summary-list__key">Risk appetite</dt>
          <dd class="govuk-summary-list__value">
            @if (sa.RiskAppetiteId.HasValue && !string.IsNullOrWhiteSpace(sa.RiskAppetiteName) && sa.RiskAppetiteName != "—")
            {
              <span class="@WorkBadgeCss.RiskAppetiteDfeFrontendBadgeClass(sa.RiskAppetiteName, sa.RiskAppetiteOptions, sa.RiskAppetiteId)">@sa.RiskAppetiteName</span>
            }
            else
            {
              <text>—</text>
            }
          </dd>
          @if (canEdit)
          {
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link govuk-link--no-visited-state" href="@(editStrategicUrl)#edit-risk-appetite">Change<span class="govuk-visually-hidden"> risk appetite</span></a>
            </dd>
          }
        </div>
      </dl>
    </div>
  </div>
</div>
