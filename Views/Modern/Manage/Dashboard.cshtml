@model FipsManageDashboardViewModel
@using Compass.ViewModels.Modern
@{
  ViewData["Title"] = "Service register dashboard";
  var productsHref = Url.Action("Fips", "ModernManage") ?? "#";
  var myProductsHref = Url.Action("Fips", "ModernManage", new { tab = "my" }) ?? productsHref;
  var activeProductsHref = Url.Action("Fips", "ModernManage", new { tab = "active" }) ?? productsHref;
  var enterpriseProductsHref = Url.Action("Fips", "ModernManage", new { tab = "enterprise" }) ?? productsHref;
  var serviceLinesHref = Url.Action("ServiceLines", "ModernManage") ?? "#";
}

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">Service register</li>
}

@await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
  Caption = "Service register",
  Title = "Dashboard",
  Lede = new Microsoft.AspNetCore.Html.HtmlString("<p class=\"govuk-body govuk-!-margin-bottom-0\">Summary of catalogue products and service lines you can manage in Compass.</p>")
})

<section class="govuk-!-margin-top-6 govuk-!-margin-bottom-6" aria-labelledby="fips-dash-stats-heading">
  <h2 class="govuk-heading-m" id="fips-dash-stats-heading">At a glance</h2>
  <div class="dfe-f-card-grid">
    @await Html.PartialAsync("~/Views/Modern/Raid/_RaidDashboardStatCard.cshtml", new RaidDashboardStatCardVm
    {
      Label = "Your products",
      Value = Model.MyProductsCount.ToString("N0"),
      Trend = "View your products",
      Href = myProductsHref,
      AriaLabel = $"Your products, {Model.MyProductsCount} products",
      TintClass = "dfe-f-stat-card--tint-blue"
    })
    @await Html.PartialAsync("~/Views/Modern/Raid/_RaidDashboardStatCard.cshtml", new RaidDashboardStatCardVm
    {
      Label = "Active products",
      Value = Model.ActiveProductsCount.ToString("N0"),
      Trend = "View active catalogue",
      Href = activeProductsHref,
      AriaLabel = $"Active products, {Model.ActiveProductsCount} products",
      TintClass = "dfe-f-stat-card--tint-teal"
    })
    @await Html.PartialAsync("~/Views/Modern/Raid/_RaidDashboardStatCard.cshtml", new RaidDashboardStatCardVm
    {
      Label = "Enterprise products",
      Value = Model.EnterpriseProductsCount.ToString("N0"),
      Trend = "View enterprise services",
      Href = enterpriseProductsHref,
      AriaLabel = $"Enterprise products, {Model.EnterpriseProductsCount} products",
      TintClass = "dfe-f-stat-card--tint-orange"
    })
    @await Html.PartialAsync("~/Views/Modern/Raid/_RaidDashboardStatCard.cshtml", new RaidDashboardStatCardVm
    {
      Label = "Service lines",
      Value = Model.ServiceLinesCount.ToString("N0"),
      Trend = "View service lines",
      Href = serviceLinesHref,
      AriaLabel = $"Service lines, {Model.ServiceLinesCount} service lines",
      TintClass = "dfe-f-stat-card--tint-grey"
    })
  </div>
</section>

<section class="govuk-!-margin-bottom-6" aria-labelledby="fips-public-heading">
  <article class="dfe-f-card dfe-f-card--action">
    <div class="dfe-f-card__inner">
      <header class="dfe-f-card__header">
        <h2 class="govuk-heading-m dfe-f-card__heading govuk-!-margin-top-0" id="fips-public-heading">Find products and services on FIPS</h2>
      </header>
      <p class="dfe-f-card__body govuk-body govuk-!-margin-bottom-0">
        Most colleagues browse the public catalogue at
        <a class="govuk-link govuk-link--no-visited-state" href="@Model.FipsPublicBaseUrl" rel="noopener noreferrer">@Model.FipsPublicBaseUrl</a>
        to discover what DfE offers, who it is for, and how to access it.
      </p>
      <div class="dfe-f-card__footer">
        <a class="govuk-button govuk-!-margin-bottom-0" href="@Model.FipsPublicBaseUrl" rel="noopener noreferrer">Go to FIPS</a>
      </div>
    </div>
  </article>
</section>
