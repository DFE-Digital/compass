@model FipsManageDashboardViewModel
@using Compass.ViewModels.Modern
@{
  ViewData["Title"] = "Service register dashboard";
  var products = Model.ActiveProducts;
  var myProductsHref = Url.Action("Fips", "ModernManage", new { tab = "my" }) ?? "#";
  var activeProductsHref = Url.Action("FipsDashboard", "ModernManage") ?? "#";
  var enterpriseProductsHref = Url.Action("Fips", "ModernManage", new { tab = "enterprise" }) ?? "#";
  var serviceLinesHref = Url.Action("ServiceLines", "ModernManage") ?? "#";
  var fipsPublicUrl = Model.FipsPublicBaseUrl;
  var headerActions = new Microsoft.AspNetCore.Html.HtmlString(
    $"<a class=\"govuk-button govuk-!-margin-bottom-0\" href=\"{fipsPublicUrl}\" rel=\"noopener noreferrer\">Go to FIPS</a>");
}

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">Service register</li>
}

@if (TempData["Success"] != null)
{
  <div class="govuk-notification-banner govuk-notification-banner--success" role="region" aria-labelledby="fips-dash-success-title">
    <div class="govuk-notification-banner__header">
      <h2 class="govuk-notification-banner__title" id="fips-dash-success-title">Success</h2>
    </div>
    <div class="govuk-notification-banner__content">
      <p class="govuk-notification-banner__heading">@TempData["Success"]</p>
    </div>
  </div>
}
@if (TempData["Error"] != null)
{
  <div class="govuk-error-summary" role="alert" style="margin-bottom:1.5rem;">
    <h2 class="govuk-error-summary__title">Something went wrong</h2>
    <div class="govuk-error-summary__body">@TempData["Error"]</div>
  </div>
}

@await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
  Caption = "Service register",
  Title = "Dashboard",
  Actions = headerActions
})

<section class="govuk-!-margin-top-6 govuk-!-margin-bottom-6" aria-label="Summary statistics">
  <div class="dfe-f-card-grid">
    @await Html.PartialAsync("~/Views/Modern/Raid/_RaidDashboardStatCard.cshtml", new RaidDashboardStatCardVm
    {
      Label = "Your products",
      Value = Model.MyProductsCount.ToString("N0"),
      Trend = "View your products",
      Href = myProductsHref,
      AriaLabel = $"Your products, {Model.MyProductsCount} products",
      TintClass = "dfe-f-stat-card--tint-blue"
    })
    @await Html.PartialAsync("~/Views/Modern/Raid/_RaidDashboardStatCard.cshtml", new RaidDashboardStatCardVm
    {
      Label = "Active products",
      Value = Model.ActiveProductsCount.ToString("N0"),
      Trend = "View active catalogue",
      Href = activeProductsHref + "#fips-active-products",
      AriaLabel = $"Active products, {Model.ActiveProductsCount} products",
      TintClass = "dfe-f-stat-card--tint-teal"
    })
    @await Html.PartialAsync("~/Views/Modern/Raid/_RaidDashboardStatCard.cshtml", new RaidDashboardStatCardVm
    {
      Label = "Enterprise products",
      Value = Model.EnterpriseProductsCount.ToString("N0"),
      Trend = "View enterprise services",
      Href = enterpriseProductsHref,
      AriaLabel = $"Enterprise products, {Model.EnterpriseProductsCount} products",
      TintClass = "dfe-f-stat-card--tint-orange"
    })
    @await Html.PartialAsync("~/Views/Modern/Raid/_RaidDashboardStatCard.cshtml", new RaidDashboardStatCardVm
    {
      Label = "Service lines",
      Value = Model.ServiceLinesCount.ToString("N0"),
      Trend = "View service lines",
      Href = serviceLinesHref,
      AriaLabel = $"Service lines, {Model.ServiceLinesCount} service lines",
      TintClass = "dfe-f-stat-card--tint-grey"
    })
  </div>
</section>

<section id="fips-active-products" class="govuk-!-margin-bottom-6" aria-labelledby="fips-active-products-heading">
  <h2 class="govuk-heading-m" id="fips-active-products-heading">Active products</h2>
  <p class="govuk-body govuk-!-margin-bottom-4">
    Active products in the service register, excluding enterprise services (see
    <a class="govuk-link govuk-link--no-visited-state" href="@enterpriseProductsHref">Enterprise</a>).
    Browse the public catalogue at
    <a class="govuk-link govuk-link--no-visited-state" href="@fipsPublicUrl" rel="noopener noreferrer">@fipsPublicUrl</a>.
  </p>

  @if (!string.IsNullOrWhiteSpace(products.CategorisationItemName))
  {
    <div class="govuk-inset-text govuk-!-margin-bottom-4">
      <p class="govuk-body govuk-!-margin-bottom-2">Showing products with categorisation value <strong>@products.CategorisationItemName</strong>.</p>
      <p class="govuk-body govuk-!-margin-bottom-0"><a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("FipsDashboard", "ModernManage", new { tab = "active" })">Clear categorisation filter</a></p>
    </div>
  }
  else if (!string.IsNullOrWhiteSpace(products.CategorisationGroupName))
  {
    <div class="govuk-inset-text govuk-!-margin-bottom-4">
      <p class="govuk-body govuk-!-margin-bottom-2">Showing products in categorisation <strong>@products.CategorisationGroupName</strong>.</p>
      <p class="govuk-body govuk-!-margin-bottom-0"><a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("FipsDashboard", "ModernManage", new { tab = "active" })">Clear categorisation filter</a></p>
    </div>
  }

  <div class="govuk-!-margin-bottom-4">
    @await Html.PartialAsync("_SearchAndFilter", (SearchAndFilterViewModel)ViewBag.SearchAndFilter)
  </div>

  @await Html.PartialAsync("~/Views/Modern/Manage/_FipsManageProductsTable.cshtml", products)
</section>
