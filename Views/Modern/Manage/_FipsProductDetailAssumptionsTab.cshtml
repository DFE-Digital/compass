@model FipsProductDetailViewModel
@{
  var addUrl = Model.ResolvedFipsServiceId is int sid && sid > 0
      ? Url.Action("AssumptionCreate", "ModernRaid", new { associationKind = "product", primaryProductId = sid })
      : Url.Action("AssumptionCreate", "ModernRaid");
}

<div id="d-fips-assumptions" class="tab-pane @(Model.ActiveDetailTab == "assumptions" ? "on" : "")" role="tabpanel">
  <div class="dfe-c-flex--between govuk-!-margin-bottom-3 govuk-!-padding-bottom-2" style="flex-wrap:wrap;gap:0.75rem;align-items:center;border-bottom:1px solid #b1b4b6;">
    <h2 class="govuk-heading-m govuk-!-margin-top-0 govuk-!-margin-bottom-0">Assumptions</h2>
    <a class="govuk-button govuk-!-margin-bottom-0" href="@addUrl">Add assumption</a>
  </div>
  @if (Model.ProductAssumptions.Count == 0)
  {
    <p class="govuk-body govuk-!-margin-bottom-0">No assumptions recorded for this product.</p>
  }
  else
  {
    <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
      <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
      <table class="govuk-table govuk-!-margin-bottom-0">
        <caption class="govuk-visually-hidden">Assumptions linked to this product</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Assumption</button></th>
            <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Status</button></th>
            <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Criticality</button></th>
            <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Review date</button></th>
            <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Owner</button></th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          @foreach (var a in Model.ProductAssumptions)
          {
            var detailUrl = Url.Action("AssumptionDetail", "ModernRaid", new { id = a.Id }) ?? "#";
            <tr class="govuk-table__row">
              <td class="govuk-table__cell"><a href="@detailUrl" class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold">@a.Description</a></td>
              <td class="govuk-table__cell">@(a.StatusLabel ?? "—")</td>
              <td class="govuk-table__cell">@(a.CriticalityLabel ?? "—")</td>
              <td class="govuk-table__cell">@(a.ReviewDate?.ToString("d MMM yyyy") ?? "—")</td>
              <td class="govuk-table__cell">@(a.OwnerLabel ?? "—")</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
</div>
