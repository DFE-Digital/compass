@model FipsProductDetailViewModel
@using Compass.Models
@using Compass.Models.Modern.Work
@{
  var p = Model.Product;
  var docId = Model.ResolvedCmsDocumentId ?? p.Id.ToString();

  string StatusLabel(CommissionSubmissionStatus s) => s switch
  {
    CommissionSubmissionStatus.NotStarted => "Not started",
    CommissionSubmissionStatus.InProgress => "In progress",
    CommissionSubmissionStatus.Submitted => "Submitted",
    CommissionSubmissionStatus.Late => "Late",
    _ => s.ToString()
  };
}

<div id="d-fips-performance" class="tab-pane @(Model.ActiveDetailTab == "performance" ? "on" : "")" role="tabpanel">
  <h2 class="govuk-heading-m govuk-!-margin-top-0">Performance reporting</h2>
  <p class="govuk-body govuk-!-margin-bottom-4">Commission metric returns linked to this product in Compass (matched by CMS document id or FIPS product code).</p>

  @if (Model.PerformanceCommissionRows.Count == 0)
  {
    <p class="govuk-body govuk-!-margin-bottom-0">No commission returns found for this product yet.</p>
  }
  else
  {
    <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
      <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
      <table class="govuk-table govuk-!-margin-bottom-0">
        <caption class="govuk-visually-hidden">Performance commission returns for this product</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Commission</button></th>
            <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Period ends</button></th>
            <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Due</button></th>
            <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Status</button></th>
            <th scope="col" class="govuk-table__header"><span class="govuk-visually-hidden">Actions</span></th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          @foreach (var row in Model.PerformanceCommissionRows)
          {
            var workspaceUrl = Url.Action("Commission", "ModernPerformance", new { commissionId = row.CommissionId, tab = "all" }) ?? "#";
            var submitUrl = Url.Action("CommissionSubmit", "ModernPerformance", new { commissionId = row.CommissionId, documentId = docId, returnTab = "all" }) ?? "#";
            <tr class="govuk-table__row">
              <td class="govuk-table__cell"><strong>@row.CommissionName</strong></td>
              <td class="govuk-table__cell">@row.PeriodEnd.ToString("d MMM yyyy")</td>
              <td class="govuk-table__cell">@row.DueDate.ToString("d MMM yyyy")</td>
              <td class="govuk-table__cell"><span class="@WorkBadgeCss.CommissionSubmissionDfeFrontendBadgeClass(row.Status)">@StatusLabel(row.Status)</span></td>
              <td class="govuk-table__cell govuk-!-text-align-right">
                <a class="govuk-link govuk-link--no-visited-state govuk-!-margin-right-3" href="@workspaceUrl">Commission workspace</a>
                <a class="govuk-link govuk-link--no-visited-state" href="@submitUrl">Enter metrics</a>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
</div>
