@model Compass.ViewModels.Modern.DemandTriageHubViewModel
@using Compass.Models.DemandPipeline
@using Compass.ViewModels.Modern
@{
  ViewData["Title"] = "Triage";
  ViewBag.QueueEmptyMessage = "No demands are currently queued for triage (scored or triage pending).";
  var selectedId = Model.SelectedMeetingId;
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernDemand")">Demand</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Triage</li>
}

<div id="sc-demand-triage">
@{
  var triageLede = await Html.PartialAsync("_GovukBodyParagraph", "Triage meetings, items per meeting, and the full triage queue");
}
@await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
  Caption = "Demand pipeline",
  Title = "Triage",
  Lede = triageLede
})

 <h2 class="dfe-c-heading-m dfe-c-mb-2">Triage meetings</h2>
 <p class="govuk-body govuk-!-margin-bottom-3">Select a meeting to see demands assigned to it. Open a demand to record the outcome on the <strong>Triage</strong> tab.</p>

 <div class="dfe-f-table-wrapper dfe-c-mb-4" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
    <table class="govuk-table">
      <thead class="govuk-table__head"><tr class="govuk-table__row"><th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Meeting</button>
        </th><th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">When</button>
        </th><th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Items in queue</button>
        </th><th></th></tr></thead>
      <tbody class="govuk-table__body">
        @if (Model.Meetings.Count == 0)
        {
          <tr class="govuk-table__row">
            <td class="govuk-table__cell" colspan="4">No triage meetings have been set up yet. Central Operations can add meetings under <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("ManageTriage", "ModernOperations")">Operations → Manage triage</a>.</td>
          </tr>
        }
        else
        {
          @foreach (var row in Model.Meetings)
          {
            var m = row.Meeting;
            var isSelected = selectedId == m.Id;
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">
                <strong>@(string.IsNullOrWhiteSpace(m.Name) ? "Triage meeting" : m.Name)</strong>
                @if (!string.IsNullOrWhiteSpace(m.Location))
                {
 <span class="dfe-c-table-ref">@m.Location</span>
                }
              </td>
              <td class="govuk-table__cell">@FormatTriageWhen(m)</td>
              <td class="govuk-table__cell">@row.DemandCount</td>
              <td class="govuk-table__cell">
                @if (isSelected)
                {
                  <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("Triage", "ModernDemand")">Clear selection</a>
                }
                else
                {
                  <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("Triage", "ModernDemand", new { meetingId = m.Id })">View items</a>
                }
              </td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>

  @if (selectedId.HasValue && Model.MeetingDemands != null)
  {
    var meetingName = Model.Meetings.FirstOrDefault(r => r.Meeting.Id == selectedId.Value)?.Meeting.Name ?? "Meeting";
 <h2 class="dfe-c-heading-m dfe-c-mb-2">Demands in this meeting</h2>
 <p class="govuk-body govuk-!-margin-bottom-3">Showing queued demands assigned to <strong>@(string.IsNullOrWhiteSpace(meetingName) ? "the selected meeting" : meetingName)</strong>.</p>
    @if (Model.MeetingDemands.Count == 0)
    {
 <p class="govuk-body">No queued demands are assigned to this meeting.</p>
    }
    else
    {
 <div class="dfe-f-table-wrapper dfe-c-mb-4" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
        <table class="govuk-table">
          <thead class="govuk-table__head"><tr class="govuk-table__row"><th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Reference</button>
        </th><th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Title</button>
        </th><th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Status</button>
        </th><th></th></tr></thead>
          <tbody class="govuk-table__body">
            @foreach (var d in Model.MeetingDemands)
            {
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">@d.Reference</td>
                <td class="govuk-table__cell"><a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("RequestDetail", "ModernDemand", new { id = d.Id, tab = "triage" })">@d.Title</a></td>
                <td class="govuk-table__cell">@d.Status</td>
                <td class="govuk-table__cell"><a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("RequestDetail", "ModernDemand", new { id = d.Id, tab = "triage" })">Open triage</a></td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  }

 <h2 class="dfe-c-heading-m dfe-c-mb-2">Full triage queue</h2>
  @await Html.PartialAsync("~/Views/Modern/Demand/_DemandQueueTable.cshtml", Model.TriageQueue)
</div>

@functions {
  private static string FormatTriageWhen(DemandPipelineTriageMeeting tm)
  {
    var datePart = tm.MeetingDate?.ToString("dddd d MMMM yyyy") ?? "Date TBC";
    if (!string.IsNullOrWhiteSpace(tm.StartTime) || !string.IsNullOrWhiteSpace(tm.EndTime))
      return $"{datePart} · {(tm.StartTime ?? "").Trim()}–{(tm.EndTime ?? "").Trim()}";
    return datePart;
  }
}
