@{
  ViewData["Title"] = "Work demand report";
  var total = ViewBag.TotalDemands as int? ?? 0;
  var sub = ViewBag.Submitted as int? ?? 0;
  var sc = ViewBag.InScoring as int? ?? 0;
  var tr = ViewBag.TriagePending as int? ?? 0;
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernDemand")">Demand</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Work demand report</li>
}
<div class="dfe-c-page-title dfe-c-mb-3">
 <h1 class="dfe-c-page-title__heading">Work demand report</h1>
 <p class="dfe-c-page-title__lede">Summary of pipeline demand requests in Compass (register and detail views hold full lists).</p>
</div>
<div class="dfe-c-grid dfe-c-grid--4 dfe-c-mb-4">
 <div class="dfe-c-metric dfe-c-metric--grey"><div class="dfe-c-metric__number">@total</div><div class="dfe-c-metric__label">Total in pipeline</div></div>
 <div class="dfe-c-metric dfe-c-metric--navy"><div class="dfe-c-metric__number">@sub</div><div class="dfe-c-metric__label">Submitted</div></div>
 <div class="dfe-c-metric dfe-c-metric--teal"><div class="dfe-c-metric__number">@sc</div><div class="dfe-c-metric__label">In scoring (est.)</div></div>
 <div class="dfe-c-metric dfe-c-metric--amber"><div class="dfe-c-metric__number">@tr</div><div class="dfe-c-metric__label">Scored / triage queue (est.)</div></div>
</div>
<p class="dfe-c-mb-2"><a href="@Url.Action("Register", "ModernDemand")">Open demand register</a> · <a href="@Url.Action("Dashboard", "ModernDemand")">Demand dashboard</a></p>
