@using Compass.ViewModels.Modern
@{
  ViewData["Title"] = "Work demand report";
  var total = ViewBag.TotalDemands as int? ?? 0;
  var sub = ViewBag.Submitted as int? ?? 0;
  var sc = ViewBag.InScoring as int? ?? 0;
  var tr = ViewBag.TriagePending as int? ?? 0;
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernDemand")">Demand</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Work demand report</li>
}
@{
  var workDemandReportLede = await Html.PartialAsync("_GovukBodyParagraph", "Summary of pipeline demand requests in Compass (register and detail views hold full lists).");
}
@await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
  Title = "Work demand report",
  Lede = workDemandReportLede
})
<div class="dfe-f-card-grid dfe-c-mb-4">
 <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
 <p class="govuk-body-s dfe-f-stat-card__label">Total in pipeline</p>
 <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@total</p>
 </div>
 <div class="dfe-f-stat-card dfe-f-stat-card--tint-blue">
 <p class="govuk-body-s dfe-f-stat-card__label">Submitted</p>
 <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@sub</p>
 </div>
 <div class="dfe-f-stat-card dfe-f-stat-card--tint-teal">
 <p class="govuk-body-s dfe-f-stat-card__label">In scoring (est.)</p>
 <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@sc</p>
 </div>
 <div class="dfe-f-stat-card dfe-f-stat-card--tint-orange">
 <p class="govuk-body-s dfe-f-stat-card__label">Scored / triage queue (est.)</p>
 <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@tr</p>
 </div>
</div>
<p class="dfe-c-mb-2"><a href="@Url.Action("Register", "ModernDemand")">Open demand register</a> · <a href="@Url.Action("Dashboard", "ModernDemand")">Demand dashboard</a></p>
