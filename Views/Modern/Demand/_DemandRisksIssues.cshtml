@model Compass.Models.DemandPipeline.DemandPipelineRequest
@{
  var rows = ViewBag.DemandRiskIssues as IList<Compass.Models.DemandPipeline.DemandPipelineRiskIssue> ?? new List<Compass.Models.DemandPipeline.DemandPipelineRiskIssue>();
  var canEdit = ViewBag.DemandCanEditRisksIssues as bool? ?? false;
  var formError = TempData["RiskIssueError"] as string;
  var risks = rows.Where(r => string.Equals(r.EntryType, "Risk", StringComparison.OrdinalIgnoreCase)).ToList();
  var issues = rows.Where(r => string.Equals(r.EntryType, "Issue", StringComparison.OrdinalIgnoreCase)).ToList();
}

<div id="demand-risks-issues">
 <h2 class="govuk-heading-m">Risks and issues</h2>
 <p class="govuk-body">Record risks or issues identified for this demand at any point in the pipeline.</p>

  @if (!string.IsNullOrWhiteSpace(formError))
  {
 <div class="govuk-error-summary" data-module="govuk-error-summary" role="alert">
 <h2 class="govuk-error-summary__title">There is a problem</h2>
 <div class="govuk-error-summary__body">
 <ul class="govuk-list govuk-error-summary__list">
          <li>@formError</li>
        </ul>
      </div>
    </div>
  }

  @* ── Risks ── *@
 <h3 class="govuk-heading-s govuk-!-margin-bottom-2">Risks (@risks.Count)</h3>

  @if (canEdit)
  {
    <p class="govuk-!-margin-bottom-6">
      <a href="@Url.Action("RequestAddRiskIssueForm", "ModernDemand", new { id = Model.Id, entryType = "Risk" })" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0">Add a risk</a>
    </p>
  }

  @if (risks.Count == 0 && !canEdit)
  {
 <p class="govuk-body dfe-c-text-muted govuk-!-margin-bottom-6">No risks recorded.</p>
  }
  else if (risks.Count > 0)
  {
 <div class="dfe-c-table-wrap" style="margin-bottom:1.5rem;">
      <table>
        <thead><tr><th>Risk</th><th>Updated</th>@if (canEdit) {<th></th>}</tr></thead>
        <tbody>
          @foreach (var r in risks)
          {
            <tr>
              <td>
                <strong>@r.Title</strong>
                @if (!string.IsNullOrWhiteSpace(r.Details))
 {<span class="dfe-c-table-ref">@r.Details</span>}
              </td>
              <td style="white-space:nowrap;">@r.UpdatedAt.ToString("d MMM yyyy")</td>
              @if (canEdit)
              {
                <td style="white-space:nowrap;text-align:right;">
 <a href="@Url.Action("RequestEditRiskIssue", "ModernDemand", new { id = Model.Id, riskIssueId = r.Id })" class="govuk-link govuk-link--no-visited-state govuk-!-margin-right-3">Edit</a>
                  <form method="post" action="@Url.Action("RequestDeleteRiskIssue", "ModernDemand", new { id = Model.Id, riskIssueId = r.Id })" style="display:inline;">
                    @Html.AntiForgeryToken()
 <button type="submit" class="govuk-link" style="padding:0;border:0;background:none;cursor:pointer;font:inherit;color:#d4351c;" data-confirm="Remove this risk? This cannot be undone.">Delete</button>
                  </form>
                </td>
              }
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  @* ── Issues ── *@
 <h3 class="govuk-heading-s govuk-!-margin-bottom-2 govuk-!-margin-top-6">Issues (@issues.Count)</h3>

  @if (canEdit)
  {
    <p class="govuk-!-margin-bottom-6">
      <a href="@Url.Action("RequestAddRiskIssueForm", "ModernDemand", new { id = Model.Id, entryType = "Issue" })" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0">Add an issue</a>
    </p>
  }

  @if (issues.Count == 0 && !canEdit)
  {
 <p class="govuk-body dfe-c-text-muted govuk-!-margin-bottom-6">No issues recorded.</p>
  }
  else if (issues.Count > 0)
  {
 <div class="dfe-c-table-wrap" style="margin-bottom:1.5rem;">
      <table>
        <thead><tr><th>Issue</th><th>Updated</th>@if (canEdit) {<th></th>}</tr></thead>
        <tbody>
          @foreach (var r in issues)
          {
            <tr>
              <td>
                <strong>@r.Title</strong>
                @if (!string.IsNullOrWhiteSpace(r.Details))
 {<span class="dfe-c-table-ref">@r.Details</span>}
              </td>
              <td style="white-space:nowrap;">@r.UpdatedAt.ToString("d MMM yyyy")</td>
              @if (canEdit)
              {
                <td style="white-space:nowrap;text-align:right;">
 <a href="@Url.Action("RequestEditRiskIssue", "ModernDemand", new { id = Model.Id, riskIssueId = r.Id })" class="govuk-link govuk-link--no-visited-state govuk-!-margin-right-3">Edit</a>
                  <form method="post" action="@Url.Action("RequestDeleteRiskIssue", "ModernDemand", new { id = Model.Id, riskIssueId = r.Id })" style="display:inline;">
                    @Html.AntiForgeryToken()
 <button type="submit" class="govuk-link" style="padding:0;border:0;background:none;cursor:pointer;font:inherit;color:#d4351c;" data-confirm="Remove this issue? This cannot be undone.">Delete</button>
                  </form>
                </td>
              }
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

  @if (!canEdit && rows.Count > 0)
  {
 <div class="govuk-inset-text govuk-!-margin-bottom-0">
 <p class="govuk-body govuk-!-margin-bottom-0">This demand is closed — risks and issues are read-only.</p>
    </div>
  }
</div>
