@{
  ViewData["Title"] = ViewBag.PlaceholderTitle as string ?? "Demand";
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernDemand")">Demand</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">@ViewBag.PlaceholderTitle</li>
}
<div class="dfe-c-page-title dfe-c-mb-3">
 <h1 class="dfe-c-page-title__heading">@ViewBag.PlaceholderTitle</h1>
 <p class="dfe-c-page-title__lede">@ViewBag.PlaceholderBody</p>
</div>
<p><a href="@Url.Action("Register", "ModernDemand")">Demand register</a></p>
<p><a href="@Url.Action("Dashboard", "ModernDemand")">Back to dashboard</a></p>
