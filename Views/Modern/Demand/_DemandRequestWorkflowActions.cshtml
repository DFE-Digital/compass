@model Compass.Models.DemandPipeline.DemandPipelineRequest
@{
  var transitions = ViewBag.WorkflowTransitions as List<(string Id, string Label)> ?? new();
  var id = Model.Id;
}
@if (transitions.Count > 0)
{
 <div class="dfe-c-scard" id="demand-pipeline-actions" tabindex="-1">
 <div class="dfe-c-scard__title">Pipeline actions</div>
    <div style="display:flex;flex-direction:column;gap:0.5rem;">
      @foreach (var (tid, tlabel) in transitions)
      {
        <form method="post" asp-controller="ModernDemand" asp-action="RequestWorkflowTransition" asp-route-id="@id" style="margin:0;">
          @Html.AntiForgeryToken()
          <input type="hidden" name="transition" value="@tid" />
 <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" style="width:100%;">@tlabel</button>
        </form>
      }
    </div>
  </div>
}
