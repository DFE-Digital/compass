@model List<DemandPipelineRequest>
@{
  ViewData["Title"] = "Explore";
  ViewBag.QueueEmptyMessage = "No demand requests are currently in exploratory review.";
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernDemand")">Demand</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Explore</li>
}

<div id="sc-demand-explore">
 <div class="dfe-c-flex--between dfe-c-mb-3" style="flex-wrap:wrap;gap:1rem;">
 <div class="dfe-c-page-title" style="margin:0;">
 <div class="dfe-c-page-title__caption">Demand pipeline</div>
 <h1 class="dfe-c-page-title__heading">Exploratory review</h1>
 <p class="dfe-c-page-title__lede">Demand requests in the exploratory review stage</p>
    </div>
  </div>
  @await Html.PartialAsync("~/Views/Modern/Demand/_DemandQueueTable.cshtml", Model)
</div>
