@{
  var active = (ViewBag.ProfileSubNav as string ?? "profile").Trim();
  var onProfile = string.Equals(active, "profile", StringComparison.OrdinalIgnoreCase);
  var onPermissions = string.Equals(active, "permissions", StringComparison.OrdinalIgnoreCase);
}
<nav class="dfe-f-sub-navigation" aria-label="Account sections">
  <ul class="dfe-f-sub-navigation__list">
    <li class="dfe-f-sub-navigation__item@(onProfile ? " dfe-f-sub-navigation__item--active" : "")">
      <a class="dfe-f-sub-navigation__link govuk-link" href="@Url.Action("Index", "ModernProfile")" @if (onProfile) { <text>aria-current="page"</text> }>Profile</a>
    </li>
    <li class="dfe-f-sub-navigation__item@(onPermissions ? " dfe-f-sub-navigation__item--active" : "")">
      <a class="dfe-f-sub-navigation__link govuk-link" href="@Url.Action("Permissions", "ModernProfile")" @if (onPermissions) { <text>aria-current="page"</text> }>Permissions</a>
    </li>
  </ul>
</nav>
