@model Compass.ViewModels.Modern.ModernProfileViewModel
@using Compass.ViewModels.Modern
@using Microsoft.AspNetCore.Html
@{
  ViewData["Title"] = "Profile";
  ViewBag.ProfileSubNav = "profile";

  var profileLede = new HtmlString("<p class=\"govuk-body govuk-!-margin-bottom-0\">This is your staff profile</p>");
}

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">Profile</li>
}

<div class="modern-work-page profile-page">

@await Html.PartialAsync("~/Views/Modern/Shared/_ModernPageHeader.cshtml", new ModernPageHeaderViewModel {
  Caption = "Account",
  Title = "Profile",
  HeadingClass = "govuk-heading-l",
  Lede = profileLede
})

@await Html.PartialAsync("~/Views/Modern/Profile/_ProfileSubNav.cshtml")

<section class="profile-page__details govuk-!-margin-bottom-6" aria-labelledby="profile-details-heading">
  <h2 class="govuk-visually-hidden" id="profile-details-heading">Your details</h2>
  <dl class="govuk-summary-list govuk-summary-list--no-border">
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Email</dt>
      <dd class="govuk-summary-list__value">@(string.IsNullOrEmpty(Model.Email) ? "—" : Model.Email)</dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Name</dt>
      <dd class="govuk-summary-list__value">@(string.IsNullOrEmpty(Model.DisplayName) ? "—" : Model.DisplayName)</dd>
    </div>
  </dl>
</section>

</div>
