@{
    ViewData["Title"] = "Exports";
    var isWorkSection = string.Equals(ViewBag.MainNavSection as string, "work", StringComparison.OrdinalIgnoreCase);
    var sectionName = isWorkSection ? "Work" : "Demand";
    var sectionDashboardUrl = isWorkSection
        ? Url.Action("Dashboard", "ModernWork")
        : Url.Action("Dashboard", "Demand");
}

@section Breadcrumbs {
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@sectionDashboardUrl">@sectionName</a></li>
    <li class="dfe-c-breadcrumb__item" aria-current="page">Exports</li>
}

<div id="sc-exports-hub">
  <div class="dfe-c-page-title dfe-c-mb-3">
    <div class="dfe-c-page-title__caption">Data</div>
    <h1 class="dfe-c-page-title__heading">Exports</h1>
    <p class="dfe-c-body dfe-c-mb-0 exports-page__subtitle">Download data for reporting and offline analysis.</p>
  </div>

  <h2 class="dfe-c-heading-m dfe-c-mb-2">Compass workbooks</h2>
  <p class="dfe-c-body muted dfe-c-mb-3">Full Excel exports from Compass (multiple sheets per file).</p>
  <div class="exports-page__grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1rem;">
    <div class="dfe-c-card dfe-c-card--plain">
      <div class="dfe-c-heading-s dfe-c-mb-2">Demand export</div>
      <p class="dfe-c-body muted">All data across the demand pipeline (legacy Compass schema).</p>
      <p class="dfe-c-body-s dfe-c-mb-3" style="color:var(--govuk-secondary-text-colour,#505a5f);">File: Compass-demand-export-YYYYMMDD-HHmm.xlsx</p>
      <p class="dfe-c-mb-0"><a href="@Url.Action("DownloadExcel", "Exports")" class="dfe-c-link">Download Excel</a></p>
    </div>
    <div class="dfe-c-card dfe-c-card--plain">
      <div class="dfe-c-heading-s dfe-c-mb-2">Work export</div>
      <p class="dfe-c-body muted">All data across the work pipeline (projects, milestones, monthly updates).</p>
      <p class="dfe-c-body-s dfe-c-mb-3" style="color:var(--govuk-secondary-text-colour,#505a5f);">File: Compass-work-export-YYYYMMDD-HHmm.xlsx</p>
      <p class="dfe-c-mb-0"><a href="@Url.Action("DownloadWorkExcel", "Exports")" class="dfe-c-link">Download Excel</a></p>
    </div>
  </div>
</div>
