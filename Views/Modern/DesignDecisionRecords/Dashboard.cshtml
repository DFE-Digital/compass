@model Compass.ViewModels.Modern.Ddr.DdrDashboardViewModel
@using Compass.ViewModels.Modern
@{
  ViewData["Title"] = "DDR dashboard";
}

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">Design decision records</li>
}

@await Html.PartialAsync("~/Views/Modern/Shared/_ModernPageHeader.cshtml", new ModernPageHeaderViewModel {
  Caption = "Design decision records",
  Title = "Dashboard",
  HeadingClass = "govuk-heading-l",
})

<p class="govuk-body govuk-!-margin-bottom-4">
  Counts by category and deviation type. Select a row to open the register with that filter applied.
</p>

<div class="govuk-grid-row govuk-!-margin-top-2">
  <div class="govuk-grid-column-one-quarter">
    <div class="govuk-summary-card">
      <div class="govuk-summary-card__title-wrapper">
        <h2 class="govuk-summary-card__title">Total DDRs</h2>
      </div>
      <div class="govuk-summary-card__content">
        <p class="govuk-heading-xl govuk-!-margin-bottom-0">@Model.TotalDdrs</p>
        <p class="govuk-body-s govuk-!-margin-bottom-0" style="color:#505a5f;">Excluding deleted records</p>
      </div>
    </div>
  </div>
</div>

<div class="govuk-grid-row">
  <div class="govuk-grid-column-one-half">
    <div class="govuk-summary-card">
      <div class="govuk-summary-card__title-wrapper">
        <h2 class="govuk-summary-card__title">By category</h2>
      </div>
      <div class="govuk-summary-card__content">
        @if (Model.ByCategory.Count == 0)
        {
          <p class="govuk-body govuk-!-margin-bottom-0" style="color:#505a5f;">No data.</p>
        }
        else
        {
          <table class="govuk-table">
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header">Category</th>
                <th scope="col" class="govuk-table__header govuk-table__header--numeric">Count</th>
              </tr>
            </thead>
            <tbody class="govuk-table__body">
              @foreach (var row in Model.ByCategory)
              {
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell">
                    <a class="govuk-link govuk-link--no-visited-state" href="@row.RegisterUrl">@row.Label</a>
                  </td>
                  <td class="govuk-table__cell govuk-table__cell--numeric govuk-!-font-tabular-numbers">@row.Count</td>
                </tr>
              }
            </tbody>
          </table>
        }
      </div>
    </div>
  </div>
  <div class="govuk-grid-column-one-half">
    <div class="govuk-summary-card">
      <div class="govuk-summary-card__title-wrapper">
        <h2 class="govuk-summary-card__title">Deviations by type</h2>
      </div>
      <div class="govuk-summary-card__content">
        @if (Model.ByDeviationType.Count == 0)
        {
          <p class="govuk-body govuk-!-margin-bottom-0" style="color:#505a5f;">No deviations recorded.</p>
        }
        else
        {
          <table class="govuk-table">
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header">Deviation type</th>
                <th scope="col" class="govuk-table__header govuk-table__header--numeric">Count</th>
              </tr>
            </thead>
            <tbody class="govuk-table__body">
              @foreach (var row in Model.ByDeviationType)
              {
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell">
                    <a class="govuk-link govuk-link--no-visited-state" href="@row.RegisterUrl">@row.Label</a>
                  </td>
                  <td class="govuk-table__cell govuk-table__cell--numeric govuk-!-font-tabular-numbers">@row.Count</td>
                </tr>
              }
            </tbody>
          </table>
        }
      </div>
    </div>
  </div>
</div>

<p class="govuk-body govuk-!-margin-top-4">
  <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("Register", "ModernDesignDecisionRecords")">Go to full register</a>
</p>
