@model Compass.Models.Ddr.DesignDecisionRecord
@{
  ViewData["Title"] = "Design decision record saved";
  var action = ViewBag.DdrAction as string ?? "saved";
  var detailUrl = Url.Action("Detail", "ModernDesignDecisionRecords", new { reference = Model.Reference });
}

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Register", "ModernDesignDecisionRecords")">Design decision records</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">Saved</li>
}

<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">

    <div class="govuk-panel govuk-panel--confirmation">
      <h1 class="govuk-panel__title govuk-heading-l">Design decision record @action</h1>
      <div class="govuk-panel__body">
        Reference<br />
        <strong>@Model.Reference</strong>
      </div>
    </div>

    <h2 class="govuk-heading-m">What happens next</h2>

    @if (string.Equals(action, "submitted", StringComparison.OrdinalIgnoreCase))
    {
      <p class="govuk-body">
        Your DDR has been submitted for DesignOps review. You can keep editing the
        record while it is reviewed; comments and classifications will appear on the
        record's detail page.
      </p>
    }
    else
    {
      <p class="govuk-body">
        Your DDR has been saved as a draft. It is not yet visible to DesignOps. Open
        the record below to keep editing or to submit it when ready.
      </p>
    }

    <ul class="govuk-list">
      <li>
        <a class="govuk-link" href="@detailUrl">View this record (@Model.Reference)</a>
      </li>
      <li>
        <a class="govuk-link" href="@Url.Action("New", "ModernDesignDecisionRecords")">Create another DDR</a>
      </li>
      <li>
        <a class="govuk-link" href="@Url.Action("Register", "ModernDesignDecisionRecords")">Back to the DDR register</a>
      </li>
    </ul>

    <h2 class="govuk-heading-m govuk-!-margin-top-6">Help us improve</h2>
    <p class="govuk-body">
      DDRs are evidence and prior art for future decisions — not automatic approval. Browse
      the register to see how others have framed similar decisions, or
      <a class="govuk-link" href="@Url.Action("DesignDecisionRecords", "ModernReporting")">view DDR reporting</a>
      for portfolio-wide insight.
    </p>
  </div>
</div>
