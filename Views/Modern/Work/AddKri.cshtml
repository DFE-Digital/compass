@model Compass.Models.Modern.Work.WorkItemKri
@using Compass.Models.Modern.Work
@{
    var work = ViewBag.WorkItem as WorkItem;
    var workId = work?.Id ?? 0;
    var riRef = ViewBag.RiRef as string ?? "RI-00000";
    ViewData["Title"] = "Add KRI — " + riRef;
    var backHref = (ViewBag.IsIssue as bool? == true)
        ? Url.Action("IssueDetail", "ModernWork", new { workId, id = Model.WorkItemRiskOrIssueId })
        : Url.Action("RiskDetail", "ModernWork", new { workId, id = Model.WorkItemRiskOrIssueId });
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Detail", "ModernWork", new { id = workId })">@(work?.Title ?? "Work")</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@backHref">@riRef</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Add KRI</li>
}

<div id="sc-work-addkri">
  @await Html.PartialAsync("_WorkItemChrome", work)

 <div class="dfe-c-page-title">
 <div class="dfe-c-page-title__caption">WI-@(ViewBag.WorkIdShort ?? "") · @(work?.Title) · @riRef</div>
    <h1>Add key risk indicator</h1>
  </div>

 <div class="dfe-c-grid-row">
 <div class="dfe-c-grid-col dfe-c-grid-col--two-thirds">
 <p class="dfe-c-body muted dfe-c-mb-3">Define what you will measure to track this risk. You can record updates from the KRI detail page after saving.</p>

 <form method="post" action="@Url.Action("AddKri", "ModernWork", new { workId, riskOrIssueId = Model.WorkItemRiskOrIssueId })" class="dfe-c-mb-4">
        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid)
        {
 <div class="dfe-c-error-summary" aria-labelledby="error-summary-title" role="alert" data-module="dfe-c-error-summary">
 <h2 class="dfe-c-error-summary__title" id="error-summary-title">There is a problem</h2>
 <div class="dfe-c-error-summary__body">
 <ul class="dfe-c-list dfe-c-error-summary__list">
                @foreach (var kv in ViewData.ModelState)
                {
                  @if (kv.Value?.Errors?.Count > 0)
                  {
                    var fieldId = string.IsNullOrEmpty(kv.Key) ? "Name" : kv.Key;
                    @foreach (var err in kv.Value.Errors)
                    {
                      <li><a href="#@fieldId">@err.ErrorMessage</a></li>
                    }
                  }
                }
              </ul>
            </div>
          </div>
        }

 <div class="dfe-c-form__group @(ViewData.ModelState["Name"]?.Errors?.Any() == true ? "dfe-c-form__group--error" : "")">
 <label class="dfe-c-form__label" for="Name">KRI name</label>
 <span class="dfe-c-form__hint">Short title, for example pipeline uptime percentage.</span>
          @if (ViewData.ModelState["Name"]?.Errors?.Any() == true)
          {
 <span class="dfe-c-form__error">@ViewData.ModelState["Name"]?.Errors?.FirstOrDefault()?.ErrorMessage</span>
          }
 <input class="dfe-c-width-full" id="Name" name="Name" type="text" value="@Model.Name" required autocomplete="off" />
        </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="WhatIsMeasured">What is measured</label>
 <span class="dfe-c-form__hint">Definition of the indicator and how it is sourced.</span>
 <textarea class="dfe-c-width-full" id="WhatIsMeasured" name="WhatIsMeasured" rows="3">@Model.WhatIsMeasured</textarea>
        </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="ThresholdDescription">Threshold / target</label>
 <span class="dfe-c-form__hint">Green, amber and red bands or a single target.</span>
 <textarea class="dfe-c-width-full" id="ThresholdDescription" name="ThresholdDescription" rows="2">@Model.ThresholdDescription</textarea>
        </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="ThresholdDate">Threshold date</label>
 <input class="dfe-c-width-full" id="ThresholdDate" name="ThresholdDate" type="date" value="@(Model.ThresholdDate?.ToString("yyyy-MM-dd"))" />
        </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="CurrentValue">Current value</label>
 <span class="dfe-c-form__hint">Latest measured value, if known.</span>
 <input class="dfe-c-width-full" id="CurrentValue" name="CurrentValue" type="text" value="@Model.CurrentValue" autocomplete="off" />
        </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="Status">Status</label>
 <select class="dfe-c-width-full" id="Status" name="Status">
            <option value="OnTrack" selected="@(string.Equals(Model.Status, "OnTrack", StringComparison.OrdinalIgnoreCase))">On track</option>
            <option value="AtRisk" selected="@(string.Equals(Model.Status, "AtRisk", StringComparison.OrdinalIgnoreCase))">At risk</option>
            <option value="Breached" selected="@(string.Equals(Model.Status, "Breached", StringComparison.OrdinalIgnoreCase))">Breached</option>
          </select>
        </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="MeasurementFrequency">Measurement frequency</label>
 <span class="dfe-c-form__hint">For example weekly or monthly.</span>
 <input class="dfe-c-width-full" id="MeasurementFrequency" name="MeasurementFrequency" type="text" value="@Model.MeasurementFrequency" autocomplete="off" />
        </div>

 <div class="dfe-c-form__group user-picker-wrapper user-picker-wrapper--full-width">
          @await Html.PartialAsync("_UserPicker", new UserPickerViewModel
          {
            FieldName = "ResponsibleUserId",
            Label = "Responsible person",
            Hint = "Search by name or email.",
            DefaultSummaryText = "No one selected.",
            DefaultUserId = Model?.ResponsibleUserId,
            DefaultName = ViewBag.ResponsibleUserName as string,
            DefaultEmail = ViewBag.ResponsibleUserEmail as string,
            InputIdSuffix = "kri-resp"
          })
        </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="BreachAction">Action if breached</label>
 <textarea class="dfe-c-width-full" id="BreachAction" name="BreachAction" rows="3">@Model.BreachAction</textarea>
        </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="NextReviewDate">Next review date</label>
 <input class="dfe-c-width-full" id="NextReviewDate" name="NextReviewDate" type="date" value="@(Model.NextReviewDate?.ToString("yyyy-MM-dd"))" />
        </div>

 <button type="submit" class="govuk-button">Add KRI</button>
 <a href="@backHref" class="govuk-button govuk-button--secondary dfe-c-ms-2">Cancel</a>
      </form>
    </div>
  </div>
</div>
