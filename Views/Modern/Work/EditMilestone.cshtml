@model Compass.Models.Milestone
@{
    var work = ViewBag.WorkItem as Compass.Models.Modern.Work.WorkItem;
    ViewData["Title"] = "Edit milestone";
}
@section Breadcrumbs {
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="/">Home</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Detail", "ModernWork", new { id = Model.ProjectId })">@(work?.Title ?? "Work")</a></li>
    <li class="dfe-c-breadcrumb__item" aria-current="page">Edit milestone</li>
}

<div id="sc-work-editmilestone">
  @await Html.PartialAsync("_WorkItemChrome", work)

  <div class="dfe-c-page-title">
    <div class="dfe-c-page-title__caption">WI-@(ViewBag.WorkIdShort ?? (Model.ProjectId.HasValue ? Model.ProjectId.Value.ToString("X8") : "")) · @(work?.Title)</div>
    <h1>Edit milestone</h1>
  </div>

  <div class="dfe-c-grid-row">
    <div class="dfe-c-grid-col dfe-c-grid-col--two-thirds">
  <form asp-controller="Project" asp-action="UpdateMilestone" asp-route-projectId="@Model.ProjectId" asp-route-milestoneId="@Model.Id" method="post" class="dfe-c-mb-4">
    @Html.AntiForgeryToken()

    <div class="dfe-c-form__group @(ViewData.ModelState["name"]?.Errors?.Any() == true ? "dfe-c-form__group--error" : "")">
      <label class="dfe-c-form__label" for="name">Title *</label>
      @if (ViewData.ModelState["name"]?.Errors?.Any() == true)
      {
        <span class="dfe-c-form__error">@ViewData.ModelState["name"]?.Errors?.FirstOrDefault()?.ErrorMessage</span>
      }
      <input class="dfe-c-width-full" id="name" name="name" type="text" value="@Model.Name" maxlength="200" />
    </div>

    <div class="dfe-c-form__group">
      <label class="dfe-c-form__label" for="Description">Description</label>
      <textarea class="dfe-c-width-full" id="Description" name="Description" rows="3">@Model.Description</textarea>
    </div>

    <div class="dfe-c-form__group">
      <label class="dfe-c-form__label" for="dueDate">Due date *</label>
      <input class="dfe-c-width-full" id="dueDate" name="dueDate" type="date" value="@Model.DueDate.ToString("yyyy-MM-dd")" required />
    </div>

    <div class="dfe-c-form__group">
      <label class="dfe-c-form__label" for="status">Status</label>
      <!select class="dfe-c-width-full" id="status" name="status">
        @{
          var statusOpts = new (string Value, string Label)[]
          {
            ("not_started", "Not started"),
            ("in_progress", "In progress"),
            ("on_track", "On track"),
            ("at_risk", "At risk"),
            ("delayed", "Delayed"),
            ("complete", "Complete"),
            ("cancelled", "Cancelled")
          };
        }
        @foreach (var o in statusOpts)
        {
          if (string.Equals(Model.Status, o.Value, StringComparison.OrdinalIgnoreCase))
          {
            <option value="@o.Value" selected>@o.Label</option>
          }
          else
          {
            <option value="@o.Value">@o.Label</option>
          }
        }
      </select>
    </div>

    <button type="submit" class="dfe-c-button dfe-c-button--primary">Save changes</button>
    <a href="@Url.Action("Detail", "ModernWork", new { id = Model.ProjectId })#wd-milestones" class="dfe-c-button dfe-c-button--secondary dfe-c-ms-2">Cancel</a>
  </form>

  <div class="dfe-c-mt-3 govuk-!-padding-top-6 dfe-c-body" style="border-top:1px solid #b1b4b6;">
    <form method="post" action="@Url.Action("DeleteMilestone", "Project", new { projectId = Model.ProjectId, milestoneId = Model.Id })" class="dfe-c-mt-3" data-confirm-title="Delete milestone" data-confirm-message="Delete this milestone? Any risks or issues linked to it will be unlinked. This cannot be undone.">
      @Html.AntiForgeryToken()
      <button type="submit" class="dfe-c-button dfe-c-button--warning">Delete milestone</button>
    </form>
  </div>
    </div>
  </div>
</div>
