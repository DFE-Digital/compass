 <a href="@(Url.Action("Detail", "ModernWork", new { id = Model.Id, milestonestab = "complete" }))#wd-milestones" class="tab @(milestoneTab =="complete" ? "on" : "")" role="tab" aria-selected="@(milestoneTab == "complete")" aria-controls="d-milestones-complete" id="tab-milestones-complete">Complete (@completedItems.Count)</a>
