  <!-- OVERVIEW TAB -->
 <div id="wd-overview" class="tab-pane on">
 @{ var canEdit = ViewBag.CanEditWorkItem as bool? ?? false; }
 <div class="modern-work-detail-overview-stack">
 <div class="govuk-summary-card">
 <div class="govuk-summary-card__title-wrapper">
 <h2 class="govuk-summary-card__title">Overview</h2>
      @if (canEdit)
      {
 <ul class="govuk-summary-card__actions">
 <li class="govuk-summary-card__action">
 <a href="@workEditUrl" class="govuk-link govuk-link--no-visited-state">Edit</a>
 </li>
 </ul>
      }
        </div>
 <div class="govuk-summary-card__content">
 <dl class="govuk-summary-list govuk-!-margin-bottom-0">
 <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
 <dt class="govuk-summary-list__key">Title</dt>
 <dd class="govuk-summary-list__value">@Model.Title</dd>
          </div>
 <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
 <dt class="govuk-summary-list__key">Problem statement</dt>
 <dd class="govuk-summary-list__value">
              @if (string.IsNullOrWhiteSpace(Model.ProblemStatement))
              {
                <text>—</text>
              }
              else
              {
                var psW = Model.ProblemStatement.Trim();
                var psEnd = WorkOverviewPreviewEnd(psW);
                var psMore = psW.Length > psEnd;
                <span class="govuk-body">@psW.Substring(0, psEnd)</span>
                @if (psMore)
                {
 <details class="govuk-details govuk-!-margin-top-2 govuk-!-margin-bottom-0" data-module="govuk-details">
 <summary class="govuk-details__summary">
 <span class="govuk-details__summary-text">View more</span>
                  </summary>
 <div class="govuk-details__text govuk-!-margin-top-2 govuk-!-margin-bottom-0">@psW.Substring(psEnd).TrimStart()</div>
                  </details>
                }
              }
            </dd>
          </div>
 <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
 <dt class="govuk-summary-list__key">Aim</dt>
 <dd class="govuk-summary-list__value">
              @if (string.IsNullOrWhiteSpace(Model.Aim))
              {
                <text>—</text>
              }
              else
              {
                var aimW = Model.Aim.Trim();
                var aimEnd = WorkOverviewPreviewEnd(aimW);
                var aimMore = aimW.Length > aimEnd;
                <span class="govuk-body">@aimW.Substring(0, aimEnd)</span>
                @if (aimMore)
                {
 <details class="govuk-details govuk-!-margin-top-2 govuk-!-margin-bottom-0" data-module="govuk-details">
 <summary class="govuk-details__summary">
 <span class="govuk-details__summary-text">View more</span>
                  </summary>
 <div class="govuk-details__text govuk-!-margin-top-2 govuk-!-margin-bottom-0">@aimW.Substring(aimEnd).TrimStart()</div>
                  </details>
                }
              }
            </dd>
          </div>
 <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
 <dt class="govuk-summary-list__key">Thematic tags</dt>
 <dd class="govuk-summary-list__value">
              @if (workTags.Count == 0)
              {
                <text>—</text>
              }
              else
              {
 <ul class="govuk-list govuk-!-margin-bottom-0">
                  @foreach (var tg in workTags)
                  {
 <li>@tg.Name</li>
                  }
                </ul>
              }
            </dd>
          </div>
 <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
 <dt class="govuk-summary-list__key">Business area</dt>
 <dd class="govuk-summary-list__value">@portfolioName</dd>
          </div>
 <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
 <dt class="govuk-summary-list__key">Priority</dt>
 <dd class="govuk-summary-list__value">
              @if (!string.IsNullOrWhiteSpace(priorityName) && priorityName != "—")
              {
 <span class="@WorkBadgeCss.PriorityDfeFrontendBadgeClass(priorityName) dfe-f-badge--small">@priorityName.ToUpperInvariant()</span>
              }
              else
              {
                <text>—</text>
              }
            </dd>
          </div>
 <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
 <dt class="govuk-summary-list__key">Flagship project</dt>
 <dd class="govuk-summary-list__value">@(Model.FlagshipProject ? "Yes" : "No")</dd>
          </div>
 <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
 <dt class="govuk-summary-list__key">Subject to spend control</dt>
 <dd class="govuk-summary-list__value">@(Model.SubjectToSpendControl ? "Yes" : "No")</dd>
          </div>
 <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
 <dt class="govuk-summary-list__key">Risk appetite</dt>
 <dd class="govuk-summary-list__value">
              @if (Model.RiskAppetiteId.HasValue && !string.IsNullOrWhiteSpace(riskAppetiteName) && riskAppetiteName != "—")
              {
 <span class="@WorkBadgeCss.RiskAppetiteDfeFrontendBadgeClass(riskAppetiteName, riskAppetiteOptions, Model.RiskAppetiteId)">@riskAppetiteName</span>
              }
              else
              {
                <text>—</text>
              }
            </dd>
          </div>
 <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
 <dt class="govuk-summary-list__key">Multi-dept cooperation</dt>
 <dd class="govuk-summary-list__value">@(Model.GovernmentDepartments?.Any() == true ? string.Join(", ", Model.GovernmentDepartments.Select(g => g.GovernmentDepartment?.Title).Where(n => n != null)) : "—")</dd>
          </div>
 <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
 <dt class="govuk-summary-list__key">Start date</dt>
 <dd class="govuk-summary-list__value">@DateWithRelativeDays(Model.StartDate)</dd>
          </div>
 <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
 <dt class="govuk-summary-list__key">Target end date</dt>
 <dd class="govuk-summary-list__value">@TargetEndDateWithPastDue(Model.TargetEndDate)</dd>
          </div>
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Current RAG</dt>
 <dd class="govuk-summary-list__value">@if (!string.IsNullOrEmpty(currentRagName)) { <span class="@WorkBadgeCss.RagDfeFrontendBadgeClass(currentRagCssClass, currentRagName)">@currentRagName.ToUpperInvariant()</span> } else { <text>—</text> }</dd>
 <dd class="govuk-summary-list__actions">
 <a class="govuk-link govuk-link--no-visited-state" href="@(Url.Action("Detail", "ModernWork", new { id = Model.Id }))#wd-updates">Updated via monthly updates</a>
            </dd>
          </div>
        </dl>
        </div>
 </div>

 @if (hasStrategicAlignment || canEdit)
 {
 <div class="govuk-summary-card govuk-!-margin-top-6">
 <div class="govuk-summary-card__title-wrapper">
 <h2 class="govuk-summary-card__title">Strategic alignment</h2>
      @if (canEdit)
      {
 <ul class="govuk-summary-card__actions">
 <li class="govuk-summary-card__action">
 <a href="@workEditStrategicUrl" class="govuk-link govuk-link--no-visited-state">Edit</a>
 </li>
 </ul>
      }
    </div>
 <div class="govuk-summary-card__content">
 <dl class="govuk-summary-list govuk-!-margin-bottom-0">
 <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
 <dt class="govuk-summary-list__key">Priority outcomes</dt>
 <dd class="govuk-summary-list__value">
          @if (priorityOutcomeNames.Count == 0)
          {
            <text>—</text>
          }
          else
          {
 <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-0">
              @foreach (var name in priorityOutcomeNames)
              {
                <li>@name</li>
              }
            </ul>
          }
        </dd>
 </div>
 <div class="govuk-summary-list__row govuk-summary-list__row--no-actions">
 <dt class="govuk-summary-list__key">Mission pillars</dt>
 <dd class="govuk-summary-list__value">
          @if (missionPillarNames.Count == 0)
          {
            <text>—</text>
          }
          else
          {
 <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-0">
              @foreach (var name in missionPillarNames)
              {
                <li>@name</li>
              }
            </ul>
          }
        </dd>
 </div>
      </dl>
    </div>
 </div>
 }

 @await Html.PartialAsync("_WorkItemKeyContactsSummaryCard", Model)

        @if (linkedDemand != null || linkedBusinessCase != null)
        {
 <div class="govuk-summary-card govuk-!-margin-top-6">
 <div class="govuk-summary-card__title-wrapper">
 <h2 class="govuk-summary-card__title">Dependencies</h2>
        </div>
 <div class="govuk-summary-card__content">
 @if (linkedDemand != null) { <dl class="dfe-c-kv"><dt>Demand</dt><dd><a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("Detail", "Demand", new { id = linkedDemand.Id })">@linkedDemand.Reference →</a></dd></dl> }
 @if (linkedBusinessCase != null) { <dl class="dfe-c-kv"><dt>Business case</dt><dd><a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("Detail", "Horizon", new { id = linkedBusinessCase.Id })">@linkedBusinessCase.BusinessCaseId →</a></dd></dl> }
 <p class="govuk-body govuk-!-margin-bottom-0"><a href="@(Url.Action("Detail", "ModernWork", new { id = Model.Id }))#wd-dependencies" class="govuk-link govuk-link--no-visited-state">Dependencies</a> and <a href="@(Url.Action("Detail", "ModernWork", new { id = Model.Id }))#wd-assumptions" class="govuk-link govuk-link--no-visited-state">assumptions</a> are managed on this work item.</p>
        </div>
 </div>
        }
 </div>
 </div>
  <!-- MILESTONES TAB -->
 <div id="wd-milestones" class="tab-pane">
    @{
      var canEditMilestones = ViewBag.CanEditWorkItem as bool? ?? false;
    }
    @if (Model.Milestones != null && Model.Milestones.Any())
    {
      var nowUtc = DateTime.UtcNow.Date;
      var allMilestoneItems = Model.Milestones
        .Where(m => !m.IsDeleted)
        .Select(m =>
        {
            var statusLabel = string.IsNullOrEmpty(m.Status) ? "—" : m.Status.Replace("_", " ", StringComparison.OrdinalIgnoreCase);
            var isComplete = string.Equals(m.Status, "complete", StringComparison.OrdinalIgnoreCase);
            var isCancelled = string.Equals(m.Status, "cancelled", StringComparison.OrdinalIgnoreCase);
            var isCompleted = isComplete || isCancelled;
            var isOverdue = !isCompleted && m.DueDate.Date < nowUtc;
            return new { m, progressName = statusLabel, isCompleted, isOverdue };
        })
        .ToList();
      var inProgressItems = allMilestoneItems.Where(x => !x.isCompleted).OrderBy(x => x.isOverdue ? 0 : 1).ThenBy(x => x.m.DueDate).ThenBy(x => x.m.ActualDate ?? DateTime.MinValue).ToList();
      var completedItems = allMilestoneItems.Where(x => x.isCompleted).OrderByDescending(x => x.m.ActualDate ?? x.m.DueDate).ToList();
      var completePanelId = $"wd-milestones-complete-panel-{Model.Id}";
      var completeToggleId = $"wd-milestones-complete-toggle-{Model.Id}";
 <div class="govuk-summary-card govuk-!-margin-top-0 wd-milestones-summary-card">
 <div class="govuk-summary-card__title-wrapper">
 <h2 class="govuk-summary-card__title">Milestones</h2>
      @if (canEditMilestones)
      {
 <ul class="govuk-summary-card__actions">
 <li class="govuk-summary-card__action">
 <a href="@Url.Content($"~/modern/work/{Model.Id}/milestone/add")" class="govuk-link govuk-link--no-visited-state">Add milestone</a>
 </li>
 </ul>
      }
    </div>
 <div class="govuk-summary-card__content">
 <h3 class="govuk-heading-s govuk-!-margin-top-0 govuk-!-margin-bottom-3">In progress</h3>
      @if (inProgressItems.Any())
      {
 <div class="dfe-f-table-wrapper govuk-!-margin-bottom-0" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
 <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed work-milestones-table govuk-!-margin-bottom-0">
 <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">In progress milestones</caption>
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th scope="col" class="govuk-table__header">Milestone</th>
                  <th scope="col" class="govuk-table__header">Status</th>
                  <th scope="col" class="govuk-table__header">Due date</th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                @foreach (var item in inProgressItems)
                {
                  var m = item.m;
                  var progressName = item.progressName;
                  var badgeClass = WorkBadgeCss.MilestoneProgressDfeFrontendBadgeClass(progressName);
                  var milestoneEditHref = Url.Content($"~/modern/work/{Model.Id}/milestone/{m.Id}/edit");
 <tr class="@(item.isOverdue ? "govuk-table__row work-milestones-table__row--overdue" : "govuk-table__row")">
                    <td class="govuk-table__cell">
 <a href="@milestoneEditHref" class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold">@m.Name</a>
                    </td>
 <td class="govuk-table__cell"><span class="@badgeClass dfe-f-badge--small" style="white-space:nowrap;">@progressName</span></td>
                    <td class="govuk-table__cell govuk-!-font-weight-regular" style="white-space:nowrap;">@if (item.isOverdue) {<span class="work-milestones-table__due--overdue">@m.DueDate.ToString("d MMM yyyy")</span>} else {@m.DueDate.ToString("d MMM yyyy")}</td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        }
        else
        {
 <p class="govuk-body govuk-!-margin-bottom-0">No in-progress milestones.</p>
        }
    </div>
 </div>
      @if (completedItems.Any())
      {
 <div class="dfe-f-toggle govuk-!-margin-top-6" data-module="dfe-f-toggle">
 <div class="dfe-f-toggle__title-wrapper">
 <h3 class="dfe-f-toggle__heading govuk-!-margin-bottom-0">
 <button type="button" class="dfe-f-toggle__button" aria-expanded="false" aria-controls="@completePanelId" id="@completeToggleId">
 <span class="dfe-f-toggle__icon" aria-hidden="true"></span>
 <span class="dfe-f-toggle__title">Complete (@completedItems.Count)</span>
            </button>
          </h3>
        </div>
 <div id="@completePanelId" class="dfe-f-toggle__content" hidden>
 <div class="dfe-f-toggle__body">
 <div class="dfe-f-table-wrapper govuk-!-margin-bottom-0" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
 <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed work-milestones-table govuk-!-margin-bottom-0">
 <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">Completed milestones</caption>
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th scope="col" class="govuk-table__header">Milestone</th>
                  <th scope="col" class="govuk-table__header">Status</th>
                  <th scope="col" class="govuk-table__header">Due date</th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                @foreach (var item in completedItems)
                {
                  var m = item.m;
                  var progressName = item.progressName;
                  var badgeClass = WorkBadgeCss.MilestoneProgressDfeFrontendBadgeClass(progressName);
                  var milestoneEditHref = Url.Content($"~/modern/work/{Model.Id}/milestone/{m.Id}/edit");
                  <tr class="govuk-table__row">
                    <td class="govuk-table__cell">
 <a href="@milestoneEditHref" class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold">@m.Name</a>
                    </td>
 <td class="govuk-table__cell"><span class="@badgeClass dfe-f-badge--small" style="white-space:nowrap;">@progressName</span></td>
                    <td class="govuk-table__cell govuk-!-font-weight-regular" style="white-space:nowrap;">@m.DueDate.ToString("d MMM yyyy")</td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        </div>
        </div>
      </div>
      }
    }
    else
    {
 <div class="govuk-summary-card govuk-!-margin-top-0 wd-milestones-summary-card">
 <div class="govuk-summary-card__title-wrapper">
 <h2 class="govuk-summary-card__title">Milestones</h2>
      @if (canEditMilestones)
      {
 <ul class="govuk-summary-card__actions">
 <li class="govuk-summary-card__action">
 <a href="@Url.Content($"~/modern/work/{Model.Id}/milestone/add")" class="govuk-link govuk-link--no-visited-state">Add milestone</a>
 </li>
 </ul>
      }
    </div>
 <div class="govuk-summary-card__content">
 <p class="govuk-body govuk-!-margin-bottom-0">No milestones yet.</p>
      </div>
 </div>
    }
  </div>

  <!-- UPDATES TAB -->
  @{
    var updatesList = Model.MonthlyUpdates?.OrderByDescending(m => m.ReportMonth).ToList() ?? new List<MonthlyUpdate>();
    var periodDueByKey = ViewBag.ReportingPeriodDueByKey as Dictionary<string, (DateTime DueDate, string Label)> ?? new Dictionary<string, (DateTime, string)>();
