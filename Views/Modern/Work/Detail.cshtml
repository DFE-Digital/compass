          <tbody class="govuk-table__body">
            @foreach (var period in reportingPeriodsList)
            {
              var parts = period.PeriodKey.Split('-');
              var periodYear = parts.Length >= 1 && int.TryParse(parts[0], out var y) ? y : 0;
              var periodMonth = parts.Length >= 2 && int.TryParse(parts[1], out var m) ? m : 0;
              var submittedUpdate = periodYear > 0 && periodMonth > 0 ? updatesList.FirstOrDefault(u => u.ReportMonth.Year == periodYear && u.ReportMonth.Month == periodMonth) : null;
              var isDraft = submittedUpdate != null && !submittedUpdate.SubmittedAt.HasValue;
              var isSubmitted = submittedUpdate != null && submittedUpdate.SubmittedAt.HasValue;
              var isUpcoming = submittedUpdate == null;
              var canSubmit = isUpcoming && string.Equals(period.UpdateStatus, "Due", System.StringComparison.OrdinalIgnoreCase) && period.WindowAllowsEditing;
              var canContinueDraft = isDraft && period.WindowAllowsEditing;
              var effectiveRagId = submittedUpdate != null ? (submittedUpdate.RagStatusId ?? (fallbackRagByUpdateId.TryGetValue(submittedUpdate.Id, out var fid) ? fid : (int?)null)) : null;
              var uRagName = MonthlyUpdateRagLabel(submittedUpdate, effectiveRagId, ragStatusesDict);
              var uRagCss = submittedUpdate?.RagCssClass
                  ?? (effectiveRagId is > 0 && ragCssByStatusId.TryGetValue(effectiveRagId.Value, out var css) ? css : null);
              var submittedByDisplay = submittedUpdate != null && submittedUpdate.SubmittedByUserId.HasValue && monthlyUpdateSubmittedByNames.TryGetValue(submittedUpdate.SubmittedByUserId.Value, out var sb) ? sb : (submittedUpdate?.SubmittedBy ?? "—");
              var uRagBg = effectiveRagId.HasValue && effectiveRagId.Value != 0 && ragBgByStatusId.TryGetValue(effectiveRagId.Value, out var ubg) ? ubg : null;
              var uRagText = effectiveRagId.HasValue && effectiveRagId.Value != 0 && ragTextByStatusId.TryGetValue(effectiveRagId.Value, out var utx) ? utx : null;
              <tr class="govuk-table__row" style="cursor:default;">
 <td class="govuk-table__cell">@if (isSubmitted) { <a href="@Url.Action("ViewMonthlyUpdate", "ModernWork", new { id = Model.Id, updateId = submittedUpdate!.Id })" class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold">@period.PeriodLabel</a> } else if (canContinueDraft) { <a href="@Url.Action("MonthlyReport", "ModernWork", new { id = Model.Id, year = submittedUpdate!.ReportMonth.Year, month = submittedUpdate.ReportMonth.Month })" class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold">@period.PeriodLabel</a> } else if (canSubmit) { <a href="@Url.Action("AddMonthlyUpdate", "ModernWork", new { id = Model.Id, periodKey = period.PeriodKey })" class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold">@period.PeriodLabel</a> } else { @period.PeriodLabel }</td>
                <td class="govuk-table__cell">@(period.SubmissionCloses?.ToString("d MMM yyyy") ?? period.DueDate.ToString("d MMM yyyy"))</td>
 <td class="govuk-table__cell">@if (isSubmitted) { <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--green">Submitted</span> } else if (isDraft && canContinueDraft) { <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--blue">Continue return</span> } else if (isDraft && !canContinueDraft) { <span class="govuk-hint govuk-!-margin-bottom-0">Outside submission window</span> } else if (canSubmit) { <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--red">Not submitted</span> } else { <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--grey">@period.UpdateStatus</span> }</td>
 <td class="govuk-table__cell">@if (isSubmitted) { <span class="@WorkBadgeCss.RagDfeFrontendBadgeClass(uRagCss, uRagName == "—" ? null : uRagName) dfe-f-badge--small">@(string.IsNullOrEmpty(uRagName) || uRagName == "—" ? "—" : uRagName.ToUpperInvariant())</span> } else if (isDraft && !string.IsNullOrWhiteSpace(uRagName) && uRagName != "—") { <span class="@WorkBadgeCss.RagDfeFrontendBadgeClass(uRagCss, uRagName) dfe-f-badge--small">@uRagName.ToUpperInvariant()</span> } else { <text>—</text> }</td>
                <td class="govuk-table__cell">@(submittedUpdate?.SubmittedAt?.ToString("d MMM yyyy") ?? "—")</td>
                <td class="govuk-table__cell">@submittedByDisplay</td>
              </tr>
            }
          </tbody>
        </table>
 </div>
      </div>
    }
    else if (updatesList.Any())
