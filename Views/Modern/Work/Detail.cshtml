                  var milestoneEditHref = Url.Content($"~/modern/work/{Model.Id}/milestone/{m.Id}/edit");
                  <tr>
                    <td>
 <a href="@milestoneEditHref" class="dfe-c-link dfe-c-fw-bold">@m.Name</a>
                    </td>
 <td><span class="@badgeClass" style="white-space:nowrap;">@progressName</span></td>
                    <td style="white-space:nowrap;">@(m.BaselineDueDate?.ToString("d MMM yyyy") ?? "—")</td>
                    <td style="white-space:nowrap;">@m.DueDate.ToString("d MMM yyyy")</td>
