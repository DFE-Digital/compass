@model Compass.Models.Modern.Work.WorkItem
@using Compass.Models.Modern.Work
@using System.Linq
@{
    ViewData["Title"] = Model.Title;
    var portfolioName = ViewBag.PortfolioName as string ?? "—";
    var priorityName = ViewBag.PriorityName as string ?? "—";
    var deliveryPhaseName = ViewBag.DeliveryPhaseName as string ?? "—";
    var activityTypeName = ViewBag.ActivityTypeName as string ?? "—";
    var riskAppetiteName = ViewBag.RiskAppetiteName as string ?? "—";
    var riskAppetiteOptions = ViewBag.RiskAppetiteOptions as List<LookupOption> ?? new List<LookupOption>();
    var linkedDemand = ViewBag.LinkedDemand as DemandRequest;
    var linkedBusinessCase = ViewBag.LinkedBusinessCase as BusinessCase;
    var latestRag = ViewBag.LatestRag as WorkItemRagHistory ?? Model.RagHistory?.OrderByDescending(r => r.UpdatedAt).FirstOrDefault();
    var monthlyReportDue = ViewBag.MonthlyReportDue as bool? ?? false;
    var currentPeriodLabel = ViewBag.CurrentPeriodLabel as string;
    var currentPeriodDueDate = ViewBag.CurrentPeriodDueDate as DateTime?;
    var monthlyReportDaysRemaining = ViewBag.MonthlyReportDaysRemaining as int?;
    var lastMonthlyUpdateMonth = ViewBag.LastMonthlyUpdateMonth as string;
    var lastMonthlyUpdateBy = ViewBag.LastMonthlyUpdateBy as string;
    var ragUpdatedByNames = ViewBag.RagUpdatedByNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var ragStatusesDict = ViewBag.RagStatusesDict as Dictionary<int, string> ?? new Dictionary<int, string>();
    var currentRagName = ViewBag.CurrentRagName as string ?? latestRag?.RagStatus?.Name ?? (Model.RagStatusId.HasValue && ragStatusesDict.TryGetValue(Model.RagStatusId.Value, out var rn) ? rn : null);
    var currentRagCssClass = ViewBag.CurrentRagCssClass as string;
    var milestoneProgressNames = ViewBag.MilestoneProgressNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var workIdShort = Model.Id.ToString("D8");
    var priorityOutcomeNames = Model.PriorityOutcomes?
        .Select(po => po.PriorityOutcome?.Name)
        .Where(n => !string.IsNullOrWhiteSpace(n))
        .Cast<string>()
        .ToList() ?? new List<string>();
    var missionPillarNames = Model.MissionPillars?
        .Select(mp => mp.MissionPillar?.Name)
        .Where(n => !string.IsNullOrWhiteSpace(n))
        .Cast<string>()
        .ToList() ?? new List<string>();
    var workTags = Model.Tags ?? new List<WorkItemTagRef>();
    var hasStrategicAlignment = priorityOutcomeNames.Count > 0 || missionPillarNames.Count > 0;
    var today = DateTime.UtcNow.Date;
    int WorkOverviewPreviewEnd(string t)
    {
        if (string.IsNullOrWhiteSpace(t)) return 0;
        var s = t.Trim();
        var idx = s.IndexOf('.');
        var endAtDot = idx >= 0 ? idx + 1 : int.MaxValue;
        var cap = Math.Min(s.Length, 200);
        return Math.Min(cap, endAtDot);
    }
    string DateWithRelativeDays(DateTime? d) {
        if (!d.HasValue) return "—";
        var date = d.Value.Date;
        var days = (date - today).Days;
        var part = days > 0 ? " (in " + days + " day" + (days == 1 ? "" : "s") + ")" : days < 0 ? " (" + (-days) + " day" + (-days == 1 ? "" : "s") + " ago)" : " (today)";
        return date.ToString("d MMMM yyyy") + part;
    }
    string TargetEndDateWithPastDue(DateTime? d) {
        if (!d.HasValue) return "—";
        var date = d.Value.Date;
        var days = (date - today).Days;
        var part = days > 0 ? " (in " + days + " day" + (days == 1 ? "" : "s") + ")" : days < 0 ? " (" + (-days) + " day" + (-days == 1 ? "" : "s") + " ago)" : " (today)";
        var pastDue = (Model.Status == "Active" || Model.Status == "Paused") && date < today;
        return date.ToString("d MMMM yyyy") + part + (pastDue ? " — Past due date" : "");
    }
    var workEditUrl = $"/modern/work/{Model.Id}/edit";
    var workEditTagsUrl = $"/modern/work/{Model.Id}/tags/edit";
    var workEditStrategicUrl = $"/modern/work/{Model.Id}/strategic-alignment/edit";
    var workEditMultiDeptUrl = $"/modern/work/{Model.Id}/multi-dept/edit";
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="/">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("AllWork", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">@Model.Title</li>
}


  @await Html.PartialAsync("_WorkItemChrome", Model)

<div id="sc-work-detail" class="govuk-grid-row modern-work-detail-layout govuk-!-margin-top-4">
  <div class="govuk-grid-column-one-quarter-from-desktop modern-work-detail-layout__nav">
