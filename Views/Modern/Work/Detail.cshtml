                    <td style="white-space:nowrap;">@(item.isOverdue ? Html.Raw($"<strong class=\"work-milestones-table__due--overdue\">{m.DueDate.ToString("d MMM yyyy")}</strong>") : Html.Raw(m.DueDate.ToString("d MMM yyyy")))</td>
                    <td style="white-space:nowrap;">@(m.ActualDate?.ToString("d MMM yyyy") ?? "—")</td>
                  </tr>
