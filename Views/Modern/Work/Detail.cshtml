  </div>

  <!-- RISKS & ISSUES TAB -->
  @{
    var riskOrIssues = Model.RiskOrIssues?.OrderBy(r => r.ReferenceNumber).ToList() ?? new List<WorkItemRiskOrIssue>();
    var allRisks = riskOrIssues.Where(r => string.Equals(r.Type, "Risk", StringComparison.OrdinalIgnoreCase)).ToList();
    var allIssues = riskOrIssues.Where(r => string.Equals(r.Type, "Issue", StringComparison.OrdinalIgnoreCase)).ToList();
    var openIssues = allIssues.Where(r => !string.Equals(r.Status, "Closed", StringComparison.OrdinalIgnoreCase)).ToList();
    var openRisks = allRisks.Where(r => !string.Equals(r.Status, "Closed", StringComparison.OrdinalIgnoreCase)).ToList();
    var closedRisks = allRisks.Where(r => string.Equals(r.Status, "Closed", StringComparison.OrdinalIgnoreCase)).ToList();
    var closedIssues = allIssues.Where(r => string.Equals(r.Status, "Closed", StringComparison.OrdinalIgnoreCase)).ToList();
    var riskStatuses = allRisks.Select(r => r.Status).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(s => s).ToList();
    var issueStatuses = allIssues.Select(r => r.Status).Distinct(StringComparer.OrdinalIgnoreCase).OrderBy(s => s).ToList();
    string RiTierPillClass(string? t) {
      if (!string.IsNullOrEmpty(t) && t.Contains("2")) return "ri-tier-pill ri-tier-pill--2";
      return "ri-tier-pill ri-tier-pill--default";
    }
    string WorkRiskIssueDetailHref(WorkItemRiskOrIssue r) =>
        string.Equals(r.Type, "Issue", StringComparison.OrdinalIgnoreCase)
            ? (Url.Action("IssueDetail", "ModernRaid", new { id = r.Id }) ?? "")
            : (Url.Action("RiskDetail", "ModernRaid", new { id = r.Id }) ?? "");
    var workRaidRelation = new RaidRegisterRelationParts(RaidRegisterRelationKinds.Work, Model.Id, Model.Title);
    string WdRaidRegScoreClass(int? score)
    {
      if (score is null) return "raid-reg-score";
      return score.Value >= 20 ? "raid-reg-score raid-reg-score--highest"
          : score.Value >= 15 ? "raid-reg-score raid-reg-score--elevated"
          : score.Value >= 8 ? "raid-reg-score raid-reg-score--medium"
          : "raid-reg-score raid-reg-score--lower";
    }
  }
 <div id="wd-risks" class="tab-pane">
 <div class="tabs wd-tabs" role="tablist" aria-label="Risks and issues sections" id="ri-tabs-bar" style="margin-bottom:0;">
 <button type="button" class="tab on" role="tab" aria-selected="true" aria-controls="ri-pane-risks" id="ri-tab-risks" data-ri-tab="ri-pane-risks">Risks (@allRisks.Count)</button>
 <button type="button" class="tab" role="tab" aria-selected="false" aria-controls="ri-pane-issues" id="ri-tab-issues" data-ri-tab="ri-pane-issues">Issues (@allIssues.Count)</button>
    </div>

    <!-- RISKS PANE -->
 <div id="ri-pane-risks" class="tab-pane on" role="tabpanel" style="padding-top:0;">
 <div id="ri-risk-search-and-filter" class="wd-ri-search-filter dfe-c-mb-0" style="padding:16px 0 12px;">
 <div class="filter-toolbar">
 <div class="filter-toolbar__search-wrap">
 <input type="search" id="ri-risk-search" placeholder="Search risks…" class="filter-search" autocomplete="off" aria-label="Search risks" data-ri-filter="risk">
 <button type="button" class="govuk-button govuk-button--secondary filter-toolbar__search-submit" id="ri-risk-search-submit" data-ri-filter="risk">Search</button>
          </div>
 <button type="button" class="filter-toggle-btn" id="ri-risk-filter-btn" aria-expanded="false" aria-controls="ri-risk-filter-panel">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="flex-shrink:0;" aria-hidden="true"><path d="M1 3h14v1.5l-5 5V14l-4-2V9.5L1 4.5V3z"></path></svg>
 <span class="filter-toggle-label">Filter</span>
          </button>
 <div class="dfe-c-flex" style="gap:8px;flex-wrap:wrap;align-items:center;">
 <a href="@Url.Action("LogRisk", "ModernWork", new { id = Model.Id })" class="govuk-button govuk-button--sm" style="margin-bottom:0;">Add risk</a>
 <a href="@Url.Action("RiskCreate", "ModernRaid", new { associationKind = "work", projectId = Model.Id })" class="govuk-link govuk-link--no-visited-state govuk-!-font-size-16">Full RAID editor</a>
          </div>
        </div>
 <div class="filter-panel filter-panel--allwork" id="ri-risk-filter-panel">
 <div class="filter-panel__grid">
            <div>
              <label for="ri-risk-status">Status</label>
 <select id="ri-risk-status" class="govuk-select" data-ri-filter="risk">
                <option value="">All statuses</option>
                @foreach (var s in riskStatuses) { <option value="@s">@s</option> }
              </select>
            </div>
          </div>
 <div class="filter-panel__actions">
 <button type="button" class="govuk-button" data-ri-apply="risk">Apply filters</button>
 <a href="#" class="govuk-link" role="button" data-ri-clear="risk">Clear filters</a>
          </div>
        </div>
      </div>
      @if (allRisks.Any())
      {
 <div class="dfe-c-table-wrap dfe-c-mb-3">
 <table id="ri-risks-table" class="work-ri-table work-ri-raid">
        <thead>
          <tr>
            <th>Risk</th>
            <th>Business area</th>
            <th>Tier</th>
            <th>Relation</th>
            <th>Status</th>
            <th>Owner</th>
            <th>Likelihood</th>
            <th>Impact</th>
            <th>Score (inherent)</th>
          </tr>
        </thead>
        <tbody>
            @foreach (var r in openRisks.Concat(closedRisks))
            {
              var ownerName = r.OwnerUser?.Name ?? r.OwnerUser?.Email ?? r.UpdatedBy ?? "—";
              var isClosed = string.Equals(r.Status, "Closed", StringComparison.OrdinalIgnoreCase) || r.ClosedAt.HasValue;
              var riskRowClosed = (r.Status ?? "").Contains("closed", StringComparison.OrdinalIgnoreCase) || isClosed;
              var riskDetailUrl = WorkRiskIssueDetailHref(r);
            <tr class="work-ri-table__row--clickable@(isClosed ? " work-ri-table__row--closed" : "")" data-ri-title="@r.Title.ToLowerInvariant()" data-ri-status="@r.Status" data-ri-href="@riskDetailUrl">
              @await Html.PartialAsync("~/Views/Modern/Raid/_RaidRegisterItemTitleCell.cshtml", new RaidRegisterItemTitleVm(riskDetailUrl, r.Title, $"R-{r.Id:D4}"))
 <td class="work-ri-raid__ba">@(string.IsNullOrEmpty(r.BusinessAreaLabel) ? "—" : r.BusinessAreaLabel)</td>
 <td><span class="@RiTierPillClass(r.Tier)">@(r.Tier ?? "Tier 3")</span></td>
 @await Html.PartialAsync("~/Views/Modern/Raid/_RaidRegisterRelationCell.cshtml", workRaidRelation)
 <td><span class="dfe-c-tag @(!riskRowClosed ? "dfe-c-tag--blue" : "dfe-c-tag--green")">@((r.Status ?? "—").ToUpperInvariant())</span></td>
 <td class="work-ri-raid__td-muted">@ownerName</td>
 <td class="work-ri-raid__td-muted">@(r.LikelihoodLabel ?? "—")</td>
 <td class="work-ri-raid__td-muted">@(r.ImpactLabel ?? "—")</td>
 <td class="work-ri-raid__score" style="text-align:right;">@if (r.RiskScore is int s) { <span class="@WdRaidRegScoreClass(s)">@s</span> } else { <span class="work-ri-raid__td-muted">—</span> }</td>
            </tr>
            }
        </tbody>
        </table>
 </div>
 <p class="dfe-c-body muted dfe-c-mb-3" id="ri-risks-empty" style="display:none;">No risks match your search.</p>
      }
      else
      {
 <p class="dfe-c-body muted dfe-c-mb-3">No risks logged.</p>
      }
    </div>

    <!-- ISSUES PANE -->
 <div id="ri-pane-issues" class="tab-pane" role="tabpanel" style="padding-top:0;">
 <div id="ri-issue-search-and-filter" class="wd-ri-search-filter dfe-c-mb-0" style="padding:16px 0 12px;">
 <div class="filter-toolbar">
 <div class="filter-toolbar__search-wrap">
 <input type="search" id="ri-issue-search" placeholder="Search issues…" class="filter-search" autocomplete="off" aria-label="Search issues" data-ri-filter="issue">
 <button type="button" class="govuk-button govuk-button--secondary filter-toolbar__search-submit" id="ri-issue-search-submit" data-ri-filter="issue">Search</button>
          </div>
 <button type="button" class="filter-toggle-btn" id="ri-issue-filter-btn" aria-expanded="false" aria-controls="ri-issue-filter-panel">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="flex-shrink:0;" aria-hidden="true"><path d="M1 3h14v1.5l-5 5V14l-4-2V9.5L1 4.5V3z"></path></svg>
 <span class="filter-toggle-label">Filter</span>
          </button>
 <div class="dfe-c-flex" style="gap:8px;flex-wrap:wrap;align-items:center;">
 <a href="@Url.Action("LogIssue", "ModernWork", new { id = Model.Id })" class="govuk-button govuk-button--sm" style="margin-bottom:0;">Add issue</a>
 <a href="@Url.Action("IssueCreate", "ModernRaid", new { associationKind = "work", projectId = Model.Id })" class="govuk-link govuk-link--no-visited-state govuk-!-font-size-16">Full RAID editor</a>
          </div>
        </div>
 <div class="filter-panel filter-panel--allwork" id="ri-issue-filter-panel">
 <div class="filter-panel__grid">
            <div>
              <label for="ri-issue-status">Status</label>
 <select id="ri-issue-status" class="govuk-select" data-ri-filter="issue">
                <option value="">All statuses</option>
                @foreach (var s in issueStatuses) { <option value="@s">@s</option> }
              </select>
            </div>
          </div>
 <div class="filter-panel__actions">
 <button type="button" class="govuk-button" data-ri-apply="issue">Apply filters</button>
 <a href="#" class="govuk-link" role="button" data-ri-clear="issue">Clear filters</a>
          </div>
        </div>
      </div>
      @if (allIssues.Any())
      {
 <div class="dfe-c-table-wrap dfe-c-mb-3">
 <table id="ri-issues-table" class="work-ri-table work-ri-table--issue work-ri-raid">
        <thead>
          <tr>
            <th>Issue</th>
            <th>Business area</th>
            <th>Relation</th>
            <th>Status</th>
            <th>Owner</th>
            <th>Priority</th>
            <th>Severity</th>
          </tr>
        </thead>
        <tbody>
            @foreach (var r in openIssues.Concat(closedIssues))
            {
              var ownerName = r.OwnerUser?.Name ?? r.OwnerUser?.Email ?? r.UpdatedBy ?? "—";
              var isClosed = string.Equals(r.Status, "Closed", StringComparison.OrdinalIgnoreCase) || r.ClosedAt.HasValue;
              var issueRowClosed = (r.Status ?? "").Contains("closed", StringComparison.OrdinalIgnoreCase) || isClosed;
              var sev = r.IssueSeverityLabel ?? r.Priority ?? "—";
              var pri = r.IssuePriorityLabel ?? "—";
              var issueDetailUrl = WorkRiskIssueDetailHref(r);
            <tr class="work-ri-table__row--issue work-ri-table__row--clickable@(isClosed ? " work-ri-table__row--closed" : "")" data-ri-title="@r.Title.ToLowerInvariant()" data-ri-status="@r.Status" data-ri-href="@issueDetailUrl">
              @await Html.PartialAsync("~/Views/Modern/Raid/_RaidRegisterItemTitleCell.cshtml", new RaidRegisterItemTitleVm(issueDetailUrl, r.Title, $"I-{r.Id:D4}"))
 <td class="work-ri-raid__ba">@(string.IsNullOrEmpty(r.BusinessAreaLabel) ? "—" : r.BusinessAreaLabel)</td>
 @await Html.PartialAsync("~/Views/Modern/Raid/_RaidRegisterRelationCell.cshtml", workRaidRelation)
 <td><span class="dfe-c-tag @(!issueRowClosed ? "dfe-c-tag--blue" : "dfe-c-tag--green")">@((r.Status ?? "—").ToUpperInvariant())</span></td>
 <td class="work-ri-raid__td-muted">@ownerName</td>
 <td><span class="dfe-c-tag @((pri ?? "").Contains("critical", StringComparison.OrdinalIgnoreCase) ? "dfe-c-tag--red" : (pri ?? "").Contains("high", StringComparison.OrdinalIgnoreCase) ? "dfe-c-tag--amber" : "dfe-c-tag--grey")">@((pri ?? "—").ToUpperInvariant())</span></td>
 <td><span class="dfe-c-tag @((sev ?? "").Contains("critical", StringComparison.OrdinalIgnoreCase) ? "dfe-c-tag--red" : (sev ?? "").Contains("major", StringComparison.OrdinalIgnoreCase) ? "dfe-c-tag--amber" : "dfe-c-tag--green")">@((sev ?? "—").ToUpperInvariant())</span></td>
            </tr>
            }
        </tbody>
        </table>
 </div>
 <p class="dfe-c-body muted dfe-c-mb-3" id="ri-issues-empty" style="display:none;">No issues match your search.</p>
      }
      else
      {
 <p class="dfe-c-body muted dfe-c-mb-3">No issues logged.</p>
      }
    </div>
  </div>

  <!-- DEPENDENCIES TAB (More) -->
  @{
    var dependencyTargetPortfolioNames = ViewBag.DependencyTargetPortfolioNames as Dictionary<int, string> ?? new Dictionary<int, string>();
  }
 <div id="wd-dependencies" class="tab-pane">
 <div class="dfe-c-flex--between mb4">
      <h2 style="margin:0;">Dependencies</h2>
 <a href="@Url.Action("AddDependency", "ModernWork", new { id = Model.Id })" class="govuk-button govuk-button--secondary govuk-button--sm">Add dependency</a>
    </div>
    @{
      var inDeps = Model.Dependencies?.Where(d => string.Equals(d.Direction, "In", StringComparison.OrdinalIgnoreCase)).ToList() ?? new List<WorkItemDependency>();
      var outDeps = Model.Dependencies?.Where(d => string.Equals(d.Direction, "Out", StringComparison.OrdinalIgnoreCase)).ToList() ?? new List<WorkItemDependency>();
    }
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
      <div>
        <h3 style="background:#003a69;color:#fff;padding:10px 14px;font-size:15px;margin-bottom:0;">⬆ In-dependencies (upstream)</h3>
        <p style="font-size:13px;color:#505a5f;padding:8px 0 12px;">Things this work item depends on.</p>
        @if (inDeps.Any())
        {
          @foreach (var d in inDeps)
          {
            var depTitle = d.IsInternal && d.TargetWorkItem != null ? d.TargetWorkItem.Title : (d.ExternalDescription ?? "—");
            var depPortfolioName = d.IsInternal && d.TargetWorkItem != null && d.TargetWorkItem.PortfolioId.HasValue && dependencyTargetPortfolioNames.TryGetValue(d.TargetWorkItem.PortfolioId.Value, out var pn) ? pn : null;
            <div style="border:1px solid #dee0e2;overflow:hidden;margin-bottom:10px;">
              <div style="display:grid;grid-template-columns:auto 1fr auto;gap:0;align-items:stretch;">
                <div style="background:@(d.IsInternal ? "#e3f5eb" : "#fde8e4");width:6px;"></div>
                <div style="padding:12px 14px;">
                  <div style="display:flex;gap:8px;align-items:center;margin-bottom:4px;">
                    <span style="background:@(d.IsInternal ? "#d2e2f1" : "#fde8e4");color:@(d.IsInternal ? "#003078" : "#942514");padding:2px 7px;font-size:11px;font-weight:700;">@(d.IsInternal ? "INTERNAL" : "EXTERNAL")</span>
                  </div>
                  @if (d.IsInternal && d.TargetWorkItem != null)
                  {
 <div style="font-weight:700;font-size:15px;"><a href="@Url.Action("Detail", "ModernWork", new { id = d.TargetWorkItem.Id })" class="dfe-c-link">@depTitle</a></div>
                    @if (!string.IsNullOrEmpty(depPortfolioName))
                    {
                      <div style="font-size:13px;color:#505a5f;margin-top:4px;">@depPortfolioName</div>
                    }
                  }
                  else
                  {
                    <div style="font-weight:700;font-size:15px;">@depTitle</div>
                  }
                </div>
                <div style="padding:12px;display:flex;gap:10px;align-items:center;">
                  <form method="post" action="@Url.Action("RemoveDependency", "ModernWork", new { id = Model.Id })" style="display:inline;" data-confirm-title="Remove dependency" data-confirm-message="Remove this dependency link?">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="dependencyId" value="@d.Id" />
 <button type="submit" class="dfe-c-link" style="background:none;border:none;padding:0;font-size:13px;color:var(--govuk-error-colour);cursor:pointer;text-decoration:underline;">Remove</button>
                  </form>
                </div>
              </div>
            </div>
          }
        }
        else { <p style="font-size:13px;color:#505a5f;">None recorded.</p> }
      </div>
      <div>
        <h3 style="background:#003a69;color:#fff;padding:10px 14px;font-size:15px;margin-bottom:0;">⬇ Out-dependencies (downstream)</h3>
        <p style="font-size:13px;color:#505a5f;padding:8px 0 12px;">Work items that depend on this.</p>
        @if (outDeps.Any())
        {
          @foreach (var d in outDeps)
          {
            var depTitle = d.IsInternal && d.TargetWorkItem != null ? d.TargetWorkItem.Title : (d.ExternalDescription ?? "—");
            var depPortfolioName = d.IsInternal && d.TargetWorkItem != null && d.TargetWorkItem.PortfolioId.HasValue && dependencyTargetPortfolioNames.TryGetValue(d.TargetWorkItem.PortfolioId.Value, out var pn2) ? pn2 : null;
            <div style="border:1px solid #dee0e2;overflow:hidden;margin-bottom:10px;">
              <div style="display:grid;grid-template-columns:auto 1fr auto;gap:0;align-items:stretch;">
                <div style="background:#fff7e0;width:6px;"></div>
                <div style="padding:12px 14px;">
                  <div style="display:flex;gap:8px;align-items:center;margin-bottom:4px;">
                    <span style="background:#d2e2f1;color:#003078;padding:2px 7px;font-size:11px;font-weight:700;">@(d.IsInternal ? "INTERNAL" : "EXTERNAL")</span>
                  </div>
                  @if (d.IsInternal && d.TargetWorkItem != null)
                  {
 <div style="font-weight:700;font-size:15px;"><a href="@Url.Action("Detail", "ModernWork", new { id = d.TargetWorkItem.Id })" class="dfe-c-link">@depTitle</a></div>
                    @if (!string.IsNullOrEmpty(depPortfolioName))
                    {
                      <div style="font-size:13px;color:#505a5f;margin-top:4px;">@depPortfolioName</div>
                    }
                  }
                  else
                  {
                    <div style="font-weight:700;font-size:15px;">@depTitle</div>
                  }
                </div>
                <div style="padding:12px;display:flex;gap:10px;align-items:center;">
                  <form method="post" action="@Url.Action("RemoveDependency", "ModernWork", new { id = Model.Id })" style="display:inline;" data-confirm-title="Remove dependency" data-confirm-message="Remove this dependency link?">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="dependencyId" value="@d.Id" />
 <button type="submit" class="dfe-c-link" style="background:none;border:none;padding:0;font-size:13px;color:var(--govuk-error-colour);cursor:pointer;text-decoration:underline;">Remove</button>
                  </form>
                </div>
              </div>
            </div>
          }
        }
        else { <p style="font-size:13px;color:#505a5f;">None recorded.</p> }
      </div>
    </div>
  </div>

  <!-- LINKED RECORDS TAB (More) -->
