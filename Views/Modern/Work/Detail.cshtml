  <!-- RISKS & ISSUES TAB -->
  @{
    var raidEnabled = ViewBag.ShowRaidNavigation == true;
    var riskOrIssues = Model.RiskOrIssues?.OrderBy(r => r.ReferenceNumber).ToList() ?? new List<WorkItemRiskOrIssue>();
    var allRisks = riskOrIssues.Where(r => string.Equals(r.Type, "Risk", StringComparison.OrdinalIgnoreCase)).ToList();
    var allIssues = riskOrIssues.Where(r => string.Equals(r.Type, "Issue", StringComparison.OrdinalIgnoreCase)).ToList();
    var openIssues = allIssues.Where(r => !string.Equals(r.Status, "Closed", StringComparison.OrdinalIgnoreCase)).ToList();
    var openRisks = allRisks.Where(r => !string.Equals(r.Status, "Closed", StringComparison.OrdinalIgnoreCase)).ToList();
    var closedRisks = allRisks.Where(r => string.Equals(r.Status, "Closed", StringComparison.OrdinalIgnoreCase)).ToList();
    var closedIssues = allIssues.Where(r => string.Equals(r.Status, "Closed", StringComparison.OrdinalIgnoreCase)).ToList();
    string WorkRiskIssueDetailHref(WorkItemRiskOrIssue r) =>
        string.Equals(r.Type, "Issue", StringComparison.OrdinalIgnoreCase)
            ? (Url.Action("IssueDetail", "ModernRaid", new { id = r.Id }) ?? "")
            : (Url.Action("RiskDetail", "ModernRaid", new { id = r.Id }) ?? "");
