 <a href="@(Url.Action("Detail", "ModernWork", new { id = Model.Id }))#wd-dependencies" class="govuk-button govuk-button--secondary govuk-button--sm">Manage links &amp; dependencies →</a>
      </div>
    </div>
  </div>

  <!-- AUDIT TRAIL TAB (More) -->
 <div id="wd-audit" class="tab-pane">
    <h2 style="margin-bottom:16px;">Audit trail</h2>
    @{
      var lifecycleEntries = ViewBag.LifecycleAuditEntries as List<Compass.Models.Modern.Work.LifecycleAuditEntry> ?? new List<Compass.Models.Modern.Work.LifecycleAuditEntry>();
      var auditEntries = ViewBag.WorkItemAuditEntries as List<Compass.Models.Modern.Work.AuditLog> ?? new List<Compass.Models.Modern.Work.AuditLog>();
      var auditChangedByDisplay = ViewBag.AuditChangedByDisplay as Dictionary<string, string> ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
      string AuditWho(string? by) => by != null && auditChangedByDisplay.TryGetValue(by, out var name) ? name : by ?? "—";
    }
    <div id="wd-audit-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:300;align-items:center;justify-content:center;" role="dialog" aria-modal="true" aria-labelledby="wd-audit-modal-title">
      <div style="background:#fff;max-width:480px;width:90%;max-height:85vh;overflow:auto;padding:24px;box-shadow:0 4px 24px rgba(0,0,0,0.2);">
 <h3 id="wd-audit-modal-title" class="dfe-c-heading-m" style="margin-top:0;">Change details</h3>
 <dl class="dfe-c-summary-list dfe-c-summary-list--no-border" style="margin-bottom:20px;">
 <div class="dfe-c-summary-list__row"><dt class="dfe-c-summary-list__key">Event</dt><dd class="dfe-c-summary-list__value" id="wd-audit-modal-type">—</dd></div>
 <div class="dfe-c-summary-list__row"><dt class="dfe-c-summary-list__key">When</dt><dd class="dfe-c-summary-list__value" id="wd-audit-modal-when">—</dd></div>
 <div class="dfe-c-summary-list__row"><dt class="dfe-c-summary-list__key">Who</dt><dd class="dfe-c-summary-list__value" id="wd-audit-modal-who">—</dd></div>
 <div class="dfe-c-summary-list__row" id="wd-audit-modal-previous-row" style="display:none;"><dt class="dfe-c-summary-list__key">Previous</dt><dd class="dfe-c-summary-list__value" id="wd-audit-modal-previous">—</dd></div>
 <div class="dfe-c-summary-list__row"><dt class="dfe-c-summary-list__key">New / value</dt><dd class="dfe-c-summary-list__value" id="wd-audit-modal-new" style="white-space:pre-wrap;word-break:break-word;">—</dd></div>
        </dl>
 <button type="button" class="govuk-button" id="wd-audit-modal-close">Close</button>
      </div>
    </div>
 <div class="dfe-c-table-wrap">
 <table style="table-layout:fixed;width:100%;">
 <thead>
 <tr>
 <th style="width:40%;">Event</th>
 <th style="width:28%;">When</th>
 <th style="width:32%;min-width:0;overflow:hidden;text-overflow:ellipsis;">Who</th>
        </tr>
      </thead>
 <tbody>
        @if (lifecycleEntries.Any())
        {
          var idx = 0;
          foreach (var e in lifecycleEntries)
          {
 <tr style="@(e.Highlight ? "background:#e3f5eb;border-left:3px solid #00703c;" : (idx % 2 == 1 ? "background:#f8f9fa;" : ""))">
 <td style="font-size:14px;">
                @if (!string.IsNullOrEmpty(e.LinkUrl))
                {
 <a href="@e.LinkUrl" class="dfe-c-link"><strong>@e.Event</strong></a>
                  @if (!string.IsNullOrEmpty(e.LinkText)) { <text> — </text><span style="font-size:12px;color:#505a5f;">@e.LinkText</span> }
                }
                else
                {
                  <strong>@e.Event</strong>
                }
              </td>
 <td style="font-size:13px;color:#505a5f;">@e.When.ToString("d MMM yyyy · HH:mm")</td>
 <td class="--who" style="font-size:13px;max-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@e.Who">@e.Who</td>
            </tr>
            idx++;
          }
        }
        else if (auditEntries.Any())
        {
          var auditData = auditEntries.Select(a => new { type = a.ChangeType ?? "", when = a.ChangedAt.ToString("d MMM yyyy · HH:mm"), who = AuditWho(a.ChangedBy), previous = a.PreviousValue ?? "", @new = a.NewValue ?? "" }).ToList();
          <script>window.WD_AUDIT_ENTRIES = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(auditData));</script>
          var idx = 0;
          foreach (var a in auditEntries)
          {
            var whoDisplay = AuditWho(a.ChangedBy);
 <tr style="@(idx % 2 == 1 ? "background:#f8f9fa;" : "")">
 <td style="font-size:14px;">
 <button type="button" class="dfe-c-link wd-audit-row-btn" style="background:none;border:none;padding:0;text-align:left;cursor:pointer;text-decoration:underline;color:var(--dfe-c-link-colour);" data-audit-index="@idx"><strong>@(a.ChangeType ?? "—").</strong> @(a.NewValue ?? a.PreviousValue ?? "—")</button>
              </td>
 <td style="font-size:13px;color:#505a5f;">@a.ChangedAt.ToString("d MMM yyyy · HH:mm")</td>
 <td class="--who" style="font-size:13px;max-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@whoDisplay">@whoDisplay</td>
            </tr>
            idx++;
          }
        }
        else
        {
 <tr>
 <td style="font-size:14px;"><strong>Work item updated.</strong></td>
 <td style="font-size:13px;color:#505a5f;">@Model.UpdatedAt.ToString("d MMM yyyy · HH:mm")</td>
 <td class="--who" style="font-size:13px;max-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@AuditWho(Model.UpdatedBy)">@AuditWho(Model.UpdatedBy)</td>
          </tr>
 <tr style="background:#f8f9fa;">
 <td style="font-size:14px;"><strong>Work item created.</strong> @(linkedDemand != null ? "Linked to " + linkedDemand.Reference + "." : "") @(linkedBusinessCase != null ? "Linked to " + linkedBusinessCase.BusinessCaseId + "." : "")</td>
 <td style="font-size:13px;color:#505a5f;">@Model.CreatedAt.ToString("d MMM yyyy · HH:mm")</td>
 <td class="--who" style="font-size:13px;max-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@AuditWho(Model.CreatedBy)">@AuditWho(Model.CreatedBy)</td>
          </tr>
        }
      </tbody>
    </table>
 </div>
  </div>


@section Scripts {
<script nonce="@Context.Items["Nonce"]">
window.openWorkOverviewDialog = function (id) {
  var d = document.getElementById(id);
  if (!d) return;
  if (typeof d.showModal === 'function') {
    d.showModal();
  } else {
    d.setAttribute('open', '');
  }
  if (window.GOVUKFrontend && typeof window.GOVUKFrontend.initAll === 'function') {
    window.GOVUKFrontend.initAll();
  }
};
(function() {
  document.querySelectorAll('[data-dialog]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      window.openWorkOverviewDialog(btn.getAttribute('data-dialog'));
    });
  });
  document.querySelectorAll('.js-work-overview-dialog-close').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var dlg = btn.closest('dialog');
      if (dlg && typeof dlg.close === 'function') dlg.close();
    });
  });
  window.switchRiTab = function(btn, paneId) {
    document.querySelectorAll('#ri-tabs-bar .tab').forEach(function(t){ t.classList.remove('on'); t.setAttribute('aria-selected','false'); });
    document.querySelectorAll('#wd-risks > .tab-pane').forEach(function(p){ p.classList.remove('on'); });
    if (btn) { btn.classList.add('on'); btn.setAttribute('aria-selected','true'); }
    var p = document.getElementById(paneId);
    if (p) p.classList.add('on');
  };
  window.filterRiTable = function(searchId, statusId, tableId, emptyId) {
    var q = (document.getElementById(searchId)?.value || '').toLowerCase();
    var st = document.getElementById(statusId)?.value || '';
    var tbl = document.getElementById(tableId);
    var empty = document.getElementById(emptyId);
    if (!tbl) return;
    var rows = tbl.querySelectorAll('tbody tr');
    var visible = 0;
    rows.forEach(function(row) {
      var title = row.getAttribute('data-ri-title') || '';
      var status = row.getAttribute('data-ri-status') || '';
      var matchSearch = !q || title.indexOf(q) !== -1;
      var matchStatus = !st || status === st;
      if (matchSearch && matchStatus) { row.style.display = ''; visible++; }
      else { row.style.display = 'none'; }
    });
    if (empty) empty.style.display = visible === 0 ? '' : 'none';
  };
  window.riCloseFilterPanel = function(panelId, btnId) {
    var panel = document.getElementById(panelId);
    var btn = document.getElementById(btnId);
    if (panel) panel.classList.remove('open');
    if (btn) {
      btn.classList.remove('active');
      btn.setAttribute('aria-expanded', 'false');
      var label = btn.querySelector('.filter-toggle-label');
      if (label) label.textContent = 'Filter';
    }
  };
  window.riClearRiskFilters = function() {
    var s = document.getElementById('ri-risk-search');
    var st = document.getElementById('ri-risk-status');
    if (s) s.value = '';
    if (st) st.value = '';
    filterRiTable('ri-risk-search','ri-risk-status','ri-risks-table','ri-risks-empty');
    riCloseFilterPanel('ri-risk-filter-panel','ri-risk-filter-btn');
  };
  window.riClearIssueFilters = function() {
    var s = document.getElementById('ri-issue-search');
    var st = document.getElementById('ri-issue-status');
    if (s) s.value = '';
    if (st) st.value = '';
    filterRiTable('ri-issue-search','ri-issue-status','ri-issues-table','ri-issues-empty');
    riCloseFilterPanel('ri-issue-filter-panel','ri-issue-filter-btn');
  };

  // Bind risks/issues tab buttons
  document.querySelectorAll('[data-ri-tab]').forEach(function(btn) {
    btn.addEventListener('click', function() { switchRiTab(btn, btn.getAttribute('data-ri-tab')); });
  });
  // Bind risk filter: search input, search button, status select
  var riRiskSearch = document.getElementById('ri-risk-search');
  var riRiskSubmit = document.getElementById('ri-risk-search-submit');
  var riRiskStatus = document.getElementById('ri-risk-status');
  function doRiskFilter() { filterRiTable('ri-risk-search','ri-risk-status','ri-risks-table','ri-risks-empty'); }
  if (riRiskSearch) riRiskSearch.addEventListener('input', doRiskFilter);
  if (riRiskSubmit) riRiskSubmit.addEventListener('click', doRiskFilter);
  if (riRiskStatus) riRiskStatus.addEventListener('change', doRiskFilter);
  // Bind issue filter: search input, search button, status select
  var riIssueSearch = document.getElementById('ri-issue-search');
  var riIssueSubmit = document.getElementById('ri-issue-search-submit');
  var riIssueStatus = document.getElementById('ri-issue-status');
  function doIssueFilter() { filterRiTable('ri-issue-search','ri-issue-status','ri-issues-table','ri-issues-empty'); }
  if (riIssueSearch) riIssueSearch.addEventListener('input', doIssueFilter);
  if (riIssueSubmit) riIssueSubmit.addEventListener('click', doIssueFilter);
  if (riIssueStatus) riIssueStatus.addEventListener('change', doIssueFilter);
  // Bind apply/clear filter buttons
  document.querySelectorAll('[data-ri-apply="risk"]').forEach(function(btn) {
    btn.addEventListener('click', function() { doRiskFilter(); riCloseFilterPanel('ri-risk-filter-panel','ri-risk-filter-btn'); });
  });
  document.querySelectorAll('[data-ri-clear="risk"]').forEach(function(btn) {
    btn.addEventListener('click', function(e) { e.preventDefault(); riClearRiskFilters(); });
  });
  document.querySelectorAll('[data-ri-apply="issue"]').forEach(function(btn) {
    btn.addEventListener('click', function() { doIssueFilter(); riCloseFilterPanel('ri-issue-filter-panel','ri-issue-filter-btn'); });
  });
  document.querySelectorAll('[data-ri-clear="issue"]').forEach(function(btn) {
    btn.addEventListener('click', function(e) { e.preventDefault(); riClearIssueFilters(); });
  });
  // Bind clickable table rows
  document.querySelectorAll('[data-ri-href]').forEach(function(row) {
    row.addEventListener('click', function(e) {
      if (e.target.closest('a')) return; // let link clicks work normally
      window.location.href = row.getAttribute('data-ri-href');
    });
  });

  (function auditModal() {
    var modal = document.getElementById('wd-audit-modal');
    var closeBtn = document.getElementById('wd-audit-modal-close');
    if (!modal || !closeBtn) return;
    function showModal(entry) {
      if (!entry) return;
      document.getElementById('wd-audit-modal-type').textContent = entry.type || '—';
      document.getElementById('wd-audit-modal-when').textContent = entry.when || '—';
      document.getElementById('wd-audit-modal-who').textContent = entry.who || '—';
      var prevRow = document.getElementById('wd-audit-modal-previous-row');
      var prevEl = document.getElementById('wd-audit-modal-previous');
      if (entry.previous) { prevRow.style.display = ''; prevEl.textContent = entry.previous; } else { prevRow.style.display = 'none'; }
      document.getElementById('wd-audit-modal-new').textContent = (entry['new'] !== undefined && entry['new'] !== null ? entry['new'] : '—');
      modal.style.display = 'flex';
    }
    function hideModal() { modal.style.display = 'none'; }
    document.querySelectorAll('.wd-audit-row-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var idx = parseInt(btn.getAttribute('data-audit-index'), 10);
        if (typeof window.WD_AUDIT_ENTRIES !== 'undefined' && window.WD_AUDIT_ENTRIES[idx]) showModal(window.WD_AUDIT_ENTRIES[idx]);
      });
    });
    closeBtn.addEventListener('click', hideModal);
    modal.addEventListener('click', function(e) { if (e.target === modal) hideModal(); });
  })();
})();
</script>
}
