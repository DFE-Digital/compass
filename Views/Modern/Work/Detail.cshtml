              var pri = r.IssuePriorityLabel ?? "—";
              var issueDetailUrl = WorkRiskIssueDetailHref(r);
            <tr class="work-ri-table__row--issue work-ri-table__row--clickable@(isClosed ? " work-ri-table__row--closed" : "")" data-ri-href="@issueDetailUrl">
              @await Html.PartialAsync("~/Views/Modern/Raid/_RaidRegisterItemTitleCell.cshtml", new RaidRegisterItemTitleVm(issueDetailUrl, r.Title, $"I-{r.Id:D4}"))
 <td class="govuk-table__cell"><span class="@WorkBadgeCss.RaidOpenClosedDfeFrontendBadgeClass(issueRowClosed) dfe-f-badge--small">@((r.Status ?? "—").ToUpperInvariant())</span></td>
 <td class="govuk-table__cell"><span class="@WorkBadgeCss.RaidPriorityLabelDfeFrontendBadgeClass(pri) dfe-f-badge--small">@((pri ?? "—").ToUpperInvariant())</span></td>
 <td class="govuk-table__cell"><span class="@WorkBadgeCss.RaidSeverityLabelDfeFrontendBadgeClass(sev) dfe-f-badge--small">@((sev ?? "—").ToUpperInvariant())</span></td>
            </tr>
            }
        </tbody>
        </table>
 </div>
      }
      else
      {
 <p class="dfe-c-body muted govuk-!-margin-bottom-3">No issues logged.</p>
      }
 </div>
  }

  <!-- DEPENDENCIES TAB (More) -->
  @{
    var dependencyTargetPortfolioNames = ViewBag.DependencyTargetPortfolioNames as Dictionary<int, string> ?? new Dictionary<int, string>();
  }
 <div id="wd-dependencies" class="tab-pane">
 <h2 class="govuk-heading-m govuk-!-margin-top-0 govuk-!-margin-bottom-4">Dependencies</h2>
    @{
      var inDeps = Model.Dependencies?.Where(d => string.Equals(d.Direction, "In", StringComparison.OrdinalIgnoreCase)).ToList() ?? new List<WorkItemDependency>();
      var outDeps = Model.Dependencies?.Where(d => string.Equals(d.Direction, "Out", StringComparison.OrdinalIgnoreCase)).ToList() ?? new List<WorkItemDependency>();
    }
 <div class="govuk-summary-card govuk-!-margin-bottom-4">
 <div class="govuk-summary-card__title-wrapper">
 <h3 class="govuk-summary-card__title">In-dependencies (upstream)</h3>
 <ul class="govuk-summary-card__actions">
 <li class="govuk-summary-card__action">
 <a href="@Url.Action("AddDependency", "ModernWork", new { id = Model.Id })" class="govuk-link govuk-link--no-visited-state">Add dependency</a>
 </li>
 </ul>
 </div>
 <div class="govuk-summary-card__content">
 <p class="govuk-body govuk-!-margin-bottom-3">Things this work item depends on.</p>
        @if (inDeps.Any())
        {
 <div class="dfe-f-table-wrapper govuk-!-margin-bottom-0" data-module="dfe-f-table">
 <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
 <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed">
 <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">In-dependencies</caption>
 <thead class="govuk-table__head">
 <tr class="govuk-table__row">
 <th scope="col" class="govuk-table__header">Type</th>
 <th scope="col" class="govuk-table__header">Dependency</th>
 <th scope="col" class="govuk-table__header">Business area</th>
 <th scope="col" class="govuk-table__header govuk-table__header--numeric">Action</th>
              </tr>
            </thead>
 <tbody class="govuk-table__body">
          @foreach (var d in inDeps)
          {
            var depTitle = d.IsInternal && d.TargetWorkItem != null ? d.TargetWorkItem.Title : (d.ExternalDescription ?? "—");
            var depPortfolioName = d.IsInternal && d.TargetWorkItem != null && d.TargetWorkItem.PortfolioId.HasValue && dependencyTargetPortfolioNames.TryGetValue(d.TargetWorkItem.PortfolioId.Value, out var pn) ? pn : null;
 <tr class="govuk-table__row">
 <td class="govuk-table__cell">
                @if (d.IsInternal)
                {
 <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--blue">Internal</span>
                }
                else
                {
 <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--orange">External</span>
                }
              </td>
 <td class="govuk-table__cell">
                @if (d.IsInternal && d.TargetWorkItem != null)
                {
 <a href="@Url.Action("Detail", "ModernWork", new { id = d.TargetWorkItem.Id })" class="govuk-link govuk-link--no-visited-state">@depTitle</a>
                }
                else
                {
                  @depTitle
                }
              </td>
 <td class="govuk-table__cell">@(string.IsNullOrEmpty(depPortfolioName) ? "—" : depPortfolioName)</td>
 <td class="govuk-table__cell govuk-table__cell--numeric">
 <form method="post" action="@Url.Action("RemoveDependency", "ModernWork", new { id = Model.Id })" class="govuk-!-margin-bottom-0" data-confirm-title="Remove dependency" data-confirm-message="Remove this dependency link?">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="dependencyId" value="@d.Id" />
 <button type="submit" class="govuk-link govuk-link--no-visited-state" style="background:none;border:none;padding:0;color:var(--govuk-error-colour,#d4351c);cursor:pointer;text-decoration:underline;">Remove<span class="govuk-visually-hidden"> dependency @depTitle</span></button>
                  </form>
              </td>
            </tr>
          }
            </tbody>
          </table>
        </div>
        }
        else
        {
 <p class="govuk-body govuk-!-margin-bottom-0">None recorded.</p>
        }
 </div>
 </div>
 <div class="govuk-summary-card">
 <div class="govuk-summary-card__title-wrapper">
 <h3 class="govuk-summary-card__title">Out-dependencies (downstream)</h3>
 <ul class="govuk-summary-card__actions">
 <li class="govuk-summary-card__action">
 <a href="@Url.Action("AddDependency", "ModernWork", new { id = Model.Id })" class="govuk-link govuk-link--no-visited-state">Add dependency</a>
 </li>
 </ul>
 </div>
 <div class="govuk-summary-card__content">
 <p class="govuk-body govuk-!-margin-bottom-3">Work items that depend on this.</p>
        @if (outDeps.Any())
        {
 <div class="dfe-f-table-wrapper govuk-!-margin-bottom-0" data-module="dfe-f-table">
 <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
 <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed">
 <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">Out-dependencies</caption>
 <thead class="govuk-table__head">
 <tr class="govuk-table__row">
 <th scope="col" class="govuk-table__header">Type</th>
 <th scope="col" class="govuk-table__header">Dependency</th>
 <th scope="col" class="govuk-table__header">Business area</th>
 <th scope="col" class="govuk-table__header govuk-table__header--numeric">Action</th>
              </tr>
            </thead>
 <tbody class="govuk-table__body">
          @foreach (var d in outDeps)
          {
            var depTitle = d.IsInternal && d.TargetWorkItem != null ? d.TargetWorkItem.Title : (d.ExternalDescription ?? "—");
            var depPortfolioName = d.IsInternal && d.TargetWorkItem != null && d.TargetWorkItem.PortfolioId.HasValue && dependencyTargetPortfolioNames.TryGetValue(d.TargetWorkItem.PortfolioId.Value, out var pn2) ? pn2 : null;
 <tr class="govuk-table__row">
 <td class="govuk-table__cell">
                @if (d.IsInternal)
                {
 <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--blue">Internal</span>
                }
                else
                {
 <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--orange">External</span>
                }
              </td>
 <td class="govuk-table__cell">
                @if (d.IsInternal && d.TargetWorkItem != null)
                {
 <a href="@Url.Action("Detail", "ModernWork", new { id = d.TargetWorkItem.Id })" class="govuk-link govuk-link--no-visited-state">@depTitle</a>
                }
                else
                {
                  @depTitle
                }
              </td>
 <td class="govuk-table__cell">@(string.IsNullOrEmpty(depPortfolioName) ? "—" : depPortfolioName)</td>
 <td class="govuk-table__cell govuk-table__cell--numeric">
 <form method="post" action="@Url.Action("RemoveDependency", "ModernWork", new { id = Model.Id })" class="govuk-!-margin-bottom-0" data-confirm-title="Remove dependency" data-confirm-message="Remove this dependency link?">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="dependencyId" value="@d.Id" />
 <button type="submit" class="govuk-link govuk-link--no-visited-state" style="background:none;border:none;padding:0;color:var(--govuk-error-colour,#d4351c);cursor:pointer;text-decoration:underline;">Remove<span class="govuk-visually-hidden"> dependency @depTitle</span></button>
                  </form>
              </td>
            </tr>
          }
            </tbody>
          </table>
        </div>
        }
        else
        {
 <p class="govuk-body govuk-!-margin-bottom-0">None recorded.</p>
        }
 </div>
 </div>
  </div>

  @{
    var workAsm = Model.Assumptions?.OrderByDescending(x => x.Id).ToList() ?? new List<WorkItemAssumptionRef>();
  }
 <div id="wd-assumptions" class="tab-pane">
 <div class="modern-work-detail-section-head__title-row govuk-!-margin-bottom-3">
 <h2 class="govuk-heading-m govuk-!-margin-top-0 govuk-!-margin-bottom-0">Assumptions</h2>
 <div class="modern-work-detail-section-head__actions">
 <a href="@Url.Action("AssumptionCreate", "ModernRaid", new { projectId = Model.Id })" class="govuk-button govuk-!-margin-bottom-0">Add assumption</a>
 </div>
 </div>
      @if (workAsm.Count > 0)
      {
 <div class="dfe-f-table-wrapper govuk-!-margin-bottom-0" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
 <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed work-ri-table work-ri-raid">
        <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">Assumptions for this work item</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">Assumption</th>
            <th scope="col" class="govuk-table__header">Criticality</th>
            <th scope="col" class="govuk-table__header">Status</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
            @foreach (var a in workAsm)
            {
              var desc = (a.Description ?? "").Trim();
              var snip = desc.Length > 200 ? desc.Substring(0, 197) + "…" : desc;
              var asmHref = $"/modern/raid/assumptions/{a.Id}";
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">
                <a class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold" href="@asmHref">@snip</a>
                <div class="govuk-body-s govuk-!-margin-top-1 govuk-!-margin-bottom-0" style="color:#505a5f;">A-@(a.Id.ToString("D4"))</div>
              </td>
 <td class="govuk-table__cell"><span class="@WorkBadgeCss.RaidAssumptionCriticalityDfeFrontendBadgeClass(a.Criticality) dfe-f-badge--small">@((a.Criticality ?? "—").ToUpperInvariant())</span></td>
 <td class="govuk-table__cell govuk-body-s">@(string.IsNullOrWhiteSpace(a.Status) ? "—" : a.Status)</td>
            </tr>
            }
        </tbody>
        </table>
 </div>
      }
      else
      {
 <p class="dfe-c-body muted govuk-!-margin-bottom-3">No assumptions recorded.</p>
      }
 <p class="govuk-body-s govuk-!-margin-top-2 govuk-!-margin-bottom-0"><a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("Assumptions", "ModernRaid")">View assumptions register</a></p>
 </div>

</div>
</div>

@section Scripts {
<script nonce="@Context.Items["Nonce"]">
(function() {
  document.querySelectorAll('[data-ri-href]').forEach(function(row) {
    row.addEventListener('click', function(e) {
      if (e.target.closest('a')) return;
      window.location.href = row.getAttribute('data-ri-href');
    });
  });
})();
</script>
}
