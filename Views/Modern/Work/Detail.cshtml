              var effectiveRagId2 = u.RagStatusId ?? (fallbackRagByUpdateId.TryGetValue(u.Id, out var fid2) ? fid2 : (int?)null);
              var uRagName = MonthlyUpdateRagLabel(u, effectiveRagId2, ragStatusesDict);
              var uRagCss2 = u.RagCssClass
                  ?? (effectiveRagId2 is > 0 && ragCssByStatusId.TryGetValue(effectiveRagId2.Value, out var css2) ? css2 : null);
              var submittedByDisplay = u.SubmittedByUserId.HasValue && monthlyUpdateSubmittedByNames.TryGetValue(u.SubmittedByUserId.Value, out var sb) ? sb : (u.SubmittedBy ?? "—");
              var uRagBg2 = effectiveRagId2.HasValue && effectiveRagId2.Value != 0 && ragBgByStatusId.TryGetValue(effectiveRagId2.Value, out var ubg2) ? ubg2 : null;
              var uRagText2 = effectiveRagId2.HasValue && effectiveRagId2.Value != 0 && ragTextByStatusId.TryGetValue(effectiveRagId2.Value, out var utx2) ? utx2 : null;
              <tr class="govuk-table__row">
 <td class="govuk-table__cell"><a href="@Url.Action("ViewMonthlyUpdate", "ModernWork", new { id = Model.Id, updateId = u.Id })" class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold">@u.ReportMonth.ToString("MMMM yyyy")</a></td>
 <td class="govuk-table__cell"><span class="@WorkBadgeCss.RagDfeFrontendBadgeClass(uRagCss2, uRagName == "—" ? null : uRagName) dfe-f-badge--small">@(string.IsNullOrEmpty(uRagName) || uRagName == "—" ? "—" : uRagName.ToUpperInvariant())</span></td>
                <td class="govuk-table__cell">@(u.SubmittedAt?.ToString("d MMM yyyy") ?? "—")</td>
