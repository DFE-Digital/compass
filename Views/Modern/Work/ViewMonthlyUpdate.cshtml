@model Compass.Models.Modern.Work.MonthlyUpdate
@using Compass.Models.Modern.Work
@{
    var work = ViewBag.WorkItem as WorkItem;
    var ragStatusesDict = ViewBag.RagStatusesDict as Dictionary<int, string> ?? new Dictionary<int, string>();
    var effectiveRagStatusId = Model.RagStatusId ?? (ViewBag.ViewUpdateRagStatusId as int?);
    var ragName = effectiveRagStatusId.HasValue && ragStatusesDict.TryGetValue(effectiveRagStatusId.Value, out string? rn) ? rn : "—";
    var submittedByName = ViewBag.SubmittedByName as string ?? Model.SubmittedBy ?? "—";
    var ragJustification = !string.IsNullOrEmpty(Model.RagJustification) ? Model.RagJustification : (ViewBag.ViewUpdateRagJustification as string);
    var pathToGreen = !string.IsNullOrEmpty(Model.PathToGreen) ? Model.PathToGreen : (ViewBag.ViewUpdatePathToGreen as string);
    var isGreen = (ragName ?? "").Contains("green", StringComparison.OrdinalIgnoreCase);
    var ragBgKey = ViewBag.RagBackgroundColourKey as string;
    var ragTextKey = ViewBag.RagTextColourKey as string;
    string RagBadgeClass(string? name) {
        if (string.IsNullOrEmpty(name)) return "rag-badge rag-none";
        var n = (name ?? "").ToLowerInvariant();
        if (n.Contains("green")) return "rag-badge rag-green";
        if (n.Contains("amber") && n.Contains("red")) return "rag-badge rag-amber-red";
        if (n.Contains("red")) return "rag-badge rag-red";
        if (n.Contains("amber")) return "rag-badge rag-amber";
        return "rag-badge rag-none";
    }
    ViewData["Title"] = "Monthly update — " + Model.ReportMonth.ToString("MMMM yyyy");
}
@section Breadcrumbs {
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="/">Home</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Detail", "ModernWork", new { id = Model.WorkItemId })">@(work?.Title ?? "Work")</a></li>
    <li class="dfe-c-breadcrumb__item" aria-current="page">@Model.ReportMonth.ToString("MMMM yyyy")</li>
}

<div id="sc-work-viewmonthlyupdate">
  @await Html.PartialAsync("_WorkItemChrome", ViewBag.WorkItem as WorkItem)
  <h2 class="dfe-c-heading-m dfe-c-mt-0">Monthly update — @Model.ReportMonth.ToString("MMMM yyyy")</h2>
  <p class="dfe-c-body muted dfe-c-mb-3"><strong>Submitted</strong> @(Model.SubmittedAt?.ToString("d MMMM yyyy") ?? "—")@(Model.SubmittedAt?.ToString(" 'at' HH:mm") ?? "") <strong>by</strong> @submittedByName</p>

  <dl class="dfe-c-summary-list dfe-c-summary-list--no-border dfe-c-mb-4">
    <div class="dfe-c-summary-list__row">
      <dt class="dfe-c-summary-list__key">RAG status</dt>
      <dd class="dfe-c-summary-list__value">
        @if (!string.IsNullOrEmpty(ragBgKey) || !string.IsNullOrEmpty(ragTextKey))
        {
          <span class="rag-badge" style="@(string.IsNullOrEmpty(ragBgKey) ? "" : "background-color: var(--govuk-colour-" + ragBgKey + ");")@(string.IsNullOrEmpty(ragTextKey) ? "" : " color: var(--govuk-colour-" + ragTextKey + ");")">@(ragName ?? "—")</span>
        }
        else
        {
          <span class="@RagBadgeClass(ragName)">@(ragName ?? "—")</span>
        }
      </dd>
    </div>
    <div class="dfe-c-summary-list__row">
      <dt class="dfe-c-summary-list__key">Monthly update</dt>
      <dd class="dfe-c-summary-list__value dfe-c-body">@(string.IsNullOrEmpty(Model.Narrative) ? "—" : Model.Narrative)</dd>
    </div>
    <div class="dfe-c-summary-list__row">
      <dt class="dfe-c-summary-list__key">RAG justification</dt>
      <dd class="dfe-c-summary-list__value dfe-c-body">@(string.IsNullOrEmpty(ragJustification) ? "—" : ragJustification)</dd>
    </div>
    @if (!isGreen)
    {
      <div class="dfe-c-summary-list__row">
        <dt class="dfe-c-summary-list__key">Path to green</dt>
        <dd class="dfe-c-summary-list__value dfe-c-body">@(string.IsNullOrEmpty(pathToGreen) ? "—" : pathToGreen)</dd>
      </div>
    }
  </dl>

  <div class="dfe-c-button dfe-c-button--primary-group">
    <a href="@Url.Action("Detail", "ModernWork", new { id = Model.WorkItemId })#wd-updates" class="dfe-c-link">← Back to monthly updates</a>
    @if (ViewBag.CanUnsubmit == true)
    {
      <form method="post" action="@Url.Action("UnsubmitMonthlyUpdate", "ModernWork", new { id = Model.WorkItemId })" class="dfe-c-d-inline-block govuk-!-margin-left-4">
        @Html.AntiForgeryToken()
        <input type="hidden" name="updateId" value="@Model.Id" />
        <button type="submit" class="dfe-c-button dfe-c-button--secondary">Unsubmit</button>
      </form>
      <p class="dfe-c-body dfe-c-form__hint dfe-c-mt-2 dfe-c-mb-0">You can unsubmit this update before the due date, edit it and resubmit. Once the due date has passed, unsubmit is no longer available.</p>
    }
  </div>
</div>
