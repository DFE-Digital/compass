@using Compass.Models.Modern.Work
@using Compass.ViewModels.Dashboard
@{
  var periodLabel = ViewBag.WdMrPeriodLabel as string;
  var submitted = ViewBag.WdMrSubmitted as int? ?? 0;
  var activeAssigned = ViewBag.WdMrActiveAssignedCount as int? ?? 0;
  var rows = ViewBag.WdMrRows as List<HomeMonthlyUpdateRow> ?? new();
  var monthlyTotal = (ViewBag.WdMrSubmitted as int? ?? 0) + (ViewBag.WdMrDraft as int? ?? 0) + (ViewBag.WdMrMissing as int? ?? 0);
  var windowOpen = ViewBag.WdMrWindowOpen as bool? ?? false;
  var monthlyColHeader = ViewBag.WdMrMonthlyUpdateColumnHeader as string ?? "Monthly update";
}

<div>
  @if (activeAssigned == 0)
  {
 <p class="dfe-c-body dfe-c-text-muted govuk-!-margin-bottom-3">No work items are assigned to you — monthly reporting tasks will show here when you are on a delivery team.</p>
  }
  else if (activeAssigned > 0 && windowOpen && monthlyTotal == 0)
  {
 <p class="dfe-c-body dfe-c-text-muted govuk-!-margin-bottom-3">All assigned work has a submitted update for this period.</p>
  }

  @if (activeAssigned > 0 && rows.Count > 0)
  {
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
 <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
 <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed modern-work-table" id="work-dashboard-table">
 <thead class="govuk-table__head">
 <tr class="govuk-table__row">
 <th scope="col" class="govuk-table__header" aria-sort="none">
 <button type="button" class="dfe-f-table-sort-button">Work item</button>
 </th>
 <th scope="col" class="govuk-table__header" aria-sort="none">
 <button type="button" class="dfe-f-table-sort-button">Business area</button>
 </th>
 <th scope="col" class="govuk-table__header" aria-sort="none">
 <button type="button" class="dfe-f-table-sort-button">Priority</button>
 </th>
 <th scope="col" class="govuk-table__header" aria-sort="none">
 <button type="button" class="dfe-f-table-sort-button">RAG</button>
 </th>
 <th scope="col" class="govuk-table__header" aria-sort="none">
 <button type="button" class="dfe-f-table-sort-button">Primary contact</button>
 </th>
 <th scope="col" class="govuk-table__header" aria-sort="none">
 <button type="button" class="dfe-f-table-sort-button">Status</button>
 </th>
 <th scope="col" class="govuk-table__header" aria-sort="none">
 <button type="button" class="dfe-f-table-sort-button">@monthlyColHeader</button>
 </th>
 </tr>
 </thead>
 <tbody class="govuk-table__body">
          @foreach (var row in rows)
          {
 <tr class="govuk-table__row">
 <td class="govuk-table__cell">
 <a href="@Url.Action("Detail", "ModernWork", new { id = row.WorkItemId })" class="govuk-link govuk-link--no-visited-state">@row.WorkTitle</a>
 <div class="govuk-body-s dfe-t-u-text-muted modern-work-table__meta">
 WI-@row.WorkItemId.ToString("D8")@if (!string.IsNullOrEmpty(row.PhaseName)) { <span aria-hidden="true"> · </span><span>@row.PhaseName</span> }
                </div>
              </td>
 <td class="govuk-table__cell">@row.BusinessArea</td>
 <td class="govuk-table__cell">
                @if (!string.IsNullOrEmpty(row.PriorityName))
                {
 <span class="@WorkBadgeCss.PriorityDfeFrontendBadgeClass(row.PriorityName)">@row.PriorityName.ToUpperInvariant()</span>
                }
                else
                {
 <span class="dfe-c-text-muted">—</span>
                }
              </td>
 <td class="govuk-table__cell">@await Html.PartialAsync("_WorkRagBadge", row.LatestRag)</td>
 <td class="govuk-table__cell">@row.PrimaryContact</td>
 <td class="govuk-table__cell"><span class="@WorkBadgeCss.StatusDfeFrontendBadgeClass(row.WorkItemStatus)">@row.WorkItemStatus</span></td>
 <td class="govuk-table__cell">
                @{
                  var badgeClass = WorkBadgeCss.MonthlyReportingStatusDfeFrontendBadgeClass(row.StatusLabel);
                  var canLink = row.RowKind is "view" or "complete" && !string.IsNullOrEmpty(row.ActionUrl);
                }
                @if (canLink)
                {
 <a class="govuk-link govuk-link--no-visited-state wd-mr-update-badge-link"
    href="@row.ActionUrl"
    aria-label="@row.PeriodLabel monthly update: @row.StatusLabel — @row.ActionLabel">
 <span class="@badgeClass wd-mr-update-badge wd-mr-update-badge--with-icon">
 <span class="wd-mr-update-badge__text">@row.StatusLabel</span>
 <svg class="wd-mr-update-badge__icon" width="12" height="12" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M14 4h6v6h-2V7.4l-9.3 9.3-1.4-1.4L16.6 6H14V4z"/></svg>
                  </span>
                  </a>
                }
                else
                {
 <span class="@badgeClass">@row.StatusLabel</span>
                }
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
</div>
