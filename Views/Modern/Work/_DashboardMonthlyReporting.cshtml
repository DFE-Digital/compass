@using Compass.Models.Modern.Work
@using Compass.ViewModels.Dashboard
@{
  string PriorityTagClass(string? priorityName)
  {
    if (string.IsNullOrWhiteSpace(priorityName)) return "dfe-c-tag dfe-c-tag--grey";
    var s = priorityName.ToLowerInvariant();
    if (s.Contains("high") || s.Contains("critical")) return "dfe-c-tag dfe-c-tag--red";
    if (s.Contains("medium")) return "dfe-c-tag dfe-c-tag--amber";
    if (s.Contains("low")) return "dfe-c-tag dfe-c-tag--green";
    return "dfe-c-tag dfe-c-tag--grey";
  }
  var periodLabel = ViewBag.WdMrPeriodLabel as string;
  var submitted = ViewBag.WdMrSubmitted as int? ?? 0;
  var activeAssigned = ViewBag.WdMrActiveAssignedCount as int? ?? 0;
  var rows = ViewBag.WdMrRows as List<HomeMonthlyUpdateRow> ?? new();
  var monthlyTotal = (ViewBag.WdMrSubmitted as int? ?? 0) + (ViewBag.WdMrDraft as int? ?? 0) + (ViewBag.WdMrMissing as int? ?? 0);
  var windowOpen = ViewBag.WdMrWindowOpen as bool? ?? false;
  var windowOpensOn = ViewBag.WdMrWindowOpensOn as DateTime?;
  var monthlyColHeader = ViewBag.WdMrMonthlyUpdateColumnHeader as string ?? "Monthly update";
}

<div>
  @if (activeAssigned > 0 && !windowOpen && windowOpensOn.HasValue)
  {
 <p class="dfe-c-body dfe-c-text-muted dfe-c-mb-3">Reporting for this period is not open yet. It opens on <strong>@windowOpensOn.Value.ToString("dddd d MMMM yyyy")</strong>@if (submitted> 0) { <text> — @submitted already submitted.</text> }.</p>
  }
  else if (activeAssigned == 0)
  {
 <p class="dfe-c-body dfe-c-text-muted dfe-c-mb-3">No work items are assigned to you — monthly reporting tasks will show here when you are on a delivery team.</p>
  }
  else if (activeAssigned > 0 && windowOpen && monthlyTotal == 0)
  {
 <p class="dfe-c-body dfe-c-text-muted dfe-c-mb-3">All assigned work has a submitted update for this period.</p>
  }

  @if (activeAssigned > 0 && rows.Count > 0)
  {
 <div class="dfe-c-table-wrap">
      <table class="modern-work-table" id="work-dashboard-table">
 <caption class="compass2-visually-hidden">Your work items for @(periodLabel ?? "this reporting period")</caption>
        <thead>
          <tr>
            <th scope="col">Work item</th>
            <th scope="col">Business area</th>
            <th scope="col">Priority</th>
            <th scope="col">RAG</th>
            <th scope="col">Primary contact</th>
            <th scope="col">Tags</th>
            <th scope="col">Status</th>
            <th scope="col">@monthlyColHeader</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var row in rows)
          {
            <tr>
              <td>
 <a href="@Url.Action("Detail", "ModernWork", new { id = row.WorkItemId })">@row.WorkTitle</a>
 <div class="dfe-c-body-s dfe-c-text-muted" style="margin-top:0.25rem;line-height:1.3;">
 WI-@row.WorkItemId.ToString("D8")@if (!string.IsNullOrEmpty(row.PhaseName)) { <span aria-hidden="true"> · </span><span>@row.PhaseName</span> }
                </div>
              </td>
              <td>@row.BusinessArea</td>
              <td>
                @if (!string.IsNullOrEmpty(row.PriorityName))
                {
 <span class="@PriorityTagClass(row.PriorityName)">@row.PriorityName.ToUpperInvariant()</span>
                }
                else
                {
 <span class="dfe-c-text-muted">—</span>
                }
              </td>
              <td>@await Html.PartialAsync("_WorkRagBadge", row.LatestRag)</td>
              <td>@row.PrimaryContact</td>
 <td class="dfe-c-body-s">@(string.IsNullOrEmpty(row.TagNamesSummary) ? "—" : row.TagNamesSummary)</td>
 <td><span class="@WorkBadgeCss.StatusDfeTagClass(row.WorkItemStatus)">@row.WorkItemStatus</span></td>
              <td>
                @{
                  string? badgeClass = row.StatusLabel switch
                  {
                    "Submitted" => "dfe-c-tag dfe-c-tag--green",
                    "Draft" => "dfe-c-tag dfe-c-tag--amber",
                    "Not due" => "dfe-c-tag dfe-c-tag--grey",
                    _ => "dfe-c-tag dfe-c-tag--red"
                  };
                  var canLink = row.RowKind is "view" or "complete" && !string.IsNullOrEmpty(row.ActionUrl);
                }
                @if (canLink)
                {
 <a class="govuk-link govuk-link--no-visited-state wd-mr-update-badge-link"
    href="@row.ActionUrl"
    aria-label="@row.PeriodLabel monthly update: @row.StatusLabel — @row.ActionLabel">
 <span class="@badgeClass wd-mr-update-badge wd-mr-update-badge--with-icon">
 <span class="wd-mr-update-badge__text">@row.StatusLabel</span>
 <svg class="wd-mr-update-badge__icon" width="12" height="12" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M14 4h6v6h-2V7.4l-9.3 9.3-1.4-1.4L16.6 6H14V4z"/></svg>
                  </span>
                  </a>
                }
                else
                {
 <span class="@badgeClass" style="font-size:0.75rem;">@row.StatusLabel</span>
                }
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
</div>
