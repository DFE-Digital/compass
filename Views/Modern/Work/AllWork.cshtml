@model Compass.Models.Modern.Work.WorkRegisterViewModel
@using Compass.Models.Modern.Work
@using Compass.ViewModels.Modern
@using System.Linq
@{
    var opsManage = ViewBag.OpsManageWork as bool? == true;
    var listAction = opsManage ? "ManageWork" : "AllWork";
    var listController = opsManage ? "ModernOperations" : "ModernWork";
    ViewData["Title"] = opsManage ? "Manage work" : "All work";
    var activeTab = ViewBag.ActiveTab as string ?? "active";
    var searchAndFilter = ViewBag.SearchAndFilter as SearchAndFilterViewModel;
    var businessAreaCount = Model.BusinessAreas?.Count ?? 0;
    var allFilteredCount = Model.ActiveCount + Model.PausedCount + Model.CompletedCount + Model.CancelledCount;

    string? MonthlyQ() => string.IsNullOrWhiteSpace(Model.FilterMonthlyUpdate) ? null : Model.FilterMonthlyUpdate;
    int[]? TagIdsQ() => (Model.FilterTagIds != null && Model.FilterTagIds.Count > 0) ? Model.FilterTagIds.ToArray() : null;

    object AllWorkTabQuery(string tab) => new {
        tab,
        page = 1,
        mine = Model.IsMyWork ? true : (bool?)null,
        search = Model.FilterSearch,
        businessAreaId = Model.FilterBusinessAreaId,
        directorateId = Model.FilterDirectorateId,
        phaseId = Model.FilterPhaseId,
        ragId = Model.FilterRagId,
        priorityId = Model.FilterPriorityId,
        monthlyUpdate = MonthlyQ(),
        primaryContactUserId = Model.FilterPrimaryContactUserId,
        tagId = Model.FilterTagId,
        tagIds = TagIdsQ(),
        sort = Model.RegisterSortField,
        sd = Model.RegisterSortDescending
    };

    object AllWorkYourWorkTabQuery() => new {
        tab = "active",
        page = 1,
        mine = true,
        search = Model.FilterSearch,
        businessAreaId = Model.FilterBusinessAreaId,
        directorateId = Model.FilterDirectorateId,
        phaseId = Model.FilterPhaseId,
        ragId = Model.FilterRagId,
        priorityId = Model.FilterPriorityId,
        monthlyUpdate = MonthlyQ(),
        primaryContactUserId = Model.FilterPrimaryContactUserId,
        tagId = Model.FilterTagId,
        tagIds = TagIdsQ(),
        sort = Model.RegisterSortField,
        sd = Model.RegisterSortDescending
    };

    object AllWorkOrgScopeTabQuery(string tab) => new {
        tab,
        page = 1,
        search = Model.FilterSearch,
        businessAreaId = Model.FilterBusinessAreaId,
        directorateId = Model.FilterDirectorateId,
        phaseId = Model.FilterPhaseId,
        ragId = Model.FilterRagId,
        priorityId = Model.FilterPriorityId,
        monthlyUpdate = MonthlyQ(),
        primaryContactUserId = Model.FilterPrimaryContactUserId,
        tagId = Model.FilterTagId,
        tagIds = TagIdsQ(),
        sort = Model.RegisterSortField,
        sd = Model.RegisterSortDescending
    };

    object AllWorkPageQuery(int page) => new {
        tab = activeTab,
        page,
        mine = Model.IsMyWork ? true : (bool?)null,
        search = Model.FilterSearch,
        businessAreaId = Model.FilterBusinessAreaId,
        directorateId = Model.FilterDirectorateId,
        phaseId = Model.FilterPhaseId,
        ragId = Model.FilterRagId,
        priorityId = Model.FilterPriorityId,
        monthlyUpdate = MonthlyQ(),
        primaryContactUserId = Model.FilterPrimaryContactUserId,
        tagId = Model.FilterTagId,
        tagIds = TagIdsQ(),
        sort = Model.RegisterSortField,
        sd = Model.RegisterSortDescending
    };

    IEnumerable<WorkRegisterRow> RowsForTab(string tab)
    {
        if (Model.RegisterIsPaginated && string.Equals(activeTab, tab, StringComparison.OrdinalIgnoreCase))
            return Model.RegisterPageRows;
        if (!Model.RegisterIsPaginated)
        {
            return tab switch
            {
                "active" => Model.ActivePaused,
                "completed" => Model.Completed,
                "cancelled" => Model.Cancelled,
                "all" => Model.ActivePaused.Concat(Model.Completed).Concat(Model.Cancelled),
                _ => Model.ActivePaused
            };
        }
        return Enumerable.Empty<WorkRegisterRow>();
    }

}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 @if (opsManage)
 {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernOperations")">Operations</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Manage work</li>
 }
 else
 {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">All work</li>
 }
}

@{
  var allWorkHeaderActions = await Html.PartialAsync("_AllWorkHeaderActions");
  var allWorkHeaderLede = await Html.PartialAsync("_AllWorkHeaderLede", Model);
}

<div class="modern-work-page modern-work-page--all-work">
@await Html.PartialAsync("_ModernPageHeader", new Compass.ViewModels.Modern.ModernPageHeaderViewModel {
  Caption = Model.IsMyWork ? "Your work" : (opsManage ? "Operations" : "Work"),
  Title = opsManage ? "Manage work" : "All work",
  Lede = allWorkHeaderLede,
  Actions = allWorkHeaderActions
})

<form method="get" action="@Url.Action(listAction, listController)" id="allwork-register-form" class="dfe-c-mb-3">
  <input type="hidden" name="tab" value="@activeTab" />
  <input type="hidden" name="page" value="1" />
  @if (Model.IsMyWork)
  {
    <input type="hidden" name="mine" value="true" />
  }
  <input type="hidden" name="sort" value="@Model.RegisterSortField" />
  <input type="hidden" name="sd" value="@(Model.RegisterSortDescending.ToString().ToLowerInvariant())" />
  <div id="search-and-filter">
 <div class="filter-toolbar">
 <div class="filter-toolbar__search-wrap">
 <input type="search" name="search" id="allwork-register-search" value="@Model.FilterSearch" placeholder="@(searchAndFilter?.SearchPlaceholder ?? "Search work item titles…")" class="filter-search" autocomplete="off" aria-label="Search work item titles" />
 <button type="submit" class="govuk-button govuk-button--secondary filter-toolbar__search-submit" id="allwork-search-submit">Search</button>
    </div>
 <button type="button" class="filter-toggle-btn" id="allwork-filter-btn" aria-expanded="false" aria-controls="allwork-filter-panel">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="flex-shrink:0;" aria-hidden="true"><path d="M1 3h14v1.5l-5 5V14l-4-2V9.5L1 4.5V3z"></path></svg>
 <span class="filter-toggle-label">Filter</span>
    </button>
  </div>
@await Html.PartialAsync("~/Views/Modern/Shared/_FilterActiveChips.cshtml", Model.ActiveFilterChips)
 <div class="filter-panel filter-panel--allwork" id="allwork-filter-panel">
 <div class="filter-panel__grid">
      <div>
        <label for="allwork-filter-rag">RAG</label>
 <select name="ragId" id="allwork-filter-rag" class="govuk-select">
          <option value="">All</option>
          @foreach (var r in Model.RagOptions)
          {
            if (Model.FilterRagId == r.Id)
            {
              <option value="@r.Id" selected>@r.Name</option>
            }
            else
            {
              <option value="@r.Id">@r.Name</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="allwork-filter-phase">Phase</label>
 <select name="phaseId" id="allwork-filter-phase" class="govuk-select">
          <option value="">All</option>
          @foreach (var o in Model.DeliveryPhaseOptions)
          {
            if (Model.FilterPhaseId == o.Id)
            {
              <option value="@o.Id" selected>@(o.Name ?? o.Value)</option>
            }
            else
            {
              <option value="@o.Id">@(o.Name ?? o.Value)</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="allwork-filter-businessarea">Business area</label>
 <select name="businessAreaId" id="allwork-filter-businessarea" class="govuk-select">
          <option value="">All (@businessAreaCount)</option>
          @foreach (var b in Model.BusinessAreas)
          {
            if (Model.FilterBusinessAreaId == b.Id)
            {
              <option value="@b.Id" selected>@b.Name</option>
            }
            else
            {
              <option value="@b.Id">@b.Name</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="allwork-filter-directorate">Directorate</label>
 <select name="directorateId" id="allwork-filter-directorate" class="govuk-select">
          <option value="">All</option>
          @foreach (var d in Model.Directorates)
          {
            if (Model.FilterDirectorateId == d.Id)
            {
              <option value="@d.Id" selected>@d.Name</option>
            }
            else
            {
              <option value="@d.Id">@d.Name</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="allwork-filter-priority">Priority</label>
 <select name="priorityId" id="allwork-filter-priority" class="govuk-select">
          <option value="">All</option>
          @foreach (var o in Model.PriorityOptions)
          {
            if (Model.FilterPriorityId == o.Id)
            {
              <option value="@o.Id" selected>@(o.Name ?? o.Value)</option>
            }
            else
            {
              <option value="@o.Id">@(o.Name ?? o.Value)</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="allwork-filter-monthly">Monthly update</label>
 <select name="monthlyUpdate" id="allwork-filter-monthly" class="govuk-select">
          @if (string.IsNullOrEmpty(Model.FilterMonthlyUpdate))
          {
            <option value="" selected>All</option>
          }
          else
          {
            <option value="">All</option>
          }
          @if (string.Equals(Model.FilterMonthlyUpdate, "overdue", StringComparison.OrdinalIgnoreCase))
          {
            <option value="overdue" selected>Overdue</option>
          }
          else
          {
            <option value="overdue">Overdue</option>
          }
          @if (string.Equals(Model.FilterMonthlyUpdate, "due-today", StringComparison.OrdinalIgnoreCase))
          {
            <option value="due-today" selected>Due today</option>
          }
          else
          {
            <option value="due-today">Due today</option>
          }
          @if (string.Equals(Model.FilterMonthlyUpdate, "submitted", StringComparison.OrdinalIgnoreCase))
          {
            <option value="submitted" selected>Submitted</option>
          }
          else
          {
            <option value="submitted">Submitted</option>
          }
          @if (string.Equals(Model.FilterMonthlyUpdate, "not-required", StringComparison.OrdinalIgnoreCase))
          {
            <option value="not-required" selected>Not required</option>
          }
          else
          {
            <option value="not-required">Not required</option>
          }
        </select>
      </div>
      <div>
        <label for="allwork-filter-primarycontact">Primary contact</label>
 <select name="primaryContactUserId" id="allwork-filter-primarycontact" class="govuk-select">
          <option value="">All</option>
          @foreach (var pc in Model.PrimaryContactFilterOptions)
          {
            if (Model.FilterPrimaryContactUserId == pc.UserId)
            {
              <option value="@pc.UserId" selected>@pc.DisplayName</option>
            }
            else
            {
              <option value="@pc.UserId">@pc.DisplayName</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="allwork-filter-tags">Tags</label>
        @if ((Model.TagFilterOptions?.Count ?? 0) == 0)
        {
 <p class="dfe-c-body-s dfe-c-text-muted govuk-!-margin-bottom-0" id="allwork-filter-tags">No tags defined — add tags in Admin → Work → Tagging.</p>
        }
        else
        {
 <select name="tagId" id="allwork-filter-tags" class="govuk-select">
          <option value="">All tags</option>
          @foreach (var tg in Model.TagFilterOptions!)
          {
            if (Model.FilterTagId == tg.Id)
            {
              <option value="@tg.Id" selected>@(tg.Name ?? tg.Value)</option>
            }
            else
            {
              <option value="@tg.Id">@(tg.Name ?? tg.Value)</option>
            }
          }
        </select>
        }
      </div>
    </div>
 <div class="filter-panel__actions">
 <button type="submit" class="govuk-button">Apply filters</button>
 <a href="@Url.Action(listAction, listController, new { tab = activeTab, mine = Model.IsMyWork ? true : (bool?)null })" class="govuk-link govuk-link--no-visited-state">Clear filters</a>
    </div>
  </div>
  </div>
</form>

@if (ViewBag.WorkRegisterSubNav is WorkRegisterSubNavViewModel workRegisterSubNav)
{
  @await Html.PartialAsync("_WorkRegisterSubNav", workRegisterSubNav)
}

<div id="d-active" class="tab-pane @(activeTab =="active" ? "on" : "")" role="tabpanel">
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
    <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed modern-work-table" id="work-table-active">
 <caption class="govuk-table__caption govuk-table__caption--m compass2-visually-hidden">@(Model.IsMyWork ? "Your work" : "Active and paused work items")</caption>
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Work item</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Business area</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Priority</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">RAG</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Primary contact</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Status</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">@Model.RegisterMonthlyColumnHeader</button>
        </th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        @foreach (var r in RowsForTab("active"))
        {
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">
              <a href="@Url.Action("Detail", "ModernWork", new { id = r.Id })" class="govuk-link govuk-link--no-visited-state">@r.Title</a>
 <div class="govuk-body-s dfe-t-u-text-muted modern-work-table__meta">
                WI-@r.Id.ToString("D8")@if (!string.IsNullOrEmpty(r.PhaseName) && r.PhaseName != "—") { <span aria-hidden="true"> · </span><span>@r.PhaseName</span> }
              </div>
            </td>
            <td class="govuk-table__cell">@(r.BusinessAreaName ?? "—")</td>
            <td class="govuk-table__cell">
                @if (!string.IsNullOrEmpty(r.PriorityName))
                {
                    <span class="@WorkBadgeCss.PriorityDfeFrontendBadgeClass(r.PriorityName)">@r.PriorityName.ToUpperInvariant()</span>
                }
                else
                {
                    <span class="dfe-c-text-muted">—</span>
                }
              </td>
            <td class="govuk-table__cell"><span class="@WorkBadgeCss.RagDfeFrontendBadgeClass(r.RagCssClass, r.RagName)">@((r.RagName ?? "—").ToUpperInvariant())</span></td>
            <td class="govuk-table__cell">@(r.PrimaryContactName ?? "—")</td>
 <td class="govuk-table__cell"><span class="@WorkBadgeCss.StatusDfeFrontendBadgeClass(r.Status)">@r.Status</span></td>
            <td class="govuk-table__cell">@await Html.PartialAsync("~/Views/Modern/Work/_WorkRegisterMonthlyUpdateCell.cshtml", r)</td>
          </tr>
        }
      </tbody>
    </table>
  </div>
  @if (!RowsForTab("active").Any())
  {
 <p class="dfe-c-body muted">No active or paused work items.</p>
  }
</div>

