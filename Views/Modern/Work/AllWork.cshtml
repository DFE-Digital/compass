  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
    <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed modern-work-table" id="work-table-all">
 <caption class="govuk-table__caption govuk-table__caption--m compass2-visually-hidden">All work items</caption>
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Work item</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Business area</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Priority</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">RAG</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Primary contact</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Status</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">@Model.RegisterMonthlyColumnHeader</button>
        </th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        @foreach (var r in RowsForTab("all"))
        {
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">
              <a href="@Url.Action("Detail", "ModernWork", new { id = r.Id })" class="govuk-link govuk-link--no-visited-state">@r.Title</a>
 <div class="govuk-body-s dfe-t-u-text-muted modern-work-table__meta">
                WI-@r.Id.ToString("D8")@if (!string.IsNullOrEmpty(r.PhaseName) && r.PhaseName != "—") { <span aria-hidden="true"> · </span><span>@r.PhaseName</span> }
              </div>
            </td>
            <td class="govuk-table__cell">@(r.BusinessAreaName ?? "—")</td>
            <td class="govuk-table__cell">
                @if (!string.IsNullOrEmpty(r.PriorityName))
                {
                    <span class="@WorkBadgeCss.PriorityDfeFrontendBadgeClass(r.PriorityName)">@r.PriorityName.ToUpperInvariant()</span>
                }
                else
                {
                    <span class="dfe-c-text-muted">—</span>
                }
              </td>
            <td class="govuk-table__cell"><span class="@WorkBadgeCss.RagDfeFrontendBadgeClass(r.RagCssClass, r.RagName)">@((r.RagName ?? "—").ToUpperInvariant())</span></td>
            <td class="govuk-table__cell">@(r.PrimaryContactName ?? "—")</td>
 <td class="govuk-table__cell"><span class="@WorkBadgeCss.StatusDfeFrontendBadgeClass(r.Status)">@(r.Status ?? "—")</span></td>
            <td class="govuk-table__cell">@await Html.PartialAsync("~/Views/Modern/Work/_WorkRegisterMonthlyUpdateCell.cshtml", r)</td>
          </tr>
        }
      </tbody>
    </table>
  </div>
  @if (allFilteredCount == 0)
  {
 <p class="dfe-c-body muted">No work items match these filters.</p>
  }
</div>

@await Html.PartialAsync("~/Views/Modern/Work/_WorkRegisterPaginationFooter.cshtml", new WorkRegisterPaginationFooterViewModel {
  IsPaginated = Model.RegisterIsPaginated,
  DisplayRowStart = Model.RegisterDisplayRowStart,
  DisplayRowEnd = Model.RegisterDisplayRowEnd,
  TotalCount = Model.RegisterTotalCount,
  CurrentPage = Model.RegisterPage,
  TotalPages = Model.RegisterPageCount,
  PageUrl = p => Url.Action(listAction, listController, AllWorkPageQuery(p)) ?? "#",
  NavigationAriaLabel = "All work results"
})

</div>
