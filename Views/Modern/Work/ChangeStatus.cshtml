@model Compass.Models.Modern.Work.WorkItem
@{
    var work = ViewBag.WorkItem as Compass.Models.Modern.Work.WorkItem ?? Model;
    var statusOptions = ViewBag.WorkStatusOptions as List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem> ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var currentStatus = ViewBag.CurrentStatus as string ?? Model?.Status;
    ViewData["Title"] = "Change status";
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="/">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Detail", "ModernWork", new { id = Model.Id })">@(work?.Title ?? "Work")</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Change status</li>
}

<div id="sc-work-changestatus">
  @await Html.PartialAsync("_WorkItemChrome", work)
 <h2 class="dfe-c-heading-m dfe-c-mt-0">Change status</h2>
 <p class="dfe-c-body dfe-c-mb-3">Set a new status for this work item. Deleted items are hidden from all lists and reporting.</p>

 <form asp-action="ChangeStatus" asp-route-id="@Model.Id" method="post" class="dfe-c-mb-4">
    @Html.AntiForgeryToken()
 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="status">Status</label>
 <select id="status" name="status">
        @foreach (var opt in statusOptions)
        {
          <option value="@opt.Value" selected="@(opt.Value == currentStatus)">@opt.Text</option>
        }
      </select>
    </div>
 <div class="dfe-c-mt-3">
 <button type="submit" name="action" value="" class="govuk-button">Update status</button>
 <a href="@Url.Action("Detail", "ModernWork", new { id = Model.Id })" class="govuk-button govuk-button--secondary dfe-c-ms-2">Cancel</a>
    </div>
  </form>

 <div class="dfe-c-mt-3" style="border-top:1px solid #b1b4b6;padding-top:1.5rem;">
 <h3 class="dfe-c-heading-s dfe-c-mb-2">Delete this work item</h3>
 <p class="dfe-c-body dfe-c-mb-2">Removes the work item from all tables, views and reporting. The record is kept but marked as deleted.</p>
    <form asp-action="ChangeStatus" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this work item? It will no longer appear in any lists or reports.');">
      @Html.AntiForgeryToken()
      <input type="hidden" name="status" value="@currentStatus" />
 <button type="submit" name="action" value="delete" class="govuk-button govuk-button--warning">Delete this work item</button>
    </form>
  </div>
</div>
