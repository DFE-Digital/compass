@model Compass.Models.Modern.Work.WorkItemKri
@using Compass.Models.Modern.Work
@{
    var ri = Model.WorkItemRiskOrIssue;
    var work = ri?.WorkItem;
    var workId = work?.Id ?? 0;
    var riRef = ViewBag.RiRef as string ?? "RI-00000";
    var kriRef = ViewBag.KriRef as string ?? ("KRI-" + Model.ReferenceNumber.ToString("D3"));
    var isIssue = string.Equals(ri?.Type, "Issue", StringComparison.OrdinalIgnoreCase);
    var backRiskIssueHref = isIssue
        ? Url.Action("IssueDetail", "ModernWork", new { workId, id = Model.WorkItemRiskOrIssueId })
        : Url.Action("RiskDetail", "ModernWork", new { workId, id = Model.WorkItemRiskOrIssueId });
    ViewData["Title"] = kriRef + " — " + Model.Name;
}
@section Breadcrumbs {
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Detail", "ModernWork", new { id = workId })">@(work?.Title ?? "Work")</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@backRiskIssueHref">@riRef</a></li>
    <li class="dfe-c-breadcrumb__item" aria-current="page">@kriRef</li>
}

<div id="sc-work-kridetail">
    @await Html.PartialAsync("_WorkItemChrome", work)

    <div class="dfe-c-page-title">
        <div class="dfe-c-page-title__caption">WI-@(ViewBag.WorkIdShort ?? "") · @(work?.Title) · @riRef</div>
        <h1>@kriRef — @Model.Name</h1>
    </div>

    <div class="dfe-c-grid-row">
        <div class="dfe-c-grid-col dfe-c-grid-col--two-thirds">
            <dl class="dfe-c-summary-list dfe-c-mb-4">
                <div class="dfe-c-summary-list__row">
                    <dt class="dfe-c-summary-list__key">What is measured</dt>
                    <dd class="dfe-c-summary-list__value">@(Model.WhatIsMeasured ?? "—")</dd>
                </div>
                <div class="dfe-c-summary-list__row">
                    <dt class="dfe-c-summary-list__key">Threshold / target</dt>
                    <dd class="dfe-c-summary-list__value">@(Model.ThresholdDescription ?? "—")</dd>
                </div>
                <div class="dfe-c-summary-list__row">
                    <dt class="dfe-c-summary-list__key">Current value</dt>
                    <dd class="dfe-c-summary-list__value dfe-c-fw-bold">@(Model.CurrentValue ?? "—")</dd>
                </div>
                <div class="dfe-c-summary-list__row">
                    <dt class="dfe-c-summary-list__key">Status</dt>
                    <dd class="dfe-c-summary-list__value">@Model.Status</dd>
                </div>
                <div class="dfe-c-summary-list__row">
                    <dt class="dfe-c-summary-list__key">Measurement frequency</dt>
                    <dd class="dfe-c-summary-list__value">@(Model.MeasurementFrequency ?? "—")</dd>
                </div>
                <div class="dfe-c-summary-list__row">
                    <dt class="dfe-c-summary-list__key">Responsible</dt>
                    <dd class="dfe-c-summary-list__value">@(Model.ResponsibleUser?.Name ?? Model.ResponsibleUser?.Email ?? "—")</dd>
                </div>
                <div class="dfe-c-summary-list__row">
                    <dt class="dfe-c-summary-list__key">Next review date</dt>
                    <dd class="dfe-c-summary-list__value">@(Model.NextReviewDate?.ToString("d MMM yyyy") ?? "—")</dd>
                </div>
                <div class="dfe-c-summary-list__row">
                    <dt class="dfe-c-summary-list__key">Action if breached</dt>
                    <dd class="dfe-c-summary-list__value">@(Model.BreachAction ?? "—")</dd>
                </div>
                @if (Model.ThresholdDate is DateTime th)
                {
                    <div class="dfe-c-summary-list__row">
                        <dt class="dfe-c-summary-list__key">Threshold date</dt>
                        <dd class="dfe-c-summary-list__value">@th.ToString("d MMM yyyy")</dd>
                    </div>
                }
            </dl>

            <div class="dfe-c-button dfe-c-button--primary-group govuk-!-margin-bottom-8">
                <a href="@Url.Action("KriUpdate", "ModernWork", new { workId, riskOrIssueId = Model.WorkItemRiskOrIssueId, kriId = Model.Id })" class="dfe-c-button dfe-c-button--primary">Provide update</a>
                <a href="@backRiskIssueHref" class="dfe-c-button dfe-c-button--secondary">Back to @(isIssue ? "issue" : "risk")</a>
            </div>

            <h2 class="dfe-c-heading-m">Update history</h2>
            @if (Model.Updates?.Any() == true)
            {
                <div class="dfe-c-mt-3">
                    <table class="">
                        <thead class="">
                            <tr class="">
                                <th scope="col" class="">Date</th>
                                <th scope="col" class="">Update</th>
                                <th scope="col" class="">Status</th>
                                <th scope="col" class="">Value</th>
                            </tr>
                        </thead>
                        <tbody class="">
                            @foreach (var u in Model.Updates.OrderByDescending(x => x.UpdatedAt))
                            {
                                <tr class="">
                                    <td class="">@u.UpdatedAt.ToString("d MMM yyyy")</td>
                                    <td class="">@(u.ProximityUpdate ?? u.ActionsTaken ?? "—")</td>
                                    <td class="">@u.Status</td>
                                    <td class="dfe-c-fw-bold">@(u.MeasuredValue ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="dfe-c-body muted">No updates recorded yet.</p>
            }
        </div>
    </div>
</div>
