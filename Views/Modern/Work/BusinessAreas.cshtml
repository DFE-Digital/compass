@using Compass.Models
@using Compass.Models.Modern.Work
@{
    ViewData["Title"] = "Business areas";
    var businessAreas = (List<BusinessAreaLookup>)ViewBag.BusinessAreas ?? new List<BusinessAreaLookup>();
    var workCountByBusinessAreaId = (Dictionary<int, int>)ViewBag.WorkCountByBusinessAreaId ?? new Dictionary<int, int>();
    var workItemsByBusinessAreaId = ViewBag.WorkItemsByBusinessAreaId as Dictionary<int, List<WorkItem>> ?? new Dictionary<int, List<WorkItem>>();
    var search = ViewBag.Search as string;
    var workItemsFilter = ViewBag.WorkItemsFilter as string ?? "all";
    var countBeforeWorkFilter = ViewBag.CountBeforeWorkFilter as int?;
    var showUnassignedPanel = ViewBag.ShowUnassignedPanel as bool? ?? false;
    var unassignedWorkItems = ViewBag.UnassignedWorkItems as List<WorkItem> ?? new List<WorkItem>();
    var unassignedCount = ViewBag.UnassignedCount as int? ?? unassignedWorkItems.Count;
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Business areas</li>
}

<div id="sc-work-business-areas" class="modern-work-page">
 <div class="dfe-c-mb-3">
 <div class="dfe-c-page-title" style="margin:0;">
 <div class="dfe-c-page-title__caption">Work</div>
 <h1 class="dfe-c-page-title__heading">Business areas</h1>
 <p class="dfe-c-page-title__lede">Each work item is assigned to one business area. Expand a business area to see its work items.</p>
    </div>
  </div>

 <form method="get" action="@Url.Action("BusinessAreas", "ModernWork")" id="business-areas-search-form" class="dfe-c-mb-3">
    <div id="search-and-filter">
 <div class="filter-toolbar">
 <div class="filter-toolbar__search-wrap">
 <input type="search" name="search" id="business-areas-register-search" value="@search" placeholder="Search business areas…" class="filter-search" autocomplete="off" aria-label="Search business areas" />
 <button type="submit" class="govuk-button govuk-button--secondary filter-toolbar__search-submit">Search</button>
        </div>
 <button type="button" class="filter-toggle-btn" id="business-areas-filter-btn" aria-expanded="false" aria-controls="business-areas-filter-panel">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="flex-shrink:0;" aria-hidden="true"><path d="M1 3h14v1.5l-5 5V14l-4-2V9.5L1 4.5V3z"></path></svg>
 <span class="filter-toggle-label">Filter</span>
        </button>
      </div>
 <div class="filter-panel" id="business-areas-filter-panel">
        <div>
          <label for="business-areas-filter-workitems">Work items</label>
 <select name="workItems" id="business-areas-filter-workitems" class="govuk-select">
            @if (workItemsFilter == "all")
            {
              <option value="all" selected>All business areas</option>
            }
            else
            {
              <option value="all">All business areas</option>
            }
            @if (workItemsFilter == "with")
            {
              <option value="with" selected>With linked work</option>
            }
            else
            {
              <option value="with">With linked work</option>
            }
            @if (workItemsFilter == "without")
            {
              <option value="without" selected>No linked work</option>
            }
            else
            {
              <option value="without">No linked work</option>
            }
          </select>
        </div>
 <div class="filter-panel__actions">
 <button type="submit" class="govuk-button govuk-button--primary">Apply</button>
 <a href="@Url.Action("BusinessAreas", "ModernWork")" class="govuk-button govuk-button--secondary">Clear filters</a>
        </div>
      </div>
    </div>
  </form>

  @{
    var hasBaPanels = businessAreas != null && businessAreas.Any();
    var hasAnyPanel = hasBaPanels || showUnassignedPanel;
  }
  @if (!hasAnyPanel)
  {
 <div class="dfe-c-body dfe-c-text-muted">
      @if (countBeforeWorkFilter is > 0)
      {
        <text>No business areas match the work items filter. Try changing the filter or </text>
        <a href="@Url.Action("BusinessAreas", "ModernWork", new { search })">clear filters</a><text>.</text>
      }
      else if (!string.IsNullOrWhiteSpace(search))
      {
        <text>No business areas match your search.</text>
      }
      else
      {
        <text>No business areas defined. Add business areas in Admin.</text>
      }
    </div>
  }
  else
  {
 <div class="bypriority-bulk-bar">
 <button type="button" class="govuk-button govuk-button--secondary" id="business-areas-bulk-toggle" aria-label="Open all sections">Open all</button>
    </div>
 <div class="bypriority-group-stack dfe-c-mb-3" id="business-areas-stack">
      @foreach (var b in businessAreas)
      {
        var count = workCountByBusinessAreaId.TryGetValue(b.Id, out var c) ? c : 0;
        var groupItems = workItemsByBusinessAreaId.TryGetValue(b.Id, out var items) ? items : new List<WorkItem>();
 <details class="dfe-c-collapsible bypriority-group">
 <summary class="dfe-c-collapsible__trigger">
 <span class="dfe-c-collapsible__icon" aria-hidden="true"></span>
            <span>@b.Name</span>
 <span class="dfe-c-collapsible__status"><span class="govuk-tag govuk-tag--grey">@count work item@(count == 1 ? "" : "s")</span></span>
          </summary>
 <div class="dfe-c-collapsible__body">
            @if (!string.IsNullOrEmpty(b.Description))
            {
 <p class="dfe-c-body-s dfe-c-text-muted" style="margin-bottom:1rem;">@b.Description</p>
            }
            @if (groupItems.Any())
            {
 <div class="dfe-c-table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th scope="col">Work item</th>
                      <th scope="col">Business area</th>
                      <th scope="col">Directorate</th>
                      <th scope="col">Priority</th>
                      <th scope="col">RAG</th>
                      <th scope="col">Primary contact</th>
                      <th scope="col">Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    @await Html.PartialAsync("_ByPriorityWorkRows", groupItems)
                  </tbody>
                </table>
              </div>
            }
            else
            {
 <p class="dfe-c-body-s muted dfe-c-m-0">No work items assigned to this business area.</p>
            }
          </div>
        </details>
      }
      @if (showUnassignedPanel)
      {
 <details class="dfe-c-collapsible bypriority-group">
 <summary class="dfe-c-collapsible__trigger">
 <span class="dfe-c-collapsible__icon" aria-hidden="true"></span>
            <span>No business area assigned</span>
 <span class="dfe-c-collapsible__status"><span class="govuk-tag govuk-tag--grey">@unassignedCount work item@(unassignedCount == 1 ? "" : "s")</span></span>
          </summary>
 <div class="dfe-c-collapsible__body">
 <p class="dfe-c-body-s dfe-c-text-muted" style="margin-bottom:1rem;">Work items without a business area set on the record.</p>
            @if (unassignedWorkItems.Any())
            {
 <div class="dfe-c-table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th scope="col">Work item</th>
                      <th scope="col">Business area</th>
                      <th scope="col">Directorate</th>
                      <th scope="col">Priority</th>
                      <th scope="col">RAG</th>
                      <th scope="col">Primary contact</th>
                      <th scope="col">Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    @await Html.PartialAsync("_ByPriorityWorkRows", unassignedWorkItems)
                  </tbody>
                </table>
              </div>
            }
          </div>
        </details>
      }
    </div>
 <p class="dfe-c-body-s dfe-c-text-muted dfe-c-mt-2">
      @businessAreas.Count business area@(businessAreas.Count == 1 ? "" : "s")
      @if (showUnassignedPanel)
      {
        <text> · @unassignedCount work item@(unassignedCount == 1 ? "" : "s") with no business area</text>
      }
    </p>
  }
</div>

@section Styles {
<style>
  .bypriority-bulk-bar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 0.75rem;
  }
  .bypriority-group-stack .bypriority-group { margin-bottom: 0.75rem; }
  .bypriority-group-stack .dfe-c-collapsible__trigger { align-items: center; justify-content: flex-start; gap: 0.5rem; flex-wrap: wrap; }
  #sc-work-business-areas details.bypriority-group .dfe-c-collapsible__icon {
    font-size: 0;
    line-height: 0;
    overflow: hidden;
  }
  #sc-work-business-areas details.bypriority-group .dfe-c-collapsible__icon::before {
    content: '+';
    font-size: 1rem;
    line-height: 1;
    font-weight: 700;
    color: var(--navy);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }
  #sc-work-business-areas details.bypriority-group[open] .dfe-c-collapsible__icon::before {
    content: '\2212';
  }
</style>
}

@section Scripts {
<script nonce="@Context.Items["Nonce"]">
(function() {
  function initBulkToggle(stackId, btnId) {
    var stack = document.getElementById(stackId);
    var btn = document.getElementById(btnId);
    if (!stack || !btn) return;
    function getDetails() {
      return stack.querySelectorAll('details.bypriority-group');
    }
    function allExpanded() {
      var ds = getDetails();
      if (!ds.length) return false;
      for (var i = 0; i < ds.length; i++) {
        if (!ds[i].open) return false;
      }
      return true;
    }
    function sync() {
      var ds = getDetails();
      if (!ds.length) {
        btn.style.display = 'none';
        return;
      }
      btn.style.display = '';
      if (allExpanded()) {
        btn.textContent = 'Close all';
        btn.setAttribute('aria-label', 'Close all sections');
      } else {
        btn.textContent = 'Open all';
        btn.setAttribute('aria-label', 'Open all sections');
      }
    }
    btn.addEventListener('click', function() {
      var ds = getDetails();
      var expand = !allExpanded();
      for (var i = 0; i < ds.length; i++) {
        ds[i].open = expand;
      }
      sync();
    });
    getDetails().forEach(function(d) {
      d.addEventListener('toggle', sync);
    });
    sync();
  }

  document.addEventListener('DOMContentLoaded', function() {
    initBulkToggle('business-areas-stack', 'business-areas-bulk-toggle');
  });
})();
</script>
}
