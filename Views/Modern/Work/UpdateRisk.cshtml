@model Compass.Models.Modern.Work.WorkItemRiskOrIssue
@using Compass.Models.Modern.Work
@{
    var work = ViewBag.WorkItem as WorkItem;
    var workId = Model.WorkItemId;
    var milestones = ViewBag.Milestones as List<Milestone> ?? new List<Milestone>();
    var directorates = ViewBag.DirectorateOptions as List<RiskIssueNamedIntOption> ?? new List<RiskIssueNamedIntOption>();
    var riRef = "RI-" + Model.ReferenceNumber.ToString("D5");
    var workIdShort = ViewBag.WorkIdShort as string ?? workId.ToString("D8");
    ViewData["Title"] = "Update risk — " + riRef;
}
@section Breadcrumbs {
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Detail", "ModernWork", new { id = workId })">@(work?.Title ?? "Work")</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.RouteUrl("risks-issues-section", new { action = "RiskDetail", id = Model.Id, workId })">@riRef</a></li>
    <li class="dfe-c-breadcrumb__item" aria-current="page">Update risk</li>
}

<div id="sc-work-updaterisk">
  @await Html.PartialAsync("_WorkItemChrome", work)

  <div class="dfe-c-page-title">
    <div class="dfe-c-page-title__caption">WI-@workIdShort · @(work?.Title) · @riRef</div>
    <h1>Update risk</h1>
  </div>

  <form method="post" action="@Url.Action("UpdateRisk", "ModernWork", new { workId, id = Model.Id })" class="dfe-c-card dfe-c-card--plain" style="max-width:720px;">
    @Html.AntiForgeryToken()
    <fieldset>
      <legend style="font-size:20px;border-bottom:3px solid #003a69;padding-bottom:10px;margin-bottom:20px;width:100%">@riRef — @Model.Title</legend>

      <div class="fg">
        <label for="Status">Status</label>
        <select id="Status" name="Status" class="">
          <option value="Open" selected="@(Model.Status == "Open")">Open</option>
          <option value="Mitigating" selected="@(Model.Status == "Mitigating")">Mitigating</option>
          <option value="Escalated" selected="@(Model.Status == "Escalated")">Escalated</option>
          <option value="Closed" selected="@(Model.Status == "Closed")">Closed</option>
        </select>
      </div>
      <div class="fg">
        <label for="Priority">Priority</label>
        <select id="Priority" name="Priority" class="">
          <option value="High" selected="@(Model.Priority == "High")">High</option>
          <option value="Medium" selected="@(Model.Priority == "Medium")">Medium</option>
          <option value="Low" selected="@(Model.Priority == "Low")">Low</option>
        </select>
      </div>
      <div class="fg">
        <label for="Tier">Tier</label>
        <select id="Tier" name="Tier" class="dfe-c-width-10">
          <option value="">— Select tier —</option>
          <option value="Tier 1" selected="@(string.Equals(Model.Tier, "Tier 1", StringComparison.OrdinalIgnoreCase))">Tier 1</option>
          <option value="Tier 2" selected="@(string.Equals(Model.Tier, "Tier 2", StringComparison.OrdinalIgnoreCase))">Tier 2</option>
          <option value="Tier 3" selected="@(string.Equals(Model.Tier, "Tier 3", StringComparison.OrdinalIgnoreCase))">Tier 3</option>
        </select>
      </div>
      <div class="fg">
        <label for="DirectorateId">Directorate <span style="color:var(--red)">*</span></label>
        <select id="DirectorateId" name="DirectorateId" class="dfe-c-width-full" required>
          <option value="">— Select —</option>
          @foreach (var d in directorates)
          {
            <option value="@d.Id" selected="@(Model.DirectorateId == d.Id)">@d.Name</option>
          }
        </select>
      </div>
      <div class="fg user-picker-wrapper user-picker-wrapper--full-width">
        @await Html.PartialAsync("_UserPicker", new UserPickerViewModel
        {
          FieldName = "OwnerUserId",
          Label = "Owner",
          Hint = "Who is responsible for managing this risk?",
          DefaultSummaryText = "No user selected.",
          DefaultUserId = Model.OwnerUserId,
          DefaultName = ViewBag.OwnerName as string,
          DefaultEmail = ViewBag.OwnerEmail as string
        })
      </div>
      <div class="fg">
        <label for="MitigationOrAction">Mitigation</label>
        <textarea id="MitigationOrAction" name="MitigationOrAction" rows="4" placeholder="What is being done to mitigate this risk?">@Model.MitigationOrAction</textarea>
      </div>
      <div class="fg">
        <label for="ImpactOnDelivery">Impact on delivery</label>
        <textarea id="ImpactOnDelivery" name="ImpactOnDelivery" rows="3">@Model.ImpactOnDelivery</textarea>
      </div>
      <div class="fg">
        <label for="Likelihood">Likelihood</label>
        <select id="Likelihood" name="Likelihood" class="">
          <option value="">— Select —</option>
          <option value="Unlikely" selected="@(Model.Likelihood == "Unlikely")">Unlikely</option>
          <option value="Possible" selected="@(Model.Likelihood == "Possible")">Possible</option>
          <option value="Likely" selected="@(Model.Likelihood == "Likely")">Likely</option>
          <option value="Almost certain" selected="@(Model.Likelihood == "Almost certain")">Almost certain</option>
        </select>
      </div>
      <div class="fg">
        <label for="Proximity">Proximity</label>
        <input type="text" id="Proximity" name="Proximity" value="@Model.Proximity" placeholder="When might it materialise?" />
      </div>
      <div class="fg">
        <label for="LinkedMilestoneId">Linked milestone</label>
        <select id="LinkedMilestoneId" name="LinkedMilestoneId" class="">
          <option value="">— None —</option>
          @foreach (var m in milestones)
          {
            <option value="@m.Id" selected="@(Model.LinkedMilestoneId == m.Id)">@m.Name</option>
          }
        </select>
      </div>
      <div class="dfe-c-button-row" style="margin-top:20px;">
        <button type="submit" class="dfe-c-button dfe-c-button--primary">Save changes</button>
        <a href="@Url.Action("RiskDetail", "ModernWork", new { workId, id = Model.Id })" class="dfe-c-button dfe-c-button--secondary">Cancel</a>
      </div>
    </fieldset>
  </form>
</div>
