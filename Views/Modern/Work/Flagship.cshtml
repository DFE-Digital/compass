@model IEnumerable<Compass.Models.Modern.Work.WorkItem>
@using Compass.Models.Modern.Work
@using Compass.ViewModels.Modern
@{
    ViewData["Title"] = "Flagship Work";
    var items = Model?.ToList() ?? new List<WorkItem>();
    var count = items.Count;
    var portfolioNames = ViewBag.PortfolioNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var workStatusOptions = (List<LookupOption>)ViewBag.WorkStatusOptions ?? new List<LookupOption>();
    var portfolios = (List<Portfolio>)ViewBag.Portfolios ?? new List<Portfolio>();
    var directorates = (List<Directorate>)ViewBag.Directorates ?? new List<Directorate>();
    var portfolioCount = portfolios.Count;
    var filterPortfolioId = ViewBag.FilterPortfolioId as int?;
    var filterDirectorateId = ViewBag.FilterDirectorateId as int?;
    var filterSearch = ViewBag.Search as string;
    var filterStatus = ViewBag.StatusFilter as string;
    var hasActiveFilters = !string.IsNullOrEmpty(filterStatus) || filterPortfolioId != null || filterDirectorateId != null || !string.IsNullOrEmpty(filterSearch);
    var filterCount = (filterPortfolioId != null ? 1 : 0) + (filterDirectorateId != null ? 1 : 0) + (!string.IsNullOrEmpty(filterStatus) ? 1 : 0) + (!string.IsNullOrEmpty(filterSearch) ? 1 : 0);
    var phaseNames = ViewBag.PhaseNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var priorityNames = ViewBag.PriorityNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var businessAreaById = ViewBag.BusinessAreaNameByProjectId as Dictionary<int, string> ?? new Dictionary<int, string>();
    string DirSummary(WorkItem w) =>
        w.Directorates?.Any() == true
            ? string.Join(", ", w.Directorates.Select(d => d.Division?.Name).Where(n => !string.IsNullOrEmpty(n)).Distinct().OrderBy(n => n))
            : "—";
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Flagship work</li>
}

<div id="sc-work-flagship" class="modern-work-page">
@{
  var flagshipLede = await Html.PartialAsync("_GovukBodyParagraph", "Delivery work flagged as flagship — use search and filters to narrow the list.");
}
@await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
  Caption = "Work",
  Title = "Flagship work",
  Lede = flagshipLede
})

 <form method="get" action="@Url.Action("Flagship", "ModernWork")" id="flagship-filter-form" class="dfe-c-mb-3">
    <div id="search-and-filter">
 <div class="filter-toolbar">
 <div class="filter-toolbar__search-wrap">
 <input type="search" name="search" id="flagship-register-search" value="@filterSearch" placeholder="Search flagship work…" class="filter-search" autocomplete="off" aria-label="Search flagship work" />
 <button type="submit" class="govuk-button govuk-button--secondary filter-toolbar__search-submit">Search</button>
        </div>
 <button type="button" class="filter-toggle-btn" id="flagship-filter-btn" aria-expanded="false" aria-controls="flagship-filter-panel">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="flex-shrink:0;" aria-hidden="true"><path d="M1 3h14v1.5l-5 5V14l-4-2V9.5L1 4.5V3z"></path></svg>
 <span class="filter-toggle-label">Filter</span>
 @if (hasActiveFilters) { <span class="filter-toggle-badge" aria-label="Active filters">@filterCount</span> }
        </button>
      </div>
 <div class="filter-panel" id="flagship-filter-panel">
 <div class="filter-panel__grid">
          <div>
            <label for="filter-portfolio">Portfolio</label>
 <select name="portfolioId" id="filter-portfolio" class="govuk-select">
              <option value="">All portfolios (@portfolioCount)</option>
              @foreach (var p in portfolios)
              {
                if (filterPortfolioId == p.Id)
                {
                  <option value="@p.Id" selected>@p.Name</option>
                }
                else
                {
                  <option value="@p.Id">@p.Name</option>
                }
              }
            </select>
          </div>
          <div>
            <label for="filter-directorate">Directorate</label>
 <select name="directorateId" id="filter-directorate" class="govuk-select">
              <option value="">All directorates</option>
              @foreach (var d in directorates)
              {
                if (filterDirectorateId == d.Id)
                {
                  <option value="@d.Id" selected>@d.Name</option>
                }
                else
                {
                  <option value="@d.Id">@d.Name</option>
                }
              }
            </select>
          </div>
          <div>
            <label for="filter-status">Status</label>
 <select name="status" id="filter-status" class="govuk-select">
              <option value="">All statuses</option>
              @foreach (var opt in workStatusOptions)
              {
                if (filterStatus == opt.Value)
                {
                  <option value="@opt.Value" selected>@opt.Name</option>
                }
                else
                {
                  <option value="@opt.Value">@opt.Name</option>
                }
              }
            </select>
          </div>
        </div>
 <div class="filter-panel__actions">
 <button type="submit" class="govuk-button">Apply filters</button>
 <a href="@Url.Action("Flagship", "ModernWork")" class="govuk-link govuk-link--no-visited-state">Clear filters</a>
        </div>
      </div>
    </div>
  </form>

  @if (count == 0)
  {
 <p class="dfe-c-text-muted">No flagship work items match these filters. Clear filters or mark a work item as flagship on its overview to include it here.</p>
  }
  else
  {
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
      <table class="govuk-table modern-work-table" id="work-flagship-table">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Work item</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Business area</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Directorate</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Priority</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">RAG</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Primary contact</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Status</button>
        </th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          @foreach (var w in items)
          {
            var latestRag = w.RagHistory?.OrderByDescending(r => r.UpdatedAt).FirstOrDefault();
            var phaseName = w.DeliveryPhaseId.HasValue && phaseNames.TryGetValue(w.DeliveryPhaseId.Value, out var ph) ? ph : null;
            var priorityName = w.PriorityId.HasValue && priorityNames.TryGetValue(w.PriorityId.Value, out var pr) ? pr : null;
            var pcName = ViewBag.PrimaryContactById is Dictionary<int, string> pcMap && pcMap.TryGetValue(w.Id, out var pc) ? pc : "—";
            var baName = businessAreaById.TryGetValue(w.Id, out var ban) ? ban : "—";
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">
 <a href="@Url.Action("Detail", "ModernWork", new { id = w.Id })" class="govuk-link govuk-link--no-visited-state">@w.Title</a>
 <div class="govuk-body-s dfe-t-u-text-muted modern-work-table__meta">
 WI-@w.Id.ToString("D8")@if (!string.IsNullOrEmpty(phaseName)) { <span aria-hidden="true"> · </span><span>@phaseName</span> }
                </div>
              </td>
              <td class="dfe-c-body-s">@baName</td>
              <td class="dfe-c-body-s">@DirSummary(w)</td>
              <td class="govuk-table__cell">
                @if (!string.IsNullOrEmpty(priorityName))
                {
 <span class="@WorkBadgeCss.PriorityDfeFrontendBadgeClass(priorityName)">@priorityName.ToUpperInvariant()</span>
                }
                else
                {
 <span class="dfe-c-text-muted">—</span>
                }
              </td>
              <td class="govuk-table__cell">@await Html.PartialAsync("_WorkRagBadge", latestRag)</td>
              <td class="govuk-table__cell">@pcName</td>
 <td class="govuk-table__cell"><span class="@WorkBadgeCss.StatusDfeFrontendBadgeClass(w.Status)">@w.Status</span></td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
</div>
