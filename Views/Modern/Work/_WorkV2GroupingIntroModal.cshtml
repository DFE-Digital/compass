@using Compass.ViewModels.Modern
@model WorkV2GroupingIntroModalModel
@{
  var (storageKey, modalId, title, bodyId) = Model.Kind switch
  {
    WorkV2GroupingIntroKind.Directorates => (
      "compass.work.v2intro.directorates",
      "work-v2-intro-directorates",
      "How to use directorates (new in V2)",
      "work-v2-intro-directorates-desc"),
    WorkV2GroupingIntroKind.BusinessAreas => (
      "compass.work.v2intro.business-areas",
      "work-v2-intro-business-areas",
      "How to use business areas (new in V2)",
      "work-v2-intro-business-areas-desc"),
    WorkV2GroupingIntroKind.ByTheme => (
      "compass.work.v2intro.by-theme",
      "work-v2-intro-by-theme",
      "How to use thematic tags",
      "work-v2-intro-by-theme-desc"),
  };
}
<dialog id="@modalId"
        class="dfe-f-modal govuk-!-margin-0 work-v2-grouping-intro-modal"
        data-module="dfe-f-modal"
        data-work-v2-intro="true"
        data-storage-key="@storageKey"
        aria-labelledby="@(modalId)-title"
        aria-describedby="@bodyId"
        aria-modal="true"
        role="dialog">
  <div class="dfe-f-modal__panel">
    <header class="dfe-f-modal__header">
      <h2 id="@(modalId)-title" class="govuk-heading-m dfe-f-modal__title">@title</h2>
      <button type="button" class="dfe-f-modal__close" data-dfe-modal-close data-work-v2-intro-dismiss aria-label="Close">
        <span class="dfe-f-modal__close-x" aria-hidden="true">×</span>
      </button>
    </header>
    <div class="dfe-f-modal__body" id="@bodyId">
      @if (Model.Kind == WorkV2GroupingIntroKind.Directorates)
      {
        <p class="govuk-body">You can narrow this list to a single directorate or keep <strong>All work items</strong> to see everything together.</p>
        <ul class="govuk-list govuk-list--bullet">
          <li>Open <strong>Filter</strong> and use the <strong>Directorate</strong> dropdown to pick a directorate (or stay on all work items).</li>
          <li>When you are viewing your directorate, use <strong>Make default view</strong> (if shown) so Compass opens this filtered list for you next time.</li>
          <li>Use <strong>Reset view</strong> later if you want to clear that default.</li>
        </ul>
      }
      else if (Model.Kind == WorkV2GroupingIntroKind.ByTheme)
      {
        <p class="govuk-body">You can narrow this list to a single thematic tag or keep <strong>All work items</strong> to see everything together.</p>
        <ul class="govuk-list govuk-list--bullet">
          <li>Open <strong>Filter</strong> and use the <strong>Theme</strong> dropdown to pick a tag (or stay on all work items).</li>
          <li>Use the tabs above the table to switch between active, completed and cancelled work.</li>
        </ul>
      }
      else
      {
        <p class="govuk-body">You can narrow this list to one business area or keep <strong>All work items</strong> to see everything together.</p>
        <ul class="govuk-list govuk-list--bullet">
          <li>Open <strong>Filter</strong> and use the <strong>Business area</strong> dropdown to pick an area (or stay on all work items).</li>
          <li>When you are viewing your business area, use <strong>Make default view</strong> (if shown) so Compass opens this filtered list for you next time.</li>
          <li>Use <strong>Reset view</strong> later if you want to clear that default.</li>
        </ul>
      }
      <p class="govuk-body-s govuk-!-margin-bottom-0" style="color:#505a5f;">This message appears once per browser until you dismiss it.</p>
    </div>
    <footer class="dfe-f-modal__footer">
      <button type="button" class="govuk-button" data-module="govuk-button" data-work-v2-intro-dismiss>Got it</button>
    </footer>
  </div>
</dialog>
