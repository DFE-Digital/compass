@model Compass.Models.Milestone
@{
    var work = ViewBag.WorkItem as Compass.Models.Modern.Work.WorkItem;
    var projectId = Model.ProjectId ?? work?.Id ?? 0;
    ViewData["Title"] = "Add milestone";
    var wiRef = ViewBag.WorkIdShort as string ?? projectId.ToString("D8");
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="/">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Detail", "ModernWork", new { id = projectId })">@(work?.Title ?? "Work")</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Add milestone</li>
}

<div id="sc-work-add-milestone">
  @await Html.PartialAsync("_WorkItemChrome", work)

 <div class="dfe-c-page-title">
 <div class="dfe-c-page-title__caption">WI-@wiRef · @(work?.Title ?? "Work")</div>
 <h1 class="dfe-c-page-title__heading">Add milestone</h1>
 <p class="dfe-c-page-title__lede">Add a milestone with a due date and status. Milestones appear on the work item and in monthly reporting.</p>
  </div>

 <div class="dfe-c-form-layout">
 <div class="dfe-c-form-layout__main">
 <div class="dfe-c-card dfe-c-card--plain">
        <form asp-controller="Project" asp-action="AddMilestone" asp-route-projectId="@projectId" method="post">
          @Html.AntiForgeryToken()

          @if (!ViewData.ModelState.IsValid)
          {
 <div class="dfe-c-error-summary" aria-labelledby="error-summary-title" role="alert" data-module="dfe-c-error-summary">
 <h2 class="dfe-c-error-summary__title" id="error-summary-title">There is a problem</h2>
 <div class="dfe-c-error-summary__body">
 <ul class="dfe-c-list dfe-c-error-summary__list">
                  @foreach (var kv in ViewData.ModelState)
                  {
                    @if (kv.Value?.Errors?.Count > 0)
                    {
                      var fieldId = string.IsNullOrEmpty(kv.Key) ? "name" : kv.Key;
                      @foreach (var err in kv.Value.Errors)
                      {
                        <li><a href="#@fieldId">@err.ErrorMessage</a></li>
                      }
                    }
                  }
                </ul>
              </div>
            </div>
          }

 <div class="form-layout" style="margin-bottom:0">
            <fieldset>
              <legend>Milestone details</legend>

 <div class="dfe-c-form__group @(ViewData.ModelState["name"]?.Errors?.Any() == true ? "dfe-c-form__group--error" : "")">
 <label class="dfe-c-form__label" for="name">Title <span style="color:var(--red)">*</span></label>
                @if (ViewData.ModelState["name"]?.Errors?.Any() == true)
                {
 <span class="dfe-c-form__error">@ViewData.ModelState["name"]?.Errors?.FirstOrDefault()?.ErrorMessage</span>
                }
 <input class="dfe-c-width-full" id="name" name="name" type="text" value="@Model?.Name" maxlength="200" required />
              </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="description">Description</label>
 <textarea class="dfe-c-width-full" id="description" name="description" rows="3">@Model?.Description</textarea>
              </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="dueDate">Due date <span style="color:var(--red)">*</span></label>
 <input class="dfe-c-width-full" id="dueDate" name="dueDate" type="date" value="@Model.DueDate.ToString("yyyy-MM-dd")" required />
              </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="status">Status</label>
 <select class="dfe-c-width-full" id="status" name="status">
                  @{
                    var statusOpts = new (string Value, string Label)[]
                    {
                      ("not_started", "Not started"),
                      ("in_progress", "In progress"),
                      ("on_track", "On track"),
                      ("at_risk", "At risk"),
                      ("delayed", "Delayed"),
                      ("complete", "Complete"),
                      ("cancelled", "Cancelled")
                    };
                  }
                  @foreach (var o in statusOpts)
                  {
                    if (string.Equals(Model.Status, o.Value, StringComparison.OrdinalIgnoreCase))
                    {
                      <option value="@o.Value" selected>@o.Label</option>
                    }
                    else
                    {
                      <option value="@o.Value">@o.Label</option>
                    }
                  }
                </select>
              </div>
            </fieldset>
          </div>

 <div class="dfe-c-button-group">
 <button type="submit" class="govuk-button">Add milestone</button>
 <a href="@Url.Action("Detail", "ModernWork", new { id = projectId, tab = "milestones" })" class="govuk-button govuk-button--secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>

 <div class="dfe-c-form-layout__aside">
 <div class="dfe-c-sidebar">
 <div class="dfe-c-scard">
 <div class="dfe-c-scard__title">Milestones</div>
          <div style="font-size:0.8125rem;color:var(--grey-4);">Use milestones to track key delivery points. Link risks and issues to milestones when they affect a specific date or deliverable.</div>
        </div>
 <div class="dfe-c-scard">
 <div class="dfe-c-scard__title">Status</div>
          <div style="font-size:0.8125rem;color:var(--grey-4);">Keep status up to date so portfolio views and monthly updates reflect reality — especially if a milestone slips or completes early.</div>
        </div>
      </div>
    </div>
  </div>
</div>
