@model Compass.Models.Modern.Work.WorkItemRiskOrIssue
@using Compass.Models.Modern.Work
@{
    var work = ViewBag.WorkItem as WorkItem;
    var milestones = ViewBag.Milestones as List<Milestone> ?? new List<Milestone>();
    var directorates = ViewBag.DirectorateOptions as List<RiskIssueNamedIntOption> ?? new List<RiskIssueNamedIntOption>();
    var riskTierOpts = ViewBag.RiskTierOptions as List<RiskIssueNamedIntOption> ?? new List<RiskIssueNamedIntOption>();
    var sevOpts = ViewBag.IssueSeverityOptions as List<RiskIssueNamedIntOption> ?? new List<RiskIssueNamedIntOption>();
    var priOpts = ViewBag.IssuePriorityOptions as List<RiskIssueNamedIntOption> ?? new List<RiskIssueNamedIntOption>();
    var stOpts = ViewBag.IssueStatusOptions as List<RiskIssueNamedIntOption> ?? new List<RiskIssueNamedIntOption>();
    var issueCatOpts = ViewBag.IssueCategoryOptions as List<RiskIssueNamedIntOption> ?? new List<RiskIssueNamedIntOption>();
    ViewData["Title"] = "Log issue";
    var wiRef = ViewBag.WorkIdShort as string ?? Model.WorkItemId.ToString("D8");
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="/">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Detail", "ModernWork", new { id = Model.WorkItemId })">@(work?.Title ?? "Work")</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Add issue</li>
}

<div id="sc-work-log-issue">
  @await Html.PartialAsync("_WorkItemChrome", ViewBag.WorkItem as WorkItem)

 <div class="dfe-c-page-title">
 <div class="dfe-c-page-title__caption">WI-@wiRef · @(work?.Title ?? "Work")</div>
 <h1 class="dfe-c-page-title__heading">Add issue</h1>
 <p class="dfe-c-page-title__lede">Log an issue that is affecting this work item. An issue is something that has happened or is actively occurring and needs resolution.</p>
  </div>

 <div class="dfe-c-form-layout">
 <div class="dfe-c-form-layout__main">
 <div class="dfe-c-card dfe-c-card--plain">
        <form method="post" action="@Url.Action("LogIssue", "ModernWork", new { id = Model.WorkItemId })">
          @Html.AntiForgeryToken()

          @if (!ViewData.ModelState.IsValid)
          {
 <div class="dfe-c-error-summary" aria-labelledby="error-summary-title" role="alert" data-module="dfe-c-error-summary">
 <h2 class="dfe-c-error-summary__title" id="error-summary-title">There is a problem</h2>
 <div class="dfe-c-error-summary__body">
 <ul class="dfe-c-list dfe-c-error-summary__list">
                  @foreach (var kv in ViewData.ModelState)
                  {
                    @if (kv.Value?.Errors?.Count > 0)
                    {
                      var fieldId = string.IsNullOrEmpty(kv.Key) ? "Title" : kv.Key;
                      @foreach (var err in kv.Value.Errors)
                      {
                        <li><a href="#@fieldId">@err.ErrorMessage</a></li>
                      }
                    }
                  }
                </ul>
              </div>
            </div>
          }

 <div class="form-layout" style="margin-bottom:0">
            <fieldset>
              <legend>Issue details</legend>

 <div class="dfe-c-form__group @(ViewData.ModelState["Title"]?.Errors?.Any() == true ? "dfe-c-form__group--error" : "")">
 <label class="dfe-c-form__label" for="Title">Title <span style="color:var(--red)">*</span></label>
 <span class="dfe-c-form__hint">A short, clear description — e.g. &quot;External vendor delivery delayed&quot;</span>
                @if (ViewData.ModelState["Title"]?.Errors?.Any() == true)
                {
 <span class="dfe-c-form__error">@ViewData.ModelState["Title"]?.Errors?.FirstOrDefault()?.ErrorMessage</span>
                }
 <input class="dfe-c-width-full" id="Title" name="Title" type="text" value="@Model.Title" required />
              </div>

 <div class="dfe-c-form__group @(ViewData.ModelState["Description"]?.Errors?.Any() == true ? "dfe-c-form__group--error" : "")">
 <label class="dfe-c-form__label" for="Description">Description <span style="color:var(--red)">*</span></label>
 <span class="dfe-c-form__hint">What is it? Why has it arisen? What is the context?</span>
                @if (ViewData.ModelState["Description"]?.Errors?.Any() == true)
                {
 <span class="dfe-c-form__error">@ViewData.ModelState["Description"]?.Errors?.FirstOrDefault()?.ErrorMessage</span>
                }
 <textarea class="dfe-c-width-full" id="Description" name="Description" rows="4" required>@Model.Description</textarea>
              </div>

 <div class="dfe-c-form__group @(ViewData.ModelState["ImpactOnDelivery"]?.Errors?.Any() == true ? "dfe-c-form__group--error" : "")">
 <label class="dfe-c-form__label" for="ImpactOnDelivery">Impact on delivery <span style="color:var(--red)">*</span></label>
 <span class="dfe-c-form__hint">What effect does this have on timeline, scope, budget or quality?</span>
                @if (ViewData.ModelState["ImpactOnDelivery"]?.Errors?.Any() == true)
                {
 <span class="dfe-c-form__error">@ViewData.ModelState["ImpactOnDelivery"]?.Errors?.FirstOrDefault()?.ErrorMessage</span>
                }
 <textarea class="dfe-c-width-full" id="ImpactOnDelivery" name="ImpactOnDelivery" rows="3" required>@Model.ImpactOnDelivery</textarea>
              </div>

 <div class="dfe-c-form__group @(ViewData.ModelState["IssueSeverityId"]?.Errors?.Any() == true ? "dfe-c-form__group--error" : "")">
 <label class="dfe-c-form__label" for="IssueSeverityId">Severity <span style="color:var(--red)">*</span></label>
                @if (ViewData.ModelState["IssueSeverityId"]?.Errors?.Any() == true)
                {
 <span class="dfe-c-form__error">@ViewData.ModelState["IssueSeverityId"]?.Errors?.FirstOrDefault()?.ErrorMessage</span>
                }
 <select class="dfe-c-width-full" id="IssueSeverityId" name="IssueSeverityId" required>
                  <option value="">— Select —</option>
                  @foreach (var o in sevOpts)
                  {
                    if (Model.IssueSeverityLookupId == o.Id)
                    {
                      <option value="@o.Id" selected>@o.Name</option>
                    }
                    else
                    {
                      <option value="@o.Id">@o.Name</option>
                    }
                  }
                </select>
              </div>

 <div class="dfe-c-form__group @(ViewData.ModelState["IssuePriorityLookupId"]?.Errors?.Any() == true ? "dfe-c-form__group--error" : "")">
 <label class="dfe-c-form__label" for="IssuePriorityLookupId">Priority <span style="color:var(--red)">*</span></label>
                @if (ViewData.ModelState["IssuePriorityLookupId"]?.Errors?.Any() == true)
                {
 <span class="dfe-c-form__error">@ViewData.ModelState["IssuePriorityLookupId"]?.Errors?.FirstOrDefault()?.ErrorMessage</span>
                }
 <select class="dfe-c-width-full" id="IssuePriorityLookupId" name="IssuePriorityLookupId" required>
                  <option value="">— Select —</option>
                  @foreach (var o in priOpts)
                  {
                    if (Model.IssuePriorityLookupId == o.Id)
                    {
                      <option value="@o.Id" selected>@o.Name</option>
                    }
                    else
                    {
                      <option value="@o.Id">@o.Name</option>
                    }
                  }
                </select>
              </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="IssueStatusLookupId">Status</label>
 <span class="dfe-c-form__hint">Defaults to Open when not specified.</span>
 <select class="dfe-c-width-full" id="IssueStatusLookupId" name="IssueStatusLookupId">
                  <option value="">— Default (Open) —</option>
                  @foreach (var o in stOpts)
                  {
                    if (Model.IssueStatusLookupId == o.Id)
                    {
                      <option value="@o.Id" selected>@o.Name</option>
                    }
                    else
                    {
                      <option value="@o.Id">@o.Name</option>
                    }
                  }
                </select>
              </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="IssueCategoryId">Category</label>
 <select class="dfe-c-width-full" id="IssueCategoryId" name="IssueCategoryId">
                  <option value="">— Select —</option>
                  @foreach (var o in issueCatOpts)
                  {
                    if (Model.IssueCategoryLookupId == o.Id)
                    {
                      <option value="@o.Id" selected>@o.Name</option>
                    }
                    else
                    {
                      <option value="@o.Id">@o.Name</option>
                    }
                  }
                </select>
              </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="Tier">Tier</label>
 <span class="dfe-c-form__hint">Aligned to your organisation&apos;s escalation tiers.</span>
 <select class="dfe-c-width-full" id="Tier" name="Tier">
                  <option value="">— Select tier —</option>
                  @foreach (var t in riskTierOpts)
                  {
                    if (string.Equals(Model.Tier, t.Name, StringComparison.OrdinalIgnoreCase))
                    {
                      <option value="@t.Name" selected>@t.Name</option>
                    }
                    else
                    {
                      <option value="@t.Name">@t.Name</option>
                    }
                  }
                </select>
              </div>

 <div class="dfe-c-form__group @(ViewData.ModelState["DirectorateId"]?.Errors?.Any() == true ? "dfe-c-form__group--error" : "")">
 <label class="dfe-c-form__label" for="DirectorateId">Directorate <span style="color:var(--red)">*</span></label>
 <span class="dfe-c-form__hint">DDT directorate for reporting.</span>
                @if (ViewData.ModelState["DirectorateId"]?.Errors?.Any() == true)
                {
 <span class="dfe-c-form__error">@ViewData.ModelState["DirectorateId"]?.Errors?.FirstOrDefault()?.ErrorMessage</span>
                }
 <select class="dfe-c-width-full" id="DirectorateId" name="DirectorateId" required>
                  <option value="">— Select directorate —</option>
                  @foreach (var d in directorates)
                  {
                    if (Model.DirectorateId == d.Id)
                    {
                      <option value="@d.Id" selected>@d.Name</option>
                    }
                    else
                    {
                      <option value="@d.Id">@d.Name</option>
                    }
                  }
                </select>
              </div>

 <div class="dfe-c-form__group user-picker-wrapper user-picker-wrapper--full-width">
                @await Html.PartialAsync("_UserPicker", new UserPickerViewModel
                {
                  FieldName = "OwnerUserId",
                  Label = "Owner",
                  Hint = "Who is responsible for resolving this issue? Search by name or email.",
                  DefaultSummaryText = "No user selected.",
                  DefaultUserId = Model.OwnerUserId,
                  DefaultName = ViewBag.OwnerName as string,
                  DefaultEmail = ViewBag.OwnerEmail as string
                })
              </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="TargetResolutionDate">Target resolution date</label>
 <input class="dfe-c-width-full" id="TargetResolutionDate" name="TargetResolutionDate" type="date" value="@(Model.TargetResolutionDate?.ToString("yyyy-MM-dd"))" />
              </div>

 <div class="dfe-c-form__group @(ViewData.ModelState["MitigationOrAction"]?.Errors?.Any() == true ? "dfe-c-form__group--error" : "")">
 <label class="dfe-c-form__label" for="MitigationOrAction">Action plan <span style="color:var(--red)">*</span></label>
 <span class="dfe-c-form__hint">What is being done to resolve this issue?</span>
                @if (ViewData.ModelState["MitigationOrAction"]?.Errors?.Any() == true)
                {
 <span class="dfe-c-form__error">@ViewData.ModelState["MitigationOrAction"]?.Errors?.FirstOrDefault()?.ErrorMessage</span>
                }
 <textarea class="dfe-c-width-full" id="MitigationOrAction" name="MitigationOrAction" rows="3" required>@Model.MitigationOrAction</textarea>
              </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="LinkedMilestoneId">Linked milestone</label>
 <span class="dfe-c-form__hint">If this issue directly affects a milestone, link it here.</span>
 <select class="dfe-c-width-full" id="LinkedMilestoneId" name="LinkedMilestoneId">
                  <option value="">— None —</option>
                  @foreach (var m in milestones)
                  {
                    if (Model.LinkedMilestoneId == m.Id)
                    {
                      <option value="@m.Id" selected>@m.Name</option>
                    }
                    else
                    {
                      <option value="@m.Id">@m.Name</option>
                    }
                  }
                </select>
              </div>
            </fieldset>
          </div>

 <div class="dfe-c-button-group">
 <button type="submit" class="govuk-button">Add issue</button>
 <a href="@Url.Action("Detail", "ModernWork", new { id = Model.WorkItemId })#wd-risks" class="govuk-button govuk-button--secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>

 <div class="dfe-c-form-layout__aside">
 <div class="dfe-c-sidebar">
 <div class="dfe-c-scard">
 <div class="dfe-c-scard__title">Risk vs issue</div>
          <div style="font-size:0.8125rem;color:var(--grey-4);">An <strong>issue</strong> is something that has happened or is happening now and needs resolution. A <strong>risk</strong> is a potential future problem you are monitoring.</div>
        </div>
 <div class="dfe-c-scard">
 <div class="dfe-c-scard__title">Priority guidance</div>
          <div style="font-size:0.8125rem;color:var(--grey-4);">Use High when delivery, compliance or reputation is at immediate risk. Medium when milestones or quality are affected. Low when impact is limited and a plan is in place.</div>
        </div>
 <div class="dfe-c-scard">
 <div class="dfe-c-scard__title">Action plan</div>
          <div style="font-size:0.8125rem;color:var(--grey-4);">Be specific about owners, dates and dependencies. This helps portfolio reviews and escalation.</div>
        </div>
      </div>
    </div>
  </div>
</div>
