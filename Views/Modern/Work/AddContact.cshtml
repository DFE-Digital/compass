@model Compass.Models.Modern.Work.WorkItemContact
@{
    var work = ViewBag.WorkItem as Compass.Models.Modern.Work.WorkItem;
    var roleTypes = (List<Compass.Models.Modern.Work.ContactRoleType>)ViewBag.ContactRoleTypes ?? new List<Compass.Models.Modern.Work.ContactRoleType>();
    ViewData["Title"] = "Add contact";
    var userPicker = new Compass.Models.UserPickerViewModel { FieldName = "AppUserId", Label = "User", DefaultSummaryText = "No user selected." };
}
@section Breadcrumbs {
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="/">Home</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Detail", "ModernWork", new { id = Model.WorkItemId })">@(work?.Title ?? "Work")</a></li>
    <li class="dfe-c-breadcrumb__item" aria-current="page">Add contact</li>
}

<div id="sc-work-addcontact">
  @await Html.PartialAsync("_WorkItemChrome", ViewBag.WorkItem as Compass.Models.Modern.Work.WorkItem)
  <h2 class="dfe-c-heading-m dfe-c-mt-0">Add contact</h2>
    <p class="dfe-c-body muted dfe-c-mb-3">Add a contact with a role (SRO, Service Owner, etc.) for this work item.</p>

<form asp-action="AddContact" asp-route-id="@Model.WorkItemId" method="post" class="dfe-c-mb-4">
  @Html.AntiForgeryToken()
  @if (ViewBag.ReturnToEditPeople == true) { <input type="hidden" name="returnTo" value="EditPeople" /> }

  <div class="dfe-c-form__group">
    <label class="dfe-c-form__label" asp-for="ContactRoleTypeId">Contact role</label>
    <select class="dfe-c-width-20" asp-for="ContactRoleTypeId">
      <option value="0">— Select role —</option>
      @foreach (var rt in roleTypes)
      {
        <option value="@rt.Id">@rt.Name</option>
      }
    </select>
  </div>

  @await Html.PartialAsync("_UserPicker", userPicker)

  <button type="submit" class="dfe-c-button dfe-c-button--primary">Add contact</button>
  <a href="@Url.Action("Detail", "ModernWork", new { id = Model.WorkItemId })" class="dfe-c-button dfe-c-button--secondary">Cancel</a>
</form>
</div>
