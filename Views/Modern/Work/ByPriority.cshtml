@section Styles {
<style>
  .dfe-f-toggle-group__items.bypriority-group-stack .bypriority-group.dfe-f-toggle { margin-bottom: 0.75rem; }
  .mr-toggle-panel__meta {
    margin-left: auto;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  /* Align GOV.UK table with Compass2 register styling inside bordered wrap */
  #sc-work-bypriority .dfe-f-table-wrapper .govuk-table {
    margin-bottom: 0;
    width: 100%;
  }
</style>
}

@section Scripts {
<script nonce="@Context.Items["Nonce"]">
(function() {
  function filterTable() {
    var search = (document.getElementById('bypriority-search') && document.getElementById('bypriority-search').value) || '';
    var term = (search || '').toLowerCase().trim();
    document.querySelectorAll('#sc-work-bypriority .bypriority-work-row').forEach(function(tr) {
      var text = (tr.getAttribute('data-searchable') || '').toLowerCase();
      tr.style.display = (!term || text.indexOf(term) !== -1) ? '' : 'none';
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    var el = document.getElementById('bypriority-search');
    if (el) { el.addEventListener('input', filterTable); el.addEventListener('keyup', filterTable); if ((el.value || '').trim()) filterTable(); }
  });
})();
</script>
}
