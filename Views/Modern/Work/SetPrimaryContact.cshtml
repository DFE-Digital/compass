@model Compass.Models.Modern.Work.SetPrimaryContactViewModel
@{
    var work = ViewBag.WorkItem as Compass.Models.Modern.Work.WorkItem;
    var currentName = ViewBag.CurrentPrimaryName as string;
    ViewData["Title"] = "Set primary contact";
    var userPicker = new Compass.Models.UserPickerViewModel
    {
        FieldName = "AppUserId",
        Label = "Primary contact",
        DefaultSummaryText = "No user selected.",
        DefaultUserId = Model.AppUserId > 0 ? Model.AppUserId : null,
        DefaultName = currentName,
        DefaultEmail = ViewBag.PrimaryContactSubtitle as string
    };
}
@section Breadcrumbs {
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="/">Home</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Detail", "ModernWork", new { id = Model.WorkItemId })">@(work?.Title ?? "Work")</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("EditPeople", "ModernWork", new { id = Model.WorkItemId })">Edit people</a></li>
    <li class="dfe-c-breadcrumb__item" aria-current="page">Set primary contact</li>
}

<div id="sc-work-setprimarycontact">
  @await Html.PartialAsync("_WorkItemChrome", ViewBag.WorkItem as Compass.Models.Modern.Work.WorkItem)
  <h2 class="dfe-c-heading-m dfe-c-mt-0">Set primary contact</h2>
    <p class="dfe-c-body muted dfe-c-mb-3">The person responsible for day-to-day management and communications for this work item.</p>

    <form asp-action="SetPrimaryContact" asp-route-id="@Model.WorkItemId" method="post" class="dfe-c-mb-4">
      @Html.AntiForgeryToken()
      @await Html.PartialAsync("_UserPicker", userPicker)
      <div class="dfe-c-button-row" style="margin-top:20px;">
        <button type="submit" class="dfe-c-button dfe-c-button--primary">Save</button>
        <a href="@Url.Action("EditPeople", "ModernWork", new { id = Model.WorkItemId })" class="dfe-c-button dfe-c-button--secondary">Cancel</a>
      </div>
    </form>

    @if (Model.AppUserId > 0)
    {
      <form method="post" action="@Url.Action("SetPrimaryContact", "ModernWork", new { id = Model.WorkItemId })" style="margin-top:16px;" data-confirm-title="Confirm remove" data-confirm-message="Remove the primary contact? The work item will have no primary contact until one is set.">
        @Html.AntiForgeryToken()
        <input type="hidden" name="AppUserId" value="0" />
        <button type="submit" class="dfe-c-button dfe-c-button--secondary" style="border-color:#d4351c;color:#d4351c;">Remove primary contact</button>
      </form>
    }
</div>
