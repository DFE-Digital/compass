@model Compass.Models.Modern.Work.WorkRegisterRow
@{
    var label = Model.LatestMonthlyStatusLabel;
    string? badgeClass = label switch
    {
        "Submitted" => "dfe-c-tag dfe-c-tag--green",
        "Draft" => "dfe-c-tag dfe-c-tag--amber",
        "Not due" => "dfe-c-tag dfe-c-tag--grey",
        "Not started" => "dfe-c-tag dfe-c-tag--red",
        _ => "dfe-c-tag dfe-c-tag--grey"
    };
    var canLink = Model.LatestMonthlyDueAction is "view" or "complete" && !string.IsNullOrEmpty(Model.LatestMonthlyDueUrl);
    var period = Model.LatestMonthlyPeriodLabel ?? "";
    var actionAria = Model.LatestMonthlyActionLabel ?? "";
}
@if (Model.LatestMonthlyDueAction == "na" || string.IsNullOrEmpty(Model.LatestMonthlyDueLabel))
{
    <span class="dfe-c-text-muted">—</span>
}
else if (canLink && !string.IsNullOrEmpty(label))
{
    <a class="govuk-link govuk-link--no-visited-state wd-mr-update-badge-link"
       href="@Model.LatestMonthlyDueUrl"
       aria-label="@period monthly update: @label@(string.IsNullOrEmpty(actionAria) ? "" : " — " + actionAria)">
        <span class="@badgeClass wd-mr-update-badge wd-mr-update-badge--with-icon">
            <span class="wd-mr-update-badge__text">@label</span>
            <svg class="wd-mr-update-badge__icon" width="12" height="12" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M14 4h6v6h-2V7.4l-9.3 9.3-1.4-1.4L16.6 6H14V4z"/></svg>
        </span>
    </a>
}
else if (!string.IsNullOrEmpty(label))
{
    <span class="@badgeClass" style="font-size:0.75rem;">@label</span>
}
else
{
    <span class="dfe-c-text-muted">—</span>
}
