@model Compass.Models.Modern.Work.WorkItem
@{
    ViewData["Title"] = "Edit work item";
    var portfolios = (List<Compass.Models.Portfolio>)ViewBag.Portfolios ?? new List<Compass.Models.Portfolio>();
    var directorates = (List<Compass.Models.Directorate>)ViewBag.Directorates ?? new List<Compass.Models.Directorate>();
    var selectedDirectorateIds = (int[])ViewBag.SelectedDirectorateIds ?? Array.Empty<int>();
    var workStatusOptions = (List<Compass.Models.Modern.Work.LookupOption>)ViewBag.WorkStatusOptions ?? new List<Compass.Models.Modern.Work.LookupOption>();
    var workPriorityOptions = (List<Compass.Models.Modern.Work.LookupOption>)ViewBag.WorkPriorityOptions ?? new List<Compass.Models.Modern.Work.LookupOption>();
    var deliveryPhaseOptions = (List<Compass.Models.Modern.Work.LookupOption>)ViewBag.DeliveryPhaseOptions ?? new List<Compass.Models.Modern.Work.LookupOption>();
    var activityTypeOptions = (List<Compass.Models.Modern.Work.LookupOption>)ViewBag.ActivityTypeOptions ?? new List<Compass.Models.Modern.Work.LookupOption>();
    var riskAppetiteOptions = (List<Compass.Models.Modern.Work.LookupOption>)ViewBag.RiskAppetiteOptions ?? new List<Compass.Models.Modern.Work.LookupOption>();
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="/">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Detail", "ModernWork", new { id = Model.Id })">@Model.Title</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Edit</li>
}

<div id="sc-work-edit">
  @await Html.PartialAsync("_WorkItemChrome", ViewBag.WorkItem as Compass.Models.Modern.Work.WorkItem ?? Model)

 <div class="dfe-c-page-title">
 <h2 class="dfe-c-heading-l dfe-c-mt-0 dfe-c-mb-1">Edit work item</h2>
 <p class="dfe-c-body muted dfe-c-mb-0">Update the key information for this work item.</p>
  </div>

 <div class="dfe-c-form-layout">
 <div class="dfe-c-form-layout__main">
 <div class="dfe-c-card dfe-c-card--plain">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
          @Html.AntiForgeryToken()

 <div class="dfe-c-form__group @(ViewData.ModelState["Title"]?.Errors?.Any() == true ? "dfe-c-form__group--error" : "")">
 <label class="dfe-c-form__label dfe-c-form__label--s" asp-for="Title">Title</label>
 <div class="dfe-c-form__hint">The name of this work item as it appears across the system.</div>
            @if (ViewData.ModelState["Title"]?.Errors?.Any() == true)
            {
 <span class="dfe-c-form__error">@ViewData.ModelState["Title"]?.Errors?.FirstOrDefault()?.ErrorMessage</span>
            }
 <input class="dfe-c-width-full" asp-for="Title" type="text" required />
          </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label dfe-c-form__label--s" asp-for="ProblemStatement">Problem statement</label>
 <div class="dfe-c-form__hint">What problem does this work address? Be clear and concise.</div>
 <textarea class="dfe-c-width-full" asp-for="ProblemStatement" rows="4"></textarea>
          </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label dfe-c-form__label--s" asp-for="Aim">Aim</label>
 <div class="dfe-c-form__hint">The intended outcome or goal of this work.</div>
 <textarea class="dfe-c-width-full" asp-for="Aim" rows="3"></textarea>
          </div>

 <hr class="dfe-c-section-break dfe-c-section-break--visible" />

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label dfe-c-form__label--s" asp-for="Status">Status</label>
 <div class="dfe-c-form__hint">The current lifecycle status of this work item.</div>
 <select class="dfe-c-width-two-thirds" asp-for="Status">
              @foreach (var opt in workStatusOptions)
              {
                <option value="@opt.Value" selected="@(Model.Status == opt.Value)">@opt.Name</option>
              }
            </select>
          </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label dfe-c-form__label--s" asp-for="PortfolioId">Business area</label>
 <div class="dfe-c-form__hint">The business area this work item belongs to.</div>
 <select class="dfe-c-width-two-thirds" asp-for="PortfolioId">
              <option value="">— Select —</option>
              @foreach (var p in portfolios)
              {
                <option value="@p.Id" selected="@(Model.PortfolioId == p.Id)">@p.Name</option>
              }
            </select>
          </div>

 <fieldset class="dfe-c-form__group">
 <legend class="dfe-c-form__label dfe-c-form__label--s">Directorates</legend>
 <div class="dfe-c-form__hint">Select all directorates this work item is associated with.</div>
            @if (directorates.Count == 0)
            {
 <p class="dfe-c-body-s dfe-c-text-muted dfe-c-m-0">No active directorates are configured. Add directorates in Admin.</p>
            }
            else
            {
 <div class="dfe-c-form__check-group" style="margin-top:0.5rem;">
                @foreach (var d in directorates)
                {
                  var isChecked = selectedDirectorateIds.Contains(d.Id);
 <label class="dfe-c-form__check-item" for="edit-dir-@d.Id">
                    <input type="checkbox" name="DirectorateIds" value="@d.Id" id="edit-dir-@d.Id" checked="@isChecked" />
                    <div>@d.Name</div>
                  </label>
                }
              </div>
            }
          </fieldset>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label dfe-c-form__label--s" asp-for="PriorityId">Priority</label>
 <div class="dfe-c-form__hint">The agreed priority band for this work.</div>
 <select class="dfe-c-width-two-thirds" asp-for="PriorityId">
              <option value="">— Select —</option>
              @foreach (var opt in workPriorityOptions)
              {
                <option value="@opt.Id" selected="@(Model.PriorityId == opt.Id)">@opt.Name</option>
              }
            </select>
          </div>

 <div class="dfe-c-form__group @(ViewData.ModelState["PriorityChangeReason"]?.Errors?.Any() == true ? "dfe-c-form__group--error" : "")">
 <label class="dfe-c-form__label dfe-c-form__label--s" for="PriorityChangeReason">Reason for priority change</label>
 <div class="dfe-c-form__hint">Required when you change the priority above.</div>
            @if (ViewData.ModelState["PriorityChangeReason"]?.Errors?.Any() == true)
            {
 <span class="dfe-c-form__error">@ViewData.ModelState["PriorityChangeReason"]?.Errors?.FirstOrDefault()?.ErrorMessage</span>
            }
 <textarea class="dfe-c-width-full" id="PriorityChangeReason" name="PriorityChangeReason" rows="3" maxlength="2000">@Model.PriorityChangeReason</textarea>
          </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label dfe-c-form__label--s" asp-for="DeliveryPhaseId">Phase</label>
 <div class="dfe-c-form__hint">The current delivery phase of this work.</div>
 <select class="dfe-c-width-two-thirds" asp-for="DeliveryPhaseId">
              <option value="">— Select phase —</option>
              @foreach (var opt in deliveryPhaseOptions)
              {
                <option value="@opt.Id" selected="@(Model.DeliveryPhaseId == opt.Id)">@opt.Name</option>
              }
            </select>
          </div>

 <hr class="dfe-c-section-break dfe-c-section-break--visible" />

 <div class="dfe-c-form__group">
            @await Html.PartialAsync("_UserPicker", new Compass.Models.UserPickerViewModel
            {
              FieldName = "PrimaryContactUserId",
              Label = "Primary contact",
              Hint = "The person responsible for day-to-day management.",
              Placeholder = "Search by name or email",
              DefaultUserId = Model.PrimaryContactUserId,
              DefaultName = null,
              DefaultSummaryText = "No primary contact selected."
            })
          </div>

 <div class="dfe-c-form__group">
            @await Html.PartialAsync("_UserPicker", new Compass.Models.UserPickerViewModel
            {
              FieldName = "BudgetOwnerUserId",
              Label = "Budget owner",
              Hint = "The person accountable for the budget of this work.",
              Placeholder = "Search by name or email",
              DefaultUserId = Model.BudgetOwnerUserId,
              DefaultName = null,
              DefaultSummaryText = "No budget owner selected."
            })
          </div>

 <hr class="dfe-c-section-break dfe-c-section-break--visible" />

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label dfe-c-form__label--s" asp-for="ActivityTypeId">Activity type</label>
 <div class="dfe-c-form__hint">Categorisation of the type of activity.</div>
 <select class="dfe-c-width-two-thirds" asp-for="ActivityTypeId">
              <option value="">— Select —</option>
              @foreach (var opt in activityTypeOptions)
              {
                <option value="@opt.Id" selected="@(Model.ActivityTypeId == opt.Id)">@opt.Name</option>
              }
            </select>
          </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label dfe-c-form__label--s" asp-for="RiskAppetiteId">Risk appetite</label>
 <div class="dfe-c-form__hint">The level of risk tolerance for this work.</div>
 <select class="dfe-c-width-two-thirds" asp-for="RiskAppetiteId">
              <option value="">— Select —</option>
              @foreach (var opt in riskAppetiteOptions)
              {
                <option value="@opt.Id" selected="@(Model.RiskAppetiteId == opt.Id)">@opt.Name</option>
              }
            </select>
          </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label dfe-c-form__label--s" asp-for="StartDate">Start date</label>
 <div class="dfe-c-form__hint">When this work started or is expected to start.</div>
 <input class="dfe-c-width-one-third" asp-for="StartDate" type="date" />
          </div>

 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label dfe-c-form__label--s" asp-for="TargetEndDate">Target end date</label>
 <div class="dfe-c-form__hint">The planned completion date for this work.</div>
 <input class="dfe-c-width-one-third" asp-for="TargetEndDate" type="date" />
          </div>

 <hr class="dfe-c-section-break dfe-c-section-break--visible" />

 <fieldset class="dfe-c-form__group">
 <legend class="dfe-c-form__label dfe-c-form__label--s">Flags</legend>
 <div class="dfe-c-form__hint">Select any that apply to this work item.</div>
 <div class="dfe-c-form__check-group">
 <label class="dfe-c-form__check-item">
                <input type="checkbox" asp-for="SubjectToSpendControl" />
                Subject to spend control
              </label>
 <label class="dfe-c-form__check-item">
                <input type="checkbox" asp-for="FlagshipProject" />
                Flagship project
              </label>
            </div>
          </fieldset>

 <div class="dfe-c-button-row" style="margin-top:1.5rem;">
 <button type="submit" class="govuk-button">Save changes</button>
 <a href="@Url.Action("Detail", "ModernWork", new { id = Model.Id })" class="govuk-button govuk-button--secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>

 <div class="dfe-c-form-layout__aside">
 <div class="dfe-c-sidebar">
 <div class="dfe-c-scard">
 <h3 class="dfe-c-scard__heading">Key information</h3>
 <p class="dfe-c-scard__body">Title, problem statement, and aim define the core identity of this work item and how it appears in reports and dashboards.</p>
        </div>
 <div class="dfe-c-scard">
 <h3 class="dfe-c-scard__heading">Status &amp; classification</h3>
 <p class="dfe-c-scard__body">Status, business area, directorates, priority, and phase determine how this work is tracked, filtered, and reported across the system.</p>
        </div>
 <div class="dfe-c-scard">
 <h3 class="dfe-c-scard__heading">People</h3>
 <p class="dfe-c-scard__body">Primary contact is the day-to-day lead. Budget owner is accountable for spend. Both can also be managed from the People tab.</p>
        </div>
 <div class="dfe-c-scard">
 <h3 class="dfe-c-scard__heading">Dates &amp; flags</h3>
 <p class="dfe-c-scard__body">Start and end dates drive timeline views. Spend control and flagship flags affect governance reporting.</p>
        </div>
      </div>
    </div>
  </div>
</div>
