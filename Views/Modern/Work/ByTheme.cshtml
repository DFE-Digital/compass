@using Compass.Models.Modern.Work
@using Compass.ViewModels.Modern
@using System.Globalization
@using static Compass.ViewModels.Modern.WorkV2GroupingIntroKind
@using Microsoft.AspNetCore.Routing
@using Microsoft.AspNetCore.WebUtilities
@{
    ViewData["Title"] = "By theme";
    var themesNav = (List<WorkLookupOption>)ViewBag.ThemesNav ?? new List<WorkLookupOption>();
    var workCountByThemeId = (Dictionary<int, int>)ViewBag.WorkCountByThemeId ?? new Dictionary<int, int>();
    var search = ViewBag.Search as string;
    var workItemsFilter = ViewBag.WorkItemsFilter as string ?? "all";
    var countBeforeWorkFilter = ViewBag.CountBeforeWorkFilter as int?;
    var selectedThemeId = ViewBag.SelectedThemeId as int?;
    var showAllThemes = ViewBag.ShowAllThemes as bool? ?? false;
    var filterKey = (ViewBag.ThemeFilterKey as string ?? "all").Trim();
    var pagedWorkItems = ViewBag.PagedWorkItems as List<WorkItem> ?? new List<WorkItem>();
    var registerPage = ViewBag.RegisterPage as int? ?? 1;
    var registerPageCount = ViewBag.RegisterPageCount as int? ?? 1;
    var registerTotalCount = ViewBag.RegisterTotalCount as int? ?? 0;
    var registerDisplayRowStart = ViewBag.RegisterDisplayRowStart as int? ?? 0;
    var registerDisplayRowEnd = ViewBag.RegisterDisplayRowEnd as int? ?? 0;
    var registerIsPaginated = ViewBag.RegisterIsPaginated as bool? ?? false;
    var activeTab = ViewBag.ActiveTab as string ?? "active";

    var selectedTheme = selectedThemeId.HasValue
        ? themesNav.FirstOrDefault(t => t.Id == selectedThemeId.Value)
        : null;

    object ThemePageQuery(int p)
    {
        if (showAllThemes)
            return new { tab = activeTab, search, workItems = workItemsFilter, themeKey = "all", page = p };
        if (selectedThemeId.HasValue)
            return new { tab = activeTab, search, workItems = workItemsFilter, themeKey = selectedThemeId.Value.ToString(CultureInfo.InvariantCulture), page = p };
        return new { tab = activeTab, search, workItems = workItemsFilter, page = p };
    }

    string ByThemeUrl(object? values = null)
    {
        const string path = "/modern/work/by-theme";
        if (values == null) return path;
        var rd = new RouteValueDictionary(values);
        var query = rd
            .Where(kv => kv.Value != null && !string.IsNullOrEmpty(Convert.ToString(kv.Value, CultureInfo.InvariantCulture)))
            .ToDictionary(kv => kv.Key!, kv => Convert.ToString(kv.Value, CultureInfo.InvariantCulture)!);
        return query.Count == 0 ? path : QueryHelpers.AddQueryString(path, query);
    }
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">By theme</li>
}

<div id="sc-work-by-theme" class="modern-work-page">
@{
  var byThemeLede = await Html.PartialAsync("_GovukBodyParagraph", "Work items can have one or more thematic tags. Use the filters to choose a theme or view every work item together.");
}
@await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
  Caption = "Work",
  Title = "By theme",
  Lede = byThemeLede
})

 <form method="get" action="@ByThemeUrl()" id="by-theme-search-form" class="dfe-c-mb-3">
    <input type="hidden" name="tab" value="@activeTab" />
    <div id="search-and-filter">
 <div class="filter-toolbar">
 <div class="filter-toolbar__search-wrap">
 <input type="search" name="search" id="by-theme-register-search" value="@search" placeholder="Search themes…" class="filter-search" autocomplete="off" aria-label="Search themes" />
 <button type="submit" class="govuk-button govuk-button--secondary filter-toolbar__search-submit">Search</button>
        </div>
 <button type="button" class="filter-toggle-btn" id="by-theme-filter-btn" aria-expanded="false" aria-controls="by-theme-filter-panel">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="flex-shrink:0;" aria-hidden="true"><path d="M1 3h14v1.5l-5 5V14l-4-2V9.5L1 4.5V3z"></path></svg>
 <span class="filter-toggle-label">Filter</span>
        </button>
      </div>
 <div class="filter-panel filter-panel--allwork" id="by-theme-filter-panel">
 <div class="filter-panel__grid">
        <div>
          <label for="by-theme-filter-theme">Theme</label>
 <select name="themeKey" id="by-theme-filter-theme" class="govuk-select">
            @if (string.Equals(filterKey, "all", StringComparison.OrdinalIgnoreCase))
            {
              <option value="all" selected>All work items</option>
            }
            else
            {
              <option value="all">All work items</option>
            }
            @foreach (var t in themesNav)
            {
              var count = workCountByThemeId.TryGetValue(t.Id, out var c) ? c : 0;
              var key = t.Id.ToString(CultureInfo.InvariantCulture);
              var isSel = string.Equals(filterKey, key, StringComparison.Ordinal);
              if (isSel)
              {
                <option value="@key" selected>@(t.Name ?? t.Value) (@count)</option>
              }
              else
              {
                <option value="@key">@(t.Name ?? t.Value) (@count)</option>
              }
            }
          </select>
        </div>
        <div>
          <label for="by-theme-filter-workitems">Work items</label>
 <select name="workItems" id="by-theme-filter-workitems" class="govuk-select">
            @if (workItemsFilter == "all")
            {
              <option value="all" selected>All themes</option>
            }
            else
            {
              <option value="all">All themes</option>
            }
            @if (workItemsFilter == "with")
            {
              <option value="with" selected>With linked work</option>
            }
            else
            {
              <option value="with">With linked work</option>
            }
            @if (workItemsFilter == "without")
            {
              <option value="without" selected>No linked work</option>
            }
            else
            {
              <option value="without">No linked work</option>
            }
          </select>
        </div>
      </div>
 <div class="filter-panel__actions">
 <button type="submit" class="govuk-button govuk-button--primary">Apply</button>
 <a href="@ByThemeUrl()" class="govuk-button govuk-button--secondary">Clear filters</a>
        </div>
      </div>
    </div>
  </form>

  @if (ViewBag.WorkRegisterSubNav is WorkRegisterSubNavViewModel workRegisterSubNav)
  {
    @await Html.PartialAsync("_WorkRegisterSubNav", workRegisterSubNav)
  }

  @if (themesNav == null || !themesNav.Any())
  {
 <div class="dfe-c-body dfe-c-text-muted">
      @if (countBeforeWorkFilter is > 0)
      {
        <text>No themes match the work items filter. Try changing the filter or </text>
        <a class="govuk-link govuk-link--no-visited-state" href="@ByThemeUrl(new { search })">clear filters</a><text>.</text>
      }
      else if (!string.IsNullOrWhiteSpace(search))
      {
        <text>No themes match your search.</text>
      }
      else
      {
        <text>No thematic tags defined. Add tags in Admin → Work → Tagging.</text>
      }
    </div>
  }
  else
  {
 <div class="modern-work-theme-register govuk-!-margin-top-4">
 <div class="work-grouping-main-header">
 <div class="work-grouping-main-header__titles">
 @if (showAllThemes)
 {
 <h2 class="govuk-heading-m govuk-!-margin-top-0">All work items</h2>
 <p class="dfe-c-body-s dfe-c-text-muted govuk-!-margin-bottom-0">Every work item, including items with no thematic tag.</p>
 }
 else if (selectedTheme != null)
 {
 <h2 class="govuk-heading-m govuk-!-margin-top-0">@(selectedTheme.Name ?? selectedTheme.Value)</h2>
 <p class="dfe-c-body-s dfe-c-text-muted govuk-!-margin-bottom-0">Work items linked to this thematic tag.</p>
 }
 else
 {
 <h2 class="govuk-heading-m govuk-!-margin-top-0">Work items</h2>
 }
 </div>
 </div>

 @if (!pagedWorkItems.Any())
 {
 <p class="dfe-c-body dfe-c-text-muted govuk-!-margin-bottom-0 govuk-!-margin-top-4">No work items to show for this selection.</p>
 }
 else
 {
 <div class="dfe-f-table-wrapper dfe-f-table-wrapper--stacked govuk-!-margin-top-3 modern-work-theme-table-wrap govuk-!-width-full" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
                <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed modern-work-table govuk-!-width-full"><caption class="govuk-table__caption govuk-visually-hidden">Work items</caption>
                  <thead class="govuk-table__head">
                    <tr class="govuk-table__row">
                      <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Work item</button>
        </th>
                      <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Business area</button>
        </th>
                      <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Directorate</button>
        </th>
                      <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Priority</button>
        </th>
                      <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">RAG</button>
        </th>
                      <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Primary contact</button>
        </th>
                      <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Status</button>
        </th>
                    </tr>
                  </thead>
                  <tbody class="govuk-table__body">
                    @await Html.PartialAsync("_ByPriorityWorkRows", pagedWorkItems)
                  </tbody>
                </table>
              </div>

 <div class="work-grouping-register-footer">
    @if (registerIsPaginated)
    {
 <p class="dfe-c-text-muted work-grouping-register-footer__count" id="theme-showing-count">Showing @registerDisplayRowStart–@registerDisplayRowEnd of @registerTotalCount work items</p>
    }
    @if (registerIsPaginated && registerPageCount > 1)
    {
 @await Html.PartialAsync("~/Views/Modern/Shared/_GovUkPagination.cshtml", new GovUkPaginationViewModel {
   CurrentPage = registerPage,
   TotalPages = registerPageCount,
   PageUrl = p => ByThemeUrl(ThemePageQuery(p)),
   NavigationAriaLabel = "By theme work items"
 })
    }
  </div>
 }
 </div>
}

  @await Html.PartialAsync("~/Views/Modern/Work/_WorkV2GroupingIntroModal.cshtml", new WorkV2GroupingIntroModalModel(ByTheme))
</div>

@section Scripts {
<script src="~/modern/js/work-grouping-v2-intro.js" asp-append-version="true" nonce="@Context.Items["Nonce"]"></script>
}

@section Styles {
<style>
  .modern-work-theme-register {
    max-width: 100%;
  }
  .modern-work-theme-table-wrap {
    max-width: 100%;
  }
  .work-grouping-main-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .work-grouping-main-header__titles { flex: 1 1 12rem; min-width: 0; }
  .work-grouping-register-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.875rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .work-grouping-register-footer__count { margin: 0; }
  #sc-work-by-theme .dfe-f-table-wrapper .govuk-table {
    margin-bottom: 0;
    width: 100%;
  }
</style>
}
