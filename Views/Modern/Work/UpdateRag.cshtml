@model Compass.Models.Modern.Work.WorkItemRagHistory
@{
    var work = ViewBag.WorkItem as Compass.Models.Modern.Work.WorkItem;
    var ragStatuses = (List<Compass.Models.Modern.Work.RagStatusLookupOption>)ViewBag.RagStatuses ?? new List<Compass.Models.Modern.Work.RagStatusLookupOption>();
    ViewData["Title"] = "Update RAG status";
}
@section Breadcrumbs {
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="/">Home</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Detail", "ModernWork", new { id = Model.WorkItemId })">@(work?.Title ?? "Work")</a></li>
    <li class="dfe-c-breadcrumb__item" aria-current="page">Update RAG</li>
}

<div id="sc-work-updaterag">
  @await Html.PartialAsync("_WorkItemChrome", ViewBag.WorkItem as Compass.Models.Modern.Work.WorkItem)
  <h2 class="dfe-c-heading-m dfe-c-mt-0">Update RAG status</h2>
    <p class="dfe-c-body muted dfe-c-mb-3">Record a new RAG status with justification and path to green.</p>

<form asp-action="UpdateRag" asp-route-id="@Model.WorkItemId" method="post" class="dfe-c-mb-4">
  @Html.AntiForgeryToken()
  <div class="dfe-c-form__group">
    <label class="dfe-c-form__label" asp-for="RagStatusId">RAG status</label>
    <select class="dfe-c-width-10" asp-for="RagStatusId">
      <option value="">— Select —</option>
      @foreach (var r in ragStatuses)
      {
        <option value="@r.Id">@r.Name</option>
      }
    </select>
  </div>
  <div class="dfe-c-form__group">
    <label class="dfe-c-form__label" asp-for="Justification">Justification</label>
    <textarea class="" asp-for="Justification" rows="4"></textarea>
  </div>
  <div class="dfe-c-form__group">
    <label class="dfe-c-form__label" asp-for="PathToGreen">Path to green</label>
    <textarea class="" asp-for="PathToGreen" rows="3"></textarea>
  </div>
  <button type="submit" class="dfe-c-button dfe-c-button--primary">Save RAG update</button>
  <a href="@Url.Action("Detail", "ModernWork", new { id = Model.WorkItemId })" class="dfe-c-button dfe-c-button--secondary">Cancel</a>
</form>
</div>
