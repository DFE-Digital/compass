@model Compass.Models.Modern.Work.SetBudgetOwnerViewModel
@{
    var work = ViewBag.WorkItem as Compass.Models.Modern.Work.WorkItem;
    var firstSroName = ViewBag.FirstSroName as string;
    var budgetOwnerName = ViewBag.BudgetOwnerName as string;
    ViewData["Title"] = "Set budget owner";
    var userPicker = new Compass.Models.UserPickerViewModel
    {
        FieldName = "AppUserId",
        Label = "Budget owner",
        DefaultSummaryText = "No user selected.",
        DefaultUserId = Model.AppUserId > 0 ? Model.AppUserId : null,
        DefaultName = budgetOwnerName
    };
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="/">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Detail", "ModernWork", new { id = Model.WorkItemId })">@(work?.Title ?? "Work")</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("EditPeople", "ModernWork", new { id = Model.WorkItemId })">Edit people</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Set budget owner</li>
}

<div id="sc-work-setbudgetowner">
  @await Html.PartialAsync("_WorkItemChrome", ViewBag.WorkItem as Compass.Models.Modern.Work.WorkItem)
 <h2 class="dfe-c-heading-m dfe-c-mt-0">Set budget owner</h2>
 <p class="dfe-c-body muted dfe-c-mb-3">Defaults to SRO unless specified separately.</p>

 <form asp-action="SetBudgetOwner" asp-route-id="@Model.WorkItemId" method="post" class="dfe-c-mb-4">
      @Html.AntiForgeryToken()
 <div class="dfe-c-form__group">
 <fieldset>
 <legend class="dfe-c-form__legend--sm">Budget owner</legend>
 <div class="dfe-c-form__radio-group">
 <div class="dfe-c-radios__item">
 <input class="dfe-c-radios__input" id="SameAsSro_True" name="SameAsSro" type="radio" value="true" checked="@Model.SameAsSro" />
 <label class="dfe-c-form__label dfe-c-radios__label" for="SameAsSro_True">Same as SRO — @(firstSroName ?? "—")</label>
            </div>
 <div class="dfe-c-radios__item">
 <input class="dfe-c-radios__input" id="SameAsSro_False" name="SameAsSro" type="radio" value="false" checked="@(!Model.SameAsSro)" />
 <label class="dfe-c-form__label dfe-c-radios__label" for="SameAsSro_False">Different person</label>
            </div>
          </div>
        </fieldset>
      </div>
 <div class="dfe-c-form__group" id="budget-owner-picker" style="@(Model.SameAsSro ? "display:none;" : "")">
        @await Html.PartialAsync("_UserPicker", userPicker)
      </div>
 <div class="dfe-c-button-row" style="margin-top:20px;">
 <button type="submit" class="govuk-button">Save</button>
 <a href="@Url.Action("EditPeople", "ModernWork", new { id = Model.WorkItemId })" class="govuk-button govuk-button--secondary">Cancel</a>
      </div>
    </form>
</div>

@section Scripts {
<script>
(function(){
  var radios = document.querySelectorAll('input[name="SameAsSro"]');
  var picker = document.getElementById('budget-owner-picker');
  function toggle() {
    if (!picker) return;
    picker.style.display = document.querySelector('input[name="SameAsSro"]:checked')?.value === 'false' ? 'block' : 'none';
  }
  radios.forEach(function(r){ r.addEventListener('change', toggle); });
  toggle();
})();
</script>
}
