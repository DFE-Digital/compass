@model Compass.Models.Modern.Work.WorkItem
@using Compass.Models.Modern.Work
@{
    ViewData["Title"] = "Create work item";
    var portfolios = (List<Compass.Models.Portfolio>)ViewBag.Portfolios ?? new List<Compass.Models.Portfolio>();
    var directorates = (List<Compass.Models.Directorate>)ViewBag.Directorates ?? new List<Compass.Models.Directorate>();
    var workStatusOptions = (List<LookupOption>)ViewBag.WorkStatusOptions ?? new List<LookupOption>();
    var workPriorityOptions = (List<LookupOption>)ViewBag.WorkPriorityOptions ?? new List<LookupOption>();
    var deliveryPhaseOptions = (List<LookupOption>)ViewBag.DeliveryPhaseOptions ?? new List<LookupOption>();
    var activityTypeOptions = (List<LookupOption>)ViewBag.ActivityTypeOptions ?? new List<LookupOption>();
    var riskAppetiteOptions = (List<LookupOption>)ViewBag.RiskAppetiteOptions ?? new List<LookupOption>();
    var ragStatuses = (List<Compass.Models.RagStatus>)ViewBag.RagStatuses ?? new List<Compass.Models.RagStatus>();
    var priorityOutcomes = (List<WorkLookupOption>)ViewBag.PriorityOutcomes ?? new List<WorkLookupOption>();
    var missionPillars = (List<WorkLookupOption>)ViewBag.MissionPillars ?? new List<WorkLookupOption>();
    var workTagOptions = (List<LookupOption>)ViewBag.WorkTagOptions ?? new List<LookupOption>();
    var governmentDepartments = (List<Compass.Models.GovernmentDepartment>)ViewBag.GovernmentDepartments ?? new List<Compass.Models.GovernmentDepartment>();
    var selectedDirectorateIds = (int[])ViewBag.SelectedDirectorateIds ?? Array.Empty<int>();
    var selectedPriorityOutcomeIds = (int[])ViewBag.SelectedPriorityOutcomeIds ?? Array.Empty<int>();
    var selectedMissionPillarIds = (int[])ViewBag.SelectedMissionPillarIds ?? Array.Empty<int>();
    var selectedWorkTagIds = (int[])ViewBag.SelectedWorkTagIds ?? Array.Empty<int>();
    var fromDemand = ViewBag.FromDemand as DemandRequest;
    var fromBc = ViewBag.FromBusinessCase as BusinessCase;
    var sD0 = Model.StartDate;
    int? sDay = sD0?.Day, sMonth = sD0?.Month, sYear = sD0?.Year;
    var tD0 = Model.TargetEndDate;
    int? tDay = tD0?.Day, tMonth = tD0?.Month, tYear = tD0?.Year;

    bool HasError(string field) => ViewData.ModelState[field]?.Errors?.Any() == true;
    string? ErrorMsg(string field) => ViewData.ModelState[field]?.Errors?.FirstOrDefault()?.ErrorMessage;
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Create work item</li>
}

<div id="sc-work-create">
<p class="dfe-c-body dfe-c-mb-3">
 <a href="@(fromDemand != null ? Url.Action("Detail", "Demand", new { id = fromDemand.Id }) : fromBc != null ? Url.Action("Detail", "Horizon", new { id = fromBc.Id }) : Url.Action("Index", "ModernWork"))" class="dfe-c-link">← @(fromDemand != null ? "Back to demand request" : fromBc != null ? "Back to business case" : "Back to work register")</a>
</p>

@if (fromDemand != null)
{
 <div class="govuk-notification-banner" role="region" aria-labelledby="demand-banner-title" data-module="govuk-notification-banner">
 <div class="govuk-notification-banner__header">
 <h2 class="govuk-notification-banner__title" id="demand-banner-title">Linked to demand</h2>
    </div>
 <div class="govuk-notification-banner__content">
 <p class="govuk-notification-banner__heading">This work item will be linked to demand request <strong>@fromDemand.Reference — @fromDemand.Title</strong>.</p>
 <p class="govuk-body govuk-!-margin-bottom-0">Complete the form and create when ready.</p>
    </div>
  </div>
}

<div class="dfe-c-page-title">
 <div class="dfe-c-page-title__caption">Work</div>
 <h1 class="dfe-c-page-title__heading">Create work item</h1>
 <p class="dfe-c-page-title__lede">Create a new DDT work item to track in the business area. Typically linked to an approved demand or business case.</p>
</div>

<div class="dfe-c-form-layout">
 <div class="dfe-c-form-layout__main">
 <div class="dfe-c-card dfe-c-card--plain">
<form asp-controller="ModernWork" asp-action="Create" method="post" novalidate>
  @Html.AntiForgeryToken()
  <input type="hidden" asp-for="DemandRequestId" />
  <input type="hidden" asp-for="BusinessCaseId" />
  @if (fromBc != null)
  {
    <input type="hidden" name="businessCaseId" value="@fromBc.Id" />
  }

  @if (!ViewData.ModelState.IsValid)
  {
 <div class="govuk-error-summary" data-module="govuk-error-summary" role="alert" aria-labelledby="error-summary-title">
 <h2 class="govuk-error-summary__title" id="error-summary-title">There is a problem</h2>
 <div class="govuk-error-summary__body">
 <ul class="govuk-list govuk-error-summary__list">
          @{
            var summaryOrder = new[]
            {
              nameof(Model.Title), nameof(Model.ProblemStatement), nameof(Model.Aim), nameof(Model.PortfolioId),
              nameof(Model.Status), nameof(Model.PriorityId), nameof(Model.DeliveryPhaseId), nameof(Model.ActivityTypeId),
              nameof(Model.StartDate), nameof(Model.TargetEndDate), nameof(Model.RiskAppetiteId),
              nameof(Model.RagStatusId), "InitialRagJustification", nameof(Model.SubjectToSpendControl), nameof(Model.FlagshipProject), "MultiDept", "GovernmentDepartmentIds"
            };
          }
          @foreach (var key in summaryOrder)
          {
            if (ViewData.ModelState.TryGetValue(key, out var entry) && entry?.Errors?.Count > 0)
            {
              <li><a href="#@key">@entry.Errors[0].ErrorMessage</a></li>
            }
          }
          @foreach (var kv in ViewData.ModelState)
          {
            if (summaryOrder.Contains(kv.Key, StringComparer.Ordinal)) continue;
            if (kv.Value?.Errors?.Count > 0)
            {
              <li><a href="#@kv.Key">@kv.Value.Errors[0].ErrorMessage</a></li>
            }
          }
        </ul>
      </div>
    </div>
  }

 <fieldset class="govuk-fieldset govuk-!-margin-bottom-6">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Work item details</legend>

 <div class="govuk-form-group @(HasError(nameof(Model.Title)) ?"govuk-form-group--error" : "")">
 <label class="govuk-label" for="Title">Title <span style="color:#d4351c">*</span></label>
          @if (HasError(nameof(Model.Title)))
          {
 <p id="Title-error" class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> @ErrorMsg(nameof(Model.Title))</p>
          }
 <input asp-for="Title" type="text" class="govuk-input @(HasError(nameof(Model.Title)) ?"govuk-input--error" : "")" placeholder="Short, clear title for this work item" autocomplete="off" aria-describedby="@(HasError(nameof(Model.Title)) ? "Title-error" : null)" />
        </div>

 <div class="govuk-form-group @(HasError(nameof(Model.ProblemStatement)) ?"govuk-form-group--error" : "")">
 <label class="govuk-label" for="ProblemStatement">Problem statement <span style="color:#d4351c">*</span></label>
 <div class="govuk-hint" id="problemstatement-hint">What is the problem this work is solving? Be specific — this is the &lsquo;why&rsquo;.</div>
          @if (HasError(nameof(Model.ProblemStatement)))
          {
 <p id="ProblemStatement-error" class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> @ErrorMsg(nameof(Model.ProblemStatement))</p>
          }
 <textarea asp-for="ProblemStatement" rows="4" class="govuk-textarea @(HasError(nameof(Model.ProblemStatement)) ?"govuk-textarea--error" : "")" placeholder="Describe the problem in plain English..." aria-describedby="problemstatement-hint @(HasError(nameof(Model.ProblemStatement)) ? "ProblemStatement-error" : "")"></textarea>
        </div>

 <div class="govuk-form-group @(HasError(nameof(Model.Aim)) ?"govuk-form-group--error" : "")">
 <label class="govuk-label" for="Aim">Aim <span style="color:#d4351c">*</span></label>
 <div class="govuk-hint" id="aim-hint">What will success look like? What is this work item trying to achieve?</div>
          @if (HasError(nameof(Model.Aim)))
          {
 <p id="Aim-error" class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> @ErrorMsg(nameof(Model.Aim))</p>
          }
 <textarea asp-for="Aim" rows="3" class="govuk-textarea @(HasError(nameof(Model.Aim)) ?"govuk-textarea--error" : "")" placeholder="Describe the aim and expected outcome..." aria-describedby="aim-hint @(HasError(nameof(Model.Aim)) ? "Aim-error" : "")"></textarea>
        </div>
      </fieldset>

 <fieldset class="govuk-fieldset govuk-!-margin-bottom-6">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Business area and directorates</legend>

 <div class="govuk-form-group @(HasError(nameof(Model.PortfolioId)) ?"govuk-form-group--error" : "")">
 <label class="govuk-label" for="PortfolioId">Business area <span style="color:#d4351c">*</span></label>
          @if (HasError(nameof(Model.PortfolioId)))
          {
 <p id="PortfolioId-error" class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> @ErrorMsg(nameof(Model.PortfolioId))</p>
          }
 <select asp-for="PortfolioId" class="govuk-select govuk-!-width-full @(HasError(nameof(Model.PortfolioId)) ?"govuk-select--error" : "")" aria-describedby="@(HasError(nameof(Model.PortfolioId)) ? "PortfolioId-error" : null)">
            <option value="">— Select business area —</option>
            @foreach (var p in portfolios)
            { <option value="@p.Id">@p.Name</option> }
          </select>
        </div>

 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Directorate(s)</legend>
 <div class="govuk-hint" id="directorates-hint">Select all that apply.</div>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="directorates-hint">
              @foreach (var d in directorates)
              {
                var isChecked = selectedDirectorateIds.Contains(d.Id);
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" type="checkbox" name="DirectorateIds" value="@d.Id" id="dir-@d.Id" checked="@isChecked" />
 <label class="govuk-label govuk-checkboxes__label" for="dir-@d.Id">@d.Name</label>
                </div>
              }
            </div>
          </fieldset>
        </div>
      </fieldset>

 <fieldset class="govuk-fieldset govuk-!-margin-bottom-6">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Delivery and status</legend>

 <div class="govuk-form-group">
 <label class="govuk-label" for="Status">Status <span style="color:#d4351c">*</span></label>
 <select asp-for="Status" class="govuk-select govuk-!-width-full">
            @foreach (var opt in workStatusOptions)
            {
              if (Model?.Status == opt.Value)
              { <option value="@opt.Value" selected>@opt.Name</option> }
              else
              { <option value="@opt.Value">@opt.Name</option> }
            }
          </select>
        </div>

 <div class="govuk-form-group @(HasError(nameof(Model.PriorityId)) ?"govuk-form-group--error" : "")">
 <label class="govuk-label" for="PriorityId">Priority <span style="color:#d4351c">*</span></label>
          @if (HasError(nameof(Model.PriorityId)))
          {
 <p id="PriorityId-error" class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> @ErrorMsg(nameof(Model.PriorityId))</p>
          }
 <select asp-for="PriorityId" class="govuk-select govuk-!-width-full @(HasError(nameof(Model.PriorityId)) ?"govuk-select--error" : "")" aria-describedby="@(HasError(nameof(Model.PriorityId)) ? "PriorityId-error" : null)">
            <option value="">— Select —</option>
            @foreach (var opt in workPriorityOptions)
            {
              if (Model?.PriorityId == opt.Id)
              { <option value="@opt.Id" selected>@opt.Name</option> }
              else
              { <option value="@opt.Id">@opt.Name</option> }
            }
          </select>
        </div>

 <div class="govuk-form-group">
 <label class="govuk-label" for="DeliveryPhaseId">Phase</label>
 <div class="govuk-hint" id="phase-hint">Delivery phase (e.g. Discovery, Alpha, Beta, Live).</div>
 <select asp-for="DeliveryPhaseId" class="govuk-select govuk-!-width-full" aria-describedby="phase-hint">
            <option value="">— Select phase —</option>
            @foreach (var opt in deliveryPhaseOptions)
            {
              if (Model?.DeliveryPhaseId == opt.Id)
              { <option value="@opt.Id" selected>@opt.Name</option> }
              else
              { <option value="@opt.Id">@opt.Name</option> }
            }
          </select>
        </div>

 <div class="govuk-form-group @(HasError(nameof(Model.ActivityTypeId)) ?"govuk-form-group--error" : "")">
 <label class="govuk-label" for="ActivityTypeId">Activity type <span style="color:#d4351c">*</span></label>
          @if (HasError(nameof(Model.ActivityTypeId)))
          {
 <p id="ActivityTypeId-error" class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> @ErrorMsg(nameof(Model.ActivityTypeId))</p>
          }
 <select asp-for="ActivityTypeId" class="govuk-select govuk-!-width-full @(HasError(nameof(Model.ActivityTypeId)) ?"govuk-select--error" : "")" aria-describedby="@(HasError(nameof(Model.ActivityTypeId)) ? "ActivityTypeId-error" : null)">
            <option value="">— Select —</option>
            @foreach (var opt in activityTypeOptions)
            {
              if (Model?.ActivityTypeId == opt.Id)
              { <option value="@opt.Id" selected>@opt.Name</option> }
              else
              { <option value="@opt.Id">@opt.Name</option> }
            }
          </select>
        </div>

 <div class="govuk-form-group @(HasError(nameof(Model.StartDate)) ?"govuk-form-group--error" : "")">
 <fieldset class="govuk-fieldset" role="group" aria-describedby="@(HasError(nameof(Model.StartDate)) ? "StartDate-hint StartDate-error" : "StartDate-hint")">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Start date <span class="govuk-visually-hidden">(required)</span><span style="color:#d4351c">*</span></legend>
 <div id="StartDate-hint" class="govuk-hint">For example 15 3 @(DateTime.UtcNow.Year)</div>
          @if (HasError(nameof(Model.StartDate)))
          {
 <p id="StartDate-error" class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> @ErrorMsg(nameof(Model.StartDate))</p>
          }
 <div class="govuk-date-input" id="StartDate">
 <div class="govuk-date-input__item">
 <div class="govuk-form-group">
 <label class="govuk-label govuk-date-input__label" for="StartDay">Day</label>
 <input class="govuk-input govuk-date-input__input govuk-input--width-2 @(HasError(nameof(Model.StartDate)) ?"govuk-input--error" : "")" id="StartDay" name="startDay" type="text" inputmode="numeric" maxlength="2" autocomplete="off" pattern="[0-9]*" value="@sDay" />
              </div>
            </div>
 <div class="govuk-date-input__item">
 <div class="govuk-form-group">
 <label class="govuk-label govuk-date-input__label" for="StartMonth">Month</label>
 <input class="govuk-input govuk-date-input__input govuk-input--width-2 @(HasError(nameof(Model.StartDate)) ?"govuk-input--error" : "")" id="StartMonth" name="startMonth" type="text" inputmode="numeric" maxlength="2" autocomplete="off" pattern="[0-9]*" value="@sMonth" />
              </div>
            </div>
 <div class="govuk-date-input__item">
 <div class="govuk-form-group">
 <label class="govuk-label govuk-date-input__label" for="StartYear">Year</label>
 <input class="govuk-input govuk-date-input__input govuk-input--width-4 @(HasError(nameof(Model.StartDate)) ?"govuk-input--error" : "")" id="StartYear" name="startYear" type="text" inputmode="numeric" maxlength="4" autocomplete="off" pattern="[0-9]*" value="@sYear" />
              </div>
            </div>
          </div>
        </fieldset>
        </div>

 <div class="govuk-form-group @(HasError(nameof(Model.TargetEndDate)) ?"govuk-form-group--error" : "")">
 <fieldset class="govuk-fieldset" role="group">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Target end date</legend>
          @if (HasError(nameof(Model.TargetEndDate)))
          {
 <p id="TargetEndDate-error" class="govuk-error-message"><span class="govuk-visually-hidden">Error:</span> @ErrorMsg(nameof(Model.TargetEndDate))</p>
          }
 <div class="govuk-date-input" id="TargetEndDate">
 <div class="govuk-date-input__item">
 <div class="govuk-form-group">
 <label class="govuk-label govuk-date-input__label" for="TargetEndDay">Day</label>
 <input class="govuk-input govuk-date-input__input govuk-input--width-2 @(HasError(nameof(Model.TargetEndDate)) ?"govuk-input--error" : "")" id="TargetEndDay" name="targetEndDay" type="text" inputmode="numeric" maxlength="2" autocomplete="off" pattern="[0-9]*" value="@tDay" />
              </div>
            </div>
 <div class="govuk-date-input__item">
 <div class="govuk-form-group">
 <label class="govuk-label govuk-date-input__label" for="TargetEndMonth">Month</label>
 <input class="govuk-input govuk-date-input__input govuk-input--width-2 @(HasError(nameof(Model.TargetEndDate)) ?"govuk-input--error" : "")" id="TargetEndMonth" name="targetEndMonth" type="text" inputmode="numeric" maxlength="2" autocomplete="off" pattern="[0-9]*" value="@tMonth" />
              </div>
            </div>
 <div class="govuk-date-input__item">
 <div class="govuk-form-group">
 <label class="govuk-label govuk-date-input__label" for="TargetEndYear">Year</label>
 <input class="govuk-input govuk-date-input__input govuk-input--width-4 @(HasError(nameof(Model.TargetEndDate)) ?"govuk-input--error" : "")" id="TargetEndYear" name="targetEndYear" type="text" inputmode="numeric" maxlength="4" autocomplete="off" pattern="[0-9]*" value="@tYear" />
              </div>
            </div>
          </div>
        </fieldset>
        </div>

 <div class="govuk-form-group">
 <label class="govuk-label" for="RiskAppetiteId">Risk appetite</label>
 <select asp-for="RiskAppetiteId" class="govuk-select govuk-!-width-full">
            <option value="">— Select —</option>
            @foreach (var opt in riskAppetiteOptions)
            {
              if (Model?.RiskAppetiteId == opt.Id)
              { <option value="@opt.Id" selected>@opt.Name</option> }
              else
              { <option value="@opt.Id">@opt.Name</option> }
            }
          </select>
        </div>
      </fieldset>

 <fieldset class="govuk-fieldset govuk-!-margin-bottom-6">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Strategic alignment</legend>

 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Priority outcome</legend>
 <div class="govuk-hint" id="po-hint">Select all that apply.</div>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="po-hint">
              @foreach (var po in priorityOutcomes)
              {
                var isChecked = selectedPriorityOutcomeIds.Contains(po.Id);
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" type="checkbox" name="PriorityOutcomeIds" value="@po.Id" id="po-@po.Id" checked="@isChecked" />
 <label class="govuk-label govuk-checkboxes__label" for="po-@po.Id">@po.Name</label>
                </div>
              }
            </div>
          </fieldset>
        </div>

 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Mission pillar</legend>
 <div class="govuk-hint" id="mp-hint">Select all that apply.</div>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="mp-hint">
              @foreach (var mp in missionPillars)
              {
                var isChecked = selectedMissionPillarIds.Contains(mp.Id);
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" type="checkbox" name="MissionPillarIds" value="@mp.Id" id="mp-@mp.Id" checked="@isChecked" />
 <label class="govuk-label govuk-checkboxes__label" for="mp-@mp.Id">@mp.Name</label>
                </div>
              }
            </div>
          </fieldset>
        </div>
      </fieldset>

 <fieldset class="govuk-fieldset govuk-!-margin-bottom-6">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Tags</legend>
 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Custom tags</legend>
 <div class="govuk-hint" id="wt-hint">Select all that apply.</div>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="wt-hint">
              @foreach (var wt in workTagOptions)
              {
                var wtChecked = selectedWorkTagIds.Contains(wt.Id);
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" type="checkbox" name="workTagIds" value="@wt.Id" id="wt-@wt.Id" checked="@wtChecked" />
 <label class="govuk-label govuk-checkboxes__label" for="wt-@wt.Id">@wt.Name</label>
                </div>
              }
            </div>
          </fieldset>
        </div>
      </fieldset>

 <fieldset class="govuk-fieldset govuk-!-margin-bottom-6">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">RAG and flags</legend>

 <div class="govuk-form-group">
 <label class="govuk-label" for="RagStatusId">Initial RAG status</label>
 <select asp-for="RagStatusId" class="govuk-select govuk-!-width-full">
                <option value="">— Not set —</option>
                @foreach (var r in ragStatuses)
                {
                  if (Model?.RagStatusId == r.Id)
                  { <option value="@r.Id" selected>@r.Name</option> }
                  else
                  { <option value="@r.Id">@r.Name</option> }
                }
              </select>
            </div>

 <div class="govuk-form-group">
 <label class="govuk-label" for="InitialRagJustification">Initial RAG justification</label>
 <div class="govuk-hint" id="rag-just-hint">Explain the current status. If Red or Amber, a path to green is required.</div>
 <textarea id="InitialRagJustification" name="InitialRagJustification" rows="3" class="govuk-textarea" placeholder="Brief justification..." aria-describedby="rag-just-hint">@(ViewBag.InitialRagJustification as string)</textarea>
            </div>

 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Subject to spend control?</legend>
 <div class="govuk-radios govuk-radios--inline" data-module="govuk-radios">
 <div class="govuk-radios__item">
 <input class="govuk-radios__input" type="radio" name="SubjectToSpendControl" id="ssc-yes" value="true" @(Model.SubjectToSpendControl ? "checked" : null) />
 <label class="govuk-label govuk-radios__label" for="ssc-yes">Yes</label>
                  </div>
 <div class="govuk-radios__item">
 <input class="govuk-radios__input" type="radio" name="SubjectToSpendControl" id="ssc-no" value="false" @(!Model.SubjectToSpendControl ? "checked" : null) />
 <label class="govuk-label govuk-radios__label" for="ssc-no">No</label>
                  </div>
                </div>
              </fieldset>
            </div>

 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Flagship project?</legend>
 <div class="govuk-radios govuk-radios--inline" data-module="govuk-radios">
 <div class="govuk-radios__item">
 <input class="govuk-radios__input" type="radio" name="FlagshipProject" id="fp-yes" value="true" @(Model.FlagshipProject ? "checked" : null) />
 <label class="govuk-label govuk-radios__label" for="fp-yes">Yes</label>
                  </div>
 <div class="govuk-radios__item">
 <input class="govuk-radios__input" type="radio" name="FlagshipProject" id="fp-no" value="false" @(!Model.FlagshipProject ? "checked" : null) />
 <label class="govuk-label govuk-radios__label" for="fp-no">No</label>
                  </div>
                </div>
              </fieldset>
            </div>

 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Multi-department cooperation?</legend>
 <div class="govuk-radios govuk-radios--inline" data-module="govuk-radios">
 <div class="govuk-radios__item">
 <input class="govuk-radios__input" type="radio" name="MultiDept" id="multidept-yes" value="yes" />
 <label class="govuk-label govuk-radios__label" for="multidept-yes">Yes</label>
                  </div>
 <div class="govuk-radios__item">
 <input class="govuk-radios__input" type="radio" name="MultiDept" id="multidept-no" value="no" checked />
 <label class="govuk-label govuk-radios__label" for="multidept-no">No</label>
                  </div>
                </div>
              </fieldset>
            </div>

 <div id="dept-names" class="govuk-form-group" hidden>
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Which departments?</legend>
 <div class="govuk-hint" id="govdept-hint">Select all that apply.</div>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="govdept-hint">
              @foreach (var g in governmentDepartments)
              {
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" type="checkbox" name="GovernmentDepartmentIds" value="@g.Id" id="govdept-@g.Id" />
 <label class="govuk-label govuk-checkboxes__label" for="govdept-@g.Id">@g.Title</label>
                </div>
              }
            </div>
          </fieldset>
        </div>
      </fieldset>

 <div class="govuk-button-group">
 <button type="submit" class="govuk-button" data-module="govuk-button">Create work item</button>
 <a href="@(fromDemand != null ? Url.Action("Detail", "Demand", new { id = fromDemand.Id }) : fromBc != null ? Url.Action("Detail", "Horizon", new { id = fromBc.Id }) : Url.Action("Index", "ModernWork"))" class="govuk-button govuk-button--secondary">Cancel</a>
      </div>
</form>
    </div>
  </div>

 <div class="dfe-c-form-layout__aside">
 <div class="dfe-c-sidebar">
 <div class="dfe-c-scard">
 <div class="dfe-c-scard__title">Work item phases</div>
        <div style="font-size:0.8125rem;display:flex;flex-direction:column;gap:0.5rem;">
 <div><span class="dfe-c-phase dfe-c-phase--explore">EXPLORE</span><span style="color:var(--grey-4);margin-left:0.5rem;">Concept stage. Not yet committed.</span></div>
 <div><span class="dfe-c-phase dfe-c-phase--discovery">DISCOVERY</span><span style="color:var(--grey-4);margin-left:0.5rem;">Understanding the problem space.</span></div>
 <div><span class="dfe-c-phase dfe-c-phase--alpha">ALPHA</span><span style="color:var(--grey-4);margin-left:0.5rem;">Testing hypotheses with users.</span></div>
 <div><span class="dfe-c-phase dfe-c-phase--private-beta">PRIVATE BETA</span><span style="color:var(--grey-4);margin-left:0.5rem;">Limited release for testing.</span></div>
 <div><span class="dfe-c-phase dfe-c-phase--public-beta">PUBLIC BETA</span><span style="color:var(--grey-4);margin-left:0.5rem;">Wider release before live.</span></div>
 <div><span class="dfe-c-phase dfe-c-phase--live">LIVE</span><span style="color:var(--grey-4);margin-left:0.5rem;">Full production release.</span></div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>

@section Scripts {
@{
    var cspNonce = Context.Items["Nonce"]?.ToString() ?? "";
}
<script nonce="@cspNonce">
(function() {
  var multideptYes = document.getElementById('multidept-yes');
  var multideptNo = document.getElementById('multidept-no');
  var deptNames = document.getElementById('dept-names');
  if (multideptYes && multideptNo && deptNames) {
    function toggle() {
      var show = multideptYes.checked;
      deptNames.hidden = !show;
      if (!show) {
        deptNames.querySelectorAll('input[type="checkbox"]').forEach(function(cb) { cb.checked = false; });
      }
    }
    multideptYes.addEventListener('change', toggle);
    multideptNo.addEventListener('change', toggle);
    toggle();
  }
})();
</script>
}
