@model Compass.Models.Modern.Work.WorkItemRiskOrIssue
@using Compass.Models.Modern.Work
@using Compass.ViewModels.Modern
@{
    var work = Model.WorkItem;
    var workId = Model.WorkItemId;
    var workIdShort = ViewBag.WorkIdShort as string ?? workId.ToString("D8");
    var riRef = "RI-" + Model.ReferenceNumber.ToString("D5");
    var ownerName = Model.OwnerUser?.Name ?? Model.OwnerUser?.Email ?? Model.UpdatedBy ?? "—";
    var materialisedIssue = Model.MaterialisedAsIssues?.FirstOrDefault();
    ViewData["Title"] = riRef + " — " + Model.Title;
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="/">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Detail", "ModernWork", new { id = workId })">@(work?.Title ?? "Work")</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">@riRef</li>
}

<div id="sc-work-riskdetail">
  @await Html.PartialAsync("_WorkItemChrome", work)

 @await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
   Caption = $"WI-{workIdShort} · {work?.Title} · Risk & issue log",
   Title = $"{riRef} — {Model.Title}",
   HeadingTag = "h2",
   HeadingClass = "govuk-heading-l"
 })

  <div style="display:grid;grid-template-columns:repeat(6,1fr);gap:3px;margin-bottom:24px;">
    <div style="padding:12px;background:#fff7e0;border-top:4px solid #f47738;text-align:center;">
      <div style="font-size:11px;color:#505a5f;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Type</div>
      <span style="background:#f47738;color:#fff;padding:2px 8px;font-size:12px;font-weight:700;">Risk</span>
    </div>
    <div style="padding:12px;background:#fff7e0;border-top:4px solid #f47738;text-align:center;">
      <div style="font-size:11px;color:#505a5f;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Rating</div>
      <span style="background:#fff7e0;color:#6e4900;border:1px solid #f5e4a0;padding:2px 8px;font-size:12px;font-weight:700;">@(ViewBag.DeliveryRiskRating as string ?? "—")</span>
    </div>
    <div style="padding:12px;background:#fff7e0;border-top:4px solid #f47738;text-align:center;">
      <div style="font-size:11px;color:#505a5f;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Status</div>
      <span style="background:#fff7e0;color:#6e4900;border:1px solid #f5e4a0;padding:2px 8px;font-size:12px;font-weight:700;">@Model.Status</span>
    </div>
    <div style="padding:12px;background:#f3f2f1;border-top:4px solid #003a69;text-align:center;">
      <div style="font-size:11px;color:#505a5f;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Tier</div>
      <span style="background:#d2e2f1;color:#003078;border:1px solid #99b8d9;padding:2px 8px;font-size:12px;font-weight:700;">@(Model.Tier ?? "Tier 3")</span>
    </div>
    <div style="padding:12px;background:#f3f2f1;border-top:4px solid #003a69;text-align:center;">
      <div style="font-size:11px;color:#505a5f;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Raised</div>
      <div style="font-size:13px;font-weight:700;">@Model.RaisedAt.ToString("d MMM yyyy")</div>
    </div>
    <div style="padding:12px;background:#f3f2f1;border-top:4px solid #003a69;text-align:center;">
      <div style="font-size:11px;color:#505a5f;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;">Owner</div>
      <div style="font-size:13px;font-weight:700;">@ownerName</div>
    </div>
  </div>

  @if (materialisedIssue != null)
  {
    <div style="display:grid;grid-template-columns:auto 1fr auto;gap:16px;align-items:center;padding:12px 18px;background:#fde8e4;border:1px solid #f5b8b0;border-left:5px solid #d4351c;margin-bottom:20px;">
      <span style="font-size:20px;color:#d4351c;">!</span>
      <div>
        <div style="font-size:13px;font-weight:700;color:#942514;margin-bottom:2px;">This risk has materialised as an active issue</div>
        <div style="font-size:14px;color:#505a5f;">Risk was not mitigated in time. It became active issue <strong>RI-@(materialisedIssue.ReferenceNumber.ToString("D5")) — @materialisedIssue.Title</strong> on @(materialisedIssue.RaisedAt.ToString("d MMM yyyy")).</div>
      </div>
 <a href="@Url.Action("IssueDetail", "ModernWork", new { workId, id = materialisedIssue.Id })" class="govuk-button govuk-button--secondary govuk-button--sm">View issue RI-@(materialisedIssue.ReferenceNumber.ToString("D5")) →</a>
    </div>
  }

 <nav id="risk-detail-tabs" class="tabs dfe-f-sub-navigation govuk-!-margin-bottom-4" aria-label="Risk sections">
 <ul class="dfe-f-sub-navigation__list">
 <li class="dfe-f-sub-navigation__item dfe-f-sub-navigation__item--active">
 <button type="button" class="dfe-f-sub-navigation__link govuk-link tab on" onclick="switchTab(this,'rd-detail')">Detail</button>
 </li>
 <li class="dfe-f-sub-navigation__item">
 <button type="button" class="dfe-f-sub-navigation__link govuk-link tab" onclick="switchTab(this,'rd-kri')">Key risk indicators @if (Model.Kris?.Count> 0) { <span style="background:#d4351c;color:#fff;font-size:11px;font-weight:700;padding:1px 6px;border-radius:2px;margin-left:4px;">@Model.Kris.Count</span> }</button>
 </li>
 <li class="dfe-f-sub-navigation__item">
 <button type="button" class="dfe-f-sub-navigation__link govuk-link tab" onclick="switchTab(this,'rd-history')">History &amp; comments</button>
 </li>
 </ul>
  </nav>

 <div id="rd-detail" class="tab-pane on">
    <div style="padding:10px 16px;background:#f3f2f1;border:1px solid #dee0e2;border-left:4px solid #b1b4b6;margin-bottom:20px;font-size:13px;color:#505a5f;">
      <strong>Immutable fields:</strong> The original description, cause, and raised date are locked to preserve the audit record. You can update status, owner, mitigation, and add comments.
    </div>
    <div style="display:grid;grid-template-columns:2fr 1fr;gap:24px;align-items:start;">
      <div>
 <dl class="summary-list">
 <div class="sl-row sl-row--action"><dt>Description</dt><dd>@(string.IsNullOrEmpty(Model.Description) ? "—" : Model.Description)</dd><dd class="action"><span style="font-size:12px;color:#b1b4b6;font-weight:700;">Locked</span></dd></div>
 <div class="sl-row sl-row--action"><dt>Cause</dt><dd>@(string.IsNullOrEmpty(Model.Cause) ? "—" : Model.Cause)</dd><dd class="action"><span style="font-size:12px;color:#b1b4b6;font-weight:700;">Locked</span></dd></div>
 <div class="sl-row sl-row--action"><dt>Directorate</dt><dd>@(Model.Directorate?.Name ?? "—")</dd><dd class="action"><a href="@Url.Action("UpdateRisk", "ModernWork", new { workId, id = Model.Id })">Change</a></dd></div>
 <div class="sl-row sl-row--action"><dt>Tier</dt><dd><span style="background:#d2e2f1;color:#003078;border:1px solid #99b8d9;padding:2px 8px;font-size:12px;font-weight:700;">@(Model.Tier ?? "Tier 3")</span></dd><dd class="action"><a href="#">Edit</a></dd></div>
 <div class="sl-row sl-row--action"><dt>Impact on delivery</dt><dd>@(string.IsNullOrEmpty(Model.ImpactOnDelivery) ? "—" : Model.ImpactOnDelivery)</dd><dd class="action"><a href="#">Edit</a></dd></div>
 <div class="sl-row sl-row--action"><dt>Likelihood</dt><dd><span style="background:#fff7e0;color:#6e4900;border:1px solid #f5e4a0;padding:2px 8px;font-size:12px;font-weight:700;">@(Model.Likelihood ?? "—")</span></dd><dd class="action"><a href="#">Edit</a></dd></div>
 <div class="sl-row sl-row--action"><dt>Mitigation</dt><dd>@(string.IsNullOrEmpty(Model.MitigationOrAction) ? "—" : Model.MitigationOrAction)</dd><dd class="action"><a href="#">Edit</a></dd></div>
 <div class="sl-row sl-row--action"><dt>Proximity</dt><dd>@(string.IsNullOrEmpty(Model.Proximity) ? "—" : Model.Proximity)</dd><dd class="action"><a href="#">Edit</a></dd></div>
 <div class="sl-row sl-row--action"><dt>Owner</dt><dd>@ownerName</dd><dd class="action"><a href="#">Change</a></dd></div>
 <div class="sl-row sl-row--action"><dt>Linked milestone</dt><dd>@(Model.LinkedMilestone != null ? Model.LinkedMilestone.Name : "—")</dd><dd class="action">@(Model.LinkedMilestone != null ? Html.Raw("<a href=\"#\">View →</a>") : (object)"—")</dd></div>
          @if (materialisedIssue != null)
          {
 <div class="sl-row sl-row--action"><dt>Materialised as</dt><dd><a href="@Url.Action("IssueDetail", "ModernWork", new { workId, id = materialisedIssue.Id })">RI-@(materialisedIssue.ReferenceNumber.ToString("D5")) — @materialisedIssue.Title</a> <span style="font-size:13px;color:#505a5f;">(@materialisedIssue.RaisedAt.ToString("d MMM yyyy"))</span></dd><dd class="action"></dd></div>
          }
        </dl>
 <div class="dfe-c-button-row">
 <a href="@Url.Action("UpdateRisk", "ModernWork", new { workId, id = Model.Id })" class="govuk-button">Update risk</a>
 <a href="@Url.Action("RequestEscalation", "ModernWork", new { workId, id = Model.Id })" class="govuk-button govuk-button--secondary">Request escalation</a>
 <a href="@Url.Action("CloseRiskOrIssue", "ModernWork", new { workId, id = Model.Id })" class="govuk-button govuk-button--secondary">Close risk</a>
 <a href="@(Url.Action("Detail", "ModernWork", new { id = workId }))#wd-risks" class="govuk-button govuk-button--secondary">← Back</a>
        </div>
      </div>
 <div class="sidebar">
 <div class="dfe-c-card" style="border-top:3px solid #f47738;">
          <h3>Risk summary</h3>
 <div class="kv"><dt>Ref</dt><dd><strong>@riRef</strong></dd></div>
 <div class="kv"><dt>Type</dt><dd><span style="background:#f47738;color:#fff;padding:1px 7px;font-size:11px;font-weight:700;">Risk</span></dd></div>
 <div class="kv"><dt>Tier</dt><dd><span style="background:#d2e2f1;color:#003078;border:1px solid #99b8d9;padding:1px 7px;font-size:11px;font-weight:700;">@(Model.Tier ?? "Tier 3")</span></dd></div>
 <div class="kv"><dt>Rating</dt><dd><span style="background:#fff7e0;color:#6e4900;border:1px solid #f5e4a0;padding:2px 8px;font-size:12px;font-weight:700;">@(ViewBag.DeliveryRiskRating as string ?? "—")</span></dd></div>
 <div class="kv"><dt>Status</dt><dd><span style="background:#fff7e0;color:#6e4900;border:1px solid #f5e4a0;padding:2px 8px;font-size:12px;font-weight:700;">@Model.Status</span></dd></div>
 <div class="kv"><dt>Likelihood</dt><dd><span style="background:#fff7e0;color:#6e4900;border:1px solid #f5e4a0;padding:2px 8px;font-size:12px;font-weight:700;">@(Model.Likelihood ?? "—")</span></dd></div>
 <div class="kv"><dt>Owner</dt><dd>@ownerName</dd></div>
 <div class="kv"><dt>Directorate</dt><dd>@(Model.Directorate?.Name ?? "—")</dd></div>
 <div class="kv"><dt>Raised</dt><dd>@Model.RaisedAt.ToString("d MMM yyyy")</dd></div>
 <div class="kv"><dt>Last updated</dt><dd>@Model.UpdatedAt.ToString("d MMM yyyy")</dd></div>
 @if (materialisedIssue != null) { <div class="kv"><dt>Materialised</dt><dd><a href="@Url.Action("IssueDetail", "ModernWork", new { workId, id = materialisedIssue.Id })" style="font-size:13px;">RI-@(materialisedIssue.ReferenceNumber.ToString("D5")) →</a></dd></div> }
        </div>
      </div>
    </div>
  </div>

 <div id="rd-kri" class="tab-pane">
 <div class="dfe-c-flex--between mb4">
      <div>
        <h2 style="margin:0;">Key risk indicators</h2>
        <p style="margin-top:4px;font-size:14px;color:#505a5f;">KRIs are measurable signals that indicate whether a risk is trending towards materialising.</p>
      </div>
 <a href="@Url.Action("AddKri", "ModernWork", new { workId, riskOrIssueId = Model.Id })" class="govuk-button govuk-button--secondary govuk-button--sm">Add KRI</a>
    </div>
    @if (Model.Kris?.Any() == true)
    {
      foreach (var kri in Model.Kris.OrderBy(k => k.ReferenceNumber))
      {
        var kriRef = "KRI-" + kri.ReferenceNumber.ToString("D3");
        var statusCol = string.Equals(kri.Status, "Breached", StringComparison.OrdinalIgnoreCase) ? "#d4351c" : string.Equals(kri.Status, "AtRisk", StringComparison.OrdinalIgnoreCase) ? "#f47738" : "#00703c";
        <div style="border:1px solid #dee0e2;border-left:5px solid @statusCol;margin-bottom:12px;overflow:hidden;background:#fff;">
          <div style="display:grid;grid-template-columns:1fr auto;gap:16px;padding:14px 18px;align-items:start;background:#f8f9fa;border-bottom:1px solid #dee0e2;">
            <div>
              <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:#505a5f;margin-bottom:3px;">@kriRef · @kri.Name</div>
              <div style="font-size:14px;">@(kri.WhatIsMeasured ?? "—")</div>
            </div>
            <div style="display:flex;align-items:center;gap:6px;"><span style="width:14px;height:14px;background:@statusCol;display:inline-block;"></span><span style="font-size:14px;font-weight:700;">@kri.Status</span></div>
          </div>
          <div style="padding:10px 18px;font-size:13px;">Threshold: @(kri.ThresholdDescription ?? "—") · Current: <strong>@(kri.CurrentValue ?? "—")</strong></div>
          <div style="display:flex;gap:8px;padding:10px 18px;background:#fff;align-items:center;">
 <a href="@Url.Action("KriUpdate", "ModernWork", new { workId, riskOrIssueId = Model.Id, kriId = kri.Id })" class="govuk-button govuk-button--sm">Provide update</a>
 <a href="@Url.Action("KriDetail", "ModernWork", new { workId, riskOrIssueId = Model.Id, kriId = kri.Id })" class="govuk-button govuk-button--secondary govuk-button--sm">View details &amp; history</a>
          </div>
        </div>
      }
    }
    else
    {
 <p class="dfe-c-body muted">No KRIs defined for this risk yet.</p>
    }
  </div>

 <div id="rd-history" class="tab-pane">
 <div class="dfe-c-flex--between mb4">
      <h2 style="margin:0;">History &amp; comments</h2>
 <button type="button" class="govuk-button govuk-button--secondary govuk-button--sm">Add comment</button>
    </div>
    <div style="border:1px solid #dee0e2;">
      <div style="display:grid;grid-template-columns:140px 1fr 120px;background:#f3f2f1;padding:10px 14px;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:#505a5f;border-bottom:1px solid #dee0e2;">
        <div>When</div><div>Event / Comment</div><div>Who</div>
      </div>
      <div style="display:grid;grid-template-columns:140px 1fr 120px;padding:12px 14px;align-items:start;background:#f8f9fa;">
        <div style="font-size:12px;color:#505a5f;">@Model.RaisedAt.ToString("d MMM yyyy")</div>
        <div style="font-size:13px;"><strong>Risk raised.</strong> Rating: @(ViewBag.DeliveryRiskRating as string ?? "—"). Tier: @(Model.Tier ?? "—"). Status: @Model.Status.</div>
        <div style="font-size:13px;">@(Model.CreatedBy ?? "—")</div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
<script>
  function switchTab(btn, paneId) {
    document.querySelectorAll('#risk-detail-tabs .tab').forEach(function(t){ t.classList.remove('on'); });
    document.querySelectorAll('#risk-detail-tabs .dfe-f-sub-navigation__item').forEach(function(li){ li.classList.remove('dfe-f-sub-navigation__item--active'); });
    document.querySelectorAll('#rd-detail, #rd-kri, #rd-history').forEach(function(p){ p.classList.remove('on'); });
    if (btn) {
      btn.classList.add('on');
      var li = btn.closest('.dfe-f-sub-navigation__item');
      if (li) li.classList.add('dfe-f-sub-navigation__item--active');
    }
    var p = document.getElementById(paneId);
    if (p) p.classList.add('on');
  }
</script>
}
