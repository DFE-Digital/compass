@model Compass.Models.Modern.Work.WorkItem
@using Compass.Models.Modern.Work
@{
  var riskAppetiteOptions = ViewBag.RiskAppetiteOptions as List<LookupOption> ?? new List<LookupOption>();
}

@* ── Title ── *@
<dialog class="risk-detail-dialog" id="dlg-work-title" aria-labelledby="dlg-work-title-h">
 <div class="wo-dialog__header">
    <h2 id="dlg-work-title-h">Change title</h2>
 <button type="button" class="wo-dialog__close js-work-overview-dialog-close" aria-label="Close">&times;</button>
  </div>
  <form method="post" action="@Url.Action("UpdateWorkOverviewTitle", "ModernWork", new { id = Model.Id })">
    @Html.AntiForgeryToken()
 <div class="wo-dialog__body">
 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="wo-Title">Title</label>
 <span class="dfe-c-form__hint">The public name of this work item as it appears in registers and reports.</span>
 <input class="dfe-c-width-full" id="wo-Title" name="Title" type="text" value="@Model.Title" required />
      </div>
    </div>
 <div class="wo-dialog__footer">
 <button type="submit" class="govuk-button">Save</button>
 <button type="button" class="govuk-button govuk-button--secondary js-work-overview-dialog-close">Cancel</button>
    </div>
  </form>
</dialog>

@* ── Problem statement ── *@
<dialog class="risk-detail-dialog" id="dlg-work-problem" aria-labelledby="dlg-work-problem-h">
 <div class="wo-dialog__header">
    <h2 id="dlg-work-problem-h">Change problem statement</h2>
 <button type="button" class="wo-dialog__close js-work-overview-dialog-close" aria-label="Close">&times;</button>
  </div>
  <form method="post" action="@Url.Action("UpdateWorkOverviewProblemStatement", "ModernWork", new { id = Model.Id })">
    @Html.AntiForgeryToken()
 <div class="wo-dialog__body">
 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="wo-ProblemStatement">Problem statement</label>
 <span class="dfe-c-form__hint">Describe the problem or user need this work addresses.</span>
 <textarea class="dfe-c-width-full" id="wo-ProblemStatement" name="ProblemStatement" rows="5">@Model.ProblemStatement</textarea>
      </div>
    </div>
 <div class="wo-dialog__footer">
 <button type="submit" class="govuk-button">Save</button>
 <button type="button" class="govuk-button govuk-button--secondary js-work-overview-dialog-close">Cancel</button>
    </div>
  </form>
</dialog>

@* ── Aim ── *@
<dialog class="risk-detail-dialog" id="dlg-work-aim" aria-labelledby="dlg-work-aim-h">
 <div class="wo-dialog__header">
    <h2 id="dlg-work-aim-h">Change aim</h2>
 <button type="button" class="wo-dialog__close js-work-overview-dialog-close" aria-label="Close">&times;</button>
  </div>
  <form method="post" action="@Url.Action("UpdateWorkOverviewAim", "ModernWork", new { id = Model.Id })">
    @Html.AntiForgeryToken()
 <div class="wo-dialog__body">
 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="wo-Aim">Aim</label>
 <span class="dfe-c-form__hint">A short summary of what this work intends to achieve.</span>
 <textarea class="dfe-c-width-full" id="wo-Aim" name="Aim" rows="4">@Model.Aim</textarea>
      </div>
    </div>
 <div class="wo-dialog__footer">
 <button type="submit" class="govuk-button">Save</button>
 <button type="button" class="govuk-button govuk-button--secondary js-work-overview-dialog-close">Cancel</button>
    </div>
  </form>
</dialog>

@* ── Flagship project ── *@
<dialog class="risk-detail-dialog" id="dlg-work-flagship" aria-labelledby="dlg-work-flagship-h">
 <div class="wo-dialog__header">
    <h2 id="dlg-work-flagship-h">Change flagship status</h2>
 <button type="button" class="wo-dialog__close js-work-overview-dialog-close" aria-label="Close">&times;</button>
  </div>
  <form method="post" action="@Url.Action("UpdateWorkOverviewFlagship", "ModernWork", new { id = Model.Id })">
    @Html.AntiForgeryToken()
 <div class="wo-dialog__body">
 <fieldset class="dfe-c-form__group" style="border:0;padding:0;margin:0;">
 <legend class="dfe-c-form__label">Flagship project</legend>
 <span class="dfe-c-form__hint">Flagship projects appear prominently in reporting.</span>
 <div class="dfe-c-form__check-group">
 <label class="dfe-c-form__check-item" for="wo-FlagshipProject">
            <input id="wo-FlagshipProject" name="FlagshipProject" type="checkbox" value="true" @(Model.FlagshipProject ? "checked" : "") />
            <div>This is a flagship project</div>
          </label>
        </div>
      </fieldset>
    </div>
 <div class="wo-dialog__footer">
 <button type="submit" class="govuk-button">Save</button>
 <button type="button" class="govuk-button govuk-button--secondary js-work-overview-dialog-close">Cancel</button>
    </div>
  </form>
</dialog>

@* ── Subject to spend control ── *@
<dialog class="risk-detail-dialog" id="dlg-work-spend" aria-labelledby="dlg-work-spend-h">
 <div class="wo-dialog__header">
    <h2 id="dlg-work-spend-h">Change spend control</h2>
 <button type="button" class="wo-dialog__close js-work-overview-dialog-close" aria-label="Close">&times;</button>
  </div>
  <form method="post" action="@Url.Action("UpdateWorkOverviewSpendControl", "ModernWork", new { id = Model.Id })">
    @Html.AntiForgeryToken()
 <div class="wo-dialog__body">
 <fieldset class="dfe-c-form__group" style="border:0;padding:0;margin:0;">
 <legend class="dfe-c-form__label">Spend control</legend>
 <span class="dfe-c-form__hint">Check this if the work requires spend approval.</span>
 <div class="dfe-c-form__check-group">
 <label class="dfe-c-form__check-item" for="wo-SubjectToSpendControl">
            <input id="wo-SubjectToSpendControl" name="SubjectToSpendControl" type="checkbox" value="true" @(Model.SubjectToSpendControl ? "checked" : "") />
            <div>Subject to spend control</div>
          </label>
        </div>
      </fieldset>
    </div>
 <div class="wo-dialog__footer">
 <button type="submit" class="govuk-button">Save</button>
 <button type="button" class="govuk-button govuk-button--secondary js-work-overview-dialog-close">Cancel</button>
    </div>
  </form>
</dialog>

@* ── Risk appetite ── *@
<dialog class="risk-detail-dialog" id="dlg-work-risk-appetite" aria-labelledby="dlg-work-risk-appetite-h">
 <div class="wo-dialog__header">
    <h2 id="dlg-work-risk-appetite-h">Change risk appetite</h2>
 <button type="button" class="wo-dialog__close js-work-overview-dialog-close" aria-label="Close">&times;</button>
  </div>
  <form method="post" action="@Url.Action("UpdateWorkOverviewRiskAppetite", "ModernWork", new { id = Model.Id })">
    @Html.AntiForgeryToken()
 <div class="wo-dialog__body">
 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="wo-RiskAppetiteId">Risk appetite</label>
 <span class="dfe-c-form__hint">The agreed level of risk the organisation is willing to accept for this work.</span>
 <select class="dfe-c-width-full" id="wo-RiskAppetiteId" name="RiskAppetiteId">
          <option value="">— Select —</option>
          @foreach (var opt in riskAppetiteOptions)
          {
            <option value="@opt.Id" selected="@(Model.RiskAppetiteId == opt.Id)">@opt.Name</option>
          }
        </select>
      </div>
    </div>
 <div class="wo-dialog__footer">
 <button type="submit" class="govuk-button">Save</button>
 <button type="button" class="govuk-button govuk-button--secondary js-work-overview-dialog-close">Cancel</button>
    </div>
  </form>
</dialog>

@* ── Start date ── *@
<dialog class="risk-detail-dialog" id="dlg-work-start-date" aria-labelledby="dlg-work-start-date-h">
 <div class="wo-dialog__header">
    <h2 id="dlg-work-start-date-h">Change start date</h2>
 <button type="button" class="wo-dialog__close js-work-overview-dialog-close" aria-label="Close">&times;</button>
  </div>
  <form method="post" action="@Url.Action("UpdateWorkOverviewStartDate", "ModernWork", new { id = Model.Id })">
    @Html.AntiForgeryToken()
 <div class="wo-dialog__body">
 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="wo-StartDate">Start date</label>
 <span class="dfe-c-form__hint">When this work item started or is expected to start.</span>
 <input class="dfe-c-width-full" id="wo-StartDate" name="StartDate" type="date" value="@(Model.StartDate?.ToString("yyyy-MM-dd"))" />
      </div>
    </div>
 <div class="wo-dialog__footer">
 <button type="submit" class="govuk-button">Save</button>
 <button type="button" class="govuk-button govuk-button--secondary js-work-overview-dialog-close">Cancel</button>
    </div>
  </form>
</dialog>

@* ── Target end date ── *@
<dialog class="risk-detail-dialog" id="dlg-work-target-end" aria-labelledby="dlg-work-target-end-h">
 <div class="wo-dialog__header">
    <h2 id="dlg-work-target-end-h">Change target end date</h2>
 <button type="button" class="wo-dialog__close js-work-overview-dialog-close" aria-label="Close">&times;</button>
  </div>
  <form method="post" action="@Url.Action("UpdateWorkOverviewTargetEndDate", "ModernWork", new { id = Model.Id })">
    @Html.AntiForgeryToken()
 <div class="wo-dialog__body">
 <div class="dfe-c-form__group">
 <label class="dfe-c-form__label" for="wo-TargetEndDate">Target end date</label>
 <span class="dfe-c-form__hint">The planned completion date for this work item.</span>
 <input class="dfe-c-width-full" id="wo-TargetEndDate" name="TargetEndDate" type="date" value="@(Model.TargetEndDate?.ToString("yyyy-MM-dd"))" />
      </div>
    </div>
 <div class="wo-dialog__footer">
 <button type="submit" class="govuk-button">Save</button>
 <button type="button" class="govuk-button govuk-button--secondary js-work-overview-dialog-close">Cancel</button>
    </div>
  </form>
</dialog>
