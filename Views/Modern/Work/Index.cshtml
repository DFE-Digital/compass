@model Compass.Models.Modern.Work.WorkRegisterViewModel
@using Compass.Models.Modern.Work
@using Compass.ViewModels.Modern
@{
    ViewData["Title"] = Model.PageTitle;
    var activePausedCount = Model.ActivePaused.Count;
    var businessAreaCount = Model.BusinessAreas?.Count ?? 0;
    var indexAction = "Index";
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="/">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">@Model.PageTitle</li>
}

@{
  var indexHeaderActions = await Html.PartialAsync("_WorkIndexHeaderActions");
  var indexHeaderLede = await Html.PartialAsync("_WorkIndexHeaderLede", Model);
}
@await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
  Caption = "Work",
  Title = Model.PageTitle,
  Lede = indexHeaderLede,
  Actions = indexHeaderActions
})


  <!-- Summary metrics -->
 <div class="dfe-f-card-grid govuk-!-margin-bottom-3" role="region" aria-label="Work register summary">
 <div class="dfe-f-stat-card dfe-f-stat-card--tint-green">
 <p class="govuk-body-s dfe-f-stat-card__label">Active work items</p>
 <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@Model.ActiveCount</p>
    </div>
 <div class="dfe-f-stat-card dfe-f-stat-card--tint-orange">
 <p class="govuk-body-s dfe-f-stat-card__label">Paused</p>
 <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@Model.PausedCount</p>
    </div>
 <div class="dfe-f-stat-card @(Model.RagRedCount > 0 ? "dfe-f-stat-card--tint-red" : "dfe-f-stat-card--tint-teal")">
 <p class="govuk-body-s dfe-f-stat-card__label">@(Model.RagRedCount > 0 ? "⚠ RAG: Red" : "RAG: Red")</p>
 <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@Model.RagRedCount</p>
    </div>
 <div class="dfe-f-stat-card dfe-f-stat-card--tint-blue">
 <p class="govuk-body-s dfe-f-stat-card__label">Awaiting monthly update</p>
 <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@Model.AwaitingMonthlyCount</p>
      @if (Model.AwaitingMonthlyOverdue)
      {
 <p class="govuk-body-s govuk-!-margin-top-2 govuk-!-margin-bottom-0">Overdue</p>
      }
    </div>
  </div>

  <!-- Filter toolbar (right-aligned) + expanding panel with Apply/Clear inside -->
  <form method="get" action="@Url.Action(indexAction, "ModernWork")" id="work-register-form">
    <input type="hidden" name="tab" id="work-active-tab" value="active" />
 <div class="filter-toolbar">
 <div class="filter-toolbar__search-wrap">
 <input type="search" name="search" id="work-register-search" value="@Model.FilterSearch" placeholder="Search work items…" class="filter-search" autocomplete="off" aria-label="Search work items" />
 <button type="submit" class="govuk-button govuk-button--secondary filter-toolbar__search-submit" id="work-search-submit">Search</button>
      </div>
 <details class="filter-toolbar__details">
 <summary class="filter-toggle-btn filter-toolbar__filter-summary" id="work-filter-btn" aria-controls="work-filter-panel">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="flex-shrink:0;" aria-hidden="true"><path d="M1 3h14v1.5l-5 5V14l-4-2V9.5L1 4.5V3z"></path></svg>
 <span class="filter-toggle-label">Filter</span>
        </summary>
 <div class="filter-panel filter-panel--allwork" id="work-filter-panel">
 <div class="filter-panel__grid">
      <div>
        <label for="filter-rag">RAG</label>
        <select name="ragId" id="filter-rag" class="govuk-select">
          <option value="">All</option>
          @foreach (var r in Model.RagOptions)
          {
            if (Model.FilterRagId == r.Id)
            {
              <option value="@r.Id" selected>@r.Name</option>
            }
            else
            {
              <option value="@r.Id">@r.Name</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="filter-phase">Phase</label>
        <select name="phaseId" id="filter-phase" class="govuk-select">
          <option value="">All</option>
          @foreach (var o in Model.DeliveryPhaseOptions)
          {
            if (Model.FilterPhaseId == o.Id)
            {
              <option value="@o.Id" selected>@(o.Name ?? o.Value)</option>
            }
            else
            {
              <option value="@o.Id">@(o.Name ?? o.Value)</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="filter-businessarea">Business area</label>
        <select name="businessAreaId" id="filter-businessarea" class="govuk-select">
          <option value="">All (@businessAreaCount)</option>
          @foreach (var b in Model.BusinessAreas)
          {
            if (Model.FilterBusinessAreaId == b.Id)
            {
              <option value="@b.Id" selected>@b.Name</option>
            }
            else
            {
              <option value="@b.Id">@b.Name</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="filter-directorate">Directorate</label>
        <select name="directorateId" id="filter-directorate" class="govuk-select">
          <option value="">All</option>
          @foreach (var d in Model.Directorates)
          {
            if (Model.FilterDirectorateId == d.Id)
            {
              <option value="@d.Id" selected>@d.Name</option>
            }
            else
            {
              <option value="@d.Id">@d.Name</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="filter-priority">Priority</label>
        <select name="priorityId" id="filter-priority" class="govuk-select">
          <option value="">All</option>
          @foreach (var o in Model.PriorityOptions)
          {
            if (Model.FilterPriorityId == o.Id)
            {
              <option value="@o.Id" selected>@(o.Name ?? o.Value)</option>
            }
            else
            {
              <option value="@o.Id">@(o.Name ?? o.Value)</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="filter-monthly">Monthly update</label>
        <select name="monthlyUpdate" id="filter-monthly" class="govuk-select">
          @if (string.IsNullOrEmpty(Model.FilterMonthlyUpdate))
          {
            <option value="" selected>All</option>
          }
          else
          {
            <option value="">All</option>
          }
          @if (string.Equals(Model.FilterMonthlyUpdate, "overdue", StringComparison.OrdinalIgnoreCase))
          {
            <option value="overdue" selected>Overdue</option>
          }
          else
          {
            <option value="overdue">Overdue</option>
          }
          @if (string.Equals(Model.FilterMonthlyUpdate, "due-today", StringComparison.OrdinalIgnoreCase))
          {
            <option value="due-today" selected>Due today</option>
          }
          else
          {
            <option value="due-today">Due today</option>
          }
          @if (string.Equals(Model.FilterMonthlyUpdate, "submitted", StringComparison.OrdinalIgnoreCase))
          {
            <option value="submitted" selected>Submitted</option>
          }
          else
          {
            <option value="submitted">Submitted</option>
          }
          @if (string.Equals(Model.FilterMonthlyUpdate, "not-required", StringComparison.OrdinalIgnoreCase))
          {
            <option value="not-required" selected>Not required</option>
          }
          else
          {
            <option value="not-required">Not required</option>
          }
        </select>
      </div>
      <div>
        <label for="filter-primarycontact">Primary contact</label>
        <select name="primaryContactUserId" id="filter-primarycontact" class="govuk-select">
          <option value="">All</option>
          @foreach (var pc in Model.PrimaryContactFilterOptions)
          {
            if (Model.FilterPrimaryContactUserId == pc.UserId)
            {
              <option value="@pc.UserId" selected>@pc.DisplayName</option>
            }
            else
            {
              <option value="@pc.UserId">@pc.DisplayName</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="filter-tags">Tags</label>
        @if ((Model.TagFilterOptions?.Count ?? 0) == 0)
        {
 <p class="dfe-c-body-s dfe-c-text-muted govuk-!-margin-bottom-0" id="filter-tags">No tags defined.</p>
        }
        else
        {
 <select name="tagId" id="filter-tags" class="govuk-select">
          <option value="">All tags</option>
          @foreach (var tg in Model.TagFilterOptions!)
          {
            if (Model.FilterTagId == tg.Id)
            {
              <option value="@tg.Id" selected>@(tg.Name ?? tg.Value)</option>
            }
            else
            {
              <option value="@tg.Id">@(tg.Name ?? tg.Value)</option>
            }
          }
        </select>
        }
      </div>
 </div>
 <div class="filter-panel__actions">
 <button type="submit" class="govuk-button">Apply</button>
 <a href="@Url.Action(indexAction, "ModernWork")" class="govuk-link govuk-link--no-visited-state">Clear filters</a>
      </div>
    </div>
      </details>
      <button type="submit"
 class="govuk-button govuk-button--outline-blue"
              formaction="@Url.Action("ExportRegister", "ModernWork", new {
                  scope = "index",
                  search = Model.FilterSearch,
                  businessAreaId = Model.FilterBusinessAreaId,
                  directorateId = Model.FilterDirectorateId,
                  phaseId = Model.FilterPhaseId,
                  ragId = Model.FilterRagId,
                  priorityId = Model.FilterPriorityId,
                  monthlyUpdate = Model.FilterMonthlyUpdate,
                  primaryContactUserId = Model.FilterPrimaryContactUserId,
                  tagId = Model.FilterTagId,
                  sort = Model.RegisterSortField,
                  sd = Model.RegisterSortDescending
              })"
              formmethod="get">
        Export this view
      </button>
    </div>
  </form>

  <!-- Work register status switches -->
 <nav class="tabs dfe-f-sub-navigation govuk-!-margin-bottom-3" aria-label="Work register status">
 <ul class="dfe-f-sub-navigation__list">
 <li class="dfe-f-sub-navigation__item dfe-f-sub-navigation__item--active">
 <button type="button" class="dfe-f-sub-navigation__link govuk-link tab on" onclick="switchTab(this,'wreg-active')">Active &amp; Paused (@activePausedCount)</button>
 </li>
 <li class="dfe-f-sub-navigation__item">
 <button type="button" class="dfe-f-sub-navigation__link govuk-link tab" onclick="switchTab(this,'wreg-completed')">Completed (@Model.CompletedCount)</button>
 </li>
 <li class="dfe-f-sub-navigation__item">
 <button type="button" class="dfe-f-sub-navigation__link govuk-link tab" onclick="switchTab(this,'wreg-cancelled')">Cancelled (@Model.CancelledCount)</button>
 </li>
 </ul>
  </nav>

  <!-- Active & Paused -->
 <div id="wreg-active" class="tab-pane on">
    <div style="overflow-x:auto;">
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
 <table class="govuk-table modern-work-table">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Title</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Status</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Primary contact</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Business area</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Phase</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Priority</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Milestones</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">RAG</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">@Model.RegisterMonthlyColumnHeader</button>
        </th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          @foreach (var r in Model.ActivePaused)
          {
 <tr class="wreg-row" data-searchable="@(r.Title ?? "") @(r.PrimaryContactName ?? "") @(r.BusinessAreaName ?? "") @(r.PhaseName ?? "") @(r.PriorityName ?? "") @(r.RagName ?? "") @(r.Id.ToString("D8"))" onclick="window.location.href='@Url.Action("Detail", "ModernWork", new { id = r.Id })';">
              <td class="govuk-table__cell">
                <a href="@Url.Action("Detail", "ModernWork", new { id = r.Id })" class="govuk-link govuk-link--no-visited-state">@r.Title</a>
                <div class="govuk-body-s dfe-t-u-text-muted modern-work-table__meta">WI-@r.Id.ToString("D8")</div>
              </td>
 <td class="govuk-table__cell"><span class="@WorkBadgeCss.StatusDfeFrontendBadgeClass(r.Status)">@r.Status</span></td>
              <td class="govuk-table__cell">@(r.PrimaryContactName ?? "—")</td>
              <td class="govuk-table__cell">@(r.BusinessAreaName ?? "—")</td>
 <td class="govuk-table__cell"><span class="@WorkBadgeCss.PhaseDfeFrontendBadgeClass(r.PhaseName)">@(r.PhaseName ?? "—")</span></td>
 <td class="govuk-table__cell"><span class="@WorkBadgeCss.PriorityDfeFrontendBadgeClass(r.PriorityName)">@((r.PriorityName ?? "—").ToUpperInvariant())</span></td>
 <td class="govuk-table__cell"><span class="wreg-milestone-count">@r.MilestoneCount</span></td>
 <td class="govuk-table__cell"><span class="@WorkBadgeCss.RagDfeFrontendBadgeClass(r.RagCssClass, r.RagName)">@((r.RagName ?? "—").ToUpperInvariant())</span></td>
              <td class="govuk-table__cell">@await Html.PartialAsync("~/Views/Modern/Work/_WorkRegisterMonthlyUpdateCell.cshtml", r)</td>
            </tr>
          }
        </tbody>
      </table>
 </div>
    </div>
    @if (!Model.ActivePaused.Any())
    {
 <p class="dfe-c-body muted">No active or paused work items.</p>
    }
  </div>

  <!-- Completed -->
 <div id="wreg-completed" class="tab-pane">
    <div style="overflow-x:auto;">
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
 <table class="govuk-table modern-work-table">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Title</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Primary contact</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Business area</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Phase</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Priority</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Milestones</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Completed</button>
        </th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          @foreach (var r in Model.Completed)
          {
 <tr class="wreg-row" data-searchable="@(r.Title ?? "") @(r.PrimaryContactName ?? "") @(r.BusinessAreaName ?? "") @(r.PhaseName ?? "") @(r.PriorityName ?? "") @(r.Id.ToString("D8"))" onclick="window.location.href='@Url.Action("Detail", "ModernWork", new { id = r.Id })';">
              <td class="govuk-table__cell">
                <a href="@Url.Action("Detail", "ModernWork", new { id = r.Id })" class="govuk-link govuk-link--no-visited-state">@r.Title</a>
                <div class="govuk-body-s dfe-t-u-text-muted modern-work-table__meta">WI-@r.Id.ToString("D8")</div>
              </td>
              <td class="govuk-table__cell">@(r.PrimaryContactName ?? "—")</td>
              <td class="govuk-table__cell">@(r.BusinessAreaName ?? "—")</td>
 <td class="govuk-table__cell"><span class="@WorkBadgeCss.PhaseDfeFrontendBadgeClass(r.PhaseName)">@(r.PhaseName ?? "—")</span></td>
 <td class="govuk-table__cell"><span class="@WorkBadgeCss.PriorityDfeFrontendBadgeClass(r.PriorityName)">@((r.PriorityName ?? "—").ToUpperInvariant())</span></td>
 <td class="govuk-table__cell"><span class="wreg-milestone-count">@r.MilestoneCount</span></td>
              <td class="govuk-table__cell" style="font-size:13px;color:#505a5f;">@(r.CompletedAt ?? "—")</td>
            </tr>
          }
        </tbody>
      </table>
 </div>
    </div>
    @if (!Model.Completed.Any())
    {
 <p class="dfe-c-body muted">No completed work items.</p>
    }
  </div>

  <!-- Cancelled -->
 <div id="wreg-cancelled" class="tab-pane">
    <div style="overflow-x:auto;">
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
 <table class="govuk-table modern-work-table">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Title</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Primary contact</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Business area</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Priority</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Milestones</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Cancelled</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Reason</button>
        </th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          @foreach (var r in Model.Cancelled)
          {
 <tr class="wreg-row" data-searchable="@(r.Title ?? "") @(r.PrimaryContactName ?? "") @(r.BusinessAreaName ?? "") @(r.PriorityName ?? "") @(r.CancelledReason ?? "") @(r.Id.ToString("D8"))" onclick="window.location.href='@Url.Action("Detail", "ModernWork", new { id = r.Id })';">
              <td class="govuk-table__cell">
                <a href="@Url.Action("Detail", "ModernWork", new { id = r.Id })" class="govuk-link govuk-link--no-visited-state">@r.Title</a>
                <div class="govuk-body-s dfe-t-u-text-muted modern-work-table__meta">WI-@r.Id.ToString("D8")</div>
              </td>
              <td class="govuk-table__cell">@(r.PrimaryContactName ?? "—")</td>
              <td class="govuk-table__cell">@(r.BusinessAreaName ?? "—")</td>
 <td class="govuk-table__cell"><span class="@WorkBadgeCss.PriorityDfeFrontendBadgeClass(r.PriorityName)">@((r.PriorityName ?? "—").ToUpperInvariant())</span></td>
 <td class="govuk-table__cell"><span class="wreg-milestone-count">@r.MilestoneCount</span></td>
              <td class="govuk-table__cell" style="font-size:13px;color:#505a5f;">@(r.CompletedAt ?? "—")</td>
              <td class="govuk-table__cell" style="font-size:13px;color:#505a5f;">@(r.CancelledReason ?? "—")</td>
            </tr>
          }
        </tbody>
      </table>
 </div>
    </div>
    @if (!Model.Cancelled.Any())
    {
 <p class="dfe-c-body muted">No cancelled work items.</p>
    }
  </div>

@section Scripts {
<script>
(function(){
  function filterWorkRegisterBySearch() {
    var searchEl = document.getElementById('work-register-search');
    if (!searchEl) return;
    var q = (searchEl.value || '').trim().toLowerCase();
    var rows = document.querySelectorAll('.wreg-row');
    rows.forEach(function(tr) {
      var text = (tr.getAttribute('data-searchable') || tr.textContent || '').toLowerCase();
      var show = q === '' || text.indexOf(q) !== -1;
      tr.style.display = show ? '' : 'none';
    });
  }
  window.filterWorkRegisterBySearch = filterWorkRegisterBySearch;

  window.switchTab = function(btn, panelId) {
    var parent = btn.closest('.dfe-c-page') || document.body;
    parent.querySelectorAll('.tabs .tab').forEach(function(t){ t.classList.remove('on'); });
    parent.querySelectorAll('.tabs .dfe-f-sub-navigation__item').forEach(function(li){ li.classList.remove('dfe-f-sub-navigation__item--active'); });
    parent.querySelectorAll('.tab-pane').forEach(function(p){ p.classList.remove('on'); });
    btn.classList.add('on');
    var li = btn.closest('.dfe-f-sub-navigation__item');
    if (li) li.classList.add('dfe-f-sub-navigation__item--active');
    var panel = document.getElementById(panelId);
    if (panel) panel.classList.add('on');
    var tabField = document.getElementById('work-active-tab');
    if (tabField) {
      if (panelId === 'wreg-completed') tabField.value = 'completed';
      else if (panelId === 'wreg-cancelled') tabField.value = 'cancelled';
      else tabField.value = 'active';
    }
  };

  document.addEventListener('DOMContentLoaded', function() {
    var searchEl = document.getElementById('work-register-search');
    if (searchEl) {
      searchEl.addEventListener('input', filterWorkRegisterBySearch);
      searchEl.addEventListener('keyup', filterWorkRegisterBySearch);
      if ((searchEl.value || '').trim()) filterWorkRegisterBySearch();
    }
  });
})();
</script>
}
