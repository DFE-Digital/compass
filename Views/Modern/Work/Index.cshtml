@model Compass.Models.Modern.Work.WorkRegisterViewModel
@using Compass.Models.Modern.Work
@{
    ViewData["Title"] = Model.PageTitle;
    var activePausedCount = Model.ActivePaused.Count;
    var totalRegisterCount = Model.ActiveCount + Model.PausedCount + Model.CompletedCount + Model.CancelledCount;
    string RagBadgeClass(string? name) {
        if (string.IsNullOrEmpty(name)) return "rag-badge rag-none";
        var n = (name ?? "").ToLowerInvariant();
        if (n.Contains("green")) return "rag-badge rag-green";
        if (n.Contains("amber") && n.Contains("red")) return "rag-badge rag-amber-red";
        if (n.Contains("red")) return "rag-badge rag-red";
        if (n.Contains("amber")) return "rag-badge rag-amber";
        return "rag-badge rag-none";
    }
    string PriorityClass(string? name) {
        if (string.IsNullOrEmpty(name)) return "wreg-priority wreg-priority--medium";
        var n = (name ?? "").ToLowerInvariant();
        if (n.Contains("critical")) return "wreg-priority wreg-priority--critical";
        if (n.Contains("high")) return "wreg-priority wreg-priority--high";
        if (n.Contains("low")) return "wreg-priority wreg-priority--low";
        return "wreg-priority wreg-priority--medium";
    }
    var indexAction = "Index";
}
@section Breadcrumbs {
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="/">Home</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Dashboard", "ModernWork")">Work</a></li>
    <li class="dfe-c-breadcrumb__item" aria-current="page">@Model.PageTitle</li>
}

<div class="dfe-c-flex--between dfe-c-mb-3" style="flex-wrap:wrap;gap:1rem;">
  <div class="dfe-c-page-title" style="margin:0">
    <div class="dfe-c-page-title__caption">Work</div>
    <h1 class="dfe-c-page-title__heading">@Model.PageTitle</h1>
    <p class="dfe-c-page-title__lede">@totalRegisterCount work items (excludes deleted)</p>
    <p class="dfe-c-body dfe-c-text-muted dfe-c-mb-0 dfe-c-mt-1">@Model.PageDescription</p>
  </div>
  <div class="dfe-c-export-group" style="margin:0;">
    <a href="@Url.Action("DownloadExcel", "Exports")" class="govuk-button govuk-button--outline-blue">Export Excel</a>
    <a href="@Url.Action("Index", "Exports", new { section = "work" })" class="govuk-button govuk-button--outline-blue">All exports</a>
    <a href="@Url.Action("Create", "ModernWork")" class="govuk-button">Create work item</a>
  </div>
</div>


  <!-- Summary metrics (dfe-c-card-grid + dfe-c-metric — legacy .grid/.metric classes are not in modern CSS) -->
  <div class="dfe-c-card-grid dfe-c-card-grid--4 dfe-c-mb-3" role="region" aria-label="Work register summary">
    <div class="dfe-c-metric dfe-c-metric--green">
      <div class="dfe-c-metric__number">@Model.ActiveCount</div>
      <div class="dfe-c-metric__label">Active work items</div>
    </div>
    <div class="dfe-c-metric dfe-c-metric--amber">
      <div class="dfe-c-metric__number">@Model.PausedCount</div>
      <div class="dfe-c-metric__label">Paused</div>
    </div>
    <div class="dfe-c-metric @(Model.RagRedCount > 0 ? "dfe-c-metric--red" : "dfe-c-metric--teal")">
      <div class="dfe-c-metric__number">@Model.RagRedCount</div>
      <div class="dfe-c-metric__label" style="@(Model.RagRedCount > 0 ? "color:#d4351c;font-weight:700" : "")">@(Model.RagRedCount > 0 ? "⚠ RAG: Red" : "RAG: Red")</div>
    </div>
    <div class="dfe-c-metric dfe-c-metric--navy">
      <div class="dfe-c-metric__number">@Model.AwaitingMonthlyCount</div>
      <div class="dfe-c-metric__label">Awaiting monthly update</div>
      @if (Model.AwaitingMonthlyOverdue)
      {
        <div class="dfe-c-metric__note" style="color:var(--red, #d4351c);font-weight:700">Overdue</div>
      }
    </div>
  </div>

  <!-- Filter toolbar (right-aligned) + expanding panel with Apply/Clear inside -->
  <form method="get" action="@Url.Action(indexAction, "ModernWork")" id="work-register-form">
    <input type="hidden" name="tab" id="work-active-tab" value="active" />
    <div class="filter-toolbar">
      <div class="filter-toolbar__search-wrap">
        <input type="search" name="search" id="work-register-search" value="@Model.FilterSearch" placeholder="Search work items…" class="filter-search" autocomplete="off" aria-label="Search work items" />
        <button type="submit" class="govuk-button govuk-button--secondary filter-toolbar__search-submit" id="work-search-submit">Search</button>
      </div>
      <details class="filter-toolbar__details">
        <summary class="filter-toggle-btn filter-toolbar__filter-summary" id="work-filter-btn" aria-controls="work-filter-panel">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="flex-shrink:0;" aria-hidden="true"><path d="M1 3h14v1.5l-5 5V14l-4-2V9.5L1 4.5V3z"></path></svg>
          <span class="filter-toggle-label">Filter</span>
        </summary>
    <div class="filter-panel" id="work-filter-panel">
      <div>
        <label for="filter-portfolio">Portfolio</label>
        <select name="portfolioId" id="filter-portfolio">
          <option value="">All portfolios</option>
          @foreach (var p in Model.Portfolios)
          {
            if (Model.FilterPortfolioId == p.Id)
            {
              <option value="@p.Id" selected>@p.Name</option>
            }
            else
            {
              <option value="@p.Id">@p.Name</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="filter-directorate">Directorate</label>
        <select name="directorateId" id="filter-directorate">
          <option value="">All directorates</option>
          @foreach (var d in Model.Directorates)
          {
            if (Model.FilterDirectorateId == d.Id)
            {
              <option value="@d.Id" selected>@d.Name</option>
            }
            else
            {
              <option value="@d.Id">@d.Name</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="filter-phase">Phase</label>
        <select name="phaseId" id="filter-phase">
          <option value="">All phases</option>
          @foreach (var o in Model.DeliveryPhaseOptions)
          {
            if (Model.FilterPhaseId == o.Id)
            {
              <option value="@o.Id" selected>@(o.Name ?? o.Value)</option>
            }
            else
            {
              <option value="@o.Id">@(o.Name ?? o.Value)</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="filter-rag">RAG</label>
        <select name="ragId" id="filter-rag">
          <option value="">All RAG</option>
          @foreach (var r in Model.RagOptions)
          {
            if (Model.FilterRagId == r.Id)
            {
              <option value="@r.Id" selected>@r.Name</option>
            }
            else
            {
              <option value="@r.Id">@r.Name</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="filter-priority">Priority</label>
        <select name="priorityId" id="filter-priority">
          <option value="">All priorities</option>
          @foreach (var o in Model.PriorityOptions)
          {
            if (Model.FilterPriorityId == o.Id)
            {
              <option value="@o.Id" selected>@(o.Name ?? o.Value)</option>
            }
            else
            {
              <option value="@o.Id">@(o.Name ?? o.Value)</option>
            }
          }
        </select>
      </div>
      <div class="filter-panel__actions">
        <button type="submit" class="govuk-button">Apply</button>
        <a href="@Url.Action(indexAction, "ModernWork")" class="govuk-link">Clear filters</a>
      </div>
    </div>
      </details>
      <button type="submit"
              class="govuk-button govuk-button--outline-blue"
              formaction="@Url.Action("ExportRegister", "ModernWork", new { scope = "index" })"
              formmethod="get">
        Export this view
      </button>
    </div>
  </form>

  <!-- Tabs -->
  <div class="tabs">
    <button type="button" class="tab on" onclick="switchTab(this,'wreg-active')">Active &amp; Paused (@activePausedCount)</button>
    <button type="button" class="tab" onclick="switchTab(this,'wreg-completed')">Completed (@Model.CompletedCount)</button>
    <button type="button" class="tab" onclick="switchTab(this,'wreg-cancelled')">Cancelled (@Model.CancelledCount)</button>
  </div>

  <!-- Active & Paused -->
  <div id="wreg-active" class="tab-pane on">
    <div style="overflow-x:auto;">
      <table class="data-table">
        <thead>
          <tr>
            <th>Title</th>
            <th>Status</th>
            <th>Primary contact</th>
            <th>Portfolio</th>
            <th>Phase</th>
            <th>Priority</th>
            <th>Milestones</th>
            <th>RAG</th>
            <th>Monthly update</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var r in Model.ActivePaused)
          {
            <tr class="wreg-row" data-searchable="@(r.Title ?? "") @(r.PrimaryContactName ?? "") @(r.PortfolioName ?? "") @(r.PhaseName ?? "") @(r.PriorityName ?? "") @(r.RagName ?? "") @(r.Id.ToString("D8"))" onclick="window.location.href='@Url.Action("Detail", "ModernWork", new { id = r.Id })';">
              <td>
                <a href="@Url.Action("Detail", "ModernWork", new { id = r.Id })">@r.Title</a>
                <div style="font-size:12px;color:#505a5f;margin-top:2px;">WI-@r.Id.ToString("D8")</div>
              </td>
              <td><span class="@(r.Status == "Active" ? "wreg-status--active" : "wreg-status--paused")">@r.Status</span></td>
              <td>@(r.PrimaryContactName ?? "—")</td>
              <td>@(r.PortfolioName ?? "—")</td>
              <td><span class="wreg-phase" style="background:#d4efed;color:#00695C;border-color:#9ed0cb;">@(r.PhaseName ?? "—")</span></td>
              <td><span class="@PriorityClass(r.PriorityName)">@(r.PriorityName ?? "—")</span></td>
              <td><span class="wreg-milestone-count">@r.MilestoneCount</span></td>
              <td>@if (!string.IsNullOrEmpty(r.RagBackgroundColourKey) || !string.IsNullOrEmpty(r.RagTextColourKey))
              {
                <span class="rag-badge" style="@(string.IsNullOrEmpty(r.RagBackgroundColourKey) ? "" : "background-color: var(--govuk-colour-" + r.RagBackgroundColourKey + ");")@(string.IsNullOrEmpty(r.RagTextColourKey) ? "" : " color: var(--govuk-colour-" + r.RagTextColourKey + ");")">@(r.RagName ?? "—")</span>
              }
              else
              {
                <span class="@RagBadgeClass(r.RagName)">@(r.RagName ?? "—")</span>
              }</td>
              <td>
                @{
                  var monthlyText = r.MonthlyUpdateStatus ?? "—";
                  var monthlyCss = monthlyText.Contains("Submitted") ? "wreg-monthly--submitted" : (monthlyText.Contains("late") ? "wreg-monthly--overdue" : "");
                }
                @if (r.MonthlyUpdateStatusLink == "wd-updates")
                { <a href="@Url.Action("Detail", "ModernWork", new { id = r.Id })#wd-updates" class="dfe-c-link @monthlyCss">@monthlyText</a> }
                else if (r.MonthlyUpdateStatusLink == "add")
                { <a href="@Url.Action("AddMonthlyUpdate", "ModernWork", new { id = r.Id })" class="dfe-c-link @monthlyCss">@monthlyText</a> }
                else
                { <span class="@monthlyCss">@monthlyText</span> }
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
    @if (!Model.ActivePaused.Any())
    {
      <p class="dfe-c-body muted">No active or paused work items.</p>
    }
  </div>

  <!-- Completed -->
  <div id="wreg-completed" class="tab-pane">
    <div style="overflow-x:auto;">
      <table class="data-table">
        <thead>
          <tr>
            <th>Title</th>
            <th>Primary contact</th>
            <th>Portfolio</th>
            <th>Phase</th>
            <th>Priority</th>
            <th>Milestones</th>
            <th>Completed</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var r in Model.Completed)
          {
            <tr class="wreg-row" data-searchable="@(r.Title ?? "") @(r.PrimaryContactName ?? "") @(r.PortfolioName ?? "") @(r.PhaseName ?? "") @(r.PriorityName ?? "") @(r.Id.ToString("D8"))" onclick="window.location.href='@Url.Action("Detail", "ModernWork", new { id = r.Id })';">
              <td>
                <a href="@Url.Action("Detail", "ModernWork", new { id = r.Id })">@r.Title</a>
                <div style="font-size:12px;color:#505a5f;margin-top:2px;">WI-@r.Id.ToString("D8")</div>
              </td>
              <td>@(r.PrimaryContactName ?? "—")</td>
              <td>@(r.PortfolioName ?? "—")</td>
              <td><span class="wreg-phase" style="background:#f3f2f1;color:#505a5f;border-color:#dee0e2;">@(r.PhaseName ?? "—")</span></td>
              <td><span class="@PriorityClass(r.PriorityName)">@(r.PriorityName ?? "—")</span></td>
              <td><span class="wreg-milestone-count">@r.MilestoneCount</span></td>
              <td style="font-size:13px;color:#505a5f;">@(r.CompletedAt ?? "—")</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
    @if (!Model.Completed.Any())
    {
      <p class="dfe-c-body muted">No completed work items.</p>
    }
  </div>

  <!-- Cancelled -->
  <div id="wreg-cancelled" class="tab-pane">
    <div style="overflow-x:auto;">
      <table class="data-table">
        <thead>
          <tr>
            <th>Title</th>
            <th>Primary contact</th>
            <th>Portfolio</th>
            <th>Priority</th>
            <th>Milestones</th>
            <th>Cancelled</th>
            <th>Reason</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var r in Model.Cancelled)
          {
            <tr class="wreg-row" data-searchable="@(r.Title ?? "") @(r.PrimaryContactName ?? "") @(r.PortfolioName ?? "") @(r.PriorityName ?? "") @(r.CancelledReason ?? "") @(r.Id.ToString("D8"))" onclick="window.location.href='@Url.Action("Detail", "ModernWork", new { id = r.Id })';">
              <td>
                <a href="@Url.Action("Detail", "ModernWork", new { id = r.Id })">@r.Title</a>
                <div style="font-size:12px;color:#505a5f;margin-top:2px;">WI-@r.Id.ToString("D8")</div>
              </td>
              <td>@(r.PrimaryContactName ?? "—")</td>
              <td>@(r.PortfolioName ?? "—")</td>
              <td><span class="@PriorityClass(r.PriorityName)">@(r.PriorityName ?? "—")</span></td>
              <td><span class="wreg-milestone-count">@r.MilestoneCount</span></td>
              <td style="font-size:13px;color:#505a5f;">@(r.CompletedAt ?? "—")</td>
              <td style="font-size:13px;color:#505a5f;">@(r.CancelledReason ?? "—")</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
    @if (!Model.Cancelled.Any())
    {
      <p class="dfe-c-body muted">No cancelled work items.</p>
    }
  </div>

@section Scripts {
<script>
(function(){
  function filterWorkRegisterBySearch() {
    var searchEl = document.getElementById('work-register-search');
    if (!searchEl) return;
    var q = (searchEl.value || '').trim().toLowerCase();
    var rows = document.querySelectorAll('.wreg-row');
    rows.forEach(function(tr) {
      var text = (tr.getAttribute('data-searchable') || tr.textContent || '').toLowerCase();
      var show = q === '' || text.indexOf(q) !== -1;
      tr.style.display = show ? '' : 'none';
    });
  }
  window.filterWorkRegisterBySearch = filterWorkRegisterBySearch;

  window.switchTab = function(btn, panelId) {
    var parent = btn.closest('.dfe-c-page') || document.body;
    parent.querySelectorAll('.tabs .tab').forEach(function(t){ t.classList.remove('on'); });
    parent.querySelectorAll('.tab-pane').forEach(function(p){ p.classList.remove('on'); });
    btn.classList.add('on');
    var panel = document.getElementById(panelId);
    if (panel) panel.classList.add('on');
    var tabField = document.getElementById('work-active-tab');
    if (tabField) {
      if (panelId === 'wreg-completed') tabField.value = 'completed';
      else if (panelId === 'wreg-cancelled') tabField.value = 'cancelled';
      else tabField.value = 'active';
    }
  };

  document.addEventListener('DOMContentLoaded', function() {
    var searchEl = document.getElementById('work-register-search');
    if (searchEl) {
      searchEl.addEventListener('input', filterWorkRegisterBySearch);
      searchEl.addEventListener('keyup', filterWorkRegisterBySearch);
      if ((searchEl.value || '').trim()) filterWorkRegisterBySearch();
    }
  });
})();
</script>
}
