@model Compass.Models.Modern.Work.WorkItemRiskOrIssue
@using Compass.Models.Modern.Work
@{
    var work = ViewBag.WorkItem as WorkItem;
    var workId = Model.WorkItemId;
    var milestones = ViewBag.Milestones as List<Milestone> ?? new List<Milestone>();
    var appUsers = ViewBag.AppUsers as IEnumerable<dynamic> ?? new List<dynamic>();
    var directorates = ViewBag.DirectorateOptions as List<RiskIssueNamedIntOption> ?? new List<RiskIssueNamedIntOption>();
    var riRef = "RI-" + Model.ReferenceNumber.ToString("D5");
    ViewData["Title"] = "Update issue — " + riRef;
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Detail", "ModernWork", new { id = workId })">@(work?.Title ?? "Work")</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.RouteUrl("risks-issues-section", new { action = "RiskDetail", id = Model.Id, workId })">@riRef</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Update issue</li>
}

<div id="sc-work-updateissue">
  @await Html.PartialAsync("_WorkItemChrome", work)

 <div class="dfe-c-page-title">
 <div class="dfe-c-page-title__caption">WI-@(ViewBag.WorkIdShort ?? workId.ToString("D8")) · @(work?.Title) · @riRef</div>
    <h1>Update issue</h1>
  </div>

 <form method="post" action="@Url.Action("UpdateIssue", "ModernWork", new { workId, id = Model.Id })" class="dfe-c-card dfe-c-card--plain" style="max-width:720px;">
    @Html.AntiForgeryToken()
    <fieldset>
      <legend style="font-size:20px;border-bottom:3px solid #003a69;padding-bottom:10px;margin-bottom:20px;width:100%">@riRef — @Model.Title</legend>

 <div class="fg">
        <label for="Status">Status</label>
 <select id="Status" name="Status">
          <option value="Open" selected="@(Model.Status == "Open")">Open</option>
          <option value="In progress" selected="@(Model.Status == "In progress")">In progress</option>
          <option value="Escalated" selected="@(Model.Status == "Escalated")">Escalated</option>
          <option value="Closed" selected="@(Model.Status == "Closed")">Closed</option>
        </select>
      </div>
 <div class="fg">
        <label for="Priority">Priority</label>
 <select id="Priority" name="Priority">
          <option value="High" selected="@(Model.Priority == "High")">High</option>
          <option value="Medium" selected="@(Model.Priority == "Medium")">Medium</option>
          <option value="Low" selected="@(Model.Priority == "Low")">Low</option>
        </select>
      </div>
 <div class="fg">
        <label for="Tier">Tier</label>
        <input type="text" id="Tier" name="Tier" value="@Model.Tier" placeholder="e.g. Tier 1, Tier 2, Tier 3" />
      </div>
 <div class="fg">
        <label for="DirectorateId">Directorate <span style="color:var(--red)">*</span></label>
 <select id="DirectorateId" name="DirectorateId" class="dfe-c-width-full" required>
          <option value="">— Select —</option>
          @foreach (var d in directorates)
          {
            <option value="@d.Id" selected="@(Model.DirectorateId == d.Id)">@d.Name</option>
          }
        </select>
      </div>
 <div class="fg">
        <label for="OwnerUserId">Owner</label>
 <select id="OwnerUserId" name="OwnerUserId">
          <option value="">— Select —</option>
          @foreach (var u in appUsers)
          {
            <option value="@u.Id" selected="@(Model.OwnerUserId == u.Id)">@u.Display</option>
          }
        </select>
      </div>
 <div class="fg">
        <label for="MitigationOrAction">Action plan</label>
        <textarea id="MitigationOrAction" name="MitigationOrAction" rows="4" placeholder="What is being done to resolve this issue?">@Model.MitigationOrAction</textarea>
      </div>
 <div class="fg">
        <label for="ImpactOnDelivery">Impact on delivery</label>
        <textarea id="ImpactOnDelivery" name="ImpactOnDelivery" rows="3">@Model.ImpactOnDelivery</textarea>
      </div>
 <div class="fg">
        <label for="EscalatedTo">Escalated to</label>
        <input type="text" id="EscalatedTo" name="EscalatedTo" value="@Model.EscalatedTo" placeholder="Person or tier if escalated" />
      </div>
 <div class="fg">
        <label for="TargetResolutionDate">Target resolution date</label>
        <input type="date" id="TargetResolutionDate" name="TargetResolutionDate" value="@(Model.TargetResolutionDate?.ToString("yyyy-MM-dd"))" />
      </div>
 <div class="fg">
        <label for="LinkedMilestoneId">Linked milestone</label>
 <select id="LinkedMilestoneId" name="LinkedMilestoneId">
          <option value="">— None —</option>
          @foreach (var m in milestones)
          {
            <option value="@m.Id" selected="@(Model.LinkedMilestoneId == m.Id)">@m.Name</option>
          }
        </select>
      </div>
 <div class="dfe-c-button-row" style="margin-top:20px;">
 <button type="submit" class="govuk-button">Save changes</button>
 <a href="@Url.RouteUrl("risks-issues-section", new { action = "RiskDetail", id = Model.Id, workId })" class="govuk-button govuk-button--secondary">Cancel</a>
      </div>
    </fieldset>
  </form>
</div>
