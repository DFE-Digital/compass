@model Compass.ViewModels.Modern.WorkRegisterPaginationFooterViewModel
@if (Model.IsPaginated)
{
  <div class="modern-work-register-footer govuk-!-margin-top-6" aria-live="polite">
    <p class="dfe-c-text-muted modern-work-register-footer__count" id="work-showing-count">
      Showing @Model.DisplayRowStart–@Model.DisplayRowEnd of @Model.TotalCount.ToString("N0") @Model.ItemNoun
    </p>
    @if (Model.TotalPages > 1)
    {
      @await Html.PartialAsync("~/Views/Modern/Shared/_GovUkPagination.cshtml", new GovUkPaginationViewModel {
        CurrentPage = Model.CurrentPage,
        TotalPages = Model.TotalPages,
        PageUrl = Model.PageUrl,
        NavigationAriaLabel = Model.NavigationAriaLabel
      })
    }
  </div>
}
