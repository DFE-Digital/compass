@model IEnumerable<Compass.Models.Modern.Work.WorkItem>
@using Compass.Models.Modern.Work
@{
    ViewData["Title"] = "Watching";
    var items = Model?.ToList() ?? new List<WorkItem>();
    var count = items.Count;
    var portfolioNames = ViewBag.PortfolioNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var phaseNames = ViewBag.PhaseNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var priorityNames = ViewBag.PriorityNames as Dictionary<int, string> ?? new Dictionary<int, string>();
    var workStatusOptions = (List<LookupOption>)ViewBag.WorkStatusOptions ?? new List<LookupOption>();
    var portfolios = (List<Portfolio>)ViewBag.Portfolios ?? new List<Portfolio>();
    var directorates = (List<Directorate>)ViewBag.Directorates ?? new List<Directorate>();
    var portfolioCount = portfolios.Count;
    var filterPortfolioId = ViewBag.FilterPortfolioId as int?;
    var filterDirectorateId = ViewBag.FilterDirectorateId as int?;
    var filterSearch = ViewBag.Search as string;
    var filterStatus = ViewBag.StatusFilter as string;
    string PhaseDfeClass(string? name) {
        if (string.IsNullOrWhiteSpace(name) || name == "—") return "";
        var n = name.Trim().ToLowerInvariant().Replace(" ", "-");
        if (n.Contains("public") && n.Contains("beta")) return "dfe-c-phase--public-beta";
        if (n.Contains("private") && n.Contains("beta")) return "dfe-c-phase--private-beta";
        if (n.Contains("alpha")) return "dfe-c-phase--alpha";
        if (n.Contains("live")) return "dfe-c-phase--live";
        if (n.Contains("retired")) return "dfe-c-phase--retired";
        if (n.Contains("discovery")) return "dfe-c-phase--discovery";
        if (n.Contains("explore")) return "dfe-c-phase--explore";
        return "";
    }
    string RagDfeClass(string? name) {
        if (string.IsNullOrEmpty(name)) return "dfe-c-rag--tbc";
        var n = name.ToLowerInvariant();
        if (n.Contains("green")) return "dfe-c-rag--green";
        if (n.Contains("amber") && n.Contains("red")) return "dfe-c-rag--amber";
        if (n.Contains("red")) return "dfe-c-rag--red";
        if (n.Contains("amber")) return "dfe-c-rag--amber";
        return "dfe-c-rag--tbc";
    }
    string PriorityTagClass(string? name) {
        if (string.IsNullOrEmpty(name)) return "dfe-c-tag dfe-c-tag--grey";
        var s = name.ToLowerInvariant();
        if (s.Contains("high") || s.Contains("critical")) return "dfe-c-tag dfe-c-tag--red";
        if (s.Contains("medium")) return "dfe-c-tag dfe-c-tag--amber";
        if (s.Contains("low")) return "dfe-c-tag dfe-c-tag--green";
        return "dfe-c-tag dfe-c-tag--grey";
    }
    string StatusTagClass(string? s) {
        if (string.IsNullOrEmpty(s)) return "dfe-c-tag dfe-c-tag--grey";
        var x = s.ToLowerInvariant();
        if (x == "active") return "dfe-c-tag dfe-c-tag--green";
        if (x == "paused") return "dfe-c-tag dfe-c-tag--amber";
        if (x == "completed") return "dfe-c-tag dfe-c-tag--grey";
        if (x == "cancelled") return "dfe-c-tag dfe-c-tag--red";
        return "dfe-c-tag dfe-c-tag--grey";
    }
    string DirSummary(WorkItem w) =>
        w.Directorates?.Any() == true
            ? string.Join(", ", w.Directorates.Select(d => d.Division?.Name).Where(n => !string.IsNullOrEmpty(n)).Distinct().OrderBy(n => n))
            : "—";
}
@section Breadcrumbs {
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Dashboard", "ModernWork")">Work</a></li>
    <li class="dfe-c-breadcrumb__item" aria-current="page">Watching</li>
}

<div id="sc-work-watching" class="modern-work-page">
  <div class="dfe-c-flex--between dfe-c-mb-3" style="flex-wrap:wrap;gap:1rem;">
    <div class="dfe-c-page-title" style="margin:0;">
      <div class="dfe-c-page-title__caption">Work</div>
      <h1 class="dfe-c-page-title__heading">Watching</h1>
      <p class="dfe-c-page-title__lede">@(count == 0 ? "Work items you have opted to watch appear here." : $"{count} work item{(count == 1 ? "" : "s")} on your watch list")</p>
    </div>
  </div>

  <form method="get" action="@Url.Action("Watching", "ModernWork")" id="watching-register-form" class="dfe-c-mb-3">
    <div id="search-and-filter">
      <div class="filter-toolbar">
        <div class="filter-toolbar__search-wrap">
          <input type="search" name="search" id="watching-register-search" value="@filterSearch" placeholder="Search watched work…" class="filter-search" autocomplete="off" aria-label="Search watched work" />
          <button type="submit" class="govuk-button govuk-button--secondary filter-toolbar__search-submit">Search</button>
        </div>
        <button type="button" class="filter-toggle-btn" id="watching-filter-btn" aria-expanded="false" aria-controls="watching-filter-panel">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="flex-shrink:0;" aria-hidden="true"><path d="M1 3h14v1.5l-5 5V14l-4-2V9.5L1 4.5V3z"></path></svg>
          <span class="filter-toggle-label">Filter</span>
        </button>
      </div>
      <div class="filter-panel" id="watching-filter-panel">
        <div class="filter-panel__grid">
      <div>
        <label for="watching-portfolio">Portfolio</label>
        <select name="portfolioId" id="watching-portfolio" class="govuk-select">
          <option value="">All portfolios (@portfolioCount)</option>
          @foreach (var p in portfolios)
          {
            if (filterPortfolioId == p.Id)
            {
              <option value="@p.Id" selected>@p.Name</option>
            }
            else
            {
              <option value="@p.Id">@p.Name</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="watching-directorate">Directorate</label>
        <select name="directorateId" id="watching-directorate" class="govuk-select">
          <option value="">All directorates</option>
          @foreach (var d in directorates)
          {
            if (filterDirectorateId == d.Id)
            {
              <option value="@d.Id" selected>@d.Name</option>
            }
            else
            {
              <option value="@d.Id">@d.Name</option>
            }
          }
        </select>
      </div>
      <div>
        <label for="watching-status">Status</label>
        <select name="status" id="watching-status" class="govuk-select">
          <option value="">All statuses</option>
          @foreach (var opt in workStatusOptions)
          {
            if (filterStatus == opt.Value)
            {
              <option value="@opt.Value" selected>@opt.Name</option>
            }
            else
            {
              <option value="@opt.Value">@opt.Name</option>
            }
          }
        </select>
      </div>
        </div>
        <div class="filter-panel__actions">
          <button type="submit" class="govuk-button">Apply filters</button>
          <a href="@Url.Action("Watching", "ModernWork")" class="govuk-link">Clear filters</a>
        </div>
      </div>
    </div>
  </form>

  @if (count == 0)
  {
    <p class="dfe-c-text-muted">No watched work items match these filters. Clear filters or open a work item and choose &quot;Follow this work item&quot; to add it to your list.</p>
  }
  else
  {
    <div class="dfe-c-table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Work item</th>
            <th>Portfolio</th>
            <th>Directorate</th>
            <th>Phase</th>
            <th>Priority</th>
            <th>RAG</th>
            <th>Status</th>
            <th>Updated</th>
          </tr>
        </thead>
        <tbody>
        @foreach (var w in items)
        {
          var latestRag = w.RagHistory?.OrderByDescending(r => r.UpdatedAt).FirstOrDefault();
          var ragName = latestRag?.RagStatus?.Name ?? "";
          var rs = latestRag?.RagStatus;
          var phaseName = w.DeliveryPhaseId.HasValue && phaseNames.TryGetValue(w.DeliveryPhaseId.Value, out var ph) ? ph : null;
          var phaseClass = PhaseDfeClass(phaseName);
          var phaseDisplay = phaseClass != "" ? (phaseName ?? "").ToUpperInvariant() : (phaseName ?? "—");
          var priorityName = w.PriorityId.HasValue && priorityNames.TryGetValue(w.PriorityId.Value, out var pr) ? pr : null;
          <tr>
            <td>
              <a href="@Url.Action("Detail", "ModernWork", new { id = w.Id })">@w.Title</a>
              <span class="dfe-c-table-ref">WI-@w.Id.ToString("D8")</span>
            </td>
            <td>@(w.PortfolioId.HasValue && portfolioNames.TryGetValue(w.PortfolioId.Value, out var pname) ? pname : "—")</td>
            <td>@DirSummary(w)</td>
            <td>
              @if (!string.IsNullOrEmpty(phaseClass))
              {
                <span class="dfe-c-phase @phaseClass">@phaseDisplay</span>
              }
              else
              {
                <span>@(phaseName ?? "—")</span>
              }
            </td>
            <td><span class="@PriorityTagClass(priorityName)">@((priorityName ?? "—").ToUpperInvariant())</span></td>
            <td>
              @if (rs != null && (!string.IsNullOrEmpty(rs.BackgroundColourKey) || !string.IsNullOrEmpty(rs.TextColourKey)))
              {
                <span class="rag-badge" style="@(string.IsNullOrEmpty(rs.BackgroundColourKey) ? "" : "background-color: var(--govuk-colour-" + rs.BackgroundColourKey + ");")@(string.IsNullOrEmpty(rs.TextColourKey) ? "" : " color: var(--govuk-colour-" + rs.TextColourKey + ");")">@((ragName ?? "—").ToUpperInvariant())</span>
              }
              else
              {
                <span class="dfe-c-rag @RagDfeClass(ragName)">@((ragName ?? "—").ToUpperInvariant())</span>
              }
            </td>
            <td><span class="@StatusTagClass(w.Status)">@((w.Status ?? "—").ToUpperInvariant())</span></td>
            <td>@w.UpdatedAt.ToString("d MMM yyyy")</td>
          </tr>
        }
        </tbody>
      </table>
    </div>
    <p class="dfe-c-text-muted" style="margin:0.875rem 0 0;">Showing @count work item@(count == 1 ? "" : "s")</p>
  }
</div>
