@model Compass.Models.Modern.Work.WorkItem
@{
    var work = Model;
    var priorityOutcomes = (List<Compass.Models.Modern.Work.WorkLookupOption>)ViewBag.PriorityOutcomes ?? new List<Compass.Models.Modern.Work.WorkLookupOption>();
    var missionPillars = (List<Compass.Models.Modern.Work.WorkLookupOption>)ViewBag.MissionPillars ?? new List<Compass.Models.Modern.Work.WorkLookupOption>();
    var directorates = (List<Compass.Models.Directorate>)ViewBag.Directorates ?? new List<Compass.Models.Directorate>();
    var selectedPo = work.PriorityOutcomes?.Select(po => po.PriorityOutcomeId).ToHashSet() ?? new HashSet<int>();
    var selectedMp = work.MissionPillars?.Select(mp => mp.MissionPillarId).ToHashSet() ?? new HashSet<int>();
    var selectedDir = work.Directorates?.Select(d => d.DirectorateId).ToHashSet() ?? new HashSet<int>();
    ViewData["Title"] = "Edit strategic alignment";
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="/">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Detail", "ModernWork", new { id = Model.Id })">@work.Title</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Edit strategic alignment</li>
}

<div id="sc-work-editstrategicalignment">
  @await Html.PartialAsync("_WorkItemChrome", ViewBag.WorkItem as Compass.Models.Modern.Work.WorkItem ?? Model)

 <div class="dfe-c-page-title">
 <div class="dfe-c-page-title__caption">@work.Title</div>
 <h1 class="dfe-c-page-title__heading">Edit strategic alignment</h1>
 <p class="dfe-c-page-title__lede">Update flagship status, priority outcomes, mission pillars and directorate alignment for this work item.</p>
  </div>

 <div class="dfe-c-form-layout">
 <div class="dfe-c-form-layout__main">
 <div class="dfe-c-card dfe-c-card--plain">
        <form asp-action="EditStrategicAlignment" asp-route-id="@Model.Id" method="post">
          @Html.AntiForgeryToken()

 <fieldset class="dfe-c-form__group" style="border:0;padding:0;margin:0 0 1.25rem;">
 <legend class="dfe-c-form__label dfe-c-form__label--s">Flagship status</legend>
 <span class="dfe-c-form__hint">Flagship projects are highlighted across portfolio dashboards and reporting.</span>
            <input type="hidden" name="FlagshipProject" value="false" />
 <div class="dfe-c-form__check-group">
 <label class="dfe-c-form__check-item" for="FlagshipProject">
                <input id="FlagshipProject" name="FlagshipProject" type="checkbox" value="true" @(Model.FlagshipProject ? "checked" : "") />
                <div>This is a flagship project</div>
              </label>
            </div>
          </fieldset>

 <fieldset class="dfe-c-form__group" style="border:0;padding:0;margin:0 0 1.25rem;">
 <legend class="dfe-c-form__label dfe-c-form__label--s">Priority outcomes</legend>
 <span class="dfe-c-form__hint">Select all priority outcomes this work contributes to.</span>
 <div class="dfe-c-form__check-group">
              @foreach (var po in priorityOutcomes)
              {
 <label class="dfe-c-form__check-item" for="po_@po.Id">
                  <input id="po_@po.Id" name="PriorityOutcomeIds" type="checkbox" value="@po.Id" @(selectedPo.Contains(po.Id) ? "checked" : "") />
                  <div>@po.Name</div>
                </label>
              }
            </div>
            @if (!priorityOutcomes.Any())
            {
 <p class="dfe-c-body-s" style="color:var(--grey-4);">No priority outcomes configured. Ask an administrator to add them.</p>
            }
          </fieldset>

 <fieldset class="dfe-c-form__group" style="border:0;padding:0;margin:0 0 1.25rem;">
 <legend class="dfe-c-form__label dfe-c-form__label--s">Mission pillars</legend>
 <span class="dfe-c-form__hint">Select the mission pillars this work aligns to.</span>
 <div class="dfe-c-form__check-group">
              @foreach (var mp in missionPillars)
              {
 <label class="dfe-c-form__check-item" for="mp_@mp.Id">
                  <input id="mp_@mp.Id" name="MissionPillarIds" type="checkbox" value="@mp.Id" @(selectedMp.Contains(mp.Id) ? "checked" : "") />
                  <div>@mp.Name</div>
                </label>
              }
            </div>
            @if (!missionPillars.Any())
            {
 <p class="dfe-c-body-s" style="color:var(--grey-4);">No mission pillars configured. Ask an administrator to add them.</p>
            }
          </fieldset>

 <fieldset class="dfe-c-form__group" style="border:0;padding:0;margin:0 0 1.25rem;">
 <legend class="dfe-c-form__label dfe-c-form__label--s">Directorates</legend>
 <span class="dfe-c-form__hint">Select the directorates involved in delivering this work.</span>
 <div class="dfe-c-form__check-group">
              @foreach (var d in directorates)
              {
 <label class="dfe-c-form__check-item" for="dir_@d.Id">
                  <input id="dir_@d.Id" name="DirectorateIds" type="checkbox" value="@d.Id" @(selectedDir.Contains(d.Id) ? "checked" : "") />
                  <div>@d.Name</div>
                </label>
              }
            </div>
            @if (!directorates.Any())
            {
 <p class="dfe-c-body-s" style="color:var(--grey-4);">No directorates configured.</p>
            }
          </fieldset>

 <div class="dfe-c-button-group">
 <button type="submit" class="govuk-button">Save strategic alignment</button>
 <a href="@Url.Action("Detail", "ModernWork", new { id = Model.Id })#wd-overview" class="govuk-button govuk-button--secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>

 <div class="dfe-c-form-layout__aside">
 <div class="dfe-c-sidebar">
 <div class="dfe-c-scard">
 <div class="dfe-c-scard__title">About strategic alignment</div>
          <div style="font-size:0.8125rem;color:var(--grey-4);">Strategic alignment maps this work item to organisational priorities and governance structures. This information is used in portfolio reporting and directorate views.</div>
        </div>
 <div class="dfe-c-scard">
 <div class="dfe-c-scard__title">Priority outcomes</div>
          <div style="font-size:0.8125rem;color:var(--grey-4);">Priority outcomes are the strategic objectives defined at departmental level. Select the outcomes this work is expected to contribute to. These drive the priority outcomes reporting view.</div>
        </div>
 <div class="dfe-c-scard">
 <div class="dfe-c-scard__title">Mission pillars</div>
          <div style="font-size:0.8125rem;color:var(--grey-4);">Mission pillars represent cross-cutting delivery themes. A work item can align to more than one pillar. Pillar alignment is used in strategic and ministerial reporting.</div>
        </div>
 <div class="dfe-c-scard">
 <div class="dfe-c-scard__title">Current selections</div>
          <dl style="font-size:0.8125rem;margin:0;">
 <div class="dfe-c-kv"><dt>Flagship</dt><dd>@(work.FlagshipProject ? "Yes" : "No")</dd></div>
 <div class="dfe-c-kv"><dt>Outcomes</dt><dd>@selectedPo.Count selected</dd></div>
 <div class="dfe-c-kv"><dt>Pillars</dt><dd>@selectedMp.Count selected</dd></div>
 <div class="dfe-c-kv"><dt>Directorates</dt><dd>@selectedDir.Count selected</dd></div>
          </dl>
        </div>
      </div>
    </div>
  </div>
</div>
