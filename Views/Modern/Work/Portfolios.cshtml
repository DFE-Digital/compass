@model Compass.Models.Modern.Work.WorkPortfoliosViewModel
@using Compass.Models.Modern.Work
@using Compass.ViewModels.Modern
@{
    ViewData["Title"] = "Portfolios";
    string McCss(int p) => p >= 85 ? "var(--rag-g)" : p >= 50 ? "var(--rag-a)" : "var(--rag-r)";
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="/">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Portfolios</li>
}

<div id="sc-work-portfolios">
@{
  var portfoliosActions = await Html.PartialAsync("_PortfoliosHeaderActions");
  var portfoliosLede = await Html.PartialAsync("_GovukBodyParagraph", Model.LedePeriodLabel ?? "");
}
@await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
  Caption = "Work",
  Title = "Portfolios",
  Lede = portfoliosLede,
  Actions = portfoliosActions
})

  @if (Model.Rows.Count == 0)
  {
 <p class="dfe-c-text-muted">No active portfolios. Add portfolios in Admin.</p>
  }
  else
  {
 <div class="dfe-f-card-grid govuk-!-margin-bottom-3">
 <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
 <p class="govuk-body-s dfe-f-stat-card__label">Total work items</p>
 <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@Model.TotalWorkItems</p>
      </div>
 <div class="dfe-f-stat-card dfe-f-stat-card--tint-red">
 <p class="govuk-body-s dfe-f-stat-card__label">Red across portfolios</p>
 <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@Model.RedWorkCount</p>
      </div>
 <div class="dfe-f-stat-card dfe-f-stat-card--tint-orange">
 <p class="govuk-body-s dfe-f-stat-card__label">Monthly update compliance</p>
 <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@Model.MonthlyCompliancePercent%</p>
      </div>
    </div>

 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
      <table class="govuk-table">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Portfolio</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Directorate</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Head of portfolio</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Work items</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">RAG breakdown</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">RAG</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Monthly updates</button>
        </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Open risks</button>
        </th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
        @foreach (var row in Model.Rows)
        {
          var ragTotal = row.RagGreen + row.RagAmber + row.RagRed;
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">
              <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("Dashboard", "Reporting", new { section = "portfolio", portfolioId = row.PortfolioId })">@row.Name</a>
              @if (!string.IsNullOrWhiteSpace(row.Description))
              {
                <div>@row.Description</div>
              }
            </td>
            <td class="govuk-table__cell">@row.DirectorateDisplay</td>
            <td class="govuk-table__cell">@(row.HeadOfPortfolioDisplay ?? "—")</td>
            <td class="govuk-table__cell">@row.WorkItemCount</td>
            <td class="govuk-table__cell">
              @if (ragTotal == 0)
              {
 <span class="dfe-c-text-muted">—</span>
              }
              else
              {
                <div>
                  @if (row.RagGreen > 0)
                  {
                    <div></div>
                  }
                  @if (row.RagAmber > 0)
                  {
                    <div></div>
                  }
                  @if (row.RagRed > 0)
                  {
                    <div></div>
                  }
                </div>
                <div>@row.RagGreen G · @row.RagAmber A · @row.RagRed R</div>
              }
            </td>
 <td class="govuk-table__cell"><span class="dfe-c-rag @row.PortfolioRagClass">@row.PortfolioRagLabel</span></td>
            <td class="govuk-table__cell"><strong>@row.MonthlyCompliancePercent%</strong></td>
            <td class="govuk-table__cell">
              @if (row.OpenRisksCount > 0)
              {
                <a class="govuk-link govuk-link--no-visited-state" href="@Url.RouteUrl("risks-issues-section", new { action = "Register" })">@row.OpenRisksCount</a>
              }
              else
              {
 <span class="dfe-c-text-muted">0</span>
              }
            </td>
          </tr>
        }
        </tbody>
      </table>
    </div>
  }
</div>
