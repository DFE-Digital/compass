@model Compass.Models.Modern.Work.WorkPortfoliosViewModel
@using Compass.Models.Modern.Work
@{
    ViewData["Title"] = "Portfolios";
    string McCss(int p) => p >= 85 ? "var(--rag-g)" : p >= 50 ? "var(--rag-a)" : "var(--rag-r)";
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="/">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Portfolios</li>
}

<div id="sc-work-portfolios">
 <div class="dfe-c-flex--between dfe-c-mb-3" style="flex-wrap:wrap;gap:1rem;">
 <div class="dfe-c-page-title" style="margin:0;">
 <div class="dfe-c-page-title__caption">Work</div>
 <h1 class="dfe-c-page-title__heading">Portfolios</h1>
 <p class="dfe-c-page-title__lede">@Model.LedePeriodLabel</p>
    </div>
 <div class="dfe-c-export-group" style="margin:0;">
 <a class="govuk-button govuk-button--outline-blue" href="@Url.Action("ExportPortfolios", "ModernWork")">Export</a>
    </div>
  </div>

  @if (Model.Rows.Count == 0)
  {
 <p class="dfe-c-text-muted">No active portfolios. Add portfolios in Admin.</p>
  }
  else
  {
 <div class="dfe-c-grid dfe-c-grid--3 dfe-c-mb-3">
 <div class="dfe-c-metric dfe-c-metric--grey">
 <div class="dfe-c-metric__number">@Model.TotalWorkItems</div>
 <div class="dfe-c-metric__label">Total work items</div>
      </div>
 <div class="dfe-c-metric dfe-c-metric--red">
 <div class="dfe-c-metric__number" style="color:var(--rag-r);">@Model.RedWorkCount</div>
 <div class="dfe-c-metric__label">Red across portfolios</div>
      </div>
 <div class="dfe-c-metric dfe-c-metric--amber">
 <div class="dfe-c-metric__number" style="color:@McCss(Model.MonthlyCompliancePercent);">@Model.MonthlyCompliancePercent%</div>
 <div class="dfe-c-metric__label">Monthly update compliance</div>
      </div>
    </div>

 <div class="dfe-c-table-wrap">
      <table>
        <thead>
          <tr>
            <th>Portfolio</th>
            <th>Directorate</th>
            <th>Head of portfolio</th>
            <th>Work items</th>
            <th>RAG breakdown</th>
            <th>RAG</th>
            <th>Monthly updates</th>
            <th>Open risks</th>
          </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.Rows)
        {
          var ragTotal = row.RagGreen + row.RagAmber + row.RagRed;
          <tr>
            <td>
              <a href="@Url.Action("Dashboard", "Reporting", new { section = "portfolio", portfolioId = row.PortfolioId })" style="font-weight:700;">@row.Name</a>
              @if (!string.IsNullOrWhiteSpace(row.Description))
              {
                <div style="font-size:0.8125rem;color:var(--grey-4);">@row.Description</div>
              }
            </td>
            <td>@row.DirectorateDisplay</td>
            <td>@(row.HeadOfPortfolioDisplay ?? "—")</td>
            <td>@row.WorkItemCount</td>
            <td>
              @if (ragTotal == 0)
              {
 <span class="dfe-c-text-muted">—</span>
              }
              else
              {
                <div style="display:flex;gap:2px;height:0.5rem;border-radius:1px;overflow:hidden;width:6rem;">
                  @if (row.RagGreen > 0)
                  {
                    <div style="flex:@row.RagGreen;background:var(--rag-g);"></div>
                  }
                  @if (row.RagAmber > 0)
                  {
                    <div style="flex:@row.RagAmber;background:var(--rag-a);"></div>
                  }
                  @if (row.RagRed > 0)
                  {
                    <div style="flex:@row.RagRed;background:var(--rag-r);"></div>
                  }
                </div>
                <div style="font-size:0.75rem;color:var(--grey-4);margin-top:0.25rem;">@row.RagGreen G · @row.RagAmber A · @row.RagRed R</div>
              }
            </td>
 <td><span class="dfe-c-rag @row.PortfolioRagClass">@row.PortfolioRagLabel</span></td>
            <td><strong style="color:@row.MonthlyComplianceCssVar;">@row.MonthlyCompliancePercent%</strong></td>
            <td>
              @if (row.OpenRisksCount > 0)
              {
                <a href="@Url.RouteUrl("risks-issues-section", new { action = "Register" })" style="color:var(--blue);">@row.OpenRisksCount</a>
              }
              else
              {
 <span class="dfe-c-text-muted">0</span>
              }
            </td>
          </tr>
        }
        </tbody>
      </table>
    </div>
  }
</div>
