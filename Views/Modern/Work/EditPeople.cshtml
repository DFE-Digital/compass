@model Compass.Models.Modern.Work.WorkItem
@using Compass.Models.Modern.Work
@{
    ViewData["Title"] = "Edit key people";
    var work = ViewBag.WorkItem as WorkItem ?? Model;
    var roleTypes = (List<ContactRoleType>)ViewBag.ContactRoleTypes ?? new List<ContactRoleType>();
    var primaryContactName = ViewBag.PrimaryContactName as string;
    var primaryContactSubtitle = ViewBag.PrimaryContactSubtitle as string;
    var budgetOwnerName = ViewBag.BudgetOwnerName as string;
    var firstSroName = ViewBag.FirstSroName as string;
    var budgetOwnerSameAsSro = ViewBag.BudgetOwnerSameAsSro as bool? ?? false;
    string Initials(string? name, string? email) {
        if (!string.IsNullOrWhiteSpace(name)) {
            var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
            if (parts.Length >= 2) return (parts[0][0] + parts[^1][0].ToString()).ToUpperInvariant();
            if (parts[0].Length >= 2) return parts[0].Substring(0, 2).ToUpperInvariant();
            return parts[0].Substring(0, 1).ToUpperInvariant();
        }
        if (!string.IsNullOrWhiteSpace(email)) return email.Substring(0, Math.Min(2, email.Length)).ToUpperInvariant();
        return "—";
    }
    var contactsByRole = (work.Contacts ?? new List<WorkItemContact>()).GroupBy(c => c.ContactRoleTypeId).ToDictionary(g => g.Key, g => g.ToList());
}
@section Breadcrumbs {
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="/">Home</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
    <li class="dfe-c-breadcrumb__item"><a class="dfe-c-breadcrumb__link" href="@Url.Action("Detail", "ModernWork", new { id = work.Id })">@work.Title</a></li>
    <li class="dfe-c-breadcrumb__item" aria-current="page">Edit key people</li>
}

<div id="sc-work-editpeople">
  @await Html.PartialAsync("_WorkItemChrome", ViewBag.WorkItem as WorkItem ?? work)
  <h2 class="dfe-c-heading-l dfe-c-mt-0">Edit key people</h2>
  <p class="dfe-c-body dfe-c-mb-4">Manage who holds each role for this work item. Add or change people using the links below.</p>

  <div class="ep-roles" style="max-width: 36em;">
    @* Primary contact *@
    <div class="ep-role">
      <h3 class="ep-role__heading">Primary contact <span class="dfe-c-form__required">*</span></h3>
      <p class="ep-role__hint">Day-to-day management and communications.</p>
      @if (work.PrimaryContactUserId.HasValue && !string.IsNullOrEmpty(primaryContactName))
      {
        <div class="ep-person">
          <div class="ep-person__avatar" aria-hidden="true">@Initials(primaryContactName, primaryContactSubtitle)</div>
          <div class="ep-person__details">
            <p class="ep-person__name">@primaryContactName</p>
            @if (!string.IsNullOrEmpty(primaryContactSubtitle)) { <p class="ep-person__email">@primaryContactSubtitle</p> }
          </div>
          <div class="ep-person__action">
            <form method="post" action="@Url.Action("SetPrimaryContact", "ModernWork", new { id = work.Id })" style="display:inline;" data-confirm-title="Remove primary contact" data-confirm-message="Remove this person as primary contact? The work item will have no primary contact until one is set.">
              @Html.AntiForgeryToken()
              <input type="hidden" name="AppUserId" value="0" />
              <button type="submit" class="dfe-c-link" style="color:#d4351c;">Remove</button>
            </form>
          </div>
        </div>
      }
      else
      {
        <p class="ep-empty">No primary contact set.</p>
      }
      <div class="ep-actions">
        <a href="@Url.Action("SetPrimaryContact", "ModernWork", new { id = work.Id })" class="dfe-c-button dfe-c-button--secondary dfe-c-mb-0">@(work.PrimaryContactUserId.HasValue ? "Change" : "Add primary contact")</a>
      </div>
    </div>

    @* Other role types (SRO, Service Owner, etc.) *@
    @foreach (var rt in roleTypes.Where(r => !string.Equals(r.Name, "Primary contact", StringComparison.OrdinalIgnoreCase) && !string.Equals(r.Name, "Budget owner", StringComparison.OrdinalIgnoreCase)))
    {
      var contacts = contactsByRole.TryGetValue(rt.Id, out var list) ? list : new List<WorkItemContact>();
      var isMulti = rt.Name?.Contains("SRO", StringComparison.OrdinalIgnoreCase) == true || rt.Name?.Contains("Service Owner", StringComparison.OrdinalIgnoreCase) == true;
      var hint = rt.Name?.Contains("SRO", StringComparison.OrdinalIgnoreCase) == true ? "Senior civil servant ultimately accountable." : (rt.Name?.Contains("Service Owner", StringComparison.OrdinalIgnoreCase) == true ? "Responsible for quality and performance of the service." : null);
      <div class="ep-role">
        <h3 class="ep-role__heading">@rt.Name@(rt.Name?.Contains("SRO", StringComparison.OrdinalIgnoreCase) == true ? " (Senior Responsible Owner)" : "") @(rt.Name?.Contains("SRO", StringComparison.OrdinalIgnoreCase) == true ? Html.Raw("<span class=\"dfe-c-form__required\">*</span>") : null)</h3>
        @if (!string.IsNullOrEmpty(hint)) { <p class="ep-role__hint">@hint</p> }
        @foreach (var c in contacts)
        {
          var un = c.AppUser?.Name ?? c.AppUser?.Email ?? "—";
          var ue = c.AppUser?.Email;
          <div class="ep-person">
            <div class="ep-person__avatar" aria-hidden="true">@Initials(un, ue)</div>
            <div class="ep-person__details">
              <p class="ep-person__name">@un</p>
              @if (!string.IsNullOrEmpty(ue)) { <p class="ep-person__email">@ue</p> }
            </div>
            <div class="ep-person__action">
              <form method="post" action="@Url.Action("RemoveContact", "ModernWork", new { id = work.Id, contactId = c.Id })" style="display:inline;" data-confirm-title="Remove contact" data-confirm-message="Remove this person from the work item?">
                @Html.AntiForgeryToken()
                <button type="submit" class="dfe-c-link" style="color:#d4351c;">Remove</button>
              </form>
            </div>
          </div>
        }
        @if (!contacts.Any()) { <p class="ep-empty">None assigned.</p> }
        <div class="ep-actions">
          <a href="@Url.Action("AddContact", "ModernWork", new { id = work.Id, contactRoleTypeId = rt.Id, returnTo = "EditPeople" })" class="dfe-c-button dfe-c-button--secondary dfe-c-mb-0">@(isMulti ? "Add " + rt.Name : "Add contact")</a>
        </div>
      </div>
    }

    @* Budget owner *@
    <div class="ep-role">
      <h3 class="ep-role__heading">Budget owner</h3>
      <p class="ep-role__hint">Defaults to SRO unless set separately.</p>
      <div class="ep-budget">
        <span class="ep-budget__name">@(budgetOwnerSameAsSro ? "Same as SRO — " + (firstSroName ?? "—") : "Different person — " + (budgetOwnerName ?? "—"))</span>
        <form method="post" action="@Url.Action("SetBudgetOwner", "ModernWork", new { id = work.Id })" style="display:inline;">
          @Html.AntiForgeryToken()
          <input type="hidden" name="SameAsSro" value="true" />
          <input type="hidden" name="AppUserId" value="0" />
          <button type="submit" class="dfe-c-link">Use SRO</button>
        </form>
        <a href="@Url.Action("SetBudgetOwner", "ModernWork", new { id = work.Id })" class="dfe-c-link">@(budgetOwnerSameAsSro ? "Set different person" : "Change")</a>
      </div>
    </div>
  </div>

  <details class="dfe-c-details dfe-c-mt-5" data-module="dfe-c-details">
    <summary class="dfe-c-details__summary">
      <span class="dfe-c-details__summary-text">About these roles</span>
    </summary>
    <div class="dfe-c-details__text dfe-c-body-s">
      <ul class="dfe-c-list dfe-c-list--spaced" style="margin-bottom:0;">
        <li><strong>Primary contact</strong> — Day-to-day management and communications.</li>
        <li><strong>SRO</strong> — Ultimately accountable; typically G5 Deputy Director or above.</li>
        <li><strong>Service Owner</strong> — Responsible for quality and performance of the service.</li>
        <li><strong>PMO Contact</strong> — Portfolio management office contact for reporting.</li>
        <li><strong>Reporting contact</strong> — Receives monthly updates and reports.</li>
      </ul>
    </div>
  </details>
</div>
