@model Compass.Models.Modern.Work.WorkItem
@using Compass.Models.Modern.Work
@{
    ViewData["Title"] = "Edit key people";
    var work = ViewBag.WorkItem as WorkItem ?? Model;
    var roleTypes = (List<ContactRoleType>)ViewBag.ContactRoleTypes ?? new List<ContactRoleType>();
    var standardRoles = roleTypes.Where(r => r.Id >= 1 && r.Id <= 4).ToList();
    var primaryContactName = ViewBag.PrimaryContactName as string;
    var primaryContactSubtitle = ViewBag.PrimaryContactSubtitle as string;
    var budgetOwnerName = ViewBag.BudgetOwnerName as string;
    var firstSroName = ViewBag.FirstSroName as string;
    var budgetOwnerSameAsSro = ViewBag.BudgetOwnerSameAsSro as bool? ?? false;
    var contactsByRole = (work.Contacts ?? new List<WorkItemContact>())
        .Where(c => c.ContactRoleTypeId is >= 1 and <= 4)
        .GroupBy(c => c.ContactRoleTypeId!.Value)
        .ToDictionary(g => g.Key, g => g.ToList());
    var customRoleGroups = (work.Contacts ?? new List<WorkItemContact>())
        .Where(c => c.ContactRoleTypeId == 5 && !string.IsNullOrEmpty(c.RoleName))
        .GroupBy(c => c.RoleName!)
        .OrderBy(g => g.Key)
        .ToList();
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="/">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Detail", "ModernWork", new { id = work.Id })">@work.Title</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Key people</li>
}

<div id="sc-work-editpeople" class="modern-work-page">
  @await Html.PartialAsync("_WorkItemChrome", ViewBag.WorkItem as WorkItem ?? work)

 <h2 class="govuk-heading-l">Key people</h2>
 <p class="govuk-body govuk-!-margin-bottom-6">Assign a person to each role, or remove them when they no longer apply.</p>

 <dl class="govuk-summary-list govuk-!-margin-bottom-6">
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Primary contact</dt>
 <dd class="govuk-summary-list__value">
        @if (work.PrimaryContactUserId.HasValue && !string.IsNullOrEmpty(primaryContactName))
        {
          <strong>@primaryContactName</strong>
          @if (!string.IsNullOrEmpty(primaryContactSubtitle))
 { <br /><span class="govuk-body-s" style="color:#505a5f;">@primaryContactSubtitle</span> }
        }
        else
        {
 <span class="govuk-body" style="color:#505a5f;">Not assigned</span>
        }
      </dd>
 <dd class="govuk-summary-list__actions">
        @if (work.PrimaryContactUserId.HasValue && !string.IsNullOrEmpty(primaryContactName))
        {
 <ul class="govuk-summary-list__actions-list">
 <li class="govuk-summary-list__actions-list-item">
 <a class="govuk-link" href="@Url.Action("EditContact", "ModernWork", new { id = work.Id, kind = "primary", returnTo = "EditPeople" })">Change<span class="govuk-visually-hidden"> primary contact</span></a>
            </li>
 <li class="govuk-summary-list__actions-list-item">
              <form method="post" action="@Url.Action("SetPrimaryContactPost", "ModernWork", new { id = work.Id })" style="display:inline;" data-confirm-title="Remove primary contact" data-confirm-message="Remove this person as primary contact?">
                @Html.AntiForgeryToken()
                <input type="hidden" name="AppUserId" value="0" />
 <button type="submit" class="govuk-link" style="padding:0;border:0;background:none;cursor:pointer;font:inherit;color:#d4351c;">Remove<span class="govuk-visually-hidden"> primary contact</span></button>
              </form>
            </li>
          </ul>
        }
        else
        {
 <a class="govuk-link" href="@Url.Action("EditContact", "ModernWork", new { id = work.Id, kind = "primary", returnTo = "EditPeople" })">Add<span class="govuk-visually-hidden"> primary contact</span></a>
        }
      </dd>
    </div>

    @foreach (var rt in standardRoles)
    {
      var contacts = contactsByRole.TryGetValue(rt.Id, out var list) ? list : new List<WorkItemContact>();
      var roleName = rt.Name ?? "Role";
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">@roleName</dt>
 <dd class="govuk-summary-list__value">
          @if (contacts.Any())
          {
            @foreach (var c in contacts)
            {
              var un = c.AppUser?.Name ?? c.AppUser?.Email ?? "—";
              var ue = c.AppUser?.Email;
              <div style="@(contacts.IndexOf(c) > 0 ? "margin-top:0.5rem;" : "")">
                <strong>@un</strong>
                @if (!string.IsNullOrEmpty(ue))
 { <br /><span class="govuk-body-s" style="color:#505a5f;">@ue</span> }
                <a class="govuk-link govuk-!-margin-left-2" href="@Url.Action("EditContact", "ModernWork", new { id = work.Id, contactId = c.Id, returnTo = "EditPeople" })">Change<span class="govuk-visually-hidden"> @un</span></a>
                <form method="post" action="@Url.Action("RemoveContact", "ModernWork", new { id = work.Id, contactId = c.Id })" style="display:inline;margin-left:0.5rem;" data-confirm-title="Remove contact" data-confirm-message="Remove this person from the work item?">
                  @Html.AntiForgeryToken()
 <button type="submit" class="govuk-link" style="padding:0;border:0;background:none;cursor:pointer;font:inherit;color:#d4351c;font-size:0.875rem;">Remove<span class="govuk-visually-hidden"> @un from @roleName</span></button>
                </form>
              </div>
            }
          }
          else
          {
 <span class="govuk-body" style="color:#505a5f;">Not assigned</span>
          }
        </dd>
 <dd class="govuk-summary-list__actions">
 <a class="govuk-link" href="@Url.Action("AddContact", "ModernWork", new { id = work.Id, contactRoleTypeId = rt.Id, returnTo = "EditPeople" })">Add<span class="govuk-visually-hidden"> @roleName.ToLowerInvariant()</span></a>
        </dd>
      </div>
    }

    @foreach (var grp in customRoleGroups)
    {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">@grp.Key</dt>
 <dd class="govuk-summary-list__value">
          @foreach (var c in grp)
          {
            var un = c.AppUser?.Name ?? c.AppUser?.Email ?? "—";
            var ue = c.AppUser?.Email;
            <div style="@(grp.ToList().IndexOf(c) > 0 ? "margin-top:0.5rem;" : "")">
              <strong>@un</strong>
              @if (!string.IsNullOrEmpty(ue))
 { <br /><span class="govuk-body-s" style="color:#505a5f;">@ue</span> }
              <a class="govuk-link govuk-!-margin-left-2" href="@Url.Action("EditContact", "ModernWork", new { id = work.Id, contactId = c.Id, returnTo = "EditPeople" })">Change<span class="govuk-visually-hidden"> @un</span></a>
              <form method="post" action="@Url.Action("RemoveContact", "ModernWork", new { id = work.Id, contactId = c.Id })" style="display:inline;margin-left:0.5rem;" data-confirm-title="Remove contact" data-confirm-message="Remove this person from the work item?">
                @Html.AntiForgeryToken()
 <button type="submit" class="govuk-link" style="padding:0;border:0;background:none;cursor:pointer;font:inherit;color:#d4351c;font-size:0.875rem;">Remove<span class="govuk-visually-hidden"> @un from @grp.Key</span></button>
              </form>
            </div>
          }
        </dd>
 <dd class="govuk-summary-list__actions">
 <a class="govuk-link" href="@Url.Action("AddContact", "ModernWork", new { id = work.Id, contactRoleTypeId = 5, customRoleName = grp.Key, returnTo = "EditPeople" })">Add<span class="govuk-visually-hidden"> @grp.Key.ToLowerInvariant()</span></a>
        </dd>
      </div>
    }

 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Custom role</dt>
 <dd class="govuk-summary-list__value">
 <span class="govuk-body" style="color:#505a5f;">Add a contact with a custom role name</span>
      </dd>
 <dd class="govuk-summary-list__actions">
 <a class="govuk-link" href="@Url.Action("AddContact", "ModernWork", new { id = work.Id, contactRoleTypeId = 5, returnTo = "EditPeople" })">Add<span class="govuk-visually-hidden"> custom role</span></a>
      </dd>
    </div>

 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Budget owner</dt>
 <dd class="govuk-summary-list__value">
        @if (budgetOwnerSameAsSro)
        {
          <strong>Same as SRO</strong>
          @if (!string.IsNullOrEmpty(firstSroName))
 { <br /><span class="govuk-body-s" style="color:#505a5f;">@firstSroName</span> }
        }
        else if (!string.IsNullOrEmpty(budgetOwnerName))
        {
          <strong>@budgetOwnerName</strong>
        }
        else
        {
 <span class="govuk-body" style="color:#505a5f;">Not assigned</span>
        }
      </dd>
 <dd class="govuk-summary-list__actions">
 <ul class="govuk-summary-list__actions-list">
 <li class="govuk-summary-list__actions-list-item">
 <a class="govuk-link" href="@Url.Action("EditContact", "ModernWork", new { id = work.Id, kind = "budget", returnTo = "EditPeople" })">Change<span class="govuk-visually-hidden"> budget owner</span></a>
          </li>
 <li class="govuk-summary-list__actions-list-item">
            <form method="post" action="@Url.Action("SetBudgetOwnerPost", "ModernWork", new { id = work.Id })" style="display:inline;">
              @Html.AntiForgeryToken()
              <input type="hidden" name="SameAsSro" value="true" />
              <input type="hidden" name="AppUserId" value="0" />
 <button type="submit" class="govuk-link" style="padding:0;border:0;background:none;cursor:pointer;font:inherit;">Use SRO<span class="govuk-visually-hidden"> as budget owner</span></button>
            </form>
          </li>
        </ul>
      </dd>
    </div>
  </dl>

 <p class="govuk-body govuk-!-margin-top-4">
 <a href="@Url.Action("Detail", "ModernWork", new { id = work.Id })#wd-overview" class="govuk-button govuk-button--secondary">Back to work item</a>
  </p>
</div>
