@model Compass.ViewModels.Modern.CompassNotificationEmailLogPageViewModel
@using Compass.ViewModels.Modern
@using Microsoft.AspNetCore.Html
@{
  ViewData["Title"] = "Notification email log";
  var notificationSideNav = new NotificationAdminSideNavViewModel { IsEmailLogPage = true };
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin")">Admin</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("NotificationSettings", "ModernAdminNotificationSettings")">Notification settings</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Email log</li>
}

<div class="admin-hub">
 @{
   var notifLogLede = new HtmlString("<p class=\"govuk-body govuk-!-margin-bottom-0\">Audit of Compass notification emails. Rows are written when sending code calls <code class=\"govuk-body-s\">ICompassNotificationEmailLogService</code>.</p>");
   var notifLogActions = new HtmlString($"<a class=\"govuk-link govuk-link--no-visited-state\" href=\"{Url.Action("NotificationSettings", "ModernAdminNotificationSettings") ?? "#"}\">Notification settings</a>");
 }
 @await Html.PartialAsync("~/Views/Modern/Shared/_ModernPageHeader.cshtml", new ModernPageHeaderViewModel {
   Caption = "Administration",
   Title = "Notification email log",
   Lede = notifLogLede,
   Actions = notifLogActions
 })

 <div class="govuk-grid-row notification-settings-layout">
 <div class="govuk-grid-column-one-quarter-from-desktop notification-settings-layout__nav">
 @await Html.PartialAsync("~/Views/Modern/Admin/_NotificationAdminSideNav.cshtml", notificationSideNav)
 </div>
 <div class="govuk-grid-column-three-quarters-from-desktop">
 <div id="notification-email-log-main">

 @if (Model.TotalCount == 0)
  {
 <p class="govuk-body dfe-c-text-muted">No notification emails logged yet.</p>
  }
  else
  {
 <p class="govuk-body-s dfe-c-text-muted govuk-!-margin-bottom-3">@Model.TotalCount total</p>
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
 <table class="govuk-table govuk-table--small dfe-f-table--condensed">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Sent (UTC)</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Notification</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Recipient</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Subject</button>
        </th>
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">OK</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Context</button>
        </th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          @foreach (var r in Model.Rows)
          {
            <tr class="govuk-table__row">
              <td class="govuk-body-s">@r.SentAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
              <td class="govuk-body-s">
                <span title="@r.EventKey">@r.EventDisplayName</span>
              </td>
              <td class="govuk-body-s">
                @(string.IsNullOrEmpty(r.RecipientName) ? r.RecipientEmail : $"{r.RecipientName} ({r.RecipientEmail})")
              </td>
              <td class="govuk-body-s">@r.Subject</td>
              <td class="govuk-table__cell">
 @if (r.SendSucceeded)
                {
 <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--green">Yes</span>
                }
                else
                {
 <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--red">No</span>
                }
              </td>
              <td class="govuk-body-s dfe-c-mono">@(string.IsNullOrEmpty(r.ContextReference) ? "—" : r.ContextReference)</td>
            </tr>
          }
        </tbody>
      </table>
    </div>

 @if (Model.TotalPages > 1)
    {
 Func<int, string> notifLogPageUrl = p =>
   Url.Action("NotificationEmailLog", "ModernAdminNotificationSettings", new { page = p }) ?? "#";
 <div class="govuk-!-margin-top-3">
 @await Html.PartialAsync("~/Views/Modern/Shared/_GovUkPagination.cshtml", new GovUkPaginationViewModel {
   CurrentPage = Model.Page,
   TotalPages = Model.TotalPages,
   PageUrl = notifLogPageUrl,
   NavigationAriaLabel = "Notification email log pages"
 })
 </div>
    }
  }
 </div>
 </div>
 </div>
</div>
