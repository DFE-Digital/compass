@model List<Compass.Models.DemandPipeline.DemandScoringBandDefinition>
@{
  var bands = Model ?? new();
}

<div class="admin-dsf-panel">
 <p class="govuk-body">Bands classify the <strong>scaled</strong> score (0–100). Ranges should cover 0–100 without gaps so every score maps to exactly one band. The band <code>Code</code> is fixed in the database; edit label and ranges as needed.</p>

 <div class="admin-dsf-band-grid" aria-label="Scoring bands">
 <span class="admin-dsf-band-grid__head">Code</span>
 <span class="admin-dsf-band-grid__head">Label</span>
 <span class="admin-dsf-band-grid__head">Min</span>
 <span class="admin-dsf-band-grid__head">Max</span>
 <span class="admin-dsf-band-grid__head">Sort</span>
 <span class="admin-dsf-band-grid__head">Active</span>
 <span class="admin-dsf-band-grid__head admin-dsf-band-grid__head--action"><span class="govuk-visually-hidden">Save</span></span>
    @foreach (var b in bands)
    {
 <form method="post" action="@Url.Action("DemandScoringFrameworkBandSave", "ModernAdmin", new { id = b.Id })" class="admin-dsf-band-grid__form">
        @Html.AntiForgeryToken()
 <div class="admin-dsf-band-grid__code"><strong><code>@b.Code</code></strong></div>
        <div>
 <label class="govuk-label govuk-visually-hidden" for="bl-@b.Id">Label (@b.Code)</label>
 <input class="govuk-input" id="bl-@b.Id" name="label" value="@b.Label" required />
        </div>
        <div>
 <label class="govuk-label govuk-visually-hidden" for="bmin-@b.Id">Min</label>
 <input class="govuk-input govuk-input--width-4" id="bmin-@b.Id" name="minScaledInclusive" type="number" value="@b.MinScaledInclusive" min="0" max="100" />
        </div>
        <div>
 <label class="govuk-label govuk-visually-hidden" for="bmax-@b.Id">Max</label>
 <input class="govuk-input govuk-input--width-4" id="bmax-@b.Id" name="maxScaledInclusive" type="number" value="@b.MaxScaledInclusive" min="0" max="100" />
        </div>
        <div>
 <label class="govuk-label govuk-visually-hidden" for="bso-@b.Id">Sort order</label>
 <input class="govuk-input govuk-input--width-4" id="bso-@b.Id" name="sortOrder" type="number" value="@b.SortOrder" />
        </div>
 <div class="admin-dsf-band-grid__check">
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="ba-@b.Id" name="isActive" type="checkbox" value="true" @(b.IsActive ? "checked" : null) />
 <label class="govuk-label govuk-checkboxes__label" for="ba-@b.Id"><span class="govuk-visually-hidden">Active</span></label>
            </div>
          </div>
        </div>
 <div class="admin-dsf-band-grid__action">
 <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0">Save</button>
        </div>
      </form>
    }
  </div>
</div>
