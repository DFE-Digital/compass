@model Compass.ViewModels.Modern.AdminFipsBusinessAreasSyncedPanelModel
<div id="panel-fips-business-areas" class="admin-panel">
 <h2 class="govuk-heading-m">FIPS business areas</h2>
 <p class="govuk-body dfe-c-text-muted dfe-c-mb-2">
    These rows mirror <strong>Business areas</strong> in admin. Edit names, order, and active status there — this list refreshes when you open this panel or when products are edited.
 </p>
 <p class="govuk-body govuk-!-margin-bottom-4">
    <a class="govuk-link govuk-link--no-visited-state" href="@Model.MasterBusinessAreasUrl">Manage business areas (master list)</a>
 </p>

 @if (Model.Rows.Count == 0)
 {
 <p class="govuk-body">No business areas synced yet. Add entries under Business areas first.</p>
 }
 else
 {
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
      <table class="govuk-table govuk-table--small dfe-f-table--condensed">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Name</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Description</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Order</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Status</button></th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          @foreach (var row in Model.Rows)
          {
            <tr class="govuk-table__row">
              <td class="govuk-table__cell"><strong>@row.Name</strong></td>
              <td class="govuk-table__cell">@(string.IsNullOrEmpty(row.Description) ? "—" : row.Description)</td>
              <td class="govuk-table__cell">@row.SortOrder</td>
              <td class="govuk-table__cell">
                @if (row.IsActive)
 { <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--green">Active</span> }
                else
 { <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--grey">Inactive</span> }
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
 }
</div>
