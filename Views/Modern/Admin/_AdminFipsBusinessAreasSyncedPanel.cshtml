@model Compass.ViewModels.Modern.AdminFipsBusinessAreasSyncedPanelModel
<div id="panel-fips-business-areas" class="admin-panel">
 <h2 class="govuk-heading-m">FIPS business areas</h2>
 <p class="govuk-body dfe-c-text-muted dfe-c-mb-2">
    These rows mirror <strong>Business areas</strong> in admin. Edit names, order, and active status there — this list refreshes when you open this panel or when products are edited.
 </p>
 <p class="govuk-body govuk-!-margin-bottom-4">
    <a class="govuk-link govuk-link--no-visited-state" href="@Model.MasterBusinessAreasUrl">Manage business areas (master list)</a>
 </p>

 @if (Model.Rows.Count == 0)
 {
 <p class="govuk-body">No business areas synced yet. Add entries under Business areas first.</p>
 }
 else
 {
 <div class="dfe-c-table-wrap">
      <table>
        <thead>
          <tr>
 <th data-sort-bound="1" class="sortable">Name</th>
            <th>Description</th>
 <th data-sort-bound="1" class="sortable">Order</th>
 <th data-sort-bound="1" class="sortable">Active</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var row in Model.Rows)
          {
            <tr>
              <td><strong>@row.Name</strong></td>
              <td>@(string.IsNullOrEmpty(row.Description) ? "—" : row.Description)</td>
              <td>@row.SortOrder</td>
              <td>
                @if (row.IsActive)
 { <span class="dfe-c-tag dfe-c-tag--green">Yes</span> }
                else
 { <span class="dfe-c-tag dfe-c-tag--grey">No</span> }
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
 }
</div>
