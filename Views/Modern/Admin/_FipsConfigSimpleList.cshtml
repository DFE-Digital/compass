@{
    var items = (IEnumerable<dynamic>)ViewData["Items"]!;
    var addAction = (string)ViewData["AddAction"]!;
    var toggleAction = (string)ViewData["ToggleAction"]!;
    var entityLabel = (string)ViewData["EntityLabel"]!;
}

<h2 class="govuk-heading-m" style="text-transform:capitalize;">@entityLabel@("s")</h2>

@if (!items.Any())
{
 <p class="govuk-body">No @(entityLabel)s configured.</p>
}
else
{
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
        <table class="govuk-table govuk-table--small dfe-f-table--condensed">
            <thead class="govuk-table__head">
                <tr class="govuk-table__row">
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Name</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Description</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Order</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Status</button></th>
 <th scope="col" class="govuk-table__header govuk-table__header--numeric"><span class="govuk-visually-hidden">Actions</span></th>
                </tr>
            </thead>
            <tbody class="govuk-table__body">
                @foreach (var item in items)
                {
                    <tr class="govuk-table__row">
                        <td class="govuk-table__cell"><strong>@item.Name</strong></td>
                        <td class="govuk-table__cell">@(item.Description ?? "—")</td>
                        <td class="govuk-table__cell">@item.DisplayOrder</td>
 <td class="govuk-table__cell"><span class="dfe-f-badge dfe-f-badge--small @(item.Active ? "dfe-f-badge--green" : "dfe-f-badge--grey")">@(item.Active ? "Active" : "Inactive")</span></td>
                        <td class="govuk-table__cell" style="text-align:right;">
                            <form method="post" action="@Url.Action(toggleAction, "ModernAdmin", new { id = item.Id })" style="display:inline;">
                                @Html.AntiForgeryToken()
 <button type="submit" class="govuk-button govuk-button--secondary govuk-button--small govuk-!-margin-bottom-0">@(item.Active ? "Deactivate" : "Activate")</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<details class="govuk-details" style="margin-top:1rem;">
 <summary class="govuk-details__summary"><span class="govuk-details__summary-text">Add @entityLabel</span></summary>
 <form method="post" action="@addAction" class="govuk-form-group">
        @Html.AntiForgeryToken()
 <div class="govuk-form-group">
 <label class="govuk-label" for="sl-name">Name</label>
 <input class="govuk-input govuk-input--width-20" id="sl-name" name="name" required>
        </div>
 <div class="govuk-form-group">
 <label class="govuk-label" for="sl-desc">Description</label>
 <input class="govuk-input govuk-input--width-30" id="sl-desc" name="description">
        </div>
 <div class="govuk-form-group">
 <label class="govuk-label" for="sl-order">Display order</label>
 <input class="govuk-input govuk-input--width-5" id="sl-order" name="displayOrder" type="number" value="0">
        </div>
 <button type="submit" class="govuk-button">Add</button>
    </form>
</details>
