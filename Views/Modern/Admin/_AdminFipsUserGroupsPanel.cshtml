@model Compass.ViewModels.Modern.AdminHubViewModel
<div class="admin-panel">
 <h2 class="govuk-heading-m">FIPS user groups</h2>
 <div class="govuk-body dfe-c-text-muted dfe-c-mb-2">Hierarchical user groups for FIPS products. Groups can have children and synonyms.</div>

  @if (Model.FipsUserGroups.Count == 0)
  {
 <p class="govuk-body">No user groups configured.</p>
  }
  else
  {
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
      <table class="govuk-table govuk-table--small dfe-f-table--condensed">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Name</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Children</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Synonyms</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Order</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Status</button></th>
 <th scope="col" class="govuk-table__header govuk-table__header--numeric"><span class="govuk-visually-hidden">Actions</span></th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          @foreach (var g in Model.FipsUserGroups)
          {
            <tr class="govuk-table__row">
              <td class="govuk-table__cell"><strong>@g.Name</strong></td>
              <td class="govuk-table__cell">@(g.ChildNames.Count > 0 ? string.Join(", ", g.ChildNames) : "—")</td>
              <td class="govuk-table__cell">@(g.SynonymNames.Count > 0 ? string.Join(", ", g.SynonymNames) : "—")</td>
              <td class="govuk-table__cell">@g.DisplayOrder</td>
              <td class="govuk-table__cell">
                @if (g.Active)
 { <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--green">Active</span> }
                else
 { <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--grey">Inactive</span> }
              </td>
              <td class="govuk-table__cell" style="text-align:right;">
                <form method="post" action="@Url.Action("FipsToggleUserGroup", "ModernAdmin", new { id = g.Id })" style="display:inline;">
                  @Html.AntiForgeryToken()
 <button type="submit" class="govuk-button govuk-button--secondary govuk-button--small govuk-!-margin-bottom-0">@(g.Active ? "Deactivate" : "Activate")</button>
                </form>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }

 <details class="govuk-details" style="margin-top:1rem;">
 <summary class="govuk-details__summary"><span class="govuk-details__summary-text">Add user group</span></summary>
 <form method="post" action="@Url.Action("FipsAddUserGroup", "ModernAdmin")" class="govuk-form-group">
      @Html.AntiForgeryToken()
 <div class="govuk-form-group">
 <label class="govuk-label" for="ug-name">Name</label>
 <input class="govuk-input govuk-input--width-20" id="ug-name" name="name" required>
      </div>
 <div class="govuk-form-group">
 <label class="govuk-label" for="ug-desc">Description</label>
 <input class="govuk-input govuk-input--width-30" id="ug-desc" name="description">
      </div>
 <div class="govuk-form-group">
 <label class="govuk-label" for="ug-parent">Parent (optional)</label>
 <select class="govuk-select" id="ug-parent" name="parentId">
          <option value="">— None (top level) —</option>
          @foreach (var g in Model.FipsUserGroups)
          {
            <option value="@g.Id">@g.Name</option>
          }
        </select>
      </div>
 <div class="govuk-form-group">
 <label class="govuk-label" for="ug-order">Display order</label>
 <input class="govuk-input govuk-input--width-5" id="ug-order" name="displayOrder" type="number" value="0">
      </div>
 <button type="submit" class="govuk-button">Add</button>
    </form>
  </details>

 <details class="govuk-details">
 <summary class="govuk-details__summary"><span class="govuk-details__summary-text">Add synonym</span></summary>
 <form method="post" action="@Url.Action("FipsAddUserGroupSynonym", "ModernAdmin", new { id = 0 })" id="synonym-form" class="govuk-form-group" data-synonym-base-url="@Url.Action("FipsAddUserGroupSynonym", "ModernAdmin", new { id = 0 })">
      @Html.AntiForgeryToken()
 <div class="govuk-form-group">
 <label class="govuk-label" for="syn-group">User group</label>
 <select class="govuk-select" id="syn-group" name="id">
          <option value="">— Select —</option>
          @foreach (var g in Model.FipsUserGroups)
          {
            <option value="@g.Id">@g.Name</option>
          }
        </select>
      </div>
 <div class="govuk-form-group">
 <label class="govuk-label" for="syn-value">Synonym</label>
 <input class="govuk-input govuk-input--width-20" id="syn-value" name="synonym" required>
      </div>
 <button type="submit" class="govuk-button">Add synonym</button>
    </form>
  </details>
</div>
