@model Compass.ViewModels.Modern.AdminHubViewModel
@{
  var topLevelCount = Model.FipsUserGroups.Count(g => g.Depth == 0);
}
<div class="admin-panel">
 <h2 class="govuk-heading-m">FIPS user groups</h2>
 <p class="govuk-body dfe-c-text-muted dfe-c-mb-2">
   Hierarchical user groups for FIPS products. Groups can have children and synonyms.
   @if (Model.FipsUserGroups.Count > 0)
   {
     <span>Showing @Model.FipsUserGroups.Count groups (@topLevelCount top-level).</span>
   }
 </p>

 <p class="govuk-body govuk-!-margin-bottom-4">
   <a class="govuk-button" href="@Url.Action("FipsUserGroupCreate", "ModernAdmin")">Add top-level user group</a>
 </p>

  @if (Model.FipsUserGroups.Count == 0)
  {
 <p class="govuk-body">No user groups configured.</p>
  }
  else
  {
 <p class="govuk-body-s dfe-c-text-muted govuk-!-margin-bottom-2">Indented names show parent → child hierarchy. Use Edit to change name, parent, order, synonyms, or status.</p>
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
      <table class="govuk-table govuk-table--small dfe-f-table--condensed">
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Name</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Parent</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Synonyms</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Order</button></th>
 <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Status</button></th>
 <th scope="col" class="govuk-table__header govuk-table__header--numeric"><span class="govuk-visually-hidden">Actions</span></th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          @foreach (var g in Model.FipsUserGroups)
          {
            var indentRem = g.Depth * 1.25;
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">
                <div style="padding-left:@(indentRem.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))rem;">
                  @if (g.Depth > 0)
                  {
                    <span class="dfe-c-text-muted" aria-hidden="true">↳ </span>
                  }
                  @if (g.HasChildren)
                  {
                    <strong>@g.Name</strong>
                  }
                  else
                  {
                    @g.Name
                  }
                </div>
              </td>
              <td class="govuk-table__cell">@(string.IsNullOrWhiteSpace(g.ParentPath) ? "—" : g.ParentPath)</td>
              <td class="govuk-table__cell">@(g.SynonymNames.Count > 0 ? string.Join(", ", g.SynonymNames) : "—")</td>
              <td class="govuk-table__cell">@g.DisplayOrder</td>
              <td class="govuk-table__cell">
                @if (g.Active)
 { <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--green">Active</span> }
                else
 { <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--grey">Inactive</span> }
              </td>
              <td class="govuk-table__cell govuk-table__cell--numeric">
                <ul class="govuk-list govuk-!-margin-bottom-0" style="text-align:right;">
                  <li><a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("FipsUserGroupEdit", "ModernAdmin", new { id = g.Id })">Edit</a></li>
                  <li><a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("FipsUserGroupCreate", "ModernAdmin", new { parentId = g.Id })">Add child</a></li>
                  <li>
                    <form method="post" action="@Url.Action("FipsToggleUserGroup", "ModernAdmin", new { id = g.Id })" style="display:inline;">
                      @Html.AntiForgeryToken()
                      <button type="submit" class="govuk-link govuk-link--no-visited-state" style="border:0;background:none;padding:0;cursor:pointer;">@(g.Active ? "Deactivate" : "Activate")</button>
                    </form>
                  </li>
                </ul>
              </td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
</div>
