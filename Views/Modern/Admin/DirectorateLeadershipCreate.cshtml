@model Compass.ViewModels.Modern.AdminDirectorateLeadershipCreateViewModel
@{
  ViewData["Title"] = "Add directorate leadership";
  var picker = new Compass.Models.UserPickerViewModel
  {
    FieldName = "userId",
    Label = "Find user in directory",
    Hint = "Search by name or email, select the person, then choose their directorate and submit.",
    InputIdSuffix = "dir-leadership-add",
    DefaultSummaryText = "No user selected yet.",
    UseGovUkStyling = true
  };
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin")">Admin</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("DirectorateLeadership", "ModernAdmin")">Directorate leadership</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Add person</li>
}

<div class="admin-hub">
 <div class="dfe-c-page-title dfe-c-mb-3">
 <div class="dfe-c-page-title__caption">Administration</div>
 <h1 class="dfe-c-page-title__heading">Add directorate leadership</h1>
 <p class="dfe-c-page-title__lede"><a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("DirectorateLeadership", "ModernAdmin")">Back to directorate leadership</a></p>
  </div>

  @if (ViewBag.AdminError != null)
  {
 <div class="govuk-error-summary" role="alert" data-module="govuk-error-summary" style="margin-bottom:1.5rem;">
 <h2 class="govuk-error-summary__title">There is a problem</h2>
 <div class="govuk-error-summary__body">@ViewBag.AdminError</div>
    </div>
  }

 <div class="dfe-c-card dfe-c-mb-4" style="border:1px solid var(--grey-2);border-left:4px solid var(--blue);padding:1.25rem 1.5rem;background:var(--white);max-width:40rem;">
 <h2 class="govuk-heading-m govuk-!-margin-top-0">Directorate</h2>
 <p class="govuk-hint govuk-!-margin-bottom-3">
      Assign a user for leadership and reporting for one directorate. The same people can be listed for more than one directorate.
    </p>
    <form method="post" action="@Url.Action("DirectorateLeadershipCreate", "ModernAdmin")" novalidate>
      @Html.AntiForgeryToken()
 <div class="govuk-form-group govuk-!-margin-bottom-4">
 <label class="govuk-label govuk-label--s" for="dir-lead-create-d">Directorate</label>
 <select name="divisionId" id="dir-lead-create-d" class="govuk-select govuk-!-width-two-thirds" required>
        <option value="">Choose…</option>
        @foreach (var o in Model.DirectorateOptions)
        {
          <option value="@o.Id">@o.Name</option>
        }
      </select>
      </div>
      @await Html.PartialAsync("~/Views/Modern/Shared/_UserPicker.cshtml", picker)
 <div class="govuk-button-group govuk-!-margin-top-4">
 <button type="submit" class="govuk-button" data-module="govuk-button">Add</button>
 <a href="@Url.Action("DirectorateLeadership", "ModernAdmin")" class="govuk-link govuk-link--no-visited-state govuk-!-margin-left-2">Cancel</a>
      </div>
    </form>
  </div>
</div>
