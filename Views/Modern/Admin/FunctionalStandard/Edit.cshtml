@model Compass.Models.FunctionalStandard
@{
    ViewData["Title"] = $"Edit standard — {Model.Title}";
    string BackUrl() => Url.Action("FunctionalStandardDetail", "ModernAdmin", new { id = Model.Id }) ?? "#";
}

@section Breadcrumbs {
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin")">Admin</a></li>
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin", new { panel = "std-functional" })">Functional standards</a></li>
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@BackUrl()">@Model.Title</a></li>
    <li class="govuk-breadcrumbs__list-item" aria-current="page">Edit</li>
}

<div class="admin-hub">
    <div class="dfe-c-page-title dfe-c-mb-3">
        <div class="dfe-c-page-title__caption">Functional standard @Model.Id</div>
        <h1 class="dfe-c-page-title__heading">Edit standard</h1>
        <p class="dfe-c-page-title__lede"><a class="govuk-link govuk-link--no-visited-state" href="@BackUrl()">Back to @Model.Title</a></p>
    </div>

    @if (ViewBag.AdminError != null)
    {
        <div class="govuk-error-summary" role="alert" data-module="govuk-error-summary" style="margin-bottom:1.5rem;">
            <h2 class="govuk-error-summary__title">There is a problem</h2>
            <div class="govuk-error-summary__body">@ViewBag.AdminError</div>
        </div>
    }

    <div class="dfe-c-card dfe-c-mb-4" style="border:1px solid var(--grey-2);border-left:4px solid var(--blue);padding:1.25rem 1.5rem;background:var(--white);max-width:40rem;">
        <h2 class="govuk-heading-m govuk-!-margin-top-0">Standard details</h2>
        <form method="post" action="@Url.Action("FunctionalStandardEdit", "ModernAdmin", new { id = Model.Id })" novalidate>
            @Html.AntiForgeryToken()
            <div class="govuk-form-group govuk-!-margin-bottom-3">
                <label class="govuk-label" for="fs-title">Title</label>
                <input class="govuk-input govuk-!-width-two-thirds" type="text" name="title" id="fs-title" required autocomplete="off" maxlength="255" value="@Model.Title" />
            </div>
            <div class="govuk-form-group govuk-!-margin-bottom-3">
                <label class="govuk-label" for="fs-desc">Description <span class="govuk-hint govuk-!-display-inline">(optional)</span></label>
                <textarea class="govuk-textarea govuk-!-width-two-thirds" name="description" id="fs-desc" rows="4">@Model.Description</textarea>
            </div>
            <div class="govuk-form-group govuk-!-margin-bottom-3">
                <label class="govuk-label" for="fs-published">Published date <span class="govuk-hint govuk-!-display-inline">(optional)</span></label>
                <input class="govuk-input govuk-input--width-10" type="date" name="publishedDate" id="fs-published" value="@(Model.PublishedDate?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="govuk-button-group">
                <button type="submit" class="govuk-button" data-module="govuk-button">Save changes</button>
                <a href="@BackUrl()" class="govuk-link govuk-link--no-visited-state govuk-!-margin-left-2">Cancel</a>
            </div>
        </form>
    </div>
</div>
