@{
    var standard = ViewBag.Standard as Compass.Models.FunctionalStandard;
    ViewData["Title"] = $"Add theme — {standard!.Title}";
    string StdUrl() => Url.Action("FunctionalStandardDetail", "ModernAdmin", new { id = standard!.Id }) ?? "#";
}

@section Breadcrumbs {
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin")">Admin</a></li>
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin", new { panel = "std-functional" })">Functional standards</a></li>
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@StdUrl()">@standard.Title</a></li>
    <li class="govuk-breadcrumbs__list-item" aria-current="page">Add theme</li>
}

<div class="admin-hub">
    <div class="dfe-c-page-title dfe-c-mb-3">
        <div class="dfe-c-page-title__caption">@standard.Title</div>
        <h1 class="dfe-c-page-title__heading">Add theme</h1>
        <p class="dfe-c-page-title__lede"><a class="govuk-link govuk-link--no-visited-state" href="@StdUrl()">Back to @standard.Title</a></p>
    </div>

    @if (ViewBag.AdminError != null)
    {
        <div class="govuk-error-summary" role="alert" data-module="govuk-error-summary" style="margin-bottom:1.5rem;">
            <h2 class="govuk-error-summary__title">There is a problem</h2>
            <div class="govuk-error-summary__body">@ViewBag.AdminError</div>
        </div>
    }

    <div class="dfe-c-card dfe-c-mb-4" style="border:1px solid var(--grey-2);border-left:4px solid var(--blue);padding:1.25rem 1.5rem;background:var(--white);max-width:40rem;">
        <h2 class="govuk-heading-m govuk-!-margin-top-0">Theme details</h2>
        <p class="govuk-hint govuk-!-margin-bottom-3">The theme ID is a sequential number within this standard (for example 1, 2, 3).</p>
        <form method="post" action="@Url.Action("FsThemeCreate", "ModernAdmin", new { standardId = standard.Id })" novalidate>
            @Html.AntiForgeryToken()
            <div class="govuk-form-group govuk-!-margin-bottom-3">
                <label class="govuk-label" for="t-id">Theme ID</label>
                <input class="govuk-input govuk-input--width-4" type="number" name="themeId" id="t-id" required min="1" />
            </div>
            <div class="govuk-form-group govuk-!-margin-bottom-3">
                <label class="govuk-label" for="t-title">Title</label>
                <input class="govuk-input govuk-!-width-two-thirds" type="text" name="title" id="t-title" required autocomplete="off" maxlength="255" />
            </div>
            <div class="govuk-form-group govuk-!-margin-bottom-3">
                <label class="govuk-label" for="t-desc">Description <span class="govuk-hint govuk-!-display-inline">(optional)</span></label>
                <textarea class="govuk-textarea govuk-!-width-two-thirds" name="description" id="t-desc" rows="4"></textarea>
            </div>
            <div class="govuk-button-group">
                <button type="submit" class="govuk-button" data-module="govuk-button">Create theme</button>
                <a href="@StdUrl()" class="govuk-link govuk-link--no-visited-state govuk-!-margin-left-2">Cancel</a>
            </div>
        </form>
    </div>
</div>
