@model Compass.Models.PracticeArea
@using Compass.ViewModels.Modern
@using Microsoft.AspNetCore.Html
@using System.Net
@{
    var theme = Model.Theme!;
    var standard = theme.FunctionalStandard!;
    ViewData["Title"] = $"Practice area {Model.PracticeAreaId} — {Model.Title}";
    string ThemeUrl() => Url.Action("FsThemeDetail", "ModernAdmin", new { standardId = standard.Id, themeId = theme.ThemeId }) ?? "#";
}

@section Breadcrumbs {
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin")">Admin</a></li>
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin", new { panel = "std-functional" })">Functional standards</a></li>
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("FunctionalStandardDetail", "ModernAdmin", new { id = standard.Id })">@standard.Title</a></li>
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@ThemeUrl()">Theme @theme.ThemeId</a></li>
    <li class="govuk-breadcrumbs__list-item" aria-current="page">PA @Model.PracticeAreaId</li>
}

<div class="admin-hub">
    @await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
        Caption = $"{standard.Title} — Theme {theme.ThemeId} — Practice area {Model.PracticeAreaId}",
        Title = Model.Title,
        Lede = new HtmlString($"<p class=\"govuk-body govuk-!-margin-bottom-0\"><a class=\"govuk-link govuk-link--no-visited-state\" href=\"{ThemeUrl()}\">Back to {WebUtility.HtmlEncode(theme.Title)}</a></p>")
    })

    @if (ViewBag.AdminMessage != null)
    {
        <div class="govuk-notification-banner govuk-notification-banner--success" role="alert" style="margin-bottom:1.5rem;">
            <div class="govuk-notification-banner__content"><p class="govuk-body">@ViewBag.AdminMessage</p></div>
        </div>
    }
    @if (ViewBag.AdminError != null)
    {
        <div class="govuk-error-summary" role="alert" style="margin-bottom:1.5rem;">
            <h2 class="govuk-error-summary__title">There is a problem</h2>
            <div class="govuk-error-summary__body">@ViewBag.AdminError</div>
        </div>
    }

    <div class="dfe-c-card dfe-c-mb-4" style="border:1px solid var(--grey-2);padding:1.25rem 1.5rem;background:var(--white);max-width:50rem;">
        <dl class="govuk-summary-list govuk-!-margin-bottom-0">
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Practice area ID</dt>
                <dd class="govuk-summary-list__value">@Model.PracticeAreaId</dd>
            </div>
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Title</dt>
                <dd class="govuk-summary-list__value">@Model.Title</dd>
            </div>
            <div class="govuk-summary-list__row">
                <dt class="govuk-summary-list__key">Description</dt>
                <dd class="govuk-summary-list__value">@(string.IsNullOrWhiteSpace(Model.Description) ? "—" : Model.Description)</dd>
            </div>
        </dl>
        <div class="govuk-button-group govuk-!-margin-top-4 govuk-!-margin-bottom-0">
            <a href="@Url.Action("FsPracticeAreaEdit", "ModernAdmin", new { standardId = standard.Id, themeId = theme.ThemeId, paId = Model.Id })" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0">Edit practice area</a>
            <form method="post" action="@Url.Action("FsPracticeAreaDelete", "ModernAdmin", new { standardId = standard.Id, themeId = theme.ThemeId, paId = Model.Id })" style="display:inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-confirm="Delete this practice area and all its criteria? This cannot be undone.">Delete</button>
            </form>
        </div>
    </div>

    <div class="dfe-c-flex--between dfe-c-mb-2">
        <h2 class="govuk-heading-m" style="margin:0;">Criteria (@Model.Criteria.Count)</h2>
        <a class="govuk-button govuk-!-margin-bottom-0" href="@Url.Action("FsCriterionCreate", "ModernAdmin", new { standardId = standard.Id, themeId = theme.ThemeId, paId = Model.Id })">Add criterion</a>
    </div>

    <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
        <table class="govuk-table">
            <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                    <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Code</button></th>
                    <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Criteria</button>
        </th>
                    <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Rating</button></th>
                    <th scope="col" class="govuk-table__header govuk-table__header--numeric"><span class="govuk-visually-hidden">Actions</span></th>
                </tr>
            </thead>
            <tbody class="govuk-table__body">
                @if (!Model.Criteria.Any())
                {
                    <tr class="govuk-table__row"><td colspan="4" class="dfe-c-text-muted">No criteria yet.</td></tr>
                }
                else
                {
                    foreach (var c in Model.Criteria.OrderBy(x => x.CriteriaCode))
                    {
                        var ratingTag = c.Rating switch
                        {
                            Compass.Models.CriteriaRating.Good => ("Good", "govuk-tag--blue"),
                            Compass.Models.CriteriaRating.Better => ("Better", "govuk-tag--green"),
                            Compass.Models.CriteriaRating.Best => ("Best", "govuk-tag--purple"),
                            _ => (c.Rating.ToString(), "govuk-tag--grey")
                        };
                        <tr class="govuk-table__row">
                            <td class="govuk-table__cell"><strong>@c.CriteriaCode</strong></td>
                            <td class="govuk-table__cell" style="max-width:28rem;">@(c.Criteria.Length > 150 ? c.Criteria.Substring(0, 150) + "…" : c.Criteria)</td>
                            <td class="govuk-table__cell"><span class="govuk-tag @ratingTag.Item2">@ratingTag.Item1</span></td>
                            <td class="govuk-table__cell" style="text-align:right;white-space:nowrap;">
                                <a class="govuk-link govuk-link--no-visited-state govuk-!-margin-right-3" href="@Url.Action("FsCriterionEdit", "ModernAdmin", new { criterionId = c.Id })">Edit</a>
                                <form method="post" action="@Url.Action("FsCriterionDelete", "ModernAdmin", new { criterionId = c.Id })" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="govuk-link" style="padding:0;border:0;background:none;cursor:pointer;font:inherit;color:#d4351c;" data-confirm="Delete criterion @c.CriteriaCode? This cannot be undone.">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
