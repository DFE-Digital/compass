@{
    var pa = ViewBag.PracticeArea as Compass.Models.PracticeArea;
    var theme = ViewBag.Theme as Compass.Models.FunctionalStandardTheme;
    var standard = ViewBag.Standard as Compass.Models.FunctionalStandard;
    ViewData["Title"] = $"Add criterion — PA {pa!.PracticeAreaId}";
    string PaUrl() => Url.Action("FsPracticeAreaDetail", "ModernAdmin", new { standardId = standard!.Id, themeId = theme!.ThemeId, paId = pa!.Id }) ?? "#";
}

@section Breadcrumbs {
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin")">Admin</a></li>
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin", new { panel = "std-functional" })">Functional standards</a></li>
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("FunctionalStandardDetail", "ModernAdmin", new { id = standard!.Id })">@standard.Title</a></li>
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("FsThemeDetail", "ModernAdmin", new { standardId = standard.Id, themeId = theme!.ThemeId })">Theme @theme.ThemeId</a></li>
    <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@PaUrl()">PA @pa.PracticeAreaId</a></li>
    <li class="govuk-breadcrumbs__list-item" aria-current="page">Add criterion</li>
}

<div class="admin-hub">
    <div class="dfe-c-page-title dfe-c-mb-3">
        <div class="dfe-c-page-title__caption">@standard.Title — Theme @theme.ThemeId — PA @pa.PracticeAreaId</div>
        <h1 class="dfe-c-page-title__heading">Add criterion</h1>
        <p class="dfe-c-page-title__lede"><a class="govuk-link govuk-link--no-visited-state" href="@PaUrl()">Back to @pa.Title</a></p>
    </div>

    @if (ViewBag.AdminError != null)
    {
        <div class="govuk-error-summary" role="alert" data-module="govuk-error-summary" style="margin-bottom:1.5rem;">
            <h2 class="govuk-error-summary__title">There is a problem</h2>
            <div class="govuk-error-summary__body">@ViewBag.AdminError</div>
        </div>
    }

    <div class="dfe-c-card dfe-c-mb-4" style="border:1px solid var(--grey-2);border-left:4px solid var(--blue);padding:1.25rem 1.5rem;background:var(--white);max-width:40rem;">
        <h2 class="govuk-heading-m govuk-!-margin-top-0">Criterion details</h2>
        <p class="govuk-hint govuk-!-margin-bottom-3">The criteria code must be unique within this practice area (for example "1.1a", "1.1b").</p>
        <form method="post" action="@Url.Action("FsCriterionCreate", "ModernAdmin", new { standardId = standard.Id, themeId = theme.ThemeId, paId = pa.Id })" novalidate>
            @Html.AntiForgeryToken()
            <div class="govuk-form-group govuk-!-margin-bottom-3">
                <label class="govuk-label" for="c-code">Criteria code</label>
                <span class="govuk-hint">For example 1.1a</span>
                <input class="govuk-input govuk-input--width-10" type="text" name="criteriaCode" id="c-code" required autocomplete="off" maxlength="50" />
            </div>
            <div class="govuk-form-group govuk-!-margin-bottom-3">
                <label class="govuk-label" for="c-text">Criteria text</label>
                <textarea class="govuk-textarea govuk-!-width-two-thirds" name="criteria" id="c-text" rows="4" required></textarea>
            </div>
            <div class="govuk-form-group govuk-!-margin-bottom-3">
                <label class="govuk-label" for="c-rating">Rating</label>
                <select class="govuk-select" name="rating" id="c-rating" required>
                    <option value="0">Good</option>
                    <option value="1">Better</option>
                    <option value="2">Best</option>
                </select>
            </div>
            <div class="govuk-button-group">
                <button type="submit" class="govuk-button" data-module="govuk-button">Create criterion</button>
                <a href="@PaUrl()" class="govuk-link govuk-link--no-visited-state govuk-!-margin-left-2">Cancel</a>
            </div>
        </form>
    </div>
</div>
