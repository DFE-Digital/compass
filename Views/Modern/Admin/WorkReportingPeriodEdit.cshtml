@model Compass.ViewModels.Modern.WorkReportingPeriodFormViewModel
@using Compass.ViewModels.Modern
@{
  ViewData["Title"] = "Edit monthly reporting period";
  var adminError = ViewBag.AdminError as string;
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin")">Admin</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("WorkReporting", "ModernAdmin")">Work reporting</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Edit monthly reporting period</li>
}

<div id="sc-admin-wr-edit" class="admin-hub">
 @await Html.PartialAsync("~/Views/Modern/Shared/_ModernPageHeader.cshtml", new ModernPageHeaderViewModel {
   BackLinkHref = Url.Action("WorkReporting", "ModernAdmin"),
   BackLinkText = "Back to work reporting",
   Caption = "Administration",
   Title = "Edit monthly reporting period"
 })

 @if (!string.IsNullOrWhiteSpace(adminError))
 {
 <div class="govuk-error-summary" role="alert" data-module="govuk-error-summary" style="margin-bottom:1.5rem;">
 <h2 class="govuk-error-summary__title">There is a problem</h2>
 <div class="govuk-error-summary__body">
 <ul class="govuk-list govuk-error-summary__list">
              <li><a href="#periodLabel">@adminError</a></li>
            </ul>
          </div>
        </div>
 }

 <div class="govuk-grid-row govuk-!-margin-top-0">
 <div class="govuk-grid-column-one-quarter-from-desktop">
 <p class="govuk-body-s govuk-hint govuk-!-margin-top-0 govuk-!-margin-bottom-0">Same shape as performance commissions: period bounds, submission opens, submission closes. The calendar month for this row is taken from <strong>period start</strong> (used as the reporting month key).</p>
 </div>
 <div class="govuk-grid-column-three-quarters-from-desktop">
 <div class="dfe-c-card dfe-c-mb-4" style="border:1px solid var(--grey-2);border-left:4px solid var(--blue);padding:1.25rem 1.5rem;background:var(--white);">
    <form method="post" action="@Url.Action("WorkReportingPeriodEditPost", "ModernAdmin", new { id = Model.Id })" id="wr-period-edit-form" novalidate>
      @Html.AntiForgeryToken()
      <fieldset class="govuk-fieldset">
        <legend class="govuk-fieldset__legend govuk-fieldset__legend--m govuk-visually-hidden">Monthly reporting period details</legend>

 <div class="govuk-grid-row">
 <div class="govuk-grid-column-full">
 <div class="govuk-form-group">
 <label class="govuk-label" for="periodLabel">Name</label>
 <div id="periodLabel-hint" class="govuk-hint">For example April 2026</div>
 <input class="govuk-input govuk-!-width-two-thirds" type="text" name="periodLabel" id="periodLabel" required maxlength="100" autocomplete="off" value="@Model.PeriodLabel" aria-describedby="periodLabel-hint" />
      </div>
 </div>
 </div>

 <div class="govuk-grid-row">
 <div class="govuk-grid-column-full">
 @await Html.PartialAsync("~/Views/Modern/Raid/_RaidGovUkDateInput.cshtml", new RaidGovUkDateFieldVm {
   NamePrefix = "PeriodStart",
   Legend = "Period start",
   Hint = "First day of the reporting window. Sets the calendar month key for this row.",
   Day = Model.PeriodStart?.Day,
   Month = Model.PeriodStart?.Month,
   Year = Model.PeriodStart?.Year,
   FieldIdPrefix = "wr-period-start"
 })
 </div>
 </div>

 <div class="govuk-grid-row">
 <div class="govuk-grid-column-full">
 @await Html.PartialAsync("~/Views/Modern/Raid/_RaidGovUkDateInput.cshtml", new RaidGovUkDateFieldVm {
   NamePrefix = "PeriodEnd",
   Legend = "Period end",
   Hint = "Last day of the reporting window (inclusive).",
   Day = Model.PeriodEnd?.Day,
   Month = Model.PeriodEnd?.Month,
   Year = Model.PeriodEnd?.Year,
   FieldIdPrefix = "wr-period-end"
 })
 </div>
 </div>

 <div class="govuk-grid-row">
 <div class="govuk-grid-column-full">
 @await Html.PartialAsync("~/Views/Modern/Raid/_RaidGovUkDateInput.cshtml", new RaidGovUkDateFieldVm {
   NamePrefix = "SubmissionOpens",
   Legend = "Submission opens",
   Hint = "First day users can submit for this reporting month.",
   Day = Model.SubmissionOpens?.Day,
   Month = Model.SubmissionOpens?.Month,
   Year = Model.SubmissionOpens?.Year,
   FieldIdPrefix = "wr-sub-opens"
 })
 </div>
 </div>

 <div class="govuk-grid-row">
 <div class="govuk-grid-column-full">
 @await Html.PartialAsync("~/Views/Modern/Raid/_RaidGovUkDateInput.cshtml", new RaidGovUkDateFieldVm {
   NamePrefix = "SubmissionCloses",
   Legend = "Submission closes",
   Hint = "Last day submissions are accepted (inclusive).",
   Day = Model.SubmissionCloses?.Day,
   Month = Model.SubmissionCloses?.Month,
   Year = Model.SubmissionCloses?.Year,
   FieldIdPrefix = "wr-sub-closes"
 })
 </div>
 </div>

 <div class="govuk-grid-row">
 <div class="govuk-grid-column-full">
 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Active</legend>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="isActive" name="isActive" type="checkbox" value="true" @(Model.IsActive ? "checked" : "") />
 <label class="govuk-label govuk-checkboxes__label" for="isActive">Period is active</label>
            </div>
          </div>
        </fieldset>
      </div>
 </div>
 </div>

 <div class="govuk-button-group govuk-!-margin-top-6">
 <button type="submit" class="govuk-button" data-module="govuk-button">Save changes</button>
 <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("WorkReporting", "ModernAdmin")">Cancel</a>
      </div>
      </fieldset>
    </form>
  </div>
 </div>
 </div>
</div>
