@model Compass.ViewModels.Modern.WorkReportingPeriodFormViewModel
@{
  ViewData["Title"] = "Edit reporting period";
  var adminError = ViewBag.AdminError as string;
}
@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin")">Admin</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("WorkReporting", "ModernAdmin")">Work reporting</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Edit</li>
}

<div id="sc-admin-wr-edit" class="admin-hub dfe-c-mb-4">
 <div class="dfe-c-page-title dfe-c-mb-3">
 <div class="dfe-c-page-title__caption">Admin</div>
 <h1 class="dfe-c-page-title__heading">Edit reporting period</h1>
 <p class="dfe-c-page-title__lede"><a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("WorkReporting", "ModernAdmin")">Back to Work reporting</a></p>
  </div>

 <div class="dfe-c-card dfe-c-mb-4" style="border:1px solid var(--grey-2);border-left:4px solid var(--blue);padding:1.25rem 1.5rem;background:var(--white);max-width:56rem;">
 <h2 class="govuk-heading-m govuk-!-margin-top-0">Reporting period</h2>

    <form method="post" action="@Url.Action("WorkReportingPeriodEditPost", "ModernAdmin", new { id = Model.Id })" id="wr-period-edit-form" novalidate>
      @Html.AntiForgeryToken()

      @if (!string.IsNullOrWhiteSpace(adminError))
      {
 <div class="govuk-error-summary" data-module="govuk-error-summary" role="alert">
 <h2 class="govuk-error-summary__title">There is a problem</h2>
 <div class="govuk-error-summary__body">
 <ul class="govuk-list govuk-error-summary__list">
              <li><a href="#periodLabel">@adminError</a></li>
            </ul>
          </div>
        </div>
      }

 <div class="govuk-form-group">
 <label class="govuk-label" for="periodLabel">Name</label>
 <div id="periodLabel-hint" class="govuk-hint">For example April 2026</div>
 <input class="govuk-input govuk-!-width-two-thirds" type="text" name="periodLabel" id="periodLabel" required maxlength="100" autocomplete="off" value="@Model.PeriodLabel" aria-describedby="periodLabel-hint" />
      </div>

 <div class="govuk-grid-row">
 <div class="govuk-grid-column-one-half-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="periodStart">Period start</label>
 <input class="govuk-input" type="date" name="periodStart" id="periodStart" required value="@(Model.PeriodStart.HasValue ? Model.PeriodStart.Value.ToString("yyyy-MM-dd") : "")" />
          </div>
        </div>
 <div class="govuk-grid-column-one-half-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="periodEnd">Period end</label>
 <input class="govuk-input" type="date" name="periodEnd" id="periodEnd" required value="@(Model.PeriodEnd.HasValue ? Model.PeriodEnd.Value.ToString("yyyy-MM-dd") : "")" />
          </div>
        </div>
      </div>

 <div class="govuk-grid-row">
 <div class="govuk-grid-column-one-half-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="submissionOpens">Submission opens</label>
 <input class="govuk-input" type="date" name="submissionOpens" id="submissionOpens" required value="@(Model.SubmissionOpens.HasValue ? Model.SubmissionOpens.Value.ToString("yyyy-MM-dd") : "")" />
          </div>
        </div>
 <div class="govuk-grid-column-one-half-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="submissionCloses">Submission closes</label>
 <input class="govuk-input" type="date" name="submissionCloses" id="submissionCloses" required value="@(Model.SubmissionCloses.HasValue ? Model.SubmissionCloses.Value.ToString("yyyy-MM-dd") : "")" />
          </div>
        </div>
      </div>

 <div class="govuk-form-group">
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Active</legend>
 <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="isActive" name="isActive" type="checkbox" value="true" @(Model.IsActive ? "checked" : "") />
 <label class="govuk-label govuk-checkboxes__label" for="isActive">Period is active</label>
            </div>
          </div>
        </fieldset>
      </div>

 <div class="govuk-button-group">
 <button type="submit" class="govuk-button" data-module="govuk-button">Save changes</button>
 <a class="govuk-link" href="@Url.Action("WorkReporting", "ModernAdmin")">Cancel</a>
      </div>
    </form>
  </div>
</div>
