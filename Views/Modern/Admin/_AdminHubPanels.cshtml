 </div>
 <div class="govuk-radios__item">
 @if (fSome)
 { <input class="govuk-radios__input" id="f-access-@i-some" name="featureToggles[@i].AccessMode" type="radio" value="2" checked="checked" /> }
 else
 { <input class="govuk-radios__input" id="f-access-@i-some" name="featureToggles[@i].AccessMode" type="radio" value="2" /> }
 <label class="govuk-label govuk-radios__label" for="f-access-@i-some">On for some</label>
 </div>
 <div class="govuk-radios__item">
 @if (fOff)
 { <input class="govuk-radios__input" id="f-access-@i-off" name="featureToggles[@i].AccessMode" type="radio" value="0" checked="checked" /> }
 else
