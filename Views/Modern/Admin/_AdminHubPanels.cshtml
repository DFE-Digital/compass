  {
  <option value="@opt.Id" selected>@opt.Name</option>
  }
  else
  {
  <option value="@opt.Id">@opt.Name</option>
  }
  }
  </select>
  </div>
  }
 </div>
 </fieldset>
 </div>
 }
 <button type="submit" class="govuk-button govuk-!-margin-top-2">Save feature settings</button>
 </form>
