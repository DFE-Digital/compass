          </thead>
          <tbody>
            @if (Model.StdFunctional.Count == 0)
            {
 <tr><td colspan="5" class="dfe-c-text-muted">No functional standards found.</td></tr>
            }
            else
            {
              foreach (var row in Model.StdFunctional)
              {
                <tr>
                  <td><strong>@row.Title</strong></td>
                  <td style="max-width:20rem;">@(string.IsNullOrEmpty(row.Description) ? "—" : (row.Description.Length > 120 ? row.Description.Substring(0, 120) + "…" : row.Description))</td>
                  <td>@row.ThemeCount</td>
                  <td>@(row.PublishedDate?.ToString("d MMM yyyy") ?? "—")</td>
                  <td style="text-align:right;white-space:nowrap;">
 <a href="@Url.Action("FunctionalStandardDetail", "ModernAdmin", new { id = row.Id })" class="govuk-link govuk-link--no-visited-state">Manage</a>
                  </td>
                </tr>
              }
            }
          </tbody>
        </table>
      </div>
    </div>
    break;

  default:
 <div class="admin-panel">
 <p class="dfe-c-text-muted">Select a configuration area from the left. <a class="govuk-link" href="@Url.Action("Index", "ModernAdmin")">Back to admin home</a>.</p>
    </div>
    break;
}
