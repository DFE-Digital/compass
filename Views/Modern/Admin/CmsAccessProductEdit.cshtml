@using Compass.Models
@{
  ViewData["Title"] = "Edit CMS access product";
  var p = ViewBag.Product as CmsAccessRequestProduct;
  if (p == null) { return; }
}

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin")">Admin</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin", new { panel = "cms-access-products" })">CMS access products</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">Edit</li>
}

<div class="admin-hub">
  <div class="dfe-c-page-title dfe-c-mb-2">
    <div class="dfe-c-page-title__caption">Access &amp; integration</div>
    <h1 class="dfe-c-page-title__heading">Edit CMS access product</h1>
  </div>

  @if (ViewBag.AdminError != null)
  {
    <div class="govuk-error-summary" role="alert" style="margin-bottom:1.5rem;">
      <h2 class="govuk-error-summary__title">There is a problem</h2>
      <div class="govuk-error-summary__body">@ViewBag.AdminError</div>
    </div>
  }

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <div class="dfe-c-card dfe-c-card--plain">
        <form method="post" action="@Url.Action("CmsAccessProductSave", "ModernAdmin", new { id = p.Id })">
          @Html.AntiForgeryToken()

          <div class="govuk-form-group">
            <label class="govuk-label govuk-label--s" for="name">CMS product name</label>
            <div class="govuk-hint" id="name-hint">Integrations send this as <code class="govuk-body-s">cmsName</code> (case-insensitive).</div>
            <input class="govuk-input" id="name" name="name" type="text" required maxlength="200" value="@p.Name" aria-describedby="name-hint" />
          </div>

          <div class="govuk-form-group">
            <label class="govuk-label govuk-label--s" for="signInPageUrl">Sign-in page URL</label>
            <input class="govuk-input" id="signInPageUrl" name="signInPageUrl" type="url" required value="@p.SignInPageUrl" />
          </div>

          <div class="govuk-form-group">
            <label class="govuk-label govuk-label--s" for="sortOrder">Sort order</label>
            <input class="govuk-input govuk-input--width-5" id="sortOrder" name="sortOrder" type="number" value="@p.SortOrder" />
          </div>

          <div class="govuk-form-group">
            <label class="govuk-label govuk-label--s" for="isActive">Status</label>
            <select class="govuk-select" id="isActive" name="isActive" aria-describedby="isActive-hint">
              @if (p.IsActive)
              {
                <option value="true" selected>Active</option>
                <option value="false">Inactive</option>
              }
              else
              {
                <option value="true">Active</option>
                <option value="false" selected>Inactive</option>
              }
            </select>
            <div class="govuk-hint" id="isActive-hint">Inactive products are not accepted by the API for new <code class="govuk-body-s">cmsName</code> submissions.</div>
          </div>

          <div class="govuk-button-group">
            <button type="submit" class="govuk-button">Save</button>
            <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("Index", "ModernAdmin", new { panel = "cms-access-products" })">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
