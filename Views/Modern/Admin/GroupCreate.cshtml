@model Compass.ViewModels.Modern.AdminGroupFormViewModel
@{
    ViewData["Title"] = "Add group";
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin")">Admin</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Groups", "ModernAdmin")">Groups</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Add group</li>
}

<div class="admin-hub">
 <div class="dfe-c-page-title dfe-c-mb-3">
 <div class="dfe-c-page-title__caption">Administration</div>
 <h1 class="dfe-c-page-title__heading">Add group</h1>
 <p class="dfe-c-page-title__lede"><a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("Groups", "ModernAdmin")">Back to all groups</a></p>
  </div>

  @if (ViewBag.AdminError != null)
  {
 <div class="govuk-error-summary" role="alert" data-module="govuk-error-summary" style="margin-bottom:1.5rem;">
 <h2 class="govuk-error-summary__title">There is a problem</h2>
 <div class="govuk-error-summary__body">@ViewBag.AdminError</div>
    </div>
  }

 <div class="dfe-c-card dfe-c-mb-4" style="border:1px solid var(--grey-2);border-left:4px solid var(--blue);padding:1.25rem 1.5rem;background:var(--white);max-width:40rem;">
 <h2 class="govuk-heading-m govuk-!-margin-top-0">Group details</h2>
 <p class="govuk-hint govuk-!-margin-bottom-3">Give the group a clear name. You can add members and feature permissions after it is created.</p>
    <form method="post" action="@Url.Action("GroupCreate", "ModernAdmin")" novalidate>
      @Html.AntiForgeryToken()
 <div class="govuk-form-group govuk-!-margin-bottom-3">
 <label class="govuk-label" for="grp-name">Group name</label>
 <input class="govuk-input govuk-!-width-two-thirds" type="text" name="name" id="grp-name" required autocomplete="off" maxlength="200" value="@Model.Name" />
      </div>
 <div class="govuk-form-group govuk-!-margin-bottom-3">
 <label class="govuk-label" for="grp-desc">Description <span class="govuk-hint govuk-!-display-inline">(optional)</span></label>
 <input class="govuk-input govuk-!-width-two-thirds" type="text" name="description" id="grp-desc" autocomplete="off" maxlength="500" value="@Model.Description" />
      </div>
 <div class="govuk-button-group">
 <button type="submit" class="govuk-button" data-module="govuk-button">Create group</button>
 <a href="@Url.Action("Groups", "ModernAdmin")" class="govuk-link govuk-link--no-visited-state govuk-!-margin-left-2">Cancel</a>
      </div>
    </form>
  </div>
</div>
