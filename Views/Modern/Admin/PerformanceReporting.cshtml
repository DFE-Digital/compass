@model Compass.ViewModels.Modern.PerfReportingHubViewModel
@{
    ViewData["Title"] = "Performance reporting";
    string P(string id) => Url.Action("PerformanceReporting", "ModernAdmin", new { panel = id }) ?? "#";
    var cur = Model.Panel;
    var navGroupReporting = cur is "metrics" or "commissions" or "due-overrides";
    var navGroupScope = cur == "product-exclusions";
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin")">Admin</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Performance reporting</li>
}

<div class="admin-hub">
 <div class="dfe-c-page-title">
 <div class="dfe-c-page-title__caption">Administration</div>
 <h1 class="dfe-c-page-title__heading">Performance reporting</h1>
 <p class="dfe-c-page-title__lede">Metrics, commissions, due dates, and reporting scope</p>
  </div>

  <div style="display:grid;grid-template-columns:17rem 1fr;gap:1.5rem;align-items:start;">
    @* ── Sidebar (same pattern as Admin → Configuration areas) ── *@
    <nav style="background:var(--white);border:1px solid var(--grey-2);" aria-label="Performance configuration areas">
      <div style="padding:0.75rem 1rem;background:var(--grey-1);border-bottom:2px solid var(--navy);font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;color:var(--navy);">Configuration areas</div>
 <details class="admin-nav-group @(navGroupReporting ?"admin-nav-group--open" : "")" id="ang-perf-reporting" @(navGroupReporting ? "open" : null)>
 <summary class="admin-nav-group__header">
 <span class="admin-nav-group__icon-open" aria-hidden="true">−</span>
 <span class="admin-nav-group__icon-closed" aria-hidden="true">+</span>
          <span>Reporting &amp; deadlines</span>
        </summary>
 <div class="admin-nav-group__body">
 <a class="admin-nav-link @(cur =="metrics" ? "admin-nav-link--active" : "")" href="@P("metrics")">Metrics</a>
 <a class="admin-nav-link @(cur =="commissions" ? "admin-nav-link--active" : "")" href="@P("commissions")">Commissions</a>
 <a class="admin-nav-link @(cur =="due-overrides" ? "admin-nav-link--active" : "")" href="@P("due-overrides")">Due date overrides</a>
        </div>
      </details>
 <details class="admin-nav-group @(navGroupScope ?"admin-nav-group--open" : "")" id="ang-perf-scope" @(navGroupScope ? "open" : null)>
 <summary class="admin-nav-group__header">
 <span class="admin-nav-group__icon-open" aria-hidden="true">−</span>
 <span class="admin-nav-group__icon-closed" aria-hidden="true">+</span>
          <span>Scope &amp; exclusions</span>
        </summary>
 <div class="admin-nav-group__body">
 <a class="admin-nav-link @(cur =="product-exclusions" ? "admin-nav-link--active" : "")" href="@P("product-exclusions")">Product exclusions</a>
        </div>
      </details>
    </nav>

    @* ── Panel content ── *@
    <div>
      @if (ViewBag.PerfError != null)
      {
 <div class="govuk-error-summary" role="alert" data-module="govuk-error-summary" style="margin-bottom:1rem;">
 <h2 class="govuk-error-summary__title">There is a problem</h2>
 <div class="govuk-error-summary__body">@ViewBag.PerfError</div>
        </div>
      }
      @if (ViewBag.AdminMessage != null)
      {
 <div class="govuk-notification-banner govuk-notification-banner--success dfe-c-mb-3" role="region" aria-labelledby="perf-notif-title">
 <div class="govuk-notification-banner__header">
 <h2 class="govuk-notification-banner__title" id="perf-notif-title">Success</h2>
          </div>
 <div class="govuk-notification-banner__content">
 <p class="govuk-notification-banner__heading">@ViewBag.AdminMessage</p>
          </div>
        </div>
      }

      @switch (cur)
      {
        @* ════════════ METRICS ════════════ *@
        case "metrics":
 <div class="admin-panel">
 <div class="dfe-c-flex dfe-c-flex--between dfe-c-mb-2" style="align-items:flex-start;flex-wrap:wrap;gap:0.75rem;">
              <div>
 <h2 class="govuk-heading-m govuk-!-margin-top-0" style="margin-bottom:0.25rem;">Performance metrics</h2>
 <p class="govuk-body govuk-hint govuk-!-margin-bottom-0">Definitions used in product returns and commission submissions.</p>
              </div>
 <a class="govuk-button" href="@Url.Action("PerfMetricCreateForm", "ModernAdmin")">Create metric</a>
            </div>
 <div class="dfe-c-table-wrap">
              <table >
                <thead>
                  <tr>
 <th data-sort-bound="1" class="sortable">Identifier</th>
 <th data-sort-bound="1" class="sortable">Title</th>
 <th data-sort-bound="1" class="sortable">Type</th>
 <th data-sort-bound="1" class="sortable">Valid from</th>
 <th data-sort-bound="1" class="sortable">Phases</th>
 <th data-sort-bound="1" class="sortable">Status</th>
 <th><span class="govuk-visually-hidden">Actions</span></th>
                  </tr>
                </thead>
                <tbody>
                  @if (Model.Metrics.Count == 0)
                  {
 <tr><td colspan="7"><span class="dfe-c-text-muted">No metrics yet. Use <strong>Create metric</strong> to add one.</span></td></tr>
                  }
                  @foreach (var m in Model.Metrics)
                  {
                    <tr>
                      <td><code>@m.Identifier</code></td>
                      <td><strong>@m.Title</strong></td>
                      <td>@m.ValueType</td>
                      <td>@m.ValidFrom</td>
                      <td>@(string.IsNullOrEmpty(m.ApplicablePhases) ? "All" : m.ApplicablePhases)</td>
                      <td>
 @if (m.IsDisabled) { <span class="dfe-c-tag dfe-c-tag--grey">Disabled</span> }
 else { <span class="dfe-c-tag dfe-c-tag--green">Active</span> }
                      </td>
                      <td style="text-align:right;white-space:nowrap;">
 <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("PerfMetricEditForm", "ModernAdmin", new { id = m.Id })">Edit</a>
                      </td>
                    </tr>
                  }
                </tbody>
              </table>
            </div>
          </div>
          break;

        @* ════════════ COMMISSIONS ════════════ *@
        case "commissions":
 <div class="admin-panel">
 <div class="dfe-c-flex dfe-c-flex--between dfe-c-mb-2" style="align-items:flex-start;flex-wrap:wrap;gap:0.75rem;">
              <div>
 <h2 class="govuk-heading-m govuk-!-margin-top-0" style="margin-bottom:0.25rem;">Commissions</h2>
 <p class="govuk-body govuk-hint govuk-!-margin-bottom-0">Reporting periods when products must submit performance data.</p>
              </div>
 <a class="govuk-button" href="@Url.Action("PerfCommissionCreateForm", "ModernAdmin")">Create commission</a>
            </div>
 <div class="dfe-c-table-wrap">
              <table >
                <thead>
                  <tr>
 <th data-sort-bound="1" class="sortable">Name</th>
 <th data-sort-bound="1" class="sortable">Quarter</th>
 <th data-sort-bound="1" class="sortable">Period</th>
 <th data-sort-bound="1" class="sortable">Opens</th>
 <th data-sort-bound="1" class="sortable">Due</th>
 <th data-sort-bound="1" class="sortable">Subs</th>
 <th data-sort-bound="1" class="sortable">Active</th>
 <th><span class="govuk-visually-hidden">Actions</span></th>
                  </tr>
                </thead>
                <tbody>
                  @if (Model.Commissions.Count == 0)
                  {
 <tr><td colspan="8"><span class="dfe-c-text-muted">No commissions yet. Use <strong>Create commission</strong> to add one.</span></td></tr>
                  }
                  @foreach (var c in Model.Commissions)
                  {
                    <tr>
                      <td><strong>@c.Name</strong></td>
                      <td>@(c.Quarter ?? "—")</td>
                      <td>@c.StartDate.ToString("d MMM yy") – @c.EndDate.ToString("d MMM yy")</td>
                      <td>@c.OpenDate.ToString("d MMM yy")</td>
                      <td>@c.DueDate.ToString("d MMM yy")</td>
                      <td style="text-align:right;">@c.SubmissionCount</td>
 <td>@if (c.IsActive) { <span class="dfe-c-tag dfe-c-tag--green">Yes</span> } else { <span class="dfe-c-tag dfe-c-tag--grey">No</span> }</td>
                      <td style="text-align:right;white-space:nowrap;">
 <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("PerfCommissionEditForm", "ModernAdmin", new { id = c.Id })">Edit</a>
                      </td>
                    </tr>
                  }
                </tbody>
              </table>
            </div>
          </div>
          break;

        @* ════════════ DUE DATE OVERRIDES ════════════ *@
        case "due-overrides":
 <div class="admin-panel">
 <h2 class="govuk-heading-m govuk-!-margin-top-0 govuk-!-margin-bottom-2">Due date overrides</h2>
 <p class="govuk-body govuk-hint govuk-!-margin-bottom-4">Override the default due date for specific reporting periods (e.g. bank holiday adjustments).</p>
 <div class="dfe-c-table-wrap">
              <table >
                <thead>
                  <tr>
 <th data-sort-bound="1" class="sortable">Period</th>
 <th data-sort-bound="1" class="sortable">Due date</th>
 <th data-sort-bound="1" class="sortable">Reason</th>
 <th data-sort-bound="1" class="sortable">Active</th>
 <th><span class="govuk-visually-hidden">Actions</span></th>
                  </tr>
                </thead>
                <tbody>
                  @if (Model.DueDateOverrides.Count == 0)
                  {
 <tr><td colspan="5"><span class="dfe-c-text-muted">No overrides.</span></td></tr>
                  }
                  @foreach (var d in Model.DueDateOverrides)
                  {
                    <tr>
                      <td><strong>@d.ReportingYear-@d.ReportingMonth.ToString("D2")</strong></td>
                      <td>@d.DueDate.ToString("d MMM yyyy")</td>
                      <td>@(d.Reason ?? "—")</td>
 <td>@if (d.IsActive) { <span class="dfe-c-tag dfe-c-tag--green">Yes</span> } else { <span class="dfe-c-tag dfe-c-tag--grey">No</span> }</td>
                      <td style="text-align:right;">
                        <form method="post" action="@Url.Action("PerfDueOverrideDelete", "ModernAdmin", new { id = d.Id })" style="display:inline;">@Html.AntiForgeryToken()
 <button type="submit" class="govuk-button govuk-button--warning govuk-button--small govuk-!-margin-bottom-0" data-confirm="Remove this override?">Delete</button>
                        </form>
                      </td>
                    </tr>
                  }
                </tbody>
              </table>
            </div>
 <details class="govuk-details" style="margin-top:1rem;"><summary class="govuk-details__summary"><span class="govuk-details__summary-text">Add due date override</span></summary><div class="govuk-details__text">
              <form method="post" action="@Url.Action("PerfDueOverrideCreate", "ModernAdmin")">@Html.AntiForgeryToken()
                <div style="display:flex;gap:0.5rem;align-items:end;flex-wrap:wrap;">
 <div><label class="govuk-label govuk-label--s">Year</label><input class="govuk-input govuk-input--width-4" name="reportingYear" type="number" value="@DateTime.UtcNow.Year" required></div>
 <div><label class="govuk-label govuk-label--s">Month</label><input class="govuk-input govuk-input--width-4" name="reportingMonth" type="number" min="1" max="12" required></div>
 <div><label class="govuk-label govuk-label--s">Due date</label><input class="govuk-input govuk-input--width-10" type="date" name="dueDate" required></div>
 <div><label class="govuk-label govuk-label--s">Reason</label><input class="govuk-input govuk-input--width-20" name="reason"></div>
 <button type="submit" class="govuk-button govuk-button--small" style="margin-bottom:0;">Add</button>
                </div>
              </form>
            </div></details>
          </div>
          break;

        @* ════════════ PRODUCT EXCLUSIONS ════════════ *@
        case "product-exclusions":
 <div class="admin-panel">
 <h2 class="govuk-heading-m govuk-!-margin-top-0 govuk-!-margin-bottom-2">Product exclusions</h2>
 <p class="govuk-body govuk-hint govuk-!-margin-bottom-4">Exclude specific products from mandatory performance reporting. Use the FIPS product document ID. End date is optional (leave blank for open-ended).</p>

 <div class="dfe-c-table-wrap">
              <table >
                <thead>
                  <tr>
 <th data-sort-bound="1" class="sortable">Product</th>
 <th data-sort-bound="1" class="sortable">Document ID</th>
 <th data-sort-bound="1" class="sortable">Reason</th>
 <th data-sort-bound="1" class="sortable">From</th>
 <th data-sort-bound="1" class="sortable">Until</th>
 <th data-sort-bound="1" class="sortable">Status</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  @if (Model.ProductExclusions.Count == 0)
                  {
 <tr><td colspan="7"><span class="dfe-c-text-muted">No product exclusions yet. Add one using the form below.</span></td></tr>
                  }
                  @foreach (var p in Model.ProductExclusions)
                  {
                    if (Model.EditId == p.Id)
                    {
                      <tr>
                        <td colspan="7">
                          <form method="post" action="@Url.Action("PerfProductExclusionEdit", "ModernAdmin", new { id = p.Id })" novalidate>
                            @Html.AntiForgeryToken()
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Edit exclusion: <code>@p.ProductDocumentId</code></legend>
 <div class="govuk-grid-row">
 <div class="govuk-grid-column-one-third-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="pe-edit-doc-@p.Id">Document ID</label>
 <span class="govuk-hint">FIPS product document identifier</span>
 <input class="govuk-input govuk-!-width-full" id="pe-edit-doc-@p.Id" name="productDocumentId" type="text" value="@p.ProductDocumentId" required maxlength="100" autocomplete="off" />
                                  </div>
                                </div>
 <div class="govuk-grid-column-two-thirds-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="pe-edit-name-@p.Id">Product name <span class="govuk-hint govuk-!-display-inline">(optional)</span></label>
 <input class="govuk-input govuk-!-width-full" id="pe-edit-name-@p.Id" name="productName" type="text" value="@p.ProductName" maxlength="255" />
                                  </div>
                                </div>
                              </div>
 <div class="govuk-form-group">
 <label class="govuk-label" for="pe-edit-reason-@p.Id">Reason</label>
 <textarea class="govuk-textarea govuk-!-width-full" id="pe-edit-reason-@p.Id" name="exclusionReason" rows="3" required maxlength="1000">@p.ExclusionReason</textarea>
                              </div>
 <div class="govuk-grid-row">
 <div class="govuk-grid-column-one-quarter-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="pe-edit-fy-@p.Id">Effective from year</label>
 <input class="govuk-input govuk-input--width-4" id="pe-edit-fy-@p.Id" name="exclusionFromYear" type="number" min="2000" max="2100" value="@p.ExclusionFromYear" required />
                                  </div>
                                </div>
 <div class="govuk-grid-column-one-quarter-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="pe-edit-fm-@p.Id">Month</label>
 <input class="govuk-input govuk-input--width-4" id="pe-edit-fm-@p.Id" name="exclusionFromMonth" type="number" min="1" max="12" value="@p.ExclusionFromMonth" required />
                                  </div>
                                </div>
 <div class="govuk-grid-column-one-quarter-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="pe-edit-uy-@p.Id">End year <span class="govuk-hint govuk-!-display-inline">(optional)</span></label>
 <input class="govuk-input govuk-input--width-4" id="pe-edit-uy-@p.Id" name="exclusionUntilYear" type="number" min="2000" max="2100" value="@(p.ExclusionUntilYear?.ToString() ?? "")" />
                                  </div>
                                </div>
 <div class="govuk-grid-column-one-quarter-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="pe-edit-um-@p.Id">End month <span class="govuk-hint govuk-!-display-inline">(optional)</span></label>
 <input class="govuk-input govuk-input--width-4" id="pe-edit-um-@p.Id" name="exclusionUntilMonth" type="number" min="1" max="12" value="@(p.ExclusionUntilMonth?.ToString() ?? "")" />
                                  </div>
                                </div>
                              </div>
 <div class="govuk-button-group">
 <button type="submit" class="govuk-button govuk-button--secondary">Save changes</button>
 <a href="@P("product-exclusions")" class="govuk-link govuk-link--no-visited-state">Cancel</a>
                              </div>
                            </fieldset>
                          </form>
                        </td>
                      </tr>
                    }
                    else
                    {
                      <tr>
                        <td><strong>@(p.ProductName ?? "—")</strong></td>
                        <td><code>@p.ProductDocumentId</code></td>
                        <td>@p.ExclusionReason</td>
                        <td>@p.ExclusionFrom</td>
                        <td>@(p.ExclusionUntil ?? "Open-ended")</td>
                        <td>
 @if (p.IsActive) { <span class="dfe-c-tag dfe-c-tag--green">Active</span> }
 else { <span class="dfe-c-tag dfe-c-tag--grey">Inactive</span> }
                        </td>
                        <td style="text-align:right;">
 <div class="govuk-button-group govuk-button-group--inline" style="justify-content:flex-end;flex-wrap:wrap;">
 <a class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" href="@Url.Action("PerformanceReporting", "ModernAdmin", new { panel = "product-exclusions", editId = p.Id })">Edit</a>
 <form method="post" action="@Url.Action("PerfProductExclusionToggle", "ModernAdmin", new { id = p.Id })" style="display:inline;" class="govuk-!-margin-bottom-0">
                              @Html.AntiForgeryToken()
 <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0">@(p.IsActive ? "Deactivate" : "Activate")</button>
                            </form>
 <form method="post" action="@Url.Action("PerfProductExclusionDelete", "ModernAdmin", new { id = p.Id })" style="display:inline;" class="govuk-!-margin-bottom-0">
                              @Html.AntiForgeryToken()
 <button type="submit" class="govuk-button govuk-button--warning govuk-!-margin-bottom-0" data-confirm="Remove this product exclusion? This cannot be undone.">Remove</button>
                            </form>
                          </div>
                        </td>
                      </tr>
                    }
                  }
                </tbody>
              </table>
            </div>

 <div class="dfe-c-card govuk-!-margin-top-6" style="border:1px solid var(--grey-2);border-left:4px solid var(--blue);padding:1.25rem 1.5rem;background:var(--white);">
 <h3 class="govuk-heading-m govuk-!-margin-top-0">Add a product exclusion</h3>
 <p class="govuk-hint govuk-!-margin-bottom-4">The exclusion applies from the first day of the “from” month. Optionally set an end month; leave end fields empty if the exclusion has no fixed end.</p>
              <form method="post" action="@Url.Action("PerfProductExclusionCreate", "ModernAdmin")" novalidate>
                @Html.AntiForgeryToken()
 <div class="govuk-grid-row">
 <div class="govuk-grid-column-one-third-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="pe-new-doc">Document ID</label>
 <span class="govuk-hint">FIPS product document ID</span>
 <input class="govuk-input govuk-!-width-full" id="pe-new-doc" name="productDocumentId" type="text" required maxlength="100" autocomplete="off" />
                    </div>
                  </div>
 <div class="govuk-grid-column-two-thirds-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="pe-new-name">Product name <span class="govuk-hint govuk-!-display-inline">(optional)</span></label>
 <input class="govuk-input govuk-!-width-full" id="pe-new-name" name="productName" type="text" maxlength="255" />
                    </div>
                  </div>
                </div>
 <div class="govuk-form-group">
 <label class="govuk-label" for="pe-new-reason">Reason</label>
 <textarea class="govuk-textarea govuk-!-width-full" id="pe-new-reason" name="exclusionReason" rows="3" required maxlength="1000" placeholder="e.g. Product in discovery, being decommissioned"></textarea>
                </div>
 <div class="govuk-grid-row">
 <div class="govuk-grid-column-one-quarter-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="pe-new-fy">Effective from year</label>
 <input class="govuk-input govuk-input--width-4" id="pe-new-fy" name="exclusionFromYear" type="number" min="2000" max="2100" value="@DateTime.UtcNow.Year" required />
                    </div>
                  </div>
 <div class="govuk-grid-column-one-quarter-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="pe-new-fm">Month</label>
 <input class="govuk-input govuk-input--width-4" id="pe-new-fm" name="exclusionFromMonth" type="number" min="1" max="12" value="@DateTime.UtcNow.Month" required />
                    </div>
                  </div>
 <div class="govuk-grid-column-one-quarter-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="pe-new-uy">End year <span class="govuk-hint govuk-!-display-inline">(optional)</span></label>
 <input class="govuk-input govuk-input--width-4" id="pe-new-uy" name="exclusionUntilYear" type="number" min="2000" max="2100" />
                    </div>
                  </div>
 <div class="govuk-grid-column-one-quarter-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="pe-new-um">End month <span class="govuk-hint govuk-!-display-inline">(optional)</span></label>
 <input class="govuk-input govuk-input--width-4" id="pe-new-um" name="exclusionUntilMonth" type="number" min="1" max="12" />
                    </div>
                  </div>
                </div>
 <button type="submit" class="govuk-button">Create exclusion</button>
              </form>
            </div>
          </div>
          break;

        default:
 <div class="admin-panel"><p class="dfe-c-text-muted">Select a configuration area. <a href="@P("metrics")">Back to Metrics</a>.</p></div>
          break;
      }
    </div>
  </div>
</div>
