@section Scripts {
  @if (string.Equals(Model.Panel, "feature-settings", StringComparison.OrdinalIgnoreCase))
  {
  <script nonce="@(Context.Items["Nonce"] as string)">
    (function () {
      function sync() {
        document.querySelectorAll('[data-feature-allow-box]').forEach(function (box) {
          var id = box.getAttribute('data-feature-allow-box');
          var on = document.getElementById('f-access-' + id + '-some');
          var show = on && on.checked;
          box.classList.toggle('govuk-!-display-none', !show);
          if (box.getAttribute('aria-hidden') != null) box.setAttribute('aria-hidden', show ? 'false' : 'true');
        });
      }
      document.querySelectorAll('input[type="radio"][name*="AccessMode"]').forEach(function (r) { r.addEventListener('change', sync); });
      sync();
    })();
  </script>
  }

  <script nonce="@(Context.Items["Nonce"] as string)">
    document.querySelectorAll('[data-confirm]').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        if (!confirm(btn.getAttribute('data-confirm'))) e.preventDefault();
      });
    });
  </script>
}
