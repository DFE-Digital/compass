@model Compass.ViewModels.Modern.PerfCommissionRow
@{
    ViewData["Title"] = "Create commission";
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin")">Admin</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("PerformanceReporting", "ModernAdmin", new { panel = "commissions" })">Performance reporting</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Create commission</li>
}

<div class="admin-hub">
 <div class="dfe-c-page-title dfe-c-mb-3">
 <div class="dfe-c-page-title__caption">Administration</div>
 <h1 class="dfe-c-page-title__heading">Create commission</h1>
 <p class="dfe-c-page-title__lede"><a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("PerformanceReporting", "ModernAdmin", new { panel = "commissions" })">Back to Commissions</a></p>
  </div>

  @if (ViewBag.PerfError != null)
  {
 <div class="govuk-error-summary" role="alert" data-module="govuk-error-summary" style="margin-bottom:1.5rem;">
 <h2 class="govuk-error-summary__title">There is a problem</h2>
 <div class="govuk-error-summary__body">@ViewBag.PerfError</div>
    </div>
  }

 <div class="dfe-c-card dfe-c-mb-4" style="border:1px solid var(--grey-2);border-left:4px solid var(--blue);padding:1.25rem 1.5rem;background:var(--white);max-width:56rem;">
 <h2 class="govuk-heading-m govuk-!-margin-top-0">Commission period</h2>
 <p class="govuk-hint govuk-!-margin-bottom-4">Reporting periods when products must submit performance data. Set open and due dates so teams know when submission is available and when it closes. New commissions are created <strong>active</strong>; use Edit to deactivate later.</p>
    <form method="post" action="@Url.Action("PerfCommissionCreate", "ModernAdmin")" novalidate>
      @Html.AntiForgeryToken()
 <fieldset class="govuk-fieldset">
 <legend class="govuk-fieldset__legend govuk-fieldset__legend--m govuk-visually-hidden">Commission details</legend>
 <div class="govuk-form-group">
 <label class="govuk-label" for="cc-name">Name</label>
 <div id="cc-name-hint" class="govuk-hint">For example Q1 2026</div>
 <input class="govuk-input govuk-!-width-two-thirds" type="text" name="name" id="cc-name" required maxlength="200" autocomplete="off" value="@Model.Name" aria-describedby="cc-name-hint" />
        </div>
 <div class="govuk-form-group">
 <label class="govuk-label" for="cc-desc">Description <span class="govuk-hint govuk-!-display-inline">(optional)</span></label>
 <textarea class="govuk-textarea govuk-!-width-two-thirds" name="description" id="cc-desc" rows="3" maxlength="1000">@Model.Description</textarea>
        </div>
 <div class="govuk-form-group">
 <label class="govuk-label" for="cc-quarter">Quarter <span class="govuk-hint govuk-!-display-inline">(optional)</span></label>
 <div id="cc-quarter-hint" class="govuk-hint">For example Q1</div>
 <input class="govuk-input govuk-input--width-10" type="text" name="quarter" id="cc-quarter" maxlength="10" value="@Model.Quarter" aria-describedby="cc-quarter-hint" />
        </div>
 <div class="govuk-grid-row">
 <div class="govuk-grid-column-one-half-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="cc-start">Period start</label>
 <input class="govuk-input" type="date" name="startDate" id="cc-start" required value="@Model.StartDate.ToString("yyyy-MM-dd")" />
            </div>
          </div>
 <div class="govuk-grid-column-one-half-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="cc-end">Period end</label>
 <input class="govuk-input" type="date" name="endDate" id="cc-end" required value="@Model.EndDate.ToString("yyyy-MM-dd")" />
            </div>
          </div>
        </div>
 <div class="govuk-grid-row">
 <div class="govuk-grid-column-one-half-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="cc-open">Submission opens</label>
 <input class="govuk-input" type="date" name="openDate" id="cc-open" required value="@Model.OpenDate.ToString("yyyy-MM-dd")" />
            </div>
          </div>
 <div class="govuk-grid-column-one-half-from-desktop">
 <div class="govuk-form-group">
 <label class="govuk-label" for="cc-due">Submission due</label>
 <input class="govuk-input" type="date" name="dueDate" id="cc-due" required value="@Model.DueDate.ToString("yyyy-MM-dd")" />
            </div>
          </div>
        </div>
      </fieldset>
      @{
        ViewBag.CommissionFieldPrefix = "cc";
      }
      @await Html.PartialAsync("~/Views/Modern/Admin/_PerfCommissionScopeAndMetrics.cshtml", Model)
 <div class="govuk-button-group">
 <button type="submit" class="govuk-button" data-module="govuk-button">Create commission</button>
 <a href="@Url.Action("PerformanceReporting", "ModernAdmin", new { panel = "commissions" })" class="govuk-link govuk-link--no-visited-state">Cancel</a>
      </div>
    </form>
  </div>
</div>
