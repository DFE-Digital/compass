@model Compass.ViewModels.Modern.AdminGroupsViewModel
@{
    ViewData["Title"] = "Groups";
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernAdmin")">Admin</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Groups</li>
}

<div class="admin-hub">
 <div class="dfe-c-page-title dfe-c-mb-3">
 <div class="dfe-c-page-title__caption">Administration</div>
 <h1 class="dfe-c-page-title__heading">Groups</h1>
 <p class="dfe-c-page-title__lede">Create groups, assign members, and attach feature permissions for access control.</p>
  </div>

  @if (ViewBag.AdminError != null)
  {
 <div class="govuk-error-summary" role="alert" data-module="govuk-error-summary" style="margin-bottom:1.5rem;">
 <h2 class="govuk-error-summary__title">There is a problem</h2>
 <div class="govuk-error-summary__body">@ViewBag.AdminError</div>
    </div>
  }
  @if (ViewBag.AdminMessage != null)
  {
 <div class="govuk-notification-banner govuk-notification-banner--success dfe-c-mb-3" role="region" aria-labelledby="groups-notif-title">
 <div class="govuk-notification-banner__header">
 <h2 class="govuk-notification-banner__title" id="groups-notif-title">Success</h2>
      </div>
 <div class="govuk-notification-banner__content">
 <p class="govuk-notification-banner__heading">@ViewBag.AdminMessage</p>
      </div>
    </div>
  }

 <div class="dfe-c-flex dfe-c-flex--between dfe-c-mb-2" style="align-items:center;flex-wrap:wrap;gap:0.75rem;">
 <h2 class="govuk-heading-m" style="margin:0;">All groups</h2>
 <a class="govuk-button" href="@Url.Action("GroupCreate", "ModernAdmin")" id="btn-add-group">Add group</a>
  </div>

 <div class="dfe-c-table-wrap">
    <table >
      <thead>
        <tr>
 <th data-sort-bound="1" class="sortable">Name</th>
 <th data-sort-bound="1" class="sortable">Description</th>
 <th data-sort-bound="1" class="sortable">Members</th>
 <th data-sort-bound="1" class="sortable">Features</th>
 <th data-sort-bound="1" class="sortable">Active</th>
 <th data-sort-bound="1" class="sortable">Type</th>
 <th><span class="govuk-visually-hidden">Actions</span></th>
        </tr>
      </thead>
      <tbody>
        @if (Model.Groups.Count == 0)
        {
 <tr><td colspan="7" class="dfe-c-text-muted">No groups yet. Use <strong>Add group</strong> to create one.</td></tr>
        }
        else
        {
          foreach (var row in Model.Groups)
          {
            <tr>
              <td>
 <a href="@Url.Action("GroupDetail", "ModernAdmin", new { id = row.Id })" class="govuk-link govuk-link--no-visited-state"><strong>@row.Name</strong></a>
              </td>
              <td>@(string.IsNullOrEmpty(row.Description) ? "—" : row.Description)</td>
              <td>@row.MemberCount</td>
              <td>@row.FeatureCount</td>
              <td>
 @if (row.IsActive) { <span class="dfe-c-tag dfe-c-tag--green">Yes</span> }
 else { <span class="dfe-c-tag dfe-c-tag--grey">No</span> }
              </td>
              <td>
 @if (row.IsSystemGroup) { <span class="dfe-c-tag dfe-c-tag--blue">System</span> }
 else { <span class="dfe-c-tag dfe-c-tag--grey">Custom</span> }
              </td>
              <td style="text-align:right;white-space:nowrap;">
 <a href="@Url.Action("GroupDetail", "ModernAdmin", new { id = row.Id })" class="govuk-link govuk-link--no-visited-state">Manage</a>
                <span style="margin:0 0.25rem;" aria-hidden="true">·</span>
 <a href="@Url.Action("GroupEdit", "ModernAdmin", new { id = row.Id })" class="govuk-link govuk-link--no-visited-state">Edit</a>
              </td>
            </tr>
          }
        }
      </tbody>
    </table>
  </div>
</div>
