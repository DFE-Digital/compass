@model Compass.ViewModels.Modern.ModernPerformanceCommissionDetailViewModel
@using Compass.Models
@using Compass.ViewModels.Modern
@{
  var c = Model.Commission;
}
<dl class="govuk-summary-list govuk-summary-list--no-border govuk-!-margin-bottom-0">
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Reporting period</dt>
 <dd class="govuk-summary-list__value">
      @CommissionDisplay.FormatPeriod(c.StartDate, c.EndDate)
    </dd>
  </div>
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Due date</dt>
 <dd class="govuk-summary-list__value">@CommissionDisplay.FormatDueDate(c.DueDate)</dd>
  </div>
</dl>
