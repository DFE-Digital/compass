@using Compass.Models
@using Compass.ViewModels.Modern
@model ModernPerformanceCommissionDetailViewModel
@{
  ViewData["Title"] = Model.Commission.Name + " — products";
  var c = Model.Commission;
  var grouped = Model.GroupedProductRows;
  var useGroups = grouped is { Count: > 0 };

  var showBaCol = Model.Tab is "businessarea" or "all" && !(useGroups && Model.Tab == "businessarea");
  var showDirCol = Model.Tab is "directorate" or "all" && !(useGroups && Model.Tab == "directorate");

  var colCount = 2 + (showBaCol ? 1 : 0) + (showDirCol ? 1 : 0) + 2;

  string TabUrl(string t) =>
      Url.Action("Commission", "ModernPerformance", new
      {
          commissionId = c.Id,
          tab = t,
          businessArea = Model.BusinessAreaFilter,
          directorate = Model.DirectorateFilter,
          search = Model.Search
      }) ?? "#";

  string StatusLabel(CommissionSubmissionStatus s) => s switch
  {
    CommissionSubmissionStatus.NotStarted => "Not started",
    CommissionSubmissionStatus.InProgress => "In progress",
    CommissionSubmissionStatus.Submitted => "Submitted",
    CommissionSubmissionStatus.Late => "Late",
    _ => s.ToString()
  };
  string StatusTag(CommissionSubmissionStatus s) => s switch
  {
    CommissionSubmissionStatus.Submitted => "dfe-c-tag--green",
    CommissionSubmissionStatus.Late => "dfe-c-tag--red",
    CommissionSubmissionStatus.InProgress => "dfe-c-tag--amber",
    _ => "dfe-c-tag--grey"
  };
  bool IsSubmittedView(CommissionSubmissionStatus s) =>
    s == CommissionSubmissionStatus.Submitted || s == CommissionSubmissionStatus.Late;

  string ClearFiltersHref() =>
      Url.Action("Commission", "ModernPerformance", new { commissionId = c.Id, tab = Model.Tab }) ?? "#";
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernPerformance")">Performance</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">@c.Name</li>
}

<div class="dfe-c-commission-header dfe-c-mb-4">
 <div class="dfe-c-commission-header__main">
 <div class="dfe-c-page-title" style="margin-bottom:0;">
 <div class="dfe-c-page-title__caption">Commission</div>
 <h1 class="dfe-c-page-title__heading">@c.Name</h1>
    </div>
 <dl class="govuk-summary-list govuk-summary-list--no-border dfe-c-mt-2" style="margin-bottom:0;">
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Reporting period</dt>
 <dd class="govuk-summary-list__value">
          @CommissionDisplay.FormatPeriod(c.StartDate, c.EndDate)
        </dd>
      </div>
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Due date</dt>
 <dd class="govuk-summary-list__value">@CommissionDisplay.FormatDueDate(c.DueDate)</dd>
      </div>
    </dl>
  </div>
 <div class="dfe-c-commission-header__aside">
 <div class="dfe-c-commission-header__badges">
      @if (Model.IsOpenForSubmission)
      {
 <span class="dfe-c-tag dfe-c-tag--green">Open for submission</span>
      }
      else if (Model.IsPastDue)
      {
 <span class="dfe-c-tag dfe-c-tag--grey">Past due (read-only)</span>
      }
      else
      {
 <span class="dfe-c-tag dfe-c-tag--blue">Not open or inactive</span>
      }
    </div>
 <div class="govuk-button-group govuk-!-margin-bottom-0 dfe-c-commission-header__actions">
 <a class="govuk-button govuk-button--secondary" href="@Url.Action("ExportExcel", "ModernPerformance", new { commissionId = c.Id, tab = Model.Tab })">Download Excel</a>
 <a class="govuk-button govuk-button--secondary" href="@Url.Action("BulkUpload", "ModernPerformance", new { commissionId = c.Id, tab = Model.Tab })">Bulk upload</a>
    </div>
  </div>
</div>

@if (TempData["ErrorMessage"] != null)
{
 <div class="govuk-error-summary dfe-c-mb-3" role="alert"><p class="govuk-body">@TempData["ErrorMessage"]</p></div>
}
@if (TempData["SuccessMessage"] != null)
{
 <div class="govuk-notification-banner govuk-notification-banner--success dfe-c-mb-3" role="region">
 <div class="govuk-notification-banner__content"><p class="govuk-body">@TempData["SuccessMessage"]</p></div>
  </div>
}

<div class="tabs" role="tablist" aria-label="Product scope">
 <a href="@TabUrl("mine")" class="tab @(Model.Tab =="mine" ? "on" : "")" role="tab" aria-selected="@(Model.Tab == "mine")" aria-controls="d-scope" id="tab-mine">My products</a>
 <a href="@TabUrl("businessarea")" class="tab @(Model.Tab =="businessarea" ? "on" : "")" role="tab" aria-selected="@(Model.Tab == "businessarea")" aria-controls="d-scope" id="tab-ba">Business area</a>
 <a href="@TabUrl("directorate")" class="tab @(Model.Tab =="directorate" ? "on" : "")" role="tab" aria-selected="@(Model.Tab == "directorate")" aria-controls="d-scope" id="tab-dir">Directorate</a>
 <a href="@TabUrl("all")" class="tab @(Model.Tab =="all" ? "on" : "")" role="tab" aria-selected="@(Model.Tab == "all")" aria-controls="d-scope" id="tab-all">All products</a>
</div>

<form method="get" action="@Url.Action("Commission", "ModernPerformance", new { commissionId = c.Id })" class="filter-toolbar govuk-!-margin-bottom-3">
 <input type="hidden" name="tab" value="@Model.Tab" />
 <div class="filter-toolbar__search-wrap">
 <label for="perf-commission-search" class="govuk-visually-hidden">Search products</label>
 <input type="search" name="search" id="perf-commission-search" value="@Model.Search" placeholder="Search title, FIPS id or document id…" class="filter-search" autocomplete="off" aria-label="Search products" />
 <button type="submit" class="govuk-button govuk-button--secondary filter-toolbar__search-submit">Search</button>
 </div>
 <details class="filter-toolbar__details">
 <summary class="filter-toggle-btn filter-toolbar__filter-summary" aria-controls="perf-commission-filters">
 <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="flex-shrink:0;" aria-hidden="true"><path d="M1 3h14v1.5l-5 5V14l-4-2V9.5L1 4.5V3z"></path></svg>
 <span class="filter-toggle-label">Filter</span>
 </summary>
 <div class="filter-panel" id="perf-commission-filters">
 <div class="filter-panel__grid">
 <div>
 <label for="perf-filter-ba">Business area</label>
 <select name="businessArea" id="perf-filter-ba" class="govuk-select">
 <option value="">All</option>
 @foreach (var opt in Model.BusinessAreaOptions)
 {
   var sel = string.Equals(Model.BusinessAreaFilter, opt, StringComparison.OrdinalIgnoreCase);
   if (sel)
   {
 <option value="@opt" selected>@opt</option>
   }
   else
   {
 <option value="@opt">@opt</option>
   }
 }
 </select>
 </div>
 <div>
 <label for="perf-filter-dir">Directorate</label>
 <select name="directorate" id="perf-filter-dir" class="govuk-select">
 <option value="">All</option>
 @foreach (var opt in Model.DirectorateOptions)
 {
   var sel = string.Equals(Model.DirectorateFilter, opt, StringComparison.OrdinalIgnoreCase);
   if (sel)
   {
 <option value="@opt" selected>@opt</option>
   }
   else
   {
 <option value="@opt">@opt</option>
   }
 }
 </select>
 </div>
 </div>
 <div class="filter-panel__actions govuk-!-margin-top-3">
 <button type="submit" class="govuk-button">Apply filters</button>
 <a class="govuk-link govuk-!-margin-left-3" href="@ClearFiltersHref()">Clear filters</a>
 </div>
 </div>
 </details>
</form>

@if (Model.ScopeProductCount > 0 && Model.Rows.Count < Model.ScopeProductCount)
{
<p class="dfe-c-body-s dfe-c-text-muted govuk-!-margin-bottom-2">Showing <strong>@Model.Rows.Count</strong> of <strong>@Model.ScopeProductCount</strong> products in this tab (filters applied).</p>
}

<div id="d-scope" class="tab-pane on" role="tabpanel">
 <div class="dfe-c-table-wrap dfe-c-mt-2">
    <table>
      <thead>
        <tr>
          <th scope="col">Product</th>
          <th scope="col">Phase</th>
          @if (showBaCol)
          {
            <th scope="col">Business area</th>
          }
          @if (showDirCol)
          {
            <th scope="col">Directorate</th>
          }
          <th scope="col">Status</th>
          <th scope="col">Actions</th>
        </tr>
      </thead>
      @if (Model.ScopeProductCount == 0)
      {
 <tbody>
 <tr><td colspan="@colCount" class="dfe-c-body muted">No products in this scope for this commission (check phase/type rules and active published products).</td></tr>
 </tbody>
      }
      else if (Model.Rows.Count == 0)
      {
 <tbody>
 <tr><td colspan="@colCount" class="dfe-c-body muted">No products match your search or filters.</td></tr>
 </tbody>
      }
      else if (useGroups && grouped != null)
      {
        foreach (var sec in grouped)
        {
 <tbody class="perf-commission-group">
 <tr class="perf-commission-group__banner">
 <th colspan="@colCount" scope="colgroup" class="perf-commission-group__heading">@sec.GroupHeading</th>
 </tr>
 @foreach (var r in sec.Rows)
 {
          var doc = r.Product.DocumentId ?? "";
          var ba = CommissionReportingProductScope.GetBusinessArea(r.Product);
          var dir = CommissionReportingProductScope.GetDirectorate(r.Product);
          <tr>
            <td>@r.Product.Title</td>
            <td>@r.Product.Phase</td>
            @if (showBaCol)
            {
              <td>@(ba ?? "—")</td>
            }
            @if (showDirCol)
            {
              <td>@(dir ?? "—")</td>
            }
 <td><span class="dfe-c-tag @StatusTag(r.Status)">@StatusLabel(r.Status)</span></td>
            <td>
              @if (!string.IsNullOrEmpty(doc))
              {
                if (IsSubmittedView(r.Status))
                {
 <a class="govuk-link" href="@Url.Action("Submission", "ModernPerformance", new { commissionId = c.Id, documentId = doc, returnTab = Model.Tab })">View submission</a>
                }
                else
                {
 <a class="govuk-link" href="@Url.Action("CommissionSubmit", "ModernPerformance", new { commissionId = c.Id, documentId = doc, returnTab = Model.Tab })">Enter metrics</a>
                }
              }
            </td>
          </tr>
 }
 </tbody>
        }
      }
      else
      {
 <tbody>
        @foreach (var r in Model.Rows)
        {
          var doc = r.Product.DocumentId ?? "";
          var ba = CommissionReportingProductScope.GetBusinessArea(r.Product);
          var dir = CommissionReportingProductScope.GetDirectorate(r.Product);
          <tr>
            <td>@r.Product.Title</td>
            <td>@r.Product.Phase</td>
            @if (showBaCol)
            {
              <td>@(ba ?? "—")</td>
            }
            @if (showDirCol)
            {
              <td>@(dir ?? "—")</td>
            }
 <td><span class="dfe-c-tag @StatusTag(r.Status)">@StatusLabel(r.Status)</span></td>
            <td>
              @if (!string.IsNullOrEmpty(doc))
              {
                if (IsSubmittedView(r.Status))
                {
 <a class="govuk-link" href="@Url.Action("Submission", "ModernPerformance", new { commissionId = c.Id, documentId = doc, returnTab = Model.Tab })">View submission</a>
                }
                else
                {
 <a class="govuk-link" href="@Url.Action("CommissionSubmit", "ModernPerformance", new { commissionId = c.Id, documentId = doc, returnTab = Model.Tab })">Enter metrics</a>
                }
              }
            </td>
          </tr>
        }
 </tbody>
      }
    </table>
  </div>
</div>

<style>
  .perf-commission-group__banner th {
    background: #f3f2f1;
    font-weight: 700;
    font-size: 1rem;
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 2px solid #b1b4b6;
  }
  .perf-commission-group tr:not(.perf-commission-group__banner) td {
    vertical-align: top;
  }
</style>
