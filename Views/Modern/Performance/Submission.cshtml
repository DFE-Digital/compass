@model ModernPerformanceSubmissionViewModel
@using Compass.Models
@using Compass.ViewModels.Modern
@{
  ViewData["Title"] = "Submission — " + Model.Product.Title;
  var c = Model.Commission;
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernPerformance")">Performance</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Commission", "ModernPerformance", new { commissionId = c.Id, tab = Model.ReturnTab })">@c.Name</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Submission</li>
}

@{
  var submissionHeaderLede = await Html.PartialAsync("_PerformanceSubmissionHeaderLede", Model);
}
@await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
  BackLinkHref = Url.Action("Commission", "ModernPerformance", new { commissionId = c.Id, tab = Model.ReturnTab }),
  BackLinkText = "Back to commission",
  Caption = "Commission submission",
  Title = Model.Product.Title,
  Lede = submissionHeaderLede
})

@await Html.PartialAsync("_PerformanceCommissionScopeSubNav", new PerformanceCommissionScopeNavViewModel {
  CommissionId = c.Id,
  Tab = Model.ReturnTab
})

<h2 class="govuk-heading-m govuk-!-margin-top-6">Metrics</h2>
@if (Model.MetricRows.Count == 0)
{
 <p class="govuk-body">No applicable metrics are recorded for this product in this commission.</p>
}
else
{
 <div class="dfe-f-table-wrapper govuk-!-margin-bottom-6" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
    <table class="govuk-table govuk-table--small-text-until-tablet govuk-!-margin-bottom-0">
      <caption class="govuk-table__caption govuk-visually-hidden">Metrics returned for this submission</caption>
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Metric</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Value</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Status</button>
        </th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
      @foreach (var row in Model.MetricRows)
      {
        <tr class="govuk-table__row">
          <td class="govuk-table__cell">
            <span class="govuk-!-font-weight-bold">@row.Title</span>
            @if (!string.IsNullOrWhiteSpace(row.Identifier))
            {
 <div class="govuk-body-s dfe-c-text-muted govuk-!-margin-top-1">@row.Identifier</div>
            }
            @if (!string.IsNullOrWhiteSpace(row.Description))
            {
 <div class="govuk-body-s dfe-c-text-muted govuk-!-margin-top-1">@row.Description</div>
            }
          </td>
 <td class="govuk-table__cell">
            @row.ValueDisplay
            @if (row.IsNotCaptured && !string.IsNullOrWhiteSpace(row.NotCapturedReason))
            {
 <div class="govuk-body-s dfe-c-text-muted govuk-!-margin-top-1">@row.NotCapturedReason</div>
            }
            @if (!string.IsNullOrWhiteSpace(row.ReasonForDifference))
            {
 <div class="govuk-body-s govuk-!-margin-top-1"><strong>Reason for difference:</strong> @row.ReasonForDifference</div>
            }
          </td>
          <td class="govuk-table__cell">
            @if (row.IsComplete)
            {
 <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--green">Complete</span>
            }
            else
            {
 <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--grey">Pending</span>
            }
          </td>
        </tr>
      }
      </tbody>
    </table>
  </div>
}

<h2 class="govuk-heading-m">Comments or notes</h2>
@if (string.IsNullOrWhiteSpace(Model.Submission.Comments))
{
 <p class="govuk-body dfe-c-text-muted">No comments provided.</p>
}
else
{
 <div class="govuk-inset-text govuk-!-margin-top-2" style="white-space: pre-wrap;">@Model.Submission.Comments</div>
}
