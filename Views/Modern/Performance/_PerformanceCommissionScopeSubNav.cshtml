@model Compass.ViewModels.Modern.PerformanceCommissionScopeNavViewModel
@{
  string TabUrl(string t) =>
      Url.Action("Commission", "ModernPerformance", new
      {
          commissionId = Model.CommissionId,
          tab = t,
          businessArea = string.IsNullOrWhiteSpace(Model.BusinessArea) ? null : Model.BusinessArea,
          directorate = string.IsNullOrWhiteSpace(Model.Directorate) ? null : Model.Directorate,
          search = string.IsNullOrWhiteSpace(Model.Search) ? null : Model.Search
      }) ?? "#";

  var tab = (Model.Tab ?? "mine").Trim().ToLowerInvariant();
  if (tab is not ("mine" or "businessarea" or "directorate" or "all"))
  {
    tab = "mine";
  }
}
<nav class="dfe-f-sub-navigation perf-commission-scope-nav" aria-label="Product scope">
  <ul class="dfe-f-sub-navigation__list" style="flex-wrap:wrap;">
    <li class="dfe-f-sub-navigation__item@(tab == "mine" ? " dfe-f-sub-navigation__item--active" : "")">
      <a href="@TabUrl("mine")" class="dfe-f-sub-navigation__link govuk-link" id="perf-commission-tab-mine"@if (tab == "mine") { <text> aria-current="page"</text> }>My products</a>
    </li>
    <li class="dfe-f-sub-navigation__item@(tab == "businessarea" ? " dfe-f-sub-navigation__item--active" : "")">
      <a href="@TabUrl("businessarea")" class="dfe-f-sub-navigation__link govuk-link" id="perf-commission-tab-ba"@if (tab == "businessarea") { <text> aria-current="page"</text> }>Business area</a>
    </li>
    <li class="dfe-f-sub-navigation__item@(tab == "directorate" ? " dfe-f-sub-navigation__item--active" : "")">
      <a href="@TabUrl("directorate")" class="dfe-f-sub-navigation__link govuk-link" id="perf-commission-tab-dir"@if (tab == "directorate") { <text> aria-current="page"</text> }>Directorate</a>
    </li>
    <li class="dfe-f-sub-navigation__item@(tab == "all" ? " dfe-f-sub-navigation__item--active" : "")">
      <a href="@TabUrl("all")" class="dfe-f-sub-navigation__link govuk-link" id="perf-commission-tab-all"@if (tab == "all") { <text> aria-current="page"</text> }>All products</a>
    </li>
  </ul>
</nav>
