@model Compass.ViewModels.Modern.RaidEditorGuidanceAsideVm
@{
  var isRisk = string.Equals(Model.Mode, "risk", StringComparison.OrdinalIgnoreCase);
}
<div class="dfe-c-sidebar">
  @if (isRisk)
  {
    <div class="dfe-c-scard govuk-!-margin-bottom-4" id="raid-risk-score-panel">
      <div class="dfe-c-scard__title">Inherent risk score</div>
      <p class="govuk-body-s govuk-!-margin-bottom-2" style="font-size:0.8125rem;color:var(--grey-4);">
        Uses admin matrix weights for likelihood and impact (1–5 each). Score = likelihood × impact (max 25).
      </p>
      <p class="govuk-body govuk-!-margin-bottom-1" id="raid-score-breakdown" aria-live="polite">Select likelihood and impact to calculate.</p>
      <p class="govuk-body govuk-!-font-weight-bold govuk-!-font-size-48 govuk-!-margin-bottom-0" id="raid-score-product">—</p>
    </div>
    <script type="application/json" id="raid-matrix-json-data">@Html.Raw(Model.MatrixScoresJson ?? "{\"likelihood\":{},\"impact\":{}}")</script>
  }

  <div class="dfe-c-scard">
    <div class="dfe-c-scard__title" id="raid-guidance-heading">@(isRisk ? "How to write a strong risk" : "How to write a strong issue")</div>
    <div id="raid-field-guidance-body" class="govuk-body-s" style="font-size:0.8125rem;color:var(--grey-4);">
      @if (isRisk)
      {
        <p class="govuk-!-margin-bottom-2">Focus a field in the form to see specific guidance for that part of the risk record.</p>
      }
      else
      {
        <p class="govuk-!-margin-bottom-2">Focus a field in the form to see specific guidance for that part of the issue record.</p>
      }
    </div>
  </div>
</div>

<script>
(function () {
  var IS_RISK = @(isRisk ? "true" : "false");
  var rootId = IS_RISK ? 'sc-raid-risk-editor' : 'sc-raid-issue-editor';
  var root = document.getElementById(rootId);
  if (!root) return;

  var guideBody = document.getElementById('raid-field-guidance-body');
  var headingEl = document.getElementById('raid-guidance-heading');

  var riskGuide = {
    intro: '<p class="govuk-!-margin-bottom-2">Focus a field in the form to see specific guidance for that part of the risk record.</p>',
    association: '<p class="govuk-!-margin-bottom-2"><strong>Associated with</strong> — Link this risk to a delivery work item, a live FIPS product, or organisation-wide scope when it is not tied to one product or project.</p>',
    title: '<p class="govuk-!-margin-bottom-2"><strong>Title</strong> — Short, clear statement of the uncertain event (what might go wrong).</p>',
    description: '<p class="govuk-!-margin-bottom-2"><strong>Description</strong> — Use: there is a risk that… caused by… which may result in… Include causes, consequences, and dependencies.</p>',
    tier: '<p class="govuk-!-margin-bottom-2"><strong>Tier</strong> — Governance or portfolio significance; use your organisation’s tier definitions consistently.</p>',
    status: '<p class="govuk-!-margin-bottom-2"><strong>Status</strong> — Lifecycle in the RAID register (e.g. proposed, open, monitoring, closed).</p>',
    priority: '<p class="govuk-!-margin-bottom-2"><strong>Priority</strong> — Relative urgency versus other risks, not the same as inherent score.</p>',
    likelihood: '<p class="govuk-!-margin-bottom-2"><strong>Likelihood</strong> — Estimated chance of the risk materialising. Matrix weights are set in Admin → RAID → Risk likelihoods.</p>',
    impact: '<p class="govuk-!-margin-bottom-2"><strong>Impact level</strong> — Severity if the risk occurs. Matrix weights are set in Admin → RAID → Risk impact levels.</p>',
    proximity: '<p class="govuk-!-margin-bottom-2"><strong>Proximity</strong> — How soon effects might be felt if the risk occurs.</p>',
    treatment: '<p class="govuk-!-margin-bottom-2"><strong>Treatment</strong> — Choose the primary strategy (avoid, mitigate, accept, fallback, transfer, share, exploit).</p>',
    categories: '<p class="govuk-!-margin-bottom-2"><strong>Categories</strong> — Select every theme that applies; risks often span more than one category.</p>',
    owner: '<p class="govuk-!-margin-bottom-2"><strong>Owner</strong> — Person accountable for managing and reporting this risk.</p>',
    sro: '<p class="govuk-!-margin-bottom-2"><strong>SRO</strong> — Senior responsible officer for oversight and escalation decisions.</p>',
    identified: '<p class="govuk-!-margin-bottom-2"><strong>Identified date</strong> — When the risk was first recorded; defaults to today on create if left blank.</p>',
    nextReview: '<p class="govuk-!-margin-bottom-2"><strong>Next review</strong> — When to reassess likelihood, impact, and mitigations.</p>',
    mitigation: '<p class="govuk-!-margin-bottom-2"><strong>Mitigation / response</strong> — Actions, controls, owners, and residual risk considerations.</p>'
  };

  var issueGuide = {
    intro: '<p class="govuk-!-margin-bottom-2">Focus a field in the form to see specific guidance for that part of the issue record.</p>',
    association: '<p class="govuk-!-margin-bottom-2"><strong>Associated with</strong> — Scope the issue to work, a product, or organisation-wide impact.</p>',
    title: '<p class="govuk-!-margin-bottom-2"><strong>Title</strong> — State what is wrong and the immediate effect on users or delivery.</p>',
    description: '<p class="govuk-!-margin-bottom-2"><strong>Description</strong> — What happened, root cause if known, and operational consequence.</p>',
    status: '<p class="govuk-!-margin-bottom-2"><strong>Status</strong> — Where the issue sits in your workflow (open, in progress, resolved, etc.).</p>',
    severity: '<p class="govuk-!-margin-bottom-2"><strong>Severity</strong> — Impact if the issue remains unresolved.</p>',
    priority: '<p class="govuk-!-margin-bottom-2"><strong>Priority</strong> — Scheduling importance relative to other issues.</p>',
    categories: '<p class="govuk-!-margin-bottom-2"><strong>Categories</strong> — Select all relevant themes.</p>',
    owner: '<p class="govuk-!-margin-bottom-2"><strong>Owner</strong> — Person driving the fix.</p>',
    sro: '<p class="govuk-!-margin-bottom-2"><strong>SRO</strong> — Senior responsible officer for escalation.</p>',
    targetResolution: '<p class="govuk-!-margin-bottom-2"><strong>Target resolution</strong> — Aim date to clear or contain the issue.</p>',
    workaround: '<p class="govuk-!-margin-bottom-2"><strong>Workaround / mitigation</strong> — Temporary measures or permanent fix outline.</p>'
  };

  function pickGuide() {
    return IS_RISK ? riskGuide : issueGuide;
  }

  function setGuide(key) {
    if (!guideBody) return;
    var G = pickGuide();
    guideBody.innerHTML = G[key] || G.intro;
    if (headingEl) {
      headingEl.textContent = (key === 'intro' || !G[key])
        ? (IS_RISK ? 'How to write a strong risk' : 'How to write a strong issue')
        : 'Guidance';
    }
  }

  root.addEventListener('focusin', function (e) {
    var z = e.target && e.target.closest ? e.target.closest('[data-raid-field]') : null;
    if (!z) return;
    var k = z.getAttribute('data-raid-field');
    if (k) setGuide(k);
  });

  setGuide('intro');

  if (IS_RISK) {
    var scoreBreakdown = document.getElementById('raid-score-breakdown');
    var scoreProduct = document.getElementById('raid-score-product');
    var jsonEl = document.getElementById('raid-matrix-json-data');
    var matrix = null;
    try {
      matrix = jsonEl ? JSON.parse((jsonEl.textContent || '').trim() || '{}') : null;
    } catch (err) { matrix = null; }

    function coerceNumeric(v) {
      if (v === null || v === undefined || v === '') return null;
      if (typeof v === 'number' && Number.isFinite(v)) return v;
      var n = Number(v);
      return Number.isFinite(n) ? n : null;
    }

    function matrixVal(axis, id) {
      if (!matrix || !id) return null;
      var d = matrix[axis];
      if (!d || typeof d !== 'object') return null;
      var sid = String(id);
      var v = d[id];
      if (v === undefined) v = d[sid];
      if (v === undefined && /^\d+$/.test(sid)) v = d[Number(sid)];
      return coerceNumeric(v);
    }

    /** Prefer data-raid-matrix on the checked radio (matches server display); fall back to JSON map. */
    function axisWeight(inputEl, axis) {
      if (!inputEl || !inputEl.value) return null;
      var raw = inputEl.getAttribute('data-raid-matrix');
      if (raw !== null && String(raw).trim() !== '') {
        var n = coerceNumeric(raw);
        if (n !== null) return n;
      }
      var mapped = matrixVal(axis, inputEl.value);
      if (mapped !== null) return mapped;

      // Safety fallback: if matrix metadata is missing, infer score from radio order.
      var name = axis === 'likelihood' ? 'RiskLikelihoodId' : 'RiskImpactLevelId';
      var radios = root.querySelectorAll('input[name="' + name + '"]');
      if (!radios || !radios.length) return null;
      var idx = Array.prototype.indexOf.call(radios, inputEl);
      if (idx < 0) return null;
      return radios.length - idx;
    }

    function refreshScore() {
      if (!scoreBreakdown || !scoreProduct) return;
      var lr = root.querySelector('input[name="RiskLikelihoodId"]:checked');
      var ir = root.querySelector('input[name="RiskImpactLevelId"]:checked');
      var ls = axisWeight(lr, 'likelihood');
      var ims = axisWeight(ir, 'impact');
      if (ls != null && ims != null) {
        var prod = ls * ims;
        scoreBreakdown.textContent = 'Likelihood score ' + ls + ' × Impact score ' + ims + ' =';
        scoreProduct.textContent = String(prod);
      } else if (ls != null) {
        scoreBreakdown.textContent = 'Likelihood score ' + ls + '. Select impact to calculate.';
        scoreProduct.textContent = '—';
      } else if (ims != null) {
        scoreBreakdown.textContent = 'Impact score ' + ims + '. Select likelihood to calculate.';
        scoreProduct.textContent = '—';
      } else {
        scoreBreakdown.textContent = 'Select likelihood and impact to calculate.';
        scoreProduct.textContent = '—';
      }
    }

    function onLikelihoodImpactChange(e) {
      var t = e.target;
      if (!t || !t.name) return;
      if (t.name === 'RiskLikelihoodId' || t.name === 'RiskImpactLevelId') refreshScore();
    }

    root.addEventListener('change', onLikelihoodImpactChange);
    root.addEventListener('input', onLikelihoodImpactChange);
    root.addEventListener('click', onLikelihoodImpactChange);

    refreshScore();
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', refreshScore);
    }
    window.addEventListener('load', refreshScore);
    setTimeout(refreshScore, 0);
    setTimeout(refreshScore, 250);
  }
})();
</script>
