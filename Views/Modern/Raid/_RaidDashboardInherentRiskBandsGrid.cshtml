@model (IReadOnlyList<Compass.ViewModels.Modern.ModernRaidLabelCountVm> Bands, string DefaultRegisterUrl)
<div class="dfe-f-card-grid">
  @foreach (var band in Model.Bands)
  {
    @await Html.PartialAsync("~/Views/Modern/Raid/_RaidDashboardStatCard.cshtml", new Compass.ViewModels.Modern.RaidDashboardStatCardVm {
      Label = band.Label,
      Value = band.Count.ToString("N0"),
      Href = band.DrillUrl ?? Model.DefaultRegisterUrl,
      AriaLabel = $"{band.Label}: {band.Count} open risks"
    })
  }
</div>
