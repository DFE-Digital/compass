@section Scripts {
<script nonce="@Context.Items["Nonce"]">
(function () {
  function parseJson(id) {
    var el = document.getElementById(id);
    if (!el || !el.textContent) return [];
    try { return JSON.parse(el.textContent); } catch (e) { return []; }
  }
  var risks = parseJson("raid-ba-risk-modal-json");
  var issues = parseJson("raid-ba-issue-modal-json");
  var dlg = document.getElementById("raid-ba-item-dialog");
  if (!dlg) return;
  var titleEl = document.getElementById("raid-ba-dialog-title");
  var refEl = document.getElementById("raid-ba-dialog-ref");
  var summaryEl = document.getElementById("raid-ba-dialog-summary");
  var editEl = document.getElementById("raid-ba-dialog-edit");
  var detailEl = document.getElementById("raid-ba-dialog-detail");
  var closeBtn = document.getElementById("raid-ba-dialog-close");

  function findItem(kind, id) {
    var list = kind === "risk" ? risks : issues;
    for (var i = 0; i < list.length; i++) {
      if (list[i].id === id) return list[i];
    }
    return null;
  }

  function openModal(kind, id) {
    var item = findItem(kind, id);
    if (!item) return;
    titleEl.textContent = item.title || "—";
    refEl.textContent = item.reference || "";
    summaryEl.textContent = (item.summary && item.summary.length) ? item.summary : "No description recorded.";
    editEl.setAttribute("href", item.editUrl || "#");
    detailEl.setAttribute("href", item.detailUrl || "#");
    if (typeof dlg.showModal === "function") dlg.showModal();
    else window.location.href = item.detailUrl || "#";
  }

  document.querySelectorAll(".raid-ba-modal-open").forEach(function (btn) {
    btn.addEventListener("click", function () {
      var kind = btn.getAttribute("data-kind");
      var id = parseInt(btn.getAttribute("data-id"), 10);
      if (!kind || isNaN(id)) return;
      openModal(kind, id);
    });
  });

  if (closeBtn) {
    closeBtn.addEventListener("click", function () {
      if (typeof dlg.close === "function") dlg.close();
    });
  }
})();
</script>
}
