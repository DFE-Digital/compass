@model Compass.Models.BusinessAreaLookup
@{
  ViewData["Title"] = "Business area — " + Model.Name;
  var workItemCount = ViewBag.BusinessAreaWorkItemCount as int? ?? 0;
  var riskCount = ViewBag.BusinessAreaRiskCount as int? ?? 0;
  var openRiskCount = ViewBag.BusinessAreaOpenRiskCount as int? ?? 0;
}

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernRaid")">RAID</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("BusinessAreas", "ModernRaid")">Business areas</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">@Model.Name</li>
}

<div class="dfe-c-page modern-work-page">
  <div class="dfe-c-flex--between dfe-c-mb-3" style="flex-wrap:wrap;gap:0.75rem;">
    <div class="dfe-c-page-title" style="margin:0;">
      <div class="dfe-c-page-title__caption">RAID · Business area #@Model.Id</div>
      <h1 class="dfe-c-page-title__heading">@Model.Name</h1>
      <p class="dfe-c-page-title__lede">Business area-level risk profile for linked work items.</p>
    </div>
    <div class="dfe-c-flex" style="gap:0.5rem;">
      <a href="@Url.Action("BusinessAreas", "ModernRaid", new { businessAreaId = Model.Id })" class="govuk-button">Risks for this business area</a>
      <a href="@Url.Action("Index", "ModernAdmin", new { panel = "business-areas" })" class="govuk-button govuk-button--secondary">Manage in settings</a>
      <a href="@Url.Action("BusinessAreas", "ModernRaid")" class="govuk-button govuk-button--secondary">All business areas</a>
    </div>
  </div>

  <div class="dfe-c-grid" style="grid-template-columns:repeat(3,minmax(0,1fr));margin-bottom:1rem;">
    <div class="dfe-c-card"><div class="dfe-c-page-title__caption">Linked work items</div><strong>@workItemCount</strong></div>
    <div class="dfe-c-card"><div class="dfe-c-page-title__caption">Total risks</div><strong>@riskCount</strong></div>
    <div class="dfe-c-card"><div class="dfe-c-page-title__caption">Open risks</div><strong>@openRiskCount</strong></div>
  </div>

  <dl class="govuk-summary-list govuk-!-margin-bottom-9">
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Description</dt>
      <dd class="govuk-summary-list__value govuk-body">@(string.IsNullOrEmpty(Model.Description) ? "—" : Model.Description)</dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Sort order</dt>
      <dd class="govuk-summary-list__value">@Model.SortOrder</dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Active</dt>
      <dd class="govuk-summary-list__value">@(Model.IsActive ? "Yes" : "No")</dd>
    </div>
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Updated</dt>
      <dd class="govuk-summary-list__value">@Model.UpdatedAt.ToString("d MMM yyyy HH:mm") UTC</dd>
    </div>
  </dl>
</div>
