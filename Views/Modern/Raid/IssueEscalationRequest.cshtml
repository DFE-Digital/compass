@model Compass.ViewModels.Modern.ModernRaidEscalationRequestViewModel
@using Compass.ViewModels.Modern
@using Microsoft.AspNetCore.Html
@{
  ViewData["Title"] = "Issue escalation request";
}

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernRaid")">RAID</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("IssueDetail", "ModernRaid", new { id = Model.RecordId })">@Model.Reference</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">Escalation request</li>
}

<div class="dfe-c-page modern-work-page">
  @await Html.PartialAsync("~/Views/Modern/Shared/_ModernPageHeader.cshtml", new ModernPageHeaderViewModel {
    Caption = "Issues · " + Model.Reference,
    Title = "Request escalation or de-escalation",
    Lede = new HtmlString($"<p class=\"govuk-body govuk-!-margin-bottom-0\">{Html.Encode(Model.Title)}</p>")
  })

  <div class="dfe-f-card-grid govuk-!-margin-bottom-3" role="region" aria-label="Current issue at a glance">
    <div class="dfe-f-stat-card dfe-f-stat-card--tint-blue">
      <p class="govuk-body-s dfe-f-stat-card__label">Size</p>
      <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@Model.CurrentRatingLabel</p>
    </div>
    <div class="dfe-f-stat-card dfe-f-stat-card--tint-teal">
      <p class="govuk-body-s dfe-f-stat-card__label">Current tier</p>
      <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@Model.CurrentTierLabel</p>
    </div>
    <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
      <p class="govuk-body-s dfe-f-stat-card__label">Status</p>
      <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@Model.CurrentStatusLabel</p>
    </div>
  </div>

  <form method="post" action="@Url.Action("IssueEscalationRequestPost", "ModernRaid", new { id = Model.RecordId })" class="dfe-c-card dfe-c-card--plain">
    @Html.AntiForgeryToken()
    <div class="govuk-form-group">
      <fieldset class="govuk-fieldset">
        <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">What are you requesting?</legend>
        <div class="govuk-radios">
          <div class="govuk-radios__item"><input class="govuk-radios__input" id="issueRequestEsc" name="requestType" type="radio" value="escalate" checked><label class="govuk-label govuk-radios__label" for="issueRequestEsc">Escalate</label></div>
          <div class="govuk-radios__item"><input class="govuk-radios__input" id="issueRequestDe" name="requestType" type="radio" value="de-escalate"><label class="govuk-label govuk-radios__label" for="issueRequestDe">De-escalate</label></div>
          <div class="govuk-radios__item"><input class="govuk-radios__input" id="issueRequestClose" name="requestType" type="radio" value="close"><label class="govuk-label govuk-radios__label" for="issueRequestClose">Propose closure</label></div>
        </div>
      </fieldset>
    </div>
    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--m" for="newState">New tier / status</label>
      <input class="govuk-input" id="newState" name="newState" type="text" />
    </div>
    <div class="govuk-form-group">
      <label class="govuk-label govuk-label--m" for="rationale">Reason for change</label>
      <textarea class="govuk-textarea" id="rationale" name="rationale" rows="6"></textarea>
    </div>
    <div class="dfe-c-button-group">
      <button class="govuk-button" type="submit">Submit request</button>
      <a class="govuk-button govuk-button--secondary" href="@Url.Action("IssueDetail", "ModernRaid", new { id = Model.RecordId })">Cancel</a>
    </div>
  </form>
</div>
