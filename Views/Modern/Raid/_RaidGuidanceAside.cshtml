@model string

<div class="dfe-c-sidebar">
  @switch (Model)
  {
    case "risk":
      <div class="dfe-c-scard">
        <div class="dfe-c-scard__title">How to write a strong risk</div>
        <div style="font-size:0.8125rem;color:var(--grey-4);">
          <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-0">
            <li><strong>Title</strong> — concise event statement; keep it specific.</li>
            <li><strong>Description</strong> — use "There is a risk that... caused by... which may result in...".</li>
            <li><strong>Tier</strong> — overall significance of the risk in the portfolio.</li>
            <li><strong>Status</strong> — lifecycle state (for example New, Open, Closed).</li>
            <li><strong>Priority</strong> — how urgently the risk needs attention relative to others.</li>
            <li><strong>Likelihood</strong> — estimated chance of the risk materialising.</li>
            <li><strong>Impact level</strong> — severity if the risk occurs.</li>
            <li><strong>Proximity</strong> — how soon the risk may affect delivery.</li>
            <li><strong>Category</strong> — you can select more than one theme the risk relates to.</li>
            <li><strong>Owner / SRO</strong> — delivery owner and senior responsible officer.</li>
          </ul>
        </div>
      </div>
      break;
    case "issue":
      <div class="dfe-c-scard">
        <div class="dfe-c-scard__title">How to write a strong issue</div>
        <div style="font-size:0.8125rem;color:var(--grey-4);">
          <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-0">
            <li><strong>Title</strong> — state the incident and immediate impact.</li>
            <li><strong>Description</strong> — include what happened, why, and the operational consequence.</li>
            <li><strong>Status</strong> — whether the issue is open, in progress, resolved, etc.</li>
            <li><strong>Severity</strong> — impact on users or delivery if unresolved.</li>
            <li><strong>Priority</strong> — scheduling importance versus other issues.</li>
            <li><strong>Category</strong> — select all areas that apply; an issue can span multiple themes.</li>
            <li><strong>Target resolution</strong> — aim date for clearing the issue.</li>
          </ul>
        </div>
      </div>
      break;
    case "assumption":
      <div class="dfe-c-scard">
        <div class="dfe-c-scard__title">Assumption quality checks</div>
        <div style="font-size:0.8125rem;color:var(--grey-4);">
          <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-0">
            <li>Write assumptions as <strong>That... because...</strong>.</li>
            <li><strong>Criticality</strong> — how damaging it would be if the assumption proved false.</li>
            <li><strong>Status</strong> — whether the assumption is still believed valid.</li>
            <li><strong>Review date</strong> — when to re-check that the assumption still holds.</li>
          </ul>
        </div>
      </div>
      break;
    case "dependency":
      <div class="dfe-c-scard">
        <div class="dfe-c-scard__title">Dependency quality checks</div>
        <div style="font-size:0.8125rem;color:var(--grey-4);">
          <p class="govuk-!-margin-bottom-2">Record a directed link from a source entity to a target (for example Project → Risk).</p>
          <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-0">
            <li>Use the official entity type spelling (e.g. Project, Risk, Issue).</li>
            <li>Be explicit about the dependency and what is blocked if it slips.</li>
            <li><strong>Due date</strong> — optional deadline for resolving or reviewing the dependency.</li>
          </ul>
        </div>
      </div>
      break;
    case "tier":
      <div class="dfe-c-scard">
        <div class="dfe-c-scard__title">Risk tier guidance</div>
        <div style="font-size:0.8125rem;color:var(--grey-4);">
          <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-0">
            <li>Keep codes short and stable (for reporting and exports).</li>
            <li>Name and summary should make escalation expectations clear.</li>
            <li>Changing sort order affects grouped register views.</li>
          </ul>
        </div>
      </div>
      break;
    case "risk-escalation":
      <div class="dfe-c-scard">
        <div class="dfe-c-scard__title">How tier changes work</div>
        <div style="font-size:0.8125rem;color:var(--grey-4);">
          <ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-0">
            <li><strong>Proposed tier</strong> — pick the governance level you are asking for; approval sits with Operations RAID management.</li>
            <li><strong>Tier 1 / Tier 2</strong> — you cannot move the risk to these tiers yourself from this form; only formal escalation requests.</li>
            <li><strong>Tier 3</strong> — you cannot de-escalate further from the lowest tier.</li>
            <li><strong>Tier 1</strong> — you cannot escalate beyond the highest tier.</li>
          </ul>
          <p class="govuk-!-margin-top-3 govuk-!-margin-bottom-0">
            <a class="govuk-link" href="@Url.Action("RaidEscalations", "ModernOperations")">Open Operations → RAID escalation management</a>
          </p>
        </div>
      </div>
      break;
    default:
      <div class="dfe-c-scard">
        <div class="dfe-c-scard__title">Guidance</div>
        <div style="font-size:0.8125rem;color:var(--grey-4);">Help for this RAID form.</div>
      </div>
      break;
  }
</div>
