@model Compass.ViewModels.Modern.RaidEntityCommentsPanelVm
<section id="@Model.PanelId"
         class="govuk-!-margin-top-6 govuk-!-margin-bottom-6"
         data-raid-entity-comments
         data-entity-type="@Model.EntityType"
         data-entity-id="@Model.EntityId">
  <h2 class="govuk-heading-m govuk-!-margin-bottom-2">Progress updates</h2>
  <p class="govuk-body govuk-hint govuk-!-margin-bottom-4">Add notes for PMOs and others reviewing this record. Updates are saved immediately and appear in the register comment history.</p>

  <div id="@(Model.PanelId)-timeline"
       class="raid-entity-comments-timeline govuk-!-margin-bottom-4"
       role="list"
       aria-live="polite"
       aria-label="Progress update history">
    <p class="govuk-body-s govuk-!-margin-bottom-0" data-raid-entity-comments-loading>Loading updates…</p>
  </div>

  <div class="govuk-form-group govuk-!-margin-bottom-3">
    <label class="govuk-label" for="@(Model.PanelId)-input">Add update</label>
    <textarea class="govuk-textarea"
              id="@(Model.PanelId)-input"
              rows="4"
              maxlength="4000"
              data-raid-entity-comments-input></textarea>
  </div>
  <button type="button"
          class="govuk-button govuk-!-margin-bottom-0"
          id="@(Model.PanelId)-add"
          data-raid-entity-comments-add>
    Add update
  </button>
  <p class="govuk-body-s govuk-!-margin-top-2 govuk-!-margin-bottom-0" id="@(Model.PanelId)-status" data-raid-entity-comments-status hidden aria-live="polite"></p>
</section>
