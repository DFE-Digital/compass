@model Compass.ViewModels.Modern.ModernRaidNearMissForm
@using Compass.ViewModels.Modern
@using Microsoft.AspNetCore.Html

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernRaid")">RAID</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("NearMisses", "ModernRaid")">Near misses</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">Add near miss</li>
}

<div class="modern-work-page">
  @await Html.PartialAsync("~/Views/Modern/Shared/_ModernPageHeader.cshtml", new ModernPageHeaderViewModel {
    Caption = "RAID",
    Title = "Add near miss",
    Lede = new HtmlString("<p class=\"govuk-body govuk-!-margin-bottom-0\">Record a near miss or unexpected issue for the RAID register.</p>")
  })

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <form method="post" novalidate action="@Url.Action("NearMissCreatePost", "ModernRaid")" id="nm-form">
        @Html.AntiForgeryToken()
        @if (!ViewData.ModelState.IsValid)
        {
          <div class="govuk-error-summary" data-module="govuk-error-summary" role="alert">
            <h2 class="govuk-error-summary__title">There is a problem</h2>
            <div class="govuk-error-summary__body">
              <ul class="govuk-list govuk-error-summary__list">
                @foreach (var kv in ViewData.ModelState.Where(x => x.Value?.Errors?.Count > 0))
                {
                  if (string.IsNullOrEmpty(kv.Key)) { continue; }
                  <li><a href="#@kv.Key">@kv.Value!.Errors[0].ErrorMessage</a></li>
                }
              </ul>
            </div>
          </div>
        }
        @await Html.PartialAsync("~/Views/Modern/Raid/_NearMissFormFields.cshtml", Model)
        <div class="govuk-button-group">
          <button type="submit" class="govuk-button">Save near miss</button>
          <a class="govuk-link" href="@Url.Action("NearMisses", "ModernRaid")">Cancel</a>
        </div>
      </form>
    </div>
  </div>
</div>

@section Scripts {
  <script src="~/modern/js/near-miss-form.js" asp-append-version="true" nonce="@(Context.Items["Nonce"])"></script>
}
