@model Compass.ViewModels.Modern.RaidDashboardStatCardVm
@{
    var tint = string.IsNullOrWhiteSpace(Model.TintClass) ? "" : Model.TintClass.Trim();
    if (!string.IsNullOrWhiteSpace(tint) && !tint.StartsWith("dfe-f-stat-card--", StringComparison.Ordinal))
    {
        tint = $"dfe-f-stat-card--tint-{tint}";
    }
    var hasLink = !string.IsNullOrWhiteSpace(Model.Href);
    var hasFooter = hasLink || !string.IsNullOrWhiteSpace(Model.Trend);
}
<div class="dfe-f-stat-card @tint">
    <p class="govuk-body-s dfe-f-stat-card__label">@Model.Label</p>
    <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@Model.Value</p>
    @if (hasFooter)
    {
        <p class="govuk-body-s govuk-!-margin-top-2 govuk-!-margin-bottom-0">
            @if (hasLink)
            {
                <a class="govuk-link govuk-link--no-visited-state" href="@Model.Href" @if (!string.IsNullOrWhiteSpace(Model.AriaLabel)) { <text>aria-label="@Model.AriaLabel"</text> }>@Model.Trend</a>
            }
            else
            {
                @Model.Trend
            }
        </p>
    }
</div>
