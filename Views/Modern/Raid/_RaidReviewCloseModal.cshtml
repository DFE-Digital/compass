@* Close risk/issue from monthly review — closure comment required. *@
<dialog id="raid-review-close-modal"
        class="dfe-f-modal govuk-!-margin-0"
        data-module="dfe-f-modal"
        aria-labelledby="raid-review-close-modal-title"
        aria-modal="true"
        role="alertdialog">
  <div class="dfe-f-modal__panel">
    <header class="dfe-f-modal__header">
      <h2 id="raid-review-close-modal-title" class="govuk-heading-m dfe-f-modal__title">Close record</h2>
      <button type="button" class="dfe-f-modal__close" data-raid-review-close-cancel aria-label="Close">
        <span class="dfe-f-modal__close-x" aria-hidden="true">×</span>
      </button>
    </header>
    <div class="dfe-f-modal__body">
      <p class="govuk-body" id="raid-review-close-modal-lede">This will close the record. It will no longer appear in open monthly reviews.</p>
      <div class="govuk-form-group govuk-!-margin-bottom-0" id="raid-review-close-comment-group">
        <label class="govuk-label" for="raid-review-close-comment">Closure comment</label>
        <div class="govuk-hint" id="raid-review-close-comment-hint">Explain why this record is being closed.</div>
        <textarea class="govuk-textarea" id="raid-review-close-comment" rows="4" required aria-describedby="raid-review-close-comment-hint"></textarea>
        <p class="govuk-error-message govuk-!-margin-top-2" id="raid-review-close-comment-error" hidden>
          <span class="govuk-visually-hidden">Error:</span> Enter a closure comment.
        </p>
      </div>
    </div>
    <footer class="dfe-f-modal__footer">
      <button type="button" id="raid-review-close-confirm" class="govuk-button govuk-button--warning">Confirm close</button>
      <button type="button" class="govuk-button govuk-button--secondary" data-raid-review-close-cancel>Cancel</button>
    </footer>
  </div>
</dialog>
