@model Compass.ViewModels.Modern.RaidRegisterOnboardingViewModel

<div class="govuk-form-group">
  <label class="govuk-label govuk-label--s" for="Name">Register name</label>
  <div id="Name-hint" class="govuk-hint">Give your RAID register a name that describes its scope or purpose.</div>
  <input class="govuk-input" id="Name" name="Name" type="text" value="@Model.Name"
         aria-describedby="Name-hint" />
</div>

<div class="govuk-form-group">
  <label class="govuk-label govuk-label--s" for="Description">Description (optional)</label>
  <div id="Description-hint" class="govuk-hint">Briefly describe what this register covers and its purpose.</div>
  <textarea class="govuk-textarea" id="Description" name="Description" rows="4"
            aria-describedby="Description-hint">@Model.Description</textarea>
</div>

@if (!Model.IsRegisterOwner)
{
  <dl class="govuk-summary-list govuk-!-margin-bottom-0">
    <div class="govuk-summary-list__row">
      <dt class="govuk-summary-list__key">Register owner</dt>
      <dd class="govuk-summary-list__value">
        @(string.IsNullOrWhiteSpace(Model.OwnerName) ? Model.OwnerEmail : Model.OwnerName)
        @if (!string.IsNullOrWhiteSpace(Model.OwnerName) && !string.IsNullOrWhiteSpace(Model.OwnerEmail))
        {
          <span class="govuk-hint govuk-!-display-block govuk-!-margin-bottom-0">@Model.OwnerEmail</span>
        }
      </dd>
    </div>
  </dl>
  <p class="govuk-body-s govuk-!-margin-top-3 govuk-!-margin-bottom-0">Only the register owner can transfer ownership.</p>
  <input type="hidden" name="OwnerUserId" value="@Model.OwnerUserId" />
}
