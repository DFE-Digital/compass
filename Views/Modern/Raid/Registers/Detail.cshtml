@model Compass.ViewModels.Modern.RaidRegisterDetailViewModel
@using Compass.Models
@using System.Text.Json
@{
  ViewData["Title"] = Model.Name;
  var cspNonce = Context.Items["Nonce"]?.ToString() ?? "";
  var canManage = Model.CurrentUserRole == RaidRegisterRole.Owner || Model.CurrentUserRole == RaidRegisterRole.Manager;
  var settingsUrl = Url.Action("RegisterSettings", "ModernRaid", new { id = Model.Id });
  var totalOpen = Model.OpenRiskCount + Model.OpenIssueCount + Model.OpenAssumptionCount + Model.OpenDependencyCount + Model.OpenNearMissCount;
  var raidRegisterBootJson = JsonSerializer.Serialize(new
  {
    registerId = Model.Id,
    baseUrl = "/modern/raid",
    lookups = new
    {
      riskStatuses = Model.RiskStatuses.Select(x => new { id = x.Id, name = x.Name }),
      riskPriorities = Model.RiskPriorities.Select(x => new { id = x.Id, name = x.Name }),
      riskLikelihoods = Model.RiskLikelihoods.Select(x => new { id = x.Id, name = x.Name }),
      riskImpactLevels = Model.RiskImpactLevels.Select(x => new { id = x.Id, name = x.Name }),
      riskProximities = Model.RiskProximities.Select(x => new { id = x.Id, name = x.Name }),
      riskCategories = Model.RiskCategories.Select(x => new { id = x.Id, name = x.Name }),
      riskTiers = Model.RiskTiers.Select(x => new { id = x.Id, name = x.Name }),
      issueStatuses = Model.IssueStatuses.Select(x => new { id = x.Id, name = x.Name }),
      issuePriorities = Model.IssuePriorities.Select(x => new { id = x.Id, name = x.Name }),
      issueSeverities = Model.IssueSeverities.Select(x => new { id = x.Id, name = x.Name }),
      issueCategories = Model.IssueCategories.Select(x => new { id = x.Id, name = x.Name }),
      nearMissStatuses = Model.NearMissStatuses.Select(x => new { id = x.Id, name = x.Name }),
      nearMissSeriousnesses = Model.NearMissSeriousnesses.Select(x => new { id = x.Id, name = x.Name }),
      nearMissTypes = Model.NearMissTypes.Select(x => new { id = x.Id, name = x.Name }),
      assumptionStatuses = Model.AssumptionStatuses.Select(x => new { id = x.Id, name = x.Name }),
      assumptionCriticalities = Model.AssumptionCriticalities.Select(x => new { id = x.Id, name = x.Name }),
      workItems = Model.WorkItemOptions.Select(x => new { id = x.Id, name = x.Name }),
      fipsProducts = Model.ServiceOptions.Select(x => new { id = x.Id, name = x.Name })
    }
  });
}

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Registers", "ModernRaid")">RAID registers</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">@Model.Name</li>
}

<div class="modern-work-page govuk-!-padding-bottom-6">
  @{
    Microsoft.AspNetCore.Html.IHtmlContent? actions = null;
    if (canManage)
    {
      actions = new Microsoft.AspNetCore.Html.HtmlString(
        $"<a href=\"{settingsUrl}\" class=\"govuk-button govuk-button--secondary govuk-!-margin-right-2\" data-module=\"govuk-button\">Settings</a>");
    }
  }
  @await Html.PartialAsync("~/Views/Modern/Shared/_ModernPageHeader.cshtml", new Compass.ViewModels.Modern.ModernPageHeaderViewModel
  {
    Title = Model.Name,
    Actions = actions,
    BottomMarginClass = "govuk-!-margin-bottom-0"
  })

  @if (TempData["SuccessMessage"] is string successMsg)
  {
    <div class="govuk-notification-banner govuk-notification-banner--success" role="alert" data-module="govuk-notification-banner">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title">Success</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-body">@successMsg</p>
      </div>
    </div>
  }

  <!-- Primary view sub-navigation: Dashboard | Manage -->
  <nav class="dfe-f-sub-navigation govuk-!-margin-bottom-0" aria-label="Register views" id="register-view-tabs">
    <ul class="dfe-f-sub-navigation__list">
      <li class="dfe-f-sub-navigation__item dfe-f-sub-navigation__item--current" id="view-tab-dashboard">
        <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" href="#view-dashboard" data-view="dashboard" aria-current="page">Dashboard</a>
      </li>
      <li class="dfe-f-sub-navigation__item" id="view-tab-manage">
        <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" href="#view-manage" data-view="manage">Manage items</a>
      </li>
    </ul>
  </nav>

  <!-- ═══ DASHBOARD VIEW ═══ -->
  <div id="view-dashboard" class="raid-ss-tab-panel raid-ss-tab-active">

    <!-- Stat cards -->
    <section class="govuk-!-margin-top-4" aria-labelledby="register-summary-heading">
      <h2 id="register-summary-heading" class="govuk-visually-hidden">Summary</h2>
      <div class="dfe-f-card-grid raid-register-stat-grid">
        <div class="dfe-f-stat-card dfe-f-stat-card--tint-red">
          <p class="govuk-body-s dfe-f-stat-card__label">Open risks</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l" data-register-count="open-risks">@Model.OpenRiskCount</p>
          @if (Model.Risks.Any())
          {
            <p class="govuk-body-s govuk-!-margin-top-2 govuk-!-margin-bottom-0">
              <a class="govuk-link govuk-link--no-visited-state" href="#view-manage" data-view-switch="manage" data-tab-switch="risks">View risks</a>
            </p>
          }
        </div>
        <div class="dfe-f-stat-card dfe-f-stat-card--tint-orange">
          <p class="govuk-body-s dfe-f-stat-card__label">Open issues</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l" data-register-count="open-issues">@Model.OpenIssueCount</p>
          @if (Model.Issues.Any())
          {
            <p class="govuk-body-s govuk-!-margin-top-2 govuk-!-margin-bottom-0">
              <a class="govuk-link govuk-link--no-visited-state" href="#view-manage" data-view-switch="manage" data-tab-switch="issues">View issues</a>
            </p>
          }
        </div>
        <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
          <p class="govuk-body-s dfe-f-stat-card__label">Near misses</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l" data-register-count="open-nearmisses">@Model.OpenNearMissCount</p>
          @if (Model.NearMisses.Any())
          {
            <p class="govuk-body-s govuk-!-margin-top-2 govuk-!-margin-bottom-0">
              <a class="govuk-link govuk-link--no-visited-state" href="#view-manage" data-view-switch="manage" data-tab-switch="nearmisses">View near misses</a>
            </p>
          }
        </div>
        <div class="dfe-f-stat-card dfe-f-stat-card--tint-blue">
          <p class="govuk-body-s dfe-f-stat-card__label">Assumptions</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l" data-register-count="open-assumptions">@Model.OpenAssumptionCount</p>
          @if (Model.Assumptions.Any())
          {
            <p class="govuk-body-s govuk-!-margin-top-2 govuk-!-margin-bottom-0">
              <a class="govuk-link govuk-link--no-visited-state" href="#view-manage" data-view-switch="manage" data-tab-switch="assumptions">View assumptions</a>
            </p>
          }
        </div>
        <div class="dfe-f-stat-card dfe-f-stat-card--tint-teal">
          <p class="govuk-body-s dfe-f-stat-card__label">Dependencies</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@Model.OpenDependencyCount</p>
          @if (Model.Dependencies.Any())
          {
            <p class="govuk-body-s govuk-!-margin-top-2 govuk-!-margin-bottom-0">
              <a class="govuk-link govuk-link--no-visited-state" href="#rd-dependencies">View dependencies</a>
            </p>
          }
        </div>
      </div>
    </section>

    <!-- Scope & register meta -->
    <section class="govuk-!-margin-top-6">
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
          <div class="govuk-summary-card">
            <div class="govuk-summary-card__title-wrapper">
              <h2 class="govuk-summary-card__title">Scope</h2>
              @if (canManage)
              {
                <ul class="govuk-summary-card__actions">
                  <li class="govuk-summary-card__action">
                    <a href="@(settingsUrl)#rs-scope" class="govuk-link govuk-link--no-visited-state">Change<span class="govuk-visually-hidden"> scope</span></a>
                  </li>
                </ul>
              }
            </div>
            <div class="govuk-summary-card__content">
              <dl class="govuk-summary-list govuk-!-margin-bottom-0">
                <div class="govuk-summary-list__row">
                  <dt class="govuk-summary-list__key">Directorates</dt>
                  <dd class="govuk-summary-list__value">@(Model.DirectorateName ?? "—")</dd>
                </div>
                <div class="govuk-summary-list__row">
                  <dt class="govuk-summary-list__key">Portfolios</dt>
                  <dd class="govuk-summary-list__value">@(Model.BusinessAreaName ?? "—")</dd>
                </div>
                <div class="govuk-summary-list__row">
                  <dt class="govuk-summary-list__key">Work items</dt>
                  <dd class="govuk-summary-list__value">
                    @if (Model.WorkItemNames.Any())
                    {
                      <ul class="govuk-list govuk-!-margin-bottom-0">
                        @foreach (var name in Model.WorkItemNames)
                        {
                          <li>@name</li>
                        }
                      </ul>
                    }
                    else
                    {
                      <text>None</text>
                    }
                  </dd>
                </div>
                <div class="govuk-summary-list__row">
                  <dt class="govuk-summary-list__key">Services</dt>
                  <dd class="govuk-summary-list__value">
                    @if (Model.ServiceNames.Any())
                    {
                      <ul class="govuk-list govuk-!-margin-bottom-0">
                        @foreach (var name in Model.ServiceNames)
                        {
                          <li>@name</li>
                        }
                      </ul>
                    }
                    else
                    {
                      <text>None</text>
                    }
                  </dd>
                </div>
              </dl>
            </div>
          </div>
        </div>
        <div class="govuk-grid-column-one-third">
          <div class="govuk-summary-card">
            <div class="govuk-summary-card__title-wrapper">
              <h2 class="govuk-summary-card__title">Register details</h2>
            </div>
            <div class="govuk-summary-card__content">
              <dl class="govuk-summary-list govuk-summary-list--no-border govuk-!-margin-bottom-0">
                <div class="govuk-summary-list__row">
                  <dt class="govuk-summary-list__key">Created by</dt>
                  <dd class="govuk-summary-list__value">@Model.CreatedByName</dd>
                </div>
                <div class="govuk-summary-list__row">
                  <dt class="govuk-summary-list__key">Created</dt>
                  <dd class="govuk-summary-list__value">@Model.CreatedAt.ToString("d MMM yyyy")</dd>
                </div>
                <div class="govuk-summary-list__row">
                  <dt class="govuk-summary-list__key">Updated</dt>
                  <dd class="govuk-summary-list__value">@Model.UpdatedAt.ToString("d MMM yyyy")</dd>
                </div>
                <div class="govuk-summary-list__row">
                  <dt class="govuk-summary-list__key">Users</dt>
                  <dd class="govuk-summary-list__value">@Model.Users.Count</dd>
                  @if (canManage)
                  {
                    <dd class="govuk-summary-list__actions">
                      <a class="govuk-link govuk-link--no-visited-state" href="@(settingsUrl)#rs-users">Manage<span class="govuk-visually-hidden"> users</span></a>
                    </dd>
                  }
                </div>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- RAID item summary tables (dashboard mode) -->

    @if (Model.Risks.Any())
    {
      <section id="rd-risks" class="govuk-!-margin-top-6">
        <h2 class="govuk-heading-m">Risks <span class="govuk-body-s" style="color:#505a5f;" data-register-count="total-risks">(@Model.Risks.Count)</span></h2>
        <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
          <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed">
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header">Ref</th>
                <th scope="col" class="govuk-table__header">Title</th>
                <th scope="col" class="govuk-table__header">Status</th>
                <th scope="col" class="govuk-table__header">Owner</th>
                <th scope="col" class="govuk-table__header">Tier</th>
                <th scope="col" class="govuk-table__header govuk-table__header--numeric">Orig. Score</th>
                <th scope="col" class="govuk-table__header govuk-table__header--numeric">Curr. Score</th>
              </tr>
            </thead>
            <tbody class="govuk-table__body">
              @foreach (var risk in Model.Risks)
              {
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell"><a class="govuk-link" href="@Url.Action("RiskDetail", "ModernRaid", new { id = risk.Id })">@risk.Reference</a></td>
                  <td class="govuk-table__cell">@risk.Title</td>
                  <td class="govuk-table__cell"><span class="dfe-f-badge dfe-f-badge--small">@(risk.Status ?? "Unknown")</span></td>
                  <td class="govuk-table__cell">@(risk.Owner ?? "Unassigned")</td>
                  <td class="govuk-table__cell">@(risk.Tier ?? "—")</td>
                  <td class="govuk-table__cell govuk-table__cell--numeric">@(risk.InherentScore?.ToString("0.0") ?? "—")</td>
                  <td class="govuk-table__cell govuk-table__cell--numeric">@(risk.CurrentScore?.ToString("0.0") ?? "—")</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </section>
    }

    @if (Model.Issues.Any())
    {
      <section id="rd-issues" class="govuk-!-margin-top-6">
        <h2 class="govuk-heading-m">Issues <span class="govuk-body-s" style="color:#505a5f;" data-register-count="total-issues">(@Model.Issues.Count)</span></h2>
        <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
          <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed">
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header">Ref</th>
                <th scope="col" class="govuk-table__header">Title</th>
                <th scope="col" class="govuk-table__header">Status</th>
                <th scope="col" class="govuk-table__header">Severity</th>
                <th scope="col" class="govuk-table__header">Owner</th>
              </tr>
            </thead>
            <tbody class="govuk-table__body">
              @foreach (var issue in Model.Issues)
              {
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell"><a class="govuk-link" href="@Url.Action("IssueDetail", "ModernRaid", new { id = issue.Id })">@issue.Reference</a></td>
                  <td class="govuk-table__cell">@issue.Title</td>
                  <td class="govuk-table__cell"><span class="dfe-f-badge dfe-f-badge--small">@(issue.Status ?? "Unknown")</span></td>
                  <td class="govuk-table__cell">@(issue.Severity ?? "—")</td>
                  <td class="govuk-table__cell">@(issue.Owner ?? "Unassigned")</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </section>
    }

    @if (Model.Assumptions.Any())
    {
      <section id="rd-assumptions" class="govuk-!-margin-top-6">
        <h2 class="govuk-heading-m">Assumptions <span class="govuk-body-s" style="color:#505a5f;" data-register-count="total-assumptions">(@Model.Assumptions.Count)</span></h2>
        <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
          <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed">
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header">Description</th>
                <th scope="col" class="govuk-table__header">Status</th>
                <th scope="col" class="govuk-table__header">Criticality</th>
                <th scope="col" class="govuk-table__header">Owner</th>
              </tr>
            </thead>
            <tbody class="govuk-table__body">
              @foreach (var assumption in Model.Assumptions)
              {
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell"><a class="govuk-link" href="@Url.Action("AssumptionDetail", "ModernRaid", new { id = assumption.Id })">@assumption.Description</a></td>
                  <td class="govuk-table__cell"><span class="dfe-f-badge dfe-f-badge--small">@(assumption.Status ?? "Unknown")</span></td>
                  <td class="govuk-table__cell">@(assumption.Criticality ?? "—")</td>
                  <td class="govuk-table__cell">@(assumption.Owner ?? "Unassigned")</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </section>
    }

    @if (Model.Dependencies.Any())
    {
      <section id="rd-dependencies" class="govuk-!-margin-top-6">
        <h2 class="govuk-heading-m">Dependencies <span class="govuk-body-s" style="color:#505a5f;">(@Model.Dependencies.Count)</span></h2>
        <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
          <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed">
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header">Description</th>
                <th scope="col" class="govuk-table__header">Type</th>
                <th scope="col" class="govuk-table__header">Status</th>
                <th scope="col" class="govuk-table__header">Owner</th>
              </tr>
            </thead>
            <tbody class="govuk-table__body">
              @foreach (var dep in Model.Dependencies)
              {
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell"><a class="govuk-link" href="@Url.Action("DependencyDetail", "ModernRaid", new { id = dep.Id })">@(dep.Description ?? $"Dependency #{dep.Id}")</a></td>
                  <td class="govuk-table__cell">@(dep.LinkType ?? "—")</td>
                  <td class="govuk-table__cell"><span class="dfe-f-badge dfe-f-badge--small">@(dep.Status ?? "Unknown")</span></td>
                  <td class="govuk-table__cell">@(dep.Owner ?? "Unassigned")</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </section>
    }

    @if (Model.NearMisses.Any())
    {
      <section id="rd-nearmisses" class="govuk-!-margin-top-6">
        <h2 class="govuk-heading-m">Near misses <span class="govuk-body-s" style="color:#505a5f;" data-register-count="total-nearmisses">(@Model.NearMisses.Count)</span></h2>
        <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
          <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed">
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header">Ref</th>
                <th scope="col" class="govuk-table__header">Impact</th>
                <th scope="col" class="govuk-table__header">Status</th>
                <th scope="col" class="govuk-table__header">Seriousness</th>
              </tr>
            </thead>
            <tbody class="govuk-table__body">
              @foreach (var nm in Model.NearMisses)
              {
                <tr class="govuk-table__row">
                  <td class="govuk-table__cell"><a class="govuk-link" href="@Url.Action("NearMissDetail", "ModernRaid", new { id = nm.Id })">@nm.Reference</a></td>
                  <td class="govuk-table__cell">@(nm.Impact ?? "—")</td>
                  <td class="govuk-table__cell"><span class="dfe-f-badge dfe-f-badge--small">@(nm.Status ?? "Unknown")</span></td>
                  <td class="govuk-table__cell">@(nm.Seriousness ?? "—")</td>
                </tr>
              }
            </tbody>
          </table>
        </div>
      </section>
    }

    @if (!Model.Risks.Any() && !Model.Issues.Any() && !Model.Assumptions.Any() && !Model.Dependencies.Any() && !Model.NearMisses.Any())
    {
      <section class="govuk-!-margin-top-6">
        <div class="govuk-inset-text">
          <p class="govuk-body govuk-!-margin-bottom-2">This register has no RAID items yet.</p>
          <p class="govuk-body govuk-!-margin-bottom-0">
            You can <a class="govuk-link" href="@Url.Action("RiskCreate", "ModernRaid")">raise a new risk</a>,
            <a class="govuk-link" href="@Url.Action("IssueCreate", "ModernRaid")">log a new issue</a>,
            or adopt existing items into this register from the RAID lists.
          </p>
        </div>
      </section>
    }
  </div>

  <!-- ═══ MANAGE VIEW (Spreadsheet) ═══ -->
  <div id="view-manage" class="raid-ss-tab-panel">
    <section id="raid-manage-section" class="govuk-!-margin-top-2">
      <nav class="dfe-f-sub-navigation govuk-!-margin-bottom-0" aria-label="Manage item type" id="manage-sub-tabs">
        <ul class="dfe-f-sub-navigation__list">
          <li class="dfe-f-sub-navigation__item dfe-f-sub-navigation__item--current" id="manage-tab-risks">
            <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" href="#ss-risks" data-tab="risks" aria-current="page">Risks <span class="dfe-c-fw-regular" data-register-count="total-risks">(@Model.Risks.Count)</span></a>
          </li>
          <li class="dfe-f-sub-navigation__item" id="manage-tab-issues">
            <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" href="#ss-issues" data-tab="issues">Issues <span class="dfe-c-fw-regular" data-register-count="total-issues">(@Model.Issues.Count)</span></a>
          </li>
          <li class="dfe-f-sub-navigation__item" id="manage-tab-assumptions">
            <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" href="#ss-assumptions" data-tab="assumptions">Assumptions <span class="dfe-c-fw-regular" data-register-count="total-assumptions">(@Model.Assumptions.Count)</span></a>
          </li>
          <li class="dfe-f-sub-navigation__item" id="manage-tab-nearmisses">
            <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" href="#ss-nearmisses" data-tab="nearmisses">Near misses <span class="dfe-c-fw-regular" data-register-count="total-nearmisses">(@Model.NearMisses.Count)</span></a>
          </li>
        </ul>
      </nav>

      <div id="ss-panel-risks" class="raid-ss-tab-panel raid-ss-tab-active" style="padding-top:15px;">
        @await Html.PartialAsync("~/Views/Modern/Raid/Registers/_Spreadsheet_Risks.cshtml", Model)
      </div>
      <div id="ss-panel-issues" class="raid-ss-tab-panel" style="padding-top:15px;">
        @await Html.PartialAsync("~/Views/Modern/Raid/Registers/_Spreadsheet_Issues.cshtml", Model)
      </div>
      <div id="ss-panel-assumptions" class="raid-ss-tab-panel" style="padding-top:15px;">
        @await Html.PartialAsync("~/Views/Modern/Raid/Registers/_Spreadsheet_Assumptions.cshtml", Model)
      </div>
      <div id="ss-panel-nearmisses" class="raid-ss-tab-panel" style="padding-top:15px;">
        @await Html.PartialAsync("~/Views/Modern/Raid/Registers/_Spreadsheet_NearMisses.cshtml", Model)
      </div>
    </section>

    @await Html.PartialAsync("~/Views/Modern/Raid/Registers/_Spreadsheet_Modal.cshtml")
    @await Html.PartialAsync("~/Views/Modern/Raid/Registers/_Spreadsheet_IntroModal.cshtml")
  </div>
</div>

@section Styles {
  <link rel="stylesheet" href="~/css/raid-spreadsheet.css" asp-append-version="true" />
  <style nonce="@cspNonce">
    @@media (min-width: 48rem) {
      .raid-register-stat-grid {
        grid-template-columns: repeat(5, minmax(0, 1fr));
      }
    }
  </style>
}

@section Scripts {
  <script src="~/js/raid-register-detail.js" asp-append-version="true" nonce="@cspNonce"></script>
  <script src="~/js/raid-spreadsheet.js" asp-append-version="true" nonce="@cspNonce"></script>
  <script src="~/js/raid-spreadsheet-intro.js" asp-append-version="true" nonce="@cspNonce"></script>
  <script type="application/json" id="raid-register-boot" nonce="@cspNonce">@Html.Raw(raidRegisterBootJson)</script>
  <script src="~/js/raid-register-detail-boot.js" asp-append-version="true" nonce="@cspNonce"></script>
  @Html.AntiForgeryToken()
}
