@model (int RiskId, int Count, string Reference)
<td class="govuk-table__cell raid-ss-kri-cell" data-col="kris">
  <button type="button" class="govuk-link raid-ss-kri-open-btn govuk-!-margin-bottom-0"
          data-risk-id="@Model.RiskId"
          data-kri-count="@Model.Count"
          data-ref-label="@Model.Reference"
          aria-label="@(Model.Count == 0 ? "Add KRI for " + Model.Reference : $"View {Model.Count} KRI{(Model.Count == 1 ? "" : "s")} for {Model.Reference}")">
    @if (Model.Count == 0)
    {
      <text>Add KRI</text>
    }
    else
    {
      <text>@Model.Count KRI@(Model.Count == 1 ? "" : "s")</text>
    }
  </button>
</td>
