@model Compass.ViewModels.Modern.RaidRegisterOnboardingViewModel
@{
  bool HasError(string field) => ViewData.ModelState[field]?.Errors?.Any() == true;
  string? ErrorMsg(string field) => ViewData.ModelState[field]?.Errors?.FirstOrDefault()?.ErrorMessage;
}

<h2 class="govuk-heading-m">Name and description</h2>
<p class="govuk-body">Give your RAID register a name that describes its scope or purpose.</p>

<div class="govuk-form-group @(HasError("Name") ? "govuk-form-group--error" : "")">
  <label class="govuk-label govuk-label--s" for="Name">Register name</label>
  <div id="Name-hint" class="govuk-hint">For example, &ldquo;Digital Services Portfolio RAID&rdquo; or &ldquo;Find information about places RAID&rdquo;</div>
  @if (HasError("Name"))
  {
    <p id="Name-error" class="govuk-error-message">
      <span class="govuk-visually-hidden">Error:</span> @ErrorMsg("Name")
    </p>
  }
  <input class="govuk-input @(HasError("Name") ? "govuk-input--error" : "")"
         id="Name" name="Name" type="text" value="@Model.Name"
         aria-describedby="Name-hint @(HasError("Name") ? "Name-error" : "")" />
</div>

<div class="govuk-form-group">
  <label class="govuk-label govuk-label--s" for="Description">Description (optional)</label>
  <div id="Description-hint" class="govuk-hint">Briefly describe what this register covers and its purpose.</div>
  <textarea class="govuk-textarea" id="Description" name="Description" rows="4"
            aria-describedby="Description-hint">@Model.Description</textarea>
</div>
