@model Compass.ViewModels.Modern.RaidRegisterOnboardingViewModel
@using Compass.Models

@{
  var ownerHint = "Transfer ownership to another user. The new owner will be able to manage settings and delete this register.";
  if (!string.IsNullOrWhiteSpace(Model.CreatedByName))
  {
    ownerHint += " This register was created by " + Model.CreatedByName + ".";
  }
  var ownerPicker = new UserPickerViewModel
  {
    FieldName = "OwnerUserId",
    Label = "Register owner",
    Hint = ownerHint,
    UseGovUkStyling = true,
    DefaultUserId = Model.OwnerUserId,
    DefaultName = Model.OwnerName,
    DefaultEmail = Model.OwnerEmail,
    DefaultSummaryText = "No owner selected.",
    InputIdSuffix = "register-owner-transfer"
  };
}
@await Html.PartialAsync("~/Views/Modern/Shared/_UserPicker.cshtml", ownerPicker)
