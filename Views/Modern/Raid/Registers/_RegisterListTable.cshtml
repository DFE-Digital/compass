@model IReadOnlyList<Compass.ViewModels.Modern.RaidRegisterCardViewModel>
@{
  var tableId = ViewData["TableId"] as string ?? "raid-registers-table";
  var caption = ViewData["TableCaption"] as string ?? "RAID registers";
  var emptyMessage = ViewData["EmptyMessage"] as string ?? "No registers to show.";
}

@if (!Model.Any())
{
  <p class="govuk-body govuk-!-margin-top-4">@emptyMessage</p>
}
else
{
  <div class="dfe-f-table-wrapper govuk-!-margin-top-4" data-module="dfe-f-table">
    <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
    <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed" id="@tableId">
      <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">@caption</caption>
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Register</button></th>
          <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Owner</button></th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Risks</button></th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Issues</button></th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Assumptions</button></th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Dependencies</button></th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Near misses</button></th>
          <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Directorate</button></th>
          <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Portfolio</button></th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        @foreach (var reg in Model)
        {
          var scopeParts = new List<string>();
          if (!string.IsNullOrWhiteSpace(reg.DirectorateName))
            scopeParts.Add(reg.DirectorateName);
          if (!string.IsNullOrWhiteSpace(reg.BusinessAreaName))
            scopeParts.Add(reg.BusinessAreaName);
          var scopeSubtitle = scopeParts.Count > 0 ? string.Join(" / ", scopeParts) : null;
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">
              <a class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold" href="@($"{Url.Action("RegisterDetail", "ModernRaid", new { id = reg.Id })}#view-manage")">@reg.Name</a>
              @if (!string.IsNullOrWhiteSpace(scopeSubtitle))
              {
                <br />
                <span class="govuk-body-s" style="color:#505a5f;">@scopeSubtitle</span>
              }
            </td>
            <td class="govuk-table__cell">@(reg.OwnerName ?? "—")</td>
            <td class="govuk-table__cell govuk-table__cell--numeric">@reg.OpenRiskCount</td>
            <td class="govuk-table__cell govuk-table__cell--numeric">@reg.OpenIssueCount</td>
            <td class="govuk-table__cell govuk-table__cell--numeric">@reg.OpenAssumptionCount</td>
            <td class="govuk-table__cell govuk-table__cell--numeric">@reg.OpenDependencyCount</td>
            <td class="govuk-table__cell govuk-table__cell--numeric">@reg.OpenNearMissCount</td>
            <td class="govuk-table__cell">@(reg.DirectorateName ?? "—")</td>
            <td class="govuk-table__cell">@(reg.BusinessAreaName ?? "—")</td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}
