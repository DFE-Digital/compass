@model Compass.ViewModels.Modern.RaidRegisterDetailViewModel

@if (!Model.Dependencies.Any())
{
  <p class="govuk-body govuk-!-margin-top-2">No dependencies are linked to this register.</p>
}
else
{
  <div class="dfe-f-table-wrapper govuk-!-margin-top-2" data-module="dfe-f-table">
    <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
    <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed" id="tbl-dependencies">
      <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">Dependencies in this register</caption>
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Description</button></th>
          <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Type</button></th>
          <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Status</button></th>
          <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Owner</button></th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        @foreach (var dep in Model.Dependencies)
        {
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">
              <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("DependencyDetail", "ModernRaid", new { id = dep.Id })">@(dep.Description ?? $"Dependency #{dep.Id}")</a>
            </td>
            <td class="govuk-table__cell">@(dep.LinkType ?? "—")</td>
            <td class="govuk-table__cell"><span class="dfe-f-badge dfe-f-badge--small">@(dep.Status ?? "Unknown")</span></td>
            <td class="govuk-table__cell">@(dep.Owner ?? "Unassigned")</td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}
