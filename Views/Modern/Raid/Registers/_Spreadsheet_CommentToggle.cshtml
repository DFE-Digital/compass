@model (string Entity, int Id, int CommentCount)
@{
  var count = Model.CommentCount;
  var countLabel = count == 1 ? "1 comment" : count + " comments";
}
<button type="button"
        class="raid-ss-comment-toggle@(count > 0 ? " raid-ss-comment-toggle--has-comments" : "")"
        data-entity="@Model.Entity"
        data-id="@Model.Id"
        data-comment-count="@count"
        aria-expanded="false"
        title="@(count > 0 ? countLabel : "View comments")">
  <span class="material-symbols-outlined raid-ss-comment-toggle__icon" aria-hidden="true">chat_bubble_outline</span>
  <span class="raid-ss-comment-count@(count > 0 ? " raid-ss-comment-count--visible" : "")" aria-hidden="@(count == 0)">@count</span>
  <span class="govuk-visually-hidden">@(count > 0 ? countLabel : "Comments")</span>
</button>
