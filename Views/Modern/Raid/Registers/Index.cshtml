@model Compass.ViewModels.Modern.RaidRegisterDashboardViewModel
@{
  ViewData["Title"] = "RAID registers";
  var hasAny = Model.YourRegisters.Any() || Model.AllRegisters.Any();
}

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">RAID registers</li>
}

<div class="modern-work-page govuk-!-padding-bottom-6">
  @await Html.PartialAsync("~/Views/Modern/Shared/_ModernPageHeader.cshtml", new Compass.ViewModels.Modern.ModernPageHeaderViewModel
  {
    Title = "RAID registers",
    Lede = new Microsoft.AspNetCore.Html.HtmlString("<p class=\"govuk-body-s govuk-!-margin-bottom-0\">Manage registers you belong to and browse all registers in the organisation.</p>"),
    Actions = new Microsoft.AspNetCore.Html.HtmlString($"<a href=\"{Url.Action("RegisterCreate", "ModernRaid")}\" class=\"govuk-button\" data-module=\"govuk-button\">Create register</a>")
  })

  @if (TempData["SuccessMessage"] is string successMsg)
  {
    <div class="govuk-notification-banner govuk-notification-banner--success" role="alert" data-module="govuk-notification-banner">
      <div class="govuk-notification-banner__header">
        <h2 class="govuk-notification-banner__title">Success</h2>
      </div>
      <div class="govuk-notification-banner__content">
        <p class="govuk-body">@successMsg</p>
      </div>
    </div>
  }

  @if (!hasAny)
  {
    <div class="govuk-!-margin-top-6">
      <p class="govuk-body">There are no RAID registers yet.</p>
      <p class="govuk-body">
        <a href="@Url.Action("RegisterCreate", "ModernRaid")" class="govuk-link">Create your first RAID register</a>
        to start managing risks, issues, assumptions, dependencies and near misses.
      </p>
    </div>
  }
  else
  {
    <nav class="dfe-f-sub-navigation govuk-!-margin-top-4 govuk-!-margin-bottom-0" aria-label="Register lists" id="raid-registers-tabs">
      <ul class="dfe-f-sub-navigation__list">
        <li class="dfe-f-sub-navigation__item dfe-f-sub-navigation__item--current" id="raid-reg-tab-yours">
          <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" href="#your-registers" data-reg-tab="your-registers" aria-current="page">
            Your registers <span class="dfe-c-fw-regular">(@Model.YourRegisters.Count)</span>
          </a>
        </li>
        <li class="dfe-f-sub-navigation__item" id="raid-reg-tab-all">
          <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" href="#all-registers" data-reg-tab="all-registers">
            All registers <span class="dfe-c-fw-regular">(@Model.AllRegisters.Count)</span>
          </a>
        </li>
      </ul>
    </nav>

    <div id="panel-your-registers" class="raid-registers-tab-panel raid-registers-tab-active">
      <p class="govuk-body-s govuk-!-margin-top-4 govuk-!-margin-bottom-0" style="color:#505a5f;">
        Registers you created or where you are listed as owner, manager or viewer (A–Z).
      </p>
      @await Html.PartialAsync("~/Views/Modern/Raid/Registers/_RegisterListTable.cshtml", Model.YourRegisters, new ViewDataDictionary(ViewData)
      {
        { "TableId", "tbl-your-registers" },
        { "TableCaption", "Your RAID registers" },
        { "EmptyMessage", "You do not own or belong to any registers yet. Create a register to get started." }
      })
    </div>

    <div id="panel-all-registers" class="raid-registers-tab-panel">
      <p class="govuk-body-s govuk-!-margin-top-4 govuk-!-margin-bottom-0" style="color:#505a5f;">
        Every register in the organisation (A–Z). Registers you are not listed on are read-only.
      </p>
      @await Html.PartialAsync("~/Views/Modern/Raid/Registers/_RegisterListTable.cshtml", Model.AllRegisters, new ViewDataDictionary(ViewData)
      {
        { "TableId", "tbl-all-registers" },
        { "TableCaption", "All RAID registers" },
        { "EmptyMessage", "No registers have been created yet." },
        { "ShowAccess", true }
      })
    </div>
  }
</div>

<div id="raid-reg-scope-modal" class="raid-modal-overlay" style="display:none" role="dialog" aria-modal="true" aria-labelledby="raid-reg-scope-modal-title">
  <div class="raid-modal-panel" style="max-width:640px">
    <div class="raid-modal-header">
      <h2 class="govuk-heading-m govuk-!-margin-bottom-0" id="raid-reg-scope-modal-title">Register scope</h2>
      <button type="button" class="raid-modal-close govuk-link" aria-label="Close">&times;</button>
    </div>
    <div class="raid-modal-body" id="raid-reg-scope-modal-body">
      <p class="govuk-body">Loading…</p>
    </div>
    <div class="raid-modal-footer">
      <button type="button" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" id="raid-reg-scope-modal-close">Close</button>
    </div>
  </div>
</div>

@section Styles {
  <link rel="stylesheet" href="~/css/raid-spreadsheet.css" asp-append-version="true" />
  <style nonce="@(Context.Items["Nonce"]?.ToString() ?? "")">
    .raid-registers-tab-panel { display: none; }
    .raid-registers-tab-panel.raid-registers-tab-active { display: block; }
  </style>
}

@section Scripts {
  <script nonce="@Context.Items["Nonce"]">
  (function () {
    var panels = document.querySelectorAll('.raid-registers-tab-panel');
    var navItems = document.querySelectorAll('#raid-registers-tabs .dfe-f-sub-navigation__item');

    function activateTab(tabId) {
      var panelId = 'panel-' + tabId;
      panels.forEach(function (p) {
        p.classList.toggle('raid-registers-tab-active', p.id === panelId);
      });
      navItems.forEach(function (li) {
        var link = li.querySelector('a');
        var isCurrent = link && link.getAttribute('data-reg-tab') === tabId;
        li.classList.toggle('dfe-f-sub-navigation__item--current', isCurrent);
        if (link) link.toggleAttribute('aria-current', isCurrent);
      });
    }

    document.querySelectorAll('#raid-registers-tabs a[data-reg-tab]').forEach(function (link) {
      link.addEventListener('click', function (e) {
        e.preventDefault();
        var tab = link.getAttribute('data-reg-tab');
        history.pushState(null, '', '#' + tab);
        activateTab(tab);
      });
    });

    var defaultTab = @Model.YourRegisters.Any().ToString().ToLower() === 'true' ? 'your-registers' : 'all-registers';
    var hash = (window.location.hash || '').replace('#', '');
    if (hash !== 'all-registers' && hash !== 'your-registers') {
      hash = defaultTab;
    }
    activateTab(hash);
    window.addEventListener('hashchange', function () {
      var h = (window.location.hash || '#your-registers').replace('#', '');
      activateTab(h === 'all-registers' ? 'all-registers' : 'your-registers');
    });

    var modal = document.getElementById('raid-reg-scope-modal');
    var modalTitle = document.getElementById('raid-reg-scope-modal-title');
    var modalBody = document.getElementById('raid-reg-scope-modal-body');

    function closeScopeModal() {
      modal.style.display = 'none';
      document.body.style.overflow = '';
    }

    function openScopeModal(regName, workItems, services) {
      modalTitle.textContent = 'Scope: ' + regName;
      var html = '';
      if (workItems.length > 0) {
        html += '<h3 class="govuk-heading-s govuk-!-margin-top-0">Work items (' + workItems.length + ')</h3>';
        html += '<ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-4">';
        workItems.forEach(function (name) {
          html += '<li>' + escapeHtml(name) + '</li>';
        });
        html += '</ul>';
      }
      if (services.length > 0) {
        html += '<h3 class="govuk-heading-s' + (workItems.length === 0 ? ' govuk-!-margin-top-0' : '') + '">Services (' + services.length + ')</h3>';
        html += '<ul class="govuk-list govuk-list--bullet govuk-!-margin-bottom-0">';
        services.forEach(function (name) {
          html += '<li>' + escapeHtml(name) + '</li>';
        });
        html += '</ul>';
      }
      if (!html) {
        html = '<p class="govuk-body govuk-!-margin-bottom-0">This register has no work items or services in scope.</p>';
      }
      modalBody.innerHTML = html;
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }

    function escapeHtml(str) {
      var d = document.createElement('div');
      d.textContent = str;
      return d.innerHTML;
    }

    document.addEventListener('click', function (e) {
      var btn = e.target.closest('.raid-reg-scope-btn');
      if (!btn) return;
      e.preventDefault();
      var workItems = [];
      var services = [];
      try { workItems = JSON.parse(btn.getAttribute('data-work-items') || '[]'); } catch (err) {}
      try { services = JSON.parse(btn.getAttribute('data-services') || '[]'); } catch (err) {}
      openScopeModal(btn.getAttribute('data-reg-name') || 'Register', workItems, services);
    });

    modal.querySelectorAll('.raid-modal-close, #raid-reg-scope-modal-close').forEach(function (el) {
      el.addEventListener('click', closeScopeModal);
    });
    modal.addEventListener('click', function (e) {
      if (e.target === modal) closeScopeModal();
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && modal.style.display !== 'none') closeScopeModal();
    });
  })();
  </script>
}
