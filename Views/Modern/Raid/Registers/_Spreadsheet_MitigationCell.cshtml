@model (int RiskId, int Count, string Reference)
@{
  var count = Model.Count;
  var countLabel = count == 1 ? "1 mitigation" : count + " mitigations";
  var ariaLabel = count == 0
    ? "Add mitigation for " + Model.Reference
    : $"View {count} mitigation{(count == 1 ? "" : "s")} for {Model.Reference}";
}
<td class="govuk-table__cell raid-ss-mitigation-cell" data-col="mitigations">
  <button type="button"
          class="raid-ss-cell-icon-toggle raid-ss-mitigation-open-btn@(count > 0 ? " raid-ss-cell-icon-toggle--has-count" : "")"
          data-risk-id="@Model.RiskId"
          data-mitigation-count="@count"
          data-ref-label="@Model.Reference"
          aria-label="@ariaLabel">
    <span class="material-symbols-outlined raid-ss-cell-icon-toggle__icon" aria-hidden="true">task_alt</span>
    @if (count > 0)
    {
      <span class="dfe-f-count-badge" aria-label="@countLabel">@(count > 99 ? "99+" : count.ToString())</span>
    }
    <span class="govuk-visually-hidden">@ariaLabel</span>
  </button>
</td>
