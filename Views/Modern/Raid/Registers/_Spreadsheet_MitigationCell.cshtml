@model (int RiskId, int Count, string Reference)
<td class="govuk-table__cell raid-ss-mitigation-cell" data-col="mitigations">
  <button type="button" class="govuk-link raid-ss-mitigation-open-btn govuk-!-margin-bottom-0"
          data-risk-id="@Model.RiskId"
          data-mitigation-count="@Model.Count"
          data-ref-label="@Model.Reference"
          aria-label="@(Model.Count == 0 ? "Add mitigation for " + Model.Reference : $"View {Model.Count} mitigation{(Model.Count == 1 ? "" : "s")} for {Model.Reference}")">
    @if (Model.Count == 0)
    {
      <text>Add mitigation</text>
    }
    else
    {
      <text>@Model.Count mitigation@(Model.Count == 1 ? "" : "s")</text>
    }
  </button>
</td>
