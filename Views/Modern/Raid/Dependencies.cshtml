@model Compass.ViewModels.Modern.ModernRaidDependenciesPageViewModel
@{
  ViewData["Title"] = "RAID — Dependencies";
  var formAction = "/modern/raid/dependencies";
  var clearUrl = "/modern/raid/dependencies";
  var activeTab = string.IsNullOrWhiteSpace(Model.ActiveTab) ? "open" : Model.ActiveTab;
  var veryHighCount = Model.Rows.Count(r => (r.CriticalityLabel ?? "").Contains("very", StringComparison.OrdinalIgnoreCase));
  var highCount = Model.Rows.Count(r => (r.CriticalityLabel ?? "").Contains("high", StringComparison.OrdinalIgnoreCase) && !(r.CriticalityLabel ?? "").Contains("very", StringComparison.OrdinalIgnoreCase));
  var mediumCount = Model.Rows.Count(r => (r.CriticalityLabel ?? "").Contains("medium", StringComparison.OrdinalIgnoreCase));
  var lowCount = Model.Rows.Count(r => (r.CriticalityLabel ?? "").Contains("low", StringComparison.OrdinalIgnoreCase));
}

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="/modern/raid/dashboard">RAID</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">Dependencies</li>
}

<div class="modern-work-page">
  <div class="dfe-c-flex--between dfe-c-mb-3" style="flex-wrap:wrap;gap:1rem;">
    <div class="dfe-c-page-title" style="margin:0;">
      <div class="dfe-c-page-title__caption">RAID</div>
      <h1 class="dfe-c-page-title__heading">Dependencies register</h1>
      <p class="dfe-c-page-title__lede">Track external dependencies that can affect delivery (@Model.TotalFiltered matched).</p>
    </div>
    <a href="/modern/raid/dependencies/create" class="govuk-button">Add dependency</a>
  </div>

  <div class="dfe-c-card-grid dfe-c-mb-3" role="region" aria-label="Criticality on this page">
    <div class="dfe-c-metric dfe-c-metric--red">
      <div class="dfe-c-metric__number">@veryHighCount</div>
      <div class="dfe-c-metric__label">Very high</div>
    </div>
    <div class="dfe-c-metric dfe-c-metric--amber">
      <div class="dfe-c-metric__number">@highCount</div>
      <div class="dfe-c-metric__label">High</div>
    </div>
    <div class="dfe-c-metric dfe-c-metric--navy">
      <div class="dfe-c-metric__number">@mediumCount</div>
      <div class="dfe-c-metric__label">Medium</div>
    </div>
    <div class="dfe-c-metric dfe-c-metric--green">
      <div class="dfe-c-metric__number">@lowCount</div>
      <div class="dfe-c-metric__label">Low</div>
    </div>
  </div>

  <form method="get" action="@formAction" id="raid-deps-register-form" class="dfe-c-mb-3">
    <input type="hidden" name="tab" value="@activeTab" />
    <input type="hidden" name="page" value="1" />
    <div id="search-and-filter">
      <div class="filter-toolbar">
        <div class="filter-toolbar__search-wrap">
          <input type="search" name="search" id="raid-deps-search" value="@Model.Search" placeholder="Search description or types…" class="filter-search" autocomplete="off" aria-label="Search dependencies" />
          <button type="submit" class="govuk-button govuk-button--secondary filter-toolbar__search-submit">Search</button>
        </div>
        <button type="button" class="filter-toggle-btn" id="raid-deps-filter-btn" aria-expanded="false" aria-controls="raid-deps-filter-panel">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="flex-shrink:0;" aria-hidden="true"><path d="M1 3h14v1.5l-5 5V14l-4-2V9.5L1 4.5V3z"></path></svg>
          <span class="filter-toggle-label">Filter</span>
        </button>
      </div>
      <div class="filter-panel filter-panel--allwork" id="raid-deps-filter-panel">
        <div class="filter-panel__grid">
          <div>
            <label for="raid-deps-lt">Link type</label>
            <select name="linkTypeId" id="raid-deps-lt" class="govuk-select">
              <option value="">All</option>
              @foreach (var o in Model.LinkTypeOptions)
              {
                if (Model.LinkTypeId == o.Id) { <option value="@o.Id" selected>@o.Name</option> }
                else { <option value="@o.Id">@o.Name</option> }
              }
            </select>
          </div>
          <div>
            <label for="raid-deps-cr">Criticality</label>
            <select name="criticalityId" id="raid-deps-cr" class="govuk-select">
              <option value="">All</option>
              @foreach (var o in Model.CriticalityOptions)
              {
                if (Model.CriticalityId == o.Id) { <option value="@o.Id" selected>@o.Name</option> }
                else { <option value="@o.Id">@o.Name</option> }
              }
            </select>
          </div>
          <div>
            <label for="raid-deps-st">Status</label>
            <select name="status" id="raid-deps-st" class="govuk-select">
              <option value="">All</option>
              @foreach (var s in Model.StatusChoices)
              {
                if (Model.Status == s) { <option value="@s" selected>@s</option> }
                else { <option value="@s">@s</option> }
              }
            </select>
          </div>
        </div>
        <div class="filter-panel__actions" style="margin-top:0.75rem;display:flex;gap:0.5rem;flex-wrap:wrap;">
          <button type="submit" class="govuk-button">Apply filters</button>
          <a class="govuk-button govuk-button--secondary" href="@clearUrl">Clear</a>
        </div>
      </div>
    </div>
  </form>

  <div class="tabs" role="tablist" aria-label="RAID dependency sections">
    <a href="@($"/modern/raid/dependencies?tab=open&page=1&search={Uri.EscapeDataString(Model.Search ?? "")}&linkTypeId={Model.LinkTypeId}&criticalityId={Model.CriticalityId}&status={Uri.EscapeDataString(Model.Status ?? "")}")" class="tab @(activeTab == "open" ? "on" : "")" role="tab" aria-selected="@(activeTab == "open" ? "true" : "false")" aria-controls="raid-dependencies-open" id="tab-raid-dependencies-open">Open dependencies <span class="dfe-c-fw-regular">(@Model.OpenCount)</span></a>
    <a href="@($"/modern/raid/dependencies?tab=closed&page=1&search={Uri.EscapeDataString(Model.Search ?? "")}&linkTypeId={Model.LinkTypeId}&criticalityId={Model.CriticalityId}&status={Uri.EscapeDataString(Model.Status ?? "")}")" class="tab @(activeTab == "closed" ? "on" : "")" role="tab" aria-selected="@(activeTab == "closed" ? "true" : "false")" aria-controls="raid-dependencies-closed" id="tab-raid-dependencies-closed">Closed dependencies <span class="dfe-c-fw-regular">(@Model.ClosedCount)</span></a>
    <a href="@($"/modern/raid/dependencies?tab=all&page=1&search={Uri.EscapeDataString(Model.Search ?? "")}&linkTypeId={Model.LinkTypeId}&criticalityId={Model.CriticalityId}&status={Uri.EscapeDataString(Model.Status ?? "")}")" class="tab @(activeTab == "all" ? "on" : "")" role="tab" aria-selected="@(activeTab == "all" ? "true" : "false")" aria-controls="raid-dependencies-all" id="tab-raid-dependencies-all">All dependencies <span class="dfe-c-fw-regular">(@Model.AllCount)</span></a>
  </div>

  @if (Model.Rows.Count == 0)
  {
    <p class="govuk-body">No dependencies match your filters.</p>
  }
  else
  {
    <div class="dfe-c-table-wrap">
      <table id="raid-dependencies-table">
        <thead>
          <tr>
            <th data-sort-bound="1" class="sortable">From</th>
            <th data-sort-bound="1" class="sortable">To</th>
            <th data-sort-bound="1" class="sortable">Link / type</th>
            <th data-sort-bound="1" class="sortable">Criticality</th>
            <th data-sort-bound="1" class="sortable">Due</th>
            <th data-sort-bound="1" class="sortable">Status</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var d in Model.Rows)
          {
            <tr>
              <td>
                <div class="govuk-!-font-weight-bold">@d.SourceType</div>
                <div><a class="govuk-link" href="/modern/raid/dependencies/@d.Id">@(d.SourceTitle ?? ($"{d.SourceType} #{d.SourceId}"))</a></div>
                <div class="dfe-c-body-s dfe-c-text-muted" style="margin-top:0.25rem;line-height:1.3;">D-@d.Id.ToString("D4")</div>
              </td>
              <td>
                <div class="govuk-!-font-weight-bold">@d.TargetType</div>
                <div>@(d.TargetTitle ?? ($"{d.TargetType} #{d.TargetId}"))</div>
              </td>
              <td>@(d.LinkTypeLabel ?? d.DependencyType ?? "—")</td>
              <td><span class="dfe-c-tag @((d.CriticalityLabel ?? "").Contains("very", StringComparison.OrdinalIgnoreCase) || (d.CriticalityLabel ?? "").Contains("high", StringComparison.OrdinalIgnoreCase) ? "dfe-c-tag--red" : (d.CriticalityLabel ?? "").Contains("medium", StringComparison.OrdinalIgnoreCase) ? "dfe-c-tag--amber" : "dfe-c-tag--green")">@((d.CriticalityLabel ?? "—").ToUpperInvariant())</span></td>
              <td>@(d.DueDate.HasValue ? d.DueDate.Value.ToString("d MMM yyyy") : "—")</td>
              <td><span class="dfe-c-tag @((d.Status ?? "").Contains("closed", StringComparison.OrdinalIgnoreCase) ? "dfe-c-tag--green" : "dfe-c-tag--blue")">@((d.Status ?? "—").ToUpperInvariant())</span></td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  }
  @if (Model.TotalPages > 1)
  {
    <div style="display:flex;justify-content:space-between;align-items:center;margin-top:0.875rem;flex-wrap:wrap;gap:0.5rem;">
      <p class="dfe-c-text-muted" style="margin:0;">Page @Model.Page of @Model.TotalPages</p>
      <nav class="dfe-c-flex" style="gap:0.5rem;align-items:center;flex-wrap:wrap;" aria-label="Pagination">
        @if (Model.Page > 1)
        {
          <a class="govuk-link" href="@($"/modern/raid/dependencies?tab={activeTab}&search={Uri.EscapeDataString(Model.Search ?? "")}&linkTypeId={Model.LinkTypeId}&criticalityId={Model.CriticalityId}&status={Uri.EscapeDataString(Model.Status ?? "")}&page={Model.Page - 1}")">Previous</a>
        }
        @if (Model.Page < Model.TotalPages)
        {
          <a class="govuk-link" href="@($"/modern/raid/dependencies?tab={activeTab}&search={Uri.EscapeDataString(Model.Search ?? "")}&linkTypeId={Model.LinkTypeId}&criticalityId={Model.CriticalityId}&status={Uri.EscapeDataString(Model.Status ?? "")}&page={Model.Page + 1}")">Next</a>
        }
      </nav>
    </div>
  }
</div>
