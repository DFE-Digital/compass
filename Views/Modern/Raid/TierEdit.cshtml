@model Compass.ViewModels.Modern.ModernRaidRiskTierEditorForm
@{
  ViewData["Title"] = "Edit risk tier";
  var tid = (int)ViewBag.TierId;
}

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernRaid")">RAID</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Tier", "ModernRaid")">Risk tiers</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">Edit</li>
}

<div id="sc-raid-tier-edit" class="modern-work-page">
<p class="dfe-c-body dfe-c-mb-3">
  <a href="@Url.Action("Tier", "ModernRaid")" class="dfe-c-link">← Back to risk tiers</a>
</p>

<div class="dfe-c-page-title">
  <div class="dfe-c-page-title__caption">RAID</div>
  <h1 class="dfe-c-page-title__heading">Edit risk tier</h1>
  <p class="dfe-c-page-title__lede">Maintain how risk tiers are labelled and ordered for RAID reporting.</p>
</div>

<div class="dfe-c-form-layout">
  <div class="dfe-c-form-layout__main">
    <div class="dfe-c-card dfe-c-card--plain">
      <form method="post" novalidate action="@Url.Action("TierEditPost", "ModernRaid", new { id = tid })">
        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid)
        {
        <div class="govuk-error-summary" data-module="govuk-error-summary" role="alert" aria-labelledby="error-summary-title">
          <h2 class="govuk-error-summary__title" id="error-summary-title">There is a problem</h2>
          <div class="govuk-error-summary__body">
            <ul class="govuk-list govuk-error-summary__list">
              @foreach (var kv in ViewData.ModelState)
              {
                if (kv.Value?.Errors?.Count > 0)
                {
                  <li><a href="#@kv.Key">@kv.Value.Errors[0].ErrorMessage</a></li>
                }
              }
            </ul>
          </div>
        </div>
        }

        <div class="govuk-form-group">
          <label class="govuk-label" for="Code">Code</label>
          <input class="govuk-input govuk-input--width-20" id="Code" name="Code" type="text" value="@Model.Code" required maxlength="50" />
        </div>

        <div class="govuk-form-group">
          <label class="govuk-label" for="Name">Name</label>
          <input class="govuk-input" id="Name" name="Name" type="text" value="@Model.Name" required maxlength="100" />
        </div>

        <div class="govuk-form-group">
          <label class="govuk-label" for="Summary">Summary</label>
          <input class="govuk-input" id="Summary" name="Summary" type="text" value="@Model.Summary" maxlength="200" />
        </div>

        <div class="govuk-form-group">
          <label class="govuk-label" for="Description">Description</label>
          <textarea class="govuk-textarea" id="Description" name="Description" rows="4">@Model.Description</textarea>
        </div>

        <div class="govuk-form-group">
          <label class="govuk-label" for="SortOrder">Sort order</label>
          <input class="govuk-input govuk-input--width-5" id="SortOrder" name="SortOrder" type="number" value="@Model.SortOrder" />
        </div>

        <div class="govuk-form-group govuk-checkboxes govuk-checkboxes--small">
          <input type="hidden" name="IsActive" value="false" />
          <div class="govuk-checkboxes__item">
            @if (Model.IsActive)
            {
              <input class="govuk-checkboxes__input" id="IsActive" name="IsActive" type="checkbox" value="true" checked />
            }
            else
            {
              <input class="govuk-checkboxes__input" id="IsActive" name="IsActive" type="checkbox" value="true" />
            }
            <label class="govuk-label govuk-checkboxes__label" for="IsActive">Active</label>
          </div>
        </div>

        <div class="govuk-button-group">
          <button type="submit" class="govuk-button" data-module="govuk-button">Save changes</button>
          <a class="govuk-button govuk-button--secondary" href="@Url.Action("Tier", "ModernRaid")">Cancel</a>
        </div>
      </form>
    </div>
  </div>
  <div class="dfe-c-form-layout__aside">
    @await Html.PartialAsync("~/Views/Modern/Raid/_RaidGuidanceAside.cshtml", "tier")
  </div>
</div>
</div>
