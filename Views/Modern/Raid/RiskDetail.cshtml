            <div class="govuk-summary-list__row">
              <dt class="govuk-summary-list__key govuk-summary-list__key--width-one-third">Identified</dt>
              <dd class="govuk-summary-list__value">@((Model.IdentifiedDate ?? Model.CreatedAt).ToString("d MMMM yyyy", CultureInfo.GetCultureInfo("en-GB")))</dd>
              <dd class="govuk-summary-list__actions">
                <a class="govuk-link govuk-link--no-visited-state" href="@($"{riskEditUrl}#raid-risk-edit-identified")">Change<span class="govuk-visually-hidden"> identified date</span></a>
              </dd>
            </div>
            <div class="govuk-summary-list__row">
              <dt class="govuk-summary-list__key govuk-summary-list__key--width-one-third">Next review</dt>
              <dd class="govuk-summary-list__value">@(Model.NextReviewDate?.ToString("d MMMM yyyy", CultureInfo.GetCultureInfo("en-GB")) ?? "—")</dd>
              <dd class="govuk-summary-list__actions">
                <a class="govuk-link govuk-link--no-visited-state" href="@($"{riskEditUrl}#raid-risk-edit-nextreview")">Change<span class="govuk-visually-hidden"> next review</span></a>
              </dd>
            </div>
          </dl>
          </div>
        </div>
      </div>

      <div id="risk-key-risk-indicators" class="tab-pane @(activeTab == "kris" ? "on" : "")" role="tabpanel" aria-labelledby="tab-risk-kris">
        <div class="govuk-summary-card govuk-!-margin-top-4">
          <div class="govuk-summary-card__title-wrapper">
            <h2 class="govuk-summary-card__title">Key risk indicators</h2>
            <ul class="govuk-summary-card__actions">
              <li class="govuk-summary-card__action">
                <a class="govuk-link govuk-link--no-visited-state" href="#" id="raid-kri-add-toggle">Add KRI<span class="govuk-visually-hidden"> (show form below)</span></a>
              </li>
            </ul>
          </div>
          <div class="govuk-summary-card__content">

        <div id="raid-kri-add-form" class="govuk-!-margin-bottom-6" style="display:none;">
          <h3 class="govuk-heading-s">Add key risk indicator</h3>
          <form method="post" action="@Url.Action("RiskKeyRiskIndicatorAdd", "ModernRaid", new { riskId = Model.Id })" novalidate>
            @Html.AntiForgeryToken()
            <div class="govuk-form-group">
              <label class="govuk-label govuk-label--s" for="raid-kri-title">Title <span class="govuk-visually-hidden">(required)</span></label>
              <input class="govuk-input govuk-!-width-full" id="raid-kri-title" name="title" type="text" maxlength="300" required autocomplete="off" />
            </div>
            <div class="govuk-form-group">
              <label class="govuk-label govuk-label--s" for="raid-kri-desc">Description</label>
              <div id="raid-kri-desc-hint" class="govuk-hint">What this indicator represents for the risk.</div>
              <textarea class="govuk-textarea govuk-!-width-full" id="raid-kri-desc" name="description" rows="4" aria-describedby="raid-kri-desc-hint"></textarea>
            </div>
            <div class="govuk-form-group">
              <label class="govuk-label govuk-label--s" for="raid-kri-metric">Metric</label>
              <div id="raid-kri-metric-hint" class="govuk-hint">What you measure, units, thresholds, or reporting frequency.</div>
              <textarea class="govuk-textarea govuk-!-width-full" id="raid-kri-metric" name="metric" rows="3" maxlength="2000" aria-describedby="raid-kri-metric-hint"></textarea>
            </div>
            <div class="govuk-button-group">
              <button type="submit" class="govuk-button" data-module="govuk-button">Add</button>
              <button type="button" class="govuk-button govuk-button--secondary" data-module="govuk-button" id="raid-kri-add-cancel">Cancel</button>
            </div>
          </form>
        </div>

        @if (orderedKris.Count > 0)
        {
          <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
            <table class="govuk-table" id="raid-risk-kri-table">
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">#</button>
        </th>
                  <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Title</button>
        </th>
                  <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Description</button>
        </th>
                  <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Metric</button>
        </th>
                  <th></th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                @{ var kriIdx = 0; }
                @foreach (var k in orderedKris)
                {
                  kriIdx++;
                  var descCell = string.IsNullOrWhiteSpace(k.Description) ? "—" : k.Description;
                  var metricCell = string.IsNullOrWhiteSpace(k.Metric) ? "—" : k.Metric;
                  <tr class="govuk-table__row">
                    <td class="govuk-table__cell">@kriIdx</td>
                    <td class="govuk-table__cell">
                      <div style="font-weight:600;white-space:pre-wrap;">@k.Title</div>
                    </td>
                    <td class="govuk-table__cell">
                      <div class="govuk-body-s" style="white-space:pre-wrap;max-width:24rem;">@descCell</div>
                    </td>
                    <td class="govuk-table__cell">
                      <div class="govuk-body-s" style="white-space:pre-wrap;max-width:24rem;">@metricCell</div>
                    </td>
                    <td class="govuk-table__cell">
                      <form method="post"
                            action="@Url.Action("RiskKeyRiskIndicatorRemove", "ModernRaid", new { riskId = Model.Id, kriId = k.Id })"
                            data-confirm-title="Remove key risk indicator"
                            data-confirm-message="Remove this indicator? This cannot be undone."
                            class="govuk-!-margin-bottom-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="govuk-button govuk-button--warning govuk-button--small" data-module="govuk-button">Remove<span class="govuk-visually-hidden"> indicator @kriIdx</span></button>
                      </form>
                    </td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        }
        else
        {
          <p class="govuk-body">No key risk indicators yet. Use <strong>Add KRI</strong> to record title, description, and metric.</p>
        }

        <script nonce="@cspNonce">
          (function () {
            var addBox = document.getElementById('raid-kri-add-form');
            var addBtn = document.getElementById('raid-kri-add-toggle');
            var addCancel = document.getElementById('raid-kri-add-cancel');
            function toggleAdd() {
              if (!addBox) return;
              addBox.style.display = addBox.style.display === 'none' || addBox.style.display === '' ? 'block' : 'none';
            }
            if (addBtn) addBtn.addEventListener('click', function (e) { e.preventDefault(); toggleAdd(); });
            if (addCancel) addCancel.addEventListener('click', function () { if (addBox) addBox.style.display = 'none'; });
          })();
        </script>
          </div>
        </div>
      </div>

      <div id="risk-mitigations" class="tab-pane @(activeTab == "mitigations" ? "on" : "")" role="tabpanel" aria-labelledby="tab-risk-mitigations">
        <div class="govuk-summary-card govuk-!-margin-top-4">
          <div class="govuk-summary-card__title-wrapper">
            <h2 class="govuk-summary-card__title">Mitigation actions</h2>
            <ul class="govuk-summary-card__actions">
              <li class="govuk-summary-card__action">
                <a class="govuk-link govuk-link--no-visited-state" href="#" id="raid-mit-add-toggle">Add mitigation<span class="govuk-visually-hidden"> (show form below)</span></a>
              </li>
            </ul>
          </div>
          <div class="govuk-summary-card__content">

        <div id="raid-mit-add-form" class="govuk-!-margin-bottom-6" style="display:none;">
