                  if (prodManageHref != null)
                  {
                    <a class="govuk-link govuk-link--no-visited-state" href="@prodManageHref">@prodLabel</a>
                  }
                  else
                  {
                    <span class="govuk-body">@prodLabel</span>
                  }
                }
                else if (riskAssocUi == "work" && wi is int wkId && Model.Project != null)
                {
                  <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("Detail", "ModernWork", new { id = wkId, tab = "risks" })">@Model.Project.Title</a>
