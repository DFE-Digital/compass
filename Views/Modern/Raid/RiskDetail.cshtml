            <table class="govuk-table" id="raid-risk-actions-table">
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">#</button>
        </th>
                  <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Action</button>
        </th>
                  <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Owner</button>
        </th>
                  <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Target date</button>
        </th>
                  <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Status</button>
        </th>
                  <th></th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                @{ var mi = 0; }
                @foreach (var ra in mitigationRows)
                {
                  mi++;
                  var a = ra.Action!;
                  var ef = MitigationEffectiveSelectValue(a);
                  var ownerDisp = a.AssignedToUser?.Name ?? a.AssignedToEmail ?? "—";
                  var dueDisp = a.DueDate?.ToString("d MMM yyyy", CultureInfo.InvariantCulture) ?? "—";
                  <tr class="govuk-table__row">
                    <td class="govuk-table__cell">@mi</td>
