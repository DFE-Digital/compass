              <dd class="govuk-summary-list__actions">
                <a class="govuk-link govuk-link--no-visited-state" href="@($"{riskEditUrl}#raid-risk-edit-description")">Change<span class="govuk-visually-hidden"> description</span></a>
              </dd>
            </div>
            <div class="govuk-summary-list__row">
              <dt class="govuk-summary-list__key govuk-summary-list__key--width-one-third">Cause</dt>
              <dd class="govuk-summary-list__value">@if (string.IsNullOrWhiteSpace(Model.Cause)) { <text>—</text> } else { <span class="govuk-body" style="white-space:pre-wrap;">@Model.Cause</span> }</dd>
              <dd class="govuk-summary-list__actions">
                <a class="govuk-link govuk-link--no-visited-state" href="@($"{riskEditUrl}#raid-risk-edit-cause")">Change<span class="govuk-visually-hidden"> cause</span></a>
