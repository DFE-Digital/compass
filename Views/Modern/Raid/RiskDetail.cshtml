@model Compass.Models.Risk
@using Compass.Models
@using Compass.Models.Modern.Work
@using Compass.ViewModels.Modern
@using System.Globalization
@using System.Linq
@{
  string UserDisplayLine(User? u, string? fallbackWhenNoUser = null)
  {
    if (u != null)
    {
      if (!string.IsNullOrWhiteSpace(u.Name))
        return u.Name.Trim();
      var fl = string.Join(" ", new[] { u.FirstName, u.LastName }.Where(s => !string.IsNullOrWhiteSpace(s)));
      if (!string.IsNullOrWhiteSpace(fl))
        return fl;
      if (!string.IsNullOrWhiteSpace(u.Email))
        return u.Email;
      if (!string.IsNullOrWhiteSpace(u.UserPrincipalName))
        return u.UserPrincipalName;
    }
    if (!string.IsNullOrWhiteSpace(fallbackWhenNoUser))
      return fallbackWhenNoUser;
    return "—";
  }

  string? UserDisplayNameOnly(User? u)
  {
    if (u == null) return null;
    if (!string.IsNullOrWhiteSpace(u.Name))
      return u.Name.Trim();
    var fl = string.Join(" ", new[] { u.FirstName, u.LastName }.Where(s => !string.IsNullOrWhiteSpace(s)));
    return string.IsNullOrWhiteSpace(fl) ? null : fl;
  }

  string? UserContactEmail(User? u, string? fallbackEmail = null) =>
    !string.IsNullOrWhiteSpace(u?.Email) ? u!.Email!.Trim()
    : !string.IsNullOrWhiteSpace(fallbackEmail) ? fallbackEmail.Trim()
    : null;

  ViewData["Title"] = "Risk — " + Model.Title;
  var wi = Model.ProjectId;
  var activeTab = (ViewBag.ActiveTab as string ?? "detail").ToLowerInvariant();
  var linkedIssues = ViewBag.LinkedIssues as IReadOnlyList<RiskLinkedIssueCardVm> ?? Array.Empty<RiskLinkedIssueCardVm>();
  var orderedKris = Model.KeyRiskIndicators.OrderBy(k => k.SortOrder).ThenBy(k => k.Id).ToList();
  var riskCatLabels = Model.RiskRiskCategories?
    .Select(x => x.RiskCategory?.Label)
    .Where(x => !string.IsNullOrWhiteSpace(x))
    .Distinct()
    .ToList() ?? new List<string?>();
  if (riskCatLabels.Count == 0 && Model.RiskCategory?.Label != null)
    riskCatLabels = new List<string?> { Model.RiskCategory.Label };

  var divRegisterLabels = Model.RiskDivisions?
    .Select(x => x.Division?.Name)
    .Where(x => !string.IsNullOrWhiteSpace(x))
    .ToList() ?? new List<string?>();
  var baRegisterLabels = Model.RiskBusinessAreas?
    .Select(x => x.BusinessAreaLookup?.Name)
    .Where(x => !string.IsNullOrWhiteSpace(x))
    .ToList() ?? new List<string?>();

  var score = Model.RiskScore;
  var ratingLabel = ViewBag.RatingLabel as string ?? "—";
  var tierBadgeStep = ViewBag.TierBadgeStep is int ts ? ts : 2;
  var openDurationText = ViewBag.OpenDurationText as string ?? "—";
  var openedDate = Model.IdentifiedDate ?? Model.CreatedAt;
  var enGb = CultureInfo.GetCultureInfo("en-GB");
  var openedDateUk = openedDate.ToString("d MMMM yyyy", enGb);
  var riskIsClosed = Model.ClosedDate.HasValue;
  var riskDateColumnHeading = riskIsClosed ? "Date closed" : "Date opened";
  var riskDateColumnValue = riskIsClosed
    ? Model.ClosedDate!.Value.ToString("d MMMM yyyy", enGb)
    : openedDate.ToString("d MMMM yyyy", enGb);
  var riskProximityDisplay = string.IsNullOrWhiteSpace(Model.Proximity?.Label) ? "Not set" : Model.Proximity!.Label!;
  if (Model.ProximityDate is DateTime proxDt)
    riskProximityDisplay += " · " + proxDt.ToString("d MMMM yyyy", enGb);
  var statusForHeaderBadge = (Model.RiskStatus?.Label ?? Model.Status ?? "—").Trim();

  var teamLabel = Model.Project?.BusinessAreaLookup?.Name ?? Model.BusinessArea ?? "—";
  var groupLabel = Model.Project?.PrimaryOrganizationalGroup?.Name ?? "—";
  var ownerForHeader = ViewBag.OwnerForDisplay as User ?? Model.OwnerUser;
  var ownerNameDisplay = UserDisplayNameOnly(ownerForHeader);
  var ownerEmailForLink = UserContactEmail(ownerForHeader, Model.OwnerEmail);
  var sroDisplay = UserDisplayLine(Model.SroUser);
  var createdByDisplay = UserDisplayLine(Model.CreatedByUser);

  var riskStatusLabelForDisplay = (Model.RiskStatus?.Label ?? Model.Status ?? "").Trim();
  string TierBadgeDisplayText() =>
    Model.RiskTier == null
      ? ""
      : string.Equals(riskStatusLabelForDisplay, "Proposed", StringComparison.OrdinalIgnoreCase)
        ? Model.RiskTier.Name.ToUpperInvariant() + " PROPOSED RISK"
        : Model.RiskTier.Name.ToUpperInvariant();

  /// <summary>GOV tag pill classes: Tier 1 (and "Tier 1 - Proposed") = red, Tier 2 / proposed = yellow, Tier 3 / proposed = green.</summary>
  string TierTagClass() =>
    Model.RiskTier == null
      ? "dfe-c-tag dfe-c-tag--grey"
      : tierBadgeStep switch
      {
        1 => "dfe-c-tag dfe-c-tag--red",
        2 => "dfe-c-tag dfe-c-tag--yellow",
        3 => "dfe-c-tag dfe-c-tag--green",
        _ => "dfe-c-tag dfe-c-tag--amber"
      };

  string StatusTagClass()
  {
    var s = (Model.RiskStatus?.Label ?? Model.Status ?? "").ToLowerInvariant();
    if (s.Contains("escalat")) return "dfe-c-tag dfe-c-tag--red";
    if (s.Contains("closed")) return "dfe-c-tag dfe-c-tag--green";
    return "dfe-c-tag dfe-c-tag--blue";
  }

  /// <summary>Inherent score band colour (hex): layout does not load compass2-design.css, so CSS vars like --rag-r are undefined here.</summary>
  var ragBarFillHex = score >= 16 ? "#d4351c" : score >= 11 ? "#f8a100" : "#00703c";
  const int riskScoreMax = 25;
  var riskScoreSrLabel = $"Inherent risk score {score} out of {riskScoreMax}";
  var scoreBarPct = Math.Clamp(score <= 0 ? 0 : (double)score * 100.0 / riskScoreMax, 0, 100);

  var linkedCmdbProductId = ViewBag.LinkedCmdbProductId as Guid?;
  var linkedCmdbProductTitle = ViewBag.LinkedCmdbProductTitle as string;
  var linkedCmdbPhaseName = ViewBag.LinkedCmdbPhaseName as string;

  var mitigationRows = Model.RiskActions
    .Where(ra => ra.Action != null && !ra.Action.IsDeleted)
    .OrderBy(ra => ra.Action!.DueDate ?? DateTime.MaxValue)
    .ThenBy(ra => ra.Action!.Id)
    .ToList();
  var riskHistory = ViewBag.RiskHistoryTimeline as IReadOnlyList<RiskAuditTimelineItemVm>
    ?? Array.Empty<RiskAuditTimelineItemVm>();

  var riskEditUrl = Url.Action("RiskEdit", "ModernRaid", new { id = Model.Id }) ?? "";
  var mitigationsTabUrl = Url.Action("RiskDetail", "ModernRaid", new { id = Model.Id, tab = "mitigations" }) ?? "#";
  var assocScopeSentence = Model.RaidAssociationKind switch
  {
    RaidAssociationKinds.WorkItem => "This risk is scoped to a work item.",
    RaidAssociationKinds.Product => "This risk is scoped to a product (FIPS service).",
    RaidAssociationKinds.Organisation => "This risk is organisation-wide.",
    _ => null
  };
  var hasClassification =
      riskCatLabels.Count > 0 ||
      divRegisterLabels.Count > 0 ||
      baRegisterLabels.Count > 0 ||
      Model.GovernanceBoard != null;
  var cspNonce = Context.Items["Nonce"]?.ToString() ?? "";

  var riskAssocUi = (ViewBag.RiskAssociationUiKind as string ?? "work").Trim().ToLowerInvariant();
  var riskLinkedAssocEditor = ViewBag.RiskLinkedAssociationEditor as bool? ?? false;
  var linkPj = ViewBag.ProjectOptions as List<RiskIssueNamedIntOption> ?? new List<RiskIssueNamedIntOption>();
  var linkFp = ViewBag.FipsProductOptions as List<RiskIssueNamedIntOption> ?? new List<RiskIssueNamedIntOption>();
  var riskAssocUpdateUrl = Url.Action("RiskAssociationUpdate", "ModernRaid", new { id = Model.Id }) ?? "#";
}

@functions {
  private static string ScoreStripSub(Risk r)
  {
    var imp = r.ImpactLevel?.Label ?? $"Impact {r.ImpactRating}";
    var lik = r.Likelihood?.Label ?? $"Likelihood {r.LikelihoodRating}";
    return $"{imp} × {lik}";
  }

  private static string MitigationNormalizeStored(string? raw)
  {
    if (string.IsNullOrWhiteSpace(raw)) return "Not started";
    var t = raw.Trim();
    var l = t.ToLowerInvariant();
    if (l is "not started" or "not_started" or "open") return "Not started";
    if (l is "in progress" or "in_progress" or "progress") return "In progress";
    if (l is "complete" or "completed" or "done") return "Complete";
    if (l == "overdue") return "Overdue";
    if (l.Contains("progress")) return "In progress";
    if (l.Contains("complete")) return "Complete";
    return t.Length > 0 ? t : "Not started";
  }

  private static string MitigationEffectiveSelectValue(Compass.Models.Action a)
  {
    var s = MitigationNormalizeStored(a.Status);
    if (s == "Complete") return "Complete";
    if (s == "Overdue") return "Overdue";
    if (a.DueDate is DateTime d && d.Date < DateTime.UtcNow.Date && s != "Complete")
      return "Overdue";
    return s is "In progress" or "Not started" ? s : "Not started";
  }

  private static string MitigationProgressBadgeClass(string normalized)
  {
    var n = normalized.Trim().ToLowerInvariant();
    if (n == "complete") return "dfe-f-badge dfe-f-badge--small dfe-f-badge--green";
    if (n == "overdue") return "dfe-f-badge dfe-f-badge--small dfe-f-badge--red";
    if (n == "in progress") return "dfe-f-badge dfe-f-badge--small dfe-f-badge--blue";
    return "dfe-f-badge dfe-f-badge--small dfe-f-badge--grey";
  }

}

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="/modern/raid/dashboard">RAID</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="/modern/raid/risks">Risks</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">@Model.Title</li>
}

<div id="sc-risk-view" class="dfe-c-screen dfe-c-screen--active modern-work-page--risk-tab-@activeTab">
<style nonce="@cspNonce">
  #sc-risk-view .raid-risk-score-bar__track {
    width: 100%;
    box-sizing: border-box;
    height: 0.625rem;
    background: #f3f2f1;
    border-radius: 0.25rem;
    overflow: hidden;
    border: 1px solid #b1b4b6;
  }
  #sc-risk-view .raid-risk-score-bar__fill {
    height: 100%;
    max-width: 100%;
    box-sizing: border-box;
    border-radius: 0.25rem;
    transition: width 0.25s ease;
  }
  /* Summary + Risk detail cards: standard bordered summary list; long values wrap; actions align with first line */
  #sc-risk-view .raid-risk-detail-summary .govuk-summary-list__value,
  #sc-risk-view .raid-risk-detail-summary .govuk-summary-list__value .govuk-body {
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  #sc-risk-view .raid-risk-detail-summary .govuk-summary-list__actions {
    text-align: right;
    white-space: nowrap;
    vertical-align: top;
  }
  /* Linked records tab */
  #sc-risk-view .raid-linked-tab-stack {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  #sc-risk-view .raid-linked-record-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  #sc-risk-view .raid-linked-record {
    background: #fff;
    border: 1px solid #b1b4b6;
    border-radius: 4px;
    padding: 1rem 1.125rem;
    box-sizing: border-box;
  }
  #sc-risk-view .raid-linked-record__grid {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  #sc-risk-view .raid-linked-record__main {
    flex: 1;
    min-width: min(100%, 16rem);
  }
  #sc-risk-view .raid-linked-record__aside {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.35rem;
  }
  #sc-risk-view .raid-linked-record__meta {
    font-size: 0.75rem;
    color: #505a5f;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.03em;
    margin-bottom: 0.35rem;
  }
  #sc-risk-view .raid-linked-record__title {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
    display: inline;
  }
  #sc-risk-view .raid-linked-record__ref {
    font-family: ui-monospace, SFMono-Regular, "Roboto Mono", Menlo, Monaco, Consolas, monospace;
    font-size: 0.875rem;
    color: #505a5f;
    margin-left: 0.35rem;
  }
  #sc-risk-view .raid-linked-record__aim {
    font-size: 0.875rem;
    color: #505a5f;
    line-height: 1.45;
    margin-top: 0.5rem;
  }
  #sc-risk-view .raid-linked-record--work { border-left: 4px solid #003a69; }
  #sc-risk-view .raid-linked-record--product { border-left: 4px solid #00703c; }
  #sc-risk-view .raid-linked-record--issue { border-left: 4px solid #d4351c; }
  #sc-risk-view .raid-linked-record--mitigation { border-left: 4px solid #1d70b8; }
  #sc-risk-view .raid-linked-record--muted { border-left: 4px solid #b1b4b6; }
  #sc-risk-view .raid-linked-record__tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: center;
  }
  #sc-risk-view .raid-linked-record-modal.dfe-f-modal .dfe-f-modal__panel {
    max-width: 40rem;
    width: calc(100% - 2rem);
  }
  #sc-risk-view .raid-linked-record-modal .dfe-f-modal__body {
    max-height: min(72vh, 38rem);
    overflow-y: auto;
  }
  #sc-risk-view .raid-linked-primary-stack {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  /* Update history tab — DfE Frontend timeline */
  #sc-risk-view .raid-risk-history__timeline .dfe-f-timeline__item.raid-risk-history__timeline-item--alert::before {
    background: #d4351c;
  }
  #sc-risk-view .raid-risk-history__timeline-detail {
    color: #505a5f;
    font-size: 1rem;
    line-height: 1.45;
  }
  #sc-risk-view .raid-risk-history__footnote {
    color: #505a5f;
  }
  #sc-risk-view .raid-risk-detail-rating-card {
    display: none;
  }
  #sc-risk-view.modern-work-page--risk-tab-detail .raid-risk-detail-summary-card {
    display: block;
  }
  #sc-risk-view .raid-risk-detail-summary-card {
    display: none;
  }
</style>
<div class="modern-work-page">
  @if (TempData["Message"] is string tm)
  {
    <div class="govuk-notification-banner govuk-notification-banner--success govuk-!-margin-bottom-4" role="region">
      <div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">Success</h2></div>
      <div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">@tm</p></div>
    </div>
  }
  @if (TempData["ErrorMessage"] is string em)
  {
    <div class="govuk-error-summary govuk-!-margin-bottom-4" role="alert" data-module="govuk-error-summary">
      <h2 class="govuk-error-summary__title">There is a problem</h2>
      <div class="govuk-error-summary__body">@em</div>
    </div>
  }

  @{
    var pendingRiskTierChange = ViewBag.PendingRiskTierChange as RiskPendingTierChangeVm;
  }
  @if (pendingRiskTierChange != null)
  {
    <div class="govuk-inset-text govuk-!-margin-bottom-4">
      <p class="govuk-body govuk-!-margin-bottom-1"><strong>Pending tier change</strong></p>
      <p class="govuk-body govuk-!-margin-bottom-2">@pendingRiskTierChange.RequestLine</p>
      <p class="govuk-body-s govuk-!-margin-bottom-0" style="color: #505a5f;">
        <a class="govuk-link govuk-link--no-visited-state" href="@(Url.Action("RaidEscalations", "ModernOperations", new { tab = "escalations" }) ?? "/modern/operations/raid/escalations")">View in Operations escalation queue</a>
      </p>
    </div>
  }

  <!-- Header (same masthead pattern as work items) -->
  <p class="govuk-body govuk-!-margin-bottom-2">
    <a href="/modern/raid/risks" class="govuk-link govuk-back-link govuk-!-margin-bottom-0 govuk-link--no-visited-state">Back to risks register</a>
  </p>
  <div class="work-item-masthead govuk-!-margin-bottom-6">
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-two-thirds-from-desktop">
        <p class="govuk-caption-m govuk-!-margin-bottom-1 govuk-!-margin-top-0">R-@Model.Id.ToString("D4")</p>
        <h1 class="govuk-heading-l govuk-!-margin-bottom-4">@Model.Title</h1>
      </div>
      <div class="govuk-grid-column-one-third-from-desktop work-item-masthead__actions">
        <div class="work-item-masthead__actions-inner">
          @await Html.PartialAsync("~/Views/Modern/Raid/_RaidRiskDetailHeaderActions.cshtml", Model)
        </div>
      </div>
    </div>
    <div class="govuk-grid-row">
      <div class="govuk-grid-column-full">
        <div class="work-item-masthead__meta-wrap">
          <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed work-item-masthead__meta govuk-!-margin-bottom-0">
            <caption class="govuk-table__caption govuk-visually-hidden">Risk summary</caption>
            <thead class="govuk-table__head">
              <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header">Tier</th>
                <th scope="col" class="govuk-table__header">Risk rating</th>
                <th scope="col" class="govuk-table__header">Owner / Assigned to</th>
                <th scope="col" class="govuk-table__header">Proximity</th>
                <th scope="col" class="govuk-table__header">@riskDateColumnHeading</th>
              </tr>
            </thead>
            <tbody class="govuk-table__body">
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">
                  @if (Model.RiskTier != null)
                  {
                    <span class="@TierTagClass()">@TierBadgeDisplayText()</span>
                  }
                  else
                  {
                    <span class="govuk-hint govuk-!-margin-bottom-0">—</span>
                  }
                </td>
                <td class="govuk-table__cell">
                  <span class="@WorkBadgeCss.RaidRiskScoreDfeFrontendBadgeClass(score) dfe-f-u-tabular-numbers" aria-label="@riskScoreSrLabel"><span aria-hidden="true">@score</span></span>
                </td>
                <td class="govuk-table__cell">
                  @if (!string.IsNullOrWhiteSpace(ownerNameDisplay) && !string.IsNullOrWhiteSpace(ownerEmailForLink))
                  {
                    <a href="mailto:@ownerEmailForLink" class="govuk-link govuk-link--no-visited-state">@ownerNameDisplay</a>
                  }
                  else if (!string.IsNullOrWhiteSpace(ownerNameDisplay))
                  {
                    @ownerNameDisplay
                  }
                  else if (!string.IsNullOrWhiteSpace(ownerEmailForLink))
                  {
                    <a href="mailto:@ownerEmailForLink" class="govuk-link govuk-link--no-visited-state">@ownerEmailForLink</a>
                  }
                  else
                  {
                    <span class="govuk-hint govuk-!-margin-bottom-0">—</span>
                  }
                </td>
                <td class="govuk-table__cell">@riskProximityDisplay</td>
                <td class="govuk-table__cell">@riskDateColumnValue</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  @await Html.PartialAsync("~/Views/Modern/Shared/_PageDataAccessHint.cshtml")

  <div class="govuk-grid-row modern-work-detail-layout govuk-!-margin-top-4">
    <div class="govuk-grid-column-one-quarter-from-desktop modern-work-detail-layout__nav">
      <div class="dfe-f-u-sticky govuk-!-margin-bottom-4 modern-work-detail-layout__nav-inner" style="--dfe-f-sticky-top: 1rem;">
        <nav class="dfe-f-side-navigation modern-work-detail-side-nav" aria-label="Risk sections" data-module="dfe-f-side-navigation">
          <button type="button" class="dfe-f-side-navigation__toggle" aria-controls="raid-risk-side-nav-list" aria-expanded="false">Sections</button>
          <ul id="raid-risk-side-nav-list" class="dfe-f-side-navigation__list" hidden>
            <li class="dfe-f-side-navigation__item@(activeTab == "detail" ? " dfe-f-side-navigation__item--current" : "")">
              <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state" href="/modern/raid/risks/@Model.Id?tab=detail" id="tab-risk-detail"@if (activeTab == "detail") { <text> aria-current="page"</text> }>Risk detail</a>
            </li>
            <li class="dfe-f-side-navigation__item@(activeTab == "kris" ? " dfe-f-side-navigation__item--current" : "")">
              <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state" href="/modern/raid/risks/@Model.Id?tab=kris" id="tab-risk-kris"@if (activeTab == "kris") { <text> aria-current="page"</text> }>Key risk indicators</a>
            </li>
            <li class="dfe-f-side-navigation__item@(activeTab == "mitigations" ? " dfe-f-side-navigation__item--current" : "")">
              <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state" href="/modern/raid/risks/@Model.Id?tab=mitigations" id="tab-risk-mitigations"@if (activeTab == "mitigations") { <text> aria-current="page"</text> }>Mitigations</a>
            </li>
            <li class="dfe-f-side-navigation__item@(activeTab == "linked" ? " dfe-f-side-navigation__item--current" : "")">
              <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state" href="/modern/raid/risks/@Model.Id?tab=linked" id="tab-risk-linked"@if (activeTab == "linked") { <text> aria-current="page"</text> }>Linked records</a>
            </li>
            <li class="dfe-f-side-navigation__item@(activeTab == "history" ? " dfe-f-side-navigation__item--current" : "")">
              <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state" href="/modern/raid/risks/@Model.Id?tab=history" id="tab-risk-history"@if (activeTab == "history") { <text> aria-current="page"</text> }>Update history</a>
            </li>
          </ul>
        </nav>
      </div>
    </div>
    <div class="govuk-grid-column-three-quarters-from-desktop modern-work-detail-main">
      @{
        var riskScoreSrLabelDuplicate = $"Inherent risk score {score} out of {riskScoreMax}";
      }
      <div class="govuk-summary-card govuk-!-margin-top-0 raid-risk-detail-rating-card" hidden>
        <div class="govuk-summary-card__title-wrapper">
          <h2 class="govuk-summary-card__title">Current risk rating</h2>
        </div>
        <div class="govuk-summary-card__content">
          <div class="govuk-grid-row">
            <div class="govuk-grid-column-one-half">
              <p class="govuk-body-l govuk-!-margin-bottom-1 govuk-!-font-weight-bold" style="color:@ragBarFillHex;">@ratingLabel</p>
              <p class="govuk-body-s govuk-!-margin-bottom-0">@ScoreStripSub(Model)</p>
            </div>
            <div class="govuk-grid-column-one-half govuk-!-text-align-right-from-desktop">
              <span class="@WorkBadgeCss.RaidRiskScoreDfeFrontendBadgeClass(score) dfe-f-u-tabular-numbers" aria-label="@riskScoreSrLabel"><span aria-hidden="true">@score/@riskScoreMax</span></span>
            </div>
