                {
                  <text>—</text>
                }
                else
                {
                  @if (!string.IsNullOrWhiteSpace(Model.Response))
                  {
                    <p class="govuk-body govuk-!-margin-bottom-1"><strong>Treatment:</strong> @Model.Response</p>
                  }
                  @if (!string.IsNullOrWhiteSpace(Model.ResponseStrategy) || !string.IsNullOrWhiteSpace(Model.Notes))
                  {
                    <p class="govuk-body govuk-!-margin-bottom-0" style="white-space:pre-wrap;"><strong>Mitigation:</strong> @(Model.ResponseStrategy ?? Model.Notes)</p>
                  }
                }
              </dd>
              <dd class="govuk-summary-list__actions">
                <a class="govuk-link govuk-link--no-visited-state" href="@($"{riskEditUrl}#raid-risk-edit-mitigation")">Change<span class="govuk-visually-hidden"> treatment or mitigation</span></a>
              </dd>
