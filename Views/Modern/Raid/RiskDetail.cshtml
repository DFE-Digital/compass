                      <div style="font-weight:600;white-space:pre-wrap;">@a.Title</div>
                    </td>
                    <td class="govuk-table__cell">@ownerDisp</td>
                    <td class="govuk-table__cell">@dueDisp</td>
                    <td class="govuk-table__cell"><span class="dfe-c-tag dfe-c-tag--blue">@ef</span></td>
                    <td class="govuk-table__cell">
                      <a class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold" href="@Url.Action("MitigationEdit", "ModernRaid", new { riskId = Model.Id, actionId = a.Id })">Edit<span class="govuk-visually-hidden"> mitigation @mi</span></a>
                    </td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        }
        else
        {
          <p class="govuk-body">No mitigation actions yet. Use <strong>Add mitigation</strong> to record actions that reduce likelihood or impact.</p>
        }

        <script nonce="@cspNonce">
          (function () {
            var addBox = document.getElementById('raid-mit-add-form');
            var addBtn = document.getElementById('raid-mit-add-toggle');
            var addCancel = document.getElementById('raid-mit-add-cancel');
            function toggleAdd() {
              if (!addBox) return;
              addBox.style.display = addBox.style.display === 'none' || addBox.style.display === '' ? 'block' : 'none';
            }
            if (addBtn) addBtn.addEventListener('click', function (e) { e.preventDefault(); toggleAdd(); });
            if (addCancel) addCancel.addEventListener('click', function () { if (addBox) addBox.style.display = 'none'; });
          })();
        </script>
          </div>
        </div>
      </div>

      <div id="risk-linked" class="tab-pane @(activeTab == "linked" ? "on" : "")" role="tabpanel" aria-labelledby="tab-risk-linked">
        <div class="govuk-summary-card govuk-!-margin-top-4">
          <div class="govuk-summary-card__title-wrapper">
            <h2 class="govuk-summary-card__title">Linked records</h2>
            @if (riskLinkedAssocEditor)
            {
              <ul class="govuk-summary-card__actions">
                <li class="govuk-summary-card__action">
                  <a class="govuk-link govuk-link--no-visited-state" href="#" id="raid-linked-record-modal-open">Add linked record<span class="govuk-visually-hidden"> (opens in a dialog)</span></a>
                </li>
              </ul>
            }
          </div>
          <div class="govuk-summary-card__content">
        <div class="raid-linked-tab-stack">
          <p class="govuk-body govuk-!-margin-bottom-0">
            This tab shows how this risk is anchored in the register — its <strong>primary</strong> work item or FIPS product (if any), plus related issues and mitigations.@if (riskLinkedAssocEditor) {<text> Use <strong>Add linked record</strong> in the card header to set or change that primary link without opening the full edit screen.</text>}
          </p>
          @if (!string.IsNullOrWhiteSpace(assocScopeSentence))
          {
            <p class="govuk-body-s govuk-!-margin-bottom-0" style="color:#505a5f;">@assocScopeSentence</p>
          }

          <section aria-labelledby="risk-linked-primary-heading">
            <div class="dfe-c-flex--between govuk-!-margin-bottom-2" style="align-items:flex-start;flex-wrap:wrap;gap:0.75rem;">
              <h2 id="risk-linked-primary-heading" class="govuk-heading-s govuk-!-margin-bottom-0">Primary register link</h2>
              <a class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold govuk-body-s" href="@riskEditUrl">Open full edit risk form</a>
            </div>
            <p class="govuk-hint govuk-!-margin-top-0">Each risk has exactly one primary scope: one work item, one FIPS product, or organisation-wide (no specific record).</p>

            <div class="govuk-!-margin-bottom-3 raid-linked-record__tag-row">
              @if (riskAssocUi == "work" && wi.HasValue && Model.Project != null)
              {
                <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--blue">Work item</span>
                <span class="govuk-body-s govuk-!-margin-bottom-0" style="color:#505a5f;">Anchored to a delivery work item.</span>
              }
              else if (riskAssocUi == "product" && Model.PrimaryProductId.HasValue && Model.PrimaryProduct != null)
              {
                <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--teal">FIPS product</span>
                <span class="govuk-body-s govuk-!-margin-bottom-0" style="color:#505a5f;">Anchored to a service in the FIPS product register.</span>
              }
              else
              {
                <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--grey">Organisation-wide</span>
                <span class="govuk-body-s govuk-!-margin-bottom-0" style="color:#505a5f;">Not tied to a specific work item or product.</span>
              }
            </div>

            <div class="raid-linked-primary-stack">
              @if (riskAssocUi == "work" && wi.HasValue && Model.Project != null)
              {
                var wproj = Model.Project;
                var wPhase = wproj.PhaseLookup?.Name;
                var wRag = wproj.RagStatusLookup?.Name;
                <div class="raid-linked-record raid-linked-record--work">
                  <div class="raid-linked-record__grid">
                    <div class="raid-linked-record__main">
                      <div class="raid-linked-record__meta">Linked work item</div>
                      <div>
                        <a class="govuk-link govuk-link--no-visited-state raid-linked-record__title" href="@Url.Action("Detail", "ModernWork", new { id = wi.Value, tab = "risks" })">@wproj.Title</a><span class="raid-linked-record__ref">@wproj.ProjectCode</span>
                      </div>
                      @if (!string.IsNullOrWhiteSpace(wproj.Aim))
                      {
                        var aimTrim = wproj.Aim!.Length > 220 ? wproj.Aim[..220] + "…" : wproj.Aim;
                        <p class="raid-linked-record__aim govuk-!-margin-bottom-0">@aimTrim</p>
                      }
                      <div class="dfe-c-kv govuk-!-margin-top-2 govuk-!-margin-bottom-0" style="font-size:0.875rem;">
                        <div class="dfe-c-kv"><span class="dfe-c-kv__k">Business area</span><span class="dfe-c-kv__v">@(wproj.BusinessAreaLookup?.Name ?? teamLabel)</span></div>
                        <div class="dfe-c-kv"><span class="dfe-c-kv__k">Portfolio / group</span><span class="dfe-c-kv__v">@(wproj.PrimaryOrganizationalGroup?.Name ?? groupLabel)</span></div>
                        <div class="dfe-c-kv"><span class="dfe-c-kv__k">Work status</span><span class="dfe-c-kv__v"><span class="@WorkBadgeCss.StatusDfeFrontendBadgeClass(wproj.Status) dfe-f-badge--small">@((wproj.Status ?? "—").ToUpperInvariant())</span></span></div>
                        <div class="dfe-c-kv"><span class="dfe-c-kv__k">Target delivery</span><span class="dfe-c-kv__v">@(wproj.TargetDeliveryDate?.ToString("d MMM yyyy", CultureInfo.InvariantCulture) ?? "—")</span></div>
                        @if (wproj.DeliveryPriority != null)
                        {
                          <div class="dfe-c-kv"><span class="dfe-c-kv__k">Delivery priority</span><span class="dfe-c-kv__v"><span class="@WorkBadgeCss.PriorityDfeFrontendBadgeClass(wproj.DeliveryPriority.Name) dfe-f-badge--small">@wproj.DeliveryPriority.Name.ToUpperInvariant()</span></span></div>
                        }
                      </div>
                    </div>
                    <div class="raid-linked-record__aside raid-linked-record__tag-row">
                      @if (!string.IsNullOrWhiteSpace(wPhase))
                      {
                        <span class="@WorkBadgeCss.PhaseDfeFrontendBadgeClass(wPhase) dfe-f-badge--small">@wPhase.ToUpperInvariant()</span>
                      }
                      @if (!string.IsNullOrWhiteSpace(wRag))
                      {
                        <span class="@WorkBadgeCss.RagCompactBadgeClass(wRag)">@wRag.ToUpperInvariant()</span>
                      }
                    </div>
                  </div>
                </div>
              }
              else if (riskAssocUi == "work" && wi.HasValue)
              {
                <p class="govuk-body govuk-!-margin-bottom-0">Work item ID @wi.Value is stored on this risk, but details could not be loaded.</p>
              }

              @if (riskAssocUi == "product" && Model.PrimaryProductId.HasValue && Model.PrimaryProduct != null)
              {
                var svc = Model.PrimaryProduct;
                var prodTitle = !string.IsNullOrWhiteSpace(linkedCmdbProductTitle) ? linkedCmdbProductTitle! : (svc.DisplayName ?? svc.FipsId);
                var prodPhase = linkedCmdbPhaseName;
                var prodRef = string.IsNullOrWhiteSpace(svc.FipsId)
                  ? $"SRV-{svc.ServiceId}"
                  : (svc.FipsId.StartsWith("FIPS-", StringComparison.OrdinalIgnoreCase) ? svc.FipsId : $"FIPS-{svc.FipsId}");
                var prodHref = linkedCmdbProductId is Guid pg
                  ? Url.Action("FipsProduct", "ModernManage", new { id = pg }) ?? "#"
                  : null;
                <div class="raid-linked-record raid-linked-record--product">
                  <div class="raid-linked-record__grid">
                    <div class="raid-linked-record__main">
                      <div class="raid-linked-record__meta">Linked FIPS product</div>
                      <div>
                        @if (prodHref != null)
                        {
                          <a class="govuk-link govuk-link--no-visited-state raid-linked-record__title" href="@prodHref">@prodTitle</a>
                        }
                        else
                        {
                          <span class="raid-linked-record__title">@prodTitle</span>
                        }
                        <span class="raid-linked-record__ref">@prodRef</span>
                      </div>
                      <div class="dfe-c-kv govuk-!-margin-top-2 govuk-!-margin-bottom-0" style="font-size:0.875rem;">
                        <div class="dfe-c-kv"><span class="dfe-c-kv__k">Service register</span><span class="dfe-c-kv__v">@(linkedCmdbProductId.HasValue ? "Linked to CMDB product" : "Service row — enrich from FIPS register where available")</span></div>
                        <div class="dfe-c-kv"><span class="dfe-c-kv__k">Active</span><span class="dfe-c-kv__v"><span class="@(svc.IsActive ? "dfe-f-badge dfe-f-badge--small dfe-f-badge--green" : "dfe-f-badge dfe-f-badge--small dfe-f-badge--grey")">@(svc.IsActive ? "YES" : "NO")</span></span></div>
                      </div>
                    </div>
                    <div class="raid-linked-record__aside raid-linked-record__tag-row">
                      @if (!string.IsNullOrWhiteSpace(prodPhase))
                      {
                        <span class="@WorkBadgeCss.PhaseDfeFrontendBadgeClass(prodPhase) dfe-f-badge--small">@prodPhase.ToUpperInvariant()</span>
                      }
                      else
                      {
                        <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--grey">Phase not set</span>
                      }
                    </div>
                  </div>
                </div>
              }

              @if (riskAssocUi == "organisation")
              {
                <div class="raid-linked-record raid-linked-record--muted govuk-!-margin-bottom-0">
                  <p class="govuk-body govuk-!-margin-bottom-0">This risk is <strong>organisation-wide</strong> — it is not scoped to a single work item or product.@if (riskLinkedAssocEditor) {<text> Use <strong>Add linked record</strong> in the card header if you need to attach a work item or product.</text>}</p>
                </div>
              }
            </div>

          </section>

          @if (riskLinkedAssocEditor)
          {
            <dialog id="raid-linked-record-modal"
                    class="dfe-f-modal govuk-!-margin-0 raid-linked-record-modal"
                    data-module="dfe-f-modal"
                    aria-labelledby="raid-linked-record-modal-title"
                    aria-describedby="raid-linked-record-modal-desc"
                    aria-modal="true"
                    role="dialog">
              <div class="dfe-f-modal__panel">
                <header class="dfe-f-modal__header">
                  <h2 id="raid-linked-record-modal-title" class="govuk-heading-m dfe-f-modal__title">Add linked record</h2>
                  <button type="button" class="dfe-f-modal__close" data-dfe-modal-close aria-label="Close">
                    <span class="dfe-f-modal__close-x" aria-hidden="true">×</span>
                  </button>
                </header>
                <div class="dfe-f-modal__body" id="raid-linked-record-modal-desc">
                  <p class="govuk-body">Choose one primary scope, then save. This replaces the current primary link.</p>
                  <form method="post" action="@riskAssocUpdateUrl" class="govuk-!-margin-bottom-0">
                    @Html.AntiForgeryToken()
                    <div class="govuk-form-group govuk-!-margin-bottom-4" id="raid-risk-linked-association">
                      <fieldset class="govuk-fieldset" aria-describedby="raid-risk-linked-association-hint">
                        <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Associate this risk with</legend>
                        <div id="raid-risk-linked-association-hint" class="govuk-hint">Work item, FIPS product, or organisation-wide.</div>
                        <div class="govuk-radios" data-module="govuk-radios">
                          <div class="govuk-radios__item">
                            <input class="govuk-radios__input" id="raid-risk-linked-assoc-work" name="AssociationKind" type="radio" value="work" data-aria-controls="conditional-raid-risk-linked-assoc-work" @(riskAssocUi == "work" ? "checked" : null) />
                            <label class="govuk-label govuk-radios__label" for="raid-risk-linked-assoc-work">Work item</label>
                          </div>
                          <div class="govuk-radios__conditional@(riskAssocUi != "work" ? " govuk-radios__conditional--hidden" : null)" id="conditional-raid-risk-linked-assoc-work">
                            <div class="govuk-form-group govuk-!-margin-bottom-0">
                              <label class="govuk-label" for="raid-risk-linked-ProjectId">Work item</label>
                              <select class="govuk-select govuk-!-width-full" id="raid-risk-linked-ProjectId" name="ProjectId">
                                <option value="">— Select —</option>
                                @foreach (var o in linkPj)
                                {
                                  if (Model.ProjectId == o.Id) { <option value="@o.Id" selected>@o.Name</option> }
                                  else { <option value="@o.Id">@o.Name</option> }
                                }
                              </select>
                            </div>
                          </div>

                          <div class="govuk-radios__item">
                            <input class="govuk-radios__input" id="raid-risk-linked-assoc-product" name="AssociationKind" type="radio" value="product" data-aria-controls="conditional-raid-risk-linked-assoc-product" @(riskAssocUi == "product" ? "checked" : null) />
                            <label class="govuk-label govuk-radios__label" for="raid-risk-linked-assoc-product">Product (FIPS)</label>
                          </div>
                          <div class="govuk-radios__conditional@(riskAssocUi != "product" ? " govuk-radios__conditional--hidden" : null)" id="conditional-raid-risk-linked-assoc-product">
                            <div class="govuk-form-group govuk-!-margin-bottom-0">
                              <label class="govuk-label" for="raid-risk-linked-PrimaryProductId">FIPS product</label>
                              <select class="govuk-select govuk-!-width-full" id="raid-risk-linked-PrimaryProductId" name="PrimaryProductId">
                                <option value="">— Select —</option>
                                @foreach (var o in linkFp)
                                {
                                  if (Model.PrimaryProductId == o.Id) { <option value="@o.Id" selected>@o.Name</option> }
                                  else { <option value="@o.Id">@o.Name</option> }
                                }
                              </select>
                            </div>
                          </div>

                          <div class="govuk-radios__item">
                            <input class="govuk-radios__input" id="raid-risk-linked-assoc-org" name="AssociationKind" type="radio" value="organisation" data-aria-controls="conditional-raid-risk-linked-assoc-org" @(riskAssocUi == "organisation" ? "checked" : null) />
                            <label class="govuk-label govuk-radios__label" for="raid-risk-linked-assoc-org">Organisation-wide</label>
                          </div>
                          <div class="govuk-radios__conditional@(riskAssocUi != "organisation" ? " govuk-radios__conditional--hidden" : null)" id="conditional-raid-risk-linked-assoc-org">
                            <div class="govuk-form-group govuk-!-margin-bottom-0">
                              <div class="govuk-inset-text govuk-!-margin-bottom-0">No work item or product. Use for cross-cutting risks (people, funding, policy, etc.).</div>
                            </div>
                          </div>
                        </div>
                      </fieldset>
                    </div>
                    <div class="govuk-button-group govuk-!-margin-bottom-0">
                      <button type="submit" class="govuk-button" data-module="govuk-button">Save primary link</button>
                      <button type="button" class="govuk-button govuk-button--secondary" data-dfe-modal-close>Cancel</button>
                    </div>
                  </form>

                  @if (riskAssocUi != "organisation")
                  {
                    <form method="post" action="@riskAssocUpdateUrl" class="govuk-!-margin-top-4 govuk-!-padding-top-4" style="border-top:1px solid #b1b4b6;">
                      @Html.AntiForgeryToken()
                      <input type="hidden" name="AssociationKind" value="organisation" />
                      <p class="govuk-body-s govuk-!-margin-bottom-2">Remove the work item or product link and mark this risk as organisation-wide.</p>
                      <button type="submit" class="govuk-button govuk-button--warning">Remove primary link</button>
                    </form>
                  }
                </div>
              </div>
            </dialog>
            <script nonce="@cspNonce">
              (function () {
                var dlg = document.getElementById('raid-linked-record-modal');
                var openL = document.getElementById('raid-linked-record-modal-open');
                function initDfe() {
                  if (window.DfeFrontend && typeof window.DfeFrontend.initAll === 'function') {
                    window.DfeFrontend.initAll();
                  }
                }
                if (openL && dlg instanceof HTMLDialogElement && typeof dlg.showModal === 'function') {
                  openL.addEventListener('click', function (e) {
                    e.preventDefault();
                    if (!dlg.open) {
                      dlg.showModal();
                      initDfe();
                    }
                  });
                }
              })();
            </script>
          }

          @if (linkedIssues.Any())
          {
            <section aria-labelledby="risk-linked-issues-heading">
              <h2 id="risk-linked-issues-heading" class="govuk-heading-s govuk-!-margin-bottom-2">Linked issues (@linkedIssues.Count)</h2>
              <div class="raid-linked-record-list">
                @foreach (var issue in linkedIssues)
                {
                  var st = issue.Status ?? "";
                  var sev = issue.Severity;
                  var pri = issue.Priority;
                  var issueStatusClosed = st.Contains("closed", StringComparison.OrdinalIgnoreCase) || st.Contains("resolved", StringComparison.OrdinalIgnoreCase);
                  var issueEscalated = st.Contains("escalat", StringComparison.OrdinalIgnoreCase);
                  <div class="raid-linked-record raid-linked-record--issue">
                    <div class="raid-linked-record__grid">
                      <div class="raid-linked-record__main">
                        <div class="raid-linked-record__meta">Issue · @issue.LinkRelationship</div>
                        <div>
                          <a class="govuk-link govuk-link--no-visited-state raid-linked-record__title" href="@(Url.Action("IssueDetail", "ModernRaid", new { id = issue.Id }) ?? "#")">@issue.Title</a><span class="raid-linked-record__ref">I-@(issue.Id.ToString("D4"))</span>
                        </div>
                        <div class="raid-linked-record__tag-row govuk-!-margin-top-2">
                          @if (!string.IsNullOrWhiteSpace(sev))
                          {
                            <span class="@WorkBadgeCss.RaidSeverityLabelDfeFrontendBadgeClass(sev) dfe-f-badge--small">@sev.ToUpperInvariant()</span>
                          }
                          @if (!string.IsNullOrWhiteSpace(pri))
                          {
                            <span class="@WorkBadgeCss.RaidPriorityLabelDfeFrontendBadgeClass(pri) dfe-f-badge--small">@pri.ToUpperInvariant()</span>
                          }
                          <span class="govuk-body-s govuk-!-margin-bottom-0" style="color:#505a5f;">Updated @issue.UpdatedAt.ToString("d MMM yyyy", CultureInfo.InvariantCulture)</span>
                        </div>
                      </div>
                      <div class="raid-linked-record__aside raid-linked-record__tag-row">
                        @if (issueEscalated)
                        {
                          <span class="dfe-f-badge dfe-f-badge--small dfe-f-badge--red">@(string.IsNullOrWhiteSpace(st) ? "—" : st.ToUpperInvariant())</span>
                        }
                        else
                        {
                          <span class="@WorkBadgeCss.RaidOpenClosedDfeFrontendBadgeClass(issueStatusClosed) dfe-f-badge--small">@(string.IsNullOrWhiteSpace(st) ? "—" : st.ToUpperInvariant())</span>
                        }
                      </div>
                    </div>
                  </div>
                }
              </div>
            </section>
          }

          <section aria-labelledby="risk-linked-actions-heading">
            <h2 id="risk-linked-actions-heading" class="govuk-heading-s govuk-!-margin-bottom-2">Mitigation actions (@mitigationRows.Count)</h2>
            @if (mitigationRows.Count > 0)
            {
              <div class="raid-linked-record-list">
                @foreach (var ra in mitigationRows)
                {
                  var act = ra.Action!;
                  var due = act.DueDate?.ToString("d MMM yyyy", CultureInfo.InvariantCulture) ?? "—";
                  var progDisp = MitigationEffectiveSelectValue(act);
                  <div class="raid-linked-record raid-linked-record--mitigation">
                    <div class="raid-linked-record__grid">
                      <div class="raid-linked-record__main">
                        <div class="raid-linked-record__meta">Mitigation action</div>
                        <div>
                          <span class="raid-linked-record__title">@act.Title</span><span class="raid-linked-record__ref">A-@(act.Id.ToString("D4"))</span>
                        </div>
                        <div class="raid-linked-record__tag-row govuk-!-margin-top-2">
                          <span class="@MitigationProgressBadgeClass(progDisp)">@progDisp.ToUpperInvariant()</span>
                          <span class="govuk-body-s govuk-!-margin-bottom-0" style="color:#505a5f;">Due @due · @act.ProgressPercent%</span>
                        </div>
                      </div>
                      <div class="raid-linked-record__aside">
                        <a class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold" href="@Url.Action("MitigationEdit", "ModernRaid", new { riskId = Model.Id, actionId = act.Id })">Edit<span class="govuk-visually-hidden"> mitigation</span></a>
                      </div>
                    </div>
                  </div>
                }
              </div>
              <p class="govuk-body-s govuk-!-margin-top-3 govuk-!-margin-bottom-0">
                <a class="govuk-link govuk-link--no-visited-state" href="@mitigationsTabUrl">Edit actions on the Mitigations tab</a>
              </p>
            }
            else
            {
              <p class="govuk-body-s govuk-!-margin-bottom-0" style="color:var(--grey-4);">No mitigation actions are linked yet.</p>
            }
          </section>

          @if (hasClassification)
          {
            <section aria-labelledby="risk-linked-class-heading">
              <h2 id="risk-linked-class-heading" class="govuk-heading-s govuk-!-margin-bottom-2">Classification and governance</h2>
              <div class="raid-linked-record raid-linked-record--muted">
                <div class="dfe-c-kv govuk-!-margin-bottom-0" style="font-size:0.875rem;">
                  @if (riskCatLabels.Count > 0)
                  {
                    <div class="dfe-c-kv"><span class="dfe-c-kv__k">Risk categories</span><span class="dfe-c-kv__v">@string.Join(", ", riskCatLabels.Where(x => !string.IsNullOrWhiteSpace(x)))</span></div>
                  }
                  @if (divRegisterLabels.Count > 0)
                  {
                    <div class="dfe-c-kv"><span class="dfe-c-kv__k">Divisions</span><span class="dfe-c-kv__v">@string.Join(", ", divRegisterLabels.Where(x => !string.IsNullOrWhiteSpace(x)))</span></div>
                  }
                  @if (baRegisterLabels.Count > 0)
                  {
                    <div class="dfe-c-kv"><span class="dfe-c-kv__k">Business areas</span><span class="dfe-c-kv__v">@string.Join(", ", baRegisterLabels.Where(x => !string.IsNullOrWhiteSpace(x)))</span></div>
                  }
                  @if (Model.GovernanceBoard != null)
                  {
                    <div class="dfe-c-kv"><span class="dfe-c-kv__k">Governance board</span><span class="dfe-c-kv__v">@Model.GovernanceBoard.Label</span></div>
                  }
                </div>
              </div>
            </section>
          }

          @{
            var hasAssoc = wi.HasValue || (Model.PrimaryProductId.HasValue && Model.PrimaryProduct != null);
            var anythingLinked = hasAssoc || linkedIssues.Any() || mitigationRows.Count > 0 || hasClassification;
          }
          @if (!anythingLinked)
          {
            <p class="govuk-body govuk-!-margin-bottom-0">Nothing is linked to this risk yet@if (riskLinkedAssocEditor) {<text> — use <strong>Add linked record</strong> in the card header to set the primary scope, or </text>} else {<text>. </text>}<a class="govuk-link govuk-link--no-visited-state" href="@riskEditUrl">Edit risk</a>@if (riskLinkedAssocEditor) {<text> for other fields</text>}, or attach mitigation actions from the Mitigations tab.</p>
          }
        </div>
          </div>
        </div>
      </div>

      <div id="risk-history" class="tab-pane @(activeTab == "history" ? "on" : "")" role="tabpanel" aria-labelledby="tab-risk-history">
        <div class="govuk-summary-card govuk-!-margin-top-4">
          <div class="govuk-summary-card__title-wrapper">
            <h2 class="govuk-summary-card__title">Update history</h2>
          </div>
          <div class="govuk-summary-card__content">
        @if (riskHistory.Count > 0)
        {
          <ol class="dfe-f-timeline govuk-!-margin-0 raid-risk-history__timeline">
            @foreach (var h in riskHistory)
            {
              var whenIso = h.WhenUtc.Kind == DateTimeKind.Utc
                ? h.WhenUtc.ToString("yyyy-MM-dd'T'HH:mm:ss'Z'", CultureInfo.InvariantCulture)
                : h.WhenUtc.ToString("yyyy-MM-dd'T'HH:mm:ss", CultureInfo.InvariantCulture);
              var whenDisplay = h.WhenUtc.ToString("d MMM yyyy HH:mm", CultureInfo.InvariantCulture);
              var liClass = "dfe-f-timeline__item" + (h.IsAlert ? " raid-risk-history__timeline-item--alert" : "");
              <li class="@liClass">
                <h3 class="govuk-heading-s dfe-f-timeline__title">@h.What</h3>
                <p class="dfe-f-timeline__meta govuk-body-s govuk-!-margin-bottom-0">
                  <time datetime="@whenIso">@whenDisplay</time>@if (!string.IsNullOrWhiteSpace(h.ActorDisplay)) {<text> · @h.ActorDisplay</text>}
                </p>
                @if (!string.IsNullOrWhiteSpace(h.Detail))
                {
                  <p class="govuk-body raid-risk-history__timeline-detail govuk-!-margin-top-2 govuk-!-margin-bottom-0">@h.Detail</p>
                }
              </li>
            }
          </ol>
        }
        else
        {
          <p class="govuk-body">No recorded updates yet. Changes appear here after you save edits to this risk or its mitigation actions (audit logging must be enabled).</p>
        }
        <p class="govuk-body-s govuk-!-margin-top-4 govuk-!-margin-bottom-0 raid-risk-history__footnote">
          Latest save: @Model.UpdatedAt.ToString("d MMM yyyy HH:mm", CultureInfo.InvariantCulture) UTC · Created @Model.CreatedAt.ToString("d MMM yyyy HH:mm", CultureInfo.InvariantCulture) UTC
        </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
</div>
