@model Compass.ViewModels.Modern.RaidRegisterRelationParts
@using Compass.ViewModels.Modern
@{
  string? kindLabel = Model.Kind switch
  {
    RaidRegisterRelationKinds.Organisation => "Organisation",
    RaidRegisterRelationKinds.Work => "Work item",
    RaidRegisterRelationKinds.Fips => "Service",
    _ => null
  };

  var targetName = (Model.RelatedTitle ?? Model.Target ?? "").Trim();
  var hasViewLink = !string.IsNullOrEmpty(Model.LinkHref)
    && Model.Kind != RaidRegisterRelationKinds.Organisation
    && Model.Kind != RaidRegisterRelationKinds.Unknown
    && !string.IsNullOrEmpty(targetName);
}
<td class="govuk-table__cell govuk-body-s raid-ss-relation-cell"
    data-type="relation"
    data-association-kind="@(Model.AssociationUiKind ?? "")"
    data-project-id="@(Model.ProjectId?.ToString() ?? "")"
    data-primary-product-id="@(Model.PrimaryProductId?.ToString() ?? "")"
    data-relation-kind="@Model.Kind"
    data-relation-source="@(Model.SourceLabel ?? "")"
    data-relation-title="@(Model.RelatedTitle ?? Model.Target ?? "")"
    data-relation-description="@(Model.RelatedDescription ?? "")"
    data-relation-href="@(Model.LinkHref ?? "")">
  <div class="raid-ss-relation-cell__content">
    @if (!string.IsNullOrEmpty(kindLabel))
    {
      <span class="raid-ss-relation-kind">@kindLabel</span>
    }
    @if (hasViewLink)
    {
      <a class="govuk-link govuk-link--no-visited-state raid-ss-relation-item-link"
         href="@Model.LinkHref"
         target="_blank"
         rel="noopener noreferrer"
         aria-label="View @targetName (opens in new tab)">@targetName</a>
    }
    else if (Model.Kind == RaidRegisterRelationKinds.Organisation)
    {
      <span class="raid-ss-relation-org-label">Not linked to a work item or service</span>
    }
    else if (!string.IsNullOrEmpty(targetName))
    {
      <span class="raid-ss-relation-name">@targetName</span>
    }
    else
    {
      <span class="raid-ss-relation-empty">—</span>
    }
    <div class="raid-ss-relation-actions">
      <button type="button"
              class="govuk-link govuk-body-s raid-ss-relation-change-btn"
              aria-label="Change related item">Change</button>
    </div>
  </div>
</td>
