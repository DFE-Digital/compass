@model Compass.ViewModels.Modern.RaidRegisterRelationParts
<td class="govuk-body-s">
@if (Model.Kind == RaidRegisterRelationKinds.Organisation)
{
  <span>Organisation</span>
}
else if (Model.Kind == RaidRegisterRelationKinds.Work)
{
  <span>Work</span>
  @if (Model.ProjectId.HasValue && !string.IsNullOrEmpty(Model.Target))
  {
    <span> · </span>
    <a class="govuk-link" href="@Url.Action("Detail", "ModernWork", new { id = Model.ProjectId.Value, tab = "risks" })">@Model.Target</a>
  }
  else if (!string.IsNullOrEmpty(Model.Target))
  {
    <span> · @Model.Target</span>
  }
}
else if (Model.Kind == RaidRegisterRelationKinds.Fips)
{
  <span>FIPS</span>
  @if (!string.IsNullOrEmpty(Model.Target))
  {
    <span> · @Model.Target</span>
  }
}
else
{
  <span class="dfe-c-text-muted">—</span>
}
</td>
