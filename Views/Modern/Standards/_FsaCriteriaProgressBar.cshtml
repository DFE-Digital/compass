@model (int Answered, int Total)
@{
  var answered = Model.Answered;
  var total = Model.Total;
  var pct = total > 0 ? (int)Math.Round(100.0 * answered / total) : 0;
  var valueText = $"{answered} of {total} criteria assessed ({pct} percent)";
}
<div class="fsa-progress-bar fsa-progress-bar--compact">
  <div class="fsa-progress-bar__track"
       role="progressbar"
       aria-valuemin="0"
       aria-valuemax="@total"
       aria-valuenow="@answered"
       aria-valuetext="@valueText">
    <div class="fsa-progress-bar__fill" style="width:@(pct)%"></div>
  </div>
  <p class="fsa-progress-bar__summary govuk-body-s govuk-!-margin-bottom-0 govuk-!-margin-top-1">
    <span class="dfe-f-u-tabular-numbers">@answered</span> / <span class="dfe-f-u-tabular-numbers">@total</span>
    <span class="govuk-visually-hidden">criteria assessed</span>
    (<span class="dfe-f-u-tabular-numbers">@pct</span>%)
  </p>
</div>
