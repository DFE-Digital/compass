@model Compass.ViewModels.Modern.DdtStandardWorkflowContextViewModel
@{
  var steps = new[] { "Draft", "In review", "Approved", "Published" };
}
<div class="demand-workflow dfe-c-mb-4" aria-label="Standard publication workflow">
  <div class="demand-workflow__track">
    @for (var i = 0; i < steps.Length; i++)
    {
      var done = i < Model.WorkflowStepIndex;
      var current = i == Model.WorkflowStepIndex;
      <div class="demand-workflow__step @(done ? "demand-workflow__step--done" : "") @(current ? "demand-workflow__step--current" : "")">
        <span class="demand-workflow__dot" aria-hidden="true"></span>
        <span class="demand-workflow__label">@steps[i]</span>
      </div>
      @if (i < steps.Length - 1)
      {
        <div class="demand-workflow__join @(done ? "demand-workflow__join--done" : "")" aria-hidden="true"></div>
      }
    }
  </div>
</div>
