@model Compass.ViewModels.Modern.FunctionalStandardsLandingViewModel
@using Compass.ViewModels.Modern
@{
  ViewData["Title"] = "Functional standards";
  var rows = Model?.Standards ?? new List<Compass.ViewModels.Modern.FunctionalStandardLandingRow>();
  var inProgress = Model?.InProgressAssessments ?? new List<Compass.ViewModels.Modern.FunctionalStandardInProgressRow>();
  var completed = Model?.CompletedAssessments ?? new List<Compass.ViewModels.Modern.FunctionalStandardCompletedAssessmentRow>();
  var tab = string.IsNullOrWhiteSpace(Model?.Tab) ? "in-progress" : Model!.Tab;
  var canStartNewAssessment = rows.Any(r => r.ContinueAssessmentId == null);
}

@functions {
  string TabCount(int count) => count > 0 ? $" ({count})" : "";
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernStandards")">Standards</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Functional standards</li>
}

@{
  var fsLandingLede = await Html.PartialAsync("_GovukBodyParagraph", "HM Government functional standards applicable to DDT — with assessment records");
  Microsoft.AspNetCore.Html.IHtmlContent? fsLandingActions = null;
  if (rows.Any() && canStartNewAssessment)
  {
    fsLandingActions = await Html.PartialAsync("_FunctionalStandardsStartAssessmentButton");
  }
}
@await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
  Caption = "Standards",
  Title = "Functional standards",
  Lede = fsLandingLede,
  Actions = fsLandingActions,
  ConstrainToTwoThirds = true
})

<div class="govuk-grid-row govuk-!-margin-bottom-3">
  <div class="govuk-grid-column-two-thirds">
    <div class="dfe-c-callout dfe-c-callout--info govuk-!-margin-bottom-0">
      <div class="dfe-c-callout__heading">About functional standards</div>
      <p class="dfe-c-callout__body">HM Government functional standards set expectations for how government departments manage and run their functions. Departments must assess against applicable standards and maintain evidence of compliance. These are set centrally by Cabinet Office.</p>
    </div>
  </div>
</div>

<nav class="dfe-f-sub-navigation govuk-!-margin-bottom-4" aria-label="Functional standards views">
  <ul class="dfe-f-sub-navigation__list">
    <li class="dfe-f-sub-navigation__item">
      <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" href="@Url.Action("FunctionalStandards", "ModernStandards", new { tab = "in-progress" })"@if (tab == "in-progress") { <text> aria-current="page"</text> }>In progress<span class="dfe-c-fw-regular">@TabCount(inProgress.Count)</span></a>
    </li>
    <li class="dfe-f-sub-navigation__item">
      <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" href="@Url.Action("FunctionalStandards", "ModernStandards", new { tab = "completed" })"@if (tab == "completed") { <text> aria-current="page"</text> }>Completed<span class="dfe-c-fw-regular">@TabCount(completed.Count)</span></a>
    </li>
    <li class="dfe-f-sub-navigation__item">
      <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" href="@Url.Action("FunctionalStandards", "ModernStandards", new { tab = "all" })"@if (tab == "all") { <text> aria-current="page"</text> }>All standards<span class="dfe-c-fw-regular">@TabCount(rows.Count)</span></a>
    </li>
  </ul>
</nav>

<div id="d-fs-in-progress" class="tab-pane @(tab =="in-progress" ? "on" : "")" role="tabpanel" aria-label="Assessments in progress">
  @if (!inProgress.Any())
  {
 <p class="dfe-c-body muted">No assessments are in progress.</p>
  }
  else
  {
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
      <table class="govuk-table">
 <caption class="govuk-visually-hidden">Assessments in progress</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">Assessment</button>
            </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">Standard</button>
            </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">Started</button>
            </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">Progress</button>
            </th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
        @foreach (var a in inProgress)
        {
          var conductHref = Url.Action("ConductAssessment", "ModernStandards", new { assessmentId = a.AssessmentId }) ?? "#";
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">
              <a class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold" href="@conductHref">@a.AssessmentName</a>
            </td>
            <td class="govuk-table__cell">@a.StandardTitle</td>
            <td class="govuk-table__cell">@a.AssessmentDate.ToString("d MMM yyyy")</td>
            <td class="govuk-table__cell">
              @await Html.PartialAsync("~/Views/Modern/Standards/_FsaCriteriaProgressBar.cshtml", (a.CriteriaAnswered, a.CriteriaTotal))
            </td>
          </tr>
        }
        </tbody>
      </table>
    </div>
  }
</div>

<div id="d-fs-completed" class="tab-pane @(tab =="completed" ? "on" : "")" role="tabpanel" aria-label="Completed assessments">
  @if (!completed.Any())
  {
 <p class="dfe-c-body muted">No completed assessments yet.</p>
  }
  else
  {
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
      <table class="govuk-table">
 <caption class="govuk-visually-hidden">Completed assessments</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">Standard</button>
            </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">Assessment</button>
            </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">Started</button>
            </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">Submitted</button>
            </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">Criteria</button>
            </th>
            <th scope="col" class="govuk-table__header govuk-!-text-align-right">
              <span class="govuk-visually-hidden">Actions</span>
            </th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
        @foreach (var a in completed)
        {
          var criteriaLabel = $"{a.CriteriaAnswered} / {a.CriteriaTotal}";
          <tr class="govuk-table__row">
            <td class="govuk-table__cell"><strong>@a.StandardTitle</strong></td>
            <td class="govuk-table__cell">@a.AssessmentName</td>
            <td class="govuk-table__cell">@a.AssessmentDate.ToString("d MMM yyyy")</td>
            <td class="govuk-table__cell">@a.SubmittedAt.ToString("d MMM yyyy")</td>
            <td class="govuk-table__cell">@criteriaLabel</td>
 <td class="govuk-table__cell govuk-!-text-align-right"><a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("AssessmentSummary", "ModernStandards", new { assessmentId = a.AssessmentId })">View summary</a></td>
          </tr>
        }
        </tbody>
      </table>
    </div>
  }
</div>

<div id="d-fs-all" class="tab-pane @(tab =="all" ? "on" : "")" role="tabpanel" aria-label="All functional standards">
 <section id="standards-list" class="fs-functional-standards-anchor" aria-labelledby="fs-all-standards-heading">
 <h2 id="fs-all-standards-heading" class="govuk-heading-m govuk-!-margin-bottom-2">All standards</h2>
    @if (!rows.Any())
    {
 <p class="dfe-c-body muted">No functional standards are configured yet.</p>
    }
    else
    {
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
        <table class="govuk-table">
 <caption class="govuk-visually-hidden">Functional standards</caption>
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header" aria-sort="none">
                <button type="button" class="dfe-f-table-sort-button">Standard</button>
              </th>
              <th scope="col" class="govuk-table__header" aria-sort="none">
                <button type="button" class="dfe-f-table-sort-button">Summary</button>
              </th>
              @await Html.PartialAsync("_SortableThNumeric", "Themes")
              @await Html.PartialAsync("_SortableThNumeric", "Criteria")
            </tr>
          </thead>
          <tbody class="govuk-table__body">
          @foreach (var row in rows)
          {
            <tr class="govuk-table__row">
 <td class="govuk-table__cell"><strong><a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("FunctionalStandardDashboard", "ModernStandards", new { id = row.Id })">@row.Title</a></strong></td>
              <td class="govuk-table__cell">
                @if (!string.IsNullOrWhiteSpace(row.Description))
                {
                  var shortDesc = row.Description.Length > 160 ? row.Description[..160].TrimEnd() + "…" : row.Description;
 <span class="govuk-body-s">@shortDesc</span>
                }
                else
                {
 <span class="govuk-body-s govuk-hint govuk-!-margin-bottom-0">@row.ThemeCount theme(s), @row.CriteriaCount criteria</span>
                }
              </td>
              <td class="govuk-table__cell govuk-table__cell--numeric dfe-f-u-tabular-numbers">@row.ThemeCount</td>
              <td class="govuk-table__cell govuk-table__cell--numeric dfe-f-u-tabular-numbers">@row.CriteriaCount</td>
            </tr>
          }
          </tbody>
        </table>
      </div>
    }
  </section>
</div>

@if (rows.Any() && canStartNewAssessment)
{
 <dialog id="dlg-fs-landing-start-assessment" class="dfe-c-dialog">
 <div class="dfe-c-dialog__content">
 <h2 class="govuk-heading-m">Start new assessment</h2>
 <p class="govuk-body">Choose the standard and a name for this assessment run.</p>
      <form method="post" action="@Url.Action("StartAssessment", "ModernStandards")">
        @Html.AntiForgeryToken()
 <div class="govuk-form-group">
 <label class="govuk-label" for="landing-fs-standard">Functional standard</label>
 <select class="govuk-select" id="landing-fs-standard" name="standardId" required>
            <option value="">Select a standard…</option>
            @foreach (var r in rows.Where(x => x.ContinueAssessmentId == null))
            {
              <option value="@r.Id">@r.Title</option>
            }
          </select>
        </div>
 <div class="govuk-form-group">
 <label class="govuk-label" for="landing-assessment-name">Assessment name</label>
 <span class="govuk-hint">For example, Q2 2026 self-assessment</span>
 <input class="govuk-input" id="landing-assessment-name" name="assessmentName" type="text" required maxlength="200" autocomplete="off" />
        </div>
 <div class="dfe-c-dialog__actions">
 <button type="submit" class="govuk-button">Start assessment</button>
 <button type="button" class="govuk-button govuk-button--secondary" data-modal-close="dlg-fs-landing-start-assessment">Cancel</button>
        </div>
      </form>
    </div>
  </dialog>
}

<style>
  .fs-functional-standards-anchor { scroll-margin-top: 6.5rem; }
  .dfe-c-dialog { border: none; border-radius: 4px; padding: 1.5rem; max-width: 32rem; box-shadow: 0 4px 24px rgba(0,0,0,0.25); }
  .dfe-c-dialog::backdrop { background: rgba(0,0,0,0.5); }
  .dfe-c-dialog__actions { display: flex; gap: 0.5rem; margin-top: 1rem; flex-wrap: wrap; }
</style>
