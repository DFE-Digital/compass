@model Compass.ViewModels.Modern.StandardsManagementViewModel
@{
  ViewData["Title"] = "Standards management";
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernStandards")">Standards</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Management</li>
}

<div class="dfe-c-page-title">
 <div class="dfe-c-page-title__caption">Standards</div>
 <h1 class="dfe-c-page-title__heading">Standards management</h1>
 <p class="dfe-c-page-title__lede">Review, publish, and manage DDT standards and functional standards content</p>
</div>

@if (ViewBag.CanAccessStandardsManagement != true)
{
 <div class="dfe-c-callout dfe-c-callout--info dfe-c-mb-3">
 <div class="dfe-c-callout__heading">Access restricted</div>
 <p class="dfe-c-callout__body">Standards management is available to members of the <strong>Standards Manager</strong> group. Contact an administrator if you need access.</p>
  </div>
}
else
{
 <div class="dfe-c-mb-4">
 <div class="dfe-c-section-header">
 <h2 class="dfe-c-heading-m dfe-c-mb-0">Pending review</h2>
    </div>
    @if (Model.PendingReviewStandards.Count == 0)
    {
 <p class="dfe-c-body muted dfe-c-mb-0">No standards are pending review.</p>
    }
    else
    {
 <div class="dfe-c-table-wrap">
        <table>
          <thead>
            <tr>
              <th scope="col">Standard</th>
              <th scope="col">Category</th>
              <th scope="col">Version</th>
              <th scope="col">Owner</th>
              <th scope="col"></th>
            </tr>
          </thead>
          <tbody>
          @foreach (var s in Model.PendingReviewStandards)
          {
            <tr>
              <td><a href="@Url.Action("DdtDetail", "ModernStandards", new { id = s.Id })"><strong>@s.Title</strong></a></td>
              <td>@(string.IsNullOrEmpty(s.CategoryDisplay) ? "—" : s.CategoryDisplay)</td>
              <td>v@(s.Version)</td>
              <td>@(string.IsNullOrEmpty(s.OwnerDisplay) ? "—" : s.OwnerDisplay)</td>
 <td><a href="@Url.Action("DdtDetail", "ModernStandards", new { id = s.Id })" class="dfe-c-button dfe-c-button--secondary dfe-c-button--sm">Review</a></td>
            </tr>
          }
          </tbody>
        </table>
      </div>
    }
  </div>

 <div class="dfe-c-mb-4">
 <div class="dfe-c-section-header">
 <h2 class="dfe-c-heading-m dfe-c-mb-0">Functional standards</h2>
    </div>
    @if (Model.FunctionalStandards.Count == 0)
    {
 <p class="dfe-c-body muted dfe-c-mb-0">No functional standards configured.</p>
    }
    else
    {
 <div class="dfe-c-table-wrap">
        <table>
          <thead>
            <tr>
              <th scope="col">Standard</th>
              <th scope="col">Themes</th>
              <th scope="col">Criteria</th>
              <th scope="col">Assessments</th>
              <th scope="col"></th>
            </tr>
          </thead>
          <tbody>
          @foreach (var fs in Model.FunctionalStandards)
          {
            <tr>
              <td><strong>@fs.Title</strong></td>
              <td>@fs.ThemeCount</td>
              <td>@fs.CriteriaCount</td>
              <td>@fs.AssessmentCount</td>
 <td><a href="@Url.Action("Index", "FunctionalStandard")" class="govuk-link govuk-link--no-visited-state">Manage</a></td>
            </tr>
          }
          </tbody>
        </table>
      </div>
    }
  </div>

 <div class="dfe-c-mb-4">
 <div class="dfe-c-section-header">
 <h2 class="dfe-c-heading-m dfe-c-mb-0">Standard categories</h2>
    </div>
    @if (Model.StandardCategories.Count == 0)
    {
 <p class="dfe-c-body muted dfe-c-mb-0">No categories configured.</p>
    }
    else
    {
 <div class="dfe-c-table-wrap">
        <table>
          <thead>
            <tr>
              <th scope="col">Name</th>
              <th scope="col">Description</th>
            </tr>
          </thead>
          <tbody>
          @foreach (var c in Model.StandardCategories)
          {
            <tr>
              <td><strong>@c.Name</strong></td>
              <td>@(string.IsNullOrEmpty(c.Description) ? "—" : c.Description)</td>
            </tr>
          }
          </tbody>
        </table>
      </div>
    }
  </div>
}
