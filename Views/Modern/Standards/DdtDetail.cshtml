@model Compass.Models.DdtStandard
@using Compass.Helpers
@using Compass.ViewModels.Modern
@using System.Text.Json
@using System.Globalization
@{
    ViewData["Title"] = Model.Title;
    var culture = CultureInfo.GetCultureInfo("en-GB");

    var criteriaList = new List<string>();
    if (!string.IsNullOrWhiteSpace(Model.Criteria))
    {
        try { criteriaList = JsonSerializer.Deserialize<List<string>>(Model.Criteria) ?? new List<string>(); }
        catch { }
    }

    var approvedProducts = Model.Products?.Where(p => p.ProductType == "Approved" && p.StandardProduct != null).Select(p => p.StandardProduct!).ToList() ?? new List<StandardProduct>();
    var toleratedProducts = Model.Products?.Where(p => p.ProductType == "Tolerated" && p.StandardProduct != null).Select(p => p.StandardProduct!).ToList() ?? new List<StandardProduct>();
    var relatedStandards = ViewBag.RelatedStandards as List<DdtStandard> ?? new List<DdtStandard>();

    string StageBadgeClass(string stage) => stage switch
    {
        "Published" => "dfe-c-tag dfe-c-tag--green",
        "Draft" => "dfe-c-tag dfe-c-tag--grey",
        "For Approval" => "dfe-c-tag dfe-c-tag--amber",
        "Awaiting Publication" => "dfe-c-tag dfe-c-tag--blue",
        "Unpublished" => "dfe-c-tag dfe-c-tag--red",
        _ => "dfe-c-tag dfe-c-tag--grey"
    };

    string StageBadgeLabel(string stage) => stage switch
    {
        "For Approval" => "IN REVIEW",
        "Awaiting Publication" => "APPROVED",
        _ => stage.ToUpperInvariant()
    };

    var sections = new List<(string Id, string Label)>();
    sections.Add(("overview", "Overview"));
    if (!string.IsNullOrWhiteSpace(Model.Summary)) sections.Add(("summary", "Summary"));
    if (!string.IsNullOrWhiteSpace(Model.Purpose)) sections.Add(("purpose", "Purpose"));
    if (criteriaList.Any()) sections.Add(("criteria", "Criteria"));
    if (!string.IsNullOrWhiteSpace(Model.HowToMeet)) sections.Add(("how-to-meet", "How to meet this standard"));
    if (!string.IsNullOrWhiteSpace(Model.Governance)) sections.Add(("governance", "Governance"));
    if (!string.IsNullOrWhiteSpace(Model.LegalBasis)) sections.Add(("legal-basis", "Legal basis"));
    if (!string.IsNullOrWhiteSpace(Model.RelatedGuidance)) sections.Add(("related-guidance", "Related guidance"));
    if (Model.Phases.Any()) sections.Add(("phases", "Applicable phases"));
    if (approvedProducts.Any() || toleratedProducts.Any()) sections.Add(("products", "Products"));
    if (Model.Owners.Any() || Model.Contacts.Any()) sections.Add(("people", "People"));
    if (relatedStandards.Any()) sections.Add(("related", "Related standards"));

    var contentsNavId = "ddt-detail-contents-nav";
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernStandards")">Standards</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("DdtStandards", "ModernStandards")">DDT standards register</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">@Model.Title</li>
}

@{
  var ddtCaption = $"Standards — DDT-{Model.Id}" + (!string.IsNullOrWhiteSpace(Model.LegacyReference) ? $" ({Model.LegacyReference})" : "");
  var toolbar = ViewBag.Toolbar as DdtStandardDetailToolbarViewModel ?? new DdtStandardDetailToolbarViewModel { StandardId = Model.Id };
  var headerActions = await Html.PartialAsync("_DdtDetailHeaderActions", toolbar);
}
@await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
  BackLinkHref = Url.Action("DdtStandards", "ModernStandards"),
  BackLinkText = "Back to register",
  Caption = ddtCaption,
  Title = Model.Title,
  Actions = headerActions
})

@if (TempData["SuccessMessage"] != null)
{
  <div class="govuk-notification-banner govuk-notification-banner--success govuk-!-margin-bottom-4" role="region">
    <div class="govuk-notification-banner__header">
      <h2 class="govuk-notification-banner__title">Success</h2>
    </div>
    <div class="govuk-notification-banner__content">
      <p class="govuk-notification-banner__heading">@TempData["SuccessMessage"]</p>
    </div>
  </div>
}
@if (TempData["ErrorMessage"] != null)
{
  <div class="govuk-error-summary govuk-!-margin-bottom-4" role="alert">
    <h2 class="govuk-error-summary__title">There is a problem</h2>
    <div class="govuk-error-summary__body"><p>@TempData["ErrorMessage"]</p></div>
  </div>
}

@{
  var workflow = ViewBag.Workflow as Compass.ViewModels.Modern.DdtStandardWorkflowContextViewModel;
}
@if (workflow != null && (Model.Stage != "Published" || workflow.CanUnpublish))
{
  @await Html.PartialAsync("_DdtWorkflowBanner", workflow)
  @await Html.PartialAsync("_DdtWorkflowActions", workflow)
}

@if (Model.LegalStandard)
{
<div class="govuk-warning-text govuk-!-margin-bottom-6">
  <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
  <strong class="govuk-warning-text__text">
    <span class="govuk-visually-hidden">Warning</span>
    Legal requirement — you are breaking the law if you do not meet this standard.
    @if (!string.IsNullOrWhiteSpace(Model.LegalBasis))
    {
      <span class="govuk-!-margin-left-2">See <a class="govuk-link govuk-link--no-visited-state" href="#legal-basis">legal basis</a> below.</span>
    }
  </strong>
</div>
}

<div class="ddt-standard-detail govuk-!-margin-top-2">
  <div class="govuk-grid-row ddt-standard-detail-layout">
    <div class="govuk-grid-column-one-quarter-from-desktop">
      <div class="dfe-f-u-sticky govuk-!-margin-bottom-4" style="--dfe-f-sticky-top: 1rem;">
        <nav class="dfe-f-side-navigation ddt-standard-detail-side-nav"
                 aria-label="Page contents"
                 data-module="dfe-f-side-navigation">
                <button type="button"
                        class="dfe-f-side-navigation__toggle"
                        aria-controls="@contentsNavId"
                        aria-expanded="false">Contents</button>
                <ul id="@contentsNavId" class="dfe-f-side-navigation__list" hidden>
                    @foreach (var s in sections)
                    {
                        <li class="dfe-f-side-navigation__item">
                            <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state govuk-link--no-underline"
                               href="#@s.Id">@s.Label</a>
                        </li>
                    }
                </ul>
        </nav>
      </div>
    </div>
    <div class="govuk-grid-column-three-quarters-from-desktop ddt-standard-detail-main">

      <section id="overview" class="ddt-standard-detail-section">
        <div class="dfe-c-card dfe-c-card--plain ddt-standard-detail-section__card">
          <h2 class="govuk-heading-m ddt-standard-detail-section__heading">Overview</h2>
          <div class="ddt-standard-detail-section__body">
            <dl class="govuk-summary-list">
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Reference</dt>
 <dd class="govuk-summary-list__value">
                            DDT-@Model.Id
                            @if (!string.IsNullOrWhiteSpace(Model.LegacyReference))
                            {
 <span class="dfe-c-text-muted">(@Model.LegacyReference)</span>
                            }
                        </dd>
                    </div>
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Version</dt>
 <dd class="govuk-summary-list__value">
   @Model.Version
   <a class="govuk-link govuk-!-margin-left-2 govuk-link--no-visited-state" href="@Url.Action("DdtHistory", "ModernStandards", new { id = Model.Id })">View history</a>
 </dd>
                    </div>
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Status</dt>
 <dd class="govuk-summary-list__value"><span class="@StageBadgeClass(Model.Stage)">@StageBadgeLabel(Model.Stage)</span></dd>
                    </div>
                    @if (Model.Categories.Any())
                    {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Categories</dt>
 <dd class="govuk-summary-list__value">
              <ul class="ddt-standard-detail__tag-list">
                @foreach (var cat in Model.Categories.OrderBy(c => c.Category.Name))
                {
                  <li><span class="dfe-c-tag dfe-c-tag--grey">@cat.Category.Name</span></li>
                }
              </ul>
            </dd>
                        </div>
                    }
                    @if (Model.SubCategories.Any())
                    {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Sub-categories</dt>
 <dd class="govuk-summary-list__value">
                                @foreach (var sc in Model.SubCategories.OrderBy(s => s.SubCategory.Name))
                                {
                                    <span class="govuk-!-margin-right-2">@sc.SubCategory.Name</span>
                                }
                            </dd>
                        </div>
                    }
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">First published</dt>
 <dd class="govuk-summary-list__value">@(Model.FirstPublished?.ToString("d MMMM yyyy", culture) ?? Model.PublishedAt?.ToString("d MMMM yyyy", culture) ?? "Not published")</dd>
                    </div>
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Last updated</dt>
 <dd class="govuk-summary-list__value">@(Model.LastUpdated?.ToString("d MMMM yyyy", culture) ?? Model.UpdatedAt.ToString("d MMMM yyyy", culture))</dd>
                    </div>
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Conformance period</dt>
 <dd class="govuk-summary-list__value">
                            @if (Model.ValidityPeriod.HasValue)
                            {
                                <text>Every @Model.ValidityPeriod.Value @(Model.ValidityPeriod.Value == 1 ? "year" : "years")</text>
                            }
                            else
                            {
                                <text>Every 12 months</text>
                            }
                        </dd>
                    </div>
                    @if (Model.LegalStandard)
                    {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Legal requirement</dt>
 <dd class="govuk-summary-list__value"><span class="dfe-c-tag dfe-c-tag--red">YES</span></dd>
                        </div>
                    }
                    @if (Model.GovernanceApproval)
                    {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Governance</dt>
 <dd class="govuk-summary-list__value"><span class="dfe-c-tag dfe-c-tag--green">APPROVED</span></dd>
                        </div>
                    }
            </dl>
          </div>
        </div>
      </section>

      @if (!string.IsNullOrWhiteSpace(Model.Summary))
      {
        <section id="summary" class="ddt-standard-detail-section">
          <div class="dfe-c-card dfe-c-card--plain ddt-standard-detail-section__card">
            <h2 class="govuk-heading-m ddt-standard-detail-section__heading">Summary</h2>
            <div class="ddt-standard-detail-section__body">
              <p class="govuk-body">@Model.Summary</p>
            </div>
          </div>
        </section>
      }

      @if (!string.IsNullOrWhiteSpace(Model.Purpose))
      {
        <section id="purpose" class="ddt-standard-detail-section">
          <div class="dfe-c-card dfe-c-card--plain ddt-standard-detail-section__card">
            <h2 class="govuk-heading-m ddt-standard-detail-section__heading">Purpose</h2>
            <div class="ddt-standard-detail-section__body ddt-standard-detail__prose">
              @Html.Raw(MarkdownHelper.ToHtml(Model.Purpose))
            </div>
          </div>
        </section>
      }

      @if (criteriaList.Any())
      {
        <section id="criteria" class="ddt-standard-detail-section">
          <div class="dfe-c-card dfe-c-card--plain ddt-standard-detail-section__card">
            <h2 class="govuk-heading-m ddt-standard-detail-section__heading">Criteria</h2>
            <div class="ddt-standard-detail-section__body ddt-standard-detail__criteria">
              <p class="govuk-body">You meet this standard when all the following are achieved:</p>
              <ol class="govuk-list govuk-list--number">
                @foreach (var item in criteriaList)
                {
                  <li>@item</li>
                }
              </ol>
            </div>
          </div>
        </section>
      }

      @if (!string.IsNullOrWhiteSpace(Model.HowToMeet))
      {
        <section id="how-to-meet" class="ddt-standard-detail-section">
          <div class="dfe-c-card dfe-c-card--plain ddt-standard-detail-section__card">
            <h2 class="govuk-heading-m ddt-standard-detail-section__heading">How to meet this standard</h2>
            <div class="ddt-standard-detail-section__body ddt-standard-detail__prose">
              @Html.Raw(MarkdownHelper.ToHtml(Model.HowToMeet))
            </div>
          </div>
        </section>
      }

      @if (!string.IsNullOrWhiteSpace(Model.Governance))
      {
        <section id="governance" class="ddt-standard-detail-section">
          <div class="dfe-c-card dfe-c-card--plain ddt-standard-detail-section__card">
            <h2 class="govuk-heading-m ddt-standard-detail-section__heading">Governance</h2>
            <div class="ddt-standard-detail-section__body ddt-standard-detail__prose">
              @Html.Raw(MarkdownHelper.ToHtml(Model.Governance))
              @if (Model.GovernanceApproval)
              {
                <p class="govuk-!-margin-top-4 govuk-!-margin-bottom-0"><span class="dfe-c-tag dfe-c-tag--green">Governance approved</span></p>
              }
            </div>
          </div>
        </section>
      }

      @if (!string.IsNullOrWhiteSpace(Model.LegalBasis))
      {
        <section id="legal-basis" class="ddt-standard-detail-section">
          <div class="dfe-c-card dfe-c-card--plain ddt-standard-detail-section__card">
            <h2 class="govuk-heading-m ddt-standard-detail-section__heading">Legal basis</h2>
            <div class="ddt-standard-detail-section__body">
              <p class="govuk-body">@Model.LegalBasis</p>
            </div>
          </div>
        </section>
      }

      @if (!string.IsNullOrWhiteSpace(Model.RelatedGuidance))
      {
        <section id="related-guidance" class="ddt-standard-detail-section">
          <div class="dfe-c-card dfe-c-card--plain ddt-standard-detail-section__card">
            <h2 class="govuk-heading-m ddt-standard-detail-section__heading">Related guidance</h2>
            <div class="ddt-standard-detail-section__body ddt-standard-detail__prose">
              @Html.Raw(MarkdownHelper.ToHtml(Model.RelatedGuidance))
            </div>
          </div>
        </section>
      }

      @if (Model.Phases.Any())
      {
        <section id="phases" class="ddt-standard-detail-section">
          <div class="dfe-c-card dfe-c-card--plain ddt-standard-detail-section__card">
            <h2 class="govuk-heading-m ddt-standard-detail-section__heading">Applicable phases</h2>
            <div class="ddt-standard-detail-section__body">
              <ul class="ddt-standard-detail__tag-list">
                @foreach (var phase in Model.Phases.OrderBy(p => p.PhaseLookup?.SortOrder ?? 0))
                {
                  <li><span class="dfe-c-tag dfe-c-tag--blue">@(phase.PhaseLookup?.Name ?? "Phase")</span></li>
                }
              </ul>
            </div>
          </div>
        </section>
      }

      @if (approvedProducts.Any() || toleratedProducts.Any())
      {
        <section id="products" class="ddt-standard-detail-section">
          <div class="dfe-c-card dfe-c-card--plain ddt-standard-detail-section__card">
            <h2 class="govuk-heading-m ddt-standard-detail-section__heading">Products</h2>
            <div class="ddt-standard-detail-section__body">
              @if (approvedProducts.Any())
              {
                <h3 class="govuk-heading-s ddt-standard-detail-section__subheading">Approved products</h3>
 <div class="dfe-f-table-wrapper govuk-!-margin-bottom-6" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
                            <table class="govuk-table">
                                <thead class="govuk-table__head">
                                    <tr class="govuk-table__row">
                                        <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Product</button>
        </th>
                                        <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Provider</button>
        </th>
                                        <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Description</button>
        </th>
                                    </tr>
                                </thead>
                                <tbody class="govuk-table__body">
                                    @foreach (var p in approvedProducts)
                                    {
                                        <tr class="govuk-table__row">
                                            <td class="govuk-table__cell">@p.Name</td>
                                            <td class="govuk-table__cell">@(p.Provider ?? "—")</td>
                                            <td class="govuk-table__cell">@(p.Description ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

              @if (toleratedProducts.Any())
              {
                <h3 class="govuk-heading-s ddt-standard-detail-section__subheading">Tolerated products</h3>
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
                            <table class="govuk-table">
                                <thead class="govuk-table__head">
                                    <tr class="govuk-table__row">
                                        <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Product</button>
        </th>
                                        <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Provider</button>
        </th>
                                        <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Description</button>
        </th>
                                    </tr>
                                </thead>
                                <tbody class="govuk-table__body">
                                    @foreach (var p in toleratedProducts)
                                    {
                                        <tr class="govuk-table__row">
                                            <td class="govuk-table__cell">@p.Name</td>
                                            <td class="govuk-table__cell">@(p.Provider ?? "—")</td>
                                            <td class="govuk-table__cell">@(p.Description ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
              }
            </div>
          </div>
        </section>
      }

      @if (Model.Owners.Any() || Model.Contacts.Any())
      {
        <section id="people" class="ddt-standard-detail-section">
          <div class="dfe-c-card dfe-c-card--plain ddt-standard-detail-section__card">
            <h2 class="govuk-heading-m ddt-standard-detail-section__heading">People</h2>
            <div class="ddt-standard-detail-section__body">
              @if (Model.Owners.Any())
              {
                <h3 class="govuk-heading-s ddt-standard-detail-section__subheading">Owners</h3>
                <dl class="govuk-summary-list govuk-!-margin-bottom-4">
                            @foreach (var owner in Model.Owners.Where(o => o.User != null))
                            {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">@owner.User!.Name</dt>
 <dd class="govuk-summary-list__value">@(owner.User.Email ?? "—")</dd>
                                </div>
                            }
                        </dl>
                    }

              @if (Model.Contacts.Any())
              {
                <h3 class="govuk-heading-s ddt-standard-detail-section__subheading">Contacts</h3>
                <dl class="govuk-summary-list govuk-!-margin-bottom-0">
                            @foreach (var contact in Model.Contacts.Where(c => c.User != null))
                            {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">@contact.User!.Name</dt>
 <dd class="govuk-summary-list__value">@(contact.User.Email ?? "—")</dd>
                                </div>
                            }
                </dl>
              }
            </div>
          </div>
        </section>
      }

      @if (relatedStandards.Any())
      {
        <section id="related" class="ddt-standard-detail-section">
          <div class="dfe-c-card dfe-c-card--plain ddt-standard-detail-section__card">
            <h2 class="govuk-heading-m ddt-standard-detail-section__heading">Related standards</h2>
            <div class="ddt-standard-detail-section__body">
              <ul class="govuk-list ddt-standard-detail__related-list">
                @foreach (var rs in relatedStandards)
                {
                  <li>
                    <a href="@Url.Action("DdtDetail", "ModernStandards", new { id = rs.Id })" class="govuk-link govuk-!-font-weight-bold govuk-link--no-visited-state">@rs.Title</a>
                    <span class="dfe-c-text-muted govuk-body-s"> v@(rs.Version)</span>
                  </li>
                }
              </ul>
            </div>
          </div>
        </section>
      }
    </div>
  </div>
</div>

<dialog id="ddt-edit-denied-modal"
        class="dfe-f-modal govuk-!-margin-0"
        data-module="dfe-f-modal"
        aria-labelledby="ddt-edit-denied-title"
        aria-describedby="ddt-edit-denied-description"
        aria-modal="true">
  <div class="dfe-f-modal__panel">
    <header class="dfe-f-modal__header">
      <h2 id="ddt-edit-denied-title" class="govuk-heading-m dfe-f-modal__title">You cannot edit this standard</h2>
      <button type="button" class="dfe-f-modal__close" data-dfe-modal-close aria-label="Close"><span class="dfe-f-modal__close-x" aria-hidden="true">×</span></button>
    </header>
    <div class="dfe-f-modal__body" id="ddt-edit-denied-description">
      <p class="govuk-body">
        You are not a named owner or contact on the standard, or a member of the standards forum — you cannot edit the standard.
        Contact <strong>@toolbar.OwnerContactDisplay</strong> to make changes.
      </p>
    </div>
    <footer class="dfe-f-modal__footer">
      <button type="button" class="govuk-button govuk-button--secondary" data-dfe-modal-close>Close</button>
    </footer>
  </div>
</dialog>

@section Scripts {
<script>
  (function () {
    var btn = document.getElementById('ddt-edit-no-access');
    var dialog = document.getElementById('ddt-edit-denied-modal');
    if (!btn || !dialog) return;
    btn.addEventListener('click', function () {
      if (typeof dialog.showModal === 'function') dialog.showModal();
    });
    dialog.querySelectorAll('[data-dfe-modal-close]').forEach(function (el) {
      el.addEventListener('click', function () { dialog.close(); });
    });
  })();
</script>
}
