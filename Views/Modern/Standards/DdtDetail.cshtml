@model Compass.Models.DdtStandard
@using Compass.Helpers
@using System.Text.Json
@using System.Globalization
@{
    ViewData["Title"] = Model.Title;
    var culture = CultureInfo.GetCultureInfo("en-GB");

    var criteriaList = new List<string>();
    if (!string.IsNullOrWhiteSpace(Model.Criteria))
    {
        try { criteriaList = JsonSerializer.Deserialize<List<string>>(Model.Criteria) ?? new List<string>(); }
        catch { }
    }

    var approvedProducts = Model.Products?.Where(p => p.ProductType == "Approved" && p.StandardProduct != null).Select(p => p.StandardProduct!).ToList() ?? new List<StandardProduct>();
    var toleratedProducts = Model.Products?.Where(p => p.ProductType == "Tolerated" && p.StandardProduct != null).Select(p => p.StandardProduct!).ToList() ?? new List<StandardProduct>();
    var relatedStandards = ViewBag.RelatedStandards as List<DdtStandard> ?? new List<DdtStandard>();

    string StageBadgeClass(string stage) => stage switch
    {
        "Published" => "dfe-c-tag dfe-c-tag--green",
        "Draft" => "dfe-c-tag dfe-c-tag--grey",
        "For Approval" => "dfe-c-tag dfe-c-tag--amber",
        "Awaiting Publication" => "dfe-c-tag dfe-c-tag--blue",
        "Unpublished" => "dfe-c-tag dfe-c-tag--red",
        _ => "dfe-c-tag dfe-c-tag--grey"
    };

    string StageBadgeLabel(string stage) => stage switch
    {
        "For Approval" => "IN REVIEW",
        "Awaiting Publication" => "APPROVED",
        _ => stage.ToUpperInvariant()
    };

    var sections = new List<(string Id, string Label)>();
    sections.Add(("overview", "Overview"));
    if (!string.IsNullOrWhiteSpace(Model.Summary)) sections.Add(("summary", "Summary"));
    if (!string.IsNullOrWhiteSpace(Model.Purpose)) sections.Add(("purpose", "Purpose"));
    if (criteriaList.Any()) sections.Add(("criteria", "Criteria"));
    if (!string.IsNullOrWhiteSpace(Model.HowToMeet)) sections.Add(("how-to-meet", "How to meet this standard"));
    if (!string.IsNullOrWhiteSpace(Model.Governance)) sections.Add(("governance", "Governance"));
    if (!string.IsNullOrWhiteSpace(Model.LegalBasis)) sections.Add(("legal-basis", "Legal basis"));
    if (!string.IsNullOrWhiteSpace(Model.RelatedGuidance)) sections.Add(("related-guidance", "Related guidance"));
    if (Model.Phases.Any()) sections.Add(("phases", "Applicable phases"));
    if (approvedProducts.Any() || toleratedProducts.Any()) sections.Add(("products", "Products"));
    if (Model.Owners.Any() || Model.Contacts.Any()) sections.Add(("people", "People"));
    if (relatedStandards.Any()) sections.Add(("related", "Related standards"));
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernStandards")">Standards</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("DdtStandards", "ModernStandards")">DDT standards register</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">@Model.Title</li>
}

<div id="sc-standards-ddt-detail">

 <div class="dfe-c-flex--between dfe-c-mb-3" style="flex-wrap:wrap;gap:1rem;align-items:flex-start;">
 <div class="dfe-c-page-title" style="margin:0;">
 <div class="dfe-c-page-title__caption">
                Standards &mdash; DDT-@Model.Id
                @if (!string.IsNullOrWhiteSpace(Model.LegacyReference))
                {
 <span class="dfe-c-text-muted">(@Model.LegacyReference)</span>
                }
            </div>
 <h1 class="dfe-c-page-title__heading">@Model.Title</h1>
 <p class="dfe-c-page-title__lede">
 <span class="@StageBadgeClass(Model.Stage)">@StageBadgeLabel(Model.Stage)</span>
                <span style="margin-left:0.5rem;">Version @Model.Version</span>
            </p>
        </div>
 <div class="dfe-c-flex" style="gap:0.5rem;flex-wrap:wrap;">
 <a href="@Url.Action("DdtStandards", "ModernStandards")" class="govuk-button govuk-button--secondary">Back to register</a>
        </div>
    </div>

    @if (Model.LegalStandard)
    {
 <div class="dfe-c-banner dfe-c-banner--red dfe-c-mb-3">
            <strong>Legal requirement</strong> &mdash; You are breaking the law if you do not meet this standard.
            @if (!string.IsNullOrWhiteSpace(Model.LegalBasis))
            {
 <span class="dfe-c-text-muted" style="margin-left:0.5rem;">See <a href="#legal-basis">legal basis</a> below.</span>
            }
        </div>
    }

 <div class="dfe-c-section-nav dfe-c-mb-3" id="ddt-section-nav">
        @foreach (var s in sections)
        {
 <a href="#@s.Id" class="dfe-c-section-nav__link">@s.Label</a>
        }
    </div>

 <div class="dfe-c-grid dfe-c-grid--sidebar">
        <div>

 <section id="overview" class="dfe-c-mb-4">
 <h2 class="dfe-c-section-heading">Overview</h2>
 <dl class="govuk-summary-list">
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Reference</dt>
 <dd class="govuk-summary-list__value">
                            DDT-@Model.Id
                            @if (!string.IsNullOrWhiteSpace(Model.LegacyReference))
                            {
 <span class="dfe-c-text-muted">(@Model.LegacyReference)</span>
                            }
                        </dd>
                    </div>
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Version</dt>
 <dd class="govuk-summary-list__value">@Model.Version</dd>
                    </div>
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Status</dt>
 <dd class="govuk-summary-list__value"><span class="@StageBadgeClass(Model.Stage)">@StageBadgeLabel(Model.Stage)</span></dd>
                    </div>
                    @if (Model.Categories.Any())
                    {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Categories</dt>
 <dd class="govuk-summary-list__value">
                                @foreach (var cat in Model.Categories.OrderBy(c => c.Category.Name))
                                {
 <span class="dfe-c-tag dfe-c-tag--grey" style="margin-right:0.25rem;margin-bottom:0.25rem;">@cat.Category.Name</span>
                                }
                            </dd>
                        </div>
                    }
                    @if (Model.SubCategories.Any())
                    {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Sub-categories</dt>
 <dd class="govuk-summary-list__value">
                                @foreach (var sc in Model.SubCategories.OrderBy(s => s.SubCategory.Name))
                                {
                                    <span style="margin-right:0.5rem;">@sc.SubCategory.Name</span>
                                }
                            </dd>
                        </div>
                    }
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">First published</dt>
 <dd class="govuk-summary-list__value">@(Model.FirstPublished?.ToString("d MMMM yyyy", culture) ?? Model.PublishedAt?.ToString("d MMMM yyyy", culture) ?? "Not published")</dd>
                    </div>
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Last updated</dt>
 <dd class="govuk-summary-list__value">@(Model.LastUpdated?.ToString("d MMMM yyyy", culture) ?? Model.UpdatedAt.ToString("d MMMM yyyy", culture))</dd>
                    </div>
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Conformance period</dt>
 <dd class="govuk-summary-list__value">
                            @if (Model.ValidityPeriod.HasValue)
                            {
                                <text>Every @Model.ValidityPeriod.Value @(Model.ValidityPeriod.Value == 1 ? "year" : "years")</text>
                            }
                            else
                            {
                                <text>Every 12 months</text>
                            }
                        </dd>
                    </div>
                    @if (Model.LegalStandard)
                    {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Legal requirement</dt>
 <dd class="govuk-summary-list__value"><span class="dfe-c-tag dfe-c-tag--red">YES</span></dd>
                        </div>
                    }
                    @if (Model.GovernanceApproval)
                    {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">Governance</dt>
 <dd class="govuk-summary-list__value"><span class="dfe-c-tag dfe-c-tag--green">APPROVED</span></dd>
                        </div>
                    }
                </dl>
            </section>

            @if (!string.IsNullOrWhiteSpace(Model.Summary))
            {
 <section id="summary" class="dfe-c-mb-4">
 <h2 class="dfe-c-section-heading">Summary</h2>
 <div class="dfe-c-prose">
                        <p>@Model.Summary</p>
                    </div>
                </section>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Purpose))
            {
 <section id="purpose" class="dfe-c-mb-4">
 <h2 class="dfe-c-section-heading">Purpose</h2>
 <div class="dfe-c-prose">
                        @Html.Raw(MarkdownHelper.ToHtml(Model.Purpose))
                    </div>
                </section>
            }

            @if (criteriaList.Any())
            {
 <section id="criteria" class="dfe-c-mb-4">
 <h2 class="dfe-c-section-heading">Criteria</h2>
 <p class="dfe-c-body">You meet this standard when all the following are achieved:</p>
 <ol class="dfe-c-criteria-list">
                        @for (var i = 0; i < criteriaList.Count; i++)
                        {
 <li class="dfe-c-criteria-list__item">
 <span class="dfe-c-criteria-list__number">@(i + 1)</span>
 <span class="dfe-c-criteria-list__text">@criteriaList[i]</span>
                            </li>
                        }
                    </ol>
                </section>
            }

            @if (!string.IsNullOrWhiteSpace(Model.HowToMeet))
            {
 <section id="how-to-meet" class="dfe-c-mb-4">
 <h2 class="dfe-c-section-heading">How to meet this standard</h2>
 <div class="dfe-c-prose">
                        @Html.Raw(MarkdownHelper.ToHtml(Model.HowToMeet))
                    </div>
                </section>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Governance))
            {
 <section id="governance" class="dfe-c-mb-4">
 <h2 class="dfe-c-section-heading">Governance</h2>
 <div class="dfe-c-prose">
                        @Html.Raw(MarkdownHelper.ToHtml(Model.Governance))
                    </div>
                    @if (Model.GovernanceApproval)
                    {
 <p class="dfe-c-mt-2"><span class="dfe-c-tag dfe-c-tag--green">GOVERNANCE APPROVED</span></p>
                    }
                </section>
            }

            @if (!string.IsNullOrWhiteSpace(Model.LegalBasis))
            {
 <section id="legal-basis" class="dfe-c-mb-4">
 <h2 class="dfe-c-section-heading">Legal basis</h2>
 <div class="dfe-c-prose">
                        <p>@Model.LegalBasis</p>
                    </div>
                </section>
            }

            @if (!string.IsNullOrWhiteSpace(Model.RelatedGuidance))
            {
 <section id="related-guidance" class="dfe-c-mb-4">
 <h2 class="dfe-c-section-heading">Related guidance</h2>
 <div class="dfe-c-prose">
                        @Html.Raw(MarkdownHelper.ToHtml(Model.RelatedGuidance))
                    </div>
                </section>
            }

            @if (Model.Phases.Any())
            {
 <section id="phases" class="dfe-c-mb-4">
 <h2 class="dfe-c-section-heading">Applicable phases</h2>
 <div class="dfe-c-flex" style="gap:0.5rem;flex-wrap:wrap;">
                        @foreach (var phase in Model.Phases.OrderBy(p => p.PhaseLookup?.SortOrder ?? 0))
                        {
 <span class="dfe-c-tag dfe-c-tag--blue">@(phase.PhaseLookup?.Name ?? "Phase")</span>
                        }
                    </div>
                </section>
            }

            @if (approvedProducts.Any() || toleratedProducts.Any())
            {
 <section id="products" class="dfe-c-mb-4">
 <h2 class="dfe-c-section-heading">Products</h2>

                    @if (approvedProducts.Any())
                    {
 <h3 class="dfe-c-subsection-heading">Approved products</h3>
 <div class="dfe-c-table-wrap">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th>Provider</th>
                                        <th>Description</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in approvedProducts)
                                    {
                                        <tr>
                                            <td>@p.Name</td>
                                            <td>@(p.Provider ?? "—")</td>
                                            <td>@(p.Description ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    @if (toleratedProducts.Any())
                    {
 <h3 class="dfe-c-subsection-heading">Tolerated products</h3>
 <div class="dfe-c-table-wrap">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th>Provider</th>
                                        <th>Description</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in toleratedProducts)
                                    {
                                        <tr>
                                            <td>@p.Name</td>
                                            <td>@(p.Provider ?? "—")</td>
                                            <td>@(p.Description ?? "—")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </section>
            }

            @if (Model.Owners.Any() || Model.Contacts.Any())
            {
 <section id="people" class="dfe-c-mb-4">
 <h2 class="dfe-c-section-heading">People</h2>

                    @if (Model.Owners.Any())
                    {
 <h3 class="dfe-c-subsection-heading">Owners</h3>
 <dl class="govuk-summary-list">
                            @foreach (var owner in Model.Owners.Where(o => o.User != null))
                            {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">@owner.User!.Name</dt>
 <dd class="govuk-summary-list__value">@(owner.User.Email ?? "—")</dd>
                                </div>
                            }
                        </dl>
                    }

                    @if (Model.Contacts.Any())
                    {
 <h3 class="dfe-c-subsection-heading">Contacts</h3>
 <dl class="govuk-summary-list">
                            @foreach (var contact in Model.Contacts.Where(c => c.User != null))
                            {
 <div class="govuk-summary-list__row">
 <dt class="govuk-summary-list__key">@contact.User!.Name</dt>
 <dd class="govuk-summary-list__value">@(contact.User.Email ?? "—")</dd>
                                </div>
                            }
                        </dl>
                    }
                </section>
            }
        </div>

        <aside>
            @if (relatedStandards.Any())
            {
 <section id="related" class="dfe-c-mb-4">
 <h3 class="dfe-c-sidebar-heading">Related standards</h3>
 <ul class="dfe-c-sidebar-list">
                        @foreach (var rs in relatedStandards)
                        {
                            <li>
                                <a href="@Url.Action("DdtDetail", "ModernStandards", new { id = rs.Id })">@rs.Title</a>
 <span class="dfe-c-text-muted dfe-c-text-small">v@(rs.Version)</span>
                            </li>
                        }
                    </ul>
                </section>
            }

 <section class="dfe-c-mb-4">
 <h3 class="dfe-c-sidebar-heading">Details</h3>
 <dl class="dfe-c-sidebar-dl">
                    <dt>Created</dt>
                    <dd>@Model.DraftCreated.ToString("d MMMM yyyy", culture)</dd>
                    @if (Model.CreatorUser != null)
                    {
                        <dt>Created by</dt>
                        <dd>@Model.CreatorUser.Name</dd>
                    }
                    <dt>Last updated</dt>
                    <dd>@Model.UpdatedAt.ToString("d MMMM yyyy", culture)</dd>
                    @if (!string.IsNullOrWhiteSpace(Model.StandardUuid))
                    {
                        <dt>UUID</dt>
 <dd class="dfe-c-text-small dfe-c-text-muted" style="word-break:break-all;">@Model.StandardUuid</dd>
                    }
                </dl>
            </section>
        </aside>
    </div>
</div>

<style>
    .dfe-c-criteria-list {
        list-style: none;
        padding: 0;
        margin: 0;
        counter-reset: none;
    }
    .dfe-c-criteria-list__item {
        display: flex;
        gap: 0.75rem;
        padding: 0.75rem 0;
        border-bottom: 1px solid #b1b4b6;
        align-items: flex-start;
    }
    .dfe-c-criteria-list__item:last-child {
        border-bottom: none;
    }
    .dfe-c-criteria-list__number {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: 50%;
        background: #1d70b8;
        color: #fff;
        font-weight: 700;
        font-size: 0.875rem;
        flex-shrink: 0;
    }
    .dfe-c-criteria-list__text {
        flex: 1;
        padding-top: 0.25rem;
    }
    .dfe-c-section-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.25rem 0;
        border-bottom: 2px solid #b1b4b6;
        padding-bottom: 0;
    }
    .dfe-c-section-nav__link {
        display: inline-block;
        padding: 0.5rem 1rem;
        font-size: 0.875rem;
        color: #1d70b8;
        text-decoration: none;
        border-bottom: 3px solid transparent;
        margin-bottom: -2px;
    }
    .dfe-c-section-nav__link:hover {
        color: #003078;
        border-bottom-color: #003078;
    }
    .dfe-c-grid--sidebar {
        display: grid;
        grid-template-columns: 1fr 280px;
        gap: 2rem;
    }
    @@media (max-width: 768px) {
        .dfe-c-grid--sidebar {
            grid-template-columns: 1fr;
        }
    }
    .dfe-c-section-heading {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0 0 1rem 0;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #1d70b8;
    }
    .dfe-c-subsection-heading {
        font-size: 1.125rem;
        font-weight: 700;
        margin: 1rem 0 0.75rem 0;
        color: #0b0c0c;
    }
    .dfe-c-prose {
        line-height: 1.6;
    }
    .dfe-c-prose p {
        margin: 0 0 1rem 0;
    }
    .dfe-c-prose ul,
    .dfe-c-prose ol {
        margin: 0 0 1rem 0;
        padding-left: 1.25rem;
    }
    .dfe-c-prose li {
        margin-bottom: 0.25rem;
    }
    .dfe-c-sidebar-heading {
        font-size: 1rem;
        font-weight: 700;
        margin: 0 0 0.75rem 0;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #b1b4b6;
    }
    .dfe-c-sidebar-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .dfe-c-sidebar-list li {
        padding: 0.5rem 0;
        border-bottom: 1px solid #f3f2f1;
    }
    .dfe-c-sidebar-list li:last-child {
        border-bottom: none;
    }
    .dfe-c-sidebar-list a {
        font-size: 0.9375rem;
        text-decoration: underline;
        color: #1d70b8;
    }
    .dfe-c-sidebar-dl {
        margin: 0;
    }
    .dfe-c-sidebar-dl dt {
        font-size: 0.875rem;
        font-weight: 700;
        color: #505a5f;
        margin: 0.75rem 0 0.125rem 0;
    }
    .dfe-c-sidebar-dl dt:first-child {
        margin-top: 0;
    }
    .dfe-c-sidebar-dl dd {
        margin: 0 0 0.25rem 0;
        font-size: 0.9375rem;
    }
    .dfe-c-banner {
        padding: 0.75rem 1rem;
        border-left: 4px solid;
    }
    .dfe-c-banner--red {
        border-left-color: #d4351c;
        background: #fef7f5;
        color: #942514;
    }
    .dfe-c-text-small {
        font-size: 0.8125rem;
    }
</style>
