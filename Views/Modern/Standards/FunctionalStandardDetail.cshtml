@model Compass.Models.FunctionalStandard
@using Compass.Models
@{
    ViewData["Title"] = Model.Title;
    var inProgressAssessments = ViewBag.InProgressAssessments as List<dynamic> ?? new List<dynamic>();
    var submittedAssessments = ViewBag.SubmittedAssessments as List<dynamic> ?? new List<dynamic>();
    var hasInProgress = ViewBag.HasInProgressAssessment as bool? ?? false;
    var totalCriteria = Model.Themes?.Sum(t => t.PracticeAreas?.Sum(pa => pa.Criteria?.Count ?? 0) ?? 0) ?? 0;
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernStandards")">Standards</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("FunctionalStandards", "ModernStandards")">Functional standards</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">@Model.Title</li>
}

<div id="sc-standards-fs-detail">

 <div class="dfe-c-flex--between dfe-c-mb-3" style="flex-wrap:wrap;gap:1rem;align-items:flex-start;">
 <div class="dfe-c-page-title" style="margin:0;">
 <div class="dfe-c-page-title__caption">Functional standard</div>
 <h1 class="dfe-c-page-title__heading">@Model.Title</h1>
 <p class="dfe-c-page-title__lede">@totalCriteria criteria across @(Model.Themes?.Count ?? 0) themes</p>
        </div>
 <div class="dfe-c-flex" style="gap:0.5rem;flex-wrap:wrap;">
            @if (hasInProgress)
            {
 <button type="button" class="govuk-button" disabled title="Complete the in-progress assessment first">Start new assessment</button>
            }
            else
            {
 <button type="button" class="govuk-button" data-modal-open="dlg-start-assessment">Start new assessment</button>
            }
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
 <div class="dfe-c-callout dfe-c-callout--info dfe-c-mb-3">
 <p class="dfe-c-callout__body">@Model.Description</p>
        </div>
    }

    @if (hasInProgress)
    {
 <div class="dfe-c-banner dfe-c-banner--blue dfe-c-mb-3">
            An assessment is already in progress. Complete or submit it before starting a new one.
        </div>
    }

 <h2 class="dfe-c-heading-m dfe-c-mb-2">Assessments in progress</h2>
    @if (inProgressAssessments.Any())
    {
 <div class="dfe-c-table-wrap dfe-c-mb-4">
            <table>
                <thead>
                    <tr>
                        <th>Assessment</th>
                        <th>Started by</th>
                        <th>Started</th>
                        <th>Progress</th>
 <th><span class="govuk-visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (dynamic item in inProgressAssessments)
                    {
                        FunctionalStandardAssessment assessment = item.Assessment;
                        int completedCount = item.CompletedCount;
                        int totalCount = item.TotalCount;
                        string userName = item.UserName ?? assessment.AssessedBy;
                        var pct = totalCount > 0 ? (int)Math.Round(100.0 * completedCount / totalCount) : 0;
                        <tr>
                            <td><a href="@Url.Action("ConductAssessment", "ModernStandards", new { assessmentId = assessment.Id })"><strong>@assessment.AssessmentName</strong></a></td>
                            <td>@userName</td>
                            <td>@assessment.AssessmentDate.ToString("d MMM yyyy")</td>
                            <td>@completedCount / @totalCount (@(pct)%)</td>
 <td style="text-align:right;"><a class="govuk-link" href="@Url.Action("ConductAssessment", "ModernStandards", new { assessmentId = assessment.Id })">Continue</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
 <p class="dfe-c-body dfe-c-text-muted dfe-c-mb-4">No assessments are in progress.</p>
    }

 <h2 class="dfe-c-heading-m dfe-c-mb-2">Submitted assessments</h2>
    @if (submittedAssessments.Any())
    {
 <div class="dfe-c-table-wrap dfe-c-mb-4">
            <table>
                <thead>
                    <tr>
                        <th>Assessment</th>
                        <th>Submitted</th>
                        <th>Assessed by</th>
 <th><span class="govuk-visually-hidden">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (dynamic item in submittedAssessments)
                    {
                        FunctionalStandardAssessment assessment = item.Assessment;
                        <tr>
                            <td><a href="@Url.Action("AssessmentSummary", "ModernStandards", new { assessmentId = assessment.Id })"><strong>@assessment.AssessmentName</strong></a></td>
                            <td>@assessment.SubmittedAt?.ToString("d MMM yyyy")</td>
                            <td>@assessment.AssessedBy</td>
 <td style="text-align:right;"><a class="govuk-link" href="@Url.Action("AssessmentSummary", "ModernStandards", new { assessmentId = assessment.Id })">View summary</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
 <p class="dfe-c-body dfe-c-text-muted dfe-c-mb-4">No submitted assessments.</p>
    }
</div>

<dialog id="dlg-start-assessment" class="dfe-c-dialog">
 <div class="dfe-c-dialog__content">
        <h2>Start new assessment</h2>
        <p>Create a new assessment for <strong>@Model.Title</strong>.</p>
 <p class="dfe-c-text-muted" style="font-size:0.875rem;">This assessment includes @totalCriteria criteria across @(Model.Themes?.Count ?? 0) themes.</p>
        <form method="post" action="@Url.Action("StartAssessment", "ModernStandards")">
            @Html.AntiForgeryToken()
            <input type="hidden" name="standardId" value="@Model.Id" />
 <div class="govuk-form-group" style="margin-bottom:1rem;">
 <label class="govuk-label" for="assessmentName">Assessment name</label>
 <span class="govuk-hint">For example, Q2 2026 Assessment</span>
 <input type="text" id="assessmentName" name="assessmentName" class="govuk-input" required />
            </div>
 <div class="dfe-c-dialog__actions">
 <button type="submit" class="govuk-button">Start assessment</button>
 <button type="button" class="govuk-button govuk-button--secondary" data-modal-close="dlg-start-assessment">Cancel</button>
            </div>
        </form>
    </div>
</dialog>

<style>
    .dfe-c-dialog { border: none; border-radius: 4px; padding: 1.5rem; max-width: 480px; box-shadow: 0 4px 24px rgba(0,0,0,0.25); }
    .dfe-c-dialog::backdrop { background: rgba(0,0,0,0.5); }
    .dfe-c-dialog__actions { display: flex; gap: 0.5rem; margin-top: 1rem; }
    .dfe-c-banner--blue { padding: 0.75rem 1rem; border-left: 4px solid #1d70b8; background: #f0f4f9; color: #144e81; }
</style>
