@model FipsProductsViewModel
@{
    ViewData["Title"] = "Service register — Products";
    var tab = Model.ActiveTab;
    var bulkNew = string.Equals(tab, "new", StringComparison.OrdinalIgnoreCase);
    var showBulkManagement = bulkNew || string.Equals(tab, "all", StringComparison.OrdinalIgnoreCase);
    var showAllTabExtraColumns = string.Equals(tab, "all", StringComparison.OrdinalIgnoreCase);
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernOperations")">Operations</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Service register</li>
}

@functions {
    string TabCount(int count) => count > 0 ? $" ({count})" : "";

    string QualityPercent(int score, int max) =>
        max > 0 ? $"{Math.Round((double)score / max * 100):0}%" : "0%";

    string QualityClass(int score, int max) =>
        score >= (int)(max * 0.7) ? "fips-quality--high" :
        score >= (int)(max * 0.4) ? "fips-quality--medium" :
        "fips-quality--low";
}

@if (TempData["Success"] != null)
{
 <div class="govuk-notification-banner govuk-notification-banner--success" role="region" aria-labelledby="fips-sync-success-title">
 <div class="govuk-notification-banner__header">
 <h2 class="govuk-notification-banner__title" id="fips-sync-success-title">Success</h2>
        </div>
 <div class="govuk-notification-banner__content">
 <p class="govuk-notification-banner__heading">@TempData["Success"]</p>
        </div>
    </div>
}
@if (TempData["Error"] != null)
{
 <div class="govuk-error-summary" role="alert" style="margin-bottom:1.5rem;">
 <h2 class="govuk-error-summary__title">Something went wrong</h2>
 <div class="govuk-error-summary__body">@TempData["Error"]</div>
    </div>
}

<div class="dfe-c-flex--between dfe-c-mb-3" style="flex-wrap:wrap;gap:1rem;align-items:flex-end;">
 <div class="dfe-c-page-title" style="margin:0;">
 <div class="dfe-c-page-title__caption">Operations</div>
 <h1 class="dfe-c-page-title__heading">Service register</h1>
 <p class="govuk-body-s govuk-!-margin-top-1 govuk-!-margin-bottom-0" style="color:#505a5f;">FIPS products — list, filters, and CMDB sync (updates matching records only).</p>
    </div>
 <div class="dfe-c-flex" style="gap:0.75rem;flex-wrap:wrap;align-items:center;">
 <a href="@Url.Action("ServiceRegisterCmdbRules", "ModernOperations")" class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold">CMDB sync rules</a>
        @if (Model.CanSyncFromCmdb)
        {
 <form id="fips-cmdb-bulk-sync-antiforgery" method="post" class="govuk-!-margin-bottom-0" aria-hidden="true">
                @Html.AntiForgeryToken()
            </form>
 <button type="button" class="govuk-button" id="fips-cmdb-bulk-sync-start" aria-haspopup="dialog" aria-controls="fips-cmdb-bulk-sync-confirm-modal">Sync from CMDB</button>
        }
    </div>
</div>

<div class="tabs dfe-c-mb-3" role="tablist" aria-label="Product sections">
 <a href="@Url.Action("ServiceRegister", "ModernOperations", new { tab = "my" })" class="tab @(tab =="my" ? "on" : "")" role="tab" aria-selected="@(tab == "my")" aria-controls="d-my" id="tab-my">My products@(TabCount(Model.MyProductsCount))</a>
 <a href="@Url.Action("ServiceRegister", "ModernOperations", new { tab = "all" })" class="tab @(tab =="all" ? "on" : "")" role="tab" aria-selected="@(tab == "all")" aria-controls="d-all" id="tab-all">All products@(TabCount(Model.AllProductsCount))</a>
 <a href="@Url.Action("ServiceRegister", "ModernOperations", new { tab = "new" })" class="tab @(tab =="new" ? "on" : "")" role="tab" aria-selected="@(tab == "new")" aria-controls="d-new" id="tab-new">New products@(TabCount(Model.NewProductsCount))</a>
 <a href="@Url.Action("ServiceRegister", "ModernOperations", new { tab = "inactive" })" class="tab @(tab =="inactive" ? "on" : "")" role="tab" aria-selected="@(tab == "inactive")" aria-controls="d-inactive" id="tab-inactive">Inactive products@(TabCount(Model.InactiveProductsCount))</a>
 <a href="@Url.Action("ServiceRegister", "ModernOperations", new { tab = "retired" })" class="tab @(tab =="retired" ? "on" : "")" role="tab" aria-selected="@(tab == "retired")" aria-controls="d-retired" id="tab-retired">Retired@(TabCount(Model.RetiredCount))</a>
</div>

@if (tab == "inactive")
{
  <p class="govuk-body-s govuk-!-margin-bottom-3" style="color:#505a5f;">These products are <strong>excluded from the FIPS service register</strong> (for example by CMDB sync rules). They are not shown in the active catalogue.</p>
}
else if (tab == "retired")
{
  <p class="govuk-body-s govuk-!-margin-bottom-3" style="color:#505a5f;">These products are <strong>retired</strong> in Compass. CMDB sync does not update these records.</p>
}
else if (bulkNew)
{
  <p class="govuk-body-s govuk-!-margin-bottom-3" style="color:#505a5f;">New products are not yet live in the register. Use the checkboxes to select products, then set status and/or details in bulk.</p>
}
else if (string.Equals(tab, "all", StringComparison.OrdinalIgnoreCase))
{
  <p class="govuk-body-s govuk-!-margin-bottom-3" style="color:#505a5f;">Use the checkboxes to select products, then set status and/or details in bulk. Filters apply to the list only.</p>
}

@await Html.PartialAsync("_SearchAndFilter", (SearchAndFilterViewModel)ViewBag.SearchAndFilter)

<div id="d-@tab" class="tab-pane on" role="tabpanel">
    @if (Model.Products.Count == 0)
    {
 <p class="govuk-body">No products found.</p>
    }
    else if (showBulkManagement)
    {
        <form method="post" asp-controller="ModernOperations" asp-action="ServiceRegisterBulkNewProducts" class="govuk-!-margin-bottom-0" id="sr-bulk-new-form" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" name="SourceTab" value="@tab" />
            <input type="hidden" name="RSearch" value="@(Model.Search ?? "")" />
            <input type="hidden" name="RBusinessAreaId" value="@(Model.BusinessAreaId?.ToString() ?? "")" />
            <input type="hidden" name="RChannelId" value="@(Model.ChannelId?.ToString() ?? "")" />
            <input type="hidden" name="RUserGroupId" value="@(Model.UserGroupId?.ToString() ?? "")" />
            <input type="hidden" name="RTypeId" value="@(Model.TypeId?.ToString() ?? "")" />
            <input type="hidden" name="RPhaseId" value="@(Model.PhaseId?.ToString() ?? "")" />

            <details class="govuk-details govuk-!-margin-bottom-3" data-module="govuk-details" id="sr-bulk-management-panel"@if (bulkNew) { <text> open</text> }>
                <summary class="govuk-details__summary">
                    <span class="govuk-details__summary-text">Bulk management</span>
                </summary>
                <div class="govuk-details__text">
                    <div class="dfe-c-card dfe-c-card--plain govuk-!-margin-top-0 govuk-!-margin-bottom-0">
                <p class="govuk-body-s dfe-c-text-muted govuk-!-margin-bottom-3">Tick the actions to apply, choose values, then <strong>Apply to selected</strong>. Unticked rows keep their current values for that field.</p>

                <div class="govuk-form-group govuk-!-margin-bottom-3">
                    <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
                        <div class="govuk-checkboxes__item">
                            <input class="govuk-checkboxes__input" type="checkbox" name="ApplyStatus" id="sr-bulk-apply-status" value="true" />
                            <label class="govuk-label govuk-checkboxes__label" for="sr-bulk-apply-status">Set status for selected</label>
                        </div>
                    </div>
                    <div class="govuk-!-margin-top-1 govuk-!-padding-left-4" style="border-left:3px solid #b1b4b6">
                        <label class="govuk-label" for="sr-bulk-target-status">Target status</label>
                        <select class="govuk-select" name="TargetStatus" id="sr-bulk-target-status" aria-describedby="sr-bulk-status-hint">
                            <option value="">— Select —</option>
                            <option value="1">Active (live in register)</option>
                            <option value="3">Excluded from register (inactive)</option>
                            <option value="2">Retired</option>
                        </select>
                        <p class="govuk-hint govuk-!-margin-bottom-0" id="sr-bulk-status-hint">“Excluded” matches the Inactive tab; “Retired” matches the Retired tab.</p>
                    </div>
                </div>

                <div class="govuk-form-group govuk-!-margin-bottom-3">
                    <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
                        <div class="govuk-checkboxes__item">
                            <input class="govuk-checkboxes__input" type="checkbox" name="ApplyPhase" id="sr-bulk-apply-phase" value="true" />
                            <label class="govuk-label govuk-checkboxes__label" for="sr-bulk-apply-phase">Set phase for selected</label>
                        </div>
                    </div>
                    <div class="govuk-!-margin-top-1 govuk-!-padding-left-4" style="border-left:3px solid #b1b4b6">
                        <label class="govuk-label" for="sr-bulk-phase">Phase</label>
                        <select class="govuk-select" name="BulkPhaseId" id="sr-bulk-phase">
                            <option value="">— None —</option>
                            @foreach (var ph in Model.PhaseOptions)
                            {
                                <option value="@ph.Id">@ph.Name</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="govuk-form-group govuk-!-margin-bottom-3">
                    <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
                        <div class="govuk-checkboxes__item">
                            <input class="govuk-checkboxes__input" type="checkbox" name="ApplyBusinessArea" id="sr-bulk-apply-ba" value="true" />
                            <label class="govuk-label govuk-checkboxes__label" for="sr-bulk-apply-ba">Set business area(s) for selected</label>
                        </div>
                    </div>
                    <div class="govuk-!-margin-top-1 govuk-!-padding-left-4" style="border-left:3px solid #b1b4b6">
                        <fieldset class="govuk-fieldset">
                            <legend class="govuk-fieldset__legend govuk-fieldset__legend--s">Business area</legend>
                            <div class="govuk-hint" id="sr-bulk-ba-hint">Replaces all business areas on each selected product.</div>
                            <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="sr-bulk-ba-hint" style="max-height:12rem;overflow-y:auto">
                                @foreach (var ba in Model.BusinessAreaLookups)
                                {
                                    <div class="govuk-checkboxes__item">
                                        <input class="govuk-checkboxes__input" type="checkbox" name="BusinessAreaLookupIds" value="@ba.Id" id="sr-bulk-ba-@ba.Id" />
                                        <label class="govuk-label govuk-checkboxes__label" for="sr-bulk-ba-@ba.Id">@ba.Name</label>
                                    </div>
                                }
                            </div>
                        </fieldset>
                    </div>
                </div>

                <div class="govuk-form-group govuk-!-margin-bottom-3">
                    <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
                        <div class="govuk-checkboxes__item">
                            <input class="govuk-checkboxes__input" type="checkbox" name="ApplyChannel" id="sr-bulk-apply-ch" value="true" />
                            <label class="govuk-label govuk-checkboxes__label" for="sr-bulk-apply-ch">Set channel(s) for selected</label>
                        </div>
                    </div>
                    <div class="govuk-!-margin-top-1 govuk-!-padding-left-4" style="border-left:3px solid #b1b4b6">
                        <div class="govuk-hint" id="sr-bulk-ch-hint">Replaces all channels on each product.</div>
                        <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="sr-bulk-ch-hint" style="max-height:10rem;overflow-y:auto">
                            @foreach (var ch in Model.ChannelOptions)
                            {
                                <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" type="checkbox" name="BulkChannelIds" value="@ch.Id" id="sr-bulk-ch-@ch.Id" />
                                    <label class="govuk-label govuk-checkboxes__label" for="sr-bulk-ch-@ch.Id">@ch.Name</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="govuk-form-group govuk-!-margin-bottom-0">
                    <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
                        <div class="govuk-checkboxes__item">
                            <input class="govuk-checkboxes__input" type="checkbox" name="ApplyType" id="sr-bulk-apply-ty" value="true" />
                            <label class="govuk-label govuk-checkboxes__label" for="sr-bulk-apply-ty">Set type(s) for selected</label>
                        </div>
                    </div>
                    <div class="govuk-!-margin-top-1 govuk-!-padding-left-4" style="border-left:3px solid #b1b4b6">
                        <div class="govuk-hint" id="sr-bulk-ty-hint">Replaces all types on each product.</div>
                        <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes" aria-describedby="sr-bulk-ty-hint" style="max-height:10rem;overflow-y:auto">
                            @foreach (var tp in Model.TypeOptions)
                            {
                                <div class="govuk-checkboxes__item">
                                    <input class="govuk-checkboxes__input" type="checkbox" name="BulkTypeIds" value="@tp.Id" id="sr-bulk-ty-@tp.Id" />
                                    <label class="govuk-label govuk-checkboxes__label" for="sr-bulk-ty-@tp.Id">@tp.Name</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="govuk-button-group govuk-!-margin-top-3 govuk-!-margin-bottom-0">
                    <button type="submit" class="govuk-button" data-module="govuk-button">Apply to selected</button>
                </div>
                    </div>
                </div>
            </details>

            <div class="dfe-c-table-wrap">
                <table>
                    <caption class="govuk-visually-hidden">Products (select for bulk management)</caption>
                    <thead>
                        <tr>
                            <th scope="col" style="width:3.5rem;white-space:nowrap">
                                <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
                                    <div class="govuk-checkboxes__item">
                                        <input class="govuk-checkboxes__input" type="checkbox" id="sr-bulk-select-all" title="Select all" />
                                        <label class="govuk-label govuk-checkboxes__label" for="sr-bulk-select-all"><span class="govuk-visually-hidden">Select all</span></label>
                                    </div>
                                </div>
                            </th>
                            <th scope="col">Name</th>
                            <th scope="col">Phase</th>
                            <th scope="col">Business area</th>
                            @if (showAllTabExtraColumns)
                            {
                                <th scope="col">Types</th>
                                <th scope="col">Channels</th>
                                <th scope="col" class="govuk-!-text-align-right" style="white-space:nowrap">User groups</th>
                                <th scope="col" class="govuk-!-text-align-right" style="white-space:nowrap">Contacts</th>
                            }
                            <th scope="col">Service owner</th>
                            <th scope="col">Reporting contact</th>
                            <th scope="col">Quality</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.Products)
                        {
                            <tr>
                                <td>
                                    <div class="govuk-checkboxes govuk-checkboxes--small" data-module="govuk-checkboxes">
                                        <div class="govuk-checkboxes__item">
                                            <input class="govuk-checkboxes__input sr-bulk-row-cb" type="checkbox" name="ProductIds" value="@p.Id" id="sr-bulk-p-@p.Id" />
                                            <label class="govuk-label govuk-checkboxes__label" for="sr-bulk-p-@p.Id"><span class="govuk-visually-hidden">@p.Title</span></label>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <a href="@Url.Action("ServiceRegisterProduct", "ModernOperations", new { id = p.Id })" class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold">@p.Title</a>
                                    <span class="govuk-body-s dfe-c-text-muted" style="display:block;">ID: @p.UniqueID</span>
                                </td>
                                <td>@(p.PhaseName ?? "—")</td>
                                <td>@(string.IsNullOrWhiteSpace(p.BusinessAreaDisplay) ? "—" : p.BusinessAreaDisplay)</td>
                                @if (showAllTabExtraColumns)
                                {
                                    <td class="govuk-body-s" style="max-width:12rem;word-wrap:break-word">@(string.IsNullOrWhiteSpace(p.TypesDisplay) ? "—" : p.TypesDisplay)</td>
                                    <td class="govuk-body-s" style="max-width:12rem;word-wrap:break-word">@(string.IsNullOrWhiteSpace(p.ChannelsDisplay) ? "—" : p.ChannelsDisplay)</td>
                                    <td class="govuk-body-s govuk-!-text-align-right" style="white-space:nowrap">@p.UserGroupCount</td>
                                    <td class="govuk-body-s govuk-!-text-align-right" style="white-space:nowrap">@p.ContactCount</td>
                                }
                                <td>@(p.ServiceOwner ?? "—")</td>
                                <td>@(p.ReportingContact ?? "—")</td>
                                <td>
                                    <span class="fips-quality @QualityClass(p.QualityScore, p.QualityScoreMax)">@QualityPercent(p.QualityScore, p.QualityScoreMax)</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </form>
    }
    else
    {
        <div class="dfe-c-table-wrap">
            <table>
                <caption class="govuk-visually-hidden">Products</caption>
                <thead>
                    <tr>
                        <th scope="col">Name</th>
                        <th scope="col">Phase</th>
                        <th scope="col">Business area</th>
                        <th scope="col">Service owner</th>
                        <th scope="col">Reporting contact</th>
                        <th scope="col">Quality</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Products)
                    {
                        <tr>
                            <td>
                                <a href="@Url.Action("ServiceRegisterProduct", "ModernOperations", new { id = p.Id })" class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold">@p.Title</a>
                                <span class="govuk-body-s dfe-c-text-muted" style="display:block;">ID: @p.UniqueID</span>
                            </td>
                            <td>@(p.PhaseName ?? "—")</td>
                            <td>@(string.IsNullOrWhiteSpace(p.BusinessAreaDisplay) ? "—" : p.BusinessAreaDisplay)</td>
                            <td>@(p.ServiceOwner ?? "—")</td>
                            <td>@(p.ReportingContact ?? "—")</td>
                            <td>
                                <span class="fips-quality @QualityClass(p.QualityScore, p.QualityScoreMax)">@QualityPercent(p.QualityScore, p.QualityScoreMax)</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (Model.CanSyncFromCmdb)
{
 <div id="fips-cmdb-bulk-sync-confirm-modal" class="fips-modal fips-cmdb-sync-modal" hidden role="dialog" aria-modal="true" aria-labelledby="fips-cmdb-bulk-sync-confirm-title">
 <div class="fips-modal__content fips-cmdb-sync-modal__panel">
 <h2 class="govuk-heading-m govuk-!-margin-top-0" id="fips-cmdb-bulk-sync-confirm-title">Run CMDB sync?</h2>
 <p class="govuk-body">This will sync every matching FIPS product to CMDB. It will update existing products, add new product entries, and update contacts, titles, and descriptions from CMDB.</p>
 <p class="govuk-body"><strong>Product categories are not updated</strong> by this sync. Categories are managed separately in Compass.</p>
 <div class="govuk-button-group govuk-!-margin-bottom-0">
 <button type="button" class="govuk-button" id="fips-cmdb-bulk-sync-confirm-proceed">Run sync</button>
 <button type="button" class="govuk-button govuk-button--secondary" id="fips-cmdb-bulk-sync-confirm-cancel">Cancel</button>
        </div>
    </div>
    </div>

 <div id="fips-cmdb-bulk-sync-modal" class="fips-modal fips-cmdb-sync-modal" hidden role="dialog" aria-modal="true" aria-labelledby="fips-cmdb-bulk-sync-title">
 <div class="fips-modal__content fips-cmdb-sync-modal__panel">
 <h2 class="govuk-heading-m govuk-!-margin-top-0" id="fips-cmdb-bulk-sync-title">Sync from CMDB</h2>
 <p class="govuk-body" id="fips-cmdb-bulk-sync-live" aria-live="polite" aria-atomic="true">Starting…</p>
 <div class="fips-cmdb-sync-modal__progress-wrap govuk-!-margin-bottom-4">
 <progress id="fips-cmdb-bulk-sync-progress" class="fips-cmdb-sync-modal__progress" max="100" value="0" aria-hidden="true"></progress>
 <p class="govuk-body-s govuk-!-margin-top-1 govuk-!-margin-bottom-0" id="fips-cmdb-bulk-sync-count" style="color:#505a5f;"></p>
            </div>
 <div id="fips-cmdb-bulk-sync-summary" class="govuk-body-s govuk-!-margin-bottom-4" style="display:none;color:#0b0c0c;"></div>
 <div class="govuk-button-group govuk-!-margin-bottom-0">
 <button type="button" class="govuk-button" id="fips-cmdb-bulk-sync-close" style="display:none;">Close and refresh</button>
 <button type="button" class="govuk-button govuk-button--secondary" id="fips-cmdb-bulk-sync-dismiss" disabled>Cancel</button>
            </div>
        </div>
    </div>
}

@section Scripts {
    @if (Model.CanSyncFromCmdb)
    {
        <script nonce="@Context.Items["Nonce"]">
            (function () {
                var streamUrl = @Html.Raw(Json.Serialize(Url.Action("ServiceRegisterSyncStream", "ModernOperations")));
                var startBtn = document.getElementById('fips-cmdb-bulk-sync-start');
                var confirmModal = document.getElementById('fips-cmdb-bulk-sync-confirm-modal');
                var confirmProceed = document.getElementById('fips-cmdb-bulk-sync-confirm-proceed');
                var confirmCancel = document.getElementById('fips-cmdb-bulk-sync-confirm-cancel');
                var modal = document.getElementById('fips-cmdb-bulk-sync-modal');
                var live = document.getElementById('fips-cmdb-bulk-sync-live');
                var progress = document.getElementById('fips-cmdb-bulk-sync-progress');
                var countEl = document.getElementById('fips-cmdb-bulk-sync-count');
                var summary = document.getElementById('fips-cmdb-bulk-sync-summary');
                var closeBtn = document.getElementById('fips-cmdb-bulk-sync-close');
                var dismissBtn = document.getElementById('fips-cmdb-bulk-sync-dismiss');
                var tokenForm = document.getElementById('fips-cmdb-bulk-sync-antiforgery');
                if (!startBtn || !confirmModal || !modal || !tokenForm) return;

                var syncFinished = false;
                var abortController = null;

                function getToken() {
                    var input = tokenForm.querySelector('input[name="__RequestVerificationToken"]');
                    return input ? input.value : '';
                }

                function openModal() {
                    syncFinished = false;
                    abortController = new AbortController();
                    modal.hidden = false;
                    summary.style.display = 'none';
                    summary.textContent = '';
                    closeBtn.style.display = 'none';
                    dismissBtn.disabled = false;
                    dismissBtn.textContent = 'Cancel';
                    progress.value = 0;
                    countEl.textContent = '';
                    live.textContent = 'Starting…';
                    startBtn.disabled = true;
                }

                function endModal(success) {
                    syncFinished = true;
                    abortController = null;
                    startBtn.disabled = false;
                    dismissBtn.textContent = 'Close';
                    if (success) {
                        closeBtn.style.display = '';
                    }
                }

                function applyProgress(data) {
                    if (data.message) live.textContent = data.message;
                    if (data.processed != null && data.total != null && data.total > 0) {
                        var pct = Math.min(100, Math.round((data.processed / data.total) * 100));
                        progress.value = pct;
                        countEl.textContent = 'Processed ' + data.processed + ' of ' + data.total + ' CMDB rows.';
                    } else if (data.phase === 'preparing' || data.phase === 'loading_cmdb') {
                        progress.removeAttribute('value');
                    }
                }

                function buildSummary(r) {
                    var lines = [];
                    lines.push('Updated ' + r.updated + ' product(s). Status set by sync rules: ' + r.statusSetByRules + '.');
                    lines.push('Skipped — retired in Compass: ' + r.skippedRetired + '; no sys_id: ' + r.skippedNoSysId + '; no local match: ' + r.skippedNoLocalMatch + '.');
                    if (r.errors > 0) {
                        lines.push('Errors: ' + r.errors + '.');
                        if (r.errorSamples && r.errorSamples.length) lines.push(r.errorSamples.join(' '));
                    }
                    return lines.join(' ');
                }

                dismissBtn.addEventListener('click', function () {
                    if (!syncFinished && abortController) {
                        abortController.abort();
                    }
                    modal.hidden = true;
                });
                closeBtn.addEventListener('click', function () {
                    window.location.reload();
                });

                function openConfirmModal() {
                    confirmModal.hidden = false;
                    if (confirmProceed) {
                        setTimeout(function () { confirmProceed.focus(); }, 0);
                    }
                }

                function closeConfirmModal() {
                    confirmModal.hidden = true;
                    startBtn.focus();
                }

                function startBulkStreamSync() {
                    openModal();
                    var body = new URLSearchParams();
                    body.set('__RequestVerificationToken', getToken());
                    fetch(streamUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'Accept': 'text/event-stream'
                        },
                        body: body,
                        signal: abortController.signal
                    }).then(function (res) {
                        if (!res.ok) {
                            live.textContent = 'Sync could not start (' + res.status + ').';
                            endModal(false);
                            return null;
                        }
                        return res.body.getReader();
                    }).then(function (reader) {
                        if (!reader) return;
                        var decoder = new TextDecoder();
                        var buffer = '';
                        function pump() {
                            return reader.read().then(function (result) {
                                if (result.done) {
                                    return;
                                }
                                buffer += decoder.decode(result.value, { stream: true });
                                var parts = buffer.split('\n\n');
                                buffer = parts.pop() || '';
                                for (var i = 0; i < parts.length; i++) {
                                    var block = parts[i].trim();
                                    if (block.indexOf('data: ') !== 0) continue;
                                    var jsonStr = block.slice(6);
                                    var data;
                                    try { data = JSON.parse(jsonStr); } catch (e) { continue; }
                                    if (data.phase === 'complete' && data.success && data.result) {
                                        progress.value = 100;
                                        countEl.textContent = '';
                                        live.textContent = 'Sync finished.';
                                        summary.style.display = '';
                                        summary.textContent = buildSummary(data.result);
                                        endModal(true);
                                    } else if (data.phase === 'error') {
                                        live.textContent = data.message || 'Sync failed.';
                                        endModal(false);
                                    } else {
                                        applyProgress(data);
                                    }
                                }
                                return pump();
                            });
                        }
                        return pump();
                    }).catch(function (err) {
                        if (err && err.name === 'AbortError') {
                            live.textContent = 'Sync cancelled.';
                        } else {
                            live.textContent = 'Network error during sync.';
                        }
                        endModal(false);
                    });
                }

                startBtn.addEventListener('click', function () {
                    openConfirmModal();
                });

                if (confirmCancel) {
                    confirmCancel.addEventListener('click', function () {
                        closeConfirmModal();
                    });
                }
                if (confirmProceed) {
                    confirmProceed.addEventListener('click', function () {
                        closeConfirmModal();
                        startBulkStreamSync();
                    });
                }
                confirmModal.addEventListener('click', function (e) {
                    if (e.target === confirmModal) {
                        closeConfirmModal();
                    }
                });
                document.addEventListener('keydown', function (e) {
                    if (e.key === 'Escape' && !confirmModal.hidden) {
                        e.preventDefault();
                        closeConfirmModal();
                    }
                });
            })();
        </script>
    }
    @if (showBulkManagement)
    {
        <script nonce="@Context.Items["Nonce"]">
            (function () {
                var all = document.getElementById('sr-bulk-select-all');
                var form = document.getElementById('sr-bulk-new-form');
                if (!all || !form) return;
                all.addEventListener('change', function () {
                    var on = all.checked;
                    form.querySelectorAll('input.sr-bulk-row-cb[type="checkbox"]').forEach(function (cb) {
                        cb.checked = on;
                    });
                });
            })();
        </script>
    }
}
