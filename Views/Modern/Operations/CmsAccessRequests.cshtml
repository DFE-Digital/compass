@model Compass.ViewModels.Modern.CmsAccessRequestListViewModel
@using Compass.ViewModels.Modern
@{
  ViewData["Title"] = "CMS requests";
  var tab = Model.ActiveTab;
}
@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernOperations")">Operations</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">CMS requests</li>
}

<div class="modern-work-page modern-operations-cms-requests">
  @{
    var cmsReqLede = await Html.PartialAsync("_CmsAccessRequestsHeaderLede");
  }
  @await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
    Caption = "Operations",
    Title = "CMS requests",
    Lede = cmsReqLede
  })

  @if (TempData["ErrorMessage"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
  {
    <div class="govuk-error-summary" role="alert" data-module="govuk-error-summary">
      <h2 class="govuk-error-summary__title">There is a problem</h2>
      <div class="govuk-error-summary__body"><p>@errorMessage</p></div>
    </div>
  }
  @if (TempData["SuccessMessage"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
  {
    <div class="govuk-notification-banner govuk-notification-banner--success" role="region">
      <div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">Success</h2></div>
      <div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">@successMessage</p></div>
    </div>
  }

  <nav class="dfe-f-sub-navigation govuk-!-margin-bottom-4" aria-label="CMS request status">
    <ul class="dfe-f-sub-navigation__list">
      <li class="dfe-f-sub-navigation__item@(tab == "new" ? " dfe-f-sub-navigation__item--active" : "")">
        <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" href="@Url.Action("CmsRequests", "ModernOperations", new { tab = "new" })"@if (tab == "new") { <text> aria-current="page"</text> }>New <span class="dfe-c-fw-regular">(@Model.NewCount)</span></a>
      </li>
      <li class="dfe-f-sub-navigation__item@(tab == "completed" ? " dfe-f-sub-navigation__item--active" : "")">
        <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" href="@Url.Action("CmsRequests", "ModernOperations", new { tab = "completed" })"@if (tab == "completed") { <text> aria-current="page"</text> }>Completed <span class="dfe-c-fw-regular">(@Model.CompletedCount)</span></a>
      </li>
      <li class="dfe-f-sub-navigation__item@(tab == "rejected" ? " dfe-f-sub-navigation__item--active" : "")">
        <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" href="@Url.Action("CmsRequests", "ModernOperations", new { tab = "rejected" })"@if (tab == "rejected") { <text> aria-current="page"</text> }>Rejected <span class="dfe-c-fw-regular">(@Model.RejectedCount)</span></a>
      </li>
    </ul>
  </nav>

  @if (!Model.Rows.Any())
  {
    <div class="modern-operations-cms-requests__empty" role="status">
      <p class="govuk-body govuk-!-margin-bottom-0">No requests in this queue.</p>
    </div>
  }
  else
  {
    <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
      <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
    <table class="govuk-table govuk-!-margin-bottom-0">
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Requestor</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">CMS</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Date requested</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Status</button>
        </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Outcome</button>
        </th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
      @foreach (var row in Model.Rows)
      {
        <tr class="govuk-table__row">
          <td class="govuk-table__cell">
            <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("CmsRequestDetail", "ModernOperations", new { id = row.Id, returnTab = tab })">@row.RequestorDisplayName</a>
          </td>
          <td class="govuk-table__cell">@row.CmsName</td>
          <td class="govuk-table__cell">@row.DateRequested.ToString("dd MMM yyyy HH:mm")</td>
          <td class="govuk-table__cell">@row.Status</td>
          <td class="govuk-table__cell">@(row.Outcome ?? "—")</td>
        </tr>
      }
      </tbody>
      </table>
    </div>
  }
</div>
