@model List<FipsCmdbSyncRule>
@{
    ViewData["Title"] = "CMDB sync rules";
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernOperations")">Operations</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("ServiceRegister", "ModernOperations")">Service register</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">CMDB sync rules</li>
}

<div class="dfe-c-flex--between dfe-c-mb-3" style="flex-wrap:wrap;gap:1rem;">
 <div class="dfe-c-page-title" style="margin:0;">
 <div class="dfe-c-page-title__caption">Operations</div>
 <h1 class="dfe-c-page-title__heading">CMDB sync rules</h1>
 <p class="govuk-body-s govuk-!-margin-top-1 govuk-!-margin-bottom-0" style="color:#505a5f;">
            After each product is updated from CMDB, rules run in order. The first match sets status to Rejected or Retired (inactive).
            Use <strong>Mapped text</strong> for title and descriptions, <strong>Service classification</strong> for the CMDB <code>service_classification</code> field (e.g. Business Service), or <strong>Raw JSON</strong> to match any substring in the stored CMDB snapshot.
        </p>
    </div>
    <div>
 <a href="@Url.Action("ServiceRegister", "ModernOperations")" class="govuk-link govuk-link--no-visited-state">Back to service register</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
 <div class="govuk-notification-banner govuk-notification-banner--success dfe-c-mb-3" role="region">
 <div class="govuk-notification-banner__header">
 <h2 class="govuk-notification-banner__title">Success</h2>
        </div>
 <div class="govuk-notification-banner__content">
 <p class="govuk-notification-banner__heading">@TempData["Success"]</p>
        </div>
    </div>
}
@if (TempData["Error"] != null)
{
 <div class="govuk-error-summary dfe-c-mb-3" role="alert">
 <h2 class="govuk-error-summary__title">There is a problem</h2>
 <div class="govuk-error-summary__body">@TempData["Error"]</div>
    </div>
}

<div class="dfe-c-card dfe-c-card--plain govuk-!-margin-bottom-6">
 <h2 class="govuk-heading-m govuk-!-margin-top-0">Add rule</h2>
 <form method="post" action="@Url.Action("ServiceRegisterCmdbRulesAdd", "ModernOperations")" class="govuk-!-margin-bottom-0">
        @Html.AntiForgeryToken()
 <div class="govuk-form-group">
 <label class="govuk-label" for="rule-name">Name (optional)</label>
 <input class="govuk-input govuk-!-width-two-thirds" id="rule-name" name="name" type="text" maxlength="200" autocomplete="off" />
        </div>
 <div class="govuk-form-group">
 <label class="govuk-label" for="rule-fieldScope">Field</label>
 <select class="govuk-select" id="rule-fieldScope" name="fieldScope">
                @foreach (var s in FipsCmdbSyncRuleScopes.All)
                {
                    if (s == FipsCmdbSyncRuleScopes.MappedText)
                    {
                        <option value="@s" selected>@s</option>
                    }
                    else
                    {
                        <option value="@s">@s</option>
                    }
                }
            </select>
        </div>
 <div class="govuk-form-group">
 <label class="govuk-label" for="rule-matchKind">Match</label>
 <select class="govuk-select" id="rule-matchKind" name="matchKind">
                <option value="@FipsCmdbSyncRuleMatchKinds.Contains" selected>Contains (case-insensitive)</option>
                <option value="@FipsCmdbSyncRuleMatchKinds.Regex">Regular expression</option>
            </select>
        </div>
 <div class="govuk-form-group">
 <label class="govuk-label" for="rule-pattern">Pattern</label>
 <div class="govuk-hint" id="rule-pattern-hint">
                Examples: <code>(PP)</code> in the title; field <strong>Service classification</strong> + Contains + <code>Business Service</code>;
                or field <strong>Raw JSON</strong> + Contains + <code>"service_classification":"Business Service"</code> (spacing may vary — use Regex if needed).
            </div>
 <input class="govuk-input" id="rule-pattern" name="pattern" type="text" maxlength="2000" required aria-describedby="rule-pattern-hint" autocomplete="off" />
        </div>
 <div class="govuk-form-group">
 <label class="govuk-label" for="rule-targetStatus">Set status to</label>
 <select class="govuk-select" id="rule-targetStatus" name="targetStatus">
                <option value="@((int)CMDBProductStatus.Rejected)" selected>Rejected</option>
                <option value="@((int)CMDBProductStatus.Inactive)">Retired (inactive)</option>
            </select>
        </div>
 <div class="govuk-form-group">
 <label class="govuk-label" for="rule-sortOrder">Sort order</label>
 <div class="govuk-hint" id="rule-sort-hint">Lower numbers run first.</div>
 <input class="govuk-input govuk-input--width-5" id="rule-sortOrder" name="sortOrder" type="number" value="10" aria-describedby="rule-sort-hint" />
        </div>
 <div class="govuk-checkboxes govuk-!-margin-bottom-4" data-module="govuk-checkboxes">
 <div class="govuk-checkboxes__item">
 <input class="govuk-checkboxes__input" id="rule-isActive" name="isActive" type="checkbox" value="true" checked />
 <label class="govuk-label govuk-checkboxes__label" for="rule-isActive">Active</label>
            </div>
        </div>
 <button type="submit" class="govuk-button">Add rule</button>
    </form>
</div>

<h2 class="govuk-heading-m">Existing rules</h2>
@if (Model == null || Model.Count == 0)
{
 <p class="govuk-body">No rules yet. Add one above, then run <strong>Sync from CMDB</strong> on the service register.</p>
}
else
{
 <div class="dfe-c-table-wrap">
 <table>
 <caption class="govuk-visually-hidden">CMDB sync rules</caption>
 <thead>
 <tr>
 <th scope="col">Order</th>
 <th scope="col">Active</th>
 <th scope="col">Name</th>
 <th scope="col">Field</th>
 <th scope="col">Match</th>
 <th scope="col">Pattern</th>
 <th scope="col">Status</th>
 <th scope="col">Actions</th>
                </tr>
            </thead>
 <tbody>
            @foreach (var r in Model)
            {
 <tr>
 <td>@r.SortOrder</td>
 <td>@(r.IsActive ? "Yes" : "No")</td>
 <td>@(string.IsNullOrWhiteSpace(r.Name) ? "—" : r.Name)</td>
 <td>@r.FieldScope</td>
 <td>@r.MatchKind</td>
 <td style="max-width:18rem;word-break:break-word;">@r.Pattern</td>
 <td>@r.TargetStatus</td>
 <td>
 <div class="govuk-button-group" style="flex-wrap:wrap;">
 <form method="post" action="@Url.Action("ServiceRegisterCmdbRulesToggle", "ModernOperations", new { id = r.Id })" class="govuk-!-margin-bottom-0">
                                @Html.AntiForgeryToken()
 <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0">@(r.IsActive ? "Disable" : "Enable")</button>
                            </form>
 <form method="post" action="@Url.Action("ServiceRegisterCmdbRulesDelete", "ModernOperations", new { id = r.Id })" class="govuk-!-margin-bottom-0" onsubmit="return confirm('Delete this rule?');">
                                @Html.AntiForgeryToken()
 <button type="submit" class="govuk-button govuk-button--warning govuk-!-margin-bottom-0">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
