@model Compass.ViewModels.Modern.ModernRaidEscalationManagementViewModel
@{
  ViewData["Title"] = "RAID — tier change requests";
  var tab = Model.ActiveTab;
  var escOn = tab == "escalations" ? "on" : null;
  var deOn = tab == "deescalations" ? "on" : null;
  var curOn = tab == "current" ? "on" : null;
  var actOn = tab == "active" ? "on" : null;
}
@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernOperations")">Operations</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">RAID tier requests</li>
}

<div class="modern-work-page" style="max-width: 100%; box-sizing: border-box;">
  <div class="dfe-c-mb-4 dfe-c-flex--between" style="flex-wrap:wrap;align-items:flex-start;gap:1rem;">
    <div class="dfe-c-page-title" style="margin:0;min-width:0;flex:1;max-width: 100%;">
      <div class="dfe-c-page-title__caption">Operations · RAID</div>
      <h1 class="dfe-c-page-title__heading">Tier change requests</h1>
    </div>
  </div>
  <p class="dfe-c-body dfe-c-text-muted govuk-!-margin-bottom-4" style="margin-top:0; max-width: 40rem;">
    Review tier-change requests from delivery teams. Approve or reject each escalation or de-escalation; approved risks move to the operational Tier&nbsp;1, Tier&nbsp;2 or Tier&nbsp;3 band that matches the requested governance level.
  </p>
  @if (TempData["ErrorMessage"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
  {
    <div class="govuk-error-summary" role="alert" data-module="govuk-error-summary">
      <h2 class="govuk-error-summary__title">There is a problem</h2>
      <div class="govuk-error-summary__body"><p>@errorMessage</p></div>
    </div>
  }
  @if (TempData["SuccessMessage"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
  {
    <div class="govuk-notification-banner govuk-notification-banner--success" role="region">
      <div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">Success</h2></div>
      <div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">@successMessage</p></div>
    </div>
  }

  <div class="dfe-c-card-grid dfe-c-card-grid--3 dfe-c-mb-3" role="region" aria-label="Request summary">
    <div class="dfe-c-metric dfe-c-metric--red">
      <div class="dfe-c-metric__number">@Model.PendingEscalationsCount</div>
      <div class="dfe-c-metric__label">Requested escalations (pending)</div>
    </div>
    <div class="dfe-c-metric dfe-c-metric--amber">
      <div class="dfe-c-metric__number">@Model.PendingDeescalationsCount</div>
      <div class="dfe-c-metric__label">Requested de-escalations (pending)</div>
    </div>
    <div class="dfe-c-metric dfe-c-metric--navy">
      <div class="dfe-c-metric__number">@Model.CurrentlyEscalatedCount</div>
      <div class="dfe-c-metric__label">Currently escalated (from approved moves)</div>
    </div>
  </div>

  <div class="mr-report-section-panel dfe-c-collapsible dfe-c-collapsible--open govuk-!-margin-bottom-4" style="max-width: 100%;">
    <button type="button" class="dfe-c-collapsible__trigger" aria-expanded="true">
      <span class="dfe-c-collapsible__icon" aria-hidden="true">−</span>
      <span>How approval maps proposed tiers to operational bands</span>
    </button>
    <div class="dfe-c-collapsible__body">
      <p class="dfe-c-body-s dfe-c-text-muted govuk-!-margin-bottom-0">
        A “Tier 2 — Proposed” (or similar) request matches the <strong>governance level</strong> of Tier 2. When you approve, the risk is set to the <strong>operational</strong> risk tier in admin with that same level (for example <strong>Tier 2</strong>).
        De-escalations work the same way. Use <strong>Action request</strong> in the list to approve or reject and record a reason. The risk name link opens the same action. Use <strong>View in RAID</strong> only to read the full risk in the main RAID app.
      </p>
    </div>
  </div>

  <div class="tabs govuk-!-margin-bottom-4" role="tablist" aria-label="Tier request queues">
    <a class="tab @escOn"
       role="tab"
       id="tab-raid-esc"
       aria-selected="@(tab == "escalations" ? "true" : "false")"
       @if (tab == "escalations") { <text>aria-current="page" </text> }
       href="@Url.Action("RaidEscalations", "ModernOperations", new { tab = "escalations" })">Requested escalations <span class="dfe-c-fw-regular">(@Model.PendingEscalationsCount)</span></a>
    <a class="tab @deOn"
       role="tab"
       id="tab-raid-de"
       aria-selected="@(tab == "deescalations" ? "true" : "false")"
       @if (tab == "deescalations") { <text>aria-current="page" </text> }
       href="@Url.Action("RaidEscalations", "ModernOperations", new { tab = "deescalations" })">Requested de-escalations <span class="dfe-c-fw-regular">(@Model.PendingDeescalationsCount)</span></a>
    <a class="tab @curOn"
       role="tab"
       id="tab-raid-cur"
       aria-selected="@(tab == "current" ? "true" : "false")"
       @if (tab == "current") { <text>aria-current="page" </text> }
       href="@Url.Action("RaidEscalations", "ModernOperations", new { tab = "current" })">Currently escalated <span class="dfe-c-fw-regular">(@Model.CurrentlyEscalatedCount)</span></a>
    <a class="tab @actOn"
       role="tab"
       id="tab-raid-active"
       aria-selected="@(tab == "active" ? "true" : "false")"
       @if (tab == "active") { <text>aria-current="page" </text> }
       href="@Url.Action("RaidEscalations", "ModernOperations", new { tab = "active" })">Active risks <span class="dfe-c-fw-regular">(@Model.ActiveRisksCount)</span></a>
  </div>

  <div class="tab-panel-region" style="min-height:2rem;" role="region" aria-label="Selected queue">
  @if (tab == "escalations")
  {
    ViewBag.RaidEscQueueEmpty = "No pending escalation requests."; ViewBag.RaidEscReturnTab = "escalations";
    @await Html.PartialAsync("_RaidEscalationQueueTable", Model.PendingEscalations)
  }
  else if (tab == "deescalations")
  {
    ViewBag.RaidEscQueueEmpty = "No pending de-escalation requests."; ViewBag.RaidEscReturnTab = "deescalations";
    @await Html.PartialAsync("_RaidEscalationQueueTable", Model.PendingDeescalations)
  }
  else if (tab == "current")
  {
    @if (!Model.Current.Any())
    {
      <p class="govuk-body dfe-c-text-muted govuk-!-margin-bottom-0">No currently escalated open risks from approved tier moves. Approvals that increase governance appear here for monitoring.</p>
    }
    else
    {
      <div class="dfe-c-table-wrap">
        <table id="raid-ops-escalations-current" aria-label="Risks currently in an escalated position" class="govuk-!-margin-bottom-0">
          <thead>
            <tr>
              <th scope="col">Risk</th>
              <th scope="col">Before</th>
              <th scope="col">After (current)</th>
              <th scope="col">Move</th>
              <th scope="col">Approved</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var row in Model.Current)
            {
              var detailUrl = Url.Action("RiskDetail", "ModernRaid", new { id = row.RecordId });
              <tr>
                <td>
                  <a class="dfe-c-link govuk-!-font-weight-bold" href="@detailUrl" rel="noopener noreferrer" target="_blank">@row.Reference</a>
                  <div class="govuk-body-s dfe-c-text-muted">@row.Title</div>
                </td>
                <td class="govuk-body-s">@row.PreviousTier</td>
                <td class="govuk-body-s">@row.CurrentTier</td>
                <td class="govuk-body-s">@row.EscalationPath</td>
                <td class="govuk-body-s">@(string.IsNullOrWhiteSpace(row.ApprovedBy) ? "—" : row.ApprovedBy)<br />@((row.ApprovedAt ?? row.UpdatedAt).ToString("d MMM yyyy"))</td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  }
  else
  {
    <p class="govuk-body govuk-!-margin-bottom-4" style="max-width: 40rem;">
      Select a risk to open the full <strong>Operations</strong> editor. You can set the risk tier (including to an operational band) without using the delivery-team escalation request, and you must record a reason — it is appended to the risk notes.
    </p>
    @if (!Model.ActiveRisks.Any())
    {
      <p class="govuk-body dfe-c-text-muted govuk-!-margin-bottom-0">No open risks in the register.</p>
    }
    else
    {
      <div class="dfe-c-table-wrap">
        <table id="raid-ops-active-risks" class="govuk-!-margin-bottom-0" aria-label="Active open risks">
          <thead>
            <tr>
              <th scope="col">Reference</th>
              <th scope="col">Title</th>
              <th scope="col">Tier</th>
              <th scope="col">Status</th>
              <th scope="col">Updated</th>
              <th scope="col">Action</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var r in Model.ActiveRisks)
            {
              var editUrl = Url.Action("RaidRiskOperationsEdit", "ModernOperations", new { id = r.Id });
              <tr>
                <td class="govuk-body-s govuk-!-font-weight-bold">@r.Reference</td>
                <td class="govuk-body-s">@r.Title</td>
                <td class="govuk-body-s">@(r.TierName ?? "—")</td>
                <td class="govuk-body-s">@(r.StatusLabel ?? "—")</td>
                <td class="govuk-body-s">@r.UpdatedAt.ToString("d MMM yyyy")</td>
                <td class="govuk-body-s">
                  @if (!string.IsNullOrEmpty(editUrl))
                  {
                    <a class="govuk-link" href="@editUrl">Edit in Operations</a>
                  }
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  }
  </div>
</div>
