@model Compass.ViewModels.Modern.ModernRaidEscalationManagementViewModel
@using Compass.ViewModels.Modern
@{
  ViewData["Title"] = "RAID — tier change requests";
  var tab = Model.ActiveTab;
}
@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernOperations")">Operations</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">RAID tier requests</li>
}

<div class="modern-work-page modern-operations-raid-escalations">
  @{
    var raidEscIntro = await Html.PartialAsync("_RaidEscalationsIntroLede");
  }
  @await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
    Caption = "Operations · RAID",
    Title = "Tier change requests",
    Lede = raidEscIntro
  })
  @if (TempData["ErrorMessage"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
  {
    <div class="govuk-error-summary" role="alert" data-module="govuk-error-summary">
      <h2 class="govuk-error-summary__title">There is a problem</h2>
      <div class="govuk-error-summary__body"><p>@errorMessage</p></div>
    </div>
  }
  @if (TempData["SuccessMessage"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
  {
    <div class="govuk-notification-banner govuk-notification-banner--success" role="region">
      <div class="govuk-notification-banner__header"><h2 class="govuk-notification-banner__title">Success</h2></div>
      <div class="govuk-notification-banner__content"><p class="govuk-notification-banner__heading">@successMessage</p></div>
    </div>
  }

  <div class="dfe-f-card-grid govuk-!-margin-bottom-3" role="region" aria-label="Request summary">
    @await Html.PartialAsync("~/Views/Modern/Raid/_RaidDashboardStatCard.cshtml", new Compass.ViewModels.Modern.RaidDashboardStatCardVm
    {
      Label = "Requested escalations (pending)",
      Value = Model.PendingEscalationsCount.ToString("N0"),
      Trend = "View queue",
      Href = Url.Action("RaidEscalations", "ModernOperations", new { tab = "escalations" }) ?? "#",
      AriaLabel = $"Requested escalations pending, {Model.PendingEscalationsCount}",
      TintClass = "dfe-f-stat-card--tint-red"
    })
    @await Html.PartialAsync("~/Views/Modern/Raid/_RaidDashboardStatCard.cshtml", new Compass.ViewModels.Modern.RaidDashboardStatCardVm
    {
      Label = "Requested de-escalations (pending)",
      Value = Model.PendingDeescalationsCount.ToString("N0"),
      Trend = "View queue",
      Href = Url.Action("RaidEscalations", "ModernOperations", new { tab = "deescalations" }) ?? "#",
      AriaLabel = $"Requested de-escalations pending, {Model.PendingDeescalationsCount}",
      TintClass = "dfe-f-stat-card--tint-orange"
    })
    @await Html.PartialAsync("~/Views/Modern/Raid/_RaidDashboardStatCard.cshtml", new Compass.ViewModels.Modern.RaidDashboardStatCardVm
    {
      Label = "Currently escalated (from approved moves)",
      Value = Model.CurrentlyEscalatedCount.ToString("N0"),
      Trend = "View queue",
      Href = Url.Action("RaidEscalations", "ModernOperations", new { tab = "current" }) ?? "#",
      AriaLabel = $"Currently escalated from approved moves, {Model.CurrentlyEscalatedCount}",
      TintClass = "dfe-f-stat-card--tint-blue"
    })
    @await Html.PartialAsync("~/Views/Modern/Raid/_RaidDashboardStatCard.cshtml", new Compass.ViewModels.Modern.RaidDashboardStatCardVm
    {
      Label = "Active risks (open)",
      Value = Model.ActiveRisksCount.ToString("N0"),
      Trend = "Edit in Operations",
      Href = Url.Action("RaidEscalations", "ModernOperations", new { tab = "active" }) ?? "#",
      AriaLabel = $"Active open risks, {Model.ActiveRisksCount}",
      TintClass = "dfe-f-stat-card--tint-grey"
    })
  </div>

  <div class="mr-report-section-panel dfe-f-toggle govuk-!-margin-bottom-4" data-module="dfe-f-toggle">
    <div class="dfe-f-toggle__title-wrapper">
      <h2 class="dfe-f-toggle__heading govuk-!-margin-bottom-0">
        <button type="button" class="dfe-f-toggle__button" aria-expanded="true" aria-controls="raid-esc-approval-help" id="raid-esc-approval-help-btn">
          <span class="dfe-f-toggle__icon" aria-hidden="true"></span>
          <span class="dfe-f-toggle__title">How approval maps proposed tiers to operational bands</span>
        </button>
      </h2>
    </div>
    <div id="raid-esc-approval-help" class="dfe-f-toggle__content">
      <div class="dfe-f-toggle__body">
        <p class="govuk-body govuk-!-margin-bottom-0">
          A “Tier 2 — Proposed” (or similar) request matches the <strong>governance level</strong> of Tier 2. When you approve, the risk is set to the <strong>operational</strong> risk tier in admin with that same level (for example <strong>Tier 2</strong>).
          De-escalations work the same way. Use <strong>Action request</strong> in the list to approve or reject and record a reason. The risk name link opens the same action. Use <strong>View in RAID</strong> only to read the full risk in the main RAID app.
        </p>
      </div>
    </div>
  </div>

  <nav class="dfe-f-sub-navigation govuk-!-margin-bottom-4" aria-label="Tier request queues">
    <ul class="dfe-f-sub-navigation__list">
      <li class="dfe-f-sub-navigation__item@(tab == "escalations" ? " dfe-f-sub-navigation__item--active" : "")">
        <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" id="tab-raid-esc" href="@Url.Action("RaidEscalations", "ModernOperations", new { tab = "escalations" })"@if (tab == "escalations") { <text> aria-current="page"</text> }>Requested escalations <span class="dfe-c-fw-regular">(@Model.PendingEscalationsCount)</span></a>
      </li>
      <li class="dfe-f-sub-navigation__item@(tab == "deescalations" ? " dfe-f-sub-navigation__item--active" : "")">
        <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" id="tab-raid-de" href="@Url.Action("RaidEscalations", "ModernOperations", new { tab = "deescalations" })"@if (tab == "deescalations") { <text> aria-current="page"</text> }>Requested de-escalations <span class="dfe-c-fw-regular">(@Model.PendingDeescalationsCount)</span></a>
      </li>
      <li class="dfe-f-sub-navigation__item@(tab == "current" ? " dfe-f-sub-navigation__item--active" : "")">
        <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" id="tab-raid-cur" href="@Url.Action("RaidEscalations", "ModernOperations", new { tab = "current" })"@if (tab == "current") { <text> aria-current="page"</text> }>Currently escalated <span class="dfe-c-fw-regular">(@Model.CurrentlyEscalatedCount)</span></a>
      </li>
      <li class="dfe-f-sub-navigation__item@(tab == "active" ? " dfe-f-sub-navigation__item--active" : "")">
        <a class="dfe-f-sub-navigation__link govuk-link govuk-link--no-visited-state" id="tab-raid-active" href="@Url.Action("RaidEscalations", "ModernOperations", new { tab = "active" })"@if (tab == "active") { <text> aria-current="page"</text> }>Active risks <span class="dfe-c-fw-regular">(@Model.ActiveRisksCount)</span></a>
      </li>
    </ul>
  </nav>

  <div class="tab-panel-region" style="min-height:2rem;" role="region" aria-label="Selected queue">
  @if (tab == "escalations")
  {
    ViewBag.RaidEscQueueEmpty = "No pending escalation requests."; ViewBag.RaidEscReturnTab = "escalations";
    @await Html.PartialAsync("_RaidEscalationQueueTable", Model.PendingEscalations)
  }
  else if (tab == "deescalations")
  {
    ViewBag.RaidEscQueueEmpty = "No pending de-escalation requests."; ViewBag.RaidEscReturnTab = "deescalations";
    @await Html.PartialAsync("_RaidEscalationQueueTable", Model.PendingDeescalations)
  }
  else if (tab == "current")
  {
    @if (!Model.Current.Any())
    {
      <div class="modern-operations-raid-escalations__empty" role="status">
        <p class="govuk-body govuk-!-margin-bottom-0">No currently escalated open risks from approved tier moves. Approvals that increase governance appear here for monitoring.</p>
      </div>
    }
    else
    {
      <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
        <table id="raid-ops-escalations-current" aria-label="Risks currently in an escalated position" class="govuk-table govuk-!-margin-bottom-0">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Risk</button>
        </th>
              <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Before</button>
        </th>
              <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">After (current)</button>
        </th>
              <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Move</button>
        </th>
              <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Approved</button>
        </th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            @foreach (var row in Model.Current)
            {
              var detailUrl = Url.Action("RiskDetail", "ModernRaid", new { id = row.RecordId });
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">
                  <a class="govuk-link govuk-!-font-weight-bold govuk-link--no-visited-state" href="@detailUrl" rel="noopener noreferrer" target="_blank">@row.Reference</a>
                  <div class="govuk-body-s dfe-c-text-muted">@row.Title</div>
                </td>
                <td class="govuk-table__cell">@row.PreviousTier</td>
                <td class="govuk-table__cell">@row.CurrentTier</td>
                <td class="govuk-table__cell">@row.EscalationPath</td>
                <td class="govuk-table__cell">@(string.IsNullOrWhiteSpace(row.ApprovedBy) ? "—" : row.ApprovedBy)<br />@((row.ApprovedAt ?? row.UpdatedAt).ToString("d MMM yyyy"))</td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  }
  else
  {
    <p class="govuk-body govuk-!-margin-bottom-4" style="max-width: 40rem;">
      Select a risk to open the full <strong>Operations</strong> editor. You can set the risk tier (including to an operational band) without using the delivery-team escalation request, and you must record a reason — it is appended to the risk notes.
    </p>
    @if (!Model.ActiveRisks.Any())
    {
      <div class="modern-operations-raid-escalations__empty" role="status">
        <p class="govuk-body govuk-!-margin-bottom-0">No open risks in the register.</p>
      </div>
    }
    else
    {
      <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
        <table id="raid-ops-active-risks" class="govuk-table govuk-!-margin-bottom-0" aria-label="Active open risks">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Reference</button>
        </th>
              <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Title</button>
        </th>
              <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Tier</button>
        </th>
              <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Status</button>
        </th>
              <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Updated</button>
        </th>
              <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Action</button>
        </th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            @foreach (var r in Model.ActiveRisks)
            {
              var editUrl = Url.Action("RaidRiskOperationsEdit", "ModernOperations", new { id = r.Id });
              <tr class="govuk-table__row">
                <td class="govuk-table__cell dfe-c-mono govuk-!-font-weight-bold">@r.Reference</td>
                <td class="govuk-table__cell">@r.Title</td>
                <td class="govuk-table__cell">@(r.TierName ?? "—")</td>
                <td class="govuk-table__cell">@(r.StatusLabel ?? "—")</td>
                <td class="govuk-table__cell">@r.UpdatedAt.ToString("d MMM yyyy")</td>
                <td class="govuk-table__cell">
                  @if (!string.IsNullOrEmpty(editUrl))
                  {
                    <a class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" href="@editUrl">Edit in Operations</a>
                  }
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  }
  </div>
</div>
