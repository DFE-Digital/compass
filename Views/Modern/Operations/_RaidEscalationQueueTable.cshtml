@model IReadOnlyList<Compass.ViewModels.Modern.ModernRaidEscalationPendingRow>
@{
  var emptyMsg = ViewBag.RaidEscQueueEmpty as string ?? "Nothing in this queue.";
  var returnTab = ViewBag.RaidEscReturnTab as string ?? "escalations";
}
@if (Model == null || Model.Count == 0)
{
  <div class="modern-operations-raid-escalations__empty" role="status">
    <p class="govuk-body govuk-!-margin-bottom-0">@emptyMsg</p>
  </div>
}
else
{
  <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
    <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
    <table id="raid-ops-escalations-pending" aria-label="Pending tier change requests" class="govuk-table govuk-!-margin-bottom-0">
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header" aria-sort="none">
            <button type="button" class="dfe-f-table-sort-button">Risk</button>
          </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
            <button type="button" class="dfe-f-table-sort-button">Current (proposed)</button>
          </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
            <button type="button" class="dfe-f-table-sort-button">Requested to</button>
          </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
            <button type="button" class="dfe-f-table-sort-button">Requestor</button>
          </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
            <button type="button" class="dfe-f-table-sort-button">Date</button>
          </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
            <button type="button" class="dfe-f-table-sort-button">Rationale (snippet)</button>
          </th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric">Actions</th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        @foreach (var row in Model)
        {
          var viewInRaidUrl = Url.Action("RiskDetail", "ModernRaid", new { id = row.RecordId });
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">
              @if (row.RequestId is { } titleRequestId)
              {
                var actionUrl = Url.Action("RaidEscalationAction", "ModernOperations", new { requestId = titleRequestId, returnTab = returnTab });
                <a class="govuk-link govuk-!-font-weight-bold govuk-link--no-visited-state" href="@actionUrl" title="Open the Operations view to approve or reject this tier request">@(!string.IsNullOrWhiteSpace(row.Title) ? row.Title : row.Reference)</a>
                <div class="dfe-c-mono govuk-body-s dfe-c-text-muted">@row.Reference
                  <span class="govuk-!-margin-left-1">· <a class="govuk-link govuk-link--no-visited-state" href="@viewInRaidUrl" rel="noopener noreferrer" target="_blank" title="Open the risk in RAID (read-only)">View in RAID</a></span>
                </div>
              }
              else
              {
                <a class="govuk-link govuk-!-font-weight-bold govuk-link--no-visited-state" href="@viewInRaidUrl" title="View risk in RAID — no pending request record in Operations; fix data or submit a new tier change from RAID">@(!string.IsNullOrWhiteSpace(row.Title) ? row.Title : row.Reference)</a>
                <div class="dfe-c-mono govuk-body-s dfe-c-text-muted">@row.Reference
                  <span class="govuk-!-margin-left-1 dfe-c-text-muted">· <span class="govuk-!-font-size-16">No pending request id</span></span>
                </div>
              }
            </td>
            <td class="govuk-table__cell">@row.CurrentTierLabel</td>
            <td class="govuk-table__cell">@row.ProposedTierLabel</td>
            <td class="govuk-table__cell">@row.RequestedBy</td>
            <td class="govuk-table__cell">@row.RequestedAt.ToString("d MMM yyyy")</td>
            <td class="govuk-table__cell" style="max-width:20rem; word-wrap:break-word;">
              <span title="@row.FullReason">@(string.IsNullOrWhiteSpace(row.ReasonSnippet) ? "—" : row.ReasonSnippet)</span>
            </td>
            <td class="govuk-table__cell">
              @if (row.RequestId is { } qid)
              {
                <a class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" href="@Url.Action("RaidEscalationAction", "ModernOperations", new { requestId = qid, returnTab = returnTab })">Action request</a>
              }
              else
              {
                <span class="govuk-body-s dfe-c-text-muted" title="The risk is in a proposed tier but there is no pending tier-change request in the database.">—</span>
              }
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}
