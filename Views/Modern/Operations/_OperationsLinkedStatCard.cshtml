@model Compass.ViewModels.Modern.OperationsLinkedStatCardViewModel
@{
  var tintSlug = string.IsNullOrWhiteSpace(Model.Tint) ? "grey" : Model.Tint.Trim().ToLowerInvariant();
}
@await Html.PartialAsync("~/Views/Modern/Raid/_RaidDashboardStatCard.cshtml", new Compass.ViewModels.Modern.RaidDashboardStatCardVm
{
  Label = Model.Label,
  Value = Model.Value,
  Trend = Model.TrendText,
  Href = Model.Href,
  AriaLabel = Model.AriaLabel,
  TintClass = $"dfe-f-stat-card--tint-{tintSlug}"
})
