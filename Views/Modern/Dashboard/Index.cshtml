@model HomeDashboardViewModel
@using System.Linq
@{
  ViewData["Title"] = "Your dashboard";

  string Trunc(string? s, int n)
  {
    if (string.IsNullOrEmpty(s)) return "—";
    return s.Length <= n ? s : s[..n] + "…";
  }

  string Greeting()
  {
    var h = DateTime.Now.Hour;
    return h < 12 ? "Good morning" : h < 17 ? "Good afternoon" : "Good evening";
  }

  string RagCssSuffix(string? ragName) => (ragName ?? "") switch
  {
    "Green" => "g",
    "Amber-Green" => "ag",
    "Amber" => "a",
    "Amber-Red" => "ar",
    "Red" => "r",
    _ => ""
  };

  string PhaseCssSuffix(string? phaseName)
  {
    if (string.IsNullOrWhiteSpace(phaseName)) return "";
    return phaseName.Replace(" ", "-", StringComparison.Ordinal).ToLowerInvariant();
  }

  var overdueCount = Model.OverdueMilestones.Count;
  var highIssueCount = Model.HighPriorityIssues.Count;
  var atRiskCount = Model.AtRiskProjects.Count;
  var updatesDueCount = Model.ProjectsNeedingMonthlyUpdates.Count;
  var returnsDueCount = Model.ProductsNeedingReturns.Count;
  var commissionCount = Model.ProductsNeedingCommissionReporting.Count;
  var actionCount = Model.AssignedActions.Count;
  var attentionCount = overdueCount + highIssueCount + atRiskCount + updatesDueCount + returnsDueCount + commissionCount + actionCount;

  var updatesDueByProjectId = Model.ProjectsNeedingMonthlyUpdates.ToDictionary(t => t.Project.Id, t => t.Status);

  var ragGroups = Model.MyProjects
    .GroupBy(p => p.RagStatusLookup?.Name ?? "Not set")
    .ToDictionary(g => g.Key, g => g.Count());
  int RagCount(string k) => ragGroups.TryGetValue(k, out var v) ? v : 0;
  var ragBarG = RagCount("Green") + RagCount("Amber-Green");
  var ragBarA = RagCount("Amber");
  var ragBarR = RagCount("Red") + RagCount("Amber-Red");
  var ragBarO = RagCount("Not set");

  var monthlySubmitted = Model.MyProjects.Count - updatesDueCount;
  if (monthlySubmitted < 0) monthlySubmitted = 0;
  var monthlyTotal = monthlySubmitted + updatesDueCount;
  var pctSubmitted = monthlyTotal > 0 ? (int)Math.Round(100.0 * monthlySubmitted / monthlyTotal) : 0;
  string MonthlyPctColour() =>
    pctSubmitted >= 90 ? "var(--rag-g)" : pctSubmitted >= 60 ? "var(--rag-a)" : "var(--rag-r)";
  string ProgressFillColour() => MonthlyPctColour();
}

<div class="dfe-c-flex--between dfe-c-mb-3" style="flex-wrap:wrap;gap:1rem;">
  <div>
    <div style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.7px;color:var(--grey-4);">DDT Central Operations</div>
    <h1 style="margin-bottom:0.25rem;">@Greeting(), @Model.FirstName</h1>
    <p class="dfe-c-text-muted">
      @DateTime.Today.ToString("dddd d MMMM yyyy")
      @if (attentionCount > 0)
      {
        <span> — <strong style="color:var(--black);">@attentionCount</strong> items need your attention</span>
      }
    </p>
  </div>
  <div class="dfe-c-export-group">
    <a class="govuk-button govuk-button--outline-blue" href="@Url.Action("Index", "Reports")">Reports</a>
  </div>
</div>

<div class="dfe-c-grid dfe-c-grid--4 dfe-c-mb-4">
  <a class="dfe-c-metric @(updatesDueCount > 0 ? "dfe-c-metric--red" : "dfe-c-metric--grey")" href="@Url.Action("Index", "ModernWork")" title="View your projects">
    <div class="dfe-c-metric__number" style="@(updatesDueCount > 0 ? "color:var(--rag-r);" : "")">@updatesDueCount</div>
    <div class="dfe-c-metric__label">Project monthly updates due</div>
    <div class="dfe-c-metric__note" style="color:var(--grey-4);">Projects →</div>
  </a>
  <a class="dfe-c-metric @(returnsDueCount > 0 ? "dfe-c-metric--amber" : "dfe-c-metric--grey")" href="@Url.Action("Index", "Products")" title="Product performance">
    <div class="dfe-c-metric__number" style="@(returnsDueCount > 0 ? "color:var(--rag-a);" : "")">@returnsDueCount</div>
    <div class="dfe-c-metric__label">Product returns due</div>
    <div class="dfe-c-metric__note" style="color:var(--grey-4);">Products →</div>
  </a>
  <a class="dfe-c-metric @(Model.UnmonitoredRisks.Count > 0 ? "dfe-c-metric--red" : "dfe-c-metric--grey")" href="@Url.Action("Index", "Risk")" title="Risk register">
    <div class="dfe-c-metric__number" style="@(Model.UnmonitoredRisks.Count > 0 ? "color:var(--rag-r);" : "")">@Model.UnmonitoredRisks.Count</div>
    <div class="dfe-c-metric__label">Risks needing review</div>
    <div class="dfe-c-metric__note" style="color:var(--grey-4);">Risks →</div>
  </a>
  <a class="dfe-c-metric @(highIssueCount > 0 ? "dfe-c-metric--red" : "dfe-c-metric--grey")" href="@Url.Action("Index", "Issue")" title="Issues">
    <div class="dfe-c-metric__number" style="@(highIssueCount > 0 ? "color:var(--rag-r);" : "")">@highIssueCount</div>
    <div class="dfe-c-metric__label">High / critical issues</div>
    <div class="dfe-c-metric__note" style="color:var(--grey-4);">Issues →</div>
  </a>
</div>

<div class="dfe-c-grid dfe-c-grid--content">
  <div>
    <div class="dfe-c-section-header">
      <h2>Your work</h2>
      <a class="dfe-c-button--link" style="font-size:0.875rem;" href="@Url.Action("Index", "ModernWork")">All projects →</a>
    </div>
    @if (Model.MyProjects.Any())
    {
      <div class="dfe-c-table-wrap dfe-c-mb-3">
        <table>
          <thead>
            <tr>
              <th scope="col">Project</th>
              <th scope="col">Priority / area</th>
              <th scope="col">Phase</th>
              <th scope="col">RAG</th>
              <th scope="col">Monthly update</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var p in Model.MyProjects.OrderBy(x => x.Title).Take(25))
            {
              var ragName = p.RagStatusLookup?.Name;
              var ragSuf = RagCssSuffix(ragName);
              var phaseName = p.Phase ?? "—";
              var phaseSuf = PhaseCssSuffix(p.Phase);
              updatesDueByProjectId.TryGetValue(p.Id, out var updStatus);
              string monthlyClass = "dfe-c-tag dfe-c-tag--grey";
              string monthlyText = "Up to date";
              if (updStatus == UpdateSubmissionStatus.Due)
              {
                monthlyClass = "dfe-c-tag dfe-c-tag--amber";
                monthlyText = "Due";
              }
              else if (updStatus == UpdateSubmissionStatus.Late)
              {
                monthlyClass = "dfe-c-tag dfe-c-tag--red-strong";
                monthlyText = "Late";
              }
              <tr>
                <td>
                  <a class="dfe-c-link" href="@Url.Action("Detail", "ModernWork", new { id = p.Id })">@Trunc(p.Title, 56)</a><span class="dfe-c-table-ref">@p.ProjectCode</span>
                </td>
                <td>@(p.DeliveryPriority?.Name ?? p.BusinessAreaLookup?.Name ?? "—")</td>
                <td>
                  @if (!string.IsNullOrEmpty(phaseSuf))
                  {
                    <span class="dfe-c-phase dfe-c-phase--@phaseSuf">@phaseName.ToUpperInvariant()</span>
                  }
                  else
                  {
                    <span class="dfe-c-phase">@(string.IsNullOrEmpty(phaseName) || phaseName == "—" ? "—" : phaseName.ToUpperInvariant())</span>
                  }
                </td>
                <td>
                  @if (!string.IsNullOrEmpty(ragSuf))
                  {
                    <span class="dfe-c-rag dfe-c-rag--@ragSuf">@ragName!.ToUpperInvariant()</span>
                  }
                  else
                  {
                    <span class="dfe-c-rag dfe-c-rag--tbc">@(string.IsNullOrEmpty(ragName) ? "TBC" : ragName.ToUpperInvariant())</span>
                  }
                </td>
                <td><span class="@monthlyClass">@monthlyText</span></td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
    else
    {
      <p class="dfe-c-text-muted dfe-c-mb-3">No active projects are assigned to you yet. When you join a delivery team, projects appear here.</p>
    }

    <div class="dfe-c-section-header" id="priority-tasks">
      <h2>Priority tasks</h2>
    </div>
    <div style="border:1px solid var(--grey-2);">
      @if (Model.PriorityTasks.Any())
      {
        @foreach (var t in Model.PriorityTasks.Take(12))
        {
          <div class="dfe-c-notification">
            <span class="dfe-c-notification__dot"></span>
            <div>
              @if (!string.IsNullOrEmpty(t.LinkUrl))
              {
                <div style="font-size:0.875rem;font-weight:600;"><a class="dfe-c-link" href="@t.LinkUrl">@t.Title</a></div>
              }
              else
              {
                <div style="font-size:0.875rem;font-weight:600;">@t.Title</div>
              }
              <div class="dfe-c-text-muted">@t.Category · @t.Description</div>
            </div>
          </div>
        }
      }
      else
      {
        <div class="dfe-c-notification"><span class="dfe-c-notification__dot dfe-c-notification__dot--read"></span><div><div class="dfe-c-text-muted">No priority tasks right now.</div></div></div>
      }
    </div>
  </div>

  <aside class="dfe-c-sidebar" aria-label="Summary and quick actions">
    <div class="dfe-c-scard">
      <div class="dfe-c-scard__title">Portfolio snapshot</div>
      <div style="margin-bottom:0.875rem;">
        <div style="display:flex;justify-content:space-between;font-size:0.8125rem;margin-bottom:0.25rem;"><span>@Model.MyProjects.Count active projects</span></div>
        <div style="display:flex;gap:2px;height:0.75rem;border-radius:1px;overflow:hidden;margin-bottom:0.375rem;">
          <div style="flex:@Math.Max(ragBarG, 0.0001);background:var(--rag-g);min-width:2px;"></div>
          <div style="flex:@Math.Max(ragBarA, 0.0001);background:var(--rag-a);min-width:2px;"></div>
          <div style="flex:@Math.Max(ragBarR + ragBarO, 0.0001);background:var(--rag-r);min-width:2px;"></div>
        </div>
        <div style="display:flex;gap:0.875rem;font-size:0.75rem;color:var(--grey-4);flex-wrap:wrap;">
          <span style="color:var(--rag-g);">■ @ragBarG Green</span>
          <span style="color:var(--rag-a);">■ @ragBarA Amber</span>
          <span style="color:var(--rag-r);">■ @(ragBarR + ragBarO) Red / not set</span>
        </div>
      </div>
      <hr class="dfe-c-divider">
      <div class="dfe-c-kv"><dt>Products</dt><dd><strong>@Model.MyProducts.Count</strong></dd></div>
      <div class="dfe-c-kv"><dt>Actions assigned</dt><dd><strong>@actionCount</strong></dd></div>
      <div class="dfe-c-kv"><dt>Milestones this week</dt><dd><strong>@Model.MilestonesDueThisWeek.Count</strong></dd></div>
      <div class="dfe-c-kv"><dt>DDT standards</dt><dd><strong>@Model.MyDdtStandards.Count</strong></dd></div>
    </div>

    <div class="dfe-c-scard">
      <div class="dfe-c-scard__title">Monthly project updates</div>
      @if (monthlyTotal > 0)
      {
        <div style="text-align:center;padding:0.75rem 0;">
          <div style="font-size:2.625rem;font-weight:700;line-height:1;color:@MonthlyPctColour();">@pctSubmitted%</div>
          <div class="dfe-c-text-muted" style="margin-top:0.25rem;">@monthlySubmitted of @monthlyTotal up to date</div>
        </div>
        <div class="dfe-c-progress dfe-c-mb-2"><div class="dfe-c-progress__fill" style="width:@pctSubmitted%;background:@ProgressFillColour();"></div></div>
        <div class="dfe-c-kv"><dt>Due or late</dt><dd style="color:var(--rag-r);font-weight:700;">@updatesDueCount</dd></div>
      }
      else
      {
        <p class="dfe-c-text-muted" style="font-size:0.875rem;margin:0;">No reporting scope for your projects this period.</p>
      }
    </div>

    <div class="dfe-c-scard">
      <div class="dfe-c-scard__title">Quick actions</div>
      <div style="display:flex;flex-direction:column;gap:0.5rem;">
        <a class="dfe-c-button dfe-c-button--primary dfe-c-button--sm" href="@Url.Action("Index", "ModernWork")">View projects</a>
        <a class="dfe-c-button dfe-c-button--secondary dfe-c-button--sm" href="@Url.Action("Index", "Products")">Product performance</a>
        <a class="dfe-c-button dfe-c-button--secondary dfe-c-button--sm" href="@Url.Action("Create", "Risk")">Log a risk</a>
        <a class="dfe-c-button dfe-c-button--secondary dfe-c-button--sm" href="@Url.Action("Dashboard", "DdtStandards")">Standards</a>
      </div>
    </div>
  </aside>
</div>

@if (Model.MilestonesDueThisWeek.Any() || Model.OverdueMilestones.Any())
{
  <section class="dfe-c-mb-3 dfe-c-mt-3" aria-labelledby="home-milestones-heading">
    <div class="dfe-c-section-header"><h2 id="home-milestones-heading">Milestones</h2><a class="dfe-c-button--link" style="font-size:0.875rem;" href="@Url.Action("Index", "ModernWork")">Projects →</a></div>
    <div class="dfe-c-table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col">Timing</th>
            <th scope="col">Milestone</th>
            <th scope="col">Project</th>
            <th scope="col">Due</th>
            <th scope="col"><span class="compass2-visually-hidden">Open</span></th>
          </tr>
        </thead>
        <tbody>
          @foreach (var m in Model.OverdueMilestones.Take(8))
          {
            var proj = Model.MyProjects.FirstOrDefault(p => p.Id == m.ProjectId);
            <tr>
              <td><span class="dfe-c-tag dfe-c-tag--red-strong">OVERDUE</span></td>
              <td><a class="dfe-c-link" href="@Url.Action("Detail", "ModernWork", new { id = m.ProjectId, tab = "milestones" })">@Trunc(m.Name, 56)</a></td>
              <td class="dfe-c-text-muted">@Trunc(proj?.Title ?? "—", 48)</td>
              <td style="white-space:nowrap;">@m.DueDate.ToString("d MMM yyyy")</td>
              <td style="white-space:nowrap;"><a class="dfe-c-link" href="@Url.Action("Detail", "ModernWork", new { id = m.ProjectId, tab = "milestones" })">View</a></td>
            </tr>
          }
          @foreach (var m in Model.MilestonesDueThisWeek.Take(8))
          {
            var proj = Model.MyProjects.FirstOrDefault(p => p.Id == m.ProjectId);
            <tr>
              <td><span class="dfe-c-tag dfe-c-tag--grey">THIS WEEK</span></td>
              <td><a class="dfe-c-link" href="@Url.Action("Detail", "ModernWork", new { id = m.ProjectId, tab = "milestones" })">@Trunc(m.Name, 56)</a></td>
              <td class="dfe-c-text-muted">@Trunc(proj?.Title ?? "—", 48)</td>
              <td style="white-space:nowrap;">@m.DueDate.ToString("d MMM yyyy")</td>
              <td style="white-space:nowrap;"><a class="dfe-c-link" href="@Url.Action("Detail", "ModernWork", new { id = m.ProjectId, tab = "milestones" })">View</a></td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </section>
}

@if (Model.HighPriorityIssues.Any() || Model.UnmonitoredRisks.Any())
{
  <section class="dfe-c-mb-3" aria-labelledby="home-raid-heading">
    <div class="dfe-c-section-header">
      <h2 id="home-raid-heading">Risks and issues</h2>
      <a class="dfe-c-button--link" style="font-size:0.875rem;" href="@Url.Action("Index", "Raid")">RAID hub →</a>
    </div>
    <div class="dfe-c-table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col">Type</th>
            <th scope="col">Title</th>
            <th scope="col">Project</th>
            <th scope="col"><span class="compass2-visually-hidden">Open</span></th>
          </tr>
        </thead>
        <tbody>
          @foreach (var r in Model.UnmonitoredRisks.Take(6))
          {
            var proj = Model.MyProjects.FirstOrDefault(p => p.Id == r.ProjectId);
            <tr>
              <td><span class="dfe-c-tag dfe-c-tag--grey">RISK</span></td>
              <td><a class="dfe-c-link" href="@Url.Action("Details", "Risk", new { id = r.Id })">@Trunc(r.Title, 48)</a></td>
              <td class="dfe-c-text-muted">@Trunc(proj?.Title ?? "—", 40)</td>
              <td style="white-space:nowrap;"><a class="dfe-c-link" href="@Url.Action("Details", "Risk", new { id = r.Id })">View</a></td>
            </tr>
          }
          @foreach (var i in Model.HighPriorityIssues.Take(6))
          {
            var proj = Model.MyProjects.FirstOrDefault(p => p.Id == i.ProjectId);
            <tr>
              <td><span class="dfe-c-tag dfe-c-tag--grey">ISSUE</span></td>
              <td><a class="dfe-c-link" href="@Url.Action("Details", "Issue", new { id = i.Id })">@Trunc(i.Title, 48)</a></td>
              <td class="dfe-c-text-muted">@Trunc(proj?.Title ?? "—", 40)</td>
              <td style="white-space:nowrap;"><a class="dfe-c-link" href="@Url.Action("Details", "Issue", new { id = i.Id })">View</a></td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </section>
}

@if (Model.AssignedActions.Any())
{
  <section class="dfe-c-mb-3" aria-labelledby="home-actions-heading">
    <div class="dfe-c-section-header">
      <h2 id="home-actions-heading">Actions assigned to you</h2>
    </div>
    <div class="dfe-c-table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col">Action</th>
            <th scope="col">Due</th>
            <th scope="col">Status</th>
          </tr>
        </thead>
        <tbody>
          @foreach (var a in Model.AssignedActions)
          {
            <tr>
              <td><a class="dfe-c-link" href="@Url.Action("Details", "Action", new { id = a.Id })">@Trunc(a.Title, 48)</a></td>
              <td>@(a.DueDate.HasValue ? a.DueDate.Value.ToString("d MMM yyyy") : "—")</td>
              <td><span class="dfe-c-tag dfe-c-tag--grey">@(a.Status ?? "—").ToUpperInvariant()</span></td>
            </tr>
          }
        </tbody>
      </table>
    </div>
  </section>
}
