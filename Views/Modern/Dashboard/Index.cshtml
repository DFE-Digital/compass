@model HomeDashboardViewModel
@using System.Linq
@using Compass.Models
@using Compass.Models.Modern.Work
@using Compass.Services
@using Compass.ViewModels.Dashboard
@using System.Globalization
@{
  ViewData["Title"] = $"{Greeting()}, {Model.FirstName}";

  string Trunc(string? s, int n)
  {
    if (string.IsNullOrEmpty(s)) return "—";
    return s.Length <= n ? s : s[..n] + "…";
  }

  string Greeting()
  {
    var h = DateTime.Now.Hour;
    return h < 12 ? "Good morning" : h < 17 ? "Good afternoon" : "Good evening";
  }

  var fipsServiceRegisterEnabled = ViewBag.FipsServiceRegisterEnabled as bool? == true;
  var dashboardServiceRegisterByCmdbKey = ViewBag.DashboardServiceRegisterProductIdByCmdbKey as IReadOnlyDictionary<string, Guid>;

  string PerformanceReportingUrl(ProductDto pr)
  {
    var needle = (pr.DocumentId ?? pr.FipsId)?.Trim();
    if (string.IsNullOrEmpty(needle))
      return Url.Action("PerformanceMetrics", "ProductReporting", new { view = "mine" }) ?? "#";
    return Url.Action("PerformanceMetrics", "ProductReporting", new { view = "mine", search = needle }) ?? "#";
  }

  string? ServiceRegisterProductUrl(ProductDto pr)
  {
    if (Guid.TryParse(pr.DocumentId, out var registerId))
      return Url.Action("FipsProduct", "ModernManage", new { id = registerId });
    if (dashboardServiceRegisterByCmdbKey == null) return null;
    foreach (var k in new[] { pr.CmdbSysId, pr.FipsId })
    {
      if (string.IsNullOrWhiteSpace(k)) continue;
      if (dashboardServiceRegisterByCmdbKey.TryGetValue(k.Trim(), out var id))
        return Url.Action("FipsProduct", "ModernManage", new { id });
    }
    return null;
  }

  string ProductRegisterOrPerformanceHref(ProductDto pr)
  {
    if (fipsServiceRegisterEnabled)
    {
      var reg = ServiceRegisterProductUrl(pr);
      if (!string.IsNullOrEmpty(reg)) return reg;
    }
    return PerformanceReportingUrl(pr);
  }

  string ProductPhaseDisplay(ProductDto pr) =>
    string.IsNullOrWhiteSpace(pr.Phase) ? "—" : pr.Phase;

  string ProductBusinessAreaDisplay(ProductDto pr) =>
    !string.IsNullOrWhiteSpace(pr.BusinessArea)
      ? pr.BusinessArea
      : ProductDtoViewHelpers.BusinessArea(pr) ?? "—";

  string ProductTypeDisplay(ProductDto pr)
  {
    if (!string.IsNullOrWhiteSpace(pr.ProductType))
      return pr.ProductType;
    var types = ProductDtoViewHelpers.TypeNames(pr);
    return types.Count > 0 ? string.Join(", ", types) : "—";
  }

  var monthlyByProject = Model.MonthlyUpdateStatusByProjectId;
  var reportingPeriodLabel = !string.IsNullOrWhiteSpace(Model.ApplicableMonthlyUpdatePeriodLabel)
    ? Model.ApplicableMonthlyUpdatePeriodLabel
    : new DateTime(Model.ApplicableMonthlyUpdateYear, Model.ApplicableMonthlyUpdateMonth, 1)
      .ToString("MMMM yyyy", CultureInfo.GetCultureInfo("en-GB"));

  string MonthlyStatusLabel(int projectId)
  {
    if (!monthlyByProject.TryGetValue(projectId, out var st))
      return "—";
    return st switch
    {
      UpdateSubmissionStatus.Submitted => "Submitted",
      UpdateSubmissionStatus.Late => "Late",
      UpdateSubmissionStatus.Due => "Due",
      UpdateSubmissionStatus.Upcoming => "Upcoming",
      _ => st.ToString()
    };
  }

  string TaskStatusBadgeClass(string tag) => tag switch
  {
    _ when tag.Equals("Complete", StringComparison.OrdinalIgnoreCase) => "dfe-f-badge dfe-f-badge--small dfe-f-badge--green",
    _ when tag.Equals("Late", StringComparison.OrdinalIgnoreCase) => "dfe-f-badge dfe-f-badge--small dfe-f-badge--red",
    _ when tag.Contains("remaining", StringComparison.OrdinalIgnoreCase) => "dfe-f-badge dfe-f-badge--small dfe-f-badge--orange",
    _ => "dfe-f-badge dfe-f-badge--small dfe-f-badge--orange"
  };

  var workDashboardHref = Url.Action("Dashboard", "ModernWork") ?? "/modern/work/dashboard";
  var today = DateTime.Today;

  var rows = new List<(string Title, string Hint, DateTime? SortDate, string Href, string StatusTag)>();

  foreach (var m in Model.OverdueMilestones)
  {
    var proj = Model.MyProjects.FirstOrDefault(p => p.Id == m.ProjectId);
    var milestoneHint = proj != null ? $"Milestone · {proj.Title}" : "Milestone";
    milestoneHint = $"Due {m.DueDate.ToString("d MMM yyyy", CultureInfo.GetCultureInfo("en-GB"))} · {milestoneHint}";
    rows.Add((
      m.Name,
      milestoneHint,
      m.DueDate,
      $"{Url.Action("Detail", "ModernWork", new { id = m.ProjectId, tab = "milestones" })}#wd-milestones",
      "Late"));
  }

  foreach (var m in Model.MilestonesDueThisWeek)
  {
    var proj = Model.MyProjects.FirstOrDefault(p => p.Id == m.ProjectId);
    rows.Add((
      m.Name,
      proj != null ? $"Milestone · {proj.Title}" : "Milestone",
      m.DueDate,
      $"{Url.Action("Detail", "ModernWork", new { id = m.ProjectId, tab = "milestones" })}#wd-milestones",
      "Due"));
  }

  if (ViewBag.ShowRaidNavigation == true)
  {
    foreach (var i in Model.HighPriorityIssues.Take(8))
    {
      var proj = Model.MyProjects.FirstOrDefault(p => p.Id == i.ProjectId);
      var issueLate = i.TargetResolutionDate.HasValue && i.TargetResolutionDate.Value.Date < today;
      rows.Add((
        i.Title,
        proj != null ? $"Issue · {proj.Title}" : "Issue",
        i.TargetResolutionDate ?? DateTime.MaxValue.AddDays(-365),
        Url.Action("Details", "Issue", new { id = i.Id }) ?? "#",
        issueLate ? "Late" : "Due"));
    }
  }

  foreach (var (product, retStatus, due) in Model.ProductsNeedingReturns.Take(8))
  {
    rows.Add((
      product.Title,
      "Performance return",
      due,
      Url.Action("PerformanceMetrics", "ProductReporting", new { documentId = product.DocumentId ?? product.FipsId }) ?? "#",
      retStatus == ReturnStatus.Late ? "Late" : "Due"));
  }

  foreach (var (product, commission, subStatus, due) in Model.ProductsNeedingCommissionReporting.Take(8))
  {
    var commissionLate = due.Date < today;
    rows.Add((
      product.Title,
      $"{commission.Name} · {subStatus}",
      due,
      Url.Action("Commission", "ModernPerformance", new { commissionId = commission.Id }) ?? "#",
      commissionLate ? "Late" : "Due"));
  }

  foreach (var a in Model.AssignedActions.Take(15))
  {
    var actionLate = a.DueDate.HasValue && a.DueDate.Value.Date < today;
    rows.Add((
      a.Title,
      a.Project?.Title ?? "Action",
      a.DueDate ?? DateTime.MaxValue.AddDays(-365),
      Url.Action("Details", "Action", new { id = a.Id }) ?? "#",
      actionLate ? "Late" : "Due"));
  }

  var orderedTasks = rows
    .OrderBy(r => r.SortDate ?? DateTime.MaxValue)
    .ThenBy(r => r.Title, StringComparer.OrdinalIgnoreCase)
    .Take(40)
    .ToList();

  var showMonthlyReportingTask = Model.MonthlyReportingWindowOpen;
  var monthlyReportingComplete = Model.MonthlyReportingRemainingCount == 0;
  var hasAnyTasks = showMonthlyReportingTask || orderedTasks.Any();

  var dateCaption = DateTime.Today.ToString("dddd d MMMM yyyy", CultureInfo.GetCultureInfo("en-GB"));
  var pageTitle = $"{Greeting()}, {Model.FirstName}";
}

@section Masthead {
<div class="dfe-f-masthead dfe-f-masthead--page modern-dashboard__masthead">
  <div class="dfe-f-app-container dfe-f-app-container--wide govuk-width-container dfe-f-masthead__inner">
    <p class="govuk-caption-m govuk-!-margin-bottom-2 govuk-!-margin-top-0">@dateCaption</p>
    <h1 class="govuk-heading-xl govuk-!-margin-top-0 govuk-!-margin-bottom-0">@pageTitle</h1>
    <div class="modern-dashboard__masthead-stats" aria-labelledby="dashboard-stats-heading">
      @await Html.PartialAsync("~/Views/Modern/Dashboard/_DashboardAtAGlanceStats.cshtml", Model)
    </div>
  </div>
</div>
}

@if (TempData["ErrorMessage"] != null)
{
  <div class="govuk-error-summary govuk-!-margin-bottom-6" role="alert">
    <h2 class="govuk-error-summary__title">There is a problem</h2>
    <p class="govuk-body govuk-!-margin-bottom-0">@TempData["ErrorMessage"]</p>
  </div>
}

<div id="modern-dashboard" class="modern-dashboard modern-dashboard--with-masthead">

<section class="modern-dashboard__section" aria-labelledby="dashboard-tasks-heading">
  <h2 id="dashboard-tasks-heading" class="govuk-heading-m govuk-!-margin-top-0 modern-dashboard__section-heading">Your tasks</h2>
  <p class="govuk-body modern-dashboard__section-desc">Prioritised actions across delivery, performance and RAID. Each row links to where you complete the task in Compass.</p>

  @if (!hasAnyTasks)
  {
    <p class="govuk-body govuk-!-margin-bottom-0">No outstanding tasks from this list. Open <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("AllWork", "ModernWork")">all work</a> for the full register.</p>
  }
  else
  {
    <ul class="govuk-task-list">
      @if (showMonthlyReportingTask)
      {
        var monthlyStatusId = "dashboard-task-monthly-reporting-status";
        var monthlyHintId = "dashboard-task-monthly-reporting-hint";
        <li class="govuk-task-list__item govuk-task-list__item--with-link">
          <div class="govuk-task-list__name-and-hint">
            <a class="govuk-link govuk-task-list__link govuk-!-font-weight-bold govuk-link--no-visited-state" href="@workDashboardHref" aria-describedby="@monthlyHintId @monthlyStatusId">
              Submit monthly delivery updates (@reportingPeriodLabel)
            </a>
            <div id="@monthlyHintId" class="govuk-task-list__hint">
              @if (monthlyReportingComplete)
              {
                <text>All assigned work items have a submitted update for this period.</text>
              }
              else
              {
                <text>@Model.MonthlyReportingRemainingCount work item@(Model.MonthlyReportingRemainingCount == 1 ? "" : "s") still need an update.</text>
              }
            </div>
          </div>
          <div class="govuk-task-list__status" id="@monthlyStatusId">
            @if (monthlyReportingComplete)
            {
              <span class="@TaskStatusBadgeClass("Complete")">Complete</span>
            }
            else
            {
              <span class="@TaskStatusBadgeClass($"{Model.MonthlyReportingRemainingCount} remaining")">@Model.MonthlyReportingRemainingCount remaining</span>
            }
          </div>
        </li>
      }
      @for (var ti = 0; ti < orderedTasks.Count; ti++)
      {
        var t = orderedTasks[ti];
        var statusId = $"dashboard-task-status-{ti + 1}";
        var hintId = $"dashboard-task-hint-{ti + 1}";
        <li class="govuk-task-list__item govuk-task-list__item--with-link">
          <div class="govuk-task-list__name-and-hint">
            <a class="govuk-link govuk-task-list__link govuk-!-font-weight-bold govuk-link--no-visited-state" href="@t.Href" aria-describedby="@hintId @statusId">@Trunc(t.Title, 120)</a>
            <div id="@hintId" class="govuk-task-list__hint">@Trunc(t.Hint, 120)</div>
          </div>
          <div class="govuk-task-list__status" id="@statusId">
            <span class="@TaskStatusBadgeClass(t.StatusTag)">@t.StatusTag</span>
          </div>
        </li>
      }
    </ul>
  }
</section>

@if (Model.MyProjects.Any())
{
  <section class="modern-dashboard__section" aria-labelledby="dashboard-delivery-heading">
    <h2 id="dashboard-delivery-heading" class="govuk-heading-m govuk-!-margin-top-0 modern-dashboard__section-heading">Your delivery work</h2>
    <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
      <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
      <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed modern-dashboard__table">
        <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">Your delivery work items</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">Work item</button>
            </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">Delivery status</button>
            </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">RAG</button>
            </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">Priority</button>
            </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">Monthly (@reportingPeriodLabel)</button>
            </th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          @foreach (var p in Model.MyProjects.Take(12))
          {
            var ragName = p.RagStatusName ?? p.RagStatus ?? "—";
            var ragCss = p.RagStatusLookup?.CssClass;
            var priorityName = p.DeliveryPriority?.Name;
            var statusText = string.IsNullOrEmpty(p.Status) ? "—" : p.Status;
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">
                <a class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold" href="@Url.Action("Detail", "ModernWork", new { id = p.Id })">@Trunc(p.Title, 80)</a>
                <div class="govuk-body-s dfe-c-text-muted modern-work-table__meta">WI-@p.Id.ToString("D8")</div>
              </td>
              <td class="govuk-table__cell"><span class="@WorkBadgeCss.StatusDfeFrontendBadgeClass(statusText == "—" ? null : statusText) dfe-f-badge--small">@statusText</span></td>
              <td class="govuk-table__cell"><span class="@WorkBadgeCss.RagDfeFrontendBadgeClass(ragCss, ragName == "—" ? null : ragName) dfe-f-badge--small">@(string.IsNullOrEmpty(ragName) || ragName == "—" ? "—" : ragName.ToUpperInvariant())</span></td>
              <td class="govuk-table__cell"><span class="@WorkBadgeCss.PriorityDfeFrontendBadgeClass(priorityName) dfe-f-badge--small">@((priorityName ?? "—").ToUpperInvariant())</span></td>
              <td class="govuk-table__cell">@MonthlyStatusLabel(p.Id)</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
    @if (Model.MyProjects.Count > 12)
    {
      <p class="govuk-body govuk-!-margin-top-3 govuk-!-margin-bottom-0">
        <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("AllWork", "ModernWork")">View more</a>
      </p>
    }
  </section>
}

@if (fipsServiceRegisterEnabled && Model.MyProducts.Any())
{
  <section class="modern-dashboard__section" aria-labelledby="dashboard-products-heading">
    <h2 id="dashboard-products-heading" class="govuk-heading-m govuk-!-margin-top-0 modern-dashboard__section-heading">Products you support</h2>
    <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
      <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
      <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed modern-dashboard__table">
        <caption class="govuk-table__caption govuk-table__caption--m govuk-visually-hidden">Products you support</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">Product</button>
            </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">Phase</button>
            </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">Business area</button>
            </th>
            <th scope="col" class="govuk-table__header" aria-sort="none">
              <button type="button" class="dfe-f-table-sort-button">Type</button>
            </th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          @foreach (var pr in Model.MyProducts.Take(10))
          {
            var productHref = ProductRegisterOrPerformanceHref(pr);
            var phase = string.IsNullOrWhiteSpace(pr.Phase) ? "—" : pr.Phase;
            var businessArea = string.IsNullOrWhiteSpace(pr.BusinessArea)
              ? ProductDtoViewHelpers.BusinessArea(pr) ?? "—"
              : pr.BusinessArea;
            var types = string.IsNullOrWhiteSpace(pr.ProductType)
              ? (ProductDtoViewHelpers.TypeNames(pr).Count > 0 ? string.Join(", ", ProductDtoViewHelpers.TypeNames(pr)) : "—")
              : pr.ProductType;
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">
                <a class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold" href="@productHref">@Trunc(pr.Title, 80)</a>
              </td>
              <td class="govuk-table__cell">@phase</td>
              <td class="govuk-table__cell">@Trunc(businessArea, 60)</td>
              <td class="govuk-table__cell">@Trunc(types, 60)</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
    @if (Model.MyProducts.Count > 10)
    {
      <p class="govuk-body govuk-!-margin-top-3 govuk-!-margin-bottom-0">
        <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("Fips", "ModernManage", new { tab = "my" })">View all your products</a>
      </p>
    }
  </section>
}

</div>
