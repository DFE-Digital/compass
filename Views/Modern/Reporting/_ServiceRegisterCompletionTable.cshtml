@using Compass.Models.Modern.Work
@using Compass.ViewModels.Modern
@model IReadOnlyList<ServiceRegisterProductCompletionRow>
@{
  var rows = Model ?? Array.Empty<ServiceRegisterProductCompletionRow>();
  string ProductHref(Guid id) => Url.Action("FipsProduct", "ModernManage", new { id }) ?? "#";
}
@if (rows.Count == 0)
{
  <p class="govuk-body-s dfe-c-text-muted">No products in this group.</p>
}
else
{
  <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
    <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
    <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed">
      <caption class="govuk-table__caption govuk-visually-hidden">Service register completion</caption>
      <thead class="govuk-table__head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Product</button></th>
          <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Phase</button></th>
          <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Business area</button></th>
          <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Type</button></th>
          <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Channel</button></th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Contacts</button></th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Completion</button></th>
        </tr>
      </thead>
      <tbody class="govuk-table__body">
        @foreach (var row in rows)
        {
          <tr class="govuk-table__row">
            <td class="govuk-table__cell">
              <a class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold" href="@ProductHref(row.ProductId)">@row.Title</a>
              <div class="dfe-c-text-muted govuk-body-s">ID @row.UniqueId</div>
            </td>
            <td class="govuk-table__cell">@row.PhaseDisplay</td>
            <td class="govuk-table__cell">@row.BusinessAreasDisplay</td>
            <td class="govuk-table__cell">@row.TypesDisplay</td>
            <td class="govuk-table__cell">@row.ChannelsDisplay</td>
            <td class="govuk-table__cell govuk-table__cell--numeric">@row.ContactCount</td>
            <td class="govuk-table__cell govuk-table__cell--numeric">
              <span class="@WorkBadgeCss.ServiceRegisterCompletionBadgeClass(row.CompletionPercent)">@row.CompletionPercent%</span>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}
