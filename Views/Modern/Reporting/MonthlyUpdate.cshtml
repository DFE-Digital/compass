@using System.Text.Json
@using System.Text.Json.Serialization
@using Compass.Services
@using Compass.ViewModels.Modern
@model Compass.ViewModels.ModernMonthlyReportDashboardViewModel
@{
    ViewData["Title"] = "Monthly report";
    var m = Model ?? new Compass.ViewModels.ModernMonthlyReportDashboardViewModel();
    var jsonOpts = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase, DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull };
    var ragTrendJson = JsonSerializer.Serialize(m.RagTrend, jsonOpts);
    var priTrendJson = JsonSerializer.Serialize(m.PriorityTrend, jsonOpts);
    var ragDistJson = JsonSerializer.Serialize(m.RagDistribution, jsonOpts);
    var priDistJson = JsonSerializer.Serialize(m.PriorityDistribution, jsonOpts);
    var baProjectsJson = JsonSerializer.Serialize(
        m.BusinessAreaRows.ToDictionary(r => r.BusinessArea, r => r.Projects),
        jsonOpts);
    var ptgNarrativeJson = JsonSerializer.Serialize(
        m.ProjectsWithPathToGreen.ToDictionary(p => p.Id.ToString(), p => ProjectMonthlyUpdateNarrative.LatestSubmittedText(p) ?? ""),
        jsonOpts);
    var ptgPathJson = JsonSerializer.Serialize(
        m.ProjectsWithPathToGreen.ToDictionary(p => p.Id.ToString(), p => p.PathToGreen ?? ""),
        jsonOpts);
    var drillModalDetailsJson = JsonSerializer.Serialize(
        m.BusinessAreaRows
            .SelectMany(r => r.Projects)
            .GroupBy(p => p.Id)
            .ToDictionary(g => g.Key.ToString(), g => g.First()),
        jsonOpts);

    // Int route is /modern/work/detail/{id}; non-integer ids in Url.Action fall back to /ModernWork/Detail/…
    string MwDetailHref(int id, string? tab = null)
    {
        var path = Url.Content($"~/modern/work/detail/{id}") ?? $"/modern/work/detail/{id}";
        return string.IsNullOrEmpty(tab) ? path : $"{path}?tab={Uri.EscapeDataString(tab)}";
    }

    var mwDetailPrefix = Url.Content("~/modern/work/detail/") ?? "/modern/work/detail/";
    var mwDetailPrefixJson = JsonSerializer.Serialize(mwDetailPrefix);

    string RagBadgeClass(string rag) => rag switch
    {
        "Red" => "rag-badge rag-red",
        "Amber-Red" => "rag-badge rag-amber-red",
        "Amber-Green" => "rag-badge rag-amber",
        "Green" => "rag-badge rag-green",
        _ => "rag-badge rag-none"
    };

    string PriBadgeClass(string pri) => pri switch
    {
        "Critical" => "dfe-c-tag dfe-c-tag--red",
        "High" => "dfe-c-tag dfe-c-tag--red",
        "Medium" => "dfe-c-tag dfe-c-tag--amber",
        "Low" => "dfe-c-tag dfe-c-tag--green",
        _ => "dfe-c-tag dfe-c-tag--grey"
    };

    string RagDfeBadge(string rag) => rag switch
    {
        "Red" => "dfe-f-badge dfe-f-badge--small dfe-f-badge--red",
        "Amber-Red" => "dfe-f-badge dfe-f-badge--small dfe-f-badge--orange",
        "Amber-Green" => "dfe-f-badge dfe-f-badge--small dfe-f-badge--orange",
        "Green" => "dfe-f-badge dfe-f-badge--small dfe-f-badge--green",
        _ => "dfe-f-badge dfe-f-badge--small dfe-f-badge--grey"
    };

    string PriDfeBadge(string pri) => pri switch
    {
        "Critical" => "dfe-f-badge dfe-f-badge--small dfe-f-badge--red",
        "High" => "dfe-f-badge dfe-f-badge--small dfe-f-badge--red",
        "Medium" => "dfe-f-badge dfe-f-badge--small dfe-f-badge--orange",
        "Low" => "dfe-f-badge dfe-f-badge--small dfe-f-badge--green",
        _ => "dfe-f-badge dfe-f-badge--small dfe-f-badge--grey"
    };

    int RagDelta(string key) =>
        (m.RagDistribution.TryGetValue(key, out var cur) ? cur : 0) -
        (m.PrevMonthRagDistribution.TryGetValue(key, out var prev) ? prev : 0);

    int PriDelta(string key) =>
        (m.PriorityDistribution.TryGetValue(key, out var cur) ? cur : 0) -
        (m.PrevMonthPriorityDistribution.TryGetValue(key, out var prev) ? prev : 0);

    string DeltaHtml(int d)
    {
        if (d == 0) return "<span class=\"mr-delta mr-delta--flat\">—</span>";
        if (d > 0) return $"<span class=\"mr-delta mr-delta--up\">▲ +{d}</span>";
        return $"<span class=\"mr-delta mr-delta--down\">▼ {d}</span>";
    }

    string MatrixCellClass(string rag, string pri, int count)
    {
        if (count == 0) return "mr-mx__cell mr-mx__cell--zero";
        var severity = rag switch
        {
            "Red" => pri is "Critical" or "High" ? "mr-mx__cell mr-mx__cell--critical" : "mr-mx__cell mr-mx__cell--high",
            "Amber-Red" => pri is "Critical" or "High" ? "mr-mx__cell mr-mx__cell--high" : "mr-mx__cell mr-mx__cell--medium",
            "Amber-Green" => "mr-mx__cell mr-mx__cell--medium",
            "Green" => "mr-mx__cell mr-mx__cell--low",
            _ => "mr-mx__cell mr-mx__cell--neutral"
        };
        return severity;
    }

      int RagRank(string rag) => rag switch
      {
        "Green" => 1,
        "Amber-Green" => 2,
        "Amber-Red" => 3,
        "Red" => 4,
        _ => 0
      };

      string RagChangeBucket(string from, string to)
      {
        var fr = RagRank(from);
        var tr = RagRank(to);
        if (fr > 0 && tr > 0 && tr > fr) return "worsening";
        if (fr > 0 && tr > 0 && tr < fr) return "improving";
        return "same";
      }

      var ragWorsening = m.RagChanges.Where(r => RagChangeBucket(r.From, r.To) == "worsening").ToList();
      var ragSame = m.RagChanges.Where(r => RagChangeBucket(r.From, r.To) == "same").ToList();
      var ragImproving = m.RagChanges.Where(r => RagChangeBucket(r.From, r.To) == "improving").ToList();

      var ragChangeBuckets = new (string Title, string Hint, List<ProjectChangeRow> Rows)[]
      {
        ("Worsening", "RAG moved toward red or higher risk.", ragWorsening),
        ("Same", "Same tier, moved from not set, or lateral change.", ragSame),
        ("Improving", "RAG moved toward green or lower risk.", ragImproving)
      };

      int PriRank(string pri) => pri switch
      {
          "Low" => 1,
          "Medium" => 2,
          "High" => 3,
          "Critical" => 4,
          _ => 0
      };

      string PriChangeBucket(string from, string to)
      {
          var fr = PriRank(from);
          var tr = PriRank(to);
          if (fr == 0 || tr == 0) return "same";
          if (tr > fr) return "worsening";
          if (tr < fr) return "improving";
          return "same";
      }

      var priWorsening = m.PriorityChanges.Where(r => PriChangeBucket(r.From, r.To) == "worsening").ToList();
      var priSame = m.PriorityChanges.Where(r => PriChangeBucket(r.From, r.To) == "same").ToList();
      var priImproving = m.PriorityChanges.Where(r => PriChangeBucket(r.From, r.To) == "improving").ToList();

      var priChangeBuckets = new (string Title, string Hint, List<ProjectChangeRow> Rows)[]
      {
          ("Worsening", "Priority moved toward critical or higher urgency.", priWorsening),
          ("Same", "Involves not set, or lateral change between named levels.", priSame),
          ("Improving", "Priority moved toward low or lower urgency.", priImproving)
      };

      var mrReportPanelBaCount = m.BusinessAreaRows.Count;
      var mrReportPanelSubmissionTotal = m.MonthlyUpdateStats?.TotalProjects ?? 0;
      var mrReportPanelChangesItems = m.ProjectsWithPathToGreen.Count + m.RagChanges.Count + m.PriorityChanges.Count;
      var mrReportPanelTrendsTotal = m.TotalActiveProjects;
      var mrReportPanelMilestonesTotal = m.NewProjectsThisMonth.Count + m.MilestonesAchieved.Count + m.UpcomingMilestonesNext30Days.Count + m.LateMilestones.Count;
      var mrReportPanelRaidTotal = m.RaidSummary.TotalOpen;
      var mrReportPanelIntelligenceSignals = m.Intelligence.SignalCount;

}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernReporting")">Reporting</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Monthly report</li>
}

<div class="mr-dash">
@{
  string MrNavUrl(int? y, int? mo, int? ba, int? dir) =>
    Url.Action("MonthlyUpdate", "ModernReporting", new { year = y, month = mo, businessAreaId = ba, directorateId = dir }) ?? "#";
  var periodToolbar = MonthlyReportPeriodToolbarViewModel.FromMonthlyReport(
    m,
    Url.Action("MonthlyUpdate", "ModernReporting") ?? "",
    MrNavUrl);
  var mrHeaderLede = await Html.PartialAsync("_ReportingMutedBodyLede", "Single monthly report: submission progress, narratives, RAG and priority flows, milestones, and business-area detail.");
}
@await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
  Caption = "Reporting",
  Title = $"Monthly report — {m.MonthName}",
  Lede = mrHeaderLede
})

  @if (TempData["ErrorMessage"] != null)
  {
 <div class="dfe-c-error-summary" role="alert" style="margin-bottom:1.5rem;">
 <p class="dfe-c-body" style="margin:0;">@TempData["ErrorMessage"]</p>
    </div>
  }

  @await Html.PartialAsync("_MonthlyReportPeriodToolbar", periodToolbar)

  @* Summary stat cards live in Submission summary panel *@
  <div class="mr-report-layout" id="mr-report-layout">
    <aside class="mr-report-order-panel" id="mr-report-order-panel" hidden aria-label="Edit section order">
