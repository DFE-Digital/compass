@using System.Text.Json
@using System.Text.Json.Serialization
@using Compass.Services
@model Compass.ViewModels.ModernMonthlyReportDashboardViewModel
@{
    ViewData["Title"] = "Monthly report";
    var m = Model ?? new Compass.ViewModels.ModernMonthlyReportDashboardViewModel();
    var jsonOpts = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase, DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull };
    var ragTrendJson = JsonSerializer.Serialize(m.RagTrend, jsonOpts);
    var priTrendJson = JsonSerializer.Serialize(m.PriorityTrend, jsonOpts);
    var ragDistJson = JsonSerializer.Serialize(m.RagDistribution, jsonOpts);
    var priDistJson = JsonSerializer.Serialize(m.PriorityDistribution, jsonOpts);
    var baProjectsJson = JsonSerializer.Serialize(
        m.BusinessAreaRows.ToDictionary(r => r.BusinessArea, r => r.Projects),
        jsonOpts);
    var ptgNarrativeJson = JsonSerializer.Serialize(
        m.ProjectsWithPathToGreen.ToDictionary(p => p.Id.ToString(), p => ProjectMonthlyUpdateNarrative.LatestSubmittedText(p) ?? ""),
        jsonOpts);

    // Int route is /modern/work/detail/{id}; non-integer ids in Url.Action fall back to /ModernWork/Detail/…
    string MwDetailHref(int id, string? tab = null)
    {
        var path = Url.Content($"~/modern/work/detail/{id}") ?? $"/modern/work/detail/{id}";
        return string.IsNullOrEmpty(tab) ? path : $"{path}?tab={Uri.EscapeDataString(tab)}";
    }

    var mwDetailPrefix = Url.Content("~/modern/work/detail/") ?? "/modern/work/detail/";
    var mwDetailPrefixJson = JsonSerializer.Serialize(mwDetailPrefix);

    string RagBadgeClass(string rag) => rag switch
    {
        "Red" => "rag-badge rag-red",
        "Amber-Red" => "rag-badge rag-amber-red",
        "Amber-Green" => "rag-badge rag-amber",
        "Green" => "rag-badge rag-green",
        _ => "rag-badge rag-none"
    };

    string PriBadgeClass(string pri) => pri switch
    {
        "Critical" => "dfe-c-tag dfe-c-tag--red",
        "High" => "dfe-c-tag dfe-c-tag--red",
        "Medium" => "dfe-c-tag dfe-c-tag--amber",
        "Low" => "dfe-c-tag dfe-c-tag--green",
        _ => "dfe-c-tag dfe-c-tag--grey"
    };

    int RagDelta(string key) =>
        (m.RagDistribution.TryGetValue(key, out var cur) ? cur : 0) -
        (m.PrevMonthRagDistribution.TryGetValue(key, out var prev) ? prev : 0);

    int PriDelta(string key) =>
        (m.PriorityDistribution.TryGetValue(key, out var cur) ? cur : 0) -
        (m.PrevMonthPriorityDistribution.TryGetValue(key, out var prev) ? prev : 0);

    string DeltaHtml(int d)
    {
        if (d == 0) return "<span class=\"mr-delta mr-delta--flat\">—</span>";
        if (d > 0) return $"<span class=\"mr-delta mr-delta--up\">▲ +{d}</span>";
        return $"<span class=\"mr-delta mr-delta--down\">▼ {d}</span>";
    }

    string MatrixCellClass(string rag, string pri, int count)
    {
        if (count == 0) return "mr-mx__cell mr-mx__cell--zero";
        var severity = rag switch
        {
            "Red" => pri is "Critical" or "High" ? "mr-mx__cell mr-mx__cell--critical" : "mr-mx__cell mr-mx__cell--high",
            "Amber-Red" => pri is "Critical" or "High" ? "mr-mx__cell mr-mx__cell--high" : "mr-mx__cell mr-mx__cell--medium",
            "Amber-Green" => "mr-mx__cell mr-mx__cell--medium",
            "Green" => "mr-mx__cell mr-mx__cell--low",
            _ => "mr-mx__cell mr-mx__cell--neutral"
        };
        return severity;
    }

      int RagRank(string rag) => rag switch
      {
        "Green" => 1,
        "Amber-Green" => 2,
        "Amber-Red" => 3,
        "Red" => 4,
        _ => 0
      };

      string RagChangeMeta(string from, string to)
      {
        if (string.Equals(from, "Not Set", StringComparison.OrdinalIgnoreCase) && !string.Equals(to, "Not Set", StringComparison.OrdinalIgnoreCase))
          return "New status";

        var fromRank = RagRank(from);
        var toRank = RagRank(to);

        if (fromRank == 0 || toRank == 0 || fromRank == toRank)
          return "Updated";

        return toRank > fromRank ? "Worsening" : "Improving";
      }

      string RagChangeBucket(string from, string to)
      {
        var fr = RagRank(from);
        var tr = RagRank(to);
        if (fr > 0 && tr > 0 && tr > fr) return "worsening";
        if (fr > 0 && tr > 0 && tr < fr) return "improving";
        return "same";
      }

      var ragWorsening = m.RagChanges.Where(r => RagChangeBucket(r.From, r.To) == "worsening").ToList();
      var ragSame = m.RagChanges.Where(r => RagChangeBucket(r.From, r.To) == "same").ToList();
      var ragImproving = m.RagChanges.Where(r => RagChangeBucket(r.From, r.To) == "improving").ToList();

      var ragChangeBuckets = new (string Title, string Hint, List<ProjectChangeRow> Rows)[]
      {
        ("Worsening", "RAG moved toward red or higher risk.", ragWorsening),
        ("Same", "Same tier, moved from not set, or lateral change.", ragSame),
        ("Improving", "RAG moved toward green or lower risk.", ragImproving)
      };

      var mrReportPanelBaCount = m.BusinessAreaRows.Count;
      var mrReportPanelSubmissionTotal = m.MonthlyUpdateStats?.TotalProjects ?? 0;
      var mrReportPanelChangesItems = m.ProjectsWithPathToGreen.Count + m.RagChanges.Count + m.PriorityChanges.Count;
      var mrReportPanelTrendsTotal = m.TotalActiveProjects;
      var mrReportPanelMilestonesTotal = m.NewProjectsThisMonth.Count + m.MilestonesAchieved.Count + m.UpcomingMilestonesNext30Days.Count + m.LateMilestones.Count;

}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernReporting")">Reporting</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Monthly report</li>
}

<div class="mr-dash">

 <div class="dfe-c-page-title" style="margin-bottom:0.75rem;">
 <div class="dfe-c-page-title__caption">Reporting</div>
 <h1 class="dfe-c-page-title__heading">Monthly report — @m.MonthName</h1>
 <p class="dfe-c-body dfe-c-text-muted" style="margin:0;">Single monthly report: submission progress, narratives, RAG and priority flows, milestones, and business-area detail.</p>
  </div>

  @if (TempData["ErrorMessage"] != null)
  {
 <div class="dfe-c-error-summary" role="alert" style="margin-bottom:1.5rem;">
 <p class="dfe-c-body" style="margin:0;">@TempData["ErrorMessage"]</p>
    </div>
  }

  @* ══════════════════ Period + filters (compact) ══════════════════ *@
 <div class="mr-toolbar mr-toolbar--compact">
 <div class="mr-toolbar__row">
 <div class="mr-toolbar__nav mr-toolbar__nav--compact">
        @if (m.HasPreviousMonthNav && m.PreviousNavYear.HasValue && m.PreviousNavMonth.HasValue)
        {
 <a class="mr-toolbar__nav-link" href="@Url.Action("MonthlyUpdate", "ModernReporting", new { year = m.PreviousNavYear, month = m.PreviousNavMonth, businessAreaId = m.FilterBusinessAreaId, directorateId = m.FilterDirectorateId })">← @(new DateTime(m.PreviousNavYear.Value, m.PreviousNavMonth.Value, 1).ToString("MMM yy"))</a>
        }
 <span class="mr-toolbar__period">
          @m.MonthName
          @if (m.MonthlyUpdateStats != null)
          {
 <span class="dfe-c-text-muted"> · Due @m.MonthlyUpdateStats.DueDate.ToString("d MMM")</span>
          }
        </span>
        @if (m.HasNextMonthNav && m.NextNavYear.HasValue && m.NextNavMonth.HasValue)
        {
 <a class="mr-toolbar__nav-link" href="@Url.Action("MonthlyUpdate", "ModernReporting", new { year = m.NextNavYear, month = m.NextNavMonth, businessAreaId = m.FilterBusinessAreaId, directorateId = m.FilterDirectorateId })">@(new DateTime(m.NextNavYear.Value, m.NextNavMonth.Value, 1).ToString("MMM yy")) →</a>
        }
      </div>
 <form method="get" action="@Url.Action("MonthlyUpdate", "ModernReporting")" class="mr-toolbar__filters mr-toolbar__filters--compact" data-page-loading>
 <select name="year" class="govuk-select" id="mr-filter-year" aria-label="Year">
          @{
            var maxY = m.MaxReportYear >= m.MinReportYear ? m.MaxReportYear : DateTime.UtcNow.Year;
            var minY = m.MinReportYear;
            if (maxY < minY) { maxY = minY; }
          }
          @for (var y = maxY; y >= minY; y--)
          {
            if (m.ReportYear == y) { <option value="@y" selected>@y</option> }
            else { <option value="@y">@y</option> }
          }
        </select>
 <select name="month" class="govuk-select" id="mr-filter-month" aria-label="Month">
          @for (var mo = 1; mo <= 12; mo++)
          {
            if (m.ReportMonth == mo) { <option value="@mo" selected>@(new DateTime(2000, mo, 1).ToString("MMM"))</option> }
            else { <option value="@mo">@(new DateTime(2000, mo, 1).ToString("MMM"))</option> }
          }
        </select>
 <select name="businessAreaId" class="govuk-select" id="mr-filter-business-area" aria-label="Business area">
          <option value="">All areas</option>
          @foreach (var ba in m.BusinessAreas)
          {
            if (m.FilterBusinessAreaId == ba.Id) { <option value="@ba.Id" selected>@ba.Name</option> }
            else { <option value="@ba.Id">@ba.Name</option> }
          }
        </select>
 <select name="directorateId" class="govuk-select" id="mr-filter-directorate" aria-label="Directorate">
          <option value="">All directorates</option>
          @foreach (var d in m.Directorates)
          {
            if (m.FilterDirectorateId == d.Id) { <option value="@d.Id" selected>@d.Name</option> }
            else { <option value="@d.Id">@d.Name</option> }
          }
        </select>
 <button type="submit" class="govuk-button govuk-!-margin-bottom-0" id="mr-filter-apply">Apply</button>
      </form>
    </div>
  </div>

  @* ══════════ Summary (moved to top) ══════════ *@
 <section class="mr-section" id="mr-s-summary-top" aria-labelledby="mr-h-summary-top">
 <h2 id="mr-h-summary-top" class="mr-section__heading">Summary</h2>
 <div class="dfe-c-grid dfe-c-grid--4">
 <div class="dfe-c-metric">
 <div class="dfe-c-metric__number">@m.TotalActiveProjects</div>
 <div class="dfe-c-metric__label">Active work items</div>
      </div>
 <div class="dfe-c-metric">
 <div class="dfe-c-metric__number">@m.NewProjectsCount</div>
 <div class="dfe-c-metric__label">New this month</div>
      </div>
 <div class="dfe-c-metric">
 <div class="dfe-c-metric__number">@m.MilestonesAchievedCount</div>
 <div class="dfe-c-metric__label">Milestones achieved</div>
      </div>
      @if (m.MonthlyUpdateStats != null)
      {
 <div class="dfe-c-metric dfe-c-metric--green">
 <div class="dfe-c-metric__number">@m.MonthlyUpdateStats.Submitted</div>
 <div class="dfe-c-metric__label">Returns submitted</div>
        </div>
 <div class="dfe-c-metric">
 <div class="dfe-c-metric__number">@m.MonthlyUpdateStats.InProgress</div>
 <div class="dfe-c-metric__label">In progress</div>
        </div>
 <div class="dfe-c-metric dfe-c-metric--red">
 <div class="dfe-c-metric__number">@m.MonthlyUpdateStats.Late</div>
 <div class="dfe-c-metric__label">Late</div>
        </div>
      }
 <div class="dfe-c-metric">
 <div class="dfe-c-metric__number">@m.ProjectsWithRagChangeInPeriod</div>
 <div class="dfe-c-metric__label">RAG changes</div>
      </div>
 <div class="dfe-c-metric">
 <div class="dfe-c-metric__number">@m.ProjectsWithPriorityChangeInPeriod</div>
 <div class="dfe-c-metric__label">Priority changes</div>
      </div>
    </div>
    @if (!string.IsNullOrWhiteSpace(m.BusinessAreaSummaryNarrative))
    {
 <div class="govuk-inset-text govuk-!-margin-top-4 govuk-!-margin-bottom-0">
 <h3 class="govuk-heading-s govuk-!-margin-top-0">Business area overview</h3>
 <p class="govuk-body-s govuk-hint govuk-!-margin-bottom-3">This overview is <strong>generated automatically</strong> from Compass data shown on this page (and related history). It is intended as a gentle prompt for conversation—not a score, target, or formal assessment.</p>
        @foreach (var para in m.BusinessAreaSummaryNarrative.Split("\n\n", StringSplitOptions.RemoveEmptyEntries))
        {
 <p class="govuk-body govuk-!-margin-bottom-2">@para</p>
        }
      </div>
    }
  </section>

 <div class="mr-report-section-panel dfe-c-collapsible dfe-c-collapsible--open govuk-!-margin-bottom-3">
 <button type="button" class="dfe-c-collapsible__trigger" aria-expanded="true">
 <span class="dfe-c-collapsible__icon">−</span>
 <span>Business area summary</span>
 <span class="dfe-c-collapsible__status"><span class="govuk-tag govuk-tag--grey">@mrReportPanelBaCount</span></span>
      </button>
 <div class="dfe-c-collapsible__body">
<div id="d-mr-areas" class="mr-single-page-block" role="region" aria-labelledby="mr-h-ba">

  @* ══════════════════ Business area summary ══════════════════ *@
 <section class="mr-section" id="mr-s-ba" aria-labelledby="mr-h-ba">
 <h2 id="mr-h-ba" class="govuk-visually-hidden">Business area summary</h2>
      <div style="overflow-x:auto;-webkit-overflow-scrolling:touch;">
 <div class="dfe-c-table-wrap">
 <table class="mr-ba-table js-sortable-ba" id="mr-business-area-table">
          <thead>
            <tr>
 <th scope="col" rowspan="2" class="mr-ba-table__fixed mr-ba-table__area-col">Business area</th>
 <th scope="col" rowspan="2" class="mr-ba-table__num-hdr" data-sort-col="1" data-sort-type="num"><abbr title="Total active work items">Tot</abbr></th>
 <th scope="col" rowspan="2" class="mr-ba-table__num-hdr" data-sort-col="2" data-sort-type="num"><abbr title="Submitted returns">Submitted</abbr></th>
 <th scope="col" rowspan="2" class="mr-ba-table__num-hdr" data-sort-col="3" data-sort-type="num"><abbr title="New this month">New</abbr></th>
 <th scope="col" colspan="3" class="mr-ba-table__group mr-ba-table__group--ms">Milestones</th>
 <th scope="col" colspan="5" class="mr-ba-table__group mr-ba-table__group--rag">RAG status</th>
 <th scope="col" colspan="5" class="mr-ba-table__group mr-ba-table__group--pri">Delivery priority</th>
            </tr>
            <tr>
 <th class="mr-ba-table__sub mr-ba-table__sub--ms" data-sort-col="4" data-sort-type="num"><abbr title="Completed">Done</abbr></th><th class="mr-ba-table__sub mr-ba-table__sub--ms" data-sort-col="5" data-sort-type="num"><abbr title="Due in next 30 days">Soon</abbr></th><th class="mr-ba-table__sub mr-ba-table__sub--ms" data-sort-col="6" data-sort-type="num"><abbr title="Past due">Late</abbr></th>
 <th class="mr-ba-table__sub mr-ba-table__sub--rag" data-sort-col="7" data-sort-type="num"><abbr title="Red">R</abbr></th><th class="mr-ba-table__sub mr-ba-table__sub--rag" data-sort-col="8" data-sort-type="num"><abbr title="Amber–Red">A-R</abbr></th><th class="mr-ba-table__sub mr-ba-table__sub--rag" data-sort-col="9" data-sort-type="num"><abbr title="Amber–Green">A-G</abbr></th><th class="mr-ba-table__sub mr-ba-table__sub--rag" data-sort-col="10" data-sort-type="num"><abbr title="Green">G</abbr></th><th class="mr-ba-table__sub mr-ba-table__sub--rag" data-sort-col="11" data-sort-type="num"><abbr title="Not set">N/S</abbr></th>
 <th class="mr-ba-table__sub mr-ba-table__sub--pri" data-sort-col="12" data-sort-type="num"><abbr title="Critical">C</abbr></th><th class="mr-ba-table__sub mr-ba-table__sub--pri" data-sort-col="13" data-sort-type="num"><abbr title="High">H</abbr></th><th class="mr-ba-table__sub mr-ba-table__sub--pri" data-sort-col="14" data-sort-type="num"><abbr title="Medium">M</abbr></th><th class="mr-ba-table__sub mr-ba-table__sub--pri" data-sort-col="15" data-sort-type="num"><abbr title="Low">L</abbr></th><th class="mr-ba-table__sub mr-ba-table__sub--pri" data-sort-col="16" data-sort-type="num"><abbr title="Not set">N/S</abbr></th>
            </tr>
          </thead>
          <tbody>
          @{
            var totalRow = new ModernBusinessAreaDashboardRow
            {
              BusinessArea = "Total",
              TotalProjects = m.BusinessAreaRows.Sum(r => r.TotalProjects),
              SubmittedCount = m.BusinessAreaRows.Sum(r => r.SubmittedCount),
              NewThisMonth = m.BusinessAreaRows.Sum(r => r.NewThisMonth),
              MilestonesCompleted = m.BusinessAreaRows.Sum(r => r.MilestonesCompleted),
              MilestonesUpcoming30Days = m.BusinessAreaRows.Sum(r => r.MilestonesUpcoming30Days),
              MilestonesLate = m.BusinessAreaRows.Sum(r => r.MilestonesLate),
              RagRed = m.BusinessAreaRows.Sum(r => r.RagRed),
              RagAmberRed = m.BusinessAreaRows.Sum(r => r.RagAmberRed),
              RagAmberGreen = m.BusinessAreaRows.Sum(r => r.RagAmberGreen),
              RagGreen = m.BusinessAreaRows.Sum(r => r.RagGreen),
              RagNotSet = m.BusinessAreaRows.Sum(r => r.RagNotSet),
              PriCritical = m.BusinessAreaRows.Sum(r => r.PriCritical),
              PriHigh = m.BusinessAreaRows.Sum(r => r.PriHigh),
              PriMedium = m.BusinessAreaRows.Sum(r => r.PriMedium),
              PriLow = m.BusinessAreaRows.Sum(r => r.PriLow),
              PriNotSet = m.BusinessAreaRows.Sum(r => r.PriNotSet)
            };
          }
          @foreach (var row in m.BusinessAreaRows)
          {
            var ba = row.BusinessArea;
            var baEnc = Html.Encode(ba);
            string drillAttrs(string filter) => $"data-ba=\"{baEnc}\" data-filter=\"{filter}\" role=\"button\" tabindex=\"0\"";
            <tr>
 <th scope="row" class="mr-ba-table__fixed mr-ba-table__area-col">@ba</th>
 <td class="mr-ba-table__num"><span class="mr-ba-num mr-ba-num--strong mr-ba-drill" @Html.Raw(drillAttrs("total"))>@row.TotalProjects</span></td>
 <td class="mr-ba-table__num"><span class="mr-ba-num @(row.SubmittedCount > 0 ? "mr-ba-num--highlight mr-ba-drill" : "")" @(row.SubmittedCount > 0 ? Html.Raw(drillAttrs("submitted")) : Html.Raw(""))>@row.SubmittedCount</span></td>
 <td class="mr-ba-table__num"><span class="mr-ba-num @(row.NewThisMonth > 0 ? "mr-ba-num--highlight mr-ba-drill" : "")" @(row.NewThisMonth > 0 ? Html.Raw(drillAttrs("new")) : Html.Raw(""))>@row.NewThisMonth</span></td>
 <td class="mr-ba-table__cell--ms mr-ba-table__num"><span class="mr-ba-num @(row.MilestonesCompleted > 0 ? "mr-ba-drill" : "")" @(row.MilestonesCompleted > 0 ? Html.Raw(drillAttrs("ms-done")) : Html.Raw(""))>@row.MilestonesCompleted</span></td>
 <td class="mr-ba-table__cell--ms mr-ba-table__num"><span class="mr-ba-num @(row.MilestonesUpcoming30Days > 0 ? "mr-ba-drill" : "")" @(row.MilestonesUpcoming30Days > 0 ? Html.Raw(drillAttrs("ms-soon")) : Html.Raw(""))>@row.MilestonesUpcoming30Days</span></td>
 <td class="mr-ba-table__cell--ms mr-ba-table__num"><span class="mr-ba-num @(row.MilestonesLate > 0 ? "mr-ba-num--warn mr-ba-drill" : "")" @(row.MilestonesLate > 0 ? Html.Raw(drillAttrs("ms-late")) : Html.Raw(""))>@row.MilestonesLate</span></td>
 <td class="mr-ba-table__cell--rag mr-ba-table__num"><span class="mr-ba-num mr-ba-num--rag @(row.RagRed > 0 ? "mr-ba-num--rag-red mr-ba-drill" : "mr-ba-num--muted")" @(row.RagRed > 0 ? Html.Raw(drillAttrs("rag-Red")) : Html.Raw(""))>@row.RagRed</span></td>
 <td class="mr-ba-table__cell--rag mr-ba-table__num"><span class="mr-ba-num mr-ba-num--rag @(row.RagAmberRed > 0 ? "mr-ba-num--rag-amber-red mr-ba-drill" : "mr-ba-num--muted")" @(row.RagAmberRed > 0 ? Html.Raw(drillAttrs("rag-Amber-Red")) : Html.Raw(""))>@row.RagAmberRed</span></td>
 <td class="mr-ba-table__cell--rag mr-ba-table__num"><span class="mr-ba-num mr-ba-num--rag @(row.RagAmberGreen > 0 ? "mr-ba-num--rag-amber-grn mr-ba-drill" : "mr-ba-num--muted")" @(row.RagAmberGreen > 0 ? Html.Raw(drillAttrs("rag-Amber-Green")) : Html.Raw(""))>@row.RagAmberGreen</span></td>
 <td class="mr-ba-table__cell--rag mr-ba-table__num"><span class="mr-ba-num mr-ba-num--rag @(row.RagGreen > 0 ? "mr-ba-num--rag-green mr-ba-drill" : "mr-ba-num--muted")" @(row.RagGreen > 0 ? Html.Raw(drillAttrs("rag-Green")) : Html.Raw(""))>@row.RagGreen</span></td>
 <td class="mr-ba-table__cell--rag mr-ba-table__num"><span class="mr-ba-num mr-ba-num--rag @(row.RagNotSet > 0 ? "mr-ba-num--rag-ns mr-ba-drill" : "mr-ba-num--muted")" @(row.RagNotSet > 0 ? Html.Raw(drillAttrs("rag-Not Set")) : Html.Raw(""))>@row.RagNotSet</span></td>
 <td class="mr-ba-table__cell--pri mr-ba-table__num"><span class="mr-ba-num mr-ba-num--pri @(row.PriCritical > 0 ? "mr-ba-num--pri-crit mr-ba-drill" : "mr-ba-num--muted")" @(row.PriCritical > 0 ? Html.Raw(drillAttrs("pri-Critical")) : Html.Raw(""))>@row.PriCritical</span></td>
 <td class="mr-ba-table__cell--pri mr-ba-table__num"><span class="mr-ba-num mr-ba-num--pri @(row.PriHigh > 0 ? "mr-ba-num--pri-high mr-ba-drill" : "mr-ba-num--muted")" @(row.PriHigh > 0 ? Html.Raw(drillAttrs("pri-High")) : Html.Raw(""))>@row.PriHigh</span></td>
 <td class="mr-ba-table__cell--pri mr-ba-table__num"><span class="mr-ba-num mr-ba-num--pri @(row.PriMedium > 0 ? "mr-ba-num--pri-med mr-ba-drill" : "mr-ba-num--muted")" @(row.PriMedium > 0 ? Html.Raw(drillAttrs("pri-Medium")) : Html.Raw(""))>@row.PriMedium</span></td>
 <td class="mr-ba-table__cell--pri mr-ba-table__num"><span class="mr-ba-num mr-ba-num--pri @(row.PriLow > 0 ? "mr-ba-num--pri-low mr-ba-drill" : "mr-ba-num--muted")" @(row.PriLow > 0 ? Html.Raw(drillAttrs("pri-Low")) : Html.Raw(""))>@row.PriLow</span></td>
 <td class="mr-ba-table__cell--pri mr-ba-table__num"><span class="mr-ba-num mr-ba-num--pri @(row.PriNotSet > 0 ? "mr-ba-num--pri-ns mr-ba-drill" : "mr-ba-num--muted")" @(row.PriNotSet > 0 ? Html.Raw(drillAttrs("pri-Not Set")) : Html.Raw(""))>@row.PriNotSet</span></td>
            </tr>
          }
          </tbody>
