      <span class="dfe-f-toggle-group__separator" aria-hidden="true"> · </span>
      <button type="button" class="dfe-f-toggle-group__action" id="mr-report-edit-view" aria-pressed="false">Edit view</button>
    </div>
    <div class="dfe-f-toggle-group__items">
 <div class="mr-report-section-panel dfe-f-toggle govuk-!-margin-bottom-3" data-module="dfe-f-toggle" data-mr-section-id="business-area" data-mr-section-title="Business area summary">
 <div class="dfe-f-toggle__title-wrapper">
 <h2 class="dfe-f-toggle__heading">
 <button type="button" class="dfe-f-toggle__button" aria-expanded="true" aria-controls="mr-toggle-ba-content" id="mr-toggle-ba-button">
 <span class="dfe-f-toggle__icon" aria-hidden="true"></span>
 <span class="dfe-f-toggle__title" id="mr-h-ba">Business area summary</span>
 <span class="mr-toggle-panel__meta"><span class="govuk-tag govuk-tag--grey">@mrReportPanelBaCount</span></span>
 </button>
 </h2>
