      <style>
        .mr-ba-drill { cursor: pointer; text-decoration: underline; text-decoration-style: dotted; text-underline-offset: 2px; }
        .mr-ba-drill:hover, .mr-ba-drill:focus { text-decoration-style: solid; outline: 2px solid #fd0; outline-offset: 1px; }
        .mr-ba-drilldown-table { width: 100%; border-collapse: collapse; font-size: 0.8125rem; }
        .mr-ba-drilldown-table th,
        .mr-ba-drilldown-table td { padding: 0.5rem 0.6rem; border: 1px solid #b1b4b6; text-align: left; vertical-align: top; }
        .mr-ba-drilldown-table thead th { background: #f3f2f1; font-weight: 700; }
        .mr-ba-drilldown { margin-top: 1rem; border: 1px solid #b1b4b6; padding: 1rem 1.25rem; background: #fff; }
        .mr-ba-drilldown__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem; }
        .mr-ba-drilldown__title { margin: 0; font-size: 1.05rem; }
        .mr-ba-drilldown__close { background: none; border: none; font-size: 1.5rem; cursor: pointer; padding: 0 0.25rem; line-height: 1; color: #505a5f; }
        .mr-ba-drilldown__close:hover { color: #0b0c0c; }
      </style>

      <script nonce="@Context.Items["Nonce"]">
      (function () {
        var baProjects = @Html.Raw(baProjectsJson);
        var detailUrlPrefix = @Html.Raw(mwDetailPrefixJson);

        var filterLabels = {
          'total': 'All work items',
          'submitted': 'Submitted update',
          'new': 'New this month',
          'ms-done': 'Milestones completed',
          'ms-soon': 'Milestones due soon',
          'ms-late': 'Milestones late',
          'rag-Red': 'RAG: Red',
          'rag-Amber-Red': 'RAG: Amber-Red',
          'rag-Amber-Green': 'RAG: Amber-Green',
          'rag-Green': 'RAG: Green',
          'rag-Not Set': 'RAG: Not set',
          'pri-Critical': 'Priority: Critical',
          'pri-High': 'Priority: High',
          'pri-Medium': 'Priority: Medium',
          'pri-Low': 'Priority: Low',
          'pri-Not Set': 'Priority: Not set'
        };

        var ragBadge = { 'Red': 'rag-red', 'Amber-Red': 'rag-amber-red', 'Amber-Green': 'rag-amber', 'Green': 'rag-green', 'Not Set': 'rag-none' };
        var priBadge = { 'Critical': 'govuk-tag--red', 'High': 'govuk-tag--orange', 'Medium': 'govuk-tag--yellow', 'Low': 'govuk-tag--green', 'Not Set': 'govuk-tag--grey' };

        var panel = document.getElementById('mr-ba-drilldown');
        var title = document.getElementById('mr-ba-drilldown-title');
        var body = document.getElementById('mr-ba-drilldown-body');
        var activeCell = null;

        function filterItems(items, filter) {
          if (filter === 'total') return items;
          if (filter === 'submitted') return items.filter(function (p) { return p.submittedUpdate; });
          if (filter === 'new') return items.filter(function (p) { return p.isNew; });
          if (filter === 'ms-done') return items.filter(function (p) { return p.hasMilestoneCompletedInPeriod; });
          if (filter === 'ms-soon') return items.filter(function (p) { return p.hasMilestoneUpcomingInWindow; });
          if (filter === 'ms-late') return items.filter(function (p) { return p.hasLateMilestone; });
          if (filter.indexOf('rag-') === 0) { var v = filter.substring(4); return items.filter(function (p) { return p.rag === v; }); }
          if (filter.indexOf('pri-') === 0) { var v = filter.substring(4); return items.filter(function (p) { return p.priority === v; }); }
          return items;
        }

        function renderRows(items) {
          body.innerHTML = '';
          items.forEach(function (p) {
            var tr = document.createElement('tr');
            tr.className = 'mr-ba-drilldown-table__row';
            var href = detailUrlPrefix + p.id;
            tr.innerHTML =
              '<td class="mr-ba-drilldown-table__cell"><a class="dfe-c-link dfe-c-fw-bold" href="' + href + '">' + escHtml(p.title) + '</a></td>' +
              '<td class="mr-ba-drilldown-table__cell"><span class="rag-badge ' + (ragBadge[p.rag] || 'rag-none') + '">' + escHtml(p.rag) + '</span></td>' +
              '<td class="mr-ba-drilldown-table__cell"><span class="govuk-tag ' + (priBadge[p.priority] || 'govuk-tag--grey') + '">' + escHtml(p.priority) + '</span></td>';
            body.appendChild(tr);
          });
        }

        function escHtml(s) {
          var d = document.createElement('div');
          d.appendChild(document.createTextNode(s || ''));
          return d.innerHTML;
        }

        function show(ba, filter) {
          var items = filterItems(baProjects[ba] || [], filter);
          title.textContent = ba + ' \u2014 ' + (filterLabels[filter] || filter) + ' (' + items.length + ')';
          renderRows(items);
          panel.style.display = '';
          panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        function hide() {
          panel.style.display = 'none';
          if (activeCell) { activeCell.classList.remove('mr-ba-drill--active'); activeCell = null; }
        }

        document.getElementById('mr-business-area-table').addEventListener('click', function (e) {
          var cell = e.target.closest('.mr-ba-drill');
          if (!cell) return;
          var ba = cell.getAttribute('data-ba');
          var filter = cell.getAttribute('data-filter');
          if (!ba || !filter) return;
          if (activeCell === cell) { hide(); return; }
          if (activeCell) activeCell.classList.remove('mr-ba-drill--active');
          activeCell = cell;
          cell.classList.add('mr-ba-drill--active');
          show(ba, filter);
        });

        document.getElementById('mr-business-area-table').addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') {
            var cell = e.target.closest('.mr-ba-drill');
            if (cell) { e.preventDefault(); cell.click(); }
          }
        });

        panel.querySelector('.mr-ba-drilldown__close').addEventListener('click', hide);
      })();
      </script>

  </section>
  </div>

 </div>
