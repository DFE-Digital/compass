@section Styles {
<style>
  /* Square corners across this report (overrides nested GOV.UK / Compass2 radius tokens). */
  .mr-dash,
  .mr-dash * {
    border-radius: 0 !important;
  }

  .mr-dash { margin-bottom: 3rem; }

  /* Charts and wide tables stay inside DfE toggle panels (grid/flex default min-width:auto otherwise overflows). */
  .mr-dash .mr-report-section-panel > .dfe-f-toggle__content {
    overflow-x: auto;
    max-width: 100%;
    box-sizing: border-box;
  }
  .mr-dash .mr-report-section-panel .dfe-f-toggle__body {
    min-width: 0;
  }
  .mr-dash .mr-single-page-block {
    min-width: 0;
  }
  .mr-milestone-groups > .dfe-f-toggle {
    min-width: 0;
  }
  .mr-milestone-groups > .dfe-f-toggle > .dfe-f-toggle__content {
    overflow-x: auto;
    max-width: 100%;
    box-sizing: border-box;
  }

  .mr-report-tabs { margin-bottom: 1.25rem; flex-wrap: wrap; }

  /* ── Compact toolbar (single row where space allows) ── */
  .mr-toolbar {
    background: var(--rpt-bg-card, #fff);
    border: 1px solid var(--rpt-border, #e5e7eb);
    border-radius: var(--rpt-radius, 8px);
    padding: 0.65rem 0.85rem;
    box-shadow: var(--rpt-shadow, 0 1px 3px rgba(0,0,0,0.06));
    margin-bottom: 1rem;
  }
  .mr-toolbar--compact .mr-toolbar__row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1rem;
    justify-content: space-between;
  }
  .mr-toolbar__nav {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex: 0 1 auto;
    min-width: 0;
  }
  .mr-toolbar__nav--compact { flex-wrap: wrap; }
  .mr-toolbar__nav-link { font-size: 0.8125rem; font-weight: 600; white-space: nowrap; }
  .mr-toolbar__period { font-weight: 700; font-size: 0.9375rem; white-space: nowrap; }
  /* One horizontal row: do not cap width (old min(100%,20rem) forced stacked controls). */
  .mr-toolbar__filters {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
    overflow: visible;
    max-width: 100%;
  }
  .mr-toolbar__filters--compact {
    flex: 1 1 auto;
    justify-content: flex-end;
    min-width: 0;
  }
  .mr-toolbar__filters .govuk-select,
  .mr-toolbar__filters .govuk-button {
    flex: 0 0 auto;
  }
  .mr-toolbar__filters .govuk-select { max-width: 100%; }
  .mr-toolbar__filters .govuk-button { margin-bottom: 0; }
  #mr-filter-year { width: 6.5rem; min-width: 6.5rem; }
  #mr-filter-month { width: 7.5rem; min-width: 7.5rem; }
  #mr-filter-business-area,
  #mr-filter-directorate { width: 18rem; min-width: 16rem; max-width: 24rem; }
  #mr-filter-apply { min-width: 5.5rem; }

  /* ── Path to green (sortable table) ── */
  .mr-ptg-table-wrap { overflow-x: auto; }
  .mr-ptg-table {
    margin-bottom: 0;
    min-width: 36rem;
    table-layout: fixed;
    width: 100%;
  }
  .mr-ptg-table th,
  .mr-ptg-table td { font-size: 0.8125rem; vertical-align: top; }
  .mr-ptg-table__path-col {
    width: 33%;
  }
  .mr-ptg-table__path {
    white-space: pre-wrap;
    word-break: break-word;
    line-height: 1.45;
  }

  /* ── Milestone board ── */
  .mr-milestone-board { display: flex; flex-direction: column; gap: 1rem; }
  .mr-milestone-board__row { margin-top: 0; }
  .mr-milestone-board .mr-list li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem 0.75rem;
    align-items: baseline;
    padding: 0.5rem 0;
  }
  .mr-milestone-board .mr-list li > .mr-milestone-date {
    font-variant-numeric: tabular-nums;
    font-weight: 700;
    font-size: 0.8125rem;
    color: var(--grey-4, #505a5f);
    min-width: 4.5rem;
  }
  .mr-milestone-board .mr-list li > .mr-milestone-body { min-width: 0; }

  /* Stack milestone toggles — spacing matches former collapsible rhythm */
  .mr-milestone-groups {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mr-toggle-panel__meta {
    margin-left: auto;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .mr-report-section-panel.dfe-f-toggle {
    margin-bottom: 0;
  }

  .mr-report-layout {
    display: block;
  }
  .mr-report-layout--editing {
    display: grid;
    grid-template-columns: minmax(14rem, 18rem) 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  .mr-report-order-panel {
    background: var(--rpt-bg-card, #fff);
    border: 1px solid var(--rpt-border, #e5e7eb);
    padding: 1rem 1.25rem;
    position: sticky;
    top: 1rem;
  }
  .mr-report-order-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .mr-report-order-list__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid #f3f2f1;
    cursor: grab;
  }
  .mr-report-order-list__item--dragging {
    opacity: 0.6;
  }
  .mr-report-order-list__label {
    flex: 1;
    font-size: 0.875rem;
    font-weight: 600;
  }
  .mr-report-order-list__actions {
    display: flex;
    gap: 0.25rem;
    flex-shrink: 0;
  }
  .mr-report-order-list__btn {
    min-width: 2rem;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
  }
  .mr-report-layout__main {
    min-width: 0;
  }

  .mr-intel-section + .mr-intel-section {
    padding-top: 0.25rem;
    border-top: 1px solid #f3f2f1;
  }
  .mr-intel-group {
    padding: 0.75rem 0 0.25rem;
  }
  .mr-intel-group--warning {
    border-left: 3px solid #d4351c;
    padding-left: 0.75rem;
  }
  .mr-intel-group--positive {
    border-left: 3px solid #00703c;
    padding-left: 0.75rem;
  }
  .mr-intel-list {
    padding-left: 0;
    margin-top: 0;
  }
  .mr-intel-item {
    padding: 0.4rem 0;
    list-style: none;
  }
  .mr-intel-item__detail {
    margin-top: 0.15rem;
    line-height: 1.4;
  }

  /* ── Sections ── */
  .mr-section { margin-bottom: 2.5rem; scroll-margin-top: 1rem; }
  .mr-section__heading {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 1rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--navy, #1d70b8);
  }

  /* Submission "By business area" — scroll on small screens, no dfe-c-table-wrap card border */
  .mr-submission-ba-wrap {
    overflow-x: auto;
  }

  /* ── Cards ── */
  .mr-card {
    background: var(--rpt-bg-card, #fff);
    border: 1px solid var(--rpt-border, #e5e7eb);
    border-radius: var(--rpt-radius, 8px);
    padding: 1.25rem;
    box-shadow: var(--rpt-shadow, 0 1px 3px rgba(0,0,0,0.06));
  }
  .mr-card--full { grid-column: 1 / -1; }
  .mr-card__title { font-size: 0.9375rem; font-weight: 700; margin: 0 0 0.75rem 0; }
  .mr-card__count {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    background: var(--grey-1, #f3f2f1);
    color: var(--grey-4, #505a5f);
    padding: 0.1rem 0.45rem;
    border-radius: 10px;
    margin-left: 0.25rem;
    vertical-align: middle;
  }
  .mr-card__count--danger { background: var(--t-red-bg, #fde8e4); color: var(--t-red-fg, #942514); }

  /* ── Distribution grid (two-col) — extra gap so chart rows / matrix breathe ── */
  .mr-dist-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    align-items: start;
    min-width: 0;
  }
  .mr-dist-grid > .mr-card {
    height: 100%;
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
  }
  .mr-matrix-card {
    min-width: 0;
    overflow: hidden;
  }
  .mr-matrix-scroll {
    margin-bottom: 0;
  }
  .mr-chart-wrap {
    position: relative;
    width: 100%;
    max-width: 100%;
    height: 220px;
    max-height: 220px;
    margin-bottom: 1.5rem;
    overflow: hidden;
  }
  .mr-trend-wrap {
    position: relative;
    width: 100%;
    max-width: 100%;
    min-height: 280px;
    height: 280px;
    overflow: hidden;
  }
  .mr-chart-wrap canvas,
  .mr-trend-wrap canvas {
    display: block;
    max-width: 100% !important;
  }

  /* ── Distribution tables ── */
  .mr-dist-table { margin-top: 0.5rem; }
  .mr-dist-table th,
  .mr-dist-table td { padding: 0.4rem 0.5rem; font-size: 0.8125rem; }
  .mr-delta { font-size: 0.75rem; font-weight: 700; }
  .mr-delta--up { color: #d4351c; }
  .mr-delta--down { color: #00703c; }
  .mr-delta--flat { color: var(--grey-4, #505a5f); }

  /* ── Improved matrix ── */
  .mr-mx { border-collapse: separate; border-spacing: 3px; width: 100%; font-size: 0.875rem; }
  .mr-mx th, .mr-mx td { padding: 0.55rem 0.7rem; text-align: center; vertical-align: middle; }

  .mr-mx__corner {
    background: transparent;
    position: relative;
    min-width: 80px;
    min-height: 48px;
  }
  .mr-mx__corner-label {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--grey-4, #505a5f);
    position: absolute;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .mr-mx__corner-label--col { top: 4px; right: 6px; }
  .mr-mx__corner-label--row { bottom: 4px; left: 6px; }

  .mr-mx__col-hdr { background: #f8f8f8; font-weight: 600; border-radius: 4px; }
  .mr-mx__col-hdr--total { background: #eee; }
  .mr-mx__row-hdr, th.mr-mx__row-hdr { background: #f8f8f8; font-weight: 600; text-align: left; border-radius: 4px; padding-left: 0.5rem; }
  .mr-mx__row-hdr--total { background: #eee; }

  .mr-mx__cell { border-radius: 6px; transition: transform 0.1s; min-width: 48px; }
  .mr-mx__cell:hover { transform: scale(1.08); z-index: 1; }

  .mr-mx__cell--zero { background: #f8f8f8; }
  .mr-mx__cell--critical { background: #f8d7da; color: #721c24; font-weight: 700; border: 1px solid rgba(114,28,36,0.15); }
  .mr-mx__cell--high { background: #fff0e0; color: #80340a; font-weight: 700; border: 1px solid rgba(128,52,10,0.15); }
  .mr-mx__cell--medium { background: #fff7e0; color: #6e4900; font-weight: 600; border: 1px solid rgba(110,73,0,0.12); }
  .mr-mx__cell--low { background: #e3f5eb; color: #00703c; font-weight: 600; border: 1px solid rgba(0,112,60,0.12); }
  .mr-mx__cell--neutral { background: #f3f2f1; color: #505a5f; }
  .mr-mx__cell--total { background: #eee; font-weight: 700; border-radius: 4px; }
  .mr-mx__cell--grand { background: #ddd; font-weight: 700; font-size: 1rem; border-radius: 4px; }

  .mr-mx__count { font-size: 1.125rem; font-weight: 700; }
  .mr-mx__empty { color: #ccc; font-size: 0.875rem; }

  .mr-mx tfoot th, .mr-mx tfoot td { font-weight: 700; }

  /* ── Change tables ── */
  .mr-change-tbl th,
  .mr-change-tbl td { font-size: 0.8125rem; vertical-align: top; }
  .mr-change-arrow { color: var(--grey-4, #505a5f); font-size: 0.875rem; padding: 0 0.35rem; white-space: nowrap; }
  .mr-change-justification { max-width: 28rem; font-size: 0.8125rem; color: #333; line-height: 1.4; }
  .mr-change-tbl--narrative-first .mr-change-justification--lead {
    min-width: 14rem;
    max-width: 36rem;
    font-size: 0.875rem;
    line-height: 1.45;
  }
  .mr-change-shift { white-space: nowrap; }
  .mr-change-shift .rag-badge,
  .mr-change-shift .dfe-c-tag,
  .mr-change-shift .dfe-f-badge { vertical-align: middle; }

  /* ── BA summary table ── */
  .mr-ba-table { border-collapse: collapse; font-size: 0.8125rem; width: 100%; min-width: 52rem; }
  .mr-ba-table th, .mr-ba-table td { padding: 0.4rem 0.35rem; border: 1px solid var(--rpt-border, #e5e7eb); vertical-align: middle; }
  .mr-ba-table thead th { background: #f3f2f1; font-weight: 700; position: sticky; top: 0; z-index: 1; text-align: center; }
  .mr-ba-table thead th[data-sort-type="num"] { cursor: pointer; }
  .mr-ba-table thead th[data-sort-type="num"]:hover { background: #e8eaed; }
  .mr-ba-table__area-col {
    text-align: left !important;
    white-space: normal;
    min-width: 10rem;
    max-width: 22rem;
    font-weight: 600;
    hyphens: auto;
  }
  .mr-ba-table__num-hdr { font-variant-numeric: tabular-nums; }
  .mr-ba-table__num { text-align: center; font-variant-numeric: tabular-nums; }
  .mr-ba-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.75rem;
    padding: 0.2rem 0.45rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.8125rem;
    font-variant-numeric: tabular-nums;
    line-height: 1.2;
    background: #f3f2f1;
    color: #505a5f;
  }
  .mr-ba-num--strong { background: #e8eaed; color: #0b0c0c; font-weight: 700; }
  .mr-ba-num--muted { opacity: 0.45; font-weight: 500; }
  .mr-ba-num--highlight { background: #e8f5e9; color: #005a30; }
  .mr-ba-num--warn { background: #fff3cd; color: #6e4900; }
  .mr-ba-num--rag-red { background: #fde8e5; color: #942514; }
  .mr-ba-num--rag-amber-red { background: #ffeee5; color: #80340a; }
  .mr-ba-num--rag-amber-grn { background: #fff8e6; color: #6e4900; }
  .mr-ba-num--rag-green { background: #e3f5eb; color: #005a30; }
  .mr-ba-num--rag-ns { background: #ececec; color: #454a4d; }
  .mr-ba-num--pri-crit { background: #fde8e5; color: #942514; }
  .mr-ba-num--pri-high { background: #ffeee5; color: #80340a; }
  .mr-ba-num--pri-med { background: #fff8e6; color: #6e4900; }
  .mr-ba-num--pri-low { background: #e3f5eb; color: #005a30; }
  .mr-ba-num--pri-ns { background: #ececec; color: #454a4d; }
  .mr-ba-table__group { font-weight: 700; }
  .mr-ba-table__group--ms { background: #f0f4f5; border-bottom: 3px solid #5694ca; }
  .mr-ba-table__group--rag { background: #fef7f0; border-bottom: 3px solid #f47738; }
  .mr-ba-table__group--pri { background: #f0f5ef; border-bottom: 3px solid #00703c; }
  .mr-ba-table__sub { font-weight: 600; font-size: 0.6875rem; }
  .mr-ba-table__sub--ms { background: #f7fafb; }
  .mr-ba-table__sub--rag { background: #fffcf8; }
  .mr-ba-table__sub--pri { background: #f7faf6; }
  .mr-ba-table__cell--ms { background: rgba(86, 148, 202, 0.04); }
  .mr-ba-table__cell--rag { background: rgba(244, 119, 56, 0.04); }
  .mr-ba-table__cell--pri { background: rgba(0, 112, 60, 0.04); }
  .mr-ba-table__fixed { position: sticky; left: 0; background: #fff; z-index: 1; box-shadow: 2px 0 4px rgba(0,0,0,0.04); }
  .mr-ba-table thead .mr-ba-table__fixed { background: #f3f2f1; z-index: 2; }
  .mr-ba-table tfoot .mr-ba-table__fixed { background: #f3f2f1; z-index: 2; }
  .mr-ba-table tbody tr:nth-child(even) { background: #fafafa; }
  .mr-ba-table tbody tr:nth-child(even) .mr-ba-table__fixed { background: #fafafa; }
  .mr-ba-table__total-row th, .mr-ba-table__total-row td { background: #ebecef; font-weight: 700; border-top: 2px solid #333; }

  /* ── Lists ── */
  .mr-list { list-style: none; padding: 0; margin: 0; font-size: 0.875rem; }
  .mr-list li { padding: 0.4rem 0; border-bottom: 1px solid var(--rpt-border, #e5e7eb); }
  .mr-list li:last-child { border-bottom: none; }
  .mr-text-danger { color: #d4351c; }

  .mr-progress-bar__track {
    height: 0.75rem;
    background: #f3f2f1;
    border-radius: 999px;
    overflow: hidden;
    border: 1px solid #b1b4b6;
  }
  .mr-progress-bar__fill {
    height: 100%;
    background: linear-gradient(90deg, #5694ca, #1d70b8);
    border-radius: 999px;
    min-width: 2px;
    transition: width 0.35s ease;
  }
  .mr-progress-bar--compact .mr-progress-bar__track { height: 0.55rem; }
  .mr-completion-inline {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    justify-content: flex-end;
    flex-wrap: wrap;
  }
  .mr-completion-inline .mr-progress-bar {
    flex: 1 1 5rem;
    min-width: 4rem;
    max-width: 12rem;
    margin-top: 0;
  }
  .mr-completion-inline__pct {
    font-weight: 600;
    min-width: 3rem;
    text-align: right;
    font-variant-numeric: tabular-nums;
  }
  .mr-completion-cell { white-space: nowrap; }

  @@media (max-width: 768px) {
    .mr-dist-grid { grid-template-columns: 1fr; }
    .mr-toolbar__row {
      flex-wrap: wrap;
      align-items: center;
    }
    .mr-toolbar__filters--compact { justify-content: flex-start; }
    #mr-filter-business-area,
    #mr-filter-directorate { width: min(100%, 24rem); min-width: 14rem; }
    .mr-ptg-table { min-width: 0; }
  }
</style>
}

@section Scripts {
  <script src="~/modern/js/monthly-update-report.js" asp-append-version="true" nonce="@Context.Items["Nonce"]"></script>
  <script nonce="@Context.Items["Nonce"]">
    document.addEventListener('DOMContentLoaded', function () {
      function milestoneTogglesSetExpanded(expanded) {
        document.querySelectorAll('.mr-milestone-groups .dfe-f-toggle').forEach(function (el) {
          if (window.DfeFrontend && typeof window.DfeFrontend.setToggleExpanded === 'function') {
            window.DfeFrontend.setToggleExpanded(el, expanded);
          }
        });
      }
      var reportGroup = document.getElementById('mr-report-sections');
      if (reportGroup) {
        var expandAll = reportGroup.querySelector('[data-dfe-toggle-expand-all]');
        var collapseAll = reportGroup.querySelector('[data-dfe-toggle-collapse-all]');
        if (expandAll) {
          expandAll.addEventListener('click', function () { milestoneTogglesSetExpanded(true); });
        }
        if (collapseAll) {
          collapseAll.addEventListener('click', function () { milestoneTogglesSetExpanded(false); });
        }
      }
    });
  </script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" nonce="@Context.Items["Nonce"]"></script>
  <script nonce="@Context.Items["Nonce"]">
    (function () {
      var ragDist = @Html.Raw(ragDistJson);
      var priDist = @Html.Raw(priDistJson);
      var ragTrend = @Html.Raw(ragTrendJson);
      var priTrend = @Html.Raw(priTrendJson);

      var ragOrder = ['Red', 'Amber-Red', 'Amber-Green', 'Green', 'Not Set'];
      var ragColors = {
        'Red':         '#d4351c',
        'Amber-Red':   '#f47738',
        'Amber-Green': '#f8a100',
        'Green':       '#00703c',
        'Not Set':     '#b1b4b6'
      };

      var priOrder = ['Critical', 'High', 'Medium', 'Low', 'Not Set'];
      var priColors = {
        'Critical': '#d4351c',
        'High':     '#f47738',
        'Medium':   '#f8a100',
        'Low':      '#00703c',
        'Not Set':  '#b1b4b6'
      };

      var chartFont = { family: "'Inter', system-ui, -apple-system, sans-serif" };
      var chartDefaults = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom',
            labels: {
              boxWidth: 14,
              boxHeight: 14,
              useBorderRadius: true,
              borderRadius: 3,
              font: Object.assign({ size: 12, weight: '600' }, chartFont),
              padding: 12
            }
          },
          tooltip: {
            backgroundColor: 'rgba(11,12,12,0.92)',
            titleFont: Object.assign({ size: 13, weight: '700' }, chartFont),
            bodyFont: Object.assign({ size: 12 }, chartFont),
            padding: 10,
            cornerRadius: 6,
            displayColors: true,
            boxWidth: 10,
            boxHeight: 10,
            boxPadding: 4
          }
        }
      };

      function doughnut(id, keys, dist, colorMap) {
        var el = document.getElementById(id);
        if (!el || typeof Chart === 'undefined') return;
        var labels = keys.filter(function(k) { return (dist[k] || 0) > 0; });
        if (!labels.length) return;
        new Chart(el.getContext('2d'), {
          type: 'doughnut',
          data: {
            labels: labels,
            datasets: [{
              data: labels.map(function(k) { return dist[k] || 0; }),
              backgroundColor: labels.map(function(k) { return colorMap[k] || '#b1b4b6'; }),
              borderWidth: 3,
              borderColor: '#fff',
              hoverBorderWidth: 1,
              hoverBorderColor: '#0b0c0c'
            }]
          },
          options: Object.assign({}, chartDefaults, {
            cutout: '58%',
            plugins: Object.assign({}, chartDefaults.plugins, {
              tooltip: Object.assign({}, chartDefaults.plugins.tooltip, {
                callbacks: {
                  label: function(ctx) {
                    var total = ctx.dataset.data.reduce(function(a, b) { return a + b; }, 0);
                    var pct = total ? Math.round((ctx.parsed / total) * 100) : 0;
                    return ' ' + ctx.label + ': ' + ctx.parsed + ' (' + pct + '%)';
                  }
                }
              })
            })
          })
        });
      }

      doughnut('chart-rag', ragOrder, ragDist, ragColors);
      doughnut('chart-priority', priOrder, priDist, priColors);

      function stackedArea(id, trendData, datasets) {
        var el = document.getElementById(id);
        if (!el || typeof Chart === 'undefined' || !trendData || !trendData.length) return;
        new Chart(el.getContext('2d'), {
          type: 'line',
          data: {
            labels: trendData.map(function(t) { return t.label; }),
            datasets: datasets.map(function(ds) {
              return {
                label: ds.label,
                data: trendData.map(ds.accessor),
                borderColor: ds.color,
                backgroundColor: ds.bg,
                tension: 0.3,
                fill: true,
                pointRadius: 3,
                pointHoverRadius: 6,
                borderWidth: 2.5,
                pointBackgroundColor: ds.color,
                pointBorderColor: '#fff',
                pointBorderWidth: 1.5
              };
            })
          },
          options: Object.assign({}, chartDefaults, {
            interaction: { mode: 'index', intersect: false },
            scales: {
              x: { stacked: true, ticks: { maxRotation: 45, minRotation: 0, font: Object.assign({ size: 11 }, chartFont) }, grid: { display: false } },
              y: { stacked: true, beginAtZero: true, ticks: { precision: 0, font: Object.assign({ size: 11 }, chartFont) } }
            }
          })
        });
      }

      stackedArea('chart-rag-trend', ragTrend, [
        { label: 'Red',         accessor: function(t) { return t.red; },        color: '#d4351c', bg: 'rgba(212,53,28,0.18)' },
        { label: 'Amber-Red',   accessor: function(t) { return t.amberRed; },   color: '#f47738', bg: 'rgba(244,119,56,0.18)' },
        { label: 'Amber-Green', accessor: function(t) { return t.amberGreen; }, color: '#f8a100', bg: 'rgba(248,161,0,0.18)' },
        { label: 'Green',       accessor: function(t) { return t.green; },      color: '#00703c', bg: 'rgba(0,112,60,0.18)' },
        { label: 'Not set',     accessor: function(t) { return t.notSet; },     color: '#b1b4b6', bg: 'rgba(177,180,182,0.12)' }
      ]);

      stackedArea('chart-pri-trend', priTrend, [
        { label: 'Critical', accessor: function(t) { return t.critical; }, color: '#d4351c', bg: 'rgba(212,53,28,0.18)' },
        { label: 'High',     accessor: function(t) { return t.high; },     color: '#f47738', bg: 'rgba(244,119,56,0.18)' },
        { label: 'Medium',   accessor: function(t) { return t.medium; },   color: '#f8a100', bg: 'rgba(248,161,0,0.18)' },
        { label: 'Low',      accessor: function(t) { return t.low; },      color: '#00703c', bg: 'rgba(0,112,60,0.18)' },
        { label: 'Not set',  accessor: function(t) { return t.notSet; },   color: '#b1b4b6', bg: 'rgba(177,180,182,0.12)' }
      ]);
    })();
  </script>
}
