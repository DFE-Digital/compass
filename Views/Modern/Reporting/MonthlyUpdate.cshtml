      <div class="mr-report-order-panel__actions">
        <button type="button" class="govuk-button govuk-!-margin-bottom-2" id="mr-report-order-save">Save order</button>
        <button type="button" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0" id="mr-report-order-cancel">Cancel</button>
      </div>
    </aside>
    <div class="mr-report-layout__main">
  <div class="dfe-f-toggle-group mr-report-toggle-group govuk-!-margin-bottom-3" data-module="dfe-f-toggle-group" id="mr-report-sections">
    <div class="dfe-f-toggle-group__controls govuk-body-s govuk-!-margin-bottom-2 mr-report-toggle-group__controls">
      <button type="button" class="dfe-f-toggle-group__action" data-dfe-toggle-expand-all>Expand all</button>
      <span class="dfe-f-toggle-group__separator" aria-hidden="true"> · </span>
