 <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed mr-change-tbl mr-change-tbl--narrative-first">
 <thead class="govuk-table__head">
 <tr class="govuk-table__row">
 <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Work item</button>
        </th>
 <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Change</button>
        </th>
 <th scope="col" class="govuk-table__header govuk-table__header--numeric" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Date</button>
        </th>
 <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Reason</button>
        </th>
              </tr>
            </thead>
 <tbody class="govuk-table__body">
            @foreach (var row in bucket.Rows)
            {
 <tr class="govuk-table__row">
 <td class="govuk-table__cell">
 <button type="button" class="govuk-link govuk-!-font-weight-bold mr-info-btn mr-ba-drill-title-btn" data-mr-project-id="@row.ProjectId" data-mr-rag-just="@(row.RagJustification ?? "")" data-mr-narrative="@(row.LatestNarrative ?? "")" data-mr-title="@row.Title" aria-label="Open summary for @row.Title">@row.Title</button>
 <div class="dfe-c-body-s dfe-c-text-muted" style="margin-top:0.15rem;">@(row.BusinessArea ?? "—")</div>
                </td>
 <td class="mr-change-shift">
 <span class="@PriDfeBadge(row.From)">@row.From</span>
 <span class="mr-change-arrow" aria-hidden="true">→</span>
 <span class="@PriDfeBadge(row.To)">@row.To</span>
                </td>
 <td class="govuk-table__cell govuk-table__cell--numeric" style="white-space:nowrap;">@row.ChangedAt.ToString("d MMM yyyy")</td>
 <td class="mr-change-justification mr-change-justification--lead">@(string.IsNullOrWhiteSpace(row.Justification) ? "—" : row.Justification)</td>
              </tr>
            }
            </tbody>
          </table>
        </div>
          }
      </div>
    </div>
    </div>
        }
 </div>
      }
  </section>

  <script type="application/json" id="mr-ptg-narratives-json">@Html.Raw(ptgNarrativeJson)</script>
  <script type="application/json" id="mr-ptg-paths-json">@Html.Raw(ptgPathJson)</script>
  <script type="application/json" id="mr-ba-drill-details-json">@Html.Raw(drillModalDetailsJson)</script>

  @* ══════════════════ Info modal ══════════════════ *@
  <div id="mr-info-modal" class="mr-info-modal" role="dialog" aria-modal="true" aria-labelledby="mr-info-modal-title" style="display:none;">
    <div class="mr-info-modal__backdrop"></div>
    <div class="mr-info-modal__panel">
      <div class="mr-info-modal__header">
        <h3 id="mr-info-modal-title" class="govuk-heading-s govuk-!-margin-bottom-0"></h3>
        <button type="button" class="mr-info-modal__close" aria-label="Close">&times;</button>
      </div>
      <div class="mr-info-modal__body">
        <div id="mr-info-modal-ptg-section" class="mr-info-modal__block" hidden>
          <h4 class="govuk-heading-xs govuk-!-margin-bottom-1">Path to green</h4>
          <p id="mr-info-modal-ptg" class="dfe-c-body-s" style="white-space:pre-line;"></p>
        </div>
        <div id="mr-info-modal-narrative-section" class="mr-info-modal__block">
          <h4 class="govuk-heading-xs govuk-!-margin-bottom-1">Last submission</h4>
          <p id="mr-info-modal-narrative" class="dfe-c-body-s" style="white-space:pre-line;"></p>
        </div>
        <div id="mr-info-modal-summary-section" class="mr-info-modal__block" hidden>
          <h4 class="govuk-heading-xs govuk-!-margin-bottom-1">Summary</h4>
          <p id="mr-info-modal-summary" class="dfe-c-body-s" style="white-space:pre-line;"></p>
        </div>
        <div id="mr-info-modal-rag-section" class="mr-info-modal__block">
          <h4 class="govuk-heading-xs govuk-!-margin-bottom-1">RAG justification</h4>
          <p id="mr-info-modal-rag" class="dfe-c-body-s" style="white-space:pre-line;"></p>
        </div>
      </div>
      <div id="mr-info-modal-footer" class="mr-info-modal__footer" hidden>
        <a id="mr-info-modal-view-link" class="govuk-link govuk-link--no-visited-state" href="#">View full work item</a>
      </div>
    </div>
  </div>

  <style>
    .mr-info-btn { background:none; border:1px solid #b1b4b6; border-radius:4px; cursor:pointer; padding:0.2rem 0.5rem; font-size:0.95rem; line-height:1; color:#1d70b8; }
    .mr-info-btn:hover { background:#f3f2f1; }
    .mr-ba-drill-title-btn.mr-info-btn,
    .mr-ptg-title-btn.mr-info-btn { border:none; padding:0; text-decoration:underline; font-weight:700; text-align:left; }
    .mr-info-modal__backdrop { position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:9998; }
    .mr-info-modal__panel { position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); background:#fff; border-radius:8px; width:90%; max-width:56rem; max-height:80vh; overflow-y:auto; z-index:9999; box-shadow:0 4px 24px rgba(0,0,0,.25); }
    .mr-info-modal__header { display:flex; justify-content:space-between; align-items:flex-start; padding:1rem 1.25rem 0.5rem; border-bottom:1px solid #b1b4b6; }
    .mr-info-modal__close { background:none; border:none; font-size:1.5rem; cursor:pointer; color:#505a5f; padding:0 0.25rem; }
    .mr-info-modal__close:hover { color:#0b0c0c; }
    .mr-info-modal__body { padding:1rem 1.25rem 0.5rem; display:flex; flex-direction:column; gap:1rem; }
    .mr-info-modal__footer { padding:0 1.25rem 1.25rem; border-top:1px solid #f3f2f1; margin-top:0.5rem; padding-top:1rem; }
  </style>

  <script nonce="@Context.Items["Nonce"]">
  (function(){
    var modal = document.getElementById('mr-info-modal');
    var titleEl = document.getElementById('mr-info-modal-title');
    var summarySection = document.getElementById('mr-info-modal-summary-section');
    var summaryEl = document.getElementById('mr-info-modal-summary');
    var ptgSection = document.getElementById('mr-info-modal-ptg-section');
    var ptgEl = document.getElementById('mr-info-modal-ptg');
    var ragEl = document.getElementById('mr-info-modal-rag');
    var narrativeEl = document.getElementById('mr-info-modal-narrative');
    var footerEl = document.getElementById('mr-info-modal-footer');
    var viewLink = document.getElementById('mr-info-modal-view-link');
    var closeBtn = modal.querySelector('.mr-info-modal__close');
    var backdrop = modal.querySelector('.mr-info-modal__backdrop');
    var detailUrlPrefix = @Html.Raw(mwDetailPrefixJson);

    var ptgNarratives = {};
    try {
      var ptgNarrativesJsonEl = document.getElementById('mr-ptg-narratives-json');
      if (ptgNarrativesJsonEl && ptgNarrativesJsonEl.textContent) ptgNarratives = JSON.parse(ptgNarrativesJsonEl.textContent);
    } catch (e) { ptgNarratives = {}; }

    var ptgPaths = {};
    try {
      var ptgPathsJsonEl = document.getElementById('mr-ptg-paths-json');
      if (ptgPathsJsonEl && ptgPathsJsonEl.textContent) ptgPaths = JSON.parse(ptgPathsJsonEl.textContent);
    } catch (e) { ptgPaths = {}; }

    var drillDetailsById = {};
    try {
      var drillEl = document.getElementById('mr-ba-drill-details-json');
      if (drillEl && drillEl.textContent) drillDetailsById = JSON.parse(drillEl.textContent);
    } catch (e) { drillDetailsById = {}; }

    function openModal(btn) {
      var pid = btn.getAttribute('data-mr-project-id');
      var detail = pid && Object.prototype.hasOwnProperty.call(drillDetailsById, pid) ? drillDetailsById[pid] : null;

      titleEl.textContent = btn.getAttribute('data-mr-title') || (detail && detail.title) || '';

      var summaryText = detail && detail.summary ? detail.summary : '';
      if (!String(summaryText).trim()) summaryText = btn.getAttribute('data-mr-summary') || '';
      var showSummary = !!String(summaryText).trim();
      if (summarySection) {
        summarySection.hidden = !showSummary;
        summaryEl.textContent = showSummary ? String(summaryText).trim() : '';
      }

      var ptgText = detail && detail.pathToGreen ? String(detail.pathToGreen) : '';
      if (!String(ptgText).trim() && pid && Object.prototype.hasOwnProperty.call(ptgPaths, pid))
        ptgText = ptgPaths[pid] || '';
      var showPtg = !!String(ptgText).trim();
      if (ptgSection) {
        ptgSection.hidden = !showPtg;
        ptgEl.textContent = showPtg ? String(ptgText).trim() : '';
      }

      var ragText = btn.getAttribute('data-mr-rag-just');
      if (ragText === null || ragText === '')
        ragText = detail && detail.ragJustification ? detail.ragJustification : '';
      ragEl.textContent = ragText || '—';

      var narrative = '';
      var ptgId = btn.getAttribute('data-mr-ptg-id');
      if (ptgId && Object.prototype.hasOwnProperty.call(ptgNarratives, ptgId))
        narrative = ptgNarratives[ptgId] || '';
      else if (detail && detail.latestMonthlyUpdateNarrative)
        narrative = detail.latestMonthlyUpdateNarrative;
      else
        narrative = btn.getAttribute('data-mr-narrative') || '';
      narrativeEl.textContent = narrative || '—';

      if (!ragEl.textContent.trim()) ragEl.textContent = '—';
      if (!narrativeEl.textContent.trim()) narrativeEl.textContent = '—';

      if (pid && viewLink && detailUrlPrefix) {
        viewLink.href = detailUrlPrefix + pid;
        footerEl.hidden = false;
      } else {
        footerEl.hidden = true;
      }

      modal.style.display = '';
      closeBtn.focus();
    }

    function closeModal() {
      modal.style.display = 'none';
    }

    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.mr-info-btn');
      if (btn) { openModal(btn); return; }
    });
    closeBtn.addEventListener('click', closeModal);
    backdrop.addEventListener('click', closeModal);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && modal.style.display !== 'none') closeModal();
    });
  })();
  </script>

  </div>

 </div>
 </div>
 </div>


<div class="mr-report-section-panel dfe-f-toggle govuk-!-margin-bottom-3" data-module="dfe-f-toggle" data-mr-section-id="trends" data-mr-section-title="RAG, priority, and trends">
<div class="dfe-f-toggle__title-wrapper">
<h2 class="dfe-f-toggle__heading">
<button type="button" class="dfe-f-toggle__button" aria-expanded="true" aria-controls="mr-toggle-trends-content" id="mr-toggle-trends-button">
<span class="dfe-f-toggle__icon" aria-hidden="true"></span>
<span class="dfe-f-toggle__title">RAG, priority, and trends</span>
<span class="mr-toggle-panel__meta"><span class="govuk-tag govuk-tag--grey">@mrReportPanelTrendsTotal</span></span>
</button>
</h2>
</div>
<div id="mr-toggle-trends-content" class="dfe-f-toggle__content">
<div class="dfe-f-toggle__body govuk-body">
<div id="d-mr-rag-priority" class="mr-single-page-block" role="region" aria-labelledby="mr-h-dist">

  @* ══════════════════ RAG + Priority distribution ══════════════════ *@
 <section class="mr-section" id="mr-s-distribution" aria-labelledby="mr-h-dist">
 <h2 id="mr-h-dist" class="mr-section__heading">RAG and priority distribution</h2>
 <div class="mr-dist-grid">
 <div class="mr-card">
 <h3 class="mr-card__title">RAG status</h3>
 <div class="mr-chart-wrap">
          <canvas id="chart-rag" aria-label="RAG distribution chart"></canvas>
        </div>
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
 <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed mr-dist-table">
 <thead class="govuk-table__head">
 <tr class="govuk-table__row">
 <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">RAG</button>
        </th>
 <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Count</button>
        </th>
 <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">vs @m.PrevMonthName</button>
        </th>
            </tr>
          </thead>
 <tbody class="govuk-table__body">
          @foreach (var key in new[] { "Red", "Amber-Red", "Amber-Green", "Green", "Not Set" })
          {
            var val = m.RagDistribution.TryGetValue(key, out var v) ? v : 0;
 <tr class="govuk-table__row">
 <td class="govuk-table__cell"><span class="@RagBadgeClass(key)">@key</span></td>
 <td class="govuk-table__cell"><strong>@val</strong></td>
 <td class="govuk-table__cell">@Html.Raw(DeltaHtml(RagDelta(key)))</td>
            </tr>
          }
          </tbody>
        </table>
 </div>
      </div>
 <div class="mr-card">
 <h3 class="mr-card__title">Delivery priority</h3>
 <div class="mr-chart-wrap">
          <canvas id="chart-priority" aria-label="Priority distribution chart"></canvas>
        </div>
 <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
 <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed mr-dist-table">
 <thead class="govuk-table__head">
 <tr class="govuk-table__row">
 <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Priority</button>
        </th>
 <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">Count</button>
        </th>
 <th scope="col" class="govuk-table__header" aria-sort="none">
          <button type="button" class="dfe-f-table-sort-button">vs @m.PrevMonthName</button>
        </th>
            </tr>
          </thead>
 <tbody class="govuk-table__body">
          @foreach (var key in new[] { "Critical", "High", "Medium", "Low", "Not Set" })
          {
            var val = m.PriorityDistribution.TryGetValue(key, out var v) ? v : 0;
 <tr class="govuk-table__row">
 <td class="govuk-table__cell"><span class="@PriBadgeClass(key)">@key</span></td>
 <td class="govuk-table__cell"><strong>@val</strong></td>
 <td class="govuk-table__cell">@Html.Raw(DeltaHtml(PriDelta(key)))</td>
            </tr>
          }
          </tbody>
        </table>
 </div>
      </div>
    </div>
  </section>

  @* ══════════════════ RAG × Priority matrix ══════════════════ *@
 <section class="mr-section govuk-!-margin-top-8" id="mr-s-matrix" aria-labelledby="mr-h-matrix">
 <h2 id="mr-h-matrix" class="mr-section__heading">RAG × Priority matrix</h2>
 <p class="dfe-c-body-s dfe-c-text-muted" style="margin-bottom:1rem;">Heat map showing concentration of work items by RAG status and delivery priority. Darker shading indicates higher-risk combinations.</p>
 <div class="mr-card mr-matrix-card">
      @{
        var ragKeys = new[] { "Red", "Amber-Red", "Amber-Green", "Green", "Not Set" };
        var priKeys = new[] { "Not Set", "Low", "Medium", "High", "Critical" };
        var matrixLookup = m.RagPriorityMatrix.ToDictionary(c => c.Rag + "|" + c.Priority, c => c.Count);
      }
 <div class="dfe-f-table-wrapper mr-matrix-scroll" data-module="dfe-f-table">
  <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
 <table class="govuk-table govuk-table--small-text-until-tablet mr-mx" aria-label="RAG by Priority matrix">
 <caption class="govuk-visually-hidden">Cross-tabulation of RAG status against delivery priority</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
 <th class="mr-mx__corner" scope="col">
 <span class="mr-mx__corner-label mr-mx__corner-label--col">Priority →</span>
 <span class="mr-mx__corner-label mr-mx__corner-label--row">RAG ↓</span>
            </th>
 @foreach (var pk in priKeys) { <th scope="col" class="mr-mx__col-hdr"><span class="@PriBadgeClass(pk)">@pk</span></th> }
 <th scope="col" class="govuk-table__header mr-mx__col-hdr mr-mx__col-hdr--total">Total</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
        @foreach (var rk in ragKeys)
        {
          var rowTotal = priKeys.Sum(pk => matrixLookup.TryGetValue(rk + "|" + pk, out var cv) ? cv : 0);
          <tr class="govuk-table__row">
 <th scope="row" class="mr-mx__row-hdr"><span class="@RagBadgeClass(rk)">@rk</span></th>
            @foreach (var pk in priKeys)
            {
              var c = matrixLookup.TryGetValue(rk + "|" + pk, out var cv) ? cv : 0;
 <td class="@MatrixCellClass(rk, pk, c)">
                @if (c > 0)
                {
 <span class="mr-mx__count">@c</span>
                }
                else
                {
 <span class="mr-mx__empty">–</span>
                }
              </td>
            }
 <td class="mr-mx__cell mr-mx__cell--total"><strong>@rowTotal</strong></td>
          </tr>
        }
        </tbody>
        <tfoot>
          <tr class="govuk-table__row">
 <th scope="row" class="mr-mx__row-hdr mr-mx__row-hdr--total">Total</th>
            @foreach (var pk in priKeys)
            {
              var colTotal = ragKeys.Sum(rk => matrixLookup.TryGetValue(rk + "|" + pk, out var cv) ? cv : 0);
 <td class="mr-mx__cell mr-mx__cell--total"><strong>@colTotal</strong></td>
            }
 <td class="mr-mx__cell mr-mx__cell--grand"><strong>@m.TotalActiveProjects</strong></td>
          </tr>
        </tfoot>
      </table>
 </div>
    </div>
  </section>

  @* ══════════════════ Trend charts ══════════════════ *@
 <section class="mr-section" id="mr-s-trends" aria-labelledby="mr-h-trends">
 <h2 id="mr-h-trends" class="mr-section__heading">Trends</h2>
 <div class="mr-dist-grid">
 <div class="mr-card">
 <h3 class="mr-card__title">RAG over time</h3>
 <div class="mr-trend-wrap">
