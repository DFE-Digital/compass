@using System.Globalization
@using Compass.Models
@using Compass.ViewModels
@using Compass.ViewModels.Modern
@model ModernReportingPerformanceSubmissionProgressViewModel
@{
  ViewData["Title"] = "Performance submission progress";
  var m = Model ?? new ModernReportingPerformanceSubmissionProgressViewModel();
  var c = m.Commission;
  var ci = CultureInfo.GetCultureInfo("en-GB");
  var hasData = m.HasCommission && string.IsNullOrEmpty(m.LoadError);
  var baRows = m.BusinessAreas;
  var commissionTitle = c?.Name ?? (m.SelectedCommissionId.HasValue ? $"Commission #{m.SelectedCommissionId.Value}" : "this round");
  var windowTag = m.SubmissionWindowPhase switch
  {
    "Open" => ("govuk-tag--green", "Open for submission"),
    "Upcoming" => ("govuk-tag--blue", "Opens soon"),
    _ => ("govuk-tag--grey", "Closed")
  };
  var totP = baRows.Sum(x => x.Total);
  var totRet = baRows.Sum(x => x.Returned);
  var totNs = baRows.Sum(x => x.NotStarted);
  var totIp = baRows.Sum(x => x.InProgress);
  var totSub = baRows.Sum(x => x.Submitted);
  var totLate = baRows.Sum(x => x.Late);
}

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernReporting")">Reporting</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">Performance submission progress</li>
}

<div class="mr-dash">
  @{
    var perfSpHeaderLede = await Html.PartialAsync("_ReportingPerformanceSubmissionProgressHeaderLede");
  }
  @await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
    Caption = "Reporting",
    Title = "Performance submission progress",
    Lede = perfSpHeaderLede
  })

  @if (TempData["ErrorMessage"] != null)
  {
    <div class="dfe-c-error-summary" role="alert" style="margin-bottom:1.5rem;">
      <p class="dfe-c-body" style="margin:0;">@TempData["ErrorMessage"]</p>
    </div>
  }
  @if (!string.IsNullOrEmpty(m.LoadError))
  {
    <div class="dfe-c-error-summary" role="alert" style="margin-bottom:1.5rem;">
      <p class="dfe-c-body" style="margin:0;">@m.LoadError</p>
    </div>
  }
  else if (m.CommissionOptions.Count == 0)
  {
    <p class="govuk-body dfe-c-text-muted">No active commission rounds have opened for submission yet. When a round opens, progress will appear here.</p>
  }
  else
  {
    <div class="mr-toolbar mr-toolbar--compact govuk-!-margin-bottom-3">
      <div class="mr-toolbar__row">
        <div class="mr-toolbar__nav mr-toolbar__nav--compact">
          @if (c != null)
          {
            <span class="mr-toolbar__period">@c.Name</span>
            <strong class="govuk-tag @windowTag.Item1 govuk-!-margin-left-1">@windowTag.Item2</strong>
            <span class="dfe-c-text-muted">· @CommissionDisplay.FormatPeriod(c.StartDate, c.EndDate)</span>
            <span class="dfe-c-text-muted"> · Due @CommissionDisplay.FormatDueDate(c.DueDate)</span>
            @if (m.DaysUntilDue.HasValue && m.SubmissionWindowPhase == "Open")
            {
              <span class="dfe-c-text-muted"> · @(m.DaysUntilDue >= 0 ? $"{m.DaysUntilDue} day{(m.DaysUntilDue == 1 ? "" : "s")} left" : $"{Math.Abs(m.DaysUntilDue.Value)} day{(Math.Abs(m.DaysUntilDue.Value) == 1 ? "" : "s")} overdue")</span>
            }
          }
        </div>
        <form method="get" action="@Url.Action("PerformanceSubmissionProgress", "ModernReporting")" class="mr-toolbar__filters mr-toolbar__filters--compact" id="perf-submission-filters" data-page-loading>
          <select name="commissionId" id="perf-submission-commission" class="govuk-select" aria-label="Commission round">
            @foreach (var opt in m.CommissionOptions)
            {
              var label = $"{opt.Name} — due {opt.DueDate.ToString("d MMM yyyy", ci)}";
              if (m.SelectedCommissionId == opt.Id)
              {
                <option value="@opt.Id" selected>@label</option>
              }
              else
              {
                <option value="@opt.Id">@label</option>
              }
            }
          </select>
          <button type="submit" class="govuk-button govuk-!-margin-bottom-0" id="perf-submission-apply">Apply</button>
        </form>
      </div>
    </div>

    @if (hasData)
    {
      var overviewLines = new List<string>
      {
        $"This round ({commissionTitle}) includes {m.ProductsInScope:N0} in-scope products — the same catalogue scope as All products in the commission workspace (including product exclusions).",
        $"{m.Returned:N0} products have returned metrics ({m.ReturnRatePercent:0.#}% return rate): {m.Submitted:N0} on time and {m.Late:N0} late.",
        $"Metric completion is {m.MetricCompletionPercent:0.#}% across the reporting grid ({m.CompletedMetricCells:N0} of {m.ApplicableMetricCells:N0} applicable cells completed)."
      };

  <section class="mr-section" id="perf-sp-summary" aria-labelledby="perf-sp-h-summary">
    <h2 id="perf-sp-h-summary" class="mr-section__heading">Summary</h2>
    <div class="dfe-f-card-grid">
      <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
        <p class="govuk-body-s dfe-f-stat-card__label">Products in scope</p>
        <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@m.ProductsInScope</p>
      </div>
      <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
        <p class="govuk-body-s dfe-f-stat-card__label">Returned (submitted + late)</p>
        <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@m.Returned</p>
      </div>
      <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
        <p class="govuk-body-s dfe-f-stat-card__label">Return rate</p>
        <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@m.ReturnRatePercent%</p>
      </div>
      <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
        <p class="govuk-body-s dfe-f-stat-card__label">Metric completion</p>
        <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@m.MetricCompletionPercent%</p>
      </div>
      <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
        <p class="govuk-body-s dfe-f-stat-card__label">Not started</p>
        <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@m.NotStarted</p>
      </div>
      <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
        <p class="govuk-body-s dfe-f-stat-card__label">In progress</p>
        <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@m.InProgress</p>
      </div>
      <div class="dfe-f-stat-card dfe-f-stat-card--tint-green">
        <p class="govuk-body-s dfe-f-stat-card__label">Submitted on time</p>
        <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@m.Submitted</p>
      </div>
      <div class="dfe-f-stat-card dfe-f-stat-card--tint-red">
        <p class="govuk-body-s dfe-f-stat-card__label">Late</p>
        <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@m.Late</p>
      </div>
    </div>
    <div class="govuk-inset-text govuk-!-margin-top-4 govuk-!-margin-bottom-0">
      <h3 class="govuk-heading-s govuk-!-margin-top-0">Data summary</h3>
      @foreach (var line in overviewLines)
      {
        <p class="govuk-body govuk-!-margin-bottom-2">@line</p>
      }
    </div>
    <div class="mr-progress-bar govuk-!-margin-top-4" role="group" aria-label="Return rate">
      <div class="mr-progress-bar__label govuk-body-s govuk-!-margin-bottom-1">Return rate: <strong>@m.ReturnRatePercent%</strong> (@m.Returned of @m.ProductsInScope products returned)</div>
      <div class="mr-progress-bar__track" aria-hidden="true"><div class="mr-progress-bar__fill" style="width:@(m.ReturnRatePercent.ToString(ci))%;"></div></div>
    </div>
    <div class="mr-progress-bar govuk-!-margin-top-2" role="group" aria-label="Metric completion">
      <div class="mr-progress-bar__label govuk-body-s govuk-!-margin-bottom-1">Metric completion: <strong>@m.MetricCompletionPercent%</strong> (@m.CompletedMetricCells of @m.ApplicableMetricCells cells)</div>
      <div class="mr-progress-bar__track" aria-hidden="true"><div class="mr-progress-bar__fill mr-progress-bar__fill--metrics" style="width:@(m.MetricCompletionPercent.ToString(ci))%;"></div></div>
    </div>
  </section>

  <div class="mr-section-controls govuk-!-margin-bottom-3" style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;">
    <button type="button" class="govuk-button govuk-button--secondary" id="perf-sp-expand-all">Expand all sections</button>
    <button type="button" class="govuk-button govuk-button--secondary" id="perf-sp-collapse-all">Collapse all sections</button>
  </div>

  <div class="mr-report-section-panel dfe-f-toggle govuk-!-margin-bottom-3" data-module="dfe-f-toggle">
    <div class="dfe-f-toggle__title-wrapper">
      <h2 class="dfe-f-toggle__heading">
        <button type="button" class="dfe-f-toggle__button" aria-expanded="true" aria-controls="perf-sp-toggle-ba-content" id="perf-sp-toggle-ba-button">
          <span class="dfe-f-toggle__icon" aria-hidden="true"></span>
          <span class="dfe-f-toggle__title">Business area summary</span>
          <span class="mr-toggle-panel__meta"><span class="govuk-tag govuk-tag--grey">@baRows.Count</span></span>
        </button>
      </h2>
    </div>
    <div id="perf-sp-toggle-ba-content" class="dfe-f-toggle__content">
      <div class="dfe-f-toggle__body govuk-body">
        <p class="dfe-c-body-s dfe-c-text-muted govuk-!-margin-bottom-2">Completion by business area for in-scope products.</p>
        @if (baRows.Count == 0)
        {
          <p class="dfe-c-body-s dfe-c-text-muted">No in-scope products for this commission.</p>
        }
        else
        {
          <div style="overflow-x:auto;-webkit-overflow-scrolling:touch;">
            <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
              <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
              <table class="govuk-table mr-ba-table" id="perf-sp-business-area-table">
                <caption class="govuk-visually-hidden">Completion by business area</caption>
                <thead class="govuk-table__head">
                  <tr class="govuk-table__row">
                    <th scope="col" rowspan="2" class="mr-ba-table__fixed mr-ba-table__area-col">Business area</th>
                    <th scope="col" rowspan="2" class="mr-ba-table__num-hdr">Prod</th>
                    <th scope="col" colspan="3" class="mr-ba-table__group mr-ba-table__group--ms">Return &amp; completion</th>
                    <th scope="col" colspan="4" class="mr-ba-table__group mr-ba-table__group--pri">Submission status</th>
                  </tr>
                  <tr class="govuk-table__row">
                    <th class="mr-ba-table__sub mr-ba-table__sub--ms" scope="col">Ret</th>
                    <th class="mr-ba-table__sub mr-ba-table__sub--ms" scope="col">Ret %</th>
                    <th class="mr-ba-table__sub mr-ba-table__sub--ms" scope="col">Met %</th>
                    <th class="mr-ba-table__sub mr-ba-table__sub--pri" scope="col">N/S</th>
                    <th class="mr-ba-table__sub mr-ba-table__sub--pri" scope="col">I/P</th>
                    <th class="mr-ba-table__sub mr-ba-table__sub--pri" scope="col">Sub</th>
                    <th class="mr-ba-table__sub mr-ba-table__sub--pri" scope="col">Late</th>
                  </tr>
                </thead>
                <tbody class="govuk-table__body">
                  @foreach (var row in baRows)
                  {
                    <tr class="govuk-table__row">
                      <th scope="row" class="mr-ba-table__fixed mr-ba-table__area-col">@row.BusinessArea</th>
                      <td class="mr-ba-table__num"><span class="mr-ba-num mr-ba-num--strong">@row.Total</span></td>
                      <td class="mr-ba-table__cell--ms mr-ba-table__num"><span class="mr-ba-num @(row.Returned > 0 ? "mr-ba-num--highlight" : "mr-ba-num--muted")">@row.Returned</span></td>
                      <td class="mr-ba-table__cell--ms mr-ba-table__num"><span class="mr-ba-num">@row.ReturnRatePercent%</span></td>
                      <td class="mr-ba-table__cell--ms mr-ba-table__num"><span class="mr-ba-num">@row.MetricCompletionPercent%</span></td>
                      <td class="mr-ba-table__cell--pri mr-ba-table__num"><span class="mr-ba-num @(row.NotStarted > 0 ? "" : "mr-ba-num--muted")">@row.NotStarted</span></td>
                      <td class="mr-ba-table__cell--pri mr-ba-table__num"><span class="mr-ba-num @(row.InProgress > 0 ? "" : "mr-ba-num--muted")">@row.InProgress</span></td>
                      <td class="mr-ba-table__cell--pri mr-ba-table__num"><span class="mr-ba-num mr-ba-num--pri @(row.Submitted > 0 ? "mr-ba-num--pri-low" : "mr-ba-num--muted")">@row.Submitted</span></td>
                      <td class="mr-ba-table__cell--pri mr-ba-table__num"><span class="mr-ba-num mr-ba-num--pri @(row.Late > 0 ? "mr-ba-num--pri-crit" : "mr-ba-num--muted")">@row.Late</span></td>
                    </tr>
                  }
                </tbody>
                <tfoot>
                  <tr class="mr-ba-table__total-row">
                    <th scope="row" class="mr-ba-table__fixed mr-ba-table__area-col">Total</th>
                    <td class="mr-ba-table__num"><span class="mr-ba-num mr-ba-num--strong">@totP</span></td>
                    <td class="mr-ba-table__cell--ms mr-ba-table__num"><span class="mr-ba-num mr-ba-num--strong">@totRet</span></td>
                    <td class="mr-ba-table__cell--ms mr-ba-table__num"><span class="mr-ba-num mr-ba-num--strong">@m.ReturnRatePercent%</span></td>
                    <td class="mr-ba-table__cell--ms mr-ba-table__num"><span class="mr-ba-num mr-ba-num--strong">@m.MetricCompletionPercent%</span></td>
                    <td class="mr-ba-table__cell--pri mr-ba-table__num"><span class="mr-ba-num mr-ba-num--strong">@totNs</span></td>
                    <td class="mr-ba-table__cell--pri mr-ba-table__num"><span class="mr-ba-num mr-ba-num--strong">@totIp</span></td>
                    <td class="mr-ba-table__cell--pri mr-ba-table__num"><span class="mr-ba-num mr-ba-num--pri mr-ba-num--pri-low">@totSub</span></td>
                    <td class="mr-ba-table__cell--pri mr-ba-table__num"><span class="mr-ba-num mr-ba-num--pri mr-ba-num--pri-crit">@totLate</span></td>
                  </tr>
                </tfoot>
              </table>
            </div>
          </div>
        }
      </div>
    </div>
  </div>

  @if (m.MetricRows.Any())
  {
    <div class="mr-report-section-panel dfe-f-toggle govuk-!-margin-bottom-3" data-module="dfe-f-toggle">
      <div class="dfe-f-toggle__title-wrapper">
        <h2 class="dfe-f-toggle__heading">
          <button type="button" class="dfe-f-toggle__button" aria-expanded="true" aria-controls="perf-sp-toggle-metrics-content" id="perf-sp-toggle-metrics-button">
            <span class="dfe-f-toggle__icon" aria-hidden="true"></span>
            <span class="dfe-f-toggle__title">Metric completion</span>
            <span class="mr-toggle-panel__meta"><span class="govuk-tag govuk-tag--grey">@m.MetricRows.Count</span></span>
          </button>
        </h2>
      </div>
      <div id="perf-sp-toggle-metrics-content" class="dfe-f-toggle__content">
        <div class="dfe-f-toggle__body govuk-body">
          <p class="dfe-c-body-s dfe-c-text-muted govuk-!-margin-bottom-2">Completion rate for each active performance metric across in-scope products.</p>
          <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
            <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
            <table class="govuk-table govuk-!-margin-bottom-0" id="perf-sp-metrics-table">
              <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                  <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Metric</button></th>
                  <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Applicable products</button></th>
                  <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Completed</button></th>
                  <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Completion</button></th>
                </tr>
              </thead>
              <tbody class="govuk-table__body">
                @foreach (var metric in m.MetricRows)
                {
                  var mPct = metric.CompletionPercent;
                  var mTier = mPct >= 90m ? "mr-metric-bar-fill--green" : (mPct >= 60m ? "mr-metric-bar-fill--amber" : (mPct >= 20m ? "mr-metric-bar-fill--red" : "mr-metric-bar-fill--black"));
                  <tr class="govuk-table__row">
                    <th scope="row" class="govuk-table__cell">@metric.Name</th>
                    <td class="govuk-table__cell">@metric.ApplicableProducts</td>
                    <td class="govuk-table__cell">@metric.CompletedCount</td>
                    <td class="govuk-table__cell">
                      <div class="mr-metric-inline-bar">
                        <div class="mr-metric-bar-track" aria-hidden="true">
                          <div class="mr-metric-bar-fill @mTier" style="width: @mPct.ToString("0.#", ci)%"></div>
                        </div>
                        <span class="govuk-body-s"><strong>@mPct%</strong></span>
                      </div>
                    </td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  }

  <div class="govuk-button-group govuk-!-margin-top-6">
    <a class="govuk-button govuk-button--secondary" href="@Url.Action("Commission", "ModernPerformance", new { commissionId = c!.Id, tab = "all" })">Open commission workspace (all products)</a>
    <a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("Performance", "ModernReporting")">Performance (completed rounds)</a>
  </div>
    }
  }
</div>

@section Styles {
<style>
  .mr-dash,
  .mr-dash * {
    border-radius: 0 !important;
  }
  .mr-dash { margin-bottom: 3rem; }
  .mr-toolbar {
    background: var(--rpt-bg-card, #fff);
    border: 1px solid var(--rpt-border, #e5e7eb);
    padding: 0.65rem 0.85rem;
    box-shadow: var(--rpt-shadow, 0 1px 3px rgba(0,0,0,0.06));
    margin-bottom: 1rem;
  }
  .mr-toolbar--compact .mr-toolbar__row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1rem;
    justify-content: space-between;
  }
  .mr-toolbar__nav { display: flex; align-items: center; gap: 0.65rem; flex: 0 1 auto; min-width: 0; flex-wrap: wrap; }
  .mr-toolbar__period { font-weight: 700; font-size: 0.9375rem; white-space: nowrap; }
  .mr-toolbar__filters {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    min-width: 0;
  }
  .mr-toolbar__filters--compact { flex: 1 1 auto; justify-content: flex-end; }
  #perf-submission-commission { flex: 1 1 26rem; min-width: 22rem; max-width: 36rem; }
  .mr-section { margin-bottom: 2.5rem; scroll-margin-top: 1rem; }
  .mr-section__heading {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 1rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--navy, #1d70b8);
  }
  .mr-progress-bar__track {
    height: 0.75rem;
    background: #f3f2f1;
    overflow: hidden;
    border: 1px solid #b1b4b6;
  }
  .mr-progress-bar__fill {
    height: 100%;
    background: linear-gradient(90deg, #5694ca, #1d70b8);
    min-width: 2px;
    transition: width 0.35s ease;
  }
  .mr-progress-bar__fill--metrics { background: linear-gradient(90deg, #80cbc4, #00703c); }
  .mr-ba-table { border-collapse: collapse; font-size: 0.8125rem; width: 100%; min-width: 44rem; }
  .mr-ba-table th, .mr-ba-table td { padding: 0.4rem 0.35rem; border: 1px solid var(--rpt-border, #e5e7eb); vertical-align: middle; }
  .mr-ba-table thead th { background: #f3f2f1; font-weight: 700; position: sticky; top: 0; z-index: 1; text-align: center; }
  .mr-ba-table__area-col { text-align: left !important; white-space: normal; min-width: 10rem; max-width: 22rem; font-weight: 600; }
  .mr-ba-table__num { text-align: center; font-variant-numeric: tabular-nums; }
  .mr-ba-num {
    display: inline-flex; align-items: center; justify-content: center; min-width: 1.75rem;
    padding: 0.2rem 0.45rem; font-weight: 600; font-size: 0.8125rem; font-variant-numeric: tabular-nums;
    background: #f3f2f1; color: #505a5f;
  }
  .mr-ba-num--strong { background: #e8eaed; color: #0b0c0c; font-weight: 700; }
  .mr-ba-num--muted { opacity: 0.45; font-weight: 500; }
  .mr-ba-num--highlight { background: #e8f5e9; color: #005a30; }
  .mr-ba-num--pri-crit { background: #fde8e5; color: #942514; }
  .mr-ba-num--pri-low { background: #e3f5eb; color: #005a30; }
  .mr-ba-table__group--ms { background: #f0f4f5; border-bottom: 3px solid #5694ca; }
  .mr-ba-table__group--pri { background: #f0f5ef; border-bottom: 3px solid #00703c; }
  .mr-ba-table__sub--ms { background: #f7fafb; }
  .mr-ba-table__sub--pri { background: #f7faf6; }
  .mr-ba-table__cell--ms { background: rgba(86, 148, 202, 0.04); }
  .mr-ba-table__cell--pri { background: rgba(0, 112, 60, 0.04); }
  .mr-ba-table__fixed { position: sticky; left: 0; background: #fff; z-index: 1; box-shadow: 2px 0 4px rgba(0,0,0,0.04); }
  .mr-ba-table thead .mr-ba-table__fixed { background: #f3f2f1; z-index: 2; }
  .mr-ba-table tfoot .mr-ba-table__fixed { background: #f3f2f1; z-index: 2; }
  .mr-ba-table tbody tr:nth-child(even) { background: #fafafa; }
  .mr-ba-table tbody tr:nth-child(even) .mr-ba-table__fixed { background: #fafafa; }
