@* Shared drill-down table panel for modern reporting pages. *@
<div id="mr-ba-drilldown" class="mr-ba-drilldown govuk-!-margin-top-3" hidden>
  <div class="mr-ba-drilldown__header">
    <h3 class="mr-ba-drilldown__title" id="mr-ba-drilldown-title"></h3>
    <div class="mr-ba-drilldown__actions">
      <a href="#" class="govuk-link govuk-link--no-visited-state govuk-body-s" id="mr-ba-drilldown-export" hidden data-report-download data-generating-modal-title="Generating work export">Export workbook</a>
      <button type="button" class="mr-ba-drilldown__close" aria-label="Close drill-down">&times;</button>
    </div>
  </div>
  <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
    <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
    <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed mr-ba-drilldown-table" id="mr-ba-drilldown-table">
      <caption class="govuk-visually-hidden">Work items for selected summary cell</caption>
      <thead class="govuk-table__head" id="mr-ba-drilldown-head">
        <tr class="govuk-table__row">
          <th scope="col" class="govuk-table__header mr-col-work-item" aria-sort="none">
            <button type="button" class="dfe-f-table-sort-button">Work item</button>
          </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
            <button type="button" class="dfe-f-table-sort-button">RAG</button>
          </th>
          <th scope="col" class="govuk-table__header" aria-sort="none">
            <button type="button" class="dfe-f-table-sort-button">Priority</button>
          </th>
          <th scope="col" class="govuk-table__header govuk-table__header--numeric" aria-sort="none">
            <button type="button" class="dfe-f-table-sort-button">FTE / MSC</button>
          </th>
          <th scope="col" class="govuk-table__header mr-ba-drilldown-table__extra" id="mr-ba-drilldown-extra-hdr" hidden aria-sort="none">
            <button type="button" class="dfe-f-table-sort-button">RAG justification</button>
          </th>
        </tr>
      </thead>
      <tbody id="mr-ba-drilldown-body" class="govuk-table__body"></tbody>
    </table>
  </div>
</div>
