@using Compass.Controllers
@{
  ViewData["Title"] = "Reporting compliance";
  var periodStats = ViewBag.PeriodStats as MonthlyUpdateStats;
  var statusGroups = ViewBag.StatusGroups as Dictionary<string, List<Compass.Models.Project>> ?? new Dictionary<string, List<Compass.Models.Project>>();
  var businessAreaGroups = ViewBag.BusinessAreaGroups as Dictionary<string, BusinessAreaMonthlyData> ?? new Dictionary<string, BusinessAreaMonthlyData>();
  var monthName = ViewBag.MonthName as string ?? "";
  var dueDate = ViewBag.DueDate as DateTime?;
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernWork")">Work</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Reporting compliance</li>
}

<div class="dfe-c-page-title dfe-c-mb-3">
 <div class="dfe-c-page-title__caption">Work</div>
 <h1 class="dfe-c-page-title__heading">Monthly reporting compliance</h1>
 <p class="dfe-c-body dfe-c-text-muted dfe-c-mb-0">Status of project monthly returns for @monthName. Due date: @(dueDate?.ToString("d MMMM yyyy") ?? "—").</p>
</div>

@if (TempData["ErrorMessage"] != null)
{
 <div class="dfe-c-error-summary dfe-c-mb-3" role="alert">
 <p class="dfe-c-body dfe-c-mb-0">@TempData["ErrorMessage"]</p>
  </div>
}

<div class="dfe-c-mb-3 dfe-c-body-s">
  @if (ViewBag.HasPreviousMonth == true)
  {
 <a class="dfe-c-link" href="@Url.Action("MonthlyUpdateOverview", "ModernReporting", new { year = ViewBag.PreviousYear, month = ViewBag.PreviousMonth })">← Previous month</a>
  }
  @if (ViewBag.HasNextMonth == true)
  {
 <span class="dfe-c-text-muted"> · </span>
 <a class="dfe-c-link" href="@Url.Action("MonthlyUpdateOverview", "ModernReporting", new { year = ViewBag.NextYear, month = ViewBag.NextMonth })">Next month →</a>
  }
</div>

@if (periodStats != null)
{
 <div class="dfe-c-grid" style="grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 1rem; margin-bottom: 1.5rem;">
 <div class="dfe-c-scard" style="padding:1rem;">
 <div class="dfe-c-body-s dfe-c-text-muted">Total active projects</div>
      <div style="font-size:1.75rem;font-weight:700;">@periodStats.TotalProjects</div>
    </div>
 <div class="dfe-c-scard" style="padding:1rem;">
 <div class="dfe-c-body-s dfe-c-text-muted">Submitted</div>
      <div style="font-size:1.75rem;font-weight:700;color:#00703c;">@periodStats.Submitted</div>
    </div>
 <div class="dfe-c-scard" style="padding:1rem;">
 <div class="dfe-c-body-s dfe-c-text-muted">In progress</div>
      <div style="font-size:1.75rem;font-weight:700;">@periodStats.InProgress</div>
    </div>
 <div class="dfe-c-scard" style="padding:1rem;">
 <div class="dfe-c-body-s dfe-c-text-muted">Not started</div>
      <div style="font-size:1.75rem;font-weight:700;">@periodStats.NotStarted</div>
    </div>
 <div class="dfe-c-scard" style="padding:1rem;">
 <div class="dfe-c-body-s dfe-c-text-muted">Late</div>
      <div style="font-size:1.75rem;font-weight:700;color:#d4351c;">@periodStats.Late</div>
    </div>
  </div>
}

<h2 class="dfe-c-heading-m dfe-c-mb-2">By status</h2>
@foreach (var kv in statusGroups)
{
 <h3 class="dfe-c-heading-s dfe-c-mt-3 dfe-c-mb-2">@kv.Key (@kv.Value.Count)</h3>
  @if (kv.Value.Count == 0)
  {
 <p class="dfe-c-body-s dfe-c-text-muted">None.</p>
  }
  else
  {
 <div class="dfe-c-table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col">Work item</th>
            <th scope="col">Business area</th>
            <th scope="col">Primary contact</th>
          </tr>
        </thead>
        <tbody>
        @foreach (var p in kv.Value)
        {
          <tr>
 <td><a class="dfe-c-link dfe-c-fw-bold" href="@Url.Action("Detail", "ModernWork", new { id = p.Id })">@p.Title</a></td>
            <td>@(p.BusinessAreaLookup?.Name ?? "—")</td>
            <td>@(p.PrimaryContactUser?.Name ?? "—")</td>
          </tr>
        }
        </tbody>
      </table>
    </div>
  }
}

<h2 class="dfe-c-heading-m dfe-c-mt-4 dfe-c-mb-2">By business area</h2>
@foreach (var kv in businessAreaGroups.OrderBy(x => x.Key))
{
  var g = kv.Value;
 <h3 class="dfe-c-heading-s dfe-c-mt-3 dfe-c-mb-2">@g.BusinessAreaName — @g.SubmittedCount / @g.TotalProjects submitted</h3>
  @if (g.Projects.Count == 0)
  {
 <p class="dfe-c-body-s dfe-c-text-muted">No projects.</p>
  }
  else
  {
 <div class="dfe-c-table-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col">Work item</th>
            <th scope="col">Primary contact</th>
          </tr>
        </thead>
        <tbody>
        @foreach (var p in g.Projects)
        {
          <tr>
 <td><a class="dfe-c-link" href="@Url.Action("Detail", "ModernWork", new { id = p.Id })">@p.Title</a></td>
            <td>@(p.PrimaryContactUser?.Name ?? "—")</td>
          </tr>
        }
        </tbody>
      </table>
    </div>
  }
}
