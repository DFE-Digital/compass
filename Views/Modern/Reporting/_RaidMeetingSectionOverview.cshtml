@model Compass.ViewModels.ModernRaidMeetingReportViewModel
@{
  var h = Model.Headline;
  var r = Model.Reporting.RiskKpis;
  var i = Model.Reporting.IssueKpis;
}
<section class="mr-report-section-panel dfe-f-toggle govuk-!-margin-bottom-3" data-module="dfe-f-toggle" data-mr-section-id="overview" data-mr-section-title="Overview">
  <header class="dfe-f-toggle__title-wrapper">
    <h2 class="dfe-f-toggle__heading">
      <button type="button" class="dfe-f-toggle__button" aria-expanded="true" aria-controls="rr-toggle-overview-content" id="rr-toggle-overview-button">
        <span class="dfe-f-toggle__icon" aria-hidden="true"></span>
        <span class="dfe-f-toggle__title">Overview</span>
        <span class="mr-toggle-panel__meta"><span class="govuk-tag @(h.TotalOpen > 0 ? "govuk-tag--red" : "govuk-tag--grey")">@h.TotalOpen open</span></span>
      </button>
    </h2>
  </header>
  <section id="rr-toggle-overview-content" class="dfe-f-toggle__content">
    <section class="dfe-f-toggle__body govuk-body">
      <p class="govuk-body-s dfe-c-text-muted govuk-!-margin-top-0 govuk-!-margin-bottom-3">
        Headline counts for <strong>@Model.FilterScopeSummary</strong>. Use the sections below for meeting discussion — expand, reorder, and save your layout with Edit view.
      </p>
      <section class="dfe-f-card-grid govuk-!-margin-bottom-4">
        <article class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
          <p class="govuk-body-s dfe-f-stat-card__label">Open risks</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@h.OpenRisks</p>
        </article>
        <article class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
          <p class="govuk-body-s dfe-f-stat-card__label">Open issues</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@h.OpenIssues</p>
        </article>
        <article class="dfe-f-stat-card dfe-f-stat-card--tint-blue">
          <p class="govuk-body-s dfe-f-stat-card__label">Open near misses</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@h.OpenNearMisses</p>
        </article>
        <article class="dfe-f-stat-card dfe-f-stat-card--tint-red">
          <p class="govuk-body-s dfe-f-stat-card__label">High risks (score ≥ 15)</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@h.HighRisks</p>
        </article>
        <article class="dfe-f-stat-card dfe-f-stat-card--tint-red">
          <p class="govuk-body-s dfe-f-stat-card__label">Critical open issues</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@h.OpenCriticalIssues</p>
        </article>
        <article class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
          <p class="govuk-body-s dfe-f-stat-card__label">Risks review overdue</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@h.RisksReviewOverdue</p>
        </article>
        <article class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
          <p class="govuk-body-s dfe-f-stat-card__label">Blocked issues</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@i.BlockedIssues</p>
        </article>
        <article class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
          <p class="govuk-body-s dfe-f-stat-card__label">Avg risk score</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@r.AvgRiskScore.ToString("0.#")</p>
        </article>
      </section>
    </section>
  </section>
</section>
