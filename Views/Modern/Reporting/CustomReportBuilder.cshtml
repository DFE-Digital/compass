@model Compass.ViewModels.Modern.CustomReportBuilderViewModel
@using System.Text.Json
@using Compass.Models
@using Compass.ViewModels.Modern
@{
    var cspNonce = Context.Items["Nonce"]?.ToString() ?? "";
    var isEdit = Model.ReportId.HasValue;
    ViewData["Title"] = isEdit ? $"Edit report — {Model.Name}" : "Create custom report";
    var formAction = isEdit
        ? Url.Action("CustomReportEditPost", "ModernReporting", new { id = Model.ReportId })
        : Url.Action("CustomReportCreatePost", "ModernReporting");
    var jsonOpts = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };

    bool HasError(string field) => ViewData.ModelState[field]?.Errors?.Any() == true;
    string? ErrorMsg(string field) => ViewData.ModelState[field]?.Errors?.FirstOrDefault()?.ErrorMessage;
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernReporting")">Reporting</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("CustomReports", "ModernReporting")">Custom reports</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">@(isEdit ? "Edit" : "Create")</li>
}

@await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
    Title = isEdit ? "Edit report" : "Create custom report",
    BackLinkHref = Url.Action("CustomReports", "ModernReporting"),
    BackLinkText = "Back to custom reports"
})

@if (!ViewData.ModelState.IsValid)
{
<div class="govuk-error-summary" data-module="govuk-error-summary" role="alert">
  <h2 class="govuk-error-summary__title">There is a problem</h2>
  <div class="govuk-error-summary__body">
    <ul class="govuk-list govuk-error-summary__list">
      @foreach (var entry in ViewData.ModelState.Where(e => e.Value?.Errors?.Any() == true))
      {
        @foreach (var error in entry.Value!.Errors)
        {
          <li><a href="#@entry.Key">@error.ErrorMessage</a></li>
        }
      }
    </ul>
  </div>
</div>
}

<form method="post" action="@formAction" id="cr-builder-form" novalidate>
  @Html.AntiForgeryToken()

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <div class="govuk-form-group@(HasError("Name") ? " govuk-form-group--error" : "")">
        <label class="govuk-label govuk-label--m" for="Name">Report name</label>
        @if (HasError("Name"))
        {
        <p id="Name-error" class="govuk-error-message">
          <span class="govuk-visually-hidden">Error:</span> @ErrorMsg("Name")
        </p>
        }
        <input class="govuk-input@(HasError("Name") ? " govuk-input--error" : "")" id="Name" name="name" type="text" value="@Model.Name" maxlength="200"@(HasError("Name") ? " aria-describedby=\"Name-error\"" : "")>
      </div>

      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--m" for="Description">Description</label>
        <div class="govuk-hint">Describe the purpose of this report. This will be visible to others if the report is public.</div>
        <textarea class="govuk-textarea" id="Description" name="description" rows="3" maxlength="2000">@Model.Description</textarea>
      </div>

      <div class="govuk-form-group">
        <fieldset class="govuk-fieldset">
          <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Visibility</legend>
          <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
            <div class="govuk-radios__item">
              <input class="govuk-radios__input" id="visibility-private" name="visibility" type="radio" value="Private" @(Model.Visibility == CustomReportVisibility.Private ? "checked" : "")>
              <label class="govuk-label govuk-radios__label" for="visibility-private">Private — only you can see this report</label>
            </div>
            <div class="govuk-radios__item">
              <input class="govuk-radios__input" id="visibility-public" name="visibility" type="radio" value="Public" @(Model.Visibility == CustomReportVisibility.Public ? "checked" : "")>
              <label class="govuk-label govuk-radios__label" for="visibility-public">Public — all signed-in users can view and duplicate this report</label>
            </div>
          </div>
        </fieldset>
      </div>

      <div class="govuk-form-group">
        <fieldset class="govuk-fieldset">
          <legend class="govuk-fieldset__legend govuk-fieldset__legend--m">Default reporting period</legend>
          <div class="govuk-radios govuk-radios--small" data-module="govuk-radios">
            <div class="govuk-radios__item">
              <input class="govuk-radios__input" id="period-calendar-month" name="reportingPeriod" type="radio" value="calendar-month" @(Model.ReportingPeriod == "calendar-month" ? "checked" : "")>
              <label class="govuk-label govuk-radios__label" for="period-calendar-month">Calendar month</label>
            </div>
          </div>
        </fieldset>
      </div>

    </div>
  </div>

  <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

  <h2 class="govuk-heading-m">Scope</h2>
  <p class="govuk-body">Select the work items and service register entries to include in this report.</p>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-one-half">
      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="cr-work-search">Work items</label>
        <div class="govuk-hint">Search and select work items to include.</div>
        <input class="govuk-input govuk-!-margin-bottom-2" id="cr-work-search" type="text" placeholder="Search work items…" autocomplete="off">
        <div class="cr-scope-list" id="cr-work-list" data-scope="work" style="max-height:280px; overflow-y:auto; border:1px solid #b1b4b6; padding:5px;">
          @foreach (var item in Model.AvailableWorkItems)
          {
          <div class="govuk-checkboxes__item cr-scope-item" data-name="@item.Name.ToLower()">
            <input class="govuk-checkboxes__input cr-scope-checkbox" type="checkbox" id="wi-@item.Id" value="@item.Id" data-scope="work" @(Model.SelectedWorkItemIds.Contains(item.Id) ? "checked" : "")>
            <label class="govuk-label govuk-checkboxes__label" for="wi-@item.Id">
              @item.Name
              @if (!string.IsNullOrWhiteSpace(item.BusinessArea))
              {
              <span class="govuk-hint govuk-!-font-size-14 govuk-!-margin-bottom-0">@item.BusinessArea</span>
              }
            </label>
          </div>
          }
        </div>
        <p class="govuk-body-s govuk-!-margin-top-1"><span id="cr-work-count">@Model.SelectedWorkItemIds.Count</span> selected</p>
      </div>
    </div>
    <div class="govuk-grid-column-one-half">
      <div class="govuk-form-group">
        <label class="govuk-label govuk-label--s" for="cr-sr-search">Service register</label>
        <div class="govuk-hint">Search and select service register entries to include.</div>
        <input class="govuk-input govuk-!-margin-bottom-2" id="cr-sr-search" type="text" placeholder="Search service register…" autocomplete="off">
        <div class="cr-scope-list" id="cr-sr-list" data-scope="sr" style="max-height:280px; overflow-y:auto; border:1px solid #b1b4b6; padding:5px;">
          @foreach (var item in Model.AvailableServiceRegisterItems)
          {
          <div class="govuk-checkboxes__item cr-scope-item" data-name="@item.Name.ToLower()">
            <input class="govuk-checkboxes__input cr-scope-checkbox" type="checkbox" id="sr-@item.Id" value="@item.Id" data-scope="sr" @(Model.SelectedServiceRegisterIds.Contains(item.Id) ? "checked" : "")>
            <label class="govuk-label govuk-checkboxes__label" for="sr-@item.Id">
              @item.Name
              @if (!string.IsNullOrWhiteSpace(item.BusinessArea))
              {
              <span class="govuk-hint govuk-!-font-size-14 govuk-!-margin-bottom-0">@item.BusinessArea</span>
              }
            </label>
          </div>
          }
        </div>
        <p class="govuk-body-s govuk-!-margin-top-1"><span id="cr-sr-count">@Model.SelectedServiceRegisterIds.Count</span> selected</p>
      </div>
    </div>
  </div>

  <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

  <h2 class="govuk-heading-m">Report sections</h2>
  <p class="govuk-body">Add, remove, and reorder the sections that will appear in your report. Drag to reorder.</p>

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-one-half">
      <h3 class="govuk-heading-s">Available sections</h3>
      <div id="cr-available-sections">
        @{
          var addedTypes = new HashSet<string>(Model.Sections.Select(s => s.SectionType));
          var grouped = Model.AvailableSections.GroupBy(s => s.Group);
        }
        @foreach (var group in grouped)
        {
        <details class="govuk-details govuk-!-margin-bottom-2" open>
          <summary class="govuk-details__summary"><span class="govuk-details__summary-text">@group.Key</span></summary>
          <div class="govuk-details__text" style="padding:0;">
            @foreach (var sec in group)
            {
            <div class="cr-available-section-item govuk-!-padding-2" data-sec-type="@sec.SectionType" data-sec-label="@sec.Label" data-sec-group="@sec.Group" style="@(addedTypes.Contains(sec.SectionType) ? "display:none;" : "")border-bottom:1px solid #b1b4b6;">
              <span class="govuk-body-s govuk-!-margin-bottom-0">@sec.Label</span>
              <button type="button" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0 govuk-!-margin-left-2 cr-add-section-btn" style="float:right;font-size:14px;padding:4px 10px;">Add</button>
            </div>
            }
          </div>
        </details>
        }
      </div>
    </div>
    <div class="govuk-grid-column-one-half">
      <h3 class="govuk-heading-s">Report sections (drag to reorder)</h3>
      <div id="cr-active-sections" style="min-height:60px; border:2px dashed #b1b4b6; padding:5px;">
        @foreach (var sec in Model.Sections.OrderBy(s => s.SortOrder))
        {
        <div class="cr-section-item govuk-!-padding-2 govuk-!-margin-bottom-1" draggable="true" data-sec-type="@sec.SectionType" data-sec-label="@sec.Label" data-sec-group="@sec.Group" style="background:#f3f2f1; border:1px solid #b1b4b6; cursor:grab; display:flex; align-items:center; justify-content:space-between;">
          <span class="material-symbols-sharp" style="font-size:18px; margin-right:6px; color:#505a5f;" aria-hidden="true">drag_indicator</span>
          <span class="govuk-body-s govuk-!-margin-bottom-0" style="flex:1;">@sec.Label</span>
          <button type="button" class="govuk-link cr-remove-section" style="font-size:14px; background:none; border:none; cursor:pointer; color:#d4351c;">Remove</button>
        </div>
        }
      </div>
    </div>
  </div>

  <input type="hidden" name="selectedWorkItemIds" id="cr-selected-work-ids" value="@string.Join(",", Model.SelectedWorkItemIds)">
  <input type="hidden" name="selectedServiceRegisterIds" id="cr-selected-sr-ids" value="@string.Join(",", Model.SelectedServiceRegisterIds)">
  <input type="hidden" name="sectionsJson" id="cr-sections-json" value="">

  <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

  <div class="govuk-button-group">
    <button type="submit" class="govuk-button" id="cr-submit-btn">@(isEdit ? "Save report" : "Create report")</button>
    <a class="govuk-link" href="@Url.Action("CustomReports", "ModernReporting")">Cancel</a>
  </div>
</form>

@section Styles {
<style>
.cr-section-item.cr-drag-over {
  border-color: #1d70b8 !important;
  background: #e8f0fe !important;
}
.cr-scope-item { padding: 2px 0; }
.cr-scope-list .govuk-checkboxes__item { min-height: auto; padding-left: 36px; }
.cr-scope-list .govuk-checkboxes__input { top: 2px; }
.cr-scope-list .govuk-checkboxes__label { padding: 2px 10px 2px 6px; }
.cr-scope-list .govuk-checkboxes__label::before { top: 2px; width: 24px; height: 24px; }
.cr-scope-list .govuk-checkboxes__label::after { top: 7px; left: 6px; width: 11px; height: 5px; }
</style>
}

@section Scripts {
<script nonce="@cspNonce">
(function() {
  // Scope search filtering
  function initSearch(searchId, listId, countId, scopeKey) {
    var search = document.getElementById(searchId);
    var list = document.getElementById(listId);
    var countEl = document.getElementById(countId);
    if (!search || !list) return;
    search.addEventListener('input', function() {
      var q = this.value.toLowerCase();
      list.querySelectorAll('.cr-scope-item').forEach(function(item) {
        item.style.display = item.getAttribute('data-name').indexOf(q) >= 0 ? '' : 'none';
      });
    });
    list.addEventListener('change', function() {
      updateScopeCount(scopeKey, countId);
    });
  }

  function updateScopeCount(scopeKey, countId) {
    var checked = document.querySelectorAll('.cr-scope-checkbox[data-scope="' + scopeKey + '"]:checked');
    var el = document.getElementById(countId);
    if (el) el.textContent = checked.length;
  }

  initSearch('cr-work-search', 'cr-work-list', 'cr-work-count', 'work');
  initSearch('cr-sr-search', 'cr-sr-list', 'cr-sr-count', 'sr');

  // Drag and drop for sections
  var container = document.getElementById('cr-active-sections');
  var dragSrc = null;

  container.addEventListener('dragstart', function(e) {
    var item = e.target.closest('.cr-section-item');
    if (!item) return;
    dragSrc = item;
    item.style.opacity = '0.5';
    e.dataTransfer.effectAllowed = 'move';
    e.dataTransfer.setData('text/plain', '');
  });

  container.addEventListener('dragend', function(e) {
    var item = e.target.closest('.cr-section-item');
    if (item) item.style.opacity = '1';
    container.querySelectorAll('.cr-section-item').forEach(function(el) {
      el.classList.remove('cr-drag-over');
    });
  });

  container.addEventListener('dragover', function(e) {
    e.preventDefault();
    e.dataTransfer.dropEffect = 'move';
    var item = e.target.closest('.cr-section-item');
    if (item && item !== dragSrc) {
      container.querySelectorAll('.cr-section-item').forEach(function(el) {
        el.classList.remove('cr-drag-over');
      });
      item.classList.add('cr-drag-over');
    }
  });

  container.addEventListener('drop', function(e) {
    e.preventDefault();
    var item = e.target.closest('.cr-section-item');
    if (item && item !== dragSrc && dragSrc) {
      var rect = item.getBoundingClientRect();
      var midY = rect.top + rect.height / 2;
      if (e.clientY < midY) {
        container.insertBefore(dragSrc, item);
      } else {
        container.insertBefore(dragSrc, item.nextSibling);
      }
    }
    container.querySelectorAll('.cr-section-item').forEach(function(el) {
      el.classList.remove('cr-drag-over');
    });
  });

  // Add section (event delegation)
  document.getElementById('cr-available-sections').addEventListener('click', function(e) {
    var btn = e.target.closest('.cr-add-section-btn');
    if (!btn) return;
    var available = btn.closest('.cr-available-section-item');
    if (!available) return;
    var type = available.getAttribute('data-sec-type');
    var label = available.getAttribute('data-sec-label');
    var group = available.getAttribute('data-sec-group');
    available.style.display = 'none';

    var div = document.createElement('div');
    div.className = 'cr-section-item govuk-!-padding-2 govuk-!-margin-bottom-1';
    div.draggable = true;
    div.setAttribute('data-sec-type', type);
    div.setAttribute('data-sec-label', label);
    div.setAttribute('data-sec-group', group);
    div.style.cssText = 'background:#f3f2f1; border:1px solid #b1b4b6; cursor:grab; display:flex; align-items:center; justify-content:space-between;';
    div.innerHTML = '<span class="material-symbols-sharp" style="font-size:18px; margin-right:6px; color:#505a5f;" aria-hidden="true">drag_indicator</span>'
      + '<span class="govuk-body-s govuk-!-margin-bottom-0" style="flex:1;">' + label + '</span>'
      + '<button type="button" class="govuk-link cr-remove-section" style="font-size:14px; background:none; border:none; cursor:pointer; color:#d4351c;">Remove</button>';

    container.appendChild(div);
  });

  // Remove section (event delegation)
  container.addEventListener('click', function(e) {
    var btn = e.target.closest('.cr-remove-section');
    if (!btn) return;
    var item = btn.closest('.cr-section-item');
    if (!item) return;
    var type = item.getAttribute('data-sec-type');
    item.remove();
    var avail = document.querySelector('.cr-available-section-item[data-sec-type="' + type + '"]');
    if (avail) avail.style.display = '';
  });

  // On submit: serialize hidden fields
  document.getElementById('cr-builder-form').addEventListener('submit', function() {
    var workIds = [];
    document.querySelectorAll('.cr-scope-checkbox[data-scope="work"]:checked').forEach(function(cb) {
      workIds.push(cb.value);
    });
    document.getElementById('cr-selected-work-ids').value = workIds.join(',');

    var srIds = [];
    document.querySelectorAll('.cr-scope-checkbox[data-scope="sr"]:checked').forEach(function(cb) {
      srIds.push(cb.value);
    });
    document.getElementById('cr-selected-sr-ids').value = srIds.join(',');

    var sections = [];
    container.querySelectorAll('.cr-section-item').forEach(function(el, idx) {
      sections.push({
        sectionType: el.getAttribute('data-sec-type'),
        sortOrder: idx,
        isVisible: true
      });
    });
    document.getElementById('cr-sections-json').value = JSON.stringify(sections);
  });
})();
</script>
}
