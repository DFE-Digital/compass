@using Compass.ViewModels
@model IReadOnlyList<MonthlySubmissionLeagueRow>
@{
  var rows = Model ?? Array.Empty<MonthlySubmissionLeagueRow>();
  var toggleIdPrefix = ViewData["ToggleIdPrefix"] as string ?? "msp-group";
  string SubmissionBadgeClass(string status) => status switch
  {
    "Submitted" => "dfe-f-badge dfe-f-badge--small dfe-f-badge--green",
    "Late" => "dfe-f-badge dfe-f-badge--small dfe-f-badge--red",
    "In progress" => "dfe-f-badge dfe-f-badge--small dfe-f-badge--orange",
    _ => "dfe-f-badge dfe-f-badge--small dfe-f-badge--grey"
  };
  string GroupSubmittedBadgeClass(MonthlySubmissionLeagueRow row)
  {
    if (row.TotalToReport == 0) return "dfe-f-badge dfe-f-badge--grey";
    if (row.Submitted >= row.TotalToReport) return "dfe-f-badge dfe-f-badge--green";
    if (row.Submitted > 0) return "dfe-f-badge dfe-f-badge--blue";
    return row.Late > 0 ? "dfe-f-badge dfe-f-badge--red" : "dfe-f-badge dfe-f-badge--grey";
  }
}
@if (rows.Count == 0)
{
  <p class="govuk-body dfe-c-text-muted">No work items in scope for this filter.</p>
}
else
{
  <div class="msp-group-toggles">
    @for (var i = 0; i < rows.Count; i++)
    {
      var row = rows[i];
      var toggleId = $"{toggleIdPrefix}-{i}";
      var contentId = $"{toggleId}-content";
      <div class="dfe-f-toggle govuk-!-margin-bottom-2" data-module="dfe-f-toggle">
        <div class="dfe-f-toggle__title-wrapper">
          <h2 class="dfe-f-toggle__heading">
            <button type="button" class="dfe-f-toggle__button" aria-expanded="false" aria-controls="@contentId" id="@($"{toggleId}-button")">
              <span class="dfe-f-toggle__icon" aria-hidden="true"></span>
              <span class="dfe-f-toggle__title">@row.Name</span>
              <span class="mr-toggle-panel__meta"><span class="@GroupSubmittedBadgeClass(row) msp-group-progress" data-msp-group="@toggleId">@row.Submitted / @row.TotalToReport submitted</span></span>
            </button>
          </h2>
        </div>
        <div id="@contentId" class="dfe-f-toggle__content">
          <div class="dfe-f-toggle__body govuk-body">
            @if (row.WorkItems.Count == 0)
            {
              <p class="govuk-body-s dfe-c-text-muted">No work items in this group.</p>
            }
            else
            {
              <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
                <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed">
                  <caption class="govuk-table__caption govuk-visually-hidden">Work items for @row.Name</caption>
                  <thead class="govuk-table__head">
                    <tr class="govuk-table__row">
                      <th scope="col" class="govuk-table__header">Work item</th>
                      <th scope="col" class="govuk-table__header">Submission status</th>
                      <th scope="col" class="govuk-table__header govuk-table__header--numeric">Submitted date</th>
                    </tr>
                  </thead>
                  <tbody class="govuk-table__body">
                    @foreach (var item in row.WorkItems)
                    {
                      <tr class="govuk-table__row">
                        <td class="govuk-table__cell">
                          <a class="govuk-link govuk-!-font-weight-bold" href="@Url.Content($"~/modern/work/detail/{item.ProjectId}")">@item.Title</a>
                        </td>
                        <td class="govuk-table__cell">
                          <span class="@SubmissionBadgeClass(item.SubmissionStatus)">@item.SubmissionStatus</span>
                        </td>
                        <td class="govuk-table__cell govuk-table__cell--numeric">
                          @(item.SubmittedAt.HasValue ? item.SubmittedAt.Value.ToString("d MMM yyyy") : "—")
                        </td>
                      </tr>
                    }
                  </tbody>
                </table>
              </div>
            }
          </div>
        </div>
      </div>
    }
  </div>
}
