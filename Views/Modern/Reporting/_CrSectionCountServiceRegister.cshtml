@model Compass.ViewModels.Modern.CustomReportViewViewModel
@if (Model.ServiceRegisterItems.Count == 0)
{
<p class="govuk-body">No service register items in scope.</p>
}
else
{
<div class="dfe-f-card-grid govuk-!-margin-bottom-4">
    <div class="dfe-f-stat-card">
        <p class="govuk-body-s dfe-f-stat-card__label">Service register entries</p>
        <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@Model.ServiceRegisterItems.Count</p>
    </div>
</div>
<div class="dfe-f-table-wrapper" data-module="dfe-f-table">
    <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed">
        <thead class="govuk-table__head">
            <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Service</button></th>
                <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Phase</button></th>
                <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Business area</button></th>
                <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Status</button></th>
            </tr>
        </thead>
        <tbody class="govuk-table__body">
            @foreach (var s in Model.ServiceRegisterItems)
            {
            <tr class="govuk-table__row">
                <td class="govuk-table__cell govuk-!-font-weight-bold">@s.Name</td>
                <td class="govuk-table__cell">@(s.Phase ?? "—")</td>
                <td class="govuk-table__cell">@(s.BusinessArea ?? "—")</td>
                <td class="govuk-table__cell">@(s.Status ?? "—")</td>
            </tr>
            }
        </tbody>
    </table>
</div>
}
