@model Compass.ViewModels.Modern.CustomReportViewViewModel
@using Compass.Models.Modern.Work
@{
    var mwDetailPrefix = Url.Content("~/modern/work/detail/") ?? "/modern/work/detail/";
    var totalFte = Model.ResourcingRows.Sum(r => r.PermFte ?? 0);
    var totalMsc = Model.ResourcingRows.Sum(r => r.MspFte ?? 0);
}
@if (Model.ResourcingRows.Count == 0)
{
<p class="govuk-body">No resourcing data available.</p>
}
else
{
<div class="dfe-f-card-grid govuk-!-margin-bottom-4">
    <div class="dfe-f-stat-card">
        <p class="govuk-body-s dfe-f-stat-card__label">Total FTE</p>
        <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@totalFte.ToString("0.##")</p>
    </div>
    <div class="dfe-f-stat-card">
        <p class="govuk-body-s dfe-f-stat-card__label">Total MSC</p>
        <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@totalMsc.ToString("0.##")</p>
    </div>
</div>
<div class="dfe-f-table-wrapper" data-module="dfe-f-table">
    <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed">
        <thead class="govuk-table__head">
            <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Work item</button></th>
                <th scope="col" class="govuk-table__header govuk-table__header--numeric" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">FTE</button></th>
                <th scope="col" class="govuk-table__header govuk-table__header--numeric" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">MSC</button></th>
                <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Business area</button></th>
            </tr>
        </thead>
        <tbody class="govuk-table__body">
            @foreach (var r in Model.ResourcingRows)
            {
            <tr class="govuk-table__row">
                <td class="govuk-table__cell"><a class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold" href="@(mwDetailPrefix)@r.ProjectId">@r.Title</a></td>
                <td class="govuk-table__cell govuk-table__cell--numeric">@(r.PermFte?.ToString("0.##") ?? "—")</td>
                <td class="govuk-table__cell govuk-table__cell--numeric">@(r.MspFte?.ToString("0.##") ?? "—")</td>
                <td class="govuk-table__cell">@(r.BusinessArea ?? "—")</td>
            </tr>
            }
        </tbody>
    </table>
</div>
}
