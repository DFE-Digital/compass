@model Compass.ViewModels.Modern.ReportingTableExportBarModel
@if (Model.ShowExport && !string.IsNullOrEmpty(Model.ExportUrl))
{
  <div class="mr-table-export-bar" role="toolbar" aria-label="@(string.IsNullOrEmpty(Model.Caption) ? "Table actions" : $"{Model.Caption} — actions")">
    <div class="mr-table-export-bar__info">
      @if (!string.IsNullOrEmpty(Model.Caption))
      {
        <span class="mr-table-export-bar__caption govuk-body-s govuk-!-font-weight-bold">@Model.Caption</span>
      }
      @if (Model.Count is > 0)
      {
        <span class="mr-table-export-bar__count govuk-body-s dfe-c-text-muted">@Model.Count.Value work item@(Model.Count.Value == 1 ? "" : "s")</span>
      }
      <span class="mr-table-export-bar__hint govuk-body-s dfe-c-text-muted">Includes Work, Milestones, Updates, Risks, Issues, Assumptions, Decisions, Near misses, Accessibility</span>
    </div>
    <div class="mr-table-export-bar__actions">
      <a href="@Model.ExportUrl"
         class="govuk-button mr-table-export-bar__export govuk-!-margin-bottom-0"
         data-report-download
         data-generating-modal-title="Generating work export">
        Export workbook
      </a>
    </div>
  </div>
}
