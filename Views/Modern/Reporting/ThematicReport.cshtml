@model Compass.ViewModels.Modern.ModernThematicReportViewModel
@using Compass.ViewModels.Modern
@{
  ViewData["Title"] = "Thematic report";
  var m = Model;
  var baProjectsDict = m.DashboardRows.ToDictionary(r => r.BusinessArea, r => r.Projects);
  baProjectsDict["theme|Total"] = m.DashboardRows
    .SelectMany(r => r.Projects)
    .GroupBy(p => p.Id)
    .Select(g => g.First())
    .ToList();
  var mwDetailPrefix = Url.Content("~/modern/work/detail/") ?? "/modern/work/detail/";
  var drillExportUrl = Url.Action("ExportDrilldown", "ModernReporting", new { source = "thematic" }) ?? "";
  var drillScriptModel = ReportingDrilldownConfig.Build(
    baProjectsDict,
    m.ScopeProjectItems,
    drillExportUrl,
    new Dictionary<string, string?> { ["source"] = "thematic", ["dimension"] = "theme" },
    mwDetailPrefix,
    new Dictionary<string, string> { ["theme"] = "Theme" },
    ".thematic-report");
}

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernReporting")">Reporting</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">Thematic report</li>
}

<div class="mr-dash thematic-report">
  @{
    var lede = await Html.PartialAsync("_GovukBodyParagraph", $"Summarise delivery work by thematic tag for {m.MonthName}. Click a number to view matching work items.");
  }
  @await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
    Caption = "Reporting",
    Title = "Thematic report",
    Lede = lede
  })

  <section class="govuk-!-margin-bottom-6" aria-labelledby="thematic-summary-heading">
    <h2 id="thematic-summary-heading" class="govuk-heading-m">Delivery work by theme</h2>
    @if (!m.DashboardRows.Any())
    {
      <p class="govuk-body">No thematic tags defined. Add tags in Admin → Work → Thematic tags.</p>
    }
    else
    {
      @await Html.PartialAsync("_PrioritiesReportGroupSummaryTable", new PrioritiesReportGroupSummaryViewModel {
        Dimension = "theme",
        GroupColumnLabel = "Theme",
        Rows = m.DashboardRows.ToList(),
        TableId = "thematic-dashboard-table"
      })
      @await Html.PartialAsync("_ReportingDrilldownPanel")
      @await Html.PartialAsync("_ReportingWorkItemModal")
    }
  </section>
</div>

@section Styles {
  @await Html.PartialAsync("_MrReportCoreStyles")
  <link rel="stylesheet" href="@Url.Content("~/modern/css/reporting-drilldown.css")" asp-append-version="true" />
}

@section Scripts {
  @await Html.PartialAsync("_ReportingDrilldownScripts", drillScriptModel)
}
