@using System.Text.Json
@using System.Text.Json.Serialization
@using System.Linq
@using Compass.Models
@model Compass.ViewModels.ModernRaidReportingViewModel
@{
  ViewData["Title"] = "RAID reporting";
  var m = Model ?? new ModernRaidReportingViewModel();
  var curTab = string.IsNullOrWhiteSpace(m.ActiveTab) ? "risks" : m.ActiveTab;
  var riTab = string.IsNullOrWhiteSpace(m.RiskIntelTab) ? "patterns" : m.RiskIntelTab;
  string? RiskIntelForTabLink(string t) => t == "risks" ? (curTab == "risks" ? riTab : "patterns") : null;
  string? RiskIntelQueryForRaidUrl() => curTab == "risks" ? riTab : null;
  string RaidRiskIntelUrl(string intel) =>
      Url.Action("Raid", "ModernReporting", new { tab = "risks", riskIntel = intel, businessAreaId = m.FilterBusinessAreaId, directorateId = m.FilterDirectorateId }) ?? "";
  string RaidTabUrl(string tab) =>
      Url.Action("Raid", "ModernReporting", new { tab, riskIntel = RiskIntelForTabLink(tab), businessAreaId = m.FilterBusinessAreaId, directorateId = m.FilterDirectorateId }) ?? "";
  string IntelFilterUrl(int? businessAreaId, int? directorateId) =>
      Url.Action("Raid", "ModernReporting", new { tab = "intelligence", businessAreaId, directorateId }) ?? "";
  // Removable filter chips (monthly + work register pattern; BA / directorate only for RAID)
  var raidPageFilterChips = new List<SearchAndFilterActiveChip>();
  if (m.FilterBusinessAreaId is { } raidBa)
  {
    var bn = m.BusinessAreaFilterOptions.FirstOrDefault(o => o.Id == raidBa)?.Name;
    if (!string.IsNullOrWhiteSpace(bn))
    {
      var u = Url.Action("Raid", "ModernReporting", new { tab = curTab, riskIntel = RiskIntelQueryForRaidUrl(), businessAreaId = (int?)null, directorateId = m.FilterDirectorateId }) ?? "#";
      raidPageFilterChips.Add(new SearchAndFilterActiveChip("Business area", bn, u));
    }
  }
  if (m.FilterDirectorateId is { } raidDir)
  {
    var dn = m.DirectorateFilterOptions.FirstOrDefault(o => o.Id == raidDir)?.Name;
    if (!string.IsNullOrWhiteSpace(dn))
    {
      var u = Url.Action("Raid", "ModernReporting", new { tab = curTab, riskIntel = RiskIntelQueryForRaidUrl(), businessAreaId = m.FilterBusinessAreaId, directorateId = (int?)null }) ?? "#";
      raidPageFilterChips.Add(new SearchAndFilterActiveChip("Directorate", dn, u));
    }
  }
  var jsonOpts = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase, DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull };
  var trendLabelsJson = JsonSerializer.Serialize(m.TrendMonthLabels, jsonOpts);
  var newRisksJson = JsonSerializer.Serialize(m.TrendNewRisksPerMonth, jsonOpts);
  var avgRiskJson = JsonSerializer.Serialize(m.TrendAvgRiskScoreNewPerMonth, jsonOpts);
  var newIssuesJson = JsonSerializer.Serialize(m.TrendNewIssuesPerMonth, jsonOpts);
  var sevSeries = m.TrendNewIssuesBySeveritySeries
    .Select(kv => new { label = kv.Key, data = kv.Value })
    .ToList();
  var sevSeriesJson = JsonSerializer.Serialize(sevSeries, jsonOpts);
  var riskBucketJson = JsonSerializer.Serialize(m.RiskScoreBucketCounts, jsonOpts);
  var issueSevJson = JsonSerializer.Serialize(m.OpenIssueSeverityCounts, jsonOpts);
  var riskStatusChgJson = JsonSerializer.Serialize(m.RiskStatusChangesPerMonth, jsonOpts);
  var issueStatusChgJson = JsonSerializer.Serialize(m.IssueStatusChangesPerMonth, jsonOpts);
  string[] ageBucketOrder = ["0–7 days", "8–30 days", "31–90 days", "91–180 days", "181+ days"];
  int BarMax(System.Collections.Generic.IReadOnlyDictionary<string, int> d) => d.Count == 0 ? 1 : d.Values.Max();
  var weakMitigationMatCount = m.MaterialisedRows.Count(x => x.MitigationTag != "YES");
  var maxIssueCell = m.IssuePrioritySeverityGrid.Length == 0
    ? 0
    : m.IssuePrioritySeverityGrid.Max(row => row.Length == 0 ? 0 : row.Max());
  /* Same 5×5 banding and axis labels as <see cref="ModernRaidDashboardViewModel" /> / RAID dashboard (impact × likelihood). */
  var raidMxLikLabels = new[] { "Very unlikely", "Unlikely", "Possible", "Likely", "Very likely" };
  var raidMxImpLabels = new[] { "Negligible", "Marginal", "Moderate", "Critical", "Crisis" };
  int RaidOpenCountAt(int impact, int likelihood) =>
    m.RiskLikelihoodImpactGrid[5 - likelihood][impact - 1];
  string RaidMxDataTone(int impact, int likelihood)
  {
    var c = RaidOpenCountAt(impact, likelihood);
    if (c == 0) return "z";
    var score = impact * likelihood;
    if (score >= 20) return "r";
    if (score >= 15) return "ar";
    if (score >= 8) return "ag";
    return "g";
  }
  string RaidMxCellBg(string dataTone) => dataTone switch
  {
    "z" => "#f3f2f1",
    "r" => "#c00",
    "ar" => "#e0761e",
    "ag" => "#f5e6c8",
    _ => "#dceedd"
  };
  string RaidMxCellFg(string dataTone) => dataTone == "z" ? "#b1b4b6" : (dataTone is "r" or "ar") ? "#fff" : "#0b0c0c";
  string IssueCellStyle(int c)
  {
    if (c == 0) return "background:#f3f2f1;color:#b1b4b6;";
    var t = maxIssueCell == 0 ? 0.5 : (double)c / maxIssueCell;
    var alpha = 0.08 + t * 0.62;
    return $"background:rgba(29,112,184,{alpha:F3});color:#0b0c0c;font-weight:600;";
  }
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernReporting")">Reporting</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">RAID</li>
}

<div class="mr-dash raid-report">
 <div class="dfe-c-page-title" style="margin-bottom:0.75rem;">
 <div class="dfe-c-page-title__caption">Reporting</div>
 <h1 class="dfe-c-page-title__heading">RAID reporting</h1>
 <p class="dfe-c-body dfe-c-text-muted" style="margin:0;">High-level posture for risks and issues across DDT — use the tabs to switch view. Figures are live from the RAID registers.</p>
  </div>

  @if (TempData["ErrorMessage"] is string err)
  {
 <div class="dfe-c-error-summary" role="alert" style="margin-bottom:1rem;">
 <p class="dfe-c-body" style="margin:0;">@err</p>
    </div>
  }

@* Same compact filter row as <c>MonthlyUpdate</c> (mr-toolbar + get form + BA / directorate) — not the work <c>filter-toolbar</c> pattern. *@
 <div class="mr-toolbar mr-toolbar--compact">
 <div class="mr-toolbar__row">
 <div class="mr-toolbar__nav mr-toolbar__nav--compact">
 <span class="mr-toolbar__period">@if (m.FilterBusinessAreaId == null && m.FilterDirectorateId == null) { @m.FilterScopeSummary } else { <text>Selected: @m.FilterScopeSummary</text> }<span class="dfe-c-text-muted"> · DDT RAID registers</span></span>
      </div>
 <form method="get" action="@Url.Action("Raid", "ModernReporting")" class="mr-toolbar__filters mr-toolbar__filters--compact" id="raid-mr-filters" data-page-loading>
 <input type="hidden" name="tab" value="@curTab" />
 @if (curTab == "risks")
 {
 <input type="hidden" name="riskIntel" value="@riTab" />
 }
 <select name="businessAreaId" class="govuk-select" id="raid-filter-business-area" aria-label="Business area">
 <option value="">All areas</option>
 @foreach (var o in m.BusinessAreaFilterOptions)
 {
   if (m.FilterBusinessAreaId == o.Id) { <option value="@o.Id" selected>@o.Name</option> }
   else { <option value="@o.Id">@o.Name</option> }
 }
        </select>
 <select name="directorateId" class="govuk-select" id="raid-filter-directorate" aria-label="Directorate">
 <option value="">All directorates</option>
 @foreach (var o in m.DirectorateFilterOptions)
 {
   if (m.FilterDirectorateId == o.Id) { <option value="@o.Id" selected>@o.Name</option> }
   else { <option value="@o.Id">@o.Name</option> }
 }
        </select>
 <button type="submit" class="govuk-button govuk-!-margin-bottom-0" id="raid-filter-apply">Apply</button>
      </form>
    </div>
  </div>

@await Html.PartialAsync("~/Views/Modern/Shared/_FilterActiveChips.cshtml", raidPageFilterChips)

 <div class="tabs mr-report-tabs" role="tablist" aria-label="RAID reporting views">
 <a href="@RaidTabUrl("risks")" class="tab @(curTab == "risks" ? "on" : "")" role="tab" aria-selected="@(curTab == "risks")">Risks</a>
 <a href="@RaidTabUrl("issues")" class="tab @(curTab == "issues" ? "on" : "")" role="tab" aria-selected="@(curTab == "issues")">Issues</a>
 <a href="@RaidTabUrl("intelligence")" class="tab @(curTab == "intelligence" ? "on" : "")" role="tab" aria-selected="@(curTab == "intelligence")">Intelligence</a>
  </div>

 <div id="raid-report-panels">

  @if (curTab == "intelligence")
  {
 var intel = m.Intel;
 var intelBaByName = m.BusinessAreaFilterOptions
   .GroupBy(o => o.Name, StringComparer.OrdinalIgnoreCase)
   .ToDictionary(g => g.Key, g => g.First().Id, StringComparer.OrdinalIgnoreCase);
 var intelDirByName = m.DirectorateFilterOptions
   .GroupBy(o => o.Name, StringComparer.OrdinalIgnoreCase)
   .ToDictionary(g => g.Key, g => g.First().Id, StringComparer.OrdinalIgnoreCase);
 <div class="raid-tab-panel raid-intel-panel raid-intel-panel--wide" role="tabpanel">
 <section class="mr-section raid-intel-section" aria-labelledby="raid-intel-title">
 <h2 id="raid-intel-title" class="mr-section__heading">Portfolio intelligence</h2>
 <p class="dfe-c-body dfe-c-text-muted govuk-!-margin-bottom-3">Where load concentrates, what to tackle first, and what has gone quiet. Use the same scope controls as the monthly report to limit by business area and directorate. In hotspot tables, a name is a link when it matches a filter option — it applies that scope.</p>

 @if (intel.NarrativeBullets.Count > 0)
 {
 <div class="dfe-c-callout dfe-c-callout--info dfe-c-mb-4">
 <div class="dfe-c-callout__heading">At a glance</div>
 <ul class="dfe-c-body-s" style="margin:0;padding-left:1.25rem;">
 @foreach (var b in intel.NarrativeBullets)
 {
 <li style="margin-bottom:0.35rem;">@b</li>
 }
 </ul>
 </div>
 }

@* Match risk tab + monthly report: <c>dfe-c-card-grid</c> + <c>dfe-c-metric</c> (compass2-app). *@
 <div class="dfe-c-card-grid dfe-c-mb-4" role="region" aria-label="Open register summary">
 <div class="dfe-c-metric">
 <div class="dfe-c-metric__number">@m.RiskKpis.OpenRisks.ToString("N0")</div>
 <div class="dfe-c-metric__label">Open risks <span class="dfe-c-tag dfe-c-tag--light-grey" style="font-size:0.7rem;vertical-align:middle;">Register</span></div>
 </div>
 <div class="dfe-c-metric dfe-c-metric--amber">
 <div class="dfe-c-metric__number">@m.RiskKpis.HighRiskScoreCount.ToString("N0")</div>
 <div class="dfe-c-metric__label">Risk score ≥ 15 <span class="dfe-c-tag dfe-c-tag--red" style="font-size:0.7rem;vertical-align:middle;">Elevated</span></div>
 </div>
 <div class="dfe-c-metric">
 <div class="dfe-c-metric__number">@m.IssueKpis.OpenIssues.ToString("N0")</div>
 <div class="dfe-c-metric__label">Open issues <span class="dfe-c-tag dfe-c-tag--blue" style="font-size:0.7rem;vertical-align:middle;">Delivery</span></div>
 </div>
 <div class="dfe-c-metric dfe-c-metric--red">
 <div class="dfe-c-metric__number">@m.IssueKpis.BlockedIssues.ToString("N0")</div>
 <div class="dfe-c-metric__label">Blocked issues</div>
 </div>
 <div class="dfe-c-metric dfe-c-metric--grey">
 <div class="dfe-c-metric__number">@((intel.StaleRisks.Count + intel.StaleIssues.Count).ToString("N0"))</div>
 <div class="dfe-c-metric__label">No update 90+ days (risks + issues)</div>
 </div>
 </div>

 <div class="mr-report-section-panel raid-intel-toggle dfe-c-collapsible dfe-c-collapsible--open govuk-!-margin-bottom-3">
 <button type="button" class="dfe-c-collapsible__trigger" aria-expanded="true">
 <span class="dfe-c-collapsible__icon" aria-hidden="true">−</span>
 <span>Hotspots by business area</span>
 <span class="dfe-c-collapsible__status">@if (intel.BusinessAreaHotspots.Count > 0) { <span class="govuk-tag govuk-tag--blue">@intel.BusinessAreaHotspots.Count</span> }</span>
      </button>
 <div class="dfe-c-collapsible__body">
 @if (intel.BusinessAreaHotspots.Count == 0)
 {<p class="dfe-c-body-s dfe-c-text-muted">No tagged business areas in this scope.</p>}
 else
 {
 <p class="dfe-c-body-s dfe-c-text-muted govuk-!-margin-bottom-2">Heat combines volume, elevated scores, max-impact risks, and blocked issues. Click a name to filter this page to that area (when it matches a business area in the list).</p>
 <div class="raid-intel-table-x">
 <div class="dfe-c-table-wrap">
 <table class="mr-ba-table mr-ba-table--intel-wide">
 <caption class="govuk-visually-hidden">Risk and issue counts by business area</caption>
 <thead>
 <tr>
 <th scope="col" class="mr-ba-table__fixed mr-ba-table__area-col">Area</th>
 <th scope="col" class="mr-ba-table__num-hdr">Risks</th>
 <th scope="col" class="mr-ba-table__num-hdr">Issues</th>
 <th scope="col" class="mr-ba-table__num-hdr">≥15</th>
 <th scope="col" class="mr-ba-table__num-hdr">Impact 5</th>
 <th scope="col" class="mr-ba-table__num-hdr">Heat</th>
 </tr>
 </thead>
 <tbody>
 @foreach (var h in intel.BusinessAreaHotspots)
 {
   var uBa = intelBaByName.TryGetValue(h.Label, out var baId) ? IntelFilterUrl(baId, m.FilterDirectorateId) : null;
 <tr data-raid-filter-row data-raid-filter-text="@h.Label @h.Rationale">
 <th scope="row" class="mr-ba-table__fixed mr-ba-table__area-col">@if (uBa != null) { <a class="dfe-c-link" href="@uBa" title="Filter to this business area">@h.Label</a> } else { @h.Label }<div class="dfe-c-body-s dfe-c-text-muted" style="font-weight:400;margin-top:0.2rem;">@h.Rationale</div></th>
 <td class="mr-ba-table__num"><span class="mr-ba-num @(h.OpenRisks > 0 ? "mr-ba-num--highlight" : "mr-ba-num--muted")">@h.OpenRisks.ToString("N0")</span></td>
 <td class="mr-ba-table__num"><span class="mr-ba-num @(h.OpenIssues > 0 ? "mr-ba-num--highlight" : "mr-ba-num--muted")">@h.OpenIssues.ToString("N0")</span></td>
 <td class="mr-ba-table__num"><span class="mr-ba-num @(h.HighScoreRisks > 0 ? "mr-ba-num--warn" : "mr-ba-num--muted")">@h.HighScoreRisks.ToString("N0")</span></td>
 <td class="mr-ba-table__num"><span class="mr-ba-num @(h.MaxImpactRisks > 0 ? "mr-ba-num--rag-red" : "mr-ba-num--muted")">@h.MaxImpactRisks.ToString("N0")</span></td>
 <td class="mr-ba-table__num"><span class="mr-ba-num mr-ba-num--strong">@h.HeatScore.ToString("N0")</span></td>
 </tr>
 }
 </tbody>
 </table>
 </div>
 </div>
 }
 </div>
 </div>

 <div class="mr-report-section-panel raid-intel-toggle dfe-c-collapsible dfe-c-collapsible--open govuk-!-margin-bottom-3">
 <button type="button" class="dfe-c-collapsible__trigger" aria-expanded="true">
 <span class="dfe-c-collapsible__icon" aria-hidden="true">−</span>
 <span>Hotspots by directorate</span>
 <span class="dfe-c-collapsible__status">@if (intel.DivisionHotspots.Count > 0) { <span class="govuk-tag govuk-tag--grey">@intel.DivisionHotspots.Count</span> }</span>
      </button>
 <div class="dfe-c-collapsible__body">
 @if (intel.DivisionHotspots.Count == 0)
 {<p class="dfe-c-body-s dfe-c-text-muted">No directorate (division) tags in this scope.</p>}
 else
 {
 <p class="dfe-c-body-s dfe-c-text-muted govuk-!-margin-bottom-2">Click a name to filter to that directorate when it matches a directorate in the list.</p>
 <div class="raid-intel-table-x">
 <div class="dfe-c-table-wrap">
 <table class="mr-ba-table mr-ba-table--intel-wide">
 <caption class="govuk-visually-hidden">Counts by directorate</caption>
 <thead>
 <tr>
 <th scope="col" class="mr-ba-table__fixed mr-ba-table__area-col">Directorate</th>
 <th scope="col" class="mr-ba-table__num-hdr">Risks</th>
 <th scope="col" class="mr-ba-table__num-hdr">Issues</th>
 <th scope="col" class="mr-ba-table__num-hdr">Heat</th>
 </tr>
 </thead>
 <tbody>
 @foreach (var h in intel.DivisionHotspots)
 {
   var uD = intelDirByName.TryGetValue(h.Label, out var dId) ? IntelFilterUrl(m.FilterBusinessAreaId, dId) : null;
 <tr data-raid-filter-row data-raid-filter-text="@h.Label">
 <th scope="row" class="mr-ba-table__fixed mr-ba-table__area-col">@if (uD != null) { <a class="dfe-c-link" href="@uD" title="Filter to this directorate">@h.Label</a> } else { @h.Label }</th>
 <td class="mr-ba-table__num"><span class="mr-ba-num @(h.OpenRisks > 0 ? "mr-ba-num--highlight" : "mr-ba-num--muted")">@h.OpenRisks.ToString("N0")</span></td>
 <td class="mr-ba-table__num"><span class="mr-ba-num @(h.OpenIssues > 0 ? "mr-ba-num--highlight" : "mr-ba-num--muted")">@h.OpenIssues.ToString("N0")</span></td>
 <td class="mr-ba-table__num"><span class="mr-ba-num mr-ba-num--strong">@h.HeatScore.ToString("N0")</span></td>
 </tr>
 }
 </tbody>
 </table>
 </div>
 </div>
 }
 </div>
 </div>

 <div class="mr-report-section-panel raid-intel-toggle dfe-c-collapsible dfe-c-collapsible--open govuk-!-margin-bottom-3">
 <button type="button" class="dfe-c-collapsible__trigger" aria-expanded="true">
 <span class="dfe-c-collapsible__icon" aria-hidden="true">−</span>
 <span>Prioritise for attention</span>
 <span class="dfe-c-collapsible__status">
 <span class="govuk-tag govuk-tag--red">@intel.FocusRisks.Count R</span>
 <span class="govuk-tag govuk-tag--blue">@intel.FocusIssues.Count I</span>
 </span>
      </button>
 <div class="dfe-c-collapsible__body">
 <div class="raid-intel-prioritise-stack">
 <div>
 <h3 class="mr-section__heading" style="font-size:1.125rem;">Risks</h3>
 <p class="dfe-c-body-s dfe-c-text-muted govuk-!-margin-bottom-2">Score, impact, age, review dates, and stagnation.</p>
 @if (intel.FocusRisks.Count == 0)
 {<p class="dfe-c-body-s dfe-c-text-muted">No open risks in this scope.</p>}
 else
 {
 <div class="raid-intel-table-x">
 <div class="dfe-c-table-wrap">
 <table class="mr-change-tbl mr-change-tbl--intel">
 <caption class="govuk-visually-hidden">Prioritised risks</caption>
 <thead>
 <tr>
 <th scope="col">Risk</th>
 <th scope="col" style="text-align:right;width:5rem;">Score</th>
 <th scope="col" style="text-align:right;width:6rem;">Days open</th>
 <th scope="col">Why it matters</th>
 </tr>
 </thead>
 <tbody>
 @foreach (var r in intel.FocusRisks)
 {
 <tr class="@(r.ReviewOverdue ? "raid-intel-row-warn" : "")" data-raid-filter-row data-raid-filter-text="@r.Title @r.ReferenceLabel @r.Insight">
 <td><a class="dfe-c-link" href="@Url.Action("RiskDetail", "ModernRaid", new { id = r.Id })">@r.Title</a><span class="dfe-c-body-s dfe-c-text-muted" style="display:block;margin-top:0.2rem;">@r.ReferenceLabel</span></td>
 <td style="text-align:right;white-space:nowrap;">@if (r.RiskScore >= 15) { <span class="dfe-c-tag dfe-c-tag--red" style="margin-right:0.25rem;">@r.RiskScore</span> } else { <span class="mr-ba-num">@r.RiskScore</span> }</td>
 <td style="text-align:right;"><span class="mr-ba-num">@r.DaysOpen.ToString("N0")</span></td>
 <td class="dfe-c-body-s">@r.Insight</td>
 </tr>
 }
 </tbody>
 </table>
 </div>
 </div>
 }
 </div>
 <div>
 <h3 class="mr-section__heading" style="font-size:1.125rem;">Issues</h3>
 <p class="dfe-c-body-s dfe-c-text-muted govuk-!-margin-bottom-2">Blocked items and severe tiers rise to the top.</p>
 @if (intel.FocusIssues.Count == 0)
 {<p class="dfe-c-body-s dfe-c-text-muted">No open issues in this scope.</p>}
 else
 {
 <div class="raid-intel-table-x">
 <div class="dfe-c-table-wrap">
 <table class="mr-change-tbl mr-change-tbl--intel">
 <caption class="govuk-visually-hidden">Prioritised issues</caption>
 <thead>
 <tr>
 <th scope="col">Issue</th>
 <th scope="col">Severity</th>
 <th scope="col" style="text-align:right;width:6rem;">Days open</th>
 <th scope="col">Why it matters</th>
 </tr>
 </thead>
 <tbody>
 @foreach (var i in intel.FocusIssues)
 {
 <tr class="@(i.Blocked ? "raid-intel-row-warn" : "")" data-raid-filter-row data-raid-filter-text="@i.Title @i.ReferenceLabel @i.SeverityLabel @i.Insight">
 <td><a class="dfe-c-link" href="@Url.Action("IssueDetail", "ModernRaid", new { id = i.Id })">@i.Title</a><span class="dfe-c-body-s dfe-c-text-muted" style="display:block;margin-top:0.2rem;">@i.ReferenceLabel</span></td>
 <td><span class="dfe-c-tag dfe-c-tag--light-grey" style="margin-right:0.25rem;">@i.SeverityLabel</span>@if (i.Blocked) { <span class="dfe-c-tag dfe-c-tag--red">Blocked</span> }</td>
 <td style="text-align:right;"><span class="mr-ba-num">@i.DaysOpen.ToString("N0")</span></td>
 <td class="dfe-c-body-s">@i.Insight</td>
 </tr>
 }
 </tbody>
 </table>
 </div>
 </div>
 }
 </div>
 </div>
 </div>
 </div>

 <div class="mr-report-section-panel raid-intel-toggle dfe-c-collapsible dfe-c-collapsible--open govuk-!-margin-bottom-3">
 <button type="button" class="dfe-c-collapsible__trigger" aria-expanded="true">
 <span class="dfe-c-collapsible__icon" aria-hidden="true">−</span>
 <span>RAID hygiene</span>
 <span class="dfe-c-collapsible__status">
 <span class="govuk-tag govuk-tag--grey">@intel.StaleRisks.Count R · @intel.StaleIssues.Count I stale</span>
 </span>
      </button>
 <div class="dfe-c-collapsible__body">
 <div class="raid-intel-hygiene-stack">
 <section class="raid-intel-hygiene-block" aria-labelledby="raid-h1-stale">
 <h3 class="govuk-heading-s" id="raid-h1-stale">No update in 90+ days</h3>
 <p class="govuk-body-s govuk-!-margin-bottom-2">Open risks and issues with no recorded update for 90+ days (top 10 of each in this scope).</p>
