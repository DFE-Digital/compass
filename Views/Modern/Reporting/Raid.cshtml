 <div class="dfe-c-mb-4" id="raid-rpt-matrix-report" role="region" aria-labelledby="raid-hm-risk-title" aria-describedby="raid-hm-risk-desc">
 <div class="dfe-c-section-header dfe-c-mb-2">
 <h2 id="raid-hm-risk-title" class="govuk-heading-m govuk-!-margin-bottom-0">Inherent risk matrix (open)</h2>
 </div>
 <p id="raid-hm-risk-desc" class="dfe-c-body-s dfe-c-text-muted govuk-!-margin-bottom-3">Impact × likelihood for open risks in this scope, matching the main RAID dashboard layout. Colours are risk bands (score = impact × likelihood), not a relative heat scale.</p>
 <ul class="raid-matrix-legend" aria-label="Inherent risk band legend">
 <li class="raid-matrix-legend__item">
 <span class="raid-matrix-legend__swatch" style="background:#c00;" aria-hidden="true"></span>
 <span><span class="govuk-visually-hidden">Band: </span>Highest (20–25)</span>
 </li>
 <li class="raid-matrix-legend__item">
 <span class="raid-matrix-legend__swatch" style="background:#e0761e;" aria-hidden="true"></span>
 <span><span class="govuk-visually-hidden">Band: </span>Elevated (15–16)</span>
 </li>
 <li class="raid-matrix-legend__item">
 <span class="raid-matrix-legend__swatch" style="background:#f5e6c8;" aria-hidden="true"></span>
 <span><span class="govuk-visually-hidden">Band: </span>Medium (8–12)</span>
 </li>
 <li class="raid-matrix-legend__item">
 <span class="raid-matrix-legend__swatch" style="background:#dceedd;opacity:0.85;" aria-hidden="true"></span>
 <span><span class="govuk-visually-hidden">Band: </span>Lower (1–7)</span>
 </li>
 </ul>
 <div class="dfe-c-table-wrap raid-matrix-wrap raid-matrix-wrap--heatmap" style="min-width:0;">
 <div class="raid-matrix-scroll">
 <table class="raid-report-risk-matrix" aria-label="Open risk counts by impact and likelihood">
 <caption class="govuk-visually-hidden">Open risk counts by impact (rows) and likelihood (columns). Zero counts show as a dash.</caption>
 <thead>
 <tr>
 <th class="raid-matrix-corner" scope="col" id="raid-rpt-mx-corner">Impact (rows) <span aria-hidden="true">→</span>
 <span class="govuk-visually-hidden">, columns are likelihood: </span>
 <span class="raid-report-risk-matrix__corner-sub" aria-hidden="true"> / </span>
 <span class="raid-report-risk-matrix__corner-sub">Likelihood (columns) <span aria-hidden="true">→</span></span>
 </th>
 @for (var lh = 0; lh < 5; lh++)
 {
 <th class="raid-matrix-metric" scope="col" id="raid-rpt-mx-lik-@lh" style="text-align:center;">@raidMxLikLabels[lh]</th>
 }
 <th class="raid-matrix-metric raid-matrix-metric--total" scope="col" style="text-align:center;">Total</th>
 </tr>
 </thead>
 <tbody>
 @{
   var rptRkColSum = new int[5];
 }
 @for (var impactIdx = 0; impactIdx < 5; impactIdx++)
 {
   var impactRating = 5 - impactIdx;
   var impLabel = raidMxImpLabels[impactRating - 1];
   var rowSum = 0;
 <tr>
 <th class="raid-matrix-corner" scope="row" id="raid-rpt-mx-imp-@impactIdx" style="background:var(--grey-1);">@impLabel</th>
 @for (var colIdx = 0; colIdx < 5; colIdx++)
 {
   var likRating = colIdx + 1;
   var c = RaidOpenCountAt(impactRating, likRating);
   rptRkColSum[colIdx] += c;
   rowSum += c;
   var ton = RaidMxDataTone(impactRating, likRating);
   var bg = RaidMxCellBg(ton);
   var fg = RaidMxCellFg(ton);
   var visHdr = $"raid-rpt-mx-imp-{impactIdx} raid-rpt-mx-lik-{colIdx}";
 <td class="raid-matrix-metric @(ton == "z" ? "raid-matrix-metric--empty" : null)" style="text-align:center;background:@bg;color:@fg;" headers="@visHdr">
 @if (c == 0)
 {
 <span class="raid-matrix-empty" aria-hidden="true">—</span>
 <span class="govuk-visually-hidden">0 open risks, @impLabel impact, @raidMxLikLabels[colIdx] likelihood</span>
 }
 else
 {
 <span class="raid-report-risk-matrix__count">@c</span>
 <span class="govuk-visually-hidden">@c open risk@(c == 1 ? "" : "s") at @impLabel impact, @raidMxLikLabels[colIdx] likelihood</span>
 }
 </td>
 }
 <td class="raid-matrix-metric raid-matrix-metric--total" style="text-align:center;background:#f4f4f4;"><strong>@rowSum</strong></td>
 </tr>
 }
 <tr>
 <th class="raid-matrix-corner" scope="row" id="raid-rpt-mx-total-row" style="background:var(--grey-1);">Total</th>
 @for (var ii = 0; ii < 5; ii++)
 {
 <td class="raid-matrix-metric raid-matrix-metric--total" style="text-align:center;background:#f4f4f4;"><strong>@rptRkColSum[ii]</strong></td>
 }
 <td class="raid-matrix-metric raid-matrix-metric--total" style="text-align:center;background:#e8e8e8;font-size:1.05rem;"><strong>@m.RiskMatrixTotal</strong></td>
 </tr>
 </tbody>
 </table>
 </div>
 </div>
 <p class="dfe-c-body-s govuk-!-margin-top-2">Sums and matrix counts use 5-point inherent likelihood and impact (same as the dashboard).</p>
 </div>

 <div class="govuk-grid-row">
