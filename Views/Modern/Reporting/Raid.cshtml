    </section>

 <div class="mr-section">
 <div class="dfe-c-section-header dfe-c-mb-2">
 <h2 id="raid-issue-matrix" class="govuk-heading-m govuk-!-margin-bottom-0">Severity × priority matrix</h2>
 </div>
 <p class="dfe-c-body-s dfe-c-text-muted govuk-!-margin-bottom-3">Open issues by active severity (columns) and priority (rows). Shading is relative to the busiest cell in this view — for absolute bands use the main RAID work views.</p>
 @if (m.IssueSeverityColumns.Count == 0 || m.IssuePriorityRows.Count == 0)
        {
 <p class="dfe-c-body-s dfe-c-text-muted">Configure active issue severities and priorities to populate this heatmap.</p>
        }
        else
        {
 <div class="dfe-c-table-wrap raid-matrix-wrap raid-matrix-wrap--heatmap raid-report-issue-mx" style="min-width:0;">
 <div class="raid-matrix-scroll">
 <table class="mr-mx raid-matrix" aria-label="Issue severity and priority heatmap">
 <thead>
 <tr>
 <th class="mr-mx__corner" scope="col"><span class="mr-mx__corner-label mr-mx__corner-label--col">Severity →</span><span class="mr-mx__corner-label mr-mx__corner-label--row">Priority ↓</span></th>
 @foreach (var s in m.IssueSeverityColumns)
                    {
 <th scope="col" class="mr-mx__col-hdr">@s.Label</th>
                    }
 <th scope="col" class="mr-mx__col-hdr mr-mx__col-hdr--total">Σ</th>
                </tr>
              </thead>
 <tbody>
 @for (var pi = 0; pi < m.IssuePriorityRows.Count; pi++)
                {
                  var rowSum = 0;
                  for (var si = 0; si < m.IssueSeverityColumns.Count; si++)
                    rowSum += m.IssuePrioritySeverityGrid[pi][si];
 <tr>
 <th scope="row" class="mr-mx__row-hdr">@m.IssuePriorityRows[pi].Label</th>
 @for (var si = 0; si < m.IssueSeverityColumns.Count; si++)
