  .raid-intel-panel--wide, .raid-intel-section { max-width: 100%; }
  .raid-intel-prioritise-stack, .raid-intel-hygiene-stack { display: flex; flex-direction: column; gap: 1.5rem; }
  .raid-intel-prioritise-stack > *, .raid-intel-hygiene-stack > * { min-width: 0; width: 100%; }
  .raid-intel-hygiene-stack table { width: 100%; }
  .raid-intel-table-x { width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .mr-ba-table.mr-ba-table--intel-wide { min-width: 0; width: 100%; }
  .mr-change-tbl.mr-change-tbl--intel { width: 100%; min-width: 0; table-layout: auto; }
  .raid-intel-row-warn { background: #fef7f6; }
  .raid-intel-cardlist { list-style: none; padding: 0; margin: 0; }
  .raid-intel-cardlist__item { border: 1px solid #e5e5e5; border-radius: 4px; padding: 0.65rem 0.85rem; margin-bottom: 0.5rem; background: #fff; }
  .raid-intel-cardlist__title { font-weight: 600; font-size: 0.9375rem; margin-bottom: 0.2rem; }
  .raid-register-breakdown { border: 1px solid var(--rpt-border, #e5e7eb); border-radius: 4px; padding: 0.5rem 0.85rem 0.85rem; background: #fafafa; margin-bottom: 0.5rem; }
  .raid-register-breakdown__summary { cursor: pointer; list-style: none; }
  .raid-register-breakdown__summary::-webkit-details-marker { display: none; }
  .raid-register-breakdown__title { display: block; font-weight: 700; font-size: 1.05rem; color: #0b0c0c; }
  .raid-register-breakdown__hint { display: block; font-size: 0.8125rem; color: var(--grey-4, #505a5f); margin-top: 0.25rem; }
  .raid-register-breakdown__body { background: #fff; padding: 0.5rem 0; }

  /* BA-style numeric tables (aligned with monthly report) */
  .mr-ba-table { border-collapse: collapse; font-size: 0.8125rem; width: 100%; min-width: 52rem; }
  .mr-ba-table.mr-ba-table--raid-count { min-width: 0; }
  .mr-ba-table th, .mr-ba-table td { padding: 0.4rem 0.35rem; border: 1px solid var(--rpt-border, #e5e7eb); vertical-align: middle; }
  .mr-ba-table thead th { background: #f3f2f1; font-weight: 700; text-align: center; }
  .mr-ba-table__area-col { text-align: left !important; white-space: normal; min-width: 8rem; max-width: 22rem; font-weight: 600; hyphens: auto; }
  .mr-ba-table__num-hdr { font-variant-numeric: tabular-nums; }
  .mr-ba-table__num { text-align: center; font-variant-numeric: tabular-nums; }
  .mr-ba-num {
    display: inline-flex; align-items: center; justify-content: center; min-width: 1.75rem; padding: 0.2rem 0.45rem; border-radius: 6px;
    font-weight: 600; font-size: 0.8125rem; font-variant-numeric: tabular-nums; line-height: 1.2; background: #f3f2f1; color: #505a5f;
  }
  .mr-ba-num--strong { background: #e8eaed; color: #0b0c0c; font-weight: 700; }
  .mr-ba-num--muted { opacity: 0.45; font-weight: 500; }
  .mr-ba-num--highlight { background: #e8f5e9; color: #005a30; }
  .mr-ba-num--warn { background: #fff3cd; color: #6e4900; }
  .mr-ba-num--rag-red { background: #fde8e5; color: #942514; }
  .mr-ba-num--rag-green { background: #e3f5eb; color: #005a30; }
  .mr-ba-table__fixed { position: sticky; left: 0; background: #fff; z-index: 1; box-shadow: 2px 0 4px rgba(0,0,0,0.04); }
  .mr-ba-table thead .mr-ba-table__fixed { background: #f3f2f1; z-index: 2; }
  .mr-ba-table tbody tr:nth-child(even) { background: #fafafa; }
  .mr-ba-table tbody tr:nth-child(even) .mr-ba-table__fixed { background: #fafafa; }
 </style>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" nonce="@Context.Items["Nonce"]"></script>
<script nonce="@Context.Items["Nonce"]">
(function () {
  var chartFont = { family: "'Inter', system-ui, -apple-system, sans-serif" };
  var chartDefaults = {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
      legend: { position: 'bottom', labels: { font: Object.assign({ size: 11 }, chartFont), boxWidth: 12 } }
    },
    scales: {
      x: { ticks: { font: chartFont } },
      y: { ticks: { font: chartFont }, beginAtZero: true }
    }
  };

  var labels = @Html.Raw(trendLabelsJson);
  var newRisks = @Html.Raw(newRisksJson);
  var avgRisk = @Html.Raw(avgRiskJson);
  var newIssues = @Html.Raw(newIssuesJson);
  var sevSeries = @Html.Raw(sevSeriesJson);
  var riskBuckets = @Html.Raw(riskBucketJson);
  var issueSevOpen = @Html.Raw(issueSevJson);
  var proxLabels = @Html.Raw(JsonSerializer.Serialize(m.RiskProximityCounts.Keys.ToList(), jsonOpts));
  var proxData = @Html.Raw(JsonSerializer.Serialize(m.RiskProximityCounts.Values.ToList(), jsonOpts));
  var riskStChg = @Html.Raw(riskStatusChgJson);
  var issueStChg = @Html.Raw(issueStatusChgJson);

  function doughnut(id, labelsArr, dataArr, colors) {
    var el = document.getElementById(id);
    if (!el || typeof Chart === 'undefined') return;
    if (!labelsArr || !labelsArr.length) return;
    new Chart(el.getContext('2d'), {
      type: 'doughnut',
      data: {
        labels: labelsArr,
        datasets: [{ data: dataArr, backgroundColor: colors, borderWidth: 1, borderColor: '#fff' }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { font: chartFont, boxWidth: 12 } } }
      }
    });
  }

  @if (curTab == "risks")
  {
    <text>
    var rbKeys = Object.keys(riskBuckets || {});
    var rbVals = rbKeys.map(function (k) { return riskBuckets[k]; });
    doughnut('chart-risk-score-buckets', rbKeys, rbVals, ['#e6e6e6', '#f6c6bd', '#f47738', '#d4351c', '#6b1d12']);

    if (proxLabels && proxLabels.length) {
      var elp = document.getElementById('chart-risk-proximity');
      if (elp && typeof Chart !== 'undefined') {
        new Chart(elp.getContext('2d'), {
          type: 'bar',
          data: {
            labels: proxLabels,
            datasets: [{ label: 'Risks', data: proxData, backgroundColor: '#1d70b8aa' }]
          },
          options: Object.assign({}, chartDefaults, { indexAxis: 'y', plugins: { legend: { display: false } } })
        });
      }
    }

    var elCombo = document.getElementById('chart-risk-trend-combo');
    if (elCombo && typeof Chart !== 'undefined' && labels && labels.length) {
      new Chart(elCombo.getContext('2d'), {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [
            {
              type: 'bar',
              label: 'New risks',
              data: newRisks,
              backgroundColor: 'rgba(29, 112, 184, 0.45)',
              yAxisID: 'y',
              order: 2
            },
            {
              type: 'line',
              label: 'Avg score (new)',
              data: avgRisk,
              borderColor: '#d4351c',
              backgroundColor: 'rgba(212, 53, 28, 0.12)',
              tension: 0.25,
              spanGaps: true,
              yAxisID: 'y1',
              order: 1
            }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          scales: {
            x: { ticks: { font: chartFont } },
            y: {
              type: 'linear',
              position: 'left',
              title: { display: true, text: 'Count', font: chartFont },
              beginAtZero: true,
              ticks: { precision: 0 }
            },
            y1: {
              type: 'linear',
              position: 'right',
              grid: { drawOnChartArea: false },
              title: { display: true, text: 'Avg score', font: chartFont },
              min: 0,
              max: 25,
              ticks: { precision: 1 }
            }
          },
          plugins: { legend: { position: 'bottom', labels: { font: chartFont } } }
        }
      });
    }
    </text>
  }

  @if (curTab == "issues")
  {
    <text>
    var isLabels = Object.keys(issueSevOpen || {});
    var isVals = isLabels.map(function (k) { return issueSevOpen[k]; });
    doughnut('chart-issue-severity-open', isLabels, isVals, ['#5694ca', '#f47738', '#d4351c', '#85994b', '#6f777b', '#b58840']);

    var elStack = document.getElementById('chart-issue-severity-stack');
    if (elStack && typeof Chart !== 'undefined' && labels && labels.length && sevSeries && sevSeries.length) {
      var palette = ['#1d70b8', '#f47738', '#d4351c', '#85994b', '#b58840', '#5694ca', '#6f777b'];
      var datasets = sevSeries.map(function (s, i) {
        return {
          type: 'bar',
          label: s.label,
          data: s.data,
          backgroundColor: palette[i % palette.length],
          stack: 'issues'
        };
      });
      datasets.push({
        type: 'line',
        label: 'Total new',
        data: newIssues,
        borderColor: '#0b0c0c',
        backgroundColor: 'transparent',
        tension: 0.2,
        yAxisID: 'y1',
        order: 0
      });
      new Chart(elStack.getContext('2d'), {
        type: 'bar',
        data: { labels: labels, datasets: datasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          scales: {
            x: { stacked: true, ticks: { font: chartFont } },
            y: { stacked: true, beginAtZero: true, ticks: { precision: 0 }, title: { display: true, text: 'By severity', font: chartFont } },
            y1: {
              position: 'right',
              grid: { drawOnChartArea: false },
              beginAtZero: true,
              title: { display: true, text: 'Total', font: chartFont },
              ticks: { precision: 0 }
            }
          },
          plugins: { legend: { position: 'bottom', labels: { font: chartFont, boxWidth: 10 } } }
        }
      });
    }
    </text>
  }

  (function () {
    var elSt = document.getElementById('chart-status-changes-audit');
    if (!elSt || typeof Chart === 'undefined' || !labels || !labels.length) return;
    new Chart(elSt.getContext('2d'), {
      type: 'line',
      data: {
        labels: labels,
        datasets: [
          {
            label: 'Risk status edits (audit)',
            data: riskStChg,
            borderColor: '#d4351c',
            backgroundColor: 'rgba(212,53,28,0.08)',
            tension: 0.22,
            fill: true,
            spanGaps: true
          },
          {
            label: 'Issue status edits (audit)',
            data: issueStChg,
            borderColor: '#1d70b8',
            backgroundColor: 'rgba(29,112,184,0.06)',
            tension: 0.22,
            fill: true,
            spanGaps: true
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        scales: {
          x: { ticks: { font: chartFont } },
          y: {
            beginAtZero: true,
            ticks: { precision: 0 },
            title: { display: true, text: 'Audit transitions', font: chartFont }
          }
        },
        plugins: {
          legend: { position: 'bottom', labels: { font: chartFont, boxWidth: 12 } },
          tooltip: {
            callbacks: {
              footer: function () {
                return 'Uses audit payloads when status fields changed.';
              }
            }
          }
        }
      }
    });
  })();
})();
</script>
}
