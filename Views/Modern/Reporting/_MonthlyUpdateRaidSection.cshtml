@using Compass.Models.Modern.Work
@model Compass.ViewModels.ModernMonthlyReportDashboardViewModel
@{
  var m = Model;
  var raid = m.RaidSummary;
  var raidTotal = raid.TotalOpen;
  var raidHref = Url.Action("Raid", "ModernReporting", new
  {
    businessAreaId = m.FilterBusinessAreaId,
    directorateId = m.FilterDirectorateId
  });
  var nearMissesHref = Url.Action("NearMisses", "ModernRaid", new
  {
    tab = "open",
    businessAreaLookupId = m.FilterBusinessAreaId,
    directorateLookupId = m.FilterDirectorateId
  });
}

<div class="mr-report-section-panel dfe-f-toggle govuk-!-margin-bottom-3" data-module="dfe-f-toggle" data-mr-section-id="raid" data-mr-section-title="RAID (Risks and Issues)">
  <div class="dfe-f-toggle__title-wrapper">
    <h2 class="dfe-f-toggle__heading">
      <button type="button" class="dfe-f-toggle__button" aria-expanded="false" aria-controls="mr-toggle-raid-content" id="mr-toggle-raid-button">
        <span class="dfe-f-toggle__icon" aria-hidden="true"></span>
        <span class="dfe-f-toggle__title" id="mr-h-raid">RAID (Risks and Issues)</span>
        <span class="mr-toggle-panel__meta"><span class="@WorkBadgeCss.ToggleCountBadgeClass(raidTotal, warnWhenPositive: true)">@raidTotal open</span></span>
      </button>
    </h2>
  </div>
  <div id="mr-toggle-raid-content" class="dfe-f-toggle__content" hidden>
    <div class="dfe-f-toggle__body govuk-body">
      <p class="dfe-c-body-s dfe-c-text-muted govuk-!-margin-top-0 govuk-!-margin-bottom-3">
        Open risks, issues and near misses in scope for this report@(m.FilterBusinessAreaId.HasValue || m.FilterDirectorateId.HasValue ? " (filtered)" : ""). Counts match the RAID reporting area.
      </p>
      <div class="dfe-f-card-grid govuk-!-margin-bottom-4">
        <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
          <p class="govuk-body-s dfe-f-stat-card__label">Open risks</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@raid.OpenRisks</p>
        </div>
        <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
          <p class="govuk-body-s dfe-f-stat-card__label">Open issues</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@raid.OpenIssues</p>
        </div>
        <div class="dfe-f-stat-card dfe-f-stat-card--tint-blue">
          <p class="govuk-body-s dfe-f-stat-card__label">Open near misses</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@raid.OpenNearMisses</p>
        </div>
        <div class="dfe-f-stat-card dfe-f-stat-card--tint-red">
          <p class="govuk-body-s dfe-f-stat-card__label">High risks (score ≥ 15)</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@raid.HighRisks</p>
        </div>
        <div class="dfe-f-stat-card dfe-f-stat-card--tint-red">
          <p class="govuk-body-s dfe-f-stat-card__label">Critical open issues</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@raid.OpenCriticalIssues</p>
        </div>
        <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
          <p class="govuk-body-s dfe-f-stat-card__label">Risks review overdue</p>
          <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@raid.RisksReviewOverdue</p>
        </div>
      </div>
      <p class="govuk-body govuk-!-margin-bottom-0">
        <a class="govuk-link govuk-link--no-visited-state" href="@raidHref">Open RAID reporting</a>
        <span aria-hidden="true"> · </span>
        <a class="govuk-link govuk-link--no-visited-state" href="@nearMissesHref">Open near misses register</a>
      </p>
    </div>
  </div>
</div>
