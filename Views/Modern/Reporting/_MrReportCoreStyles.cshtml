@* Shared layout styles for modern reporting pages (monthly report, priorities report). *@
<style>
  .mr-section { margin-bottom: 2.5rem; scroll-margin-top: 1rem; }
  .mr-section__heading {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0 0 1rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--navy, #1d70b8);
  }

  .mr-card {
    background: var(--rpt-bg-card, #fff);
    border: 1px solid var(--rpt-border, #e5e7eb);
    border-radius: var(--rpt-radius, 8px);
    padding: 1.25rem;
    box-shadow: var(--rpt-shadow, 0 1px 3px rgba(0,0,0,0.06));
  }
  .mr-matrix-card {
    min-width: 0;
    overflow: hidden;
  }
  .mr-matrix-scroll {
    margin-bottom: 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .mr-toggle-panel__meta {
    margin-left: auto;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .mr-report-section-panel.dfe-f-toggle {
    margin-bottom: 0;
  }

  .mr-mx { border-collapse: separate; border-spacing: 3px; width: 100%; font-size: 0.875rem; }
  .mr-mx th, .mr-mx td { padding: 0.55rem 0.7rem; text-align: center; vertical-align: middle; }
  .mr-mx__corner {
    background: transparent;
    position: relative;
    min-width: 80px;
    min-height: 48px;
  }
  .mr-mx__corner-label {
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--grey-4, #505a5f);
    position: absolute;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .mr-mx__corner-label--col { top: 4px; right: 6px; }
  .mr-mx__corner-label--row { bottom: 4px; left: 6px; }
  .mr-mx__col-hdr { background: #f8f8f8; font-weight: 600; border-radius: 4px; }
  .mr-mx__col-hdr--total { background: #eee; }
  .mr-mx__row-hdr, th.mr-mx__row-hdr { background: #f8f8f8; font-weight: 600; text-align: left; border-radius: 4px; padding-left: 0.5rem; }
  .mr-mx__row-hdr--total { background: #eee; }
  .mr-mx__cell { border-radius: 6px; transition: transform 0.1s; min-width: 48px; }
  .mr-mx__cell:hover { transform: scale(1.08); z-index: 1; }
  .mr-mx__cell--zero { background: #f8f8f8; }
  .mr-mx__cell--critical { background: #f8d7da; color: #721c24; font-weight: 700; border: 1px solid rgba(114,28,36,0.15); }
  .mr-mx__cell--high { background: #fff0e0; color: #80340a; font-weight: 700; border: 1px solid rgba(128,52,10,0.15); }
  .mr-mx__cell--medium { background: #fff7e0; color: #6e4900; font-weight: 600; border: 1px solid rgba(110,73,0,0.12); }
  .mr-mx__cell--low { background: #e3f5eb; color: #00703c; font-weight: 600; border: 1px solid rgba(0,112,60,0.12); }
  .mr-mx__cell--neutral { background: #f3f2f1; color: #505a5f; }
  .mr-mx__cell--total { background: #eee; font-weight: 700; border-radius: 4px; }
  .mr-mx__cell--grand { background: #ddd; font-weight: 700; font-size: 1rem; border-radius: 4px; }
  .mr-mx__count { font-size: 1.125rem; font-weight: 700; }
  .mr-mx__empty { color: #ccc; font-size: 0.875rem; }
  .mr-mx tfoot th, .mr-mx tfoot td { font-weight: 700; }

  .mr-ba-table { border-collapse: collapse; font-size: 0.8125rem; width: 100%; min-width: 52rem; }
  .mr-ba-table th, .mr-ba-table td { padding: 0.4rem 0.35rem; border: 1px solid var(--rpt-border, #e5e7eb); vertical-align: middle; }
  .mr-ba-table thead th { background: #f3f2f1; font-weight: 700; position: sticky; top: 0; z-index: 1; text-align: center; }
  .mr-ba-table__area-col {
    text-align: left !important;
    white-space: normal;
    min-width: 10rem;
    max-width: 22rem;
    font-weight: 600;
    hyphens: auto;
  }
  .mr-ba-table__num-hdr { font-variant-numeric: tabular-nums; }
  .mr-ba-table__num { text-align: center; font-variant-numeric: tabular-nums; }
  .mr-ba-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.75rem;
    padding: 0.2rem 0.45rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.8125rem;
    font-variant-numeric: tabular-nums;
    line-height: 1.2;
    background: #f3f2f1;
    color: #505a5f;
  }
  .mr-ba-num--strong { background: #e8eaed; color: #0b0c0c; font-weight: 700; }
  .mr-ba-num--muted { opacity: 0.45; font-weight: 500; }
  .mr-ba-num--highlight { background: #e8f5e9; color: #005a30; }
  .mr-ba-num--warn { background: #fff3cd; color: #6e4900; }
  .mr-ba-num--rag-ns { background: #ececec; color: #454a4d; }
  .mr-ba-num--pri-crit { background: #fde8e5; color: #942514; }
  .mr-ba-num--pri-high { background: #ffeee5; color: #80340a; }
  .mr-ba-num--pri-med { background: #fff8e6; color: #6e4900; }
  .mr-ba-num--pri-low { background: #e3f5eb; color: #005a30; }
  .mr-ba-num--pri-ns { background: #ececec; color: #454a4d; }
  .mr-ba-table__group { font-weight: 700; }
  .mr-ba-table__group--ms { background: #f0f4f5; border-bottom: 3px solid #5694ca; }
  .mr-ba-table__group--rag { background: #fef7f0; border-bottom: 3px solid #f47738; }
  .mr-ba-table__group--pri { background: #f0f5ef; border-bottom: 3px solid #00703c; }
  .mr-ba-table__sub { font-weight: 600; font-size: 0.6875rem; }
  .mr-ba-table__sub--ms { background: #f7fafb; }
  .mr-ba-table__sub--rag { background: #fffcf8; }
  .mr-ba-table__sub--pri { background: #f7faf6; }
  .mr-ba-table__cell--ms { background: rgba(86, 148, 202, 0.04); }
  .mr-ba-table__cell--rag { background: rgba(244, 119, 56, 0.04); }
  .mr-ba-table__cell--pri { background: rgba(0, 112, 60, 0.04); }
  .mr-ba-table__fixed { position: sticky; left: 0; background: #fff; z-index: 1; box-shadow: 2px 0 4px rgba(0,0,0,0.04); }
  .mr-ba-table thead .mr-ba-table__fixed { background: #f3f2f1; z-index: 2; }
  .mr-ba-table tfoot .mr-ba-table__fixed { background: #f3f2f1; z-index: 2; }
  .mr-ba-table tbody tr:nth-child(even) { background: #fafafa; }
  .mr-ba-table tbody tr:nth-child(even) .mr-ba-table__fixed { background: #fafafa; }
  .mr-ba-table__total-row th, .mr-ba-table__total-row td { background: #ebecef; font-weight: 700; border-top: 2px solid #333; }

  .mr-ba-drill { cursor: pointer; text-decoration: underline; text-decoration-style: dotted; text-underline-offset: 2px; }
  .mr-ba-drill:hover, .mr-ba-drill:focus { text-decoration-style: solid; outline: 2px solid #fd0; outline-offset: 1px; }
  .mr-ba-drilldown { margin-top: 1rem; border: 1px solid #b1b4b6; padding: 1rem 1.25rem; background: #fff; }
  .mr-ba-drilldown__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem; }
  .mr-ba-drilldown__title { margin: 0; font-size: 1.05rem; }
  .mr-ba-drilldown__close { background: none; border: none; font-size: 1.5rem; cursor: pointer; padding: 0 0.25rem; line-height: 1; color: #505a5f; }
  .mr-ba-drilldown__close:hover { color: #0b0c0c; }
  .mr-mx__cell .mr-ba-drill { text-decoration: none; display: inline-block; min-width: 1.5rem; }
</style>
