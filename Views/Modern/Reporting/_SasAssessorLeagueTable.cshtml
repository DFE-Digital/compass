@model IReadOnlyList<Compass.ViewModels.Modern.SasAssessorLeagueRowVm>
@{
    var rows = Model ?? Array.Empty<Compass.ViewModels.Modern.SasAssessorLeagueRowVm>();
}
@if (rows.Count == 0)
{
    <p class="govuk-body dfe-c-text-muted govuk-!-margin-bottom-0">No panel assignments in this period.</p>
}
else
{
    <div class="dfe-f-table-wrapper govuk-!-margin-bottom-0" data-module="dfe-f-table">
        <div class="govuk-visually-hidden" aria-live="polite" data-dfe-table-sort-live></div>
        <table class="govuk-table mr-ba-table">
            <thead class="govuk-table__head">
                <tr class="govuk-table__row">
                    <th scope="col" class="govuk-table__header mr-ba-table__num-hdr" aria-sort="none">
                        <button type="button" class="dfe-f-table-sort-button">Rank</button>
                    </th>
                    <th scope="col" class="govuk-table__header" aria-sort="none">
                        <button type="button" class="dfe-f-table-sort-button">Assessor</button>
                    </th>
                    <th scope="col" class="govuk-table__header" aria-sort="none">
                        <button type="button" class="dfe-f-table-sort-button">Primary role</button>
                    </th>
                    <th scope="col" class="govuk-table__header mr-ba-table__num-hdr" aria-sort="none">
                        <button type="button" class="dfe-f-table-sort-button">Assessments</button>
                    </th>
                    <th scope="col" class="govuk-table__header mr-ba-table__num-hdr" aria-sort="none">
                        <button type="button" class="dfe-f-table-sort-button">Peer reviews</button>
                    </th>
                    <th scope="col" class="govuk-table__header mr-ba-table__num-hdr" aria-sort="none">
                        <button type="button" class="dfe-f-table-sort-button">Panels</button>
                    </th>
                    <th scope="col" class="govuk-table__header mr-ba-table__num-hdr" aria-sort="none">
                        <button type="button" class="dfe-f-table-sort-button">Published</button>
                    </th>
                    <th scope="col" class="govuk-table__header mr-ba-table__num-hdr" aria-sort="none">
                        <button type="button" class="dfe-f-table-sort-button">Red</button>
                    </th>
                    <th scope="col" class="govuk-table__header mr-ba-table__num-hdr" aria-sort="none">
                        <button type="button" class="dfe-f-table-sort-button">Amber</button>
                    </th>
                    <th scope="col" class="govuk-table__header mr-ba-table__num-hdr" aria-sort="none">
                        <button type="button" class="dfe-f-table-sort-button">Green</button>
                    </th>
                </tr>
            </thead>
            <tbody class="govuk-table__body">
                @foreach (var row in rows)
                {
                    <tr class="govuk-table__row">
                        <td class="mr-ba-table__num"><span class="mr-ba-num">@row.Rank</span></td>
                        <th scope="row">
                            @row.DisplayName
                            @if (!string.IsNullOrWhiteSpace(row.Email))
                            {
                                <span class="govuk-body-s dfe-c-text-muted" style="display:block;">@row.Email</span>
                            }
                        </th>
                        <td>@row.PrimaryRole</td>
                        <td class="mr-ba-table__num"><span class="mr-ba-num">@row.ServiceAssessmentCount.ToString("N0")</span></td>
                        <td class="mr-ba-table__num"><span class="mr-ba-num">@row.PeerReviewCount.ToString("N0")</span></td>
                        <td class="mr-ba-table__num"><span class="mr-ba-num">@row.PanelCount.ToString("N0")</span></td>
                        <td class="mr-ba-table__num"><span class="mr-ba-num">@row.PublishedCount.ToString("N0")</span></td>
                        <td class="mr-ba-table__num"><span class="mr-ba-num">@row.Red.ToString("N0")</span></td>
                        <td class="mr-ba-table__num"><span class="mr-ba-num">@row.Amber.ToString("N0")</span></td>
                        <td class="mr-ba-table__num"><span class="mr-ba-num">@row.Green.ToString("N0")</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

