@model Compass.ViewModels.Modern.ModernReportingDashboardViewModel
@using Compass.ViewModels.Modern
@{
    ViewData["Title"] = "Reporting dashboard";
    var reportingDashboardLede = await Html.PartialAsync("_GovukBodyParagraph", "Choose a report or dataset for portfolio oversight, delivery metrics, assurance, and governance packs.");
}

@section Breadcrumbs {
 <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
 <li class="govuk-breadcrumbs__list-item" aria-current="page">Reporting dashboard</li>
}

<div class="reporting-dashboard">
  @await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
    Title = "Reporting dashboard",
    Lede = reportingDashboardLede
  })

  <section class="reporting-dashboard__section" aria-labelledby="reporting-dashboard-portfolio-heading">
    <h2 id="reporting-dashboard-portfolio-heading" class="govuk-heading-m reporting-dashboard__section-heading">Portfolio and delivery</h2>
    <div class="dfe-f-card-grid reporting-dashboard__grid">
      @await Html.PartialAsync("~/Views/Modern/Reporting/_ReportingDashboardCard.cshtml", new ReportingDashboardCardViewModel {
        Title = "Monthly report",
        Href = Url.Action("MonthlyUpdate", "ModernReporting") ?? "#",
        Description = "Portfolio RAG, priorities, milestones, and business area roll-up for a month."
      })
      @await Html.PartialAsync("~/Views/Modern/Reporting/_ReportingDashboardCard.cshtml", new ReportingDashboardCardViewModel {
        Title = "Monthly submission progress",
        Href = Url.Action("MonthlySubmissionProgress", "ModernReporting") ?? "#",
        Description = "Submission progress over the reporting window, with directorate and business area league tables."
      })
      @await Html.PartialAsync("~/Views/Modern/Reporting/_ReportingDashboardCard.cshtml", new ReportingDashboardCardViewModel {
        Title = "Priorities report",
        Href = Url.Action("Priorities", "ModernReporting") ?? "#",
        Description = "Monthly metrics by mission pillar, priority outcome, or delivery priority — with drill-down into work items."
      })
      @await Html.PartialAsync("~/Views/Modern/Reporting/_ReportingDashboardCard.cshtml", new ReportingDashboardCardViewModel {
        Title = "Thematic report",
        Href = Url.Action("ThematicReport", "ModernReporting") ?? "#",
        Description = "Delivery work by theme — counts by tag (active and completed), then work items for a selected theme."
      })
    </div>
  </section>

  <section class="reporting-dashboard__section" aria-labelledby="reporting-dashboard-resourcing-heading">
    <h2 id="reporting-dashboard-resourcing-heading" class="govuk-heading-m reporting-dashboard__section-heading">Resourcing</h2>
    <div class="dfe-f-card-grid reporting-dashboard__grid">
      @await Html.PartialAsync("~/Views/Modern/Reporting/_ReportingDashboardCard.cshtml", new ReportingDashboardCardViewModel {
        Title = "Resourcing report",
        Href = Url.Action("Resourcing", "ModernReporting") ?? "#",
        Description = "FTE and MSC totals by directorate, business area, and work item with configurable resource bands and monthly trend."
      })
    </div>
  </section>

  @if (ViewBag.ShowRaidNavigation == true || ViewBag.ShowDdrNavigation == true)
  {
  <section class="reporting-dashboard__section" aria-labelledby="reporting-dashboard-governance-heading">
    <h2 id="reporting-dashboard-governance-heading" class="govuk-heading-m reporting-dashboard__section-heading">Governance</h2>
    <div class="dfe-f-card-grid reporting-dashboard__grid">
      @if (ViewBag.ShowRaidNavigation == true)
      {
      @await Html.PartialAsync("~/Views/Modern/Reporting/_ReportingDashboardCard.cshtml", new ReportingDashboardCardViewModel {
        Title = "RAID intelligence",
        Href = Url.Action("Raid", "ModernReporting", new { tab = "risks" }) ?? "#",
        Description = "Risks, issues, heatmaps, trends, and views by tier, directorate, and business area."
      })
      @await Html.PartialAsync("~/Views/Modern/Reporting/_ReportingDashboardCard.cshtml", new ReportingDashboardCardViewModel {
        Title = "RAID review report",
        Href = Url.Action("RaidReviewProgress", "ModernReporting") ?? "#",
        Description = "Monthly review completion for open risks and issues, with directorate and business area league tables."
      })
      }
      @if (ViewBag.ShowDdrNavigation == true)
      {
      @await Html.PartialAsync("~/Views/Modern/Reporting/_ReportingDashboardCard.cshtml", new ReportingDashboardCardViewModel {
        Title = "Design decision records",
        Href = Url.Action("DesignDecisionRecords", "ModernReporting") ?? "#",
        Description = "DDR volume, status, deviations, retrospectives, product coverage, and DesignOps insights."
      })
      }
    </div>
  </section>
  }

  <section class="reporting-dashboard__section" aria-labelledby="reporting-dashboard-standards-heading">
    <h2 id="reporting-dashboard-standards-heading" class="govuk-heading-m reporting-dashboard__section-heading">Standards and assurance</h2>
    <div class="dfe-f-card-grid reporting-dashboard__grid">
      @await Html.PartialAsync("~/Views/Modern/Reporting/_ReportingDashboardCard.cshtml", new ReportingDashboardCardViewModel {
        Title = "Service assessments",
        Href = Url.Action("Assessments", "ModernReporting") ?? "#",
        Description = "Published SAS portfolio summary, actions by standard, and assessment list."
      })
    </div>
  </section>

  <section class="reporting-dashboard__section" aria-labelledby="reporting-dashboard-operational-heading">
    <h2 id="reporting-dashboard-operational-heading" class="govuk-heading-m reporting-dashboard__section-heading">Operational reporting</h2>
    <div class="dfe-f-card-grid reporting-dashboard__grid">
      @await Html.PartialAsync("~/Views/Modern/Reporting/_ReportingDashboardCard.cshtml", new ReportingDashboardCardViewModel {
        Title = "Performance (commissions)",
        Href = Url.Action("Performance", "ModernReporting") ?? "#",
        Description = "Rounds, return rates, and completion across business areas."
      })
      @await Html.PartialAsync("~/Views/Modern/Reporting/_ReportingDashboardCard.cshtml", new ReportingDashboardCardViewModel {
        Title = "Service register report",
        Href = Url.Action("ServiceRegister", "ModernReporting") ?? "#",
        Description = "Service register status summary, completion score, and data-quality gaps by directorate and business area."
      })
      @if (ViewBag.CanAccessOperations as bool? == true)
      {
      @await Html.PartialAsync("~/Views/Modern/Reporting/_ReportingDashboardCard.cshtml", new ReportingDashboardCardViewModel {
        Title = "Accessibility (AISS)",
        Href = Url.Action("Accessibility", "ModernReporting") ?? "#",
        Description = "Open issues, WCAG breakdown, by service, and month-on-month trend charts from AISS."
      })
      }
    </div>
  </section>

  <section class="reporting-dashboard__section" aria-labelledby="reporting-dashboard-data-heading">
    <h2 id="reporting-dashboard-data-heading" class="govuk-heading-m reporting-dashboard__section-heading">Data and exports</h2>
    <div class="dfe-f-card-grid reporting-dashboard__grid">
      @await Html.PartialAsync("~/Views/Modern/Reporting/_ReportingDashboardCard.cshtml", new ReportingDashboardCardViewModel {
        Title = "Exports",
        Href = Url.Action("Index", "Exports", new { section = "reporting" }) ?? "#",
        Description = "Download reporting datasets for analysis and governance packs."
      })
    </div>
  </section>
</div>
