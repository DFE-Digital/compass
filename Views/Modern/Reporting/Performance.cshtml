@section Scripts {
  <script nonce="@Context.Items["Nonce"]">
    document.addEventListener('DOMContentLoaded', function () {
      function reportSectionPanelsSetExpanded(expanded) {
        document.querySelectorAll('.mr-report-section-panel.dfe-f-toggle').forEach(function (el) {
          if (window.DfeFrontend && typeof window.DfeFrontend.setToggleExpanded === 'function') {
            window.DfeFrontend.setToggleExpanded(el, expanded);
          }
        });
      }
      var ex = document.getElementById('perf-expand-all');
      var cl = document.getElementById('perf-collapse-all');
      if (ex) ex.addEventListener('click', function () { reportSectionPanelsSetExpanded(true); });
      if (cl) cl.addEventListener('click', function () { reportSectionPanelsSetExpanded(false); });
    });
  </script>
}
