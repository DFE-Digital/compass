@model Compass.ViewModels.ModernRaidMeetingReportViewModel
@{
  var n = Model.NearMisses;
}
<section class="mr-report-section-panel dfe-f-toggle govuk-!-margin-bottom-3" data-module="dfe-f-toggle" data-mr-section-id="near-misses" data-mr-section-title="Near misses">
  <header class="dfe-f-toggle__title-wrapper">
    <h2 class="dfe-f-toggle__heading">
      <button type="button" class="dfe-f-toggle__button" aria-expanded="false" aria-controls="rr-toggle-near-misses-content" id="rr-toggle-near-misses-button">
        <span class="dfe-f-toggle__icon" aria-hidden="true"></span>
        <span class="dfe-f-toggle__title">Near misses</span>
        <span class="mr-toggle-panel__meta"><span class="govuk-tag @(n.OpenCount > 0 ? "govuk-tag--blue" : "govuk-tag--grey")">@n.OpenCount open</span></span>
      </button>
    </h2>
  </header>
  <section id="rr-toggle-near-misses-content" class="dfe-f-toggle__content" hidden>
    <section class="dfe-f-toggle__body govuk-body">
      <section class="dfe-f-card-grid govuk-!-margin-bottom-4">
        <article class="dfe-f-stat-card dfe-f-stat-card--tint-blue"><p class="govuk-body-s dfe-f-stat-card__label">Open</p><p class="dfe-f-stat-card__value govuk-body-l">@n.OpenCount</p></article>
        <article class="dfe-f-stat-card dfe-f-stat-card--tint-red"><p class="govuk-body-s dfe-f-stat-card__label">High seriousness (3–4)</p><p class="dfe-f-stat-card__value govuk-body-l">@n.HighSeriousnessCount</p></article>
      </section>
      <h3 class="govuk-heading-s">Recent &amp; serious</h3>
      @await Html.PartialAsync("_RaidMeetingTableRows", n.PriorityRows)
      <p class="govuk-body govuk-!-margin-top-3 govuk-!-margin-bottom-0">
        <a class="govuk-link" href="@Url.Action("NearMisses", "ModernRaid", new { tab = "open", businessAreaLookupId = Model.FilterBusinessAreaId, directorateLookupId = Model.FilterDirectorateId })">Open near misses register</a>
      </p>
    </section>
  </section>
</section>
