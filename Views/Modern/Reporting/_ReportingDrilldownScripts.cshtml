@using System.Text.Encodings.Web
@using System.Text.Json
@using System.Text.Json.Serialization
@model Compass.ViewModels.Modern.ReportingDrilldownScriptViewModel
@{
  var jsonOpts = new JsonSerializerOptions
  {
    PropertyNamingPolicy = JsonNamingPolicy.CamelCase,
    DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull,
    Encoder = JavaScriptEncoder.Default
  };
  var config = new
  {
    projectsByKey = Model.ProjectsByKey,
    scopeProjects = Model.ScopeProjectItems,
    detailsById = Model.DetailsById,
    workDetailPrefix = Model.WorkDetailPrefix,
    exportBaseUrl = Model.ExportBaseUrl,
    exportParams = Model.ExportParams,
    dimensionLabels = Model.DimensionLabels,
    drillRootSelector = Model.DrillRootSelector
  };
}
<script type="application/json" id="mr-reporting-drilldown-config">@Html.Raw(JsonSerializer.Serialize(config, jsonOpts))</script>
<script src="@Url.Content("~/modern/js/reporting-drilldown.js")" nonce="@Context.Items["Nonce"]"></script>
