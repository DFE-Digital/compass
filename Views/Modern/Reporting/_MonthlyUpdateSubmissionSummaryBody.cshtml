@model Compass.ViewModels.ModernMonthlyReportDashboardViewModel
@{
  var m = Model;
}
<div class="dfe-f-card-grid govuk-!-margin-bottom-4">
  <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
    <p class="govuk-body-s dfe-f-stat-card__label">Active work items</p>
    <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@m.TotalActiveProjects</p>
  </div>
  <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
    <p class="govuk-body-s dfe-f-stat-card__label">New this month</p>
    <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@m.NewProjectsCount</p>
  </div>
  <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
    <p class="govuk-body-s dfe-f-stat-card__label">Milestones achieved</p>
    <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@m.MilestonesAchievedCount</p>
  </div>
  @if (m.MonthlyUpdateStats != null)
  {
    <div class="dfe-f-stat-card dfe-f-stat-card--tint-green">
      <p class="govuk-body-s dfe-f-stat-card__label">Returns submitted</p>
      <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@m.MonthlyUpdateStats.Submitted</p>
    </div>
    <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
      <p class="govuk-body-s dfe-f-stat-card__label">In progress</p>
      <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@m.MonthlyUpdateStats.InProgress</p>
    </div>
    <div class="dfe-f-stat-card dfe-f-stat-card--tint-red">
      <p class="govuk-body-s dfe-f-stat-card__label">Late</p>
      <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@m.MonthlyUpdateStats.Late</p>
    </div>
  }
  <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
    <p class="govuk-body-s dfe-f-stat-card__label">RAG changes</p>
    <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@m.ProjectsWithRagChangeInPeriod</p>
  </div>
  <div class="dfe-f-stat-card dfe-f-stat-card--tint-grey">
    <p class="govuk-body-s dfe-f-stat-card__label">Priority changes</p>
    <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@m.ProjectsWithPriorityChangeInPeriod</p>
  </div>
</div>
@if (!string.IsNullOrWhiteSpace(m.BusinessAreaSummaryNarrative))
{
  <div class="govuk-inset-text govuk-!-margin-bottom-4">
    <h3 class="govuk-heading-s govuk-!-margin-top-0">Business area overview</h3>
    <p class="govuk-body-s govuk-hint govuk-!-margin-bottom-3">This overview is <strong>generated automatically</strong> from Compass data shown on this page (and related history). It is intended as a gentle prompt for conversation—not a score, target, or formal assessment.</p>
    @foreach (var para in m.BusinessAreaSummaryNarrative.Split("\n\n", StringSplitOptions.RemoveEmptyEntries))
    {
      <p class="govuk-body govuk-!-margin-bottom-2">@para</p>
    }
  </div>
}
