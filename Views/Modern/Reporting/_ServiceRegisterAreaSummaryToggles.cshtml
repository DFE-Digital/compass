@using Compass.Models.Modern.Work
@using Compass.ViewModels.Modern
@model IReadOnlyList<ServiceRegisterAreaSummaryRow>
@{
  var rows = Model ?? Array.Empty<ServiceRegisterAreaSummaryRow>();
  var toggleIdPrefix = ViewData["ToggleIdPrefix"] as string ?? "sr-area";
  var areaLabel = ViewData["AreaLabel"] as string ?? "Area";
}
@if (rows.Count == 0)
{
  <p class="govuk-body-s dfe-c-text-muted">No products found.</p>
}
else
{
  <div class="dfe-f-toggle-group govuk-!-margin-bottom-2" data-module="dfe-f-toggle-group">
    <div class="dfe-f-toggle-group__controls govuk-body-s govuk-!-margin-bottom-2">
      <button type="button" class="dfe-f-toggle-group__action" data-dfe-toggle-expand-all>Expand all</button>
      <span class="dfe-f-toggle-group__separator" aria-hidden="true"> · </span>
      <button type="button" class="dfe-f-toggle-group__action" data-dfe-toggle-collapse-all>Collapse all</button>
    </div>
    <div class="dfe-f-toggle-group__items">
      @for (var i = 0; i < rows.Count; i++)
      {
        var row = rows[i];
        var toggleId = $"{toggleIdPrefix}-{i}";
        var contentId = $"{toggleId}-content";
        <div class="dfe-f-toggle govuk-!-margin-bottom-2" data-module="dfe-f-toggle">
          <div class="dfe-f-toggle__title-wrapper">
            <h3 class="dfe-f-toggle__heading">
              <button type="button" class="dfe-f-toggle__button" aria-expanded="false" aria-controls="@contentId" id="@($"{toggleId}-button")">
                <span class="dfe-f-toggle__icon" aria-hidden="true"></span>
                <span class="dfe-f-toggle__title">@row.Name</span>
                <span class="mr-toggle-panel__meta">
                  <span class="@WorkBadgeCss.ToggleCountBadgeClass(row.ProductCount)">@row.ProductCount</span>
                </span>
              </button>
            </h3>
          </div>
          <div id="@contentId" class="dfe-f-toggle__content" hidden>
            <div class="dfe-f-toggle__body govuk-body">
              <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
                <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed">
                  <caption class="govuk-table__caption govuk-visually-hidden">@areaLabel summary for @row.Name</caption>
                  <thead class="govuk-table__head">
                    <tr class="govuk-table__row">
                      <th scope="col" class="govuk-table__header">@areaLabel</th>
                      <th scope="col" class="govuk-table__header govuk-table__header--numeric">Products</th>
                      <th scope="col" class="govuk-table__header govuk-table__header--numeric">Active</th>
                      <th scope="col" class="govuk-table__header govuk-table__header--numeric">Rejected</th>
                      <th scope="col" class="govuk-table__header govuk-table__header--numeric">Retired</th>
                      <th scope="col" class="govuk-table__header govuk-table__header--numeric">New</th>
                      <th scope="col" class="govuk-table__header govuk-table__header--numeric">Enterprise</th>
                      <th scope="col" class="govuk-table__header govuk-table__header--numeric">Avg completion</th>
                    </tr>
                  </thead>
                  <tbody class="govuk-table__body">
                    <tr class="govuk-table__row">
                      <td class="govuk-table__cell">@row.Name</td>
                      <td class="govuk-table__cell govuk-table__cell--numeric">@row.ProductCount</td>
                      <td class="govuk-table__cell govuk-table__cell--numeric">@row.ActiveCount</td>
                      <td class="govuk-table__cell govuk-table__cell--numeric">@row.RejectedCount</td>
                      <td class="govuk-table__cell govuk-table__cell--numeric">@row.RetiredCount</td>
                      <td class="govuk-table__cell govuk-table__cell--numeric">@row.NewCount</td>
                      <td class="govuk-table__cell govuk-table__cell--numeric">@row.EnterpriseCount</td>
                      <td class="govuk-table__cell govuk-table__cell--numeric">@row.AverageCompletionPercent.ToString("0.#")%</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      }
    </div>
  </div>
}
