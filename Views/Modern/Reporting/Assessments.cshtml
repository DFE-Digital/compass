@using System.Text.Json
@using System.Text.Json.Serialization
@using Compass.ViewModels.Modern
@model ModernServiceAssessmentsReportViewModel
@{
  ViewData["Title"] = "Service assessments";
  var m = Model ?? new ModernServiceAssessmentsReportViewModel();
  var hasList = m.AssessmentRows.Count > 0;
  var hasStandardActions = m.StandardActionRows.Count > 0;
  var useStdPropensity = m.ServiceStandardOutcomeBreakdownAvailable && hasStandardActions;
  var hasSummaryTabular = m.ByOutcome.Count + m.ByType.Count + m.ByPhase.Count + m.ByYear.Count > 0;
  var showKpis = !m.SummaryLoadFailed && m.TotalAssessments > 0;

  var jsonOpts = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase, DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull };
  var chartOutcomeJson = JsonSerializer.Serialize(
    new { labels = m.ByOutcome.Select(x => x.Key).ToList(), data = m.ByOutcome.Select(x => x.Value).ToList() },
    jsonOpts);
  var chartTypeJson = JsonSerializer.Serialize(
    new { labels = m.ByType.Select(x => x.Key).ToList(), data = m.ByType.Select(x => x.Value).ToList() },
    jsonOpts);
  var chartPhaseJson = JsonSerializer.Serialize(
    new { labels = m.ByPhase.Select(x => x.Key).ToList(), data = m.ByPhase.Select(x => x.Value).ToList() },
    jsonOpts);
  var chartYearJson = JsonSerializer.Serialize(
    new { labels = m.ByYear.Select(x => x.Key).ToList(), data = m.ByYear.Select(x => x.Value).ToList() },
    jsonOpts);
  string chartStdJson;
  if (!hasStandardActions)
  {
    chartStdJson = "{}";
  }
  else if (useStdPropensity)
  {
    var rows = m.StandardActionRows;
    static double Pct(int part, int total) => total <= 0 ? 0.0 : 100.0 * part / total;
    chartStdJson = JsonSerializer.Serialize(
      new
      {
        usePropensity = true,
        standards = rows.Select(x => x.Standard).ToList(),
        redPct = rows.Select(x => Pct(x.ActionsFromRedOutcome, x.ActionCount)).ToList(),
        amberPct = rows.Select(x => Pct(x.ActionsFromAmberOutcome, x.ActionCount)).ToList(),
        greenPct = rows.Select(x => Pct(x.ActionsFromGreenOutcome, x.ActionCount)).ToList(),
        otherPct = rows.Select(x => Pct(x.ActionsFromOtherOutcome, x.ActionCount)).ToList()
      },
      jsonOpts);
  }
  else
  {
    chartStdJson = JsonSerializer.Serialize(
      new
      {
        usePropensity = false,
        standards = m.StandardActionRows.Select(x => x.Standard).ToList(),
        actionCounts = m.StandardActionRows.Select(x => x.ActionCount).ToList(),
        assessmentCounts = m.StandardActionRows.Select(x => x.AssessmentCount).ToList()
      },
      jsonOpts);
  }

  string SasOutcomeTagClass(string? o) => o switch
  {
    { } s when s.Equals("Green", StringComparison.OrdinalIgnoreCase) => "govuk-tag--green",
    { } s when s.Equals("Amber", StringComparison.OrdinalIgnoreCase) => "govuk-tag--yellow",
    { } s when s.Equals("Red", StringComparison.OrdinalIgnoreCase) => "govuk-tag--red",
    _ => "govuk-tag--grey"
  };
}

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernReporting")">Reporting</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">Service assessments</li>
}

<div class="mr-dash sas-rpt" id="sas-top">
  <header class="sas-rpt__hero">
    <div class="dfe-c-page-title sas-rpt__title">
      <div class="dfe-c-page-title__caption">Reporting</div>
      <h1 class="dfe-c-page-title__heading">Service assessments</h1>
      <p class="dfe-c-page-title__lede sas-rpt__lede">
        Published data from the Service Assessment Service. Outcome breakdowns are <strong>Service assessment</strong> only. Phases and years use a fixed order; each chart matches the table beside it.
      </p>
    </div>
  </header>

  @if (TempData["ErrorMessage"] != null)
  {
    <div class="govuk-error-summary" data-module="govuk-error-summary" role="alert" style="margin-bottom: 1.5rem;">
      <h2 class="govuk-error-summary__title">There is a problem</h2>
      <div class="govuk-error-summary__body">@TempData["ErrorMessage"]</div>
    </div>
  }

  @if (m.SummaryLoadFailed)
  {
    <p class="govuk-body">Summary data is not available. If this continues, check SAS configuration in appsettings and network access to the service assessment API.</p>
  }
  else
  {
    @if (showKpis)
    {
      <section class="sas-rpt__kpis" aria-label="High level figures">
        <div class="sas-rpt__kpi">
          <span class="sas-rpt__kpi-value" id="sas-kpi-total">@m.TotalAssessments.ToString("N0")</span>
          <span class="sas-rpt__kpi-label">Published in summary</span>
        </div>
        @if (m.ByOutcome.Count > 0)
        {
          var topOutcome = m.ByOutcome.OrderByDescending(x => x.Value).First();
          <div class="sas-rpt__kpi">
            <span class="sas-rpt__kpi-value">@topOutcome.Value.ToString("N0")</span>
            <span class="sas-rpt__kpi-label">Largest outcome (Service assessment): @topOutcome.Key</span>
          </div>
        }
        @if (hasList)
        {
          <div class="sas-rpt__kpi">
            <span class="sas-rpt__kpi-value">@m.AssessmentRows.Count.ToString("N0")</span>
            <span class="sas-rpt__kpi-label">In published list (below)</span>
          </div>
        }
        <p class="sas-rpt__kpi-hint">
          <a class="govuk-link govuk-link--no-visited-state" href="#sas-list-heading">Skip to full list</a>
          <span class="sas-rpt__kpi-hint-sep" aria-hidden="true">·</span>
          <a class="govuk-link govuk-link--no-visited-state" href="#sas-std-heading">Actions by standard</a>
        </p>
      </section>
    }

    @if (hasSummaryTabular)
    {
      <section class="sas-rpt__block" aria-label="Report summary: charts and tables">
        <h2 class="sas-rpt__h2" id="sas-summary-h">At a glance</h2>
        <p class="govuk-hint govuk-!-margin-bottom-4 sas-rpt__h2-hint">Four views of the same published cohort — use whichever is easiest to scan.</p>

        <div class="sas-rpt__summary-grid">
          <article class="sas-rpt__cell" aria-labelledby="sas-outcome">
            <h3 class="sas-rpt__h3" id="sas-outcome">By outcome</h3>
            <p class="sas-rpt__cell-hint">Service assessment type only</p>
            @if (m.ByOutcome.Count == 0)
            {
              <p class="govuk-body dfe-c-text-muted sas-rpt__empty">No outcome data for Service assessments.</p>
            }
            else
            {
              <div class="sas-rpt__chart sas-rpt__chart--doughnut">
                <div class="mr-chart-wrap" style="min-height: 200px;">
                  <canvas id="sas-chart-outcome" role="img" aria-label="Outcomes for service assessments only"></canvas>
                </div>
              </div>
              <div class="sas-rpt__table-wrap dfe-c-table-wrap">
                <table class="mr-ba-table" aria-describedby="sas-outcome">
                  <thead>
                  <tr>
                    <th scope="col" class="mr-ba-table__area-col">Outcome</th>
                    <th scope="col" class="mr-ba-table__num-hdr">Count</th>
                  </tr>
                  </thead>
                  <tbody>
                  @foreach (var row in m.ByOutcome)
                  {
                    <tr>
                      <th scope="row" class="mr-ba-table__area-col">@row.Key</th>
                      <td class="mr-ba-table__num"><span class="mr-ba-num">@row.Value.ToString("N0")</span></td>
                    </tr>
                  }
                  </tbody>
                </table>
              </div>
            }
          </article>

          <article class="sas-rpt__cell" aria-labelledby="sas-type">
            <h3 class="sas-rpt__h3" id="sas-type">By type</h3>
            <p class="sas-rpt__cell-hint">All published assessment types</p>
            @if (m.ByType.Count == 0)
            {
              <p class="govuk-body dfe-c-text-muted sas-rpt__empty">No type data.</p>
            }
            else
            {
              <div class="sas-rpt__chart sas-rpt__chart--doughnut">
                <div class="mr-chart-wrap" style="min-height: 200px;">
                  <canvas id="sas-chart-type" role="img" aria-label="Distribution by assessment type"></canvas>
                </div>
              </div>
              <div class="sas-rpt__table-wrap dfe-c-table-wrap">
                <table class="mr-ba-table" aria-describedby="sas-type">
                  <thead>
                  <tr>
                    <th scope="col" class="mr-ba-table__area-col">Type</th>
                    <th scope="col" class="mr-ba-table__num-hdr">Count</th>
                  </tr>
                  </thead>
                  <tbody>
                  @foreach (var row in m.ByType)
                  {
                    <tr>
                      <th scope="row" class="mr-ba-table__area-col">@row.Key</th>
                      <td class="mr-ba-table__num"><span class="mr-ba-num">@row.Value.ToString("N0")</span></td>
                    </tr>
                  }
                  </tbody>
                </table>
              </div>
            }
          </article>

          <article class="sas-rpt__cell" aria-labelledby="sas-phase">
            <h3 class="sas-rpt__h3" id="sas-phase">By phase</h3>
            <p class="sas-rpt__cell-hint">Discovery → Live, then any other</p>
            @if (m.ByPhase.Count == 0)
            {
              <p class="govuk-body dfe-c-text-muted sas-rpt__empty">No phase data.</p>
            }
            else
            {
              <div class="sas-rpt__chart sas-rpt__chart--bar">
                <div class="mr-chart-wrap" style="min-height: 220px;">
                  <canvas id="sas-chart-phase" role="img" aria-label="Counts by delivery phase"></canvas>
                </div>
              </div>
              <div class="sas-rpt__table-wrap dfe-c-table-wrap">
                <table class="mr-ba-table" aria-describedby="sas-phase">
                  <thead>
                  <tr>
                    <th scope="col" class="mr-ba-table__area-col">Phase</th>
                    <th scope="col" class="mr-ba-table__num-hdr">Count</th>
                  </tr>
                  </thead>
                  <tbody>
                  @foreach (var row in m.ByPhase)
                  {
                    <tr>
                      <th scope="row" class="mr-ba-table__area-col">@row.Key</th>
                      <td class="mr-ba-table__num"><span class="mr-ba-num">@row.Value.ToString("N0")</span></td>
                    </tr>
                  }
                  </tbody>
                </table>
              </div>
            }
          </article>

          <article class="sas-rpt__cell" aria-labelledby="sas-year">
            <h3 class="sas-rpt__h3" id="sas-year">By year</h3>
            <p class="sas-rpt__cell-hint">Calendar year (ascending)</p>
            @if (m.ByYear.Count == 0)
            {
              <p class="govuk-body dfe-c-text-muted sas-rpt__empty">No year data.</p>
            }
            else
            {
              <div class="sas-rpt__chart sas-rpt__chart--bar">
                <div class="mr-chart-wrap" style="min-height: 200px;">
                  <canvas id="sas-chart-year" role="img" aria-label="Counts by year"></canvas>
                </div>
              </div>
              <div class="sas-rpt__table-wrap dfe-c-table-wrap">
                <table class="mr-ba-table" aria-describedby="sas-year">
                  <thead>
                  <tr>
                    <th scope="col" class="mr-ba-table__area-col">Year</th>
                    <th scope="col" class="mr-ba-table__num-hdr">Count</th>
                  </tr>
                  </thead>
                  <tbody>
                  @foreach (var row in m.ByYear)
                  {
                    <tr>
                      <th scope="row" class="mr-ba-table__area-col">@row.Key</th>
                      <td class="mr-ba-table__num"><span class="mr-ba-num">@row.Value.ToString("N0")</span></td>
                    </tr>
                  }
                  </tbody>
                </table>
              </div>
            }
          </article>
        </div>
      </section>
    }
  }

  @if (!m.ActionsByStandardLoadFailed)
  {
    <section class="sas-rpt__block sas-rpt__block--wide" id="sas-std-section" aria-labelledby="sas-std-heading">
      <h2 class="sas-rpt__h2" id="sas-std-heading" style="margin-top:0;">Actions by Service Standard</h2>
      @if (useStdPropensity)
      {
        <p class="govuk-hint govuk-!-margin-bottom-2">Per <abbr title="Government Service Standard">GSS</abbr> point for <strong>published</strong> <strong>Service assessment</strong> only. Each action is assigned the assessment’s <strong>overall</strong> Red / Amber / Green outcome, then the chart shows how action volume is split — so a large Red+Amber share flags standards under more pressure. Standards are sorted with the <strong>most challenging first</strong> (highest % of actions on Red or Amber outcome).</p>
        <p class="govuk-body-s govuk-!-margin-bottom-4 dfe-c-text-muted" style="max-width:44rem;">Ranks 1–3 in the table are highlighted. Use raw counts in the table for absolute size; the chart is 100% of actions per row so you can compare shape between standards (bar length is the same, mix differs).</p>
      }
      else
      {
        <p class="govuk-hint govuk-!-margin-bottom-4">Per <abbr title="Government Service Standard">GSS</abbr> point from the aggregate <abbr title="Service assessment service">SAS</abbr> view. A detailed RAG mix could not be loaded — the chart and table use total action and assessment counts only. If this persists, check SAS API configuration and connectivity.</p>
      }
      @if (hasStandardActions)
      {
        <div class="sas-rpt__standards-panels">
          <div class="sas-rpt__standards-chart">
            <div class="sas-rpt__chart sas-rpt__chart--standards">
              <div class="mr-chart-wrap" style="min-height: 320px;">
                <canvas id="sas-chart-standards" role="img" aria-label="Actions by service standard, @(useStdPropensity ? "share of actions by Red Amber Green and other outcomes" : "actions and assessment counts by standard number")"></canvas>
              </div>
            </div>
          </div>
          <div class="sas-rpt__standards-table dfe-c-table-wrap">
            @if (useStdPropensity)
            {
              <table class="mr-ba-table" aria-describedby="sas-std-heading">
                <caption class="govuk-visually-hidden">Most challenging standards (highest share of actions on Red or Amber) listed first; columns show outcome mix and total actions</caption>
                <thead>
                <tr>
                  <th scope="col" class="mr-ba-table__num-hdr" title="1 = most challenging (highest share of actions on Red or Amber overall outcome)">#</th>
                  <th scope="col" class="mr-ba-table__area-col">Standard</th>
                  <th scope="col" class="mr-ba-table__num-hdr" title="Percentage of this row's actions on assessments with Red or Amber overall outcome">Red+Amber</th>
                  <th scope="col" class="mr-ba-table__num-hdr">Red</th>
                  <th scope="col" class="mr-ba-table__num-hdr">Amber</th>
                  <th scope="col" class="mr-ba-table__num-hdr">Green</th>
                  <th scope="col" class="mr-ba-table__num-hdr">Other</th>
                  <th scope="col" class="mr-ba-table__num-hdr">Actions (total)</th>
                  <th scope="col" class="mr-ba-table__num-hdr">Assessments</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var row in m.StandardActionRows)
                {
                  var isHot = row.MostProblematicRank <= 3 && row.PctOnAmberOrRed is { } p && p > 0.001;
                  <tr class="@(isHot ? "sas-std--hot" : "")">
                    <td class="mr-ba-table__num">@row.MostProblematicRank</td>
                    <th scope="row" class="mr-ba-table__area-col">@row.Standard</th>
                    <td class="mr-ba-table__num"><span class="mr-ba-num">@(row.PctOnAmberOrRed is { } x ? $"{x:0.0}%" : "—")</span></td>
                    <td class="mr-ba-table__num"><span class="mr-ba-num">@row.ActionsFromRedOutcome.ToString("N0")</span></td>
                    <td class="mr-ba-table__num"><span class="mr-ba-num">@row.ActionsFromAmberOutcome.ToString("N0")</span></td>
                    <td class="mr-ba-table__num"><span class="mr-ba-num">@row.ActionsFromGreenOutcome.ToString("N0")</span></td>
                    <td class="mr-ba-table__num"><span class="mr-ba-num">@row.ActionsFromOtherOutcome.ToString("N0")</span></td>
                    <td class="mr-ba-table__num"><span class="mr-ba-num">@row.ActionCount.ToString("N0")</span></td>
                    <td class="mr-ba-table__num"><span class="mr-ba-num">@row.AssessmentCount.ToString("N0")</span></td>
                  </tr>
                }
                </tbody>
              </table>
            }
            else
            {
              <table class="mr-ba-table" aria-describedby="sas-std-heading">
                <thead>
                <tr>
                  <th scope="col" class="mr-ba-table__area-col">Standard</th>
                  <th scope="col" class="mr-ba-table__num-hdr">Actions</th>
                  <th scope="col" class="mr-ba-table__num-hdr">Assessments</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var row in m.StandardActionRows)
                {
                  <tr>
                    <th scope="row" class="mr-ba-table__area-col">@row.Standard</th>
                    <td class="mr-ba-table__num"><span class="mr-ba-num">@row.ActionCount.ToString("N0")</span></td>
                    <td class="mr-ba-table__num"><span class="mr-ba-num">@row.AssessmentCount.ToString("N0")</span></td>
                  </tr>
                }
                </tbody>
              </table>
            }
          </div>
        </div>
      }
      else
      {
        <p class="govuk-body dfe-c-text-muted">No actions-by-standard data returned.</p>
      }
    </section>
  }
  else
  {
    <section class="sas-rpt__block" aria-labelledby="sas-std-heading-fail">
      <h2 class="sas-rpt__h2" id="sas-std-heading-fail" style="margin-top:0;">Actions by Service Standard</h2>
      <p class="govuk-body" style="margin:0;">This section could not be loaded.</p>
    </section>
  }

  @if (!m.SummaryLoadFailed)
  {
    <section class="sas-rpt__block sas-rpt__block--list" id="published-assessments" aria-labelledby="sas-list-heading">
      <h2 class="sas-rpt__h2" id="sas-list-heading" style="margin-top:0;">Published assessment list</h2>
      @if (m.AssessmentsGroupedByType.Count > 0)
      {
        <p class="govuk-hint" style="margin:0.25rem 0 0;">@m.AssessmentRows.Count published assessment@(m.AssessmentRows.Count == 1 ? "" : "s") grouped by type. Report links open in a new tab.</p>
      }
      @if (m.AssessmentsGroupedByType.Count == 0 && !hasList)
      {
        <p class="govuk-body dfe-c-text-muted" style="margin:0;">No individual assessments in the response.</p>
      }
      @{
        var grpIndex = 0;
      }
      @foreach (var grp in m.AssessmentsGroupedByType)
      {
        var typeAnchor = $"sas-type-grp-{grpIndex++}";
        <div class="sas-rpt__type-panel">
          <h3 class="sas-rpt__h3" id="@typeAnchor">@grp.TypeLabel <span class="sas-rpt__type-badge">@grp.Items.Count</span></h3>
          <div class="dfe-c-table-wrap">
            <table class="mr-ba-table" aria-labelledby="@typeAnchor">
              <thead>
              <tr>
                <th scope="col" class="mr-ba-table__area-col">Outcome</th>
                <th scope="col" class="mr-ba-table__area-col">Name</th>
                <th scope="col" class="mr-ba-table__area-col">Phase</th>
                <th scope="col" class="mr-ba-table__area-col">Portfolio</th>
                <th scope="col" class="mr-ba-table__num-hdr">Assessment date</th>
                <th scope="col" class="mr-ba-table__area-col">Report</th>
              </tr>
              </thead>
              <tbody>
              @foreach (var a in grp.Items)
              {
                var reportUrl = $"{m.SasReportBaseUrl.TrimEnd('/')}/{a.AssessmentId}";
                <tr>
                  <td>
                    <span class="govuk-tag @SasOutcomeTagClass(a.Outcome)">@(!string.IsNullOrEmpty(a.Outcome) ? a.Outcome : "—")</span>
                  </td>
                  <td class="mr-ba-table__area-col">@(!string.IsNullOrEmpty(a.Name) ? a.Name : "—")</td>
                  <td class="mr-ba-table__area-col">@(a.Phase ?? "—")</td>
                  <td class="mr-ba-table__area-col">@(a.Portfolio ?? "—")</td>
                  <td class="mr-ba-table__num"><span class="mr-ba-num">@(a.AssessmentDate is { } ad ? ad.ToString("d MMM yyyy", System.Globalization.CultureInfo.GetCultureInfo("en-GB")) : "—")</span></td>
                  <td class="mr-ba-table__num"><a class="dfe-c-link" href="@reportUrl" rel="noopener noreferrer" target="_blank" aria-label="Open full report: @(a.Name?.Replace("\"", "") ?? "assessment")">View</a></td>
                </tr>
              }
              </tbody>
            </table>
          </div>
        </div>
      }
    </section>
  }
</div>

<style>
  .sas-rpt { width: 100%; max-width: 100%; box-sizing: border-box; padding-bottom: 1rem; }
  .sas-rpt__title { margin-bottom: 0; }
  .sas-rpt__lede { max-width: 40rem; margin: 0.5rem 0 0; line-height: 1.5; }
  .sas-rpt__block { margin-top: 2.25rem; }
  .sas-rpt__kpis + .sas-rpt__block { margin-top: 1.5rem; }
  .sas-rpt__hero + .sas-rpt__block { margin-top: 1.75rem; }
  .sas-rpt__h2 {
    font-size: 1.3125rem;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 0.5rem;
    padding-bottom: 0.4rem;
    border-bottom: 4px solid #0b0c0c;
    letter-spacing: -0.01em;
  }
  .sas-rpt__h2-hint { margin-top: -0.25rem; max-width: 44rem; }
  .sas-rpt__h3 {
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 0.2rem;
    color: #0b0c0c;
  }
  .sas-rpt__cell-hint {
    font-size: 0.875rem;
    line-height: 1.4;
    color: #505a5f;
    margin: 0 0 0.75rem;
  }
  .sas-rpt__empty { margin: 0.5rem 0 0; }

  .sas-rpt__kpis {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem 1.25rem;
    margin: 0.25rem 0 0.5rem;
    padding: 1.25rem 1.25rem 1rem;
    background: #f3f2f1;
    border: 1px solid #b1b4b6;
    max-width: 100%;
  }
  @@media (min-width: 40.0625em) {
    .sas-rpt__kpis { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  .sas-rpt__kpi {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .sas-rpt__kpi-value {
    font-size: 2.125rem;
    font-weight: 700;
    line-height: 1.1;
    font-variant-numeric: tabular-nums;
    color: #0b0c0c;
  }
  .sas-rpt__kpi-label { font-size: 0.875rem; line-height: 1.4; color: #505a5f; }
  .sas-rpt__kpi-hint {
    grid-column: 1 / -1;
    font-size: 0.875rem;
    color: #505a5f;
    margin: 0.5rem 0 0;
    padding-top: 0.5rem;
    border-top: 1px solid #b1b4b6;
  }
  .sas-rpt__kpi-hint-sep { margin: 0 0.4rem; color: #b1b4b6; }

  .sas-rpt__summary-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @@media (min-width: 64.0625em) {
    .sas-rpt__summary-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1.5rem; }
  }
  .sas-rpt__cell {
    background: #fff;
    border: 1px solid #b1b4b6;
    border-left: 4px solid #1d70b8;
    padding: 1.1rem 1.15rem 1.15rem;
    min-width: 0;
  }
  .sas-rpt__cell .sas-rpt__table-wrap { margin-top: 0.5rem; }
  .sas-rpt__chart { margin: 0 0 0.5rem; }
  .sas-rpt__chart--doughnut { max-width: 17rem; margin: 0 auto; }
  .sas-rpt__chart--bar { margin-left: 0; margin-right: 0; }

  .sas-rpt__standards-panels {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  @@media (min-width: 56.25em) {
    .sas-rpt__standards-panels {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    }
  }
  .sas-rpt__standards-chart {
    background: #fff;
    border: 1px solid #b1b4b6;
    padding: 1rem;
    min-width: 0;
  }
  .sas-rpt__standards-table { min-width: 0; }
  .sas-rpt .sas-std--hot th,
  .sas-rpt .sas-std--hot td {
    background: #fff3f0;
    box-shadow: inset 4px 0 0 0 #d4351c;
  }

  .sas-rpt__type-panel {
    margin-top: 1.5rem;
    background: #fff;
    border: 1px solid #b1b4b6;
    padding: 0.85rem 1rem 0;
  }
  .sas-rpt__type-panel:first-of-type { margin-top: 1.25rem; }
  .sas-rpt__type-panel .sas-rpt__h3 { display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.4rem 0.75rem; }
  .sas-rpt__type-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.35;
    padding: 0.15rem 0.5rem;
    border-radius: 0.2rem;
    background: #e6e5e3;
    color: #0b0c0c;
    vertical-align: middle;
  }
  .sas-rpt__type-panel .dfe-c-table-wrap { border: none; border-top: 1px solid #b1b4b6; }

  /* “Report” table styling: light header band, single rule under titles, row bands, no full grid (overrides global table/thead rules in this page only) */
  .sas-rpt .sas-rpt__table-wrap.dfe-c-table-wrap,
  .sas-rpt__standards-table.dfe-c-table-wrap,
  .sas-rpt__type-panel .dfe-c-table-wrap {
    border-color: #d0d0d0;
  }
  .sas-rpt .mr-ba-table {
    width: 100%;
    min-width: 0;
    border-collapse: collapse;
    font-size: 0.875rem;
    line-height: 1.45;
  }
  .sas-rpt .mr-ba-table thead th {
    background: #f3f2f1;
    color: #0b0c0c;
    font-weight: 600;
    font-size: 0.8125rem;
    letter-spacing: 0.01em;
    padding: 0.65rem 0.75rem;
    text-align: left;
    vertical-align: bottom;
    border: 0;
    border-bottom: 2px solid #0b0c0c;
    white-space: nowrap;
    position: static; /* not sticky: avoids clash with overflow-x */
  }
  .sas-rpt .mr-ba-table thead th.mr-ba-table__num-hdr { text-align: right; }
  .sas-rpt .mr-ba-table tbody th,
  .sas-rpt .mr-ba-table tbody td {
    padding: 0.5rem 0.75rem;
    border: 0;
    border-bottom: 1px solid #e8e8e8;
    vertical-align: middle;
  }
  .sas-rpt .mr-ba-table tbody tr:nth-child(even) { background: #fafafa; }
  .sas-rpt .mr-ba-table tbody tr:hover { background: #eef2f5 !important; }
  .sas-rpt .mr-ba-table tbody th[scope="row"] {
    font-weight: 600;
    text-align: left;
    color: #0b0c0c;
  }
  .sas-rpt .mr-ba-table__num { text-align: right; }
  .sas-rpt .mr-ba-table .mr-ba-num {
    font-variant-numeric: tabular-nums;
  }
  .sas-rpt .mr-ba-table .govuk-tag { white-space: normal; }
</style>

@section Scripts {
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" nonce="@Context.Items["Nonce"]"></script>
  <script nonce="@Context.Items["Nonce"]">
  (function () {
    if (typeof Chart === 'undefined') return;
    var font = { family: "'Inter', system-ui, -apple-system, sans-serif" };
    var byOutcome = @Html.Raw(chartOutcomeJson);
    var byType = @Html.Raw(chartTypeJson);
    var byPhase = @Html.Raw(chartPhaseJson);
    var byYear = @Html.Raw(chartYearJson);
    var byStd = @Html.Raw(chartStdJson);
    var colA = '#1d70b8';
    var colB = '#6f2f5f';
    var typeColors = [
      '#1d70b8', '#00703c', '#f47738', '#4c2c92', '#d4351c', '#0b0c0c',
      '#28a197', '#85994b', '#6f2f5f', '#a285d9'
    ];
    var axisOpts = { grid: { color: 'rgba(11, 12, 12, 0.08)' }, border: { display: false } };

    function colOutcome(label) {
      var t = (label || '').toLowerCase();
      if (t === 'green') return '#00703c';
      if (t === 'amber') return '#f47738';
      if (t === 'red') return '#d4351c';
      if (t.indexOf('not') >= 0) return '#6f777b';
      return '#1d70b8';
    }

    var cOut = document.getElementById('sas-chart-outcome');
    if (cOut && byOutcome && byOutcome.data && byOutcome.data.length) {
      new Chart(cOut.getContext('2d'), {
        type: 'doughnut',
        data: {
          labels: byOutcome.labels,
          datasets: [{ data: byOutcome.data, backgroundColor: (byOutcome.labels || []).map(colOutcome), borderWidth: 0 }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          font: font,
          cutout: '55%',
          plugins: {
            legend: {
              position: 'bottom',
              align: 'center',
              labels: { boxWidth: 11, font: { size: 11, family: font.family }, padding: 8, usePointStyle: true, pointStyle: 'rectRounded' }
            }
          }
        }
      });
    }

    var cTy = document.getElementById('sas-chart-type');
    if (cTy && byType && byType.data && byType.data.length) {
      new Chart(cTy.getContext('2d'), {
        type: 'pie',
        data: {
          labels: byType.labels,
          datasets: [{
            data: byType.data,
            backgroundColor: (byType.labels || []).map(function (_l, i) { return typeColors[i % typeColors.length]; }),
            borderWidth: 0
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          font: font,
          plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, font: { size: 11, family: font.family }, padding: 8 } } }
        }
      });
    }

    var cPh = document.getElementById('sas-chart-phase');
    if (cPh && byPhase && byPhase.data && byPhase.data.length) {
      new Chart(cPh.getContext('2d'), {
        type: 'bar',
        data: {
          labels: byPhase.labels,
          datasets: [{ label: 'Count', data: byPhase.data, backgroundColor: '#1d70b8', borderRadius: 2 }]
        },
        options: {
          indexAxis: 'y',
          responsive: true,
          maintainAspectRatio: false,
          font: font,
          plugins: { legend: { display: false } },
          scales: { x: { beginAtZero: true, ticks: { precision: 0, font: { size: 11, family: font.family } }, ...axisOpts }, y: { ticks: { font: { size: 11, family: font.family } }, ...axisOpts } }
        }
      });
    }

    var cYr = document.getElementById('sas-chart-year');
    if (cYr && byYear && byYear.data && byYear.data.length) {
      new Chart(cYr.getContext('2d'), {
        type: 'bar',
        data: {
          labels: byYear.labels,
          datasets: [{ label: 'Count', data: byYear.data, backgroundColor: '#1d70b8', borderRadius: 2 }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          font: font,
          plugins: { legend: { display: false } },
          scales: { y: { beginAtZero: true, ticks: { precision: 0, font: { size: 11, family: font.family } }, ...axisOpts }, x: { ticks: { font: { size: 11, family: font.family } }, ...axisOpts } }
        }
      });
    }

    var cSt = document.getElementById('sas-chart-standards');
    if (cSt && byStd && byStd.standards && byStd.standards.length) {
      var colRed = '#b10e1e';
      var colAmber = '#f47738';
      var colGreen = '#00703c';
      var colOth = '#6f777b';
      if (byStd.usePropensity) {
        new Chart(cSt.getContext('2d'), {
          type: 'bar',
          data: {
            labels: (byStd.standards || []).map(function (s) { return 'Std ' + s; }),
            datasets: [
              { label: 'Red (share of row)', data: byStd.redPct, backgroundColor: colRed, borderRadius: 0, stack: 'rag' },
              { label: 'Amber (share of row)', data: byStd.amberPct, backgroundColor: colAmber, borderRadius: 0, stack: 'rag' },
              { label: 'Green (share of row)', data: byStd.greenPct, backgroundColor: colGreen, borderRadius: 0, stack: 'rag' },
              { label: 'Other (share of row)', data: byStd.otherPct, backgroundColor: colOth, borderRadius: 0, stack: 'rag' }
            ]
          },
          options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            font: font,
            interaction: { mode: 'index', axis: 'y' },
            plugins: {
              title: { display: true, text: '100% of actions per standard — compare mix, not total bar length', font: { size: 12, family: font.family, weight: '400' } },
              tooltip: {
                callbacks: {
                  label: function (c) {
                    var n = c.dataset.label || '';
                    if (c.parsed && typeof c.parsed.x === 'number') { return n + ': ' + c.parsed.x.toFixed(1) + '%'; }
                    return n;
                  }
                }
              },
              legend: { position: 'bottom', labels: { font: { size: 12, family: font.family }, boxWidth: 12, padding: 8 } }
            },
            scales: {
              x: { stacked: true, max: 100, min: 0, ticks: { callback: function (v) { return v + '%'; }, font: { size: 11, family: font.family } }, ...axisOpts },
              y: { stacked: true, ticks: { font: { size: 11, family: font.family } }, ...axisOpts }
            }
          }
        });
      } else {
        new Chart(cSt.getContext('2d'), {
          type: 'bar',
          data: {
            labels: (byStd.standards || []).map(function (s) { return 'Std ' + s; }),
            datasets: [
              { label: 'Actions', data: byStd.actionCounts, backgroundColor: colA, borderRadius: 2 },
              { label: 'Assessments', data: byStd.assessmentCounts, backgroundColor: colB, borderRadius: 2 }
            ]
          },
          options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            font: font,
            interaction: { mode: 'index', axis: 'y' },
            plugins: {
              legend: { position: 'bottom', labels: { font: { size: 12, family: font.family }, boxWidth: 12, padding: 10 } }
            },
            scales: { x: { beginAtZero: true, ticks: { precision: 0, font: { size: 11, family: font.family } }, ...axisOpts }, y: { stacked: false, ticks: { font: { size: 11, family: font.family } }, ...axisOpts } }
          }
        });
      }
    }
  })();
  </script>
}
