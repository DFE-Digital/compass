@model Compass.ViewModels.Modern.CustomReportViewViewModel
@using Compass.Models.Modern.Work
@{
    var mwDetailPrefix = Url.Content("~/modern/work/detail/") ?? "/modern/work/detail/";
    var submitted = Model.MonthlyUpdateRows.Count(r => r.SubmittedAt.HasValue);
    var total = Model.MonthlyUpdateRows.Count;
}
@if (total == 0)
{
<p class="govuk-body">No monthly update data available.</p>
}
else
{
<div class="dfe-f-card-grid govuk-!-margin-bottom-4">
    <div class="dfe-f-stat-card">
        <p class="govuk-body-s dfe-f-stat-card__label">Submitted</p>
        <p class="dfe-f-stat-card__value dfe-f-u-tabular-numbers govuk-body-l">@submitted / @total</p>
    </div>
</div>
<div class="dfe-f-table-wrapper" data-module="dfe-f-table">
    <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed">
        <thead class="govuk-table__head">
            <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Work item</button></th>
                <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">RAG</button></th>
                <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Submitted</button></th>
                <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Narrative</button></th>
            </tr>
        </thead>
        <tbody class="govuk-table__body">
            @foreach (var r in Model.MonthlyUpdateRows)
            {
            <tr class="govuk-table__row">
                <td class="govuk-table__cell"><a class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold" href="@(mwDetailPrefix)@r.ProjectId">@r.Title</a></td>
                <td class="govuk-table__cell"><span class="@WorkBadgeCss.RagCompactBadgeClass(r.Rag ?? "Not set")">@(r.Rag ?? "Not set")</span></td>
                <td class="govuk-table__cell">@(r.SubmittedAt.HasValue ? r.SubmittedAt.Value.ToString("d MMM yyyy") : "Not submitted")</td>
                <td class="govuk-table__cell" style="max-width:28rem; white-space:pre-wrap; word-break:break-word; line-height:1.45;">@(string.IsNullOrWhiteSpace(r.UpdateSummary) ? "—" : r.UpdateSummary)</td>
            </tr>
            }
        </tbody>
    </table>
</div>
}
