@model Compass.ViewModels.Modern.CustomReportViewViewModel
@using Compass.Models.Modern.Work
@{
    var mwDetailPrefix = Url.Content("~/modern/work/detail/") ?? "/modern/work/detail/";
}
@if (Model.RagPriorityRows.Count == 0)
{
<p class="govuk-body">No RAG and priority data available.</p>
}
else
{
<div class="dfe-f-table-wrapper" data-module="dfe-f-table">
    <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed">
        <thead class="govuk-table__head">
            <tr class="govuk-table__row">
                <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Work item</button></th>
                <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">RAG</button></th>
                <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Previous RAG</button></th>
                <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Priority</button></th>
                <th scope="col" class="govuk-table__header" aria-sort="none"><button type="button" class="dfe-f-table-sort-button">Business area</button></th>
            </tr>
        </thead>
        <tbody class="govuk-table__body">
            @foreach (var r in Model.RagPriorityRows)
            {
            <tr class="govuk-table__row">
                <td class="govuk-table__cell"><a class="govuk-link govuk-link--no-visited-state govuk-!-font-weight-bold" href="@(mwDetailPrefix)@r.ProjectId">@r.Title</a></td>
                <td class="govuk-table__cell"><span class="@WorkBadgeCss.RagCompactBadgeClass(r.Rag ?? "Not set")">@(r.Rag ?? "Not set")</span></td>
                <td class="govuk-table__cell"><span class="@WorkBadgeCss.RagCompactBadgeClass(r.PreviousRag ?? "Not set")">@(r.PreviousRag ?? "—")</span></td>
                <td class="govuk-table__cell"><span class="@(WorkBadgeCss.PriorityDfeFrontendBadgeClass(r.Priority ?? "Not set") + " dfe-f-badge--small")">@(r.Priority ?? "Not set")</span></td>
                <td class="govuk-table__cell">@(r.BusinessArea ?? "—")</td>
            </tr>
            }
        </tbody>
    </table>
</div>
}
