@using Compass.ViewModels.Modern
@model ModernServiceAssessmentsReportViewModel
@{
  var m = Model;
  var sa = m.StandardsAnalysis;
  var hasStdAnalysis = sa.StandardPoints.Any(p => p.ActionCount > 0);
  var trendMonths = sa.TrendComparisonMonths > 0 ? sa.TrendComparisonMonths : 6;
  var pointsWithActions = sa.StandardPoints.Where(x => x.ActionCount > 0).ToList();

  string SasOutcomeBadgeModifier(string? o) => o switch
  {
    { } s when s.Equals("Green", StringComparison.OrdinalIgnoreCase) => "dfe-f-badge--green",
    { } s when s.Equals("Amber", StringComparison.OrdinalIgnoreCase) => "dfe-f-badge--orange",
    { } s when s.Equals("Red", StringComparison.OrdinalIgnoreCase) => "dfe-f-badge--red",
    _ => "dfe-f-badge--grey"
  };

  string SasTrendBadgeModifier(string trend) => trend switch
  {
    "Increasing" => "dfe-f-badge--red",
    "Decreasing" => "dfe-f-badge--green",
    _ => "dfe-f-badge--grey"
  };
}

<section class="sas-rpt__block" id="sas-standards-analysis" aria-labelledby="sas-standards-analysis-h">
  <h2 class="sas-rpt__h2" id="sas-standards-analysis-h">Standards analysis</h2>
  <p class="govuk-hint govuk-!-margin-bottom-4 sas-rpt__h2-hint">
    Published <strong>Service assessment</strong> actions across Government Service Standard points 1–14.
    Trends compare the last @trendMonths months with the previous @trendMonths months (by action created date), using actions per assessment so volume tracks proportionately with assessment activity.
    Actions over time shows the last six UK financial quarters.
  </p>

  @if (!hasStdAnalysis)
  {
    <p class="govuk-body dfe-c-text-muted">Detailed action data is not available. Check SAS API connectivity and the assessments/actions endpoint.</p>
  }
  else
  {
    @if (sa.IncreasingStandards.Count > 0)
    {
      <div class="sas-rpt__callout sas-rpt__callout--warn" role="note">
        <h3 class="govuk-heading-s govuk-!-margin-top-0">Points with rising action volume</h3>
        <p class="govuk-body govuk-!-margin-bottom-2">
          These service standards have a higher actions-per-assessment rate in the last @trendMonths months than the previous @trendMonths months:
          @string.Join(", ", sa.IncreasingStandards.Select(p => $"Point {p.Standard}"))
        </p>
        <ul class="govuk-list govuk-!-margin-bottom-0">
          @foreach (var p in sa.IncreasingStandards.Take(5))
          {
            <li>
              <a class="govuk-link govuk-link--no-visited-state" href="#sas-std-detail-@p.Standard">Point @p.Standard</a>
              — @p.ActionsRecentPeriod recent vs @p.ActionsPriorPeriod prior (@p.ActionCount total)
            </li>
          }
        </ul>
      </div>
    }

    <div class="sas-rpt__summary-grid govuk-!-margin-bottom-4">
      <article class="sas-panel" data-sas-panel="std-year-trend">
        <header class="sas-panel__head">
          <div class="sas-panel__title-wrap">
            <h3 class="sas-rpt__h3">Actions over time</h3>
            <p class="sas-rpt__cell-hint govuk-!-margin-bottom-0">Total GSS actions per financial quarter (last six quarters)</p>
          </div>
          <div class="sas-panel__tools">
            <div class="sas-panel__view" role="group" aria-label="Show actions over time as">
              <button type="button" class="sas-panel__view-btn is-active" data-sas-view="chart" aria-pressed="true">Chart</button>
              <button type="button" class="sas-panel__view-btn" data-sas-view="table" aria-pressed="false">Table</button>
            </div>
            <button type="button" class="govuk-button govuk-button--secondary govuk-button--small sas-panel__expand" aria-expanded="false">Expand</button>
          </div>
        </header>
        <div class="sas-panel__body">
          <div class="sas-panel__pane sas-panel__pane--chart">
            <div class="sas-panel__chart-wrap">
              <canvas id="sas-chart-std-year-total" role="img" aria-label="Total GSS actions by financial quarter"></canvas>
            </div>
          </div>
          <div class="sas-panel__pane sas-panel__pane--table" hidden>
            <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
              <table class="govuk-table mr-ba-table">
                <thead class="govuk-table__head">
                  <tr class="govuk-table__row">
                    <th scope="col" class="govuk-table__header">Quarter</th>
                    <th scope="col" class="govuk-table__header mr-ba-table__num-hdr">Actions</th>
                  </tr>
                </thead>
                <tbody class="govuk-table__body">
                  @for (var i = 0; i < sa.TrendPeriodLabels.Count; i++)
                  {
                    var label = sa.TrendPeriodLabels[i];
                    var total = i < sa.TrendPeriodTotals.Count ? sa.TrendPeriodTotals[i] : 0;
                    <tr class="govuk-table__row">
                      <th scope="row">@label</th>
                      <td class="mr-ba-table__num"><span class="mr-ba-num">@total.ToString("N0")</span></td>
                    </tr>
                  }
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </article>

      <article class="sas-panel" data-sas-panel="std-period">
        <header class="sas-panel__head">
          <div class="sas-panel__title-wrap">
            <h3 class="sas-rpt__h3">Recent vs prior @trendMonths months</h3>
            <p class="sas-rpt__cell-hint govuk-!-margin-bottom-0">Action counts by service standard — trend uses actions per assessment</p>
          </div>
          <div class="sas-panel__tools">
            <div class="sas-panel__view" role="group" aria-label="Show period comparison as">
              <button type="button" class="sas-panel__view-btn is-active" data-sas-view="chart" aria-pressed="true">Chart</button>
              <button type="button" class="sas-panel__view-btn" data-sas-view="table" aria-pressed="false">Table</button>
            </div>
            <button type="button" class="govuk-button govuk-button--secondary govuk-button--small sas-panel__expand" aria-expanded="false">Expand</button>
          </div>
        </header>
        <div class="sas-panel__body">
          <div class="sas-panel__pane sas-panel__pane--chart">
            <div class="sas-panel__chart-wrap">
              <canvas id="sas-chart-std-period" role="img" aria-label="GSS actions last @trendMonths months compared with prior @trendMonths months"></canvas>
            </div>
          </div>
          <div class="sas-panel__pane sas-panel__pane--table" hidden>
            <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
              <table class="govuk-table mr-ba-table">
                <thead class="govuk-table__head">
                  <tr class="govuk-table__row">
                    <th scope="col" class="govuk-table__header">Service standard</th>
                    <th scope="col" class="govuk-table__header mr-ba-table__num-hdr">Last @trendMonths m</th>
                    <th scope="col" class="govuk-table__header mr-ba-table__num-hdr">Prior @trendMonths m</th>
                    <th scope="col" class="govuk-table__header">Trend</th>
                    <th scope="col" class="govuk-table__header mr-ba-table__num-hdr">Total</th>
                  </tr>
                </thead>
                <tbody class="govuk-table__body">
                  @foreach (var p in sa.StandardPoints)
                  {
                    <tr class="govuk-table__row">
                      <th scope="row">@p.Standard — @p.StandardTitle</th>
                      <td class="mr-ba-table__num"><span class="mr-ba-num">@p.ActionsRecentPeriod.ToString("N0")</span></td>
                      <td class="mr-ba-table__num"><span class="mr-ba-num">@p.ActionsPriorPeriod.ToString("N0")</span></td>
                      <td><span class="dfe-f-badge dfe-f-badge--small @SasTrendBadgeModifier(p.TrendLabel)">@p.TrendLabel</span></td>
                      <td class="mr-ba-table__num"><span class="mr-ba-num">@p.ActionCount.ToString("N0")</span></td>
                    </tr>
                  }
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </article>
    </div>

    <h3 class="govuk-heading-m govuk-!-margin-top-6" id="sas-actions-per-standard-h">Actions per service standard</h3>
    <p class="govuk-hint govuk-!-margin-bottom-4">Expand a standard for outcome mix, status breakdown, and all actions.</p>

    <div class="dfe-f-toggle-group govuk-!-margin-bottom-0" data-module="dfe-f-toggle-group">
      <div class="dfe-f-toggle-group__controls govuk-body-s govuk-!-margin-bottom-2">
        <button type="button" class="dfe-f-toggle-group__action" data-dfe-toggle-expand-all>Expand all</button>
        <span class="dfe-f-toggle-group__separator" aria-hidden="true"> · </span>
        <button type="button" class="dfe-f-toggle-group__action" data-dfe-toggle-collapse-all>Collapse all</button>
      </div>
      <div class="dfe-f-toggle-group__items">
        @foreach (var p in pointsWithActions)
        {
          <div class="dfe-f-toggle" data-module="dfe-f-toggle" id="sas-std-detail-@p.Standard">
            <div class="dfe-f-toggle__title-wrapper">
              <h4 class="dfe-f-toggle__heading govuk-!-margin-bottom-0">
                <button type="button"
                        class="dfe-f-toggle__button"
                        aria-expanded="false"
                        aria-controls="sas-std-panel-@p.Standard"
                        id="sas-std-toggle-@p.Standard">
                  <span class="dfe-f-toggle__icon" aria-hidden="true"></span>
                  <span class="dfe-f-toggle__title">Point @p.Standard — @p.StandardTitle</span>
                  <span class="mr-toggle-panel__meta"><span class="dfe-f-badge dfe-f-badge--small @SasTrendBadgeModifier(p.TrendLabel)">@p.TrendLabel</span></span>
                </button>
              </h4>
            </div>
            <div id="sas-std-panel-@p.Standard" class="dfe-f-toggle__content" hidden>
              <div class="dfe-f-toggle__body">
                <div class="govuk-grid-row">
                  <div class="govuk-grid-column-one-half-from-desktop">
                    <h5 class="govuk-heading-s">Volume</h5>
                    <ul class="govuk-list">
                      <li>Total actions: <strong>@p.ActionCount.ToString("N0")</strong></li>
                      <li>Assessments: <strong>@p.AssessmentCount.ToString("N0")</strong></li>
                      <li>Last @trendMonths months: <strong>@p.ActionsRecentPeriod.ToString("N0")</strong> (@p.AssessmentsRecentPeriod assessments)</li>
                      <li>Prior @trendMonths months: <strong>@p.ActionsPriorPeriod.ToString("N0")</strong> (@p.AssessmentsPriorPeriod assessments)</li>
                      @if (p.ActionsWithoutDate > 0)
                      {
                        <li class="govuk-body-s dfe-c-text-muted">@p.ActionsWithoutDate action(s) without a created date</li>
                      }
                    </ul>
                    @if (p.ActionsByOutcome.Count > 0)
                    {
                      <h5 class="govuk-heading-s govuk-!-margin-top-4">By assessment outcome</h5>
                      <ul class="govuk-list">
                        @foreach (var o in p.ActionsByOutcome)
                        {
                          <li><span class="dfe-f-badge dfe-f-badge--small @SasOutcomeBadgeModifier(o.Key)">@o.Key</span> @o.Value.ToString("N0")</li>
                        }
                      </ul>
                    }
                  </div>
                  <div class="govuk-grid-column-one-half-from-desktop">
                    @if (p.ActionsByStatus.Count > 0)
                    {
                      <h5 class="govuk-heading-s">By status</h5>
                      <ul class="govuk-list">
                        @foreach (var s in p.ActionsByStatus)
                        {
                          <li>@s.Key: <strong>@s.Value.ToString("N0")</strong></li>
                        }
                      </ul>
                    }
                  </div>
                </div>

                @if (p.Actions.Count > 0)
                {
                  <h5 class="govuk-heading-s govuk-!-margin-top-4">Actions (@p.Actions.Count.ToString("N0"))</h5>
                  <div class="dfe-f-table-wrapper" data-module="dfe-f-table">
                    <table class="govuk-table mr-ba-table govuk-!-margin-bottom-0">
                      <thead class="govuk-table__head">
                        <tr class="govuk-table__row">
                          <th scope="col" class="govuk-table__header">Assessment</th>
                          <th scope="col" class="govuk-table__header">Outcome</th>
                          <th scope="col" class="govuk-table__header">Status</th>
                          <th scope="col" class="govuk-table__header">Created</th>
                          <th scope="col" class="govuk-table__header">Comment</th>
                        </tr>
                      </thead>
                      <tbody class="govuk-table__body">
                        @foreach (var a in p.Actions)
                        {
                          <tr class="govuk-table__row">
                            <td>@a.AssessmentName</td>
                            <td>
                              @if (!string.IsNullOrEmpty(a.Outcome))
                              {
                                <span class="dfe-f-badge dfe-f-badge--small @SasOutcomeBadgeModifier(a.Outcome)">@a.Outcome</span>
                              }
                              else
                              {
                                <span>—</span>
                              }
                            </td>
                            <td>@(a.Status ?? "—")</td>
                            <td>@(a.Created?.ToString("d MMM yyyy") ?? "—")</td>
                            <td><p class="sas-rpt__theme-snippet govuk-!-margin-bottom-0">@(string.IsNullOrEmpty(a.Comment) ? "—" : a.Comment)</p></td>
                          </tr>
                        }
                      </tbody>
                    </table>
                  </div>
                }
              </div>
            </div>
          </div>
        }
      </div>
    </div>
  }
</section>
