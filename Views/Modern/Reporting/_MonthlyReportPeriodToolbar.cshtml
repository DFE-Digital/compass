@model Compass.ViewModels.Modern.MonthlyReportPeriodToolbarViewModel
@{
  var t = Model ?? new Compass.ViewModels.Modern.MonthlyReportPeriodToolbarViewModel();
  var maxY = t.MaxReportYear >= t.MinReportYear ? t.MaxReportYear : DateTime.UtcNow.Year;
  var minY = t.MinReportYear;
  if (maxY < minY) { maxY = minY; }
}

<div class="mr-toolbar mr-toolbar--compact govuk-!-margin-bottom-3">
  <div class="mr-toolbar__row">
    <div class="mr-toolbar__nav mr-toolbar__nav--compact">
      @if (t.HasPreviousMonthNav && t.PreviousNavYear.HasValue && t.PreviousNavMonth.HasValue)
      {
        <a class="govuk-link mr-toolbar__nav-link govuk-link--no-visited-state" href="@t.PreviousNavUrl">← @(new DateTime(t.PreviousNavYear.Value, t.PreviousNavMonth.Value, 1).ToString("MMM yy"))</a>
      }
      <span class="mr-toolbar__period">
        @t.MonthName
        @if (!string.IsNullOrWhiteSpace(t.PeriodMeta))
        {
          <span class="dfe-c-text-muted">@t.PeriodMeta</span>
        }
      </span>
      @if (t.HasNextMonthNav && t.NextNavYear.HasValue && t.NextNavMonth.HasValue)
      {
        <a class="govuk-link mr-toolbar__nav-link govuk-link--no-visited-state" href="@t.NextNavUrl">@(new DateTime(t.NextNavYear.Value, t.NextNavMonth.Value, 1).ToString("MMM yy")) →</a>
      }
    </div>
    <form method="get" action="@t.FormAction" class="mr-toolbar__filters mr-toolbar__filters--compact" data-page-loading>
      <select name="year" class="govuk-select mr-toolbar__filter--year" id="@t.FilterYearId" aria-label="Year">
        @for (var y = maxY; y >= minY; y--)
        {
          if (t.ReportYear == y) { <option value="@y" selected>@y</option> }
          else { <option value="@y">@y</option> }
        }
      </select>
      <select name="month" class="govuk-select mr-toolbar__filter--month" id="@t.FilterMonthId" aria-label="Month">
        @for (var mo = 1; mo <= 12; mo++)
        {
          if (t.ReportMonth == mo) { <option value="@mo" selected>@(new DateTime(2000, mo, 1).ToString("MMM"))</option> }
          else { <option value="@mo">@(new DateTime(2000, mo, 1).ToString("MMM"))</option> }
        }
      </select>
      <select name="businessAreaId" class="govuk-select mr-toolbar__filter--business-area" id="@t.FilterBusinessAreaIdElement" aria-label="Business area">
        <option value="">All areas</option>
        @foreach (var ba in t.BusinessAreas)
        {
          if (t.FilterBusinessAreaId == ba.Id) { <option value="@ba.Id" selected>@ba.Name</option> }
          else { <option value="@ba.Id">@ba.Name</option> }
        }
      </select>
      <select name="directorateId" class="govuk-select mr-toolbar__filter--directorate" id="@t.FilterDirectorateIdElement" aria-label="Directorate">
        <option value="">All directorates</option>
        @foreach (var d in t.Directorates)
        {
          if (t.FilterDirectorateId == d.Id) { <option value="@d.Id" selected>@d.Name</option> }
          else { <option value="@d.Id">@d.Name</option> }
        }
      </select>
      <button type="submit" class="govuk-button mr-toolbar__filter--apply govuk-!-margin-bottom-0" id="@t.FilterApplyId">Apply</button>
    </form>
  </div>
</div>
