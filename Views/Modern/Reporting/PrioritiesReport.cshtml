@using System.Linq
@using System.Text.Json
@using System.Text.Json.Serialization
@using Compass.Models.Modern.Work
@using Compass.ViewModels
@using Compass.ViewModels.Modern
@model ModernPrioritiesReportViewModel
@{
  ViewData["Title"] = "Priorities report";
  var pr = Model;
  var m = pr.Report;
  var jsonOpts = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase, DefaultIgnoreCondition = JsonIgnoreCondition.WhenWritingNull };
  var baProjectsDict = pr.DimensionSections
    .SelectMany(s => s.Rows.Select(r => new { s.Dimension, Row = r }))
    .ToDictionary(x => $"{x.Dimension}|{x.Row.BusinessArea}", x => x.Row.Projects);
  foreach (var section in pr.DimensionSections)
  {
    baProjectsDict[$"{section.Dimension}|Total"] = section.Rows
      .SelectMany(r => r.Projects)
      .GroupBy(p => p.Id)
      .Select(g => g.First())
      .ToList();
  }
  var mwDetailPrefix = Url.Content("~/modern/work/detail/") ?? "/modern/work/detail/";
  var drillExportUrl = Url.Action("ExportDrilldown", "ModernReporting", new { source = "priorities" }) ?? "";
  var drillScriptModel = ReportingDrilldownConfig.Build(
    baProjectsDict,
    m.ScopeProjectItems,
    drillExportUrl,
    new Dictionary<string, string?>
    {
      ["source"] = "priorities",
      ["year"] = m.ReportYear.ToString(),
      ["month"] = m.ReportMonth.ToString(),
      ["groupId"] = m.PrioritiesReport?.FilterGroupId?.ToString()
    },
    mwDetailPrefix,
    new Dictionary<string, string>
    {
      ["mission"] = "Mission pillar",
      ["outcomes"] = "Priority outcome",
      ["priority"] = "Delivery priority"
    });
  var dimensionSections = pr.DimensionSections;

  string RagBadgeClass(string rag) => WorkBadgeCss.RagBadgeClass(rag);
  string PriBadgeClass(string pri) => pri switch
  {
    "Critical" or "High" => "dfe-c-tag dfe-c-tag--red",
    "Medium" => "dfe-c-tag dfe-c-tag--amber",
    "Low" => "dfe-c-tag dfe-c-tag--green",
    _ => "dfe-c-tag dfe-c-tag--grey"
  };
  string MatrixCellClass(string rag, string pri, int count)
  {
    if (count == 0) return "mr-mx__cell mr-mx__cell--zero";
    return rag switch
    {
      "Red" => pri is "Critical" or "High" ? "mr-mx__cell mr-mx__cell--critical" : "mr-mx__cell mr-mx__cell--high",
      "Amber-Red" => pri is "Critical" or "High" ? "mr-mx__cell mr-mx__cell--high" : "mr-mx__cell mr-mx__cell--medium",
      "Amber-Green" => "mr-mx__cell mr-mx__cell--medium",
      "Green" => "mr-mx__cell mr-mx__cell--low",
      _ => "mr-mx__cell mr-mx__cell--neutral"
    };
  }
  var ragKeys = new[] { "Red", "Amber-Red", "Amber-Green", "Green", "Not Set" };
  var priKeys = new[] { "Not Set", "Low", "Medium", "High", "Critical" };
  var matrixLookup = m.RagPriorityMatrix.ToDictionary(c => c.Rag + "|" + c.Priority, c => c.Count);
  var prSubmissionTotal = m.MonthlyUpdateStats?.TotalProjects ?? m.TotalActiveProjects;
}

@section Breadcrumbs {
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Index", "ModernDashboard")">Home</a></li>
  <li class="govuk-breadcrumbs__list-item"><a class="govuk-breadcrumbs__link" href="@Url.Action("Dashboard", "ModernReporting")">Reporting</a></li>
  <li class="govuk-breadcrumbs__list-item" aria-current="page">Priorities report</li>
}

<div class="mr-dash">
  @{
    var prHeaderLede = await Html.PartialAsync("_ReportingMutedBodyLede", "Monthly portfolio metrics by mission pillar, priority outcome, and delivery priority — submission, milestones, RAG and priority breakdown.");
  }
  @await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
    Caption = "Reporting",
    Title = $"Priorities report — {m.MonthName}",
    Lede = prHeaderLede
  })

  @if (TempData["ErrorMessage"] != null)
  {
    <div class="dfe-c-error-summary" role="alert" style="margin-bottom:1.5rem;">
      <p class="dfe-c-body" style="margin:0;">@TempData["ErrorMessage"]</p>
    </div>
  }

  @await Html.PartialAsync("_PrioritiesReportToolbar", pr)


  <div class="dfe-f-toggle-group mr-report-toggle-group govuk-!-margin-bottom-3" data-module="dfe-f-toggle-group" id="pr-report-sections">
    <div class="dfe-f-toggle-group__controls govuk-body-s govuk-!-margin-bottom-2 mr-report-toggle-group__controls">
      <button type="button" class="dfe-f-toggle-group__action" data-dfe-toggle-expand-all>Expand all</button>
      <span class="dfe-f-toggle-group__separator" aria-hidden="true"> · </span>
      <button type="button" class="dfe-f-toggle-group__action" data-dfe-toggle-collapse-all>Collapse all</button>
    </div>
    <div class="dfe-f-toggle-group__items">

      <div class="mr-report-section-panel dfe-f-toggle govuk-!-margin-bottom-3" data-module="dfe-f-toggle" data-mr-section-id="submission" data-mr-section-title="Submission summary">
        <div class="dfe-f-toggle__title-wrapper">
          <h2 class="dfe-f-toggle__heading">
            <button type="button" class="dfe-f-toggle__button" aria-expanded="true" aria-controls="pr-toggle-submission-content" id="pr-toggle-submission-button">
              <span class="dfe-f-toggle__icon" aria-hidden="true"></span>
              <span class="dfe-f-toggle__title">Submission summary</span>
              <span class="mr-toggle-panel__meta"><span class="govuk-tag govuk-tag--grey">@prSubmissionTotal</span></span>
            </button>
          </h2>
        </div>
        <div id="pr-toggle-submission-content" class="dfe-f-toggle__content">
          <div class="dfe-f-toggle__body govuk-body">
            @await Html.PartialAsync("_PrioritiesReportSummaryBody", m)
          </div>
        </div>
      </div>

      @foreach (var dimSection in dimensionSections)
      {
        var sectionCount = dimSection.Rows.Sum(r => r.TotalProjects);
        var sectionSlug = dimSection.Dimension;
        <div class="mr-report-section-panel dfe-f-toggle govuk-!-margin-bottom-3" data-module="dfe-f-toggle" data-mr-section-id="group-summary-@sectionSlug" data-mr-section-title="@(dimSection.GroupColumnLabel) summary">
        <div class="dfe-f-toggle__title-wrapper">
          <h2 class="dfe-f-toggle__heading">
            <button type="button" class="dfe-f-toggle__button" aria-expanded="true" aria-controls="pr-toggle-group-@sectionSlug-content" id="pr-toggle-group-@sectionSlug-button">
              <span class="dfe-f-toggle__icon" aria-hidden="true"></span>
              <span class="dfe-f-toggle__title">@(dimSection.GroupColumnLabel) summary</span>
              <span class="mr-toggle-panel__meta"><span class="govuk-tag govuk-tag--grey">@sectionCount</span></span>
            </button>
          </h2>
        </div>
        <div id="pr-toggle-group-@sectionSlug-content" class="dfe-f-toggle__content">
          <div class="dfe-f-toggle__body govuk-body">
            @await Html.PartialAsync("_PrioritiesReportGroupSummaryTable", new PrioritiesReportGroupSummaryViewModel {
              Dimension = dimSection.Dimension,
              GroupColumnLabel = dimSection.GroupColumnLabel,
              Rows = dimSection.Rows,
              TableId = dimSection.TableId
            })
          </div>
        </div>
      </div>
      }

      @await Html.PartialAsync("_ReportingDrilldownPanel")
      @await Html.PartialAsync("_ReportingWorkItemModal")

      <div class="mr-report-section-panel dfe-f-toggle govuk-!-margin-bottom-3" data-module="dfe-f-toggle" data-mr-section-id="matrix" data-mr-section-title="RAG × Priority matrix">
        <div class="dfe-f-toggle__title-wrapper">
          <h2 class="dfe-f-toggle__heading">
            <button type="button" class="dfe-f-toggle__button" aria-expanded="true" aria-controls="pr-toggle-matrix-content" id="pr-toggle-matrix-button">
              <span class="dfe-f-toggle__icon" aria-hidden="true"></span>
              <span class="dfe-f-toggle__title">RAG × Priority matrix</span>
              <span class="mr-toggle-panel__meta"><span class="govuk-tag govuk-tag--grey">@m.TotalActiveProjects</span></span>
            </button>
          </h2>
        </div>
        <div id="pr-toggle-matrix-content" class="dfe-f-toggle__content">
          <div class="dfe-f-toggle__body govuk-body">
            <section class="mr-section" style="margin-top:0.75rem;margin-bottom:0;" aria-labelledby="pr-matrix-heading">
              <p id="pr-matrix-heading" class="govuk-visually-hidden">RAG by Priority matrix</p>
              <p class="dfe-c-body-s dfe-c-text-muted govuk-!-margin-bottom-3">Heat map showing concentration of work items by RAG status and delivery priority. Click a cell to see matching work items.</p>
              <div class="mr-card mr-matrix-card">
                <div class="dfe-f-table-wrapper mr-matrix-scroll" data-module="dfe-f-table">
                  <table class="govuk-table govuk-table--small-text-until-tablet mr-mx" id="pr-rag-priority-matrix" aria-label="RAG by Priority matrix">
                    <caption class="govuk-visually-hidden">Cross-tabulation of RAG status against delivery priority</caption>
                    <thead class="govuk-table__head">
                      <tr class="govuk-table__row">
                        <th class="mr-mx__corner" scope="col">
                          <span class="mr-mx__corner-label mr-mx__corner-label--col">Priority →</span>
                          <span class="mr-mx__corner-label mr-mx__corner-label--row">RAG ↓</span>
                        </th>
                        @foreach (var pk in priKeys) { <th scope="col" class="mr-mx__col-hdr"><span class="@PriBadgeClass(pk)">@pk</span></th> }
                        <th scope="col" class="govuk-table__header mr-mx__col-hdr mr-mx__col-hdr--total">Total</th>
                      </tr>
                    </thead>
                    <tbody class="govuk-table__body">
                      @foreach (var rk in ragKeys)
                      {
                        var rowTotal = priKeys.Sum(pk => matrixLookup.TryGetValue(rk + "|" + pk, out var cv) ? cv : 0);
                        <tr class="govuk-table__row">
                          <th scope="row" class="mr-mx__row-hdr"><span class="@RagBadgeClass(rk)">@rk</span></th>
                          @foreach (var pk in priKeys)
                          {
                            var c = matrixLookup.TryGetValue(rk + "|" + pk, out var cv) ? cv : 0;
                            var mxFilter = $"mx-{rk}|{pk}";
                            <td class="@MatrixCellClass(rk, pk, c)">
                              @if (c > 0)
                              {
                                <span class="mr-mx__count mr-ba-drill" data-ba="__scope__" data-filter="@mxFilter" role="button" tabindex="0">@c</span>
                              }
                              else
                              {
                                <span class="mr-mx__empty">–</span>
                              }
                            </td>
                          }
                          <td class="mr-mx__cell mr-mx__cell--total"><strong>@rowTotal</strong></td>
                        </tr>
                      }
                    </tbody>
                    <tfoot>
                      <tr class="govuk-table__row">
                        <th scope="row" class="mr-mx__row-hdr mr-mx__row-hdr--total">Total</th>
                        @foreach (var pk in priKeys)
                        {
                          var colTotal = ragKeys.Sum(rk => matrixLookup.TryGetValue(rk + "|" + pk, out var cv) ? cv : 0);
                          <td class="mr-mx__cell mr-mx__cell--total"><strong>@colTotal</strong></td>
                        }
                        <td class="mr-mx__cell mr-mx__cell--grand"><strong>@m.TotalActiveProjects</strong></td>
                      </tr>
                    </tfoot>
                  </table>
                </div>
              </div>
            </section>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

@section Styles {
  @await Html.PartialAsync("_MrReportCoreStyles")
  <link rel="stylesheet" href="@Url.Content("~/modern/css/reporting-drilldown.css")" asp-append-version="true" />
}

@section Scripts {
  @await Html.PartialAsync("_ReportingDrilldownScripts", drillScriptModel)
}
