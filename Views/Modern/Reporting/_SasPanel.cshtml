@model Compass.ViewModels.Modern.SasReportPanelViewModel
<article class="sas-panel" data-sas-panel="@Model.PanelKey" aria-labelledby="@Model.HeadingId">
  <header class="sas-panel__head">
    <div class="sas-panel__title-wrap">
      <h3 class="sas-rpt__h3" id="@Model.HeadingId">@Model.Title</h3>
      @if (!string.IsNullOrWhiteSpace(Model.Hint))
      {
        <p class="sas-rpt__cell-hint govuk-!-margin-bottom-0">@Model.Hint</p>
      }
    </div>
    <div class="sas-panel__tools">
      <div class="sas-panel__view" role="group" aria-label="Show @Model.Title as">
        <button type="button" class="sas-panel__view-btn is-active" data-sas-view="chart" aria-pressed="true">Chart</button>
        <button type="button" class="sas-panel__view-btn" data-sas-view="table" aria-pressed="false">Table</button>
      </div>
      <button type="button" class="govuk-button govuk-button--secondary govuk-button--small sas-panel__expand" aria-expanded="false">Expand</button>
    </div>
  </header>
  <div class="sas-panel__body">
    <div class="sas-panel__pane sas-panel__pane--chart">
      <div class="sas-panel__chart-wrap @(Model.DoughnutWrap ? "sas-panel__chart-wrap--doughnut" : "")">
        <canvas id="@Model.CanvasId" role="img" aria-label="@Model.ChartAriaLabel"></canvas>
      </div>
    </div>
    <div class="sas-panel__pane sas-panel__pane--table" hidden>
      @Model.TableContent
    </div>
  </div>
</article>
