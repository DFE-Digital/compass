@model FipsProductDetailViewModel
@using Compass.Models
@{
  var p = Model.Product;
  var tab = Model.ActiveDetailTab ?? "information";
  (CMDBProductStatus Status, string Label)[] StatusTransitions(CMDBProductStatus current) => current switch
  {
    CMDBProductStatus.New => new[]
    {
      (CMDBProductStatus.Active, "Set active"),
      (CMDBProductStatus.Inactive, "Set as inactive")
    },
    CMDBProductStatus.Active => new[] { (CMDBProductStatus.Inactive, "Set as inactive") },
    CMDBProductStatus.Inactive => new[] { (CMDBProductStatus.Active, "Reactivate") },
    CMDBProductStatus.Rejected => new[] { (CMDBProductStatus.Active, "Set active") },
    _ => Array.Empty<(CMDBProductStatus, string)>()
  };
  var transitions = StatusTransitions(p.Status);
  var showEditCta = Model.CanManage && !Model.EditMode && tab == "information";
  var editAllUrl = Url.Action("FipsProductEditInformation", "ModernManage", new { id = p.Id, nc = "operations" });
}
@if (showEditCta || transitions.Length > 0)
{
  <div class="govuk-!-margin-bottom-4">
    @if (showEditCta)
    {
      <div class="govuk-button-group govuk-!-margin-bottom-0">
        <a href="@editAllUrl"
           class="govuk-button govuk-button--secondary">Edit entry</a>
      </div>
    }
    @if (transitions.Length > 0)
    {
      <div class="@(showEditCta ? "govuk-!-margin-top-3" : "")">
        @foreach (var t in transitions)
        {
          if (t.Status == CMDBProductStatus.Inactive)
          {
            <form method="post" asp-controller="ModernOperations" asp-action="ServiceRegisterProductChangeStatus" asp-route-id="@p.Id" class="govuk-!-margin-bottom-2" data-confirm-title="Set product to inactive" data-confirm-message="The product will be treated as retired in Compass and will not be included in the active FIPS/CMDB sync. You can reactivate it later.">
              @Html.AntiForgeryToken()
              <input type="hidden" name="newStatus" value="@((int)t.Status)" />
              <button type="submit" class="govuk-button govuk-button--warning govuk-!-margin-bottom-0">@t.Label</button>
            </form>
          }
          else
          {
            <form method="post" asp-controller="ModernOperations" asp-action="ServiceRegisterProductChangeStatus" asp-route-id="@p.Id" class="govuk-!-margin-bottom-2">
              @Html.AntiForgeryToken()
              <input type="hidden" name="newStatus" value="@((int)t.Status)" />
              <button type="submit" class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0">@t.Label</button>
            </form>
          }
        }
      </div>
    }
  </div>
}
