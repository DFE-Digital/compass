@*
  Shared entry properties block for Horizon (BC) and Demand (DR) detail views.
  Set in controller: ViewBag.EntryEditUrl (or EntryEditController, EntryEditId), ViewBag.EntryReference, ViewBag.EntryCreated, ViewBag.EntryUpdated, ViewBag.EntryRequestor, ViewBag.EntryPortfolio, ViewBag.EntryDirectorate, ViewBag.EntrySRO.
*@
@{
  var reference = ViewBag.EntryReference as string ?? "—";
  var created = ViewBag.EntryCreated as DateTime?;
  var updated = ViewBag.EntryUpdated as DateTime?;
  var requestor = ViewBag.EntryRequestor as string ?? "—";
  var portfolio = ViewBag.EntryPortfolio as string ?? "—";
  var directorate = ViewBag.EntryDirectorate as string ?? "—";
  var sro = ViewBag.EntrySRO as string ?? "—";
  var editUrl = ViewBag.EntryEditUrl as string;
  var editController = ViewBag.EntryEditController as string;
  var editId = ViewBag.EntryEditId as Guid?;
  var href = !string.IsNullOrEmpty(editUrl) ? editUrl : (editController != null && editId.HasValue ? Url.Action("Edit", editController, new { id = editId }) : null);
}
<div class="dfe-c-card">
  <h3>Entry details</h3>
 <div class="kv"><dt>Reference</dt><dd><strong>@reference</strong></dd></div>
 <div class="kv"><dt>Created</dt><dd>@(created.HasValue ? created.Value.ToString("d MMM yyyy") : "—")</dd></div>
 <div class="kv"><dt>Last updated</dt><dd>@(updated.HasValue ? updated.Value.ToString("d MMM yyyy") : "—")</dd></div>
 <div class="kv"><dt>Requestor</dt><dd>@requestor</dd></div>
 <div class="kv"><dt>Portfolio</dt><dd>@portfolio</dd></div>
 <div class="kv"><dt>Directorate</dt><dd>@directorate</dd></div>
 <div class="kv"><dt>SRO</dt><dd>@sro</dd></div>
  @if (href != null)
  {
 <div class="kv" style="border-top:1px solid var(--grey-2);margin-top:8px;padding-top:8px"><dt></dt><dd><a href="@href" class="dfe-c-link">Edit entry</a></dd></div>
  }
</div>
