@* Renders left-hand nav for System settings section. Set ViewBag.SystemSettingsSection to "email-templates" | "event-reference" | "api-tokens" *@
@{
    var section = ViewBag.SystemSettingsSection as string ?? "";
}
<nav class="dfe-c-grid-col dfe-c-grid-col--one-third" aria-label="System settings sections">
  <ul class="dfe-c-list">
    <li>
      @if (section == "email-templates")
      {
        <span class="dfe-c-fw-bold">Email templates</span>
      }
      else
      {
        <a class="dfe-c-link" href="@Url.Action("SystemSettings", "Admin")">Email templates</a>
      }
    </li>
    <li>
      @if (section == "event-reference")
      {
        <span class="dfe-c-fw-bold">Event key and placeholder reference</span>
      }
      else
      {
        <a class="dfe-c-link" href="@Url.Action("NotificationEventReference", "Admin")">Event key and placeholder reference</a>
      }
    </li>
    <li>
      @if (section == "api-tokens")
      {
        <span class="dfe-c-fw-bold">API tokens</span>
      }
      else
      {
        <a class="dfe-c-link" href="@Url.Action("Index", "ApiTokens")">API tokens</a>
      }
    </li>
  </ul>
</nav>
