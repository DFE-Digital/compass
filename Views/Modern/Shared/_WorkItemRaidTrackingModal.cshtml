@using Compass.ViewModels.Modern
@{
  var registers = ViewBag.WorkRaidTrackingRegisters as IReadOnlyList<WorkRaidRegisterTrackingVm>
      ?? Array.Empty<WorkRaidRegisterTrackingVm>();
  if (registers.Count == 0)
  {
    return;
  }
}
<dialog id="work-item-raid-tracking-modal"
        class="dfe-f-modal govuk-!-margin-0"
        data-module="dfe-f-modal"
        aria-labelledby="work-item-raid-tracking-modal-title"
        aria-modal="true"
        role="dialog">
  <div class="dfe-f-modal__panel">
    <header class="dfe-f-modal__header">
      <h2 id="work-item-raid-tracking-modal-title" class="govuk-heading-m dfe-f-modal__title">Tracked in RAID registers</h2>
      <button type="button" class="dfe-f-modal__close" data-dfe-modal-close aria-label="Close">
        <span class="dfe-f-modal__close-x" aria-hidden="true">×</span>
      </button>
    </header>
    <div class="dfe-f-modal__body">
      <p class="govuk-body">This work item is in scope for @registers.Count RAID register@(registers.Count == 1 ? "" : "s").</p>
      <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed govuk-!-margin-bottom-0">
        <caption class="govuk-table__caption govuk-visually-hidden">RAID registers tracking this work item</caption>
        <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">Register</th>
            <th scope="col" class="govuk-table__header">Owner</th>
          </tr>
        </thead>
        <tbody class="govuk-table__body">
          @foreach (var reg in registers)
          {
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">
                <a href="@reg.DetailUrl" class="govuk-link govuk-link--no-visited-state">@reg.Name</a>
              </td>
              <td class="govuk-table__cell">@reg.OwnerName</td>
            </tr>
          }
        </tbody>
      </table>
    </div>
    <footer class="dfe-f-modal__footer">
      <button type="button" class="govuk-button govuk-button--secondary" data-dfe-modal-close>Close</button>
    </footer>
  </div>
</dialog>
