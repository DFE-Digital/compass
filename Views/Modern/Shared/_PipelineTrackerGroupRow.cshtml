@model Compass.Models.PipelineTrackerViewModel
@{
  var groupSpans = Model.GroupSpans ?? new List<Compass.Models.PipelineTrackerGroupSpan>();
  var stageCount = (Model.Stages ?? new List<Compass.Models.PipelineStage>()).Count;
  string GroupSpanClass(string? key) => string.Equals(key, "Demand", StringComparison.OrdinalIgnoreCase) ? "pipeline-group--demand" : string.Equals(key, "Work", StringComparison.OrdinalIgnoreCase) ? "pipeline-group--work" : "pipeline-group--other";
}
@if (stageCount > 0 && groupSpans.Count > 0)
{
 <div class="pipeline-tracker__group-row pipeline-tracker__group-row--header pipeline-view-section__group-row" style="grid-template-columns: repeat(@stageCount, minmax(0, 1fr));">
    @foreach (var g in groupSpans)
    {
 <div class="pipeline-tracker__group-span @GroupSpanClass(g.Key)" style="grid-column: span @g.SpanCount;">
 <span class="pipeline-tracker__group-label">@(string.IsNullOrEmpty(g.Key) ? "—" : g.Key)</span>
 <span class="pipeline-tracker__group-badge pipeline-count-badge" aria-label="@(g.Key ?? "Group") count">@g.ItemCount</span>
      </div>
    }
  </div>
}
