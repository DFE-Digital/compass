@model Compass.Models.Modern.Work.WorkItem?
@using Compass.Models.Modern.Work
@{
  var work = Model ?? ViewBag.WorkItem as WorkItem;
  if (work == null) { return; }
  var subPageChrome = ViewBag.WorkChromeSubPage as bool? ?? false;
  var detailUrl = Url.Action("Detail", "ModernWork", new { id = work.Id });
  var minimalHeader = ViewBag.WorkChromeMinimalHeader as bool? ?? false;
  var req = Context?.Request;
  var embedFrame = string.Equals(req?.Query["embed"].FirstOrDefault(), "1", StringComparison.Ordinal)
      || (req != null && req.HasFormContentType
          && string.Equals(req.Form["embed"].FirstOrDefault(), "1", StringComparison.Ordinal));
}
@if (subPageChrome)
{
 <a href="@detailUrl" class="govuk-back-link dfe-c-mt-0 dfe-c-mb-2">Back to work item</a>
}
@if (!minimalHeader && !embedFrame)
{
  @await Html.PartialAsync("_WorkItemMasthead", work)
}
