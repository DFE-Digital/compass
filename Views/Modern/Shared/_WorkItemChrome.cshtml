@model Compass.Models.Modern.Work.WorkItem?
@using Compass.Models.Modern.Work
@{
  var work = Model ?? ViewBag.WorkItem as WorkItem;
  if (work == null) { return; }
  var subPageChrome = ViewBag.WorkChromeSubPage as bool? ?? false;
  var detailUrl = Url.Action("Detail", "ModernWork", new { id = work.Id });
  var monthlyReportDue = ViewBag.MonthlyReportDue as bool? ?? false;
  var currentPeriodLabel = ViewBag.CurrentPeriodLabel as string;
  var currentPeriodDueDate = ViewBag.CurrentPeriodDueDate as DateTime?;
  var lastMonthlyMonth = ViewBag.LastMonthlyUpdateMonth as string;
  var lastMonthlyBy = ViewBag.LastMonthlyUpdateBy as string;
  var minimalHeader = ViewBag.WorkChromeMinimalHeader as bool? ?? false;
  var req = Context?.Request;
  var embedFrame = string.Equals(req?.Query["embed"].FirstOrDefault(), "1", StringComparison.Ordinal)
      || (req != null && req.HasFormContentType
          && string.Equals(req.Form["embed"].FirstOrDefault(), "1", StringComparison.Ordinal));
}
@if (subPageChrome)
{
 <a href="@detailUrl" class="govuk-back-link dfe-c-mt-0 dfe-c-mb-2">Back to work item</a>
}
@if (!minimalHeader && !embedFrame)
{
  @await Html.PartialAsync("_WorkItemMasthead", work)
  @await Html.PartialAsync("_PageDataAccessHint")
}

@if (!subPageChrome && monthlyReportDue && !string.IsNullOrEmpty(currentPeriodLabel))
{
 <div class="dfe-c-callout dfe-c-callout--warning dfe-c-mb-2" role="region" aria-label="Monthly update overdue">
 <div class="dfe-c-callout__heading">Monthly update overdue — window closes @(currentPeriodDueDate?.ToString("d MMMM yyyy") ?? "—")</div>
 <p class="dfe-c-callout__body">
      @if (!string.IsNullOrEmpty(lastMonthlyMonth))
      {
        <text>Last submitted: @lastMonthlyMonth@(string.IsNullOrEmpty(lastMonthlyBy) ? "." : " (" + lastMonthlyBy + ").")</text>
      }
      else
      {
        <text>No previous submission on record.</text>
      }
    </p>
  </div>
}

<style>
.monthly-due-banner { background: #1d70b8; color: #fff; padding: 10px 20px; margin-bottom: 0; border-bottom: 1px solid #dee0e2; }
.monthly-due-banner__inner { display: flex; align-items: center; justify-content: space-between; gap: 16px; flex-wrap: wrap; max-width: 100%; }
.monthly-due-banner__text { font-size: 14px; font-weight: 600; }
.monthly-due-banner__btn { margin: 0; flex-shrink: 0; background: #fff; color: #1d70b8; }
.monthly-due-banner__btn:hover { background: #f3f2f1; color: #1d70b8; }
.wd-tab-badge { font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 4px; margin-left: 6px; white-space: nowrap; }
.wd-tab-badge--red { background: #d4351c; color: #fff; }
.wd-tab-badge--blue { background: #1d70b8; color: #fff; }
.wd-updates-badge { font-size: 12px; font-weight: 700; padding: 3px 10px; border-radius: 4px; display: inline-block; }
.wd-updates-badge--red { background: #d4351c; color: #fff; }
.wd-updates-badge--blue { background: #1d70b8; color: #fff; }
</style>
