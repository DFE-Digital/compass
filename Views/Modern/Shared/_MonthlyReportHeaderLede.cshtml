@model Compass.Models.Modern.Work.MonthlyReportViewModel
@{
  var refLine = $"WI-{ViewBag.WorkIdShort as string ?? Model.WorkItemId.ToString("D8", System.Globalization.CultureInfo.InvariantCulture)}";
  var work = ViewBag.WorkItem as Compass.Models.Modern.Work.WorkItem;
}
<p class="govuk-body govuk-!-margin-bottom-0">@refLine · @(Model.WorkItemTitle ?? work?.Title ?? "—")</p>
