@using Compass.ViewModels.Modern
@{
    var export = ViewBag.SubNavExport as SubNavExportOptions;
    if (export is not { HasAny: true })
    {
        return;
    }

    var hasCurrent = !string.IsNullOrEmpty(export.CurrentViewUrl);
    var hasAll = !string.IsNullOrEmpty(export.AllDataUrl);
    var menuId = $"subnav-export-menu-{Guid.NewGuid():N}";
}
<li class="dfe-f-sub-navigation__item subnav-export-item">
  <div class="subnav-export" data-module="subnav-export">
    <button type="button"
            class="dfe-f-sub-navigation__link govuk-link subnav-export__trigger"
            aria-expanded="false"
            aria-haspopup="true"
            aria-controls="@menuId">
      Export
      <span class="subnav-export__chevron" aria-hidden="true"></span>
    </button>
    <div id="@menuId" class="subnav-export__menu" role="menu" hidden>
      @if (hasCurrent)
      {
        <a class="govuk-link govuk-link--no-visited-state subnav-export__menu-link"
           role="menuitem"
           href="@export.CurrentViewUrl"
           data-report-download
           data-generating-modal-title="Exporting current view"
           data-generating-modal-hint="Please wait — your download will start when the file is ready.">Current view</a>
      }
      @if (hasAll)
      {
        <a class="govuk-link govuk-link--no-visited-state subnav-export__menu-link"
           role="menuitem"
           href="@export.AllDataUrl"
           data-report-download
           data-generating-modal-title="Exporting all data"
           data-generating-modal-hint="Please wait — your download will start when the file is ready.">All data</a>
      }
    </div>
  </div>
</li>
