@model ServiceRegisterSyncSettingsViewModel

<div class="dfe-f-toggle" data-module="dfe-f-toggle">
  <div class="dfe-f-toggle__title-wrapper">
    <h2 class="dfe-f-toggle__heading govuk-!-margin-bottom-0">
      <button type="button" class="dfe-f-toggle__button" aria-expanded="@(Model.LastStrapiImportResult != null ? "true" : "false")" aria-controls="fips-sync-panel-strapi-json" id="fips-sync-toggle-strapi-json">
        <span class="dfe-f-toggle__icon" aria-hidden="true"></span>
        <span class="dfe-f-toggle__title">Import from legacy CMS JSON</span>
      </button>
    </h2>
  </div>
  <div id="fips-sync-panel-strapi-json" class="dfe-f-toggle__content"@if (Model.LastStrapiImportResult == null) { <text> hidden</text> }>
    <div class="dfe-f-toggle__body">
      <p class="govuk-body-s govuk-!-margin-bottom-3" style="color:#505a5f;">
        Bulk-update service register products from a Strapi/CMS export (<code>data.json</code>).
        Matches by <strong>cmdb_sys_id</strong> to each product’s CMDB ID.
        Updates <strong>user description</strong> (from <code>long_description</code>),
        <strong>product URL</strong>, <strong>phase</strong>, <strong>channel</strong>, and <strong>type</strong>.
        Does <strong>not</strong> change business area.
      </p>
      <form method="post" action="@Url.Action("ServiceRegisterImportStrapiJson", "ModernOperations")" enctype="multipart/form-data" class="govuk-!-margin-bottom-0">
        @Html.AntiForgeryToken()
        <div class="govuk-form-group">
          <label class="govuk-label" for="fips-strapi-json-import-file">Upload JSON file</label>
          <div class="govuk-hint" id="fips-strapi-json-import-hint">Export from legacy FIPS CMS with <code>cmdb_sys_id</code> and <code>category_values</code>.</div>
          <input class="govuk-file-upload" id="fips-strapi-json-import-file" name="file" type="file" accept=".json,application/json" aria-describedby="fips-strapi-json-import-hint" required />
        </div>
        <div class="govuk-checkboxes govuk-checkboxes--small govuk-!-margin-bottom-4" data-module="govuk-checkboxes">
          <div class="govuk-checkboxes__item">
            <input class="govuk-checkboxes__input" id="fips-strapi-json-dry-run" name="dryRun" type="checkbox" value="true" checked="checked" />
            <label class="govuk-label govuk-checkboxes__label" for="fips-strapi-json-dry-run">Dry run (preview only — no database changes)</label>
          </div>
        </div>
        <button type="submit" class="govuk-button">Import updates</button>
      </form>
    </div>
  </div>
</div>
