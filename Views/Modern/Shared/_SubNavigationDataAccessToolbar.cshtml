@using Compass.ViewModels.Modern
@{
    var access = ViewBag.SubNavDataAccess as SubNavDataAccessOptions;
    if (access is not { ShowToolbar: true })
    {
        return;
    }

    var suffix = Guid.NewGuid().ToString("N")[..8];
    var exportPanelId = $"subnav-data-export-{suffix}";
    var apiPanelId = $"subnav-data-api-{suffix}";
    ViewData["SubNavDataAccessExportPanelId"] = exportPanelId;
    ViewData["SubNavDataAccessApiPanelId"] = apiPanelId;
}
<div class="subnav-data-access-toolbar" data-module="subnav-data-access">
  @if (access.ShowExport)
  {
    <button type="button"
            class="subnav-data-access__trigger"
            data-subnav-panel="export"
            aria-expanded="false"
            aria-controls="@exportPanelId"
            title="Download data">
      <span class="material-symbols-sharp subnav-data-access__icon" aria-hidden="true">download</span>
      <span class="govuk-visually-hidden">Download data</span>
    </button>
  }
  @if (access.ShowApi)
  {
    <button type="button"
            class="subnav-data-access__trigger"
            data-subnav-panel="api"
            aria-expanded="false"
            aria-controls="@apiPanelId"
            title="API data access">
      <span class="material-symbols-sharp subnav-data-access__icon" aria-hidden="true">api</span>
      <span class="govuk-visually-hidden">API data access</span>
    </button>
  }
</div>
