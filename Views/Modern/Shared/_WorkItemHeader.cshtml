@model Compass.Models.Modern.Work.WorkItem?
@using Compass.Models.Modern.Work
@using Compass.ViewModels.Modern
@{
  var work = Model ?? ViewBag.WorkItem as WorkItem;
  var portfolioName = ViewBag.PortfolioName as string ?? "—";
  var showBanners = ViewBag.ShowBanners as bool? ?? false;
  var isWatching = ViewBag.IsWatching as bool? ?? false;
  var monthlyReportDue = ViewBag.MonthlyReportDue as bool? ?? false;
  var ragNeedsJustification = ViewBag.RagNeedsJustification as bool? ?? false;
  var currentPeriodDueDate = ViewBag.CurrentPeriodDueDate as DateTime?;
  var canEditWorkItem = ViewBag.CanEditWorkItem as bool? ?? false;
}
@if (work != null)
{
  var headerCaption = $"{work.Id.ToString("X8")} · {portfolioName} · {work.Status}";
  var headerActions = await Html.PartialAsync("_WorkItemHeaderActions", work);
  @await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
    Caption = headerCaption,
    Title = work.Title,
    Actions = headerActions,
    HeadingClass = "govuk-heading-l"
  })

  @if (showBanners && monthlyReportDue)
  {
 <div class="dfe-c-notification-banner" role="region" aria-label="Monthly report due">
 <div class="dfe-c-notification-banner__header">
 <h2 class="dfe-c-notification-banner__title">Monthly report due</h2>
      </div>
 <div class="dfe-c-notification-banner__content">
 <p class="dfe-c-body dfe-c-mb-2">Complete your monthly update for this work item@(currentPeriodDueDate.HasValue ? " by " + currentPeriodDueDate.Value.ToString("d MMM yyyy") : "").</p>
 <p class="dfe-c-body"><a href="@Url.Action("AddMonthlyUpdate", "ModernWork", new { id = work.Id })" class="dfe-c-link">Add monthly update</a></p>
      </div>
    </div>
  }
  @if (showBanners && ragNeedsJustification)
  {
 <div class="dfe-c-notification-banner dfe-c-notification-banner--warning" role="region" aria-label="RAG justification">
 <div class="dfe-c-notification-banner__header">
 <h2 class="dfe-c-notification-banner__title">RAG status not green</h2>
      </div>
 <div class="dfe-c-notification-banner__content">
 <p class="dfe-c-body">Ensure justification and path to green are recorded in <a href="@Url.Action("UpdateRag", "ModernWork", new { id = work.Id })" class="dfe-c-link">RAG history</a>.</p>
      </div>
    </div>
  }
}
