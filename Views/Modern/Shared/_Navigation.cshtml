        <a class="govuk-service-navigation__link" href="@Url.Action("Dashboard", "ModernWork")" data-nav="work">Work</a>
      }
    </li>
    <li class="govuk-service-navigation__item@(ViewBag.MainNavSection == "products-services" ? " govuk-service-navigation__item--active" : "")">
      @if (ViewBag.MainNavSection == "products-services")
      {
        <a class="govuk-service-navigation__link" href="@Url.RouteUrl("products-services-section", new { action = "Dashboard" })" aria-current="true" data-nav="products-services"><strong class="govuk-service-navigation__active-fallback">Products and Services</strong></a>
      }
