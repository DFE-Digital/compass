@{
  var navSection = (ViewBag.MainNavSection as string ?? "").Trim();
  bool IsNav(string key) => string.Equals(navSection, key, StringComparison.OrdinalIgnoreCase);
  var navListId = "compass-service-navigation";
  var isAuthenticated = User?.Identity?.IsAuthenticated == true;
}
@if (!isAuthenticated)
{
  return;
}
<nav id="main-nav" aria-label="Menu" class="govuk-service-navigation__wrapper">
  <button type="button" class="govuk-service-navigation__toggle govuk-js-service-navigation-toggle" aria-controls="@navListId" hidden="hidden" aria-hidden="true">
    Menu
  </button>
  <ul class="govuk-service-navigation__list" id="@navListId">
    @if (ViewBag.ShowDemandNavigation == true)
    {
      <li class="govuk-service-navigation__item@(IsNav("demand") ? " govuk-service-navigation__item--active" : "")">
        <a class="govuk-service-navigation__link" href="@Url.Action("Dashboard", "ModernDemand")" data-nav="demand"@if (IsNav("demand")) { <text> aria-current="true"</text> }>
          @if (IsNav("demand"))
          {<strong class="govuk-service-navigation__active-fallback">Demand</strong>}
          else
          {<text>Demand</text>}
        </a>
      </li>
    }
    <li class="govuk-service-navigation__item@(IsNav("work") ? " govuk-service-navigation__item--active" : "")">
      <a class="govuk-service-navigation__link" href="@Url.Action("Dashboard", "ModernWork")" data-nav="work"@if (IsNav("work")) { <text> aria-current="true"</text> }>
        @if (IsNav("work"))
        {<strong class="govuk-service-navigation__active-fallback">Work</strong>}
        else
        {<text>Work</text>}
      </a>
    </li>
    @if (ViewBag.ShowRaidNavigation == true)
    {
      <li class="govuk-service-navigation__item@(IsNav("raid") ? " govuk-service-navigation__item--active" : "")">
        <a class="govuk-service-navigation__link" href="@Url.Action("Dashboard", "ModernRaid")" data-nav="raid"@if (IsNav("raid")) { <text> aria-current="true"</text> }>
          @if (IsNav("raid"))
          {<strong class="govuk-service-navigation__active-fallback">RAID</strong>}
          else
          {<text>RAID</text>}
        </a>
      </li>
    }
    <li class="govuk-service-navigation__item@(IsNav("performance") ? " govuk-service-navigation__item--active" : "")">
      <a class="govuk-service-navigation__link" href="@Url.Action("Index", "ModernPerformance")" data-nav="performance"@if (IsNav("performance")) { <text> aria-current="true"</text> }>
        @if (IsNav("performance"))
        {<strong class="govuk-service-navigation__active-fallback">Performance</strong>}
        else
        {<text>Performance</text>}
      </a>
    </li>
    @if (ViewBag.ShowFipsDatabaseServiceRegister == true)
    {
      <li class="govuk-service-navigation__item@(IsNav("manage") ? " govuk-service-navigation__item--active" : "")">
        <a class="govuk-service-navigation__link" href="@Url.Action("FipsDashboard", "ModernManage")" data-nav="manage"@if (IsNav("manage")) { <text> aria-current="true"</text> }>
          @if (IsNav("manage"))
          {<strong class="govuk-service-navigation__active-fallback">Service Register</strong>}
          else
          {<text>Service Register</text>}
        </a>
      </li>
    }
    @if (ViewBag.ShowDdrNavigation == true)
    {
      <li class="govuk-service-navigation__item@(IsNav("ddr") ? " govuk-service-navigation__item--active" : "")">
        <a class="govuk-service-navigation__link" href="@Url.Action("Register", "ModernDesignDecisionRecords")" data-nav="ddr"@if (IsNav("ddr")) { <text> aria-current="true"</text> }>
          @if (IsNav("ddr"))
          {<strong class="govuk-service-navigation__active-fallback">Decisions</strong>}
          else
          {<text>Decisions</text>}
        </a>
      </li>
    }
    @if (ViewBag.ShowStandardsNavigation == true)
    {
      <li class="govuk-service-navigation__item@(IsNav("standards") ? " govuk-service-navigation__item--active" : "")">
        <a class="govuk-service-navigation__link" href="@Url.Action("Dashboard", "ModernStandards")" data-nav="standards"@if (IsNav("standards")) { <text> aria-current="true"</text> }>
          @if (IsNav("standards"))
          {<strong class="govuk-service-navigation__active-fallback">Standards</strong>}
          else
          {<text>Standards</text>}
        </a>
      </li>
    }
    <li class="govuk-service-navigation__item@(IsNav("reporting") ? " govuk-service-navigation__item--active" : "")">
      <a class="govuk-service-navigation__link" href="@Url.Action("Dashboard", "ModernReporting")" data-nav="reporting"@if (IsNav("reporting")) { <text> aria-current="true"</text> }>
        @if (IsNav("reporting"))
        {<strong class="govuk-service-navigation__active-fallback">Reporting</strong>}
        else
        {<text>Reporting</text>}
      </a>
    </li>
    @if (ViewBag.CanAccessOperations == true)
    {
      <li class="govuk-service-navigation__item@(IsNav("operations") ? " govuk-service-navigation__item--active" : "")">
        <a class="govuk-service-navigation__link" href="@Url.Action("Dashboard", "ModernOperations")" data-nav="operations"@if (IsNav("operations")) { <text> aria-current="true"</text> }>
          @if (IsNav("operations"))
          {<strong class="govuk-service-navigation__active-fallback">Operations</strong>}
          else
          {<text>Operations</text>}
        </a>
      </li>
    }
  </ul>
</nav>
