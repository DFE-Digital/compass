        <a class="govuk-service-navigation__link" href="@Url.RouteUrl("standards-dashboard")" data-nav="standards">Standards</a>
      }
    </li>
    @if (ViewBag.CanAccessOperations == true)
    {
    <li class="govuk-service-navigation__item@(ViewBag.MainNavSection == "operations" ? " govuk-service-navigation__item--active" : "")">
      @if (ViewBag.MainNavSection == "operations")
      {
        <a class="govuk-service-navigation__link" href="@Url.Action("Index", "Operations")" aria-current="true" data-nav="operations"><strong class="govuk-service-navigation__active-fallback">Operations</strong></a>
