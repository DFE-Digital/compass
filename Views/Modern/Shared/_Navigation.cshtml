@{
  var navListId = "compass-service-navigation";
}
<nav aria-label="Menu" class="govuk-service-navigation__wrapper">
  <button type="button" class="govuk-service-navigation__toggle govuk-js-service-navigation-toggle" aria-controls="@navListId" hidden aria-hidden="true">
    Menu
  </button>
  <ul class="govuk-service-navigation__list" id="@navListId">
    <li class="govuk-service-navigation__item@(ViewBag.MainNavSection == "home" ? " govuk-service-navigation__item--active" : "")">
      @if (ViewBag.MainNavSection == "home")
      {
        <a class="govuk-service-navigation__link" href="@Url.Action("Index", "ModernDashboard")" aria-current="true" data-nav="home"><strong class="govuk-service-navigation__active-fallback">Home</strong></a>
      }
      else
      {
        <a class="govuk-service-navigation__link" href="@Url.Action("Index", "ModernDashboard")" data-nav="home">Home</a>
      }
    </li>
    <li class="govuk-service-navigation__item@(ViewBag.MainNavSection == "demand" ? " govuk-service-navigation__item--active" : "")">
