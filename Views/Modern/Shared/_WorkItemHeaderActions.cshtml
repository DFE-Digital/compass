@model Compass.Models.Modern.Work.WorkItem
@{
  var work = Model;
  var isWatching = ViewBag.IsWatching as bool? ?? false;
  var canEditWorkItem = ViewBag.CanEditWorkItem as bool? ?? false;
  var toggleWatchUrl = Url.Action("ToggleWatch", "ModernWork", new { id = work.Id }) ?? "";
}
<div class="govuk-button-group work-item-masthead__actions-buttons">
  @Html.AntiForgeryToken()
  <button type="button"
          class="govuk-button govuk-button--secondary govuk-!-margin-bottom-0"
          id="work-item-watch-toggle"
          data-work-item-watch-toggle="true"
          data-toggle-url="@toggleWatchUrl"
          data-watching="@(isWatching ? "true" : "false")"
          aria-pressed="@(isWatching ? "true" : "false")">
    @(isWatching ? "Unwatch" : "Watch")
  </button>
  @if (canEditWorkItem)
  {
    <a href="@Url.Action("Edit", "ModernWork", new { id = work.Id })" class="govuk-button govuk-!-margin-bottom-0">Edit</a>
  }
</div>
<script nonce="@(Context.Items["Nonce"]?.ToString() ?? "")">
  (function () {
    if (window.__workItemWatchToggleBound) return;
    window.__workItemWatchToggleBound = true;

    function getAntiForgeryToken() {
      var input = document.querySelector('.work-item-masthead__actions-buttons input[name="__RequestVerificationToken"]')
        || document.querySelector('input[name="__RequestVerificationToken"]');
      return input ? input.value : '';
    }

    function setWatchingState(btn, watching) {
      btn.setAttribute('data-watching', watching ? 'true' : 'false');
      btn.setAttribute('aria-pressed', watching ? 'true' : 'false');
      btn.textContent = watching ? 'Unwatch' : 'Watch';
    }

    document.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-work-item-watch-toggle]');
      if (!btn || btn.disabled) return;

      var url = btn.getAttribute('data-toggle-url');
      if (!url) return;

      e.preventDefault();

      var wasWatching = btn.getAttribute('data-watching') === 'true';
      var nextWatching = !wasWatching;
      setWatchingState(btn, nextWatching);

      var token = getAntiForgeryToken();
      fetch(url, {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
          'RequestVerificationToken': token,
          'Accept': 'application/json'
        }
      }).then(function (res) {
        if (!res.ok) throw new Error('watch toggle failed');
        return res.json();
      }).then(function (data) {
        if (typeof data.watching === 'boolean') {
          setWatchingState(btn, data.watching);
        }
      }).catch(function () {
        setWatchingState(btn, wasWatching);
      });
    });
  })();
</script>
