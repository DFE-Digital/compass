@* Reusable confirmation modal for destructive actions (delete, suspend, etc.). *@
@* Trigger by adding data-confirm-title and data-confirm-message to a form; submit is intercepted and modal shown before actual submit. *@
<div id="confirm-modal-overlay" class="confirm-modal-overlay" role="presentation" aria-hidden="true" style="display: none;">
 <div id="confirm-modal" class="confirm-modal" role="alertdialog" aria-modal="true" aria-labelledby="confirm-modal-title" aria-describedby="confirm-modal-description" style="display: none;">
 <h2 id="confirm-modal-title" class="confirm-modal__title"></h2>
 <p id="confirm-modal-description" class="confirm-modal__description"></p>
 <div class="confirm-modal__actions">
 <button type="button" id="confirm-modal-cancel" class="dfe-c-button dfe-c-button--secondary">Cancel</button>
 <button type="button" id="confirm-modal-confirm" class="dfe-c-button dfe-c-button--warning">Confirm</button>
    </div>
  </div>
</div>
