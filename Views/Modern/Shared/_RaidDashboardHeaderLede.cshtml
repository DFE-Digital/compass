@model Compass.ViewModels.Modern.ModernRaidDashboardViewModel
@using System.Linq
@{
  var firstName = string.IsNullOrWhiteSpace(Model.ViewerDisplayName)
    ? null
    : Model.ViewerDisplayName.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
}
<p class="govuk-body govuk-!-margin-bottom-2" style="max-width:44rem;">
  @if (Model.IsScoped)
  {
    @Model.ScopeSummary
  }
  else if (firstName != null)
  {
    <text>This dashboard shows <strong>your</strong> open risks and issues — records you create, own, are assigned to, or that relate to your work items and products.</text>
  }
  else
  {
    <text>This dashboard shows <strong>your</strong> open risks and issues in Compass.</text>
  }
</p>
@if (!Model.IsScoped)
{
  <ul class="govuk-body-s dfe-c-text-muted govuk-!-margin-bottom-0" style="max-width:44rem;">
    @if (Model.LinkedWorkItemCount > 0)
    {
      <li>@Model.LinkedWorkItemCount linked work @(Model.LinkedWorkItemCount == 1 ? "item" : "items")</li>
    }
    @if (Model.LinkedProductCount > 0)
    {
      <li>@Model.LinkedProductCount linked @(Model.LinkedProductCount == 1 ? "product" : "products")</li>
    }
    @if (Model.LinkedWorkItemCount == 0 && Model.LinkedProductCount == 0)
    {
      <li>No work items or products linked to your profile — counts include records you create, own, or are assigned to.</li>
    }
    @if (Model.ViewerIsBusinessAreaAdmin)
    {
      <li>You are a business area administrator — additional risks in your areas are included.</li>
    }
  </ul>
}
