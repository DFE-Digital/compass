@model Compass.Models.Modern.Work.WorkItem
@{
  if (Model == null)
  {
    return;
  }

  var detailUrl = Url.Action("Detail", "ModernWork", new { id = Model.Id });
  var section = (ViewBag.WorkChromeSection as string ?? "overview").Trim().ToLowerInvariant();
  var showRaid = ViewBag.ShowRaidNavigation == true;

  bool IsCurrent(string s) =>
      string.Equals(section, s, StringComparison.OrdinalIgnoreCase);
}

<nav class="dfe-f-side-navigation wd-work-detail-tabs modern-work-detail-side-nav"
     aria-label="Work item sections"
     data-module="dfe-f-side-navigation">
  <button type="button"
          class="dfe-f-side-navigation__toggle"
          aria-controls="wd-work-detail-side-nav-list"
          aria-expanded="false">
    Sections
  </button>
  <ul id="wd-work-detail-side-nav-list" class="dfe-f-side-navigation__list" hidden>
    <li class="dfe-f-side-navigation__item@(IsCurrent("overview") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state"
         href="@(detailUrl)#wd-overview"
         id="wd-tab-overview">Overview</a>
    </li>
    <li class="dfe-f-side-navigation__item@(IsCurrent("updates") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state"
         href="@(detailUrl)#wd-updates"
         id="wd-tab-updates">Monthly updates</a>
    </li>
    @if (showRaid)
    {
      <li class="dfe-f-side-navigation__item@(IsCurrent("risks") ? " dfe-f-side-navigation__item--current" : "")">
        <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state"
           href="@(detailUrl)#wd-risks"
           id="wd-tab-risks">Risks</a>
      </li>
      <li class="dfe-f-side-navigation__item@(IsCurrent("issues") ? " dfe-f-side-navigation__item--current" : "")">
        <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state"
           href="@(detailUrl)#wd-issues"
           id="wd-tab-issues">Issues</a>
      </li>
    }
    <li class="dfe-f-side-navigation__item@(IsCurrent("milestones") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state"
         href="@(detailUrl)#wd-milestones"
         id="wd-tab-milestones">Milestones</a>
    </li>
    <li class="dfe-f-side-navigation__item@(IsCurrent("contacts") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state"
         href="@(detailUrl)#wd-contacts"
         id="wd-tab-contacts">Contacts</a>
    </li>
    <li class="dfe-f-side-navigation__item@(IsCurrent("strategicalignment") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state"
         href="@(detailUrl)#wd-strategic-alignment"
         id="wd-tab-strategic-alignment">Strategic alignment</a>
    </li>
    <li class="dfe-f-side-navigation__item@(IsCurrent("dependencies") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state"
         href="@(detailUrl)#wd-dependencies"
         id="wd-tab-dependencies">Dependencies</a>
    </li>
    <li class="dfe-f-side-navigation__item@(IsCurrent("assumptions") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state"
         href="@(detailUrl)#wd-assumptions"
         id="wd-tab-assumptions">Assumptions</a>
    </li>
  </ul>
</nav>
