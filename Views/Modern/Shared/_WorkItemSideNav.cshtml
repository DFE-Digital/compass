@model Compass.Models.Modern.Work.WorkItem
@{
  if (Model == null)
  {
    return;
  }

  var detailUrl = Url.Action("Detail", "ModernWork", new { id = Model.Id });
  var section = (ViewBag.WorkChromeSection as string ?? "overview").Trim().ToLowerInvariant();
  var showRaid = ViewBag.ShowRaidNavigation == true;
  var showServiceRegister = ViewBag.ShowFipsDatabaseServiceRegister as bool? == true;
  var serviceRegisterLinkCount = ViewBag.WorkServiceRegisterLinkCount as int? ?? 0;
  var milestoneCount = ViewBag.WorkSideNavMilestoneCount as int? ?? 0;
  var monthlyUpdatesCount = ViewBag.WorkSideNavMonthlyUpdatesCount as int? ?? 0;
  var risksCount = ViewBag.WorkSideNavRisksCount as int? ?? 0;
  var issuesCount = ViewBag.WorkSideNavIssuesCount as int? ?? 0;
  var assumptionsCount = ViewBag.WorkSideNavAssumptionsCount as int? ?? 0;
  var dependenciesCount = ViewBag.WorkSideNavDependenciesCount as int? ?? 0;
  var contactsCount = ViewBag.WorkSideNavContactsCount as int? ?? 0;
  var strategicAlignmentCount = ViewBag.WorkSideNavStrategicAlignmentCount as int? ?? 0;

  bool IsCurrent(string s) =>
      string.Equals(section, s, StringComparison.OrdinalIgnoreCase);
}

<nav class="dfe-f-side-navigation wd-work-detail-tabs modern-work-detail-side-nav"
     aria-label="Work item sections"
     data-module="dfe-f-side-navigation">
  <button type="button"
          class="dfe-f-side-navigation__toggle"
          aria-controls="wd-work-detail-side-nav-list"
          aria-expanded="false">
    Sections
  </button>
  <ul id="wd-work-detail-side-nav-list" class="dfe-f-side-navigation__list" hidden>
    <li class="dfe-f-side-navigation__item@(IsCurrent("overview") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state"
         href="@(detailUrl)#wd-overview"
         id="wd-tab-overview">Overview</a>
    </li>
    <li class="dfe-f-side-navigation__item@(IsCurrent("strategicalignment") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state dfe-f-side-navigation__link--with-badge"
         href="@(detailUrl)#wd-strategic-alignment"
         id="wd-tab-strategic-alignment">
        <span class="dfe-f-side-navigation__link-text">Strategic alignment</span>
        @await Html.PartialAsync("~/Views/Modern/Shared/_SideNavCountBadge.cshtml", strategicAlignmentCount)
      </a>
    </li>
    <li class="dfe-f-side-navigation__item@(IsCurrent("updates") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state dfe-f-side-navigation__link--with-badge"
         href="@(detailUrl)#wd-updates"
         id="wd-tab-updates">
        <span class="dfe-f-side-navigation__link-text">Monthly updates</span>
        @await Html.PartialAsync("~/Views/Modern/Shared/_SideNavCountBadge.cshtml", monthlyUpdatesCount)
      </a>
    </li>
    <li class="dfe-f-side-navigation__item@(IsCurrent("milestones") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state dfe-f-side-navigation__link--with-badge"
         href="@(detailUrl)#wd-milestones"
         id="wd-tab-milestones">
        <span class="dfe-f-side-navigation__link-text">Milestones</span>
        @await Html.PartialAsync("~/Views/Modern/Shared/_SideNavCountBadge.cshtml", milestoneCount)
      </a>
    </li>
    @if (showRaid)
    {
      <li class="dfe-f-side-navigation__item@(IsCurrent("risks") ? " dfe-f-side-navigation__item--current" : "")">
        <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state dfe-f-side-navigation__link--with-badge"
           href="@(detailUrl)#wd-risks"
           id="wd-tab-risks">
          <span class="dfe-f-side-navigation__link-text">Risks</span>
          @await Html.PartialAsync("~/Views/Modern/Shared/_SideNavCountBadge.cshtml", risksCount)
        </a>
      </li>
      <li class="dfe-f-side-navigation__item@(IsCurrent("issues") ? " dfe-f-side-navigation__item--current" : "")">
        <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state dfe-f-side-navigation__link--with-badge"
           href="@(detailUrl)#wd-issues"
           id="wd-tab-issues">
          <span class="dfe-f-side-navigation__link-text">Issues</span>
          @await Html.PartialAsync("~/Views/Modern/Shared/_SideNavCountBadge.cshtml", issuesCount)
        </a>
      </li>
    }
    <li class="dfe-f-side-navigation__item@(IsCurrent("assumptions") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state dfe-f-side-navigation__link--with-badge"
         href="@(detailUrl)#wd-assumptions"
         id="wd-tab-assumptions">
        <span class="dfe-f-side-navigation__link-text">Assumptions</span>
        @await Html.PartialAsync("~/Views/Modern/Shared/_SideNavCountBadge.cshtml", assumptionsCount)
      </a>
    </li>
    <li class="dfe-f-side-navigation__item@(IsCurrent("dependencies") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state dfe-f-side-navigation__link--with-badge"
         href="@(detailUrl)#wd-dependencies"
         id="wd-tab-dependencies">
        <span class="dfe-f-side-navigation__link-text">Dependencies</span>
        @await Html.PartialAsync("~/Views/Modern/Shared/_SideNavCountBadge.cshtml", dependenciesCount)
      </a>
    </li>
    <li class="dfe-f-side-navigation__item@(IsCurrent("contacts") ? " dfe-f-side-navigation__item--current" : "")">
      <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state dfe-f-side-navigation__link--with-badge"
         href="@(detailUrl)#wd-contacts"
         id="wd-tab-contacts">
        <span class="dfe-f-side-navigation__link-text">Contacts</span>
        @await Html.PartialAsync("~/Views/Modern/Shared/_SideNavCountBadge.cshtml", contactsCount)
      </a>
    </li>
    @if (showServiceRegister)
    {
      <li class="dfe-f-side-navigation__item@(IsCurrent("serviceregister") ? " dfe-f-side-navigation__item--current" : "")">
        <a class="dfe-f-side-navigation__link govuk-link govuk-link--no-visited-state dfe-f-side-navigation__link--with-badge"
           href="@(detailUrl)#wd-service-register"
           id="wd-tab-service-register">
          <span class="dfe-f-side-navigation__link-text">Service register</span>
          @await Html.PartialAsync("~/Views/Modern/Shared/_SideNavCountBadge.cshtml", serviceRegisterLinkCount)
        </a>
      </li>
    }
  </ul>
</nav>
