@{
  var workItemId = (Guid)ViewBag.WorkItemId!;
  var currentSection = ViewBag.WorkSection as string ?? "";
  var detailUrl = Url.Action("Detail", "Work", new { id = workItemId });
}
<nav class="admin-sidebar" aria-label="Work item sections">
  <h2 class="admin-sidebar__title">Sections</h2>
  <ul class="admin-sidebar__list">
    <li class="admin-sidebar__item">
      <a href="@(detailUrl)#wd-overview" class="admin-sidebar__link @(currentSection == "overview" ? "admin-sidebar__link--active" : "")" data-section="overview">Overview</a>
    </li>
    <li class="admin-sidebar__item">
      <a href="@(detailUrl)#wd-updates" class="admin-sidebar__link @(currentSection == "updates" ? "admin-sidebar__link--active" : "")" data-section="updates">Monthly updates</a>
    </li>
    <li class="admin-sidebar__item">
      <a href="@(detailUrl)#wd-rag-history" class="admin-sidebar__link @(currentSection == "rag-history" ? "admin-sidebar__link--active" : "")" data-section="rag-history">RAG history</a>
    </li>
    <li class="admin-sidebar__item">
      <a href="@(detailUrl)#wd-milestones" class="admin-sidebar__link @(currentSection == "milestones" ? "admin-sidebar__link--active" : "")" data-section="milestones">Milestones</a>
    </li>
    <li class="admin-sidebar__item">
      <a href="@Url.Action("AddMilestone", "ModernWork", new { id = workItemId })" class="admin-sidebar__link">Add milestone</a>
    </li>
    <li class="admin-sidebar__item">
      <a href="@(detailUrl)#wd-team" class="admin-sidebar__link @(currentSection == "contacts" ? "admin-sidebar__link--active" : "")" data-section="contacts">Contacts</a>
    </li>
    <li class="admin-sidebar__item">
      <a href="@Url.Action("EditPeople", "Work", new { id = workItemId })" class="admin-sidebar__link @(currentSection == "team" ? "admin-sidebar__link--active" : "")">Edit people &amp; team</a>
    </li>
    <li class="admin-sidebar__item">
      <a href="@(detailUrl)#wd-overview" class="admin-sidebar__link @(currentSection == "overview" ? "admin-sidebar__link--active" : "")" data-section="strategic-alignment">Strategic alignment</a>
    </li>
    <li class="admin-sidebar__item">
      <a href="@(detailUrl)#wd-team" class="admin-sidebar__link @(currentSection == "team" ? "admin-sidebar__link--active" : "")" data-section="team">Team</a>
    </li>
    <li class="admin-sidebar__item">
      <a href="@(detailUrl)#wd-dependencies" class="admin-sidebar__link @(currentSection == "dependencies" ? "admin-sidebar__link--active" : "")" data-section="dependencies">Manage links &amp; dependencies</a>
    </li>
  </ul>
</nav>
