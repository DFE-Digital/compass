@* Work item detail — “Change” links load edit forms into this modal (fetch, not iframe). *@
<dialog id="wd-overview-edit-modal"
        class="dfe-f-modal govuk-!-margin-0 work-overview-edit-modal"
        data-module="dfe-f-modal"
        aria-labelledby="wd-overview-edit-modal-title"
        aria-modal="true"
        role="dialog">
  <div class="dfe-f-modal__panel">
    <header class="dfe-f-modal__header">
      <h2 id="wd-overview-edit-modal-title" class="govuk-heading-m dfe-f-modal__title">Edit</h2>
      <button type="button" class="dfe-f-modal__close" data-dfe-modal-close aria-label="Close">
        <span class="dfe-f-modal__close-x" aria-hidden="true">×</span>
      </button>
    </header>
    <div class="dfe-f-modal__body wd-overview-edit-modal__body govuk-!-padding-0">
      <div id="wd-overview-edit-modal-host"
           class="wd-overview-edit-modal__host work-embed-modal-body"
           aria-live="polite"
           aria-busy="false"></div>
    </div>
  </div>
</dialog>
<button type="button"
        id="wd-overview-edit-modal-opener"
        class="govuk-visually-hidden"
        aria-controls="wd-overview-edit-modal"
        tabindex="-1"
        hidden>Open edit</button>
