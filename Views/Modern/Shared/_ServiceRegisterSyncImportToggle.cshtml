@model ServiceRegisterSyncSettingsViewModel

<div class="dfe-f-toggle" data-module="dfe-f-toggle">
  <div class="dfe-f-toggle__title-wrapper">
    <h2 class="dfe-f-toggle__heading govuk-!-margin-bottom-0">
      <button type="button" class="dfe-f-toggle__button" aria-expanded="@(Model.LastImportResult != null ? "true" : "false")" aria-controls="fips-sync-panel-import" id="fips-sync-toggle-import">
        <span class="dfe-f-toggle__icon" aria-hidden="true"></span>
        <span class="dfe-f-toggle__title">Import from Excel</span>
      </button>
    </h2>
  </div>
  <div id="fips-sync-panel-import" class="dfe-f-toggle__content"@if (Model.LastImportResult == null) { <text> hidden</text> }>
    <div class="dfe-f-toggle__body">
      <p class="govuk-body-s govuk-!-margin-bottom-3" style="color:#505a5f;">
        Bulk update <strong>phase</strong> and <strong>product URL</strong> from a FIPS completion export (.xlsx).
        Matches products by <strong>FIPS ID</strong> (preferred) or <strong>product title</strong>.
        Updates FIPS (CMS) and matching service register records.
      </p>
      <p class="govuk-body-s govuk-!-margin-bottom-3">
        <a class="govuk-link" href="@Url.Action("ServiceRegisterExportCompletionTemplate", "ModernOperations")">Download import template</a>
        <span style="color:#505a5f;"> — same columns as the DdtReports FIPS completion export.</span>
      </p>
      <form method="post" action="@Url.Action("ServiceRegisterImportCompletion", "ModernOperations")" enctype="multipart/form-data" class="govuk-!-margin-bottom-0">
        @Html.AntiForgeryToken()
        <div class="govuk-form-group">
          <label class="govuk-label" for="fips-completion-import-file">Upload Excel file</label>
          <div class="govuk-hint" id="fips-completion-import-hint">Edit phase and product URL columns, then upload. Leave other columns unchanged.</div>
          <input class="govuk-file-upload" id="fips-completion-import-file" name="file" type="file" accept=".xlsx,.xlsm,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" aria-describedby="fips-completion-import-hint" required />
        </div>
        <button type="submit" class="govuk-button">Import updates</button>
      </form>
    </div>
  </div>
</div>
