<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@ViewData["Title"] — Compass</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/modern/css/govuk-frontend-6.1.0.min.css" />
    <link rel="stylesheet" href="~/modern/css/compass2-design.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/modern/css/compass2-app.css" asp-append-version="true" />
    <link rel="icon" href="~/modern/assets/images/favicon.svg" type="image/svg+xml" />
    <link rel="mask-icon" href="~/modern/assets/images/govuk-icon-mask.svg" color="#0b0c0c" />
    <link rel="apple-touch-icon" sizes="180x180" href="~/modern/assets/images/favicon.svg" />
    <meta name="theme-color" content="#0b0c0c" />
    <meta name="format-detection" content="telephone=no" />
    @await RenderSectionAsync("Styles", required: false)
</head>

<body class="compass2-body @(IsSectionDefined("Breadcrumbs") ? "compass2-body--has-breadcrumbs" : "")" data-main-nav="@(ViewBag.MainNavSection ?? "")" data-sub-nav="@(ViewBag.SubNavItem ?? "")">
  <a href="#main-content" class="dfe-c-skip-link">Skip to main content</a>

  @await Html.PartialAsync("~/Views/Modern/Shared/_Header.cshtml")

  @if (IsSectionDefined("Breadcrumbs") && !IsSectionDefined("Masthead"))
  {
    <nav class="dfe-c-breadcrumb dfe-c-breadcrumb--visible" aria-label="Breadcrumb">
      <div class="govuk-width-container dfe-c-breadcrumb__inner">
        <ol>
          @RenderSection("Breadcrumbs", required: false)
        </ol>
      </div>
    </nav>
  }

  @RenderSection("Masthead", required: false)

  <main class="dfe-c-main" id="main-content" role="main">
    <div class="govuk-width-container dfe-c-page">
      @await Html.PartialAsync("~/Views/Modern/Shared/_TempDataBanner.cshtml")
      @RenderBody()
    </div>
  </main>

  @await Html.PartialAsync("~/Views/Modern/Shared/_Footer.cshtml")

  <div id="toast" class="dfe-c-toast" role="status" aria-live="polite" aria-atomic="true">
    <span aria-hidden="true">✓</span> <span id="toast-msg"></span>
  </div>

  @await Html.PartialAsync("~/Views/Modern/Shared/_ConfirmModal.cshtml")

  <script src="~/modern/js/compass2-design-file.js" asp-append-version="true"></script>
  @await RenderSectionAsync("Scripts", required: false)
  <script src="~/modern/js/site.js" asp-append-version="true"></script>
  <script src="~/modern/js/dfe-f-panel-container.js" asp-append-version="true"></script>
  <script src="~/modern/js/dfe-sortable-table.js" asp-append-version="true"></script>
  <script src="~/modern/js/user-picker.js" asp-append-version="true"></script>
  <script src="~/modern/js/confirm-modal.js" asp-append-version="true"></script>

  <script type="module" src="~/modern/js/govuk-frontend-6.1.0.min.js"></script>
  <script type="module">
    import {
      initAll
    } from '~/modern/js/govuk-frontend-6.1.0.min.js'
    initAll()
  </script>

</body>
</html>
