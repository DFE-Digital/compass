@{
	var cspNonce = Context.Items["Nonce"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="en" class="govuk-template govuk-template--rebranded">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<title>@ViewData["Title"] — Compass</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
		<link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Sharp:opsz,wght,FILL,GRAD@24,400,1,0" rel="stylesheet">
		<link rel="stylesheet" href="~/modern/css/govuk-frontend-6.1.0.min.css" />
		<link rel="stylesheet" href="~/_content/DfEDigital.Frontend.AspNetCore/dfe/dfe.min.css" asp-append-version="true" />
		<link rel="stylesheet" href="~/modern/css/modern.css" asp-append-version="true" />
		<link rel="icon" href="~/modern/assets/images/favicon.svg" type="image/svg+xml" />
		<link rel="mask-icon" href="~/modern/assets/images/govuk-icon-mask.svg" color="#1d70b8" />
		<link rel="apple-touch-icon" sizes="180x180" href="~/modern/assets/images/favicon.svg" />
		<meta name="theme-color" content="#1d70b8" />
		<script type="text/javascript" nonce="@cspNonce">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "wsxf2m282b");
</script>
		@await RenderSectionAsync("Styles", required: false)
	</head>
	<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-QFGPH30G4N" nonce="@cspNonce"></script>
<script nonce="@cspNonce">
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-QFGPH30G4N');
</script>
	<body class="govuk-template__body govuk-body use-dfe-brand  @(IsSectionDefined("Breadcrumbs") ? "compass2-body--has-breadcrumbs" : "")" data-main-nav="@(ViewBag.MainNavSection ?? "")" data-sub-nav="@(ViewBag.SubNavItem ?? "")">
		<script nonce="@cspNonce">
			document.body.className += ' js-enabled' + ('noModule' in HTMLScriptElement.prototype ? ' govuk-frontend-supported' : '');
		</script>

		@await Html.PartialAsync("~/Views/Modern/Shared/_DevEnvironmentBanner.cshtml")

		<a href="#main-content" class="govuk-skip-link" data-module="govuk-skip-link">Skip to main content</a>

		@await Html.PartialAsync("~/Views/Modern/Shared/_Header.cshtml")

		@if (IsSectionDefined("Breadcrumbs") && !IsSectionDefined("Masthead"))
		{
			<div class="dfe-f-breadcrumb-wrapper">
				<div class="govuk-width-container">
					<div class="compass-breadcrumb-bar">
						<nav class="govuk-breadcrumbs" aria-label="Breadcrumb">
							<ol class="govuk-breadcrumbs__list">
								@RenderSection("Breadcrumbs", required: false)
							</ol>
						</nav>
					</div>
				</div>
			</div>
		}

		@RenderSection("Masthead", required: false)

		<main class="dfe-c-main" id="main-content" role="main">
			<div class="govuk-width-container dfe-c-page">
				@await Html.PartialAsync("~/Views/Modern/Shared/_TempDataBanner.cshtml")
				@RenderBody()
			</div>
		</main>

		@await Html.PartialAsync("~/Views/Modern/Shared/_Footer.cshtml")
		@await Html.PartialAsync("~/Views/Shared/_BackToTop.cshtml")

		@await Html.PartialAsync("~/Views/Modern/Shared/_ConfirmModal.cshtml")
		@await Html.PartialAsync("~/Views/Modern/Shared/_ViewAsModal.cshtml")
		@await Html.PartialAsync("~/Views/Modern/Shared/_GeneratingReportModal.cshtml")
		@await Html.PartialAsync("~/Views/Modern/Shared/_PageNavLoadingOverlay.cshtml")
		<script src="~/modern/js/compass2-design-file.js" asp-append-version="true" nonce="@cspNonce"></script>
		@await RenderSectionAsync("Scripts", required: false)
		<script src="~/modern/js/site.js" asp-append-version="true" nonce="@cspNonce"></script>
		<script src="~/_content/DfEDigital.Frontend.AspNetCore/dfe/dfe-frontend.iife.min.js" asp-append-version="true" nonce="@cspNonce"></script>
		<script src="~/modern/js/dfe-f-panel-container.js" asp-append-version="true" nonce="@cspNonce"></script>
		<script src="~/modern/js/user-picker.js" asp-append-version="true" nonce="@cspNonce"></script>
		<script src="~/modern/js/view-as.js" asp-append-version="true" nonce="@cspNonce"></script>
		<script src="~/modern/js/confirm-modal.js" asp-append-version="true" nonce="@cspNonce"></script>
		<script src="~/modern/js/generating-report-modal.js" asp-append-version="true" nonce="@cspNonce"></script>
		<script src="~/modern/js/subnav-export.js" asp-append-version="true" nonce="@cspNonce"></script>
		<script src="~/modern/js/page-data-access.js" asp-append-version="true" nonce="@cspNonce"></script>
		<script src="~/modern/js/page-nav-loading.js" asp-append-version="true" nonce="@cspNonce"></script>
		<script type="module" src="~/modern/js/govuk-frontend-init.js" asp-append-version="true" nonce="@cspNonce"></script>

	</body>
</html>
