@* Full-page blocking state while a slow full navigation runs (reporting GET pages). *@
@* Styling: same as generating-report (compass2-app.css .generating-report-*) *@
@* Default copy; page-nav-loading.js sets title from the target URL. *@
<div id="page-nav-loading-overlay"
     class="generating-report-overlay"
     role="presentation"
     aria-hidden="true"
     style="display: none;">
  <div id="page-nav-loading-dialog"
       class="generating-report-dialog"
       role="status"
       aria-live="polite"
       aria-relevant="additions text"
       style="display: none;">
    <div class="generating-report-dialog__spinner" aria-hidden="true"></div>
    <h2 id="page-nav-loading-title" class="generating-report-dialog__title">Loading report</h2>
    <p id="page-nav-loading-hint" class="generating-report-dialog__hint">Please wait while the page is prepared.</p>
  </div>
</div>
