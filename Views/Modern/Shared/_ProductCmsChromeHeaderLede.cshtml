@model Compass.Models.ProductDto
@using Compass.Models
@{
  var types = ProductDtoViewHelpers.TypeNames(Model);
}
<div class="work-item-header__badges dfe-c-mt-2">
  @if (!string.IsNullOrWhiteSpace(Model.State))
  {
    <span class="work-item-badge work-item-badge--status">@Model.State</span>
  }
  @if (!string.IsNullOrWhiteSpace(Model.Phase))
  {
    <span class="work-item-badge work-item-badge--phase">@Model.Phase</span>
  }
  @foreach (var t in types.Take(4))
  {
    <span class="work-item-badge" style="background:#e8eff7;color:#003a69;border:1px solid #b5c9e0;">@t</span>
  }
  @if (types.Count > 4)
  {
    <span class="work-item-badge" style="background:#f3f2f1;color:#505a5f;">+@(types.Count - 4) types</span>
  }
</div>
