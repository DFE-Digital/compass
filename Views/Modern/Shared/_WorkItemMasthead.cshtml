@model Compass.Models.Modern.Work.WorkItem
@using System.Linq
@using Compass.Models
@using Compass.Models.Modern.Work
@using Compass.ViewModels.Modern
@{
  var work = Model;
  var workNumber = ViewBag.WorkIdShort as string ?? work.Id.ToString("D8", System.Globalization.CultureInfo.InvariantCulture);
  var caption = "WI-" + workNumber;
  var portfolioName = ViewBag.PortfolioName as string ?? "—";
  var priorityName = ViewBag.PriorityName as string ?? "—";
  var primaryContactUser = ViewBag.PrimaryContactUser as User;
  var statusDisplay = ViewBag.WorkStatusDisplayName as string ?? work.Status ?? "—";
  var latestRag = ViewBag.LatestRag as ChromeRagSnapshot ?? work.RagHistory?.OrderByDescending(r => r.UpdatedAt).FirstOrDefault();
  var ragDisplayName = latestRag?.RagStatus?.Name ?? ViewBag.CurrentRagName as string;
  var currentRagCssClass = ViewBag.CurrentRagCssClass as string;
  var currentRagBgKey = ViewBag.CurrentRagBackgroundColourKey as string;
  var currentRagTextKey = ViewBag.CurrentRagTextColourKey as string;
  var trackingRegisters = ViewBag.WorkRaidTrackingRegisters as IReadOnlyList<WorkRaidRegisterTrackingVm>
      ?? Array.Empty<WorkRaidRegisterTrackingVm>();
  var trackingCount = trackingRegisters.Count;

  string DisplayName(User? u)
  {
    if (u == null) return "—";
    var firstLast = (u.FirstName ?? "").Trim() + " " + (u.LastName ?? "").Trim();
    return !string.IsNullOrWhiteSpace(firstLast) ? firstLast.Trim() : (u.Name ?? "—");
  }
}

<div class="work-item-masthead govuk-!-margin-bottom-6">
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds-from-desktop">
      <p class="govuk-caption-m govuk-!-margin-bottom-1 govuk-!-margin-top-0">@caption</p>
      <h1 class="govuk-heading-l govuk-!-margin-bottom-4">@work.Title</h1>
    </div>
    <div class="govuk-grid-column-one-third-from-desktop work-item-masthead__actions">
      <div class="work-item-masthead__actions-inner">
        @await Html.PartialAsync("_WorkItemHeaderActions", work)
      </div>
    </div>
  </div>
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <div class="work-item-masthead__meta-wrap">
        <table class="govuk-table govuk-table--small-text-until-tablet dfe-f-table--condensed work-item-masthead__meta govuk-!-margin-bottom-0">
          <caption class="govuk-table__caption govuk-visually-hidden">Work item summary</caption>
          <thead class="govuk-table__head">
          <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">RAG</th>
            <th scope="col" class="govuk-table__header">Priority</th>
            <th scope="col" class="govuk-table__header">Business area</th>
            <th scope="col" class="govuk-table__header">Primary contact</th>
            <th scope="col" class="govuk-table__header">Status</th>
            <th scope="col" class="govuk-table__header">Tracked</th>
          </tr>
          </thead>
            <tbody class="govuk-table__body">
            <tr class="govuk-table__row">
              <td class="govuk-table__cell">
                @if (!string.IsNullOrEmpty(ragDisplayName))
                {
                  @if (!string.IsNullOrEmpty(currentRagBgKey) || !string.IsNullOrEmpty(currentRagTextKey))
                  {
                    <span class="dfe-f-badge dfe-f-badge--small"
                          style="@(string.IsNullOrEmpty(currentRagBgKey) ? "" : "background-color: var(--govuk-colour-" + currentRagBgKey + ");")@(string.IsNullOrEmpty(currentRagTextKey) ? "" : " color: var(--govuk-colour-" + currentRagTextKey + ");")">@ragDisplayName.ToUpperInvariant()</span>
                  }
                  else
                  {
                    <span class="@WorkBadgeCss.RagDfeFrontendBadgeClass(currentRagCssClass, ragDisplayName)">@ragDisplayName.ToUpperInvariant()</span>
                  }
                }
                else
                {
                  <span class="govuk-hint govuk-!-margin-bottom-0">—</span>
                }
              </td>
              <td class="govuk-table__cell">
                @if (!string.IsNullOrWhiteSpace(priorityName) && priorityName != "—")
                {
                  <span class="@WorkBadgeCss.PriorityDfeFrontendBadgeClass(priorityName) dfe-f-badge--small">@priorityName.ToUpperInvariant()</span>
                }
                else
                {
                  <span class="govuk-hint govuk-!-margin-bottom-0">—</span>
                }
              </td>
              <td class="govuk-table__cell">@portfolioName</td>
              <td class="govuk-table__cell">
                @if (primaryContactUser != null)
                {
                  var pcName = DisplayName(primaryContactUser);
                  @if (!string.IsNullOrWhiteSpace(primaryContactUser.Email))
                  {
                    <a href="mailto:@primaryContactUser.Email" class="govuk-link govuk-link--no-visited-state">@pcName</a>
                  }
                  else
                  {
                    @pcName
                  }
                }
                else
                {
                  <span class="govuk-hint govuk-!-margin-bottom-0">—</span>
                }
              </td>
              <td class="govuk-table__cell">
                <span class="@WorkBadgeCss.StatusDfeFrontendBadgeClass(statusDisplay) dfe-f-badge--small">@statusDisplay.ToUpperInvariant()</span>
              </td>
              <td class="govuk-table__cell">
                @if (trackingCount == 0)
                {
                  <span class="govuk-hint govuk-!-margin-bottom-0">—</span>
                }
                else
                {
                  <span class="work-item-masthead__tracked-count">@trackingCount</span>
                  <button type="button"
                          class="work-item-masthead__tracked-info"
                          id="work-item-raid-tracking-open"
                          aria-haspopup="dialog"
                          aria-controls="work-item-raid-tracking-modal">
                    <span class="work-item-masthead__tracked-info-icon" aria-hidden="true">i</span>
                    <span class="govuk-visually-hidden">Show which RAID registers track this work item (@trackingCount)</span>
                  </button>
                }
              </td>
            </tr>
            </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@if (trackingCount > 0)
{
  @await Html.PartialAsync("~/Views/Modern/Shared/_WorkItemRaidTrackingModal.cshtml")
  <style nonce="@(Context.Items["Nonce"]?.ToString() ?? "")">
    .work-item-masthead__tracked-count { font-weight: 700; margin-right: 4px; }
    .work-item-masthead__tracked-info {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 1.25rem;
      height: 1.25rem;
      padding: 0;
      border: 2px solid #1d70b8;
      border-radius: 50%;
      background: #fff;
      color: #1d70b8;
      font: inherit;
      font-size: 0.75rem;
      font-weight: 700;
      line-height: 1;
      vertical-align: middle;
      cursor: pointer;
    }
    .work-item-masthead__tracked-info:hover,
    .work-item-masthead__tracked-info:focus {
      background: #1d70b8;
      color: #fff;
      outline: 3px solid transparent;
      box-shadow: 0 0 0 3px #ffdd00;
    }
    .work-item-masthead__tracked-info-icon { font-style: italic; font-family: Georgia, serif; }
  </style>
  <script nonce="@(Context.Items["Nonce"]?.ToString() ?? "")">
    (function () {
      var btn = document.getElementById('work-item-raid-tracking-open');
      var dialog = document.getElementById('work-item-raid-tracking-modal');
      if (!btn || !dialog) return;
      btn.addEventListener('click', function () {
        if (typeof dialog.showModal === 'function') dialog.showModal();
      });
      dialog.querySelectorAll('[data-dfe-modal-close]').forEach(function (el) {
        el.addEventListener('click', function () { dialog.close(); });
      });
    })();
  </script>
}
