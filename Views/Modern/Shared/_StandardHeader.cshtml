@model Compass.Models.ViewModels.StandardHeaderViewModel
@{
  if (Model == null) { return; }
}
<div class="work-item-header__caption">DDT Standard</div>
<h1 class="govuk-heading-l work-item-header__h1">@Model.Title</h1>
<p class="dfe-c-body-s muted dfe-c-mt-1">
 Version @Model.Version | <span class="work-item-badge work-item-badge--status @(Model.StatusBadgeClass ??"")">@Model.StatusLabel</span>
</p>
