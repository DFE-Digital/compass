@model Compass.ViewModels.Modern.ModernPageHeaderViewModel
@{
  var useH2 = string.Equals(Model.HeadingTag, "h2", StringComparison.OrdinalIgnoreCase);
}

<div class="govuk-grid-row modern-page-header govuk-!-margin-bottom-6">
@if (Model.Actions != null)
{
  <div class="govuk-grid-column-two-thirds">
    @if (!string.IsNullOrWhiteSpace(Model.BackLinkHref))
    {
      <p class="govuk-!-margin-bottom-3 govuk-!-margin-top-0"><a class="govuk-back-link govuk-!-margin-bottom-0" href="@Model.BackLinkHref">@(Model.BackLinkText ?? "Back")</a></p>
    }
    @if (!string.IsNullOrWhiteSpace(Model.Caption))
    {
      <p class="govuk-caption-m govuk-!-margin-bottom-1 govuk-!-margin-top-0">@Model.Caption</p>
    }
    @if (useH2)
    {
      <h2 class="@Model.HeadingClass govuk-!-margin-bottom-0">@Model.Title</h2>
    }
    else
    {
      <h1 class="@Model.HeadingClass govuk-!-margin-bottom-0">@Model.Title</h1>
    }
    @if (Model.TitleBelow != null)
    {
      <div class="modern-page-header__title-below govuk-!-margin-top-2 govuk-!-margin-bottom-0">@Model.TitleBelow</div>
    }
    @if (Model.Lede != null)
    {
      <div class="modern-page-header__lede govuk-!-margin-top-2 govuk-!-margin-bottom-0">@Model.Lede</div>
    }
  </div>
  <div class="govuk-grid-column-one-third modern-page-header__actions-col">
    <div class="modern-page-header__actions">
      @Model.Actions
    </div>
  </div>
}
else
{
  <div class="@(Model.ConstrainToTwoThirds ? "govuk-grid-column-two-thirds" : "govuk-grid-column-full")">
    @if (!string.IsNullOrWhiteSpace(Model.BackLinkHref))
    {
      <p class="govuk-!-margin-bottom-3 govuk-!-margin-top-0"><a class="govuk-back-link govuk-!-margin-bottom-0" href="@Model.BackLinkHref">@(Model.BackLinkText ?? "Back")</a></p>
    }
    @if (!string.IsNullOrWhiteSpace(Model.Caption))
    {
      <p class="govuk-caption-m govuk-!-margin-bottom-1 govuk-!-margin-top-0">@Model.Caption</p>
    }
    @if (useH2)
    {
      <h2 class="@Model.HeadingClass govuk-!-margin-bottom-0">@Model.Title</h2>
    }
    else
    {
      <h1 class="@Model.HeadingClass govuk-!-margin-bottom-0">@Model.Title</h1>
    }
    @if (Model.TitleBelow != null)
    {
      <div class="modern-page-header__title-below govuk-!-margin-top-2 govuk-!-margin-bottom-0">@Model.TitleBelow</div>
    }
    @if (Model.Lede != null)
    {
      <div class="modern-page-header__lede govuk-!-margin-top-2 govuk-!-margin-bottom-0">@Model.Lede</div>
    }
  </div>
}
</div>
