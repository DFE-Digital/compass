@* Minimal layout for presentation mode — no header, full-screen overlay; styles in compass2-app.css *@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Presentation") - Triage Meeting</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/modern/css/compass2-design.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/modern/css/compass2-app.css" asp-append-version="true" />
</head>
<body style="margin:0;background:#0b0c0c;overflow:hidden">
    @RenderBody()
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
