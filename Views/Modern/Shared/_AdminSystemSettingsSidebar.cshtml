@* Left-hand nav for System settings (Email templates, Event reference, UI Configuration, API tokens). Email recipients are under Admin → Lookups & options → System lookups and settings. Set ViewBag.SystemSettingsSection to "email-templates" | "event-reference" | "ui-configuration" | "api-tokens" *@
@{
  var section = ViewBag.SystemSettingsSection as string ?? "";
}
<nav class="admin-sidebar" aria-label="System settings">
 <h2 class="admin-sidebar__title">System settings</h2>
 <ul class="admin-sidebar__list">
 <li class="admin-sidebar__item">
 <a href="@Url.Action("SystemSettings", "Admin")" class="admin-sidebar__link @(section =="email-templates" ? "admin-sidebar__link--active" : "")">Email templates</a>
    </li>
 <li class="admin-sidebar__item">
 <a href="@Url.Action("NotificationEventReference", "Admin")" class="admin-sidebar__link @(section =="event-reference" ? "admin-sidebar__link--active" : "")">Event key and placeholder reference</a>
    </li>
 <li class="admin-sidebar__item">
 <a href="@Url.Action("UiConfiguration", "Admin")" class="admin-sidebar__link @(section =="ui-configuration" ? "admin-sidebar__link--active" : "")">UI Configuration</a>
    </li>
 <li class="admin-sidebar__item">
 <a href="@Url.Action("Index", "ApiTokens")" class="admin-sidebar__link @(section =="api-tokens" ? "admin-sidebar__link--active" : "")">API tokens</a>
    </li>
  </ul>
</nav>
