<dialog id="fips-cmdb-bulk-sync-confirm-modal"
        class="dfe-f-modal govuk-!-margin-0 fips-cmdb-sync-modal"
        data-module="dfe-f-modal"
        aria-labelledby="fips-cmdb-bulk-sync-confirm-title"
        aria-describedby="fips-cmdb-bulk-sync-confirm-description"
        aria-modal="true"
        role="dialog">
  <div class="dfe-f-modal__panel">
    <header class="dfe-f-modal__header">
      <h2 id="fips-cmdb-bulk-sync-confirm-title" class="govuk-heading-m dfe-f-modal__title">Run CMDB sync?</h2>
      <button type="button" class="dfe-f-modal__close" data-dfe-modal-close aria-label="Close"><span class="dfe-f-modal__close-x" aria-hidden="true">×</span></button>
    </header>
    <div class="dfe-f-modal__body" id="fips-cmdb-bulk-sync-confirm-description">
      <p class="govuk-body">This will sync every matching FIPS product to CMDB. It will update existing products, add new product entries, and update contacts, titles, and descriptions from CMDB.</p>
      <p class="govuk-body govuk-!-margin-bottom-0"><strong>Product categories are not updated</strong> by this sync. Categories are managed separately in Compass.</p>
    </div>
    <footer class="dfe-f-modal__footer">
      <button type="button" class="govuk-button" id="fips-cmdb-bulk-sync-confirm-proceed">Run sync</button>
      <button type="button" class="govuk-button govuk-button--secondary" id="fips-cmdb-bulk-sync-confirm-cancel" data-dfe-modal-close>Cancel</button>
    </footer>
  </div>
</dialog>

<dialog id="fips-cmdb-bulk-sync-modal"
        class="dfe-f-modal govuk-!-margin-0 fips-cmdb-sync-modal"
        data-module="dfe-f-modal"
        aria-labelledby="fips-cmdb-bulk-sync-title"
        aria-describedby="fips-cmdb-bulk-sync-description"
        aria-modal="true"
        role="dialog">
  <div class="dfe-f-modal__panel">
    <header class="dfe-f-modal__header">
      <h2 id="fips-cmdb-bulk-sync-title" class="govuk-heading-m dfe-f-modal__title">Sync from CMDB</h2>
      <button type="button" class="dfe-f-modal__close" id="fips-cmdb-bulk-sync-header-close" aria-label="Close"><span class="dfe-f-modal__close-x" aria-hidden="true">×</span></button>
    </header>
    <div class="dfe-f-modal__body" id="fips-cmdb-bulk-sync-description">
      <p class="govuk-body" id="fips-cmdb-bulk-sync-live" aria-live="polite" aria-atomic="true">Starting…</p>
      <div class="fips-cmdb-sync-modal__progress-wrap govuk-!-margin-bottom-4">
        <progress id="fips-cmdb-bulk-sync-progress" class="fips-cmdb-sync-modal__progress" max="100" value="0" aria-hidden="true"></progress>
        <p class="govuk-body-s govuk-!-margin-top-1 govuk-!-margin-bottom-0" id="fips-cmdb-bulk-sync-count" style="color:#505a5f;"></p>
      </div>
      <div id="fips-cmdb-bulk-sync-summary" class="govuk-body-s" style="display:none;color:#0b0c0c;"></div>
    </div>
    <footer class="dfe-f-modal__footer">
      <button type="button" class="govuk-button" id="fips-cmdb-bulk-sync-close" style="display:none;">Close and refresh</button>
      <button type="button" class="govuk-button govuk-button--secondary" id="fips-cmdb-bulk-sync-dismiss" disabled>Cancel</button>
    </footer>
  </div>
</dialog>
