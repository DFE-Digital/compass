@* Shown while report / export files are generated (see generating-report-modal.js). *@
<div id="generating-report-overlay" class="generating-report-overlay" role="presentation" aria-hidden="true" style="display: none;">
  <div id="generating-report-dialog" class="generating-report-dialog" role="alertdialog" aria-modal="true" aria-labelledby="generating-report-title" aria-busy="true" style="display: none;">
    <div class="generating-report-dialog__spinner" aria-hidden="true"></div>
    <h2 id="generating-report-title" class="generating-report-dialog__title">Generating report</h2>
    <p class="generating-report-dialog__hint">Please wait — your download will start when the file is ready.</p>
  </div>
</div>
