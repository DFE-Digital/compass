@model Compass.Models.ProductDto
@using Compass.Models
@using Compass.ViewModels.Modern
@{
  var p = Model;
  var businessArea = ProductDtoViewHelpers.BusinessArea(p) ?? "—";
  var idCaption = !string.IsNullOrEmpty(p.FipsId)
    ? p.FipsId!
    : (!string.IsNullOrEmpty(p.DocumentId) ? p.DocumentId! : "—");
  if (idCaption.Length > 28)
    idCaption = idCaption[..25] + "…";
  var productCmsLede = await Html.PartialAsync("_ProductCmsChromeHeaderLede", Model);
}
<div class="work-item-header mb4 product-cms-header">
  @await Html.PartialAsync("_ModernPageHeader", new ModernPageHeaderViewModel {
    Caption = $"FIPS product · {idCaption} · {businessArea}",
    Title = p.Title,
    Lede = productCmsLede,
    HeadingClass = "govuk-heading-l work-item-header__h1"
  })
</div>
