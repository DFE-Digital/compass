@model Compass.Models.ProductDto
@using Compass.Models
@{
  var p = Model;
  var businessArea = ProductDtoViewHelpers.BusinessArea(p) ?? "—";
  var types = ProductDtoViewHelpers.TypeNames(p);
  var idCaption = !string.IsNullOrEmpty(p.FipsId)
    ? p.FipsId!
    : (!string.IsNullOrEmpty(p.DocumentId) ? p.DocumentId! : "—");
  if (idCaption.Length > 28)
    idCaption = idCaption[..25] + "…";
}
<div class="work-item-header mb4 product-cms-header">
  <div class="work-item-header__title">
    <div class="dfe-c-page-title__caption work-item-header__caption">FIPS product · @idCaption · @businessArea</div>
    <h1 class="work-item-header__h1">@p.Title</h1>
    <div class="work-item-header__badges dfe-c-mt-2">
      @if (!string.IsNullOrWhiteSpace(p.State))
      {
        <span class="work-item-badge work-item-badge--status">@p.State</span>
      }
      @if (!string.IsNullOrWhiteSpace(p.Phase))
      {
        <span class="work-item-badge work-item-badge--phase">@p.Phase</span>
      }
      @foreach (var t in types.Take(4))
      {
        <span class="work-item-badge" style="background:#e8eff7;color:#003a69;border:1px solid #b5c9e0;">@t</span>
      }
      @if (types.Count > 4)
      {
        <span class="work-item-badge" style="background:#f3f2f1;color:#505a5f;">+@(types.Count - 4) types</span>
      }
    </div>
  </div>
</div>
