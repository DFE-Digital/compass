@model Compass.Models.Modern.Work.WorkRegisterViewModel
@{
  var opsManage = ViewBag.OpsManageWork as bool? == true;
  var businessAreaCount = Model.BusinessAreas?.Count ?? 0;
}
<p class="govuk-body govuk-!-margin-bottom-0" id="work-reg-count">@(Model.IsMyWork ? "Work assigned to you" : $"{Model.ActiveCount + Model.PausedCount} work items across {businessAreaCount} business areas")@(opsManage && !Model.IsMyWork ? " — search, filter and edit any delivery item." : Model.IsMyWork ? "." : "")</p>
