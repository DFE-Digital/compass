@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<h1 class="dfe-c-heading-l">Error</h1>
<p class="dfe-c-body">An error occurred while processing your request.</p>
@if (Model?.ShowRequestId == true)
{
 <p class="dfe-c-body"><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
}
