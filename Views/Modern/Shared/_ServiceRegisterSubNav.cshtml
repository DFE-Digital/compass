@model FipsProductsViewModel
@{
    var tab = Model.ActiveTab ?? "active";
    string TabCount(int count) => count > 0 ? $" ({count})" : "";
}
<nav class="dfe-f-sub-navigation govuk-!-margin-bottom-3" aria-label="Product sections">
  <ul class="dfe-f-sub-navigation__list">
    <li class="dfe-f-sub-navigation__item@(tab == "my" ? " dfe-f-sub-navigation__item--active" : "")">
      <a class="dfe-f-sub-navigation__link govuk-link" href="@Url.Action("ServiceRegister", "ModernOperations", new { tab = "my" })" id="tab-my"@if (tab == "my") { <text> aria-current="page"</text> }>My products@(TabCount(Model.MyProductsCount))</a>
    </li>
    <li class="dfe-f-sub-navigation__item@(tab == "active" ? " dfe-f-sub-navigation__item--active" : "")">
      <a class="dfe-f-sub-navigation__link govuk-link" href="@Url.Action("ServiceRegister", "ModernOperations", new { tab = "active" })" id="tab-active"@if (tab == "active") { <text> aria-current="page"</text> }>Active@(TabCount(Model.AllProductsCount))</a>
    </li>
    <li class="dfe-f-sub-navigation__item@(tab == "all" ? " dfe-f-sub-navigation__item--active" : "")">
      <a class="dfe-f-sub-navigation__link govuk-link" href="@Url.Action("ServiceRegister", "ModernOperations", new { tab = "all" })" id="tab-all"@if (tab == "all") { <text> aria-current="page"</text> }>All@(TabCount(Model.CatalogueProductsCount))</a>
    </li>
    <li class="dfe-f-sub-navigation__item@(tab == "enterprise" ? " dfe-f-sub-navigation__item--active" : "")">
      <a class="dfe-f-sub-navigation__link govuk-link" href="@Url.Action("ServiceRegister", "ModernOperations", new { tab = "enterprise" })" id="tab-enterprise"@if (tab == "enterprise") { <text> aria-current="page"</text> }>Enterprise@(TabCount(Model.EnterpriseProductsCount))</a>
    </li>
    <li class="dfe-f-sub-navigation__item@(tab == "new" ? " dfe-f-sub-navigation__item--active" : "")">
      <a class="dfe-f-sub-navigation__link govuk-link" href="@Url.Action("ServiceRegister", "ModernOperations", new { tab = "new" })" id="tab-new"@if (tab == "new") { <text> aria-current="page"</text> }>New products@(TabCount(Model.NewProductsCount))</a>
    </li>
    <li class="dfe-f-sub-navigation__item@(tab == "inactive" ? " dfe-f-sub-navigation__item--active" : "")">
      <a class="dfe-f-sub-navigation__link govuk-link" href="@Url.Action("ServiceRegister", "ModernOperations", new { tab = "inactive" })" id="tab-inactive"@if (tab == "inactive") { <text> aria-current="page"</text> }>Inactive@(TabCount(Model.InactiveProductsCount))</a>
    </li>
    <li class="dfe-f-sub-navigation__item@(tab == "retired" ? " dfe-f-sub-navigation__item--active" : "")">
      <a class="dfe-f-sub-navigation__link govuk-link" href="@Url.Action("ServiceRegister", "ModernOperations", new { tab = "retired" })" id="tab-retired"@if (tab == "retired") { <text> aria-current="page"</text> }>Retired@(TabCount(Model.RetiredCount))</a>
    </li>
    <li class="dfe-f-sub-navigation__item@(tab == "sync" || tab == "sync-settings" ? " dfe-f-sub-navigation__item--active" : "")">
      <a class="dfe-f-sub-navigation__link govuk-link" href="@Url.Action("ServiceRegisterSyncSettings", "ModernOperations")" id="tab-sync"@if (tab == "sync" || tab == "sync-settings") { <text> aria-current="page"</text> }>Sync</a>
    </li>
  </ul>
</nav>
