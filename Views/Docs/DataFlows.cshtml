@*
    /docs/data-flows — per-field provenance and consumption flows for the
    Modern COMPASS UI. Each flow card shows where a piece of data is
    captured, what it writes (including side effects), every Modern surface
    that reads it, what notifications / triggers it fires, and downstream
    consumers (exports, API, PowerBI).

    Each card embeds a Mermaid flow diagram (with a "Mermaid source" tab so
    the underlying graph can be inspected or copied for use elsewhere).
*@
@{
    // ---- Mermaid source per flow card. Defined once here so the cards
    // below stay readable. Raw string literals avoid the "@" sigil colliding
    // with Razor attribute parsing.
    const string flowPalette = """

  classDef actor fill:#1b3a5b,stroke:#1d70b8,color:#fff;
  classDef action fill:#2b3a4a,stroke:#7da3c4,color:#fff;
  classDef store fill:#3a2e57,stroke:#9579c7,color:#fff;
  classDef surface fill:#1f4f2c,stroke:#52b06d,color:#fff;
  classDef ext fill:#5a3a18,stroke:#d09a4a,color:#fff;
  classDef trigger fill:#5a1f1f,stroke:#d4534f,color:#fff;
""";

