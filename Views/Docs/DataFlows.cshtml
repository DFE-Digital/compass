  NEW --> S[("DdtStandard<br/>Stage = Draft · StandardUuid<br/>Version 0.1.0 · IsModified = true")]:::store
  EDT(["Author edits a published standard"]):::actor --> ED{{"POST /modern/standards/ddt/{id}/start-edit"}}:::action
  ED --> SC[("Child DdtStandard<br/>ParentStandardId set · Stage = Draft")]:::store
  WORK(["Author edits child content"]):::actor --> EP{{"POST /modern/standards/ddt/{id}/edit"}}:::action
  EP --> CON[("Purpose · Criteria · HowToMeet<br/>Governance · RelatedGuidance<br/>Owners · Contacts · Categories · Phases<br/>ValidationRules · Products · Exceptions")]:::store
  AUTH2(["Author submits for review"]):::actor --> SUB{{"POST /modern/standards/ddt/{id}/submit-for-review"}}:::action
  SUB --> ST1[("Stage = Under Review")]:::store
  REV(["Reviewer approves"]):::actor --> APP{{"POST /modern/standards/ddt/{id}/approve"}}:::action
  APP --> ST2[("Stage = Approved<br/>GovernanceApproval = true")]:::store
  REV2(["Reviewer rejects"]):::actor --> REJ{{"POST /modern/standards/ddt/{id}/reject"}}:::action
  REJ --> ST3[("Stage = Draft (DdtStandardComment captures reason)")]:::store
  PUB(["Publisher publishes"]):::actor --> PB{{"POST /modern/standards/ddt/{id}/publish"}}:::action
  PB --> ST4[("Stage = Published<br/>IsPublished = true · PublishedAt<br/>FirstPublished (if first) · Version bumped<br/>Snapshot in DdtStandardVersion")]:::store
  UNP(["Publisher unpublishes"]):::actor --> UP{{"POST /modern/standards/ddt/{id}/delete or admin unpublish"}}:::action
  UP --> UA[("DdtStandardUnpublishAudit")]:::store
  ST1 --> CMT[("DdtStandardComment per transition")]:::store
  ST2 --> CMT
  ST3 --> CMT
  ST4 --> CAT[/"/modern/standards/ddt catalogue"/]:::surface
  S --> DET[/"/modern/standards/ddt/{id} detail"/]:::surface
  ST4 --> PROD["Approved/tolerated products tab"]:::surface
  ST4 --> EXC["Exceptions tab + register"]:::surface
  ST4 --> API[/"GET /api/DdtStandards"/]:::ext
  ST4 --> APIE[/"GET /api/DdtStandards/Exceptions"/]:::ext
  ST4 --> APIP[/"GET /api/DdtStandards/ApprovedProducts"/]:::ext
  ST2 -. transitions .-> AUDIT[("AuditLog<br/>(every stage change)")]:::store
""" + flowPalette;

    var flowStandardsAssessment = """
flowchart LR
  USR(["Assessor opens conduct page"]):::actor --> G{{"GET /modern/standards/functional/assessment/{id}/conduct"}}:::action
  USR --> SAVE{{"POST /modern/standards/functional/assessment/save-response"}}:::action
  SAVE --> R[("AssessmentCriteriaResponse*<br/>per criterion: Attainment + Notes")]:::store
  USR2(["Assessor submits"]):::actor --> SUB{{"POST /modern/standards/functional/assessment/submit"}}:::action
  SUB --> A[("FunctionalStandardAssessment.SubmittedAt set")]:::store
  DEL(["Assessor deletes"]):::actor --> DD{{"POST /modern/standards/functional/assessment/delete"}}:::action
  DD --> DR[("Soft-delete cascade<br/>AssessmentCriteriaResponse removed")]:::store
  R --> SCORE["Score roll-up<br/>practice-area avg(Attainment)<br/>theme avg(practice areas)"]:::action
  SCORE --> SUM[/"/modern/standards/functional/assessment/{id}/summary"/]:::surface
  A --> CAT[/"/modern/standards/functional catalogue<br/>last assessment per standard"/]:::surface
  A --> WORK["Work-item / Service standards card"]:::surface
  A --> WORD[/"Word: /assessment/{id}/export/word"/]:::ext
  A --> XLSX[/"Excel: /assessment/{id}/export"/]:::ext
  R --> PBI[("PowerBI FactAssessmentResponse<br/>+ DimCriterion via Criterion.Id")]:::ext
""" + flowPalette;
}

<div class="developers-docs__intro govuk-!-margin-bottom-6">
    <span class="govuk-caption-xl">Reference</span>
    <h1 class="govuk-heading-xl govuk-!-margin-bottom-2">Data flows</h1>
    <p class="govuk-body-l govuk-!-margin-bottom-0">
        For each piece of data the user captures in COMPASS, the cards below
        show what gets written, every Modern surface that reads it, which
        notifications it fires, and how it leaves the system through exports
        and the JSON API.
    </p>
</div>

<h2 class="govuk-heading-l" id="how-to-read">How to read a flow card</h2>
<p class="govuk-body">Each card follows the same shape:</p>
<ul class="govuk-list govuk-list--bullet">
    <li><strong>Diagram</strong> &mdash; a Mermaid flowchart of the capture, storage and downstream nodes. The <em>Mermaid source</em> tab exposes the raw graph definition so you can copy it into an architecture doc.</li>
    <li><strong>Captured at</strong> &mdash; the Modern URL the user fills in, plus the controller action that handles the POST.</li>
    <li><strong>Stored in</strong> &mdash; the EF entity and database column(s) written by the action.</li>
    <li><strong>Side effects</strong> &mdash; anything else the action writes: history rows, denormalised copies, audit log entries, recomputed scores.</li>
    <li><strong>Surfaces in</strong> &mdash; every Modern page or partial that subsequently reads the value.</li>
    <li><strong>Triggers</strong> &mdash; notifications or workflow rules that fire as a result.</li>
    <li><strong>Downstream</strong> &mdash; CSV / Excel exports, JSON API endpoints, and the implications for PowerBI consumers.</li>
</ul>

<div class="govuk-inset-text">
    Every Modern controller action also writes an <code>AuditLog</code> row
    (entity, id, action, user, timestamp). Audit is omitted from individual
    cards unless the action writes something custom on top. See
    <a class="govuk-link" href="#cross-audit">Cross-cutting: audit &amp; observability</a>
    below.
</div>

<hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

<h2 class="govuk-heading-l" id="work-item-capture">Work item: capture</h2>

<section class="developers-data-flow" id="flow-work-create">
    <header class="developers-data-flow__header">
        <h3 class="developers-data-flow__title">Create a work item</h3>
        <span class="developers-data-flow__kind">Composite create</span>
    </header>
    <partial name="_DataFlowDiagram" model='("work-create", flowWorkCreate)' />
    <div class="developers-data-flow__stages">
        <h4 class="developers-data-flow__label">Captured at</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>GET /ModernWork/Create</code> &rarr; multi-step wizard. Each step persists progress into <code>ProjectDraft</code> (one row per user, payload as JSON) so the user can resume later.</li>
                <li><code>POST /ModernWork/Create</code> &rarr; final submit. Validates, then runs the creation transaction (<code>CreateWorkItem</code>).</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Stored in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>Project</code> &mdash; headline row: <code>Title</code>, <code>Aim</code>, <code>Description</code>, <code>Status</code> = <code>Active</code>, <code>PhaseId</code>, <code>DeliveryPriorityId</code>, <code>WorkType</code> / <code>ActivityTypeId</code>, <code>StartDate</code>, <code>TargetDeliveryDate</code>, <code>PrimaryOrganizationalGroupId</code>, flags (<code>IsFlagship</code>, <code>SubjectToSpendControl</code>, <code>IsCentralRiskBucket</code>, <code>IsAiInitiative</code>).</li>
                <li>Governance contacts &mdash; <code>ProjectSeniorResponsibleOfficer</code>, <code>ProjectServiceOwner</code>, <code>ProjectPmoContact</code>, <code>ProjectBudgetOwner</code>; plus <code>Project.PrimaryContactUserId</code>.</li>
                <li>Strategic alignment joins &mdash; <code>ProjectMission</code>, <code>ProjectObjective</code>, <code>ProjectWorkItemTag</code>.</li>
                <li>Organisational joins &mdash; <code>ProjectDirectorate</code>, <code>ProjectGovernmentDepartment</code>.</li>
                <li>Optional team members &mdash; <code>ProjectContact</code> rows with role-type 5 (custom).</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Side effects</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Wraps the writes in a transaction; on any failure, no row persists and the draft is preserved.</li>
                <li>On success, the user's <code>ProjectDraft</code> is cleared.</li>
                <li>The creator is added to <code>ProjectWatchlist</code> so the new work item shows on their <code>/modern/dashboard</code>.</li>
                <li><code>AuditLog</code> row written with action <code>created</code>.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Surfaces in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Work register &mdash; new row appears in <code>/modern/work</code>, <code>/modern/work/all</code>, and any "by theme" or business-area-scoped views.</li>
                <li>Work detail &mdash; <code>/modern/work/{Id}</code> with every tab (overview, people, RAID, milestones, monthly).</li>
                <li>Picker dialogs &mdash; available as a RAID parent on risk / issue / action / decision / assumption / dependency create forms.</li>
                <li>Demand back-link &mdash; if created from approving a <code>DemandTriageRequest</code>, the new <code>Project.Id</code> is set on <code>DemandTriageRequest.ProjectId</code>.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Triggers</h4>
        <div class="developers-data-flow__body">
            Once the work item becomes reportable (phase joins the monthly-update window), the first monthly-update reminder is scheduled for the SRO / Service Owner / Primary Contact. No outbound email is sent on creation itself.
        </div>

        <h4 class="developers-data-flow__label">Downstream</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>CSV export &mdash; included in the next <code>/modern/work/export-register</code> download.</li>
                <li>JSON API &mdash; new row exposed via <code>GET /api/v1/work-items</code> (and <code>/{Id}</code>).</li>
                <li>PowerBI &mdash; appears in <code>DimWorkItem</code>; the absence of <code>ProjectRagHistory</code> rows means RAG-trend visuals will be empty until the first monthly update is submitted.</li>
            </ul>
        </div>
    </div>
</section>

<section class="developers-data-flow" id="flow-work-title">
    <header class="developers-data-flow__header">
        <h3 class="developers-data-flow__title">Work item: <code>Title</code></h3>
        <span class="developers-data-flow__kind">Scalar field</span>
    </header>
    <partial name="_DataFlowDiagram" model='("work-title", flowWorkTitle)' />
    <div class="developers-data-flow__stages">
        <h4 class="developers-data-flow__label">Captured at</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>POST /modern/work/create</code> &rarr; <code>ModernWorkController.CreatePost</code> (first capture from the new-work flow).</li>
                <li><code>POST /modern/work/{id}/overview/title</code> &rarr; <code>ModernWorkController.UpdateWorkOverviewTitle</code> (inline edit on the detail header).</li>
                <li><code>POST /modern/work/{id}/edit</code> &rarr; <code>ModernWorkController.EditPost</code> (full edit form).</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Stored in</h4>
        <div class="developers-data-flow__body">
            <code>Project.Title</code> &mdash; <code>nvarchar(200)</code>, required.
        </div>

        <h4 class="developers-data-flow__label">Side effects</h4>
        <div class="developers-data-flow__body">
            <code>Project.UpdatedAt</code> is bumped; an <code>AuditLog</code> row is written with the previous and new value.
        </div>

        <h4 class="developers-data-flow__label">Surfaces in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Work register row link &mdash; <code>/modern/work</code>, <code>/modern/work/all</code>, <code>/modern/work/by-theme</code>.</li>
                <li>Work detail header &mdash; <code>/modern/work/{id}</code> and every sub-tab (<code>/people</code>, <code>/milestones</code>, <code>/monthly</code>, <code>/audit</code>).</li>
                <li>RAID register columns &mdash; <code>/modern/raid/risks</code>, <code>/issues</code>, <code>/actions</code>, <code>/decisions</code> show the parent work-item title.</li>
                <li>Reporting rollups &mdash; <code>/modern/reporting/monthly-update</code>, <code>/raid-review-progress</code>, <code>/priorities</code>, <code>/thematic</code>.</li>
                <li>Dashboards &mdash; <code>/modern</code> and <code>/modern/dashboard</code> watchlist / overdue cards.</li>
                <li>Search results, breadcrumbs and modal pickers.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Triggers</h4>
        <div class="developers-data-flow__body">
            None directly. The title is interpolated into outbound emails (monthly-update reminders, RAID escalation, overdue milestone) when those rules fire.
        </div>

        <h4 class="developers-data-flow__label">Downstream</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>CSV export &mdash; <code>GET /modern/work/export-register</code>.</li>
                <li>Excel export &mdash; <code>GET /modern/raid/dashboard/export.xlsx</code> (parent title column).</li>
                <li>JSON API &mdash; surfaced as <code>title</code> on every work-item-scoped endpoint (<code>/api/v1/risks</code>, <code>/issues</code>, <code>/actions</code>, <code>/milestones</code> via the join).</li>
                <li>PowerBI &mdash; this is the user-facing label of a work item; use it on every <code>DimWorkItem</code>-joined visual.</li>
            </ul>
        </div>
    </div>
</section>

<section class="developers-data-flow" id="flow-work-rag">
    <header class="developers-data-flow__header">
        <h3 class="developers-data-flow__title">Work item: <code>RagStatusId</code> + justification</h3>
        <span class="developers-data-flow__kind">Versioned</span>
    </header>
    <partial name="_DataFlowDiagram" model='("work-rag", flowWorkRag)' />
    <div class="developers-data-flow__stages">
        <h4 class="developers-data-flow__label">Captured at</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>POST /modern/work/{id}/monthly-report/{year}/{month}</code> &rarr; <code>MonthlyReportPost</code> (primary capture path).</li>
                <li>RAG update modal launched from the work-item header (also routed through the monthly-report action).</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Stored in</h4>
        <div class="developers-data-flow__body">
            <code>Project.RagStatusLookupId</code> (current) and a new <code>ProjectRagHistory</code> row capturing <code>RagStatusLookupId</code>, <code>Justification</code>, <code>PathToGreen</code>, <code>ChangedAt</code>, <code>ChangedBy*</code>.
        </div>

        <h4 class="developers-data-flow__label">Side effects</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Legacy <code>Project.RagStatus</code> (string), <code>RagJustification</code> and <code>PathToGreen</code> denormalised for older consumers.</li>
                <li>Submitting also stamps <code>ProjectMonthlyUpdate.SubmittedAt</code>; saving as draft leaves the previous RAG untouched and only writes the <code>Draft*</code> fields.</li>
                <li><code>Project.UpdatedAt</code> bumped; <code>AuditLog</code> entry written for the work item.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Surfaces in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Modern <code>WorkItemRagHistory</code> &mdash; powers the <code>_WorkRagBadge</code> partial used on the detail header, register rows and watchlist.</li>
                <li>Work detail RAG history tab &mdash; <code>/modern/work/{id}#rag-history</code>.</li>
                <li>Monthly update viewer &mdash; <code>/modern/work/{id}/monthly-update/view</code>.</li>
                <li>Cross-org rollups &mdash; <code>/modern/reporting/monthly-update</code>, <code>/raid-review-progress</code>, <code>/priorities</code>, <code>/thematic</code>.</li>
                <li>Operations dashboard &mdash; <code>/modern/operations</code> RAG counts.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Triggers</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>If the new RAG is Red, the next monthly-update cycle requires <code>PathToGreen</code> (server validation in <code>ValidateMonthlyReportForm</code>).</li>
                <li>RAG change of two or more steps within a cycle is flagged in <code>/modern/reporting/raid</code> "RAG volatility" panel.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Downstream</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Monthly update Excel export.</li>
                <li>JSON API &mdash; <code>/api/v1/work-items</code> exposes current RAG; <code>/api/v1/work-items/{id}/rag-history</code> exposes the time series.</li>
                <li>PowerBI &mdash; use <code>ProjectRagHistory</code> for trends; <code>Project.RagStatusLookupId</code> alone collapses to "current snapshot".</li>
            </ul>
        </div>
    </div>
</section>

<section class="developers-data-flow" id="flow-work-people">
    <header class="developers-data-flow__header">
        <h3 class="developers-data-flow__title">Work item: People (SRO, Service Owner, PMO, Primary contact, Budget owner)</h3>
        <span class="developers-data-flow__kind">Multi-row contacts</span>
    </header>
    <partial name="_DataFlowDiagram" model='("work-people", flowWorkPeople)' />
    <div class="developers-data-flow__stages">
        <h4 class="developers-data-flow__label">Captured at</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>POST /modern/work/{id}/contact/edit?kind=sro|serviceowner|pmo</code> &rarr; <code>GovernanceRoleAddUser</code> / <code>GovernanceRoleRemoveUser</code> (per-user add &amp; remove on the modern contact edit).</li>
                <li><code>POST /modern/work/{id}/primary-contact/set</code> &rarr; <code>SetPrimaryContact</code>.</li>
                <li><code>POST /modern/work/{id}/budget-owner/set</code> &rarr; <code>SetBudgetOwner</code>.</li>
                <li><code>POST /modern/work/{id}/add-team-member</code> &rarr; <code>AddTeamMember</code>.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Stored in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>SRO &rarr; <code>ProjectSeniorResponsibleOfficer</code>; Service Owner &rarr; <code>ProjectServiceOwner</code>; PMO &rarr; <code>ProjectPmoContact</code>.</li>
                <li>Primary contact &rarr; <code>Project.PrimaryContactUserId</code>.</li>
                <li>Budget owner &rarr; <code>ProjectBudgetOwner</code> (per business area).</li>
                <li>Custom-role contacts &rarr; <code>ProjectContact</code> with <code>Role</code> string (role-type 5).</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Side effects</h4>
        <div class="developers-data-flow__body">
            Duplicate add is a no-op (idempotent). Remove deletes the join row but keeps the underlying <code>User</code>. <code>AuditLog</code> row written.
        </div>

        <h4 class="developers-data-flow__label">Surfaces in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Work item Key Contacts card &mdash; <code>_WorkItemKeyContactsSummaryCard</code> on <code>/modern/work/{id}</code>.</li>
                <li>People tab &mdash; <code>/modern/work/{id}/people</code>.</li>
                <li>Register filters &mdash; "My work items" on <code>/modern/work</code> matches on any of these roles.</li>
                <li>RAID review &mdash; risk / issue rows display the parent work-item SRO.</li>
                <li>Reporting tables &mdash; SRO / Service Owner columns in priorities, monthly update league table.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Triggers</h4>
        <div class="developers-data-flow__body">
            Notification rules resolve recipients via these tables. Monthly-update reminders email the SRO + Service Owner + Primary Contact; RAID escalation emails the SRO; budget-related queries email the Budget Owner.
        </div>

        <h4 class="developers-data-flow__label">Downstream</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Register CSV includes SRO / Service Owner / PMO display names.</li>
                <li>JSON API &mdash; <code>/api/v1/work-items/{id}/contacts</code>.</li>
                <li>PowerBI &mdash; useful as a many-to-many bridge between <code>DimUser</code> and <code>FactWorkItem</code>.</li>
            </ul>
        </div>
    </div>
</section>

<section class="developers-data-flow" id="flow-work-lookups">
    <header class="developers-data-flow__header">
        <h3 class="developers-data-flow__title">Work item: lookup fields (Phase, Priority, Activity, Risk appetite, Spend control, Flagship)</h3>
        <span class="developers-data-flow__kind">Scalar lookups</span>
    </header>
    <partial name="_DataFlowDiagram" model='("work-lookups", flowWorkLookups)' />
    <div class="developers-data-flow__stages">
        <h4 class="developers-data-flow__label">Captured at</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>POST /modern/work/{id}/overview/flagship</code></li>
                <li><code>POST /modern/work/{id}/overview/spend-control</code></li>
                <li><code>POST /modern/work/{id}/overview/risk-appetite</code></li>
                <li><code>POST /modern/work/{id}/overview/start-date</code> / <code>/target-end-date</code></li>
                <li><code>POST /modern/work/{id}/edit</code> (Phase, Priority, Activity type, Work type, Portfolio in the full edit form).</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Stored in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Phase &rarr; <code>Project.PhaseId</code> (FK <code>PhaseLookup</code>).</li>
                <li>Priority &rarr; <code>Project.DeliveryPriorityId</code> (FK <code>DeliveryPriority</code>). Priority change reason &rarr; <code>Project.DeliveryPriorityChangeReason</code>.</li>
                <li>Activity type &rarr; <code>Project.ActivityTypeId</code> (FK <code>ActivityTypeLookup</code>).</li>
                <li>Risk appetite &rarr; <code>Project.RiskAppetiteId</code> (FK <code>RiskAppetiteLookup</code>).</li>
                <li>Spend control &rarr; <code>Project.SubjectToSpendControl</code> (bool).</li>
                <li>Flagship &rarr; <code>Project.IsFlagship</code> (bool).</li>
                <li>Dates &rarr; <code>Project.StartDate</code> / <code>TargetDeliveryDate</code>.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Surfaces in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Work register columns and filters &mdash; <code>/modern/work</code>.</li>
                <li>Detail header chips (Phase, Priority badge, Flagship star).</li>
                <li>Reporting slices &mdash; <code>/modern/reporting/priorities</code> groups by Priority; thematic report groups by Phase / Activity.</li>
                <li>RAID dashboards &mdash; risk volume by Phase, Risk appetite vs actual risk score.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Triggers</h4>
        <div class="developers-data-flow__body">
            Priority change without a reason is rejected by <code>EditPost</code>. Phase change to <code>Live</code> opens monthly-update submission for that work item if currently excluded.
        </div>

        <h4 class="developers-data-flow__label">Downstream</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Register CSV export includes all of these.</li>
                <li>JSON API &mdash; <code>/api/v1/work-items</code> exposes ids; resolve labels through <code>/api/v1/admin/lookups/{type}</code>.</li>
                <li>PowerBI &mdash; treat as classic dimension keys; load <code>PhaseLookup</code>, <code>DeliveryPriority</code>, <code>ActivityTypeLookup</code> as small dim tables.</li>
            </ul>
        </div>
    </div>
</section>

<hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

<h2 class="govuk-heading-l" id="monthly-update">Monthly update</h2>
<p class="developers-data-flow-group__intro">
    The composite case &mdash; a single monthly submission writes to several
    tables and propagates the new RAG, FTE figures and narrative across the
    Modern UI, reports and notifications.
</p>

<section class="developers-data-flow" id="flow-monthly-submission">
    <header class="developers-data-flow__header">
        <h3 class="developers-data-flow__title">Monthly update: submit</h3>
        <span class="developers-data-flow__kind">Composite</span>
    </header>
    <partial name="_DataFlowDiagram" model='("monthly", flowMonthly)' />
    <div class="developers-data-flow__stages">
        <h4 class="developers-data-flow__label">Captured at</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Form &mdash; <code>GET /modern/work/{id}/monthly-report/{year}/{month}</code> renders the <code>MonthlyReportViewModel</code>.</li>
                <li>Save draft &mdash; <code>POST /modern/work/{id}/monthly-report/{year}/{month}</code> with <code>command=save</code>.</li>
                <li>Submit &mdash; same URL with <code>command=submit</code> (handled by <code>MonthlyReportPost</code>).</li>
                <li>Unsubmit (admin) &mdash; <code>POST /modern/work/{id}/monthly-report/{year}/{month}/unsubmit</code>.</li>
            </ul>
            <p class="govuk-body govuk-!-margin-top-2 govuk-!-margin-bottom-0">
                Server enforces the submission window via <code>MonthlyStatusReportTimescaleConfig</code> + per-area <code>MonthlyUpdateDeadlineConfig</code>; a closed window rejects with a TempData error.
            </p>
        </div>

        <h4 class="developers-data-flow__label">Stored in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>ProjectMonthlyUpdate</code> &mdash; one row per <code>(ProjectId, Year, Month)</code>. Fields: <code>Narrative</code>, <code>MonthlyPermFte</code>, <code>MonthlyMspFte</code>, <code>CreatedByEmail/Name/UserId</code>, <code>UpdatedAt</code>, <code>SubmittedAt</code> (set on submit), draft fields <code>DraftRagStatusLookupId</code>, <code>DraftRagJustification</code>, <code>DraftPathToGreen</code>.</li>
                <li><code>MonthlyUpdateNarrative</code> &mdash; one child row per topic heading (Highlights, Lowlights, Next 30 days, etc.).</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Side effects on submit</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>New <code>ProjectRagHistory</code> row with the submitted RAG, justification, path-to-green and submitter details.</li>
                <li>Denormalised current-state copied onto the parent: <code>Project.RagStatusLookupId</code>, <code>Project.RagStatus</code> (legacy string), <code>Project.RagJustification</code>, <code>Project.PathToGreen</code>.</li>
                <li><code>Project.UpdatedAt</code> bumped.</li>
                <li>If RAG is Green, <code>PathToGreen</code> is force-cleared on persistence.</li>
                <li><code>AuditLog</code> row written for both <code>ProjectMonthlyUpdate</code> and <code>Project</code>.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Surfaces in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Work detail last-month card &mdash; <code>_MonthlyReportLastMonth</code> partial on <code>/modern/work/{id}</code>.</li>
                <li>Per-period viewer &mdash; <code>/modern/work/{id}/monthly-update/view</code>.</li>
                <li>Cycle navigator on the work item &mdash; <code>ReportingCyclePeriod</code> chips (Upcoming / Due / Late / Submitted).</li>
                <li>RAG badge &mdash; updates everywhere the parent work item is rendered.</li>
                <li>Cross-org rollup &mdash; <code>/modern/reporting/monthly-update</code> and <code>/monthly-update-overview</code>.</li>
                <li>Submission progress &mdash; <code>/modern/reporting/monthly-submission-progress</code> league table.</li>
                <li>Business-area trend &mdash; <code>_BusinessAreaSubmissionTrendTable</code> partial on the same page.</li>
                <li>RAID review meeting export &mdash; <code>/modern/reporting/raid</code> uses the latest narrative as the &ldquo;Last update&rdquo; column.</li>
                <li>Operations dashboard &mdash; FTE rollups consume <code>MonthlyPermFte</code> + <code>MonthlyMspFte</code>.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Triggers</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>If submitted, suppresses the &ldquo;Monthly update due&rdquo; reminder for that work item / period.</li>
                <li>If unsubmitted by an admin, the reminder schedule re-opens for the remaining window.</li>
                <li>If RAG changed to Red, fires the &ldquo;Work item now Red&rdquo; rule (if enabled at <code>/modern/admin/notification-settings</code>).</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Downstream</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Excel export from <code>/modern/reporting/monthly-update</code>.</li>
                <li>JSON API &mdash; <code>/api/v1/monthly-updates</code> returns the headline submission and FTE; <code>/api/v1/monthly-updates/{id}/narratives</code> returns the per-topic narrative rows.</li>
                <li>PowerBI &mdash; the natural <code>FactMonthlyUpdate</code> grain is <code>(WorkItemId, Year, Month)</code>. Join to <code>DimWorkItem</code> on <code>ProjectId</code>, to <code>DimDate</code> via <code>Year + Month</code>, to <code>DimRagStatus</code> via <code>DraftRagStatusLookupId</code>.</li>
            </ul>
        </div>
    </div>
</section>

<hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

<h2 class="govuk-heading-l" id="raid-capture">RAID capture</h2>
<p class="developers-data-flow-group__intro">
    Risks, issues, actions, decisions and milestones share a near-identical
    capture flow; the risk card below is the canonical example. Differences
    for the other record types are called out at the end of the section.
</p>

<section class="developers-data-flow" id="flow-risk">
    <header class="developers-data-flow__header">
        <h3 class="developers-data-flow__title">RAID: <code>Risk</code></h3>
        <span class="developers-data-flow__kind">Multi-attachable</span>
    </header>
    <partial name="_DataFlowDiagram" model='("risk", flowRisk)' />
    <div class="developers-data-flow__stages">
        <h4 class="developers-data-flow__label">Captured at</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>POST /modern/raid/risks/create</code> &rarr; <code>RiskCreatePost</code>.</li>
                <li><code>POST /modern/raid/risks/{id}/edit</code> &rarr; <code>RiskEditPost</code> (including re-scoring).</li>
                <li><code>POST /modern/raid/risks/{id}/association</code> &rarr; attach or detach from a work item / product.</li>
                <li><code>POST /modern/raid/risks/{id}/escalation-request</code> &rarr; tier-change request.</li>
                <li><code>POST /modern/raid/risks/{id}/make-issue</code> &rarr; materialise to an <code>Issue</code> with <code>SourceRiskId</code> set.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Stored in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>Risk</code> &mdash; scalar fields including <code>ImpactRating</code>, <code>LikelihoodRating</code>, <code>RiskScore</code> (computed), <code>Status</code>, dates, owner.</li>
                <li>Tagging joins &mdash; <code>RiskRiskType</code>, <code>RiskRiskCategory</code>, <code>RiskKeyRiskIndicator</code>, <code>RiskDivision</code>, <code>RiskBusinessArea</code>.</li>
                <li>Attached records &mdash; <code>Risk.ProjectId</code>, <code>Risk.ProductDocumentId</code>, <code>RiskAction</code>, <code>RiskDecision</code>, <code>IssueRisk</code>, <code>MilestoneRisk</code>.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Side effects</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>RiskScore</code> recomputed on every save.</li>
                <li>Tier-change request writes <code>RaidEscalationTierChangeRequest</code> with status <code>pending</code> until an authoriser approves it.</li>
                <li>&ldquo;Make issue&rdquo; creates a paired <code>Issue</code> row and back-links via <code>Issue.SourceRiskId</code>.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Surfaces in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Modern register &mdash; <code>/modern/raid/risks</code> (filterable by tier, status, score).</li>
                <li>Risk detail &mdash; <code>/modern/raid/risks/{id}</code>.</li>
                <li>Work-item RAID summary &mdash; on <code>/modern/work/{id}</code> via <code>WorkItemRiskOrIssue</code>.</li>
                <li>RAID dashboard &mdash; <code>/modern/raid</code> heatmap, by-tier table, by-business-area table.</li>
                <li>Scoped dashboards &mdash; <code>/modern/raid/business-areas/{id}</code>, <code>/directorate/{id}</code>, <code>/tier-reporting</code>.</li>
                <li>RAID review meeting &mdash; <code>/modern/reporting/raid</code> risk matrix + tab.</li>
                <li>Operations dashboard top-risks card.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Triggers</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Score crossing tier threshold appears in the &ldquo;Risks to review&rdquo; queue.</li>
                <li>Status change to <code>closed</code> sets <code>ClosedDate</code> and removes from open-risks rollups.</li>
                <li>Tier-change request approval can change <code>RiskTierId</code> and write a follow-up <code>AuditLog</code> entry.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Downstream</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>CSV export &mdash; <code>GET /modern/raid/export/risks.csv</code>.</li>
                <li>Excel export &mdash; <code>GET /modern/raid/dashboard/export.xlsx</code>.</li>
                <li>JSON API &mdash; <code>GET /api/v1/risks</code>.</li>
                <li>PowerBI &mdash; this is the <code>FactRisk</code> grain.</li>
            </ul>
        </div>
    </div>
</section>

<div class="govuk-inset-text">
    Actions, decisions and near-misses follow the same shape as Risk. They live at
    <code>/modern/raid/actions/*</code>, <code>/modern/raid/decisions/*</code> and
    <code>/modern/raid/near-misses/*</code> respectively. The three cards below cover
    record types whose flow differs meaningfully from Risk.
</div>

<section class="developers-data-flow" id="flow-issue">
    <header class="developers-data-flow__header">
        <h3 class="developers-data-flow__title">RAID: <code>Issue</code></h3>
        <span class="developers-data-flow__kind">Multi-attachable</span>
    </header>
    <partial name="_DataFlowDiagram" model='("issue", flowIssue)' />
    <div class="developers-data-flow__stages">
        <h4 class="developers-data-flow__label">Captured at</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>POST /modern/raid/issues/create</code> &rarr; <code>IssueCreatePost</code>.</li>
                <li><code>POST /modern/raid/issues/{id}/edit</code> &rarr; <code>IssueEditPost</code>.</li>
                <li><code>POST /modern/raid/risks/{riskId}/make-issue</code> &mdash; materialises a risk into an issue and sets <code>Issue.SourceRiskId</code>.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Stored in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>Issue</code> &mdash; <code>Title</code>, <code>Description</code>, <code>Severity</code>, <code>Priority</code>, <code>Status</code>, <code>DetectedDate</code>, <code>TargetResolutionDate</code>, <code>OwnerUserId</code>.</li>
                <li>Provenance &mdash; <code>SourceType</code>, <code>SourceReference</code>, <code>SourceRecordUrl</code>, <code>SourceRiskId</code>.</li>
                <li>Attached parent &mdash; <code>Issue.ProjectId</code> and/or <code>Issue.ProductDocumentId</code> (see <a class="govuk-link" href="#flow-raid-assignment">RAID assignment</a>).</li>
                <li>Cross-links &mdash; <code>IssueRisk</code>, <code>IssueAction</code>, <code>IssueDecision</code>.</li>
                <li>History &mdash; <code>IssueHistory</code> (one row per state change), <code>IssueAssuranceEvent</code>.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Surfaces in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Modern register &mdash; <code>/modern/raid/issues</code>.</li>
                <li>Issue detail &mdash; <code>/modern/raid/issues/{id}</code>.</li>
                <li>Work-item RAID summary &mdash; <code>/modern/work/{id}</code> via <code>WorkItemRiskOrIssue</code>.</li>
                <li>RAID dashboards, by-tier / by-business-area slices, and the RAID review meeting agenda.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Triggers</h4>
        <div class="developers-data-flow__body">
            Moving to <code>resolved</code> emails the owner and the parent SRO; reopening flips status back to <code>open</code> and records an <code>IssueHistory</code> row.
        </div>

        <h4 class="developers-data-flow__label">Downstream</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>CSV export &mdash; <code>GET /modern/raid/export/issues.csv</code>.</li>
                <li>JSON API &mdash; <code>GET /api/v1/issues</code>.</li>
                <li>PowerBI &mdash; <code>FactIssue</code> grain.</li>
            </ul>
        </div>
    </div>
</section>

<section class="developers-data-flow" id="flow-assumption">
    <header class="developers-data-flow__header">
        <h3 class="developers-data-flow__title">RAID: <code>Assumption</code></h3>
        <span class="developers-data-flow__kind">Cross-scoped</span>
    </header>
    <partial name="_DataFlowDiagram" model='("assumption", flowAssumption)' />
    <div class="developers-data-flow__stages">
        <h4 class="developers-data-flow__label">Captured at</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>POST /modern/raid/assumptions/create</code> &rarr; <code>AssumptionCreatePost</code>.</li>
                <li><code>POST /modern/raid/assumptions/{id}/edit</code> &rarr; <code>AssumptionEditPost</code>.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Stored in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>Assumption</code> &mdash; <code>Description</code>, <code>ReviewDate</code>, <code>ValidationOutcome</code>, <code>AssumptionCriticalityId</code>, <code>AssumptionStatusId</code>.</li>
                <li>Scope &mdash; <code>RaidAssociationKind</code> (one of <code>WorkItem</code> / <code>Product</code> / <code>Organisation</code>) plus one of <code>ProjectId</code>, <code>PrimaryProductId</code>, <code>SroUserId</code>.</li>
                <li>Multi-select joins &mdash; <code>AssumptionDivision</code>, <code>AssumptionBusinessArea</code>.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Surfaces in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Modern register &mdash; <code>/modern/raid/assumptions</code>.</li>
                <li>Detail &mdash; <code>/modern/raid/assumptions/{id}</code>.</li>
                <li>Work-item Assumptions tab and Product detail Assumptions card.</li>
                <li>RAID dashboards and the RAID review meeting agenda.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Triggers</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Moving status to <code>Invalidated</code> surfaces a UI hint to create a follow-up Risk or Issue.</li>
                <li>An overdue <code>ReviewDate</code> appears on the Operations dashboard "Assumptions to review" tile and emails the owner + parent SRO.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Downstream</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>JSON API &mdash; <code>GET /api/v1/raid/assumptions</code>.</li>
                <li>PowerBI &mdash; <code>FactAssumption</code> with optional <code>DimWorkItem</code> / <code>DimProduct</code> bridges.</li>
            </ul>
        </div>
    </div>
</section>

<section class="developers-data-flow" id="flow-dependency">
    <header class="developers-data-flow__header">
        <h3 class="developers-data-flow__title">RAID: <code>Dependency</code></h3>
        <span class="developers-data-flow__kind">Edge between records</span>
    </header>
    <partial name="_DataFlowDiagram" model='("dependency", flowDependency)' />
    <div class="developers-data-flow__stages">
        <h4 class="developers-data-flow__label">Captured at</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>POST /modern/raid/dependencies/create</code> &rarr; <code>DependencyCreatePost</code>.</li>
                <li><code>POST /modern/raid/dependencies/{id}/edit</code> &rarr; <code>DependencyEditPost</code>.</li>
                <li><code>POST /modern/work/{id}/dependency/add</code> &mdash; convenience entry point from a work item that pre-fills the source side.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Stored in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>Dependency</code> &mdash; source pair <code>(SourceEntityType, SourceEntityId)</code> and target pair <code>(TargetEntityType, TargetEntityId)</code> where the type is one of <code>Project</code>, <code>Risk</code>, <code>Issue</code>, <code>Milestone</code>, <code>Action</code>.</li>
                <li>Classification &mdash; <code>DependencyLinkTypeId</code> (preferred) or legacy free-text <code>DependencyType</code>; <code>DependencyCriticalityId</code>.</li>
                <li>Ownership &mdash; <code>OwnerUserId</code>, <code>Organisation</code> (free text for external parties), <code>DueDate</code>, <code>Status</code> (<code>Active</code> / <code>Resolved</code> / <code>Cancelled</code>).</li>
                <li>Resolution &mdash; <code>ResolvedDate</code>, <code>ResolvedByEmail</code>, <code>ResolvedByName</code> populated when <code>Status</code> moves to <code>Resolved</code>.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Surfaces in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Modern register &mdash; <code>/modern/raid/dependencies</code>.</li>
                <li>Detail &mdash; <code>/modern/raid/dependencies/{id}</code>.</li>
                <li>Work item Dependencies tab &mdash; appears under both the source and the target work item.</li>
                <li>Product detail dependency card; RAID dashboards "Critical dependencies" tile.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Triggers</h4>
        <div class="developers-data-flow__body">
            Past-due <code>DueDate</code> emails the owner and the parent SRO of either side. Resolution removes the row from the open-dependencies dashboard tile.
        </div>

        <h4 class="developers-data-flow__label">Downstream</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>JSON API &mdash; <code>GET /api/v1/raid/dependencies</code>.</li>
                <li>PowerBI &mdash; <code>FactDependency</code>; the two <code>EntityType + EntityId</code> pairs let you model it as an edge between source and target dim tables.</li>
            </ul>
        </div>
    </div>
</section>

<section class="developers-data-flow" id="flow-raid-assignment">
    <header class="developers-data-flow__header">
        <h3 class="developers-data-flow__title">RAID: assign to a work item or service</h3>
        <span class="developers-data-flow__kind">Cross-cutting</span>
    </header>
    <partial name="_DataFlowDiagram" model='("raid-assignment", flowRaidAssignment)' />
    <div class="developers-data-flow__stages">
        <h4 class="developers-data-flow__label">Captured at</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>On <strong>create</strong> &mdash; every RAID create form (<code>POST /modern/raid/{kind}/create</code> for <code>risks</code>, <code>issues</code>, <code>actions</code>, <code>decisions</code>, <code>milestones</code>, <code>near-misses</code>, <code>assumptions</code>) accepts a work-item picker or a product picker.</li>
                <li>On an <strong>existing record</strong> &mdash; <code>POST /modern/raid/{kind}/{id}/association</code> changes the parent without re-creating the row.</li>
                <li>Milestones additionally accept the parent at <code>POST /modern/work/{id}/milestone/{mid}/update</code>.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Stored in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>{Entity}.ProjectId</code> (FK <code>Project.Id</code>) &mdash; the work-item parent.</li>
                <li><code>{Entity}.ProductDocumentId</code> (string FK to <code>FipsService.FipsId</code> / <code>CMDBProduct.Id</code>) &mdash; the service / product parent.</li>
                <li>Both may be set; either may be cleared. The pair is the canonical "who owns this RAID record" for reporting.</li>
                <li><code>AuditLog</code> entry records the previous and new association.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Surfaces in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Work item &mdash; RAID summary card and per-kind tabs at <code>/modern/work/{id}</code>.</li>
                <li>Product / service &mdash; the RAID card at <code>/modern/operations/service-register/product/{id}</code>.</li>
                <li>RAID register filters &mdash; "by parent work item" and "by parent product".</li>
                <li>RAID review meeting groups all records by parent work item; unassigned rows fall into a separate &ldquo;orphan&rdquo; bucket.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Triggers</h4>
        <div class="developers-data-flow__body">
            Notification recipient resolution uses the parent: e.g. an Issue moves to "resolved" emails the parent work-item SRO / Service Owner (via the contacts captured in <a class="govuk-link" href="#flow-work-people">Work item: People</a>). Re-pointing the parent changes who gets future emails for the same record.
        </div>

        <h4 class="developers-data-flow__label">Downstream</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>JSON API &mdash; every RAID resource exposes <code>workItemId</code> and <code>productDocumentId</code>; PowerBI joins back to <code>DimWorkItem</code> and <code>DimProduct</code> through these.</li>
                <li>CSV / Excel exports include the parent title columns; the lookup is satisfied from <code>Project.Title</code> / <code>FipsService.DisplayName</code>.</li>
            </ul>
        </div>
    </div>
</section>

<section class="developers-data-flow" id="flow-milestone">
    <header class="developers-data-flow__header">
        <h3 class="developers-data-flow__title">Milestone</h3>
        <span class="developers-data-flow__kind">Baseline + actual</span>
    </header>
    <partial name="_DataFlowDiagram" model='("milestone", flowMilestone)' />
    <div class="developers-data-flow__stages">
        <h4 class="developers-data-flow__label">Captured at</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li><code>POST /modern/work/{id}/milestone/{milestoneId}/update</code> &rarr; <code>UpdateMilestone</code> (covers create &amp; edit).</li>
                <li><code>POST /modern/work/{id}/milestone/{milestoneId}/delete</code> &rarr; soft-delete.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Stored in</h4>
        <div class="developers-data-flow__body">
            <code>Milestone</code> &mdash; <code>Name</code>, <code>BaselineDueDate</code> (locked on first save), <code>DueDate</code>, <code>ActualDate</code>, <code>Status</code>, <code>ProgressPercent</code>, ownership, <code>ProjectId</code> / <code>ProductDocumentId</code>.
        </div>

        <h4 class="developers-data-flow__label">Side effects</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Changing <code>DueDate</code> while keeping the original <code>BaselineDueDate</code> drives the &ldquo;slip&rdquo; calculation across reports.</li>
                <li>Setting <code>ActualDate</code> auto-flips <code>Status</code> to <code>complete</code>.</li>
                <li>Optional cross-links to risks / issues / actions are written through <code>MilestoneRisk</code>, <code>MilestoneIssue</code>, <code>MilestoneAction</code>.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Surfaces in</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>Milestones tab &mdash; <code>/modern/work/{id}/milestones</code>.</li>
                <li>Detail header &mdash; next-milestone chip on <code>/modern/work/{id}</code>.</li>
                <li>RAID review meeting &mdash; milestone trail in <code>_RaidMeetingTableRows</code>.</li>
                <li>Operations dashboard overdue-milestones tile.</li>
                <li>Monthly report &mdash; auto-listed upcoming &amp; overdue milestones on the form.</li>
            </ul>
        </div>

        <h4 class="developers-data-flow__label">Downstream</h4>
        <div class="developers-data-flow__body">
            <ul>
                <li>JSON API &mdash; <code>GET /api/v1/milestones</code>.</li>
                <li>PowerBI &mdash; <code>FactMilestone</code> grain; pair <code>BaselineDueDate</code> + <code>DueDate</code> + <code>ActualDate</code> for slip / variance visuals.</li>
            </ul>
        </div>
    </div>
</section>

