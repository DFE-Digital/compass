                <th scope="row" class="govuk-table__header"><code>[RequireCentralOpsAdmin]</code> &mdash; <code>Attributes/RequireCentralOpsAdminAttribute.cs</code></th>
                <td class="govuk-table__cell">Super admin OR <code>Central Operations Admin</code>.</td>
