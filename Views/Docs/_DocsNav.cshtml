@{
    var section = ViewData["DocsSection"]?.ToString() ?? "index";
}
<nav class="developers-doc-nav" aria-label="Documentation sections">
    <p class="developers-doc-nav__heading">Guide</p>
    <ul class="developers-doc-nav__list">
        <li class="developers-doc-nav__item">
            <a class="developers-doc-nav__link @(section == "index" ? "developers-doc-nav__link--current" : null)"
               href="@Url.Action("Index", "Docs")"
               aria-current="@(section == "index" ? "page" : null)">Overview</a>
        </li>
    </ul>
    <p class="developers-doc-nav__heading">Reference</p>
    <ul class="developers-doc-nav__list">
        <li class="developers-doc-nav__item">
            <a class="developers-doc-nav__link @(section == "api" ? "developers-doc-nav__link--current" : null)"
               href="@Url.Action("Api", "Docs")"
               aria-current="@(section == "api" ? "page" : null)">API reference</a>
        </li>
    </ul>
</nav>
