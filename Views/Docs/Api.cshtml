@using Compass.Models.Docs
@{
    ViewData["Title"] = "API reference";
    ViewData["DocsSection"] = "api";

    // Endpoint catalogue is defined once in Models/Docs/ApiCatalogue.cs so
    // the /docs/api-explorer page can render the same set of endpoints
    // without us duplicating the source-of-truth here.
    var sections = ApiCatalogue.Sections;
    var apiExplorerUrl = Url.Action("ApiExplorer", "Docs");
}

@section Styles {
    <link rel="stylesheet" href="~/css/docs-api.css" asp-append-version="true" />
}

<div class="developers-docs__intro govuk-!-margin-bottom-6">
    <span class="govuk-caption-xl">Reference</span>
    <h1 class="govuk-heading-xl govuk-!-margin-bottom-2">API reference</h1>
    <p class="govuk-body-l govuk-!-margin-bottom-0">
        REST endpoints for risks, issues, milestones, performance metrics,
        service register and standards. Each endpoint has copy-ready code
        snippets &mdash; try them live in the
        <a class="govuk-link" href="@apiExplorerUrl">API explorer</a>.
    </p>
</div>

<div class="govuk-inset-text govuk-!-margin-bottom-6">
    <strong>Endpoint missing?</strong> If the data you need is not exposed
    below, please
    <a class="govuk-link" href="https://github.com/DFE-Digital/compass/issues" target="_blank" rel="noopener">raise an issue for a change in the repo</a>.
    Endpoints are added on demand &mdash; we would rather expose what you
    need than have you scrape the UI.
</div>

<section class="govuk-!-margin-bottom-6">
    <h2 id="overview" class="govuk-heading-l">Overview</h2>
    <p class="govuk-body">
        All endpoints use bearer-token authentication. Request a key from the
        <a class="govuk-link" href="@Url.Action("Index", "DocsDeveloperApi")">API keys developer portal</a>
        (read-only access to all data is available to everyone; @@education.gov.uk accounts are auto-approved for read-only keys).
        Pass your token as <code>Authorization: Bearer cps_...</code>. Tokens are scoped per resource — request only what your integration needs.
        Delete access is not available through self-service; contact
        <a class="govuk-link" href="mailto:design.ops@education.gov.uk">design.ops@education.gov.uk</a> if required.
    </p>

    <div class="api-base-urls">
        <div>
            <span class="api-base-label">Production</span>
            <code class="api-base-value">https://compass.education.gov.uk</code>
        </div>
        <div>
            <span class="api-base-label">Test</span>
            <code class="api-base-value">https://s186d01-compass-g8g3bvheb2dsctey.westeurope-01.azurewebsites.net</code>
        </div>
    </div>

    <div class="govuk-warning-text govuk-!-margin-top-4">
        <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
        <strong class="govuk-warning-text__text">
            <span class="govuk-warning-text__assistive">Warning</span>
            Not yet available: there are no API endpoints for <strong>Assumptions</strong> or <strong>Dependencies</strong>. They exist as RAID features inside the modern UI but are not exposed over HTTP. The lookup keys <code>assumption-statuses</code>, <code>assumption-criticalities</code>, <code>dependency-criticalities</code> and <code>dependency-link-types</code> are <em>lookup catalogues</em> only &mdash; not the assumption / dependency records themselves.
        </strong>
    </div>

    <div class="govuk-notification-banner govuk-!-margin-top-4" role="region" aria-labelledby="api-explorer-banner-title">
        <div class="govuk-notification-banner__header">
            <h2 class="govuk-notification-banner__title" id="api-explorer-banner-title">Try it interactively</h2>
        </div>
        <div class="govuk-notification-banner__content">
            <p class="govuk-notification-banner__heading">
                The <a class="govuk-notification-banner__link" href="@apiExplorerUrl">API explorer</a> is a full Postman-style workspace.
            </p>
            <p class="govuk-body">
                Paste your bearer token once, pick any endpoint from the
                collections panel, fill in path / query parameters and hit
                Send. The response panel shows the status code, time and
                size, with one-click Copy / JSON / CSV / Excel export.
            </p>
        </div>
    </div>
</section>

@* ================= ENDPOINTS ================= *@
@foreach (var group in sections)
{
    <section class="api-section" id="@group.Id">
        <h2 class="govuk-heading-l">@group.Title</h2>
        <p class="govuk-body">@group.Description</p>

        @foreach (var ep in group.Endpoints)
        {
            @await Html.PartialAsync("_ApiEndpointCard", ep)
        }
    </section>
}

