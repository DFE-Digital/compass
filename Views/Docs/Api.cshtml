<section id="feedback" class="govuk-!-margin-top-6">
    <h2 class="govuk-heading-l">Feedback &amp; missing endpoints</h2>
    <div class="govuk-inset-text">
        Need a new endpoint, an extra field, or a fix to an existing one?
        <a class="govuk-link" href="https://github.com/DFE-Digital/compass/issues" target="_blank" rel="noopener">Raise an issue for a change in the repo</a>.
        Endpoints are added on demand &mdash; we would rather expose what you
        need than have you scrape the UI.
    </div>
</section>

@section Aside {
    <h2 class="docs-page-aside-heading">On this page</h2>
    <ul class="docs-page-aside-nav">
        <li><a class="govuk-link govuk-link--no-visited-state" href="#overview">Overview</a></li>
        <li><a class="govuk-link govuk-link--no-visited-state" href="@Url.Action("Index", "DocsDeveloperApi")">Your API keys</a></li>
        <li><a class="govuk-link govuk-link--no-visited-state" href="@apiExplorerUrl">API explorer</a></li>
        @foreach (var group in sections)
        {
            <li><a class="govuk-link govuk-link--no-visited-state" href="#@group.Id">@group.Title</a></li>
        }
        <li><a class="govuk-link govuk-link--no-visited-state" href="#lookup-keys">Admin lookup keys</a></li>
        <li><a class="govuk-link govuk-link--no-visited-state" href="#feedback">Feedback &amp; missing endpoints</a></li>
    </ul>
}

@section Scripts {
    <script src="~/js/docs-api.js" asp-append-version="true" nonce="@(Context.Items["Nonce"]?.ToString() ?? "")"></script>
}
