        <li><code>action-types</code></li>
        <li><code>action-categories</code></li>
        <li><code>action-impact-levels</code></li>
        <li><code>action-reminder-frequencies</code></li>
        <li><code>action-escalation-thresholds</code></li>
        <li><code>decision-statuses</code></li>
