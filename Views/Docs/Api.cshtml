@*
    /docs/api — full API reference rendered inside the new developers-doc shell.
    The body, styles and on-this-page links live in Views/Shared/_ApiDocs*.cshtml
    partials so this page stays in sync with the legacy /documentation/api view.
*@

@await Html.PartialAsync("_ApiDocsStyles")

@await Html.PartialAsync("_ApiDocsBody")

@section Aside {
    <h2 class="docs-page-aside-heading">On this page</h2>
    <div class="documentation-toc">
        @await Html.PartialAsync("_ApiDocsNavLinks")
    </div>
}
