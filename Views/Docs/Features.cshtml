<h2 class="govuk-heading-l" id="issues">Issues</h2>
<p class="govuk-body">Entity: <code>Issue</code>. Modern register at <code>/modern/raid/issues</code>.</p>
<table class="govuk-table">
    <thead class="govuk-table__head">
        <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">Field</th>
            <th scope="col" class="govuk-table__header">Type</th>
            <th scope="col" class="govuk-table__header">Required</th>
            <th scope="col" class="govuk-table__header">Notes</th>
        </tr>
    </thead>
    <tbody class="govuk-table__body">
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>Id</code></td><td class="govuk-table__cell">int (identity)</td><td class="govuk-table__cell">yes</td><td class="govuk-table__cell"></td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>Title</code></td><td class="govuk-table__cell">string(200)</td><td class="govuk-table__cell">yes</td><td class="govuk-table__cell"></td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>Description</code></td><td class="govuk-table__cell">string (max)</td><td class="govuk-table__cell">&mdash;</td><td class="govuk-table__cell"></td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>Severity</code></td><td class="govuk-table__cell">string(10)</td><td class="govuk-table__cell">yes</td><td class="govuk-table__cell">One of <code>low</code>, <code>medium</code>, <code>high</code>, <code>critical</code>.</td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>Priority</code></td><td class="govuk-table__cell">string(10)</td><td class="govuk-table__cell">&mdash;</td><td class="govuk-table__cell">Optional ordering label (<code>P1</code>..<code>P4</code>).</td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>DetectedDate</code></td><td class="govuk-table__cell">datetime</td><td class="govuk-table__cell">yes</td><td class="govuk-table__cell">Defaults to <code>UtcNow</code>.</td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>TargetResolutionDate</code></td><td class="govuk-table__cell">datetime?</td><td class="govuk-table__cell">&mdash;</td><td class="govuk-table__cell"></td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>Status</code></td><td class="govuk-table__cell">string(20)</td><td class="govuk-table__cell">yes</td><td class="govuk-table__cell">One of <code>open</code>, <code>investigating</code>, <code>in_progress</code>, <code>resolved</code>, <code>closed</code>.</td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>ResolutionSummary</code> / <code>Workaround</code></td><td class="govuk-table__cell">string (max)</td><td class="govuk-table__cell">&mdash;</td><td class="govuk-table__cell"></td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>OwnerUserId</code></td><td class="govuk-table__cell">int? (FK <code>User</code>)</td><td class="govuk-table__cell">&mdash;</td><td class="govuk-table__cell">Issue owner.</td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>SourceType</code> / <code>SourceReference</code> / <code>SourceRecordUrl</code></td><td class="govuk-table__cell">string</td><td class="govuk-table__cell">&mdash;</td><td class="govuk-table__cell">Provenance (for example <code>survey</code> + survey id).</td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>SourceRiskId</code></td><td class="govuk-table__cell">int? (FK <code>Risk</code>)</td><td class="govuk-table__cell">&mdash;</td><td class="govuk-table__cell">When the issue is a materialised risk.</td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>ProjectId</code> / <code>ProductDocumentId</code></td><td class="govuk-table__cell">FKs</td><td class="govuk-table__cell">&mdash;</td><td class="govuk-table__cell"></td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>IsDeleted</code></td><td class="govuk-table__cell">bool</td><td class="govuk-table__cell">yes</td><td class="govuk-table__cell">Soft-delete.</td></tr>
    </tbody>
</table>

