<h2 class="govuk-heading-l" id="risks">Risks</h2>
<p class="govuk-body">Entity: <code>Risk</code>. Modern register at <code>/modern/raid/risks</code>; detail at <code>/modern/raid/risks/{id}</code>.</p>
<table class="govuk-table">
    <thead class="govuk-table__head">
        <tr class="govuk-table__row">
            <th scope="col" class="govuk-table__header">Field</th>
            <th scope="col" class="govuk-table__header">Type</th>
            <th scope="col" class="govuk-table__header">Required</th>
            <th scope="col" class="govuk-table__header">Notes</th>
        </tr>
    </thead>
    <tbody class="govuk-table__body">
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>Id</code></td><td class="govuk-table__cell">int (identity)</td><td class="govuk-table__cell">yes</td><td class="govuk-table__cell"></td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>Title</code></td><td class="govuk-table__cell">string(200)</td><td class="govuk-table__cell">yes</td><td class="govuk-table__cell"></td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>Description</code></td><td class="govuk-table__cell">string (max)</td><td class="govuk-table__cell">&mdash;</td><td class="govuk-table__cell"></td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>RiskTierId</code></td><td class="govuk-table__cell">int? (FK <code>RiskTier</code>)</td><td class="govuk-table__cell">&mdash;</td><td class="govuk-table__cell">Tier 1..4. Tier changes go through <code>RaidEscalationTierChangeRequest</code>.</td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>OwnerEmail</code></td><td class="govuk-table__cell">string(255)</td><td class="govuk-table__cell">&mdash;</td><td class="govuk-table__cell">Owner email (denormalised). Newer records also set <code>OwnerUserId</code>.</td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>ImpactRating</code> / <code>LikelihoodRating</code></td><td class="govuk-table__cell">int (1..5)</td><td class="govuk-table__cell">yes</td><td class="govuk-table__cell">Gross score.</td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>RiskScore</code></td><td class="govuk-table__cell">int</td><td class="govuk-table__cell">yes</td><td class="govuk-table__cell">Computed <code>Impact &times; Likelihood</code>.</td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>ResidualImpact</code> / <code>ResidualLikelihood</code></td><td class="govuk-table__cell">int? (1..5)</td><td class="govuk-table__cell">&mdash;</td><td class="govuk-table__cell">After mitigations.</td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>ProximityDate</code> / <code>TargetDate</code></td><td class="govuk-table__cell">datetime?</td><td class="govuk-table__cell">&mdash;</td><td class="govuk-table__cell">UTC.</td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>Response</code></td><td class="govuk-table__cell">string(20)</td><td class="govuk-table__cell">&mdash;</td><td class="govuk-table__cell">One of <code>treat</code>, <code>tolerate</code>, <code>transfer</code>, <code>terminate</code>.</td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>Status</code></td><td class="govuk-table__cell">string(20)</td><td class="govuk-table__cell">yes</td><td class="govuk-table__cell">One of <code>new</code>, <code>open</code>, <code>monitoring</code>, <code>escalated</code>, <code>closed</code>.</td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>ClosedDate</code> / <code>Notes</code></td><td class="govuk-table__cell">datetime? / string (max)</td><td class="govuk-table__cell">&mdash;</td><td class="govuk-table__cell"></td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>ProjectId</code> / <code>ProductDocumentId</code></td><td class="govuk-table__cell">FKs</td><td class="govuk-table__cell">&mdash;</td><td class="govuk-table__cell">Modern surfaces filter by these.</td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>Source</code></td><td class="govuk-table__cell">string(150)</td><td class="govuk-table__cell">&mdash;</td><td class="govuk-table__cell">Free-text source (for example "Internal audit Q2").</td></tr>
        <tr class="govuk-table__row"><td class="govuk-table__cell"><code>IsDeleted</code></td><td class="govuk-table__cell">bool</td><td class="govuk-table__cell">yes</td><td class="govuk-table__cell">Soft-delete.</td></tr>
    </tbody>
</table>

