@*
    /docs landing page. Documents the Modern COMPASS surface at /modern.
*@
@{
    var apiKeyCount = ViewBag.UserApiKeyCount as int? ?? 0;
    var hasApiKeys = apiKeyCount > 0;
}

<div class="developers-docs__intro govuk-!-margin-bottom-6">
    <span class="govuk-caption-xl">Documentation</span>
    <h1 class="govuk-heading-xl govuk-!-margin-bottom-2">COMPASS documentation</h1>
    <p class="govuk-body-l govuk-!-margin-bottom-0">
        Internal documentation for the Modern COMPASS platform. Use the sections
        below to find feature guides, technical reference, and integration
        instructions for the application at <code>/modern</code>.
    </p>
</div>

<h2 class="govuk-heading-l" id="getting-started">Getting started</h2>
<p class="govuk-body">
    New to COMPASS? Start with the
    <a class="govuk-link" href="@Url.Action("Features", "Docs")">Feature reference</a>
    to see what each part of the Modern application records, then read
    <a class="govuk-link" href="@Url.Action("DataModels", "Docs")">Data models</a>
    for the underlying tables and Modern view models. Integration teams
    should head straight to
    <a class="govuk-link" href="@Url.Action("Api", "Docs")">API reference</a>
    or the
    <a class="govuk-link" href="@Url.Action("PowerBi", "Docs")">PowerBI developer guide</a>.
</p>

<hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

<h2 class="govuk-heading-l" id="your-keys">Your keys</h2>
@if (hasApiKeys)
{
    <p class="govuk-body">
        You have <strong>@apiKeyCount</strong> API key@(apiKeyCount == 1 ? "" : "s") you can use for integrations and the
        <a class="govuk-link" href="@Url.Action("ApiExplorer", "Docs")">API explorer</a>.
    </p>
    <div class="govuk-button-group">
        <a class="govuk-button" href="@Url.Action("Index", "DocsDeveloperApi")">Manage your keys</a>
        <a class="govuk-button govuk-button--secondary" href="@Url.Action("Request", "DocsDeveloperApi")">Request another key</a>
    </div>
}
else
{
    <p class="govuk-body">
        Request a read-only API key for all COMPASS data, or ask for create and update access on specific resources.
        Keys are named by environment and project (for example <code>DEV-RO-my-app</code>).
    </p>
    <div class="govuk-button-group">
        <a class="govuk-button" href="@Url.Action("Request", "DocsDeveloperApi")">Request an API key</a>
        <a class="govuk-button govuk-button--secondary" href="@Url.Action("Index", "DocsDeveloperApi")">About API keys</a>
    </div>
}

<hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

<h2 class="govuk-heading-l" id="reference">Reference</h2>
<ul class="govuk-list govuk-list--spaced">
    <li>
        <a class="govuk-link govuk-!-font-weight-bold" href="@Url.Action("Api", "Docs")">API reference</a>
        <br>
        <span class="govuk-body">Endpoint guidance, authentication, request and response models for the COMPASS REST API at <code>/api/v1</code>.</span>
    </li>
    <li>
        <a class="govuk-link govuk-!-font-weight-bold" href="@Url.Action("DataModels", "Docs")">Data models</a>
        <br>
        <span class="govuk-body">Entity-level reference for the Modern COMPASS database and the view models behind <code>/modern/*</code> pages. Grouped by feature area.</span>
    </li>
    <li>
        <a class="govuk-link govuk-!-font-weight-bold" href="@Url.Action("DataFlows", "Docs")">Data flows</a>
        <br>
        <span class="govuk-body">How data moves between FIPS CMS, CMDB, Modern COMPASS and downstream consumers. RAID lifecycle, monthly reporting cycle, demand pipeline.</span>
    </li>
    <li>
        <a class="govuk-link govuk-!-font-weight-bold" href="@Url.Action("Features", "Docs")">Feature reference</a>
        <br>
        <span class="govuk-body">Field-level reference for each Modern feature: work items, RAID, monthly updates, demand pipeline, performance reporting, accessibility.</span>
    </li>
    <li>
        <a class="govuk-link govuk-!-font-weight-bold" href="@Url.Action("Rbac", "Docs")">RBAC &amp; authorization</a>
        <br>
        <span class="govuk-body">Roles, groups, feature toggles and API token scopes. How <code>[RequireAdmin]</code>, <code>[RequireSuperAdmin]</code>, <code>[RequireOperationConsoleUser]</code> and the feature-gate filters compose, and how per-record ownership checks gate the Modern UI.</span>
    </li>
</ul>

<hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

<h2 class="govuk-heading-l" id="integrations">Integrations</h2>
<ul class="govuk-list govuk-list--spaced">
    <li>
        <a class="govuk-link govuk-!-font-weight-bold" href="@Url.Action("PowerBi", "Docs")">PowerBI developer guide</a>
        <br>
        <span class="govuk-body">Authentication, recommended endpoints, a star-schema starting point and refresh patterns for PowerBI consumers of the Modern COMPASS API.</span>
    </li>
</ul>

<hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

<h2 class="govuk-heading-l" id="specifications">Specifications</h2>
<ul class="govuk-list govuk-list--spaced">
    <li>
        <a class="govuk-link govuk-!-font-weight-bold" href="@Url.Action("Specifications", "Docs")">Functional specifications</a>
        <br>
        <span class="govuk-body">Per-view specifications for Work, RAID, Performance, Standards, Service register and Reporting: what each process does, data collected, permissions, downstream use and API availability.</span>
    </li>
</ul>

@section Aside {
    <h2 class="docs-page-aside-heading">On this page</h2>
    <ul class="docs-page-aside-nav">
        <li><a class="govuk-link govuk-link--no-visited-state" href="#getting-started">Getting started</a></li>
        <li><a class="govuk-link govuk-link--no-visited-state" href="#your-keys">Your keys</a></li>
        <li><a class="govuk-link govuk-link--no-visited-state" href="#reference">Reference</a></li>
        <li><a class="govuk-link govuk-link--no-visited-state" href="#integrations">Integrations</a></li>
        <li><a class="govuk-link govuk-link--no-visited-state" href="#specifications">Specifications</a></li>
    </ul>
}
