@{
    var docsDocShell = ViewData["DocsDocShell"] as bool? == true;
    var cspNonce = Context.Items["Nonce"]?.ToString() ?? "";
    var dfeLogoWhite = Url.Content("~/_content/DfEDigital.Frontend.AspNetCore/dfe/dfe-logo-white.png");
}
<!DOCTYPE html>
<html lang="en" class="govuk-template govuk-template--rebranded">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>@ViewData["Title"] - COMPASS Documentation</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" nonce="@cspNonce" />
    <link rel="stylesheet" href="~/modern/css/govuk-frontend-6.1.0.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/_content/DfEDigital.Frontend.AspNetCore/dfe/dfe.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/docs-content.css" asp-append-version="true" />
    @if (docsDocShell)
    {
        <link rel="stylesheet" href="~/css/docs-theme.css" asp-append-version="true" />
    }
    <link rel="icon" href="~/modern/assets/images/favicon.svg" type="image/svg+xml" asp-append-version="true" />
    <meta name="theme-color" content="@(docsDocShell ? "#ffffff" : "#0b0c0c")" />
    <style nonce="@cspNonce">
        .js-enabled .no-js-only { display: none !important; }
        body:not(.js-enabled) .js-only { display: none !important; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="govuk-template__body use-dfe-brand@(docsDocShell ? " developers-doc-page" : "")">
    <script nonce="@cspNonce">
        document.body.className += ' js-enabled' + ('noModule' in HTMLScriptElement.prototype ? ' govuk-frontend-supported' : '');
    </script>

    <a href="#main-content" class="govuk-skip-link" data-module="govuk-skip-link">Skip to main content</a>

    <header class="govuk-header@(docsDocShell ? " developers-doc-header--full" : "")" data-module="govuk-header">
        <div class="govuk-header__container @(docsDocShell ? "developers-doc-header__container" : "govuk-width-container")">
            <div class="govuk-header__logo">
                <a href="/modern/dashboard" class="govuk-header__link govuk-header__link--homepage">
                    <img src="@dfeLogoWhite" alt="Department for Education" class="govuk-header__logotype" asp-append-version="true" />
                </a>
            </div>
        </div>
    </header>

    <main class="govuk-main-wrapper @(docsDocShell ? "developers-doc-main-host" : null)" id="main-content" role="main">
        @RenderBody()
    </main>

    <script src="~/_content/DfEDigital.Frontend.AspNetCore/dfe/dfe-frontend.iife.min.js" asp-append-version="true" nonce="@cspNonce"></script>
    <script type="module" src="~/modern/js/govuk-frontend-init.js" asp-append-version="true" nonce="@cspNonce"></script>
    @if (docsDocShell)
    {
        <script src="~/js/docs-theme.js" asp-append-version="true" nonce="@cspNonce"></script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
