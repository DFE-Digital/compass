@{
    ViewData["Title"] = "Reports";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item active">Reports</li>
                </ol>
                <h1 class="m-0">Reports</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <!-- RAID Reports -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">RAID reports</h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-lg-3 col-md-6 col-12 mb-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <h4 class="mb-2">Risks</h4>
                                <p class="text-muted mb-3">Group by impact, likelihood, tier, type</p>
                                <a href="@Url.Action("Risks", "Reports")" class="btn btn-primary btn-block">View report</a>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-3 col-md-6 col-12 mb-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <h4 class="mb-2">Issues</h4>
                                <p class="text-muted mb-3">Group by severity, status, priority</p>
                                <a href="@Url.Action("Issues", "Reports")" class="btn btn-primary btn-block">View report</a>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-3 col-md-6 col-12 mb-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <h4 class="mb-2">Actions</h4>
                                <p class="text-muted mb-3">Group by status, source, assignee</p>
                                <a href="@Url.Action("Actions", "Reports")" class="btn btn-primary btn-block">View report</a>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-3 col-md-6 col-12 mb-3">
                        <div class="card h-100">
                            <div class="card-body">
                                <h4 class="mb-2">Milestones</h4>
                                <p class="text-muted mb-3">Group by status, quarter, owner</p>
                                <a href="@Url.Action("Milestones", "Reports")" class="btn btn-primary btn-block">View report</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Custom Queries -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Custom queries</h3>
            </div>
            <div class="card-body">
                <p class="mb-3">Build custom queries with your own filters and column selections</p>
                <a href="@Url.Action("QueryData", "Reports")" class="btn btn-primary">Query data builder</a>
            </div>
        </div>

        <!-- Report Usage Tips -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Report usage tips</h3>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Query data builder</dt>
                    <dd class="col-sm-9">Create custom queries by selecting fields, adding filters, and choosing sort options. Perfect for ad-hoc analysis and answering specific questions.</dd>
                    
                    <dt class="col-sm-3">Risks report</dt>
                    <dd class="col-sm-9">Use the impact & likelihood matrix to identify which risks need immediate attention. Group by risk tier to review tier assignments.</dd>
                    
                    <dt class="col-sm-3">Issues report</dt>
                    <dd class="col-sm-9">Group by severity to prioritise critical and high-severity issues. Use the blocked filter to identify impediments.</dd>
                    
                    <dt class="col-sm-3">Actions report</dt>
                    <dd class="col-sm-9">Group by assigned to see workload distribution. Group by action source to track resolution of risks and issues.</dd>
                    
                    <dt class="col-sm-3">Milestones report</dt>
                    <dd class="col-sm-9 mb-0">Group by quarter for roadmap planning. Group by status to identify delayed or at-risk deliverables.</dd>
                </dl>
            </div>
        </div>
    </div>
</section>
