@{
    ViewData["Title"] = "Reports";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Reports</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row mb-3">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Available reports</h5>
                    </div>
                    <div class="card-body">
                        <p>Select a report type to view detailed analysis and summaries.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- RAID Reports -->
        <div class="row">
            <div class="col-xxl-3 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12 mb-3">
                <a href="@Url.Action("Risks", "Reports")" class="text-decoration-none">
                    <div class="small-box bg-danger">
                        <div class="inner">
                            <h3>Risks</h3>
                            <p>Group by impact, likelihood, tier, type</p>
                        </div>
                        <div class="icon">
                            <i class="fas fa-exclamation-triangle"></i>
                        </div>
                        <span class="small-box-footer">
                            View risks report <i class="fas fa-arrow-circle-right"></i>
                        </span>
                    </div>
                </a>
            </div>

            <div class="col-xxl-3 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12 mb-3">
                <a href="@Url.Action("Issues", "Reports")" class="text-decoration-none">
                    <div class="small-box bg-warning">
                        <div class="inner">
                            <h3>Issues</h3>
                            <p>Group by severity, status, priority</p>
                        </div>
                        <div class="icon">
                            <i class="fas fa-bug"></i>
                        </div>
                        <span class="small-box-footer">
                            View issues report <i class="fas fa-arrow-circle-right"></i>
                        </span>
                    </div>
                </a>
            </div>

            <div class="col-xxl-3 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12 mb-3">
                <a href="@Url.Action("Actions", "Reports")" class="text-decoration-none">
                    <div class="small-box bg-info">
                        <div class="inner">
                            <h3>Actions</h3>
                            <p>Group by status, source, assignee</p>
                        </div>
                        <div class="icon">
                            <i class="fas fa-tasks"></i>
                        </div>
                        <span class="small-box-footer">
                            View actions report <i class="fas fa-arrow-circle-right"></i>
                        </span>
                    </div>
                </a>
            </div>

            <div class="col-xxl-3 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12 mb-3">
                <a href="@Url.Action("Milestones", "Reports")" class="text-decoration-none">
                    <div class="small-box bg-success">
                        <div class="inner">
                            <h3>Milestones</h3>
                            <p>Group by status, quarter, owner</p>
                        </div>
                        <div class="icon">
                            <i class="fas fa-flag-checkered"></i>
                        </div>
                        <span class="small-box-footer">
                            View milestones report <i class="fas fa-arrow-circle-right"></i>
                        </span>
                    </div>
                </a>
            </div>
        </div>

        <!-- Query Builder -->
        <div class="row">
            <div class="col-12">
                <div class="card border-primary">
                    <div class="card-header bg-primary text-white">
                        <h5 class="card-title mb-0"><i class="fas fa-search"></i> Custom Queries</h5>
                    </div>
                    <div class="card-body">
                        <a href="@Url.Action("QueryData", "Reports")" class="btn btn-lg btn-primary btn-block">
                            <i class="fas fa-magic"></i> Query Data Builder
                            <p class="mb-0 mt-2 small">Build custom queries with your own filters and column selections</p>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Additional Reports -->
        <div class="row mt-3">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Other reports</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group">
                            <a href="@Url.Action("RisksAndIssues", "Reports")" class="list-group-item list-group-item-action">
                                <div class="d-flex w-100 justify-content-between">
                                    <h5 class="mb-1"><i class="fas fa-clipboard-list text-primary"></i> Product RAID Summary</h5>
                                </div>
                                <p class="mb-1">View overall risks, issues, actions, and milestones by product.</p>
                            </a>
                            <a href="@Url.Action("Analysis", "Reports")" class="list-group-item list-group-item-action">
                                <div class="d-flex w-100 justify-content-between">
                                    <h5 class="mb-1"><i class="fas fa-chart-bar text-info"></i> Product Analysis</h5>
                                </div>
                                <p class="mb-1">Comprehensive product health analysis with problem scoring.</p>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Report Usage Tips -->
        <div class="row mt-3">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-light">
                        <h5 class="card-title mb-0"><i class="fas fa-info-circle"></i> Report usage tips</h5>
                    </div>
                    <div class="card-body">
                        <ul class="mb-0">
                            <li><strong>Query Data Builder:</strong> Create custom queries by selecting fields, adding filters, and choosing sort options. Perfect for ad-hoc analysis and answering specific questions.</li>
                            <li><strong>Risks report:</strong> Use the impact & likelihood matrix to identify which risks need immediate attention. Group by risk tier to review tier assignments.</li>
                            <li><strong>Issues report:</strong> Group by severity to prioritise critical and high-severity issues. Use the blocked filter to identify impediments.</li>
                            <li><strong>Actions report:</strong> Group by assigned to see workload distribution. Group by action source to track resolution of risks and issues.</li>
                            <li><strong>Milestones report:</strong> Group by quarter for roadmap planning. Group by status to identify delayed or at-risk deliverables.</li>
                            <li><strong>Product RAID Summary:</strong> Quick overview of all products with health scores for governance meetings.</li>
                            <li><strong>Product Analysis:</strong> Detailed analysis including user satisfaction correlation with RAID data.</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

