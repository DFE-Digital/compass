@using Compass.Models
@{
    ViewData["Title"] = "Reports overview";
    ViewData["BodyClass"] = "reports-page";
    var allProjects = ViewBag.AllProjects as List<Project> ?? new List<Project>();
    var totalProjects = ViewBag.TotalProjects as int? ?? 0;
    var activeProjects = ViewBag.ActiveProjects as int? ?? 0;
    var divisions = ViewBag.Divisions as List<Division> ?? new List<Division>();
    var businessAreas = ViewBag.BusinessAreas as List<BusinessAreaLookup> ?? new List<BusinessAreaLookup>();
    var ragBreakdown = ViewBag.RagBreakdown as Dictionary<string, int> ?? new Dictionary<string, int>();
    var phaseBreakdown = ViewBag.PhaseBreakdown as Dictionary<string, int> ?? new Dictionary<string, int>();
    var submittedThisMonth = ViewBag.SubmittedThisMonth as int? ?? 0;
    var totalActiveProjects = ViewBag.TotalActiveProjects as int? ?? 0;
    var monthName = ViewBag.MonthName as string ?? "";
    var totalOpenAccessibilityIssues = ViewBag.TotalOpenAccessibilityIssues as int? ?? 0;
    var criticalAccessibilityIssues = ViewBag.CriticalAccessibilityIssues as int? ?? 0;
    var flagshipCount = ViewBag.FlagshipCount as int? ?? 0;
    var multiDeptCount = ViewBag.MultiDeptCount as int? ?? 0;
    var aiInitiativeCount = ViewBag.AiInitiativeCount as int? ?? 0;
    var highRiskProjects = ViewBag.HighRiskProjects as int? ?? 0;
    var highIssueProjects = ViewBag.HighIssueProjects as int? ?? 0;
    var isAdmin = ViewBag.IsAdmin as bool? ?? false;
    var divisionCounts = ViewBag.DivisionProjectCounts as dynamic ?? new List<dynamic>();
    var baCounts = ViewBag.BaProjectCounts as dynamic ?? new List<dynamic>();

    // Computed values
    var reportingPct = totalActiveProjects > 0 ? (int)Math.Round(submittedThisMonth * 100.0 / totalActiveProjects) : 0;
    var redCount = ragBreakdown.GetValueOrDefault("Red", 0);
    var amberRedCount = ragBreakdown.GetValueOrDefault("Amber-Red", 0);
    var amberCount = ragBreakdown.GetValueOrDefault("Amber", 0);
    var greenCount = ragBreakdown.GetValueOrDefault("Green", 0);
    var amberGreenCount = ragBreakdown.GetValueOrDefault("Amber-Green", 0);
    var notSetCount = ragBreakdown.GetValueOrDefault("Not set", 0);
    var atRiskCount = redCount + amberRedCount;
    var ragTotal = ragBreakdown.Values.Sum();
    if (ragTotal == 0) ragTotal = 1;

    // Flagship projects list for modal
    var flagshipList = allProjects.Where(p => p.IsFlagship).ToList();
    var atRiskList = allProjects.Where(p => p.RagStatusLookup?.Name == "Red" || p.RagStatusLookup?.Name == "Amber-Red").ToList();

    // RAG ordered list
    var ragOrder = new[] { "Green", "Amber-Green", "Amber", "Amber-Red", "Red", "Not set" };
    var swatchClass = new Dictionary<string, string> {
        ["Green"] = "rag-swatch-green",
        ["Amber-Green"] = "rag-swatch-amber-green",
        ["Amber"] = "rag-swatch-amber",
        ["Amber-Red"] = "rag-swatch-amber-red",
        ["Red"] = "rag-swatch-red",
        ["Not set"] = "rag-swatch-unknown"
    };
    var segClass = new Dictionary<string, string> {
        ["Green"] = "rag-green",
        ["Amber-Green"] = "rag-amber-green",
        ["Amber"] = "rag-amber",
        ["Amber-Red"] = "rag-amber-red",
        ["Red"] = "rag-red",
        ["Not set"] = "rag-unknown"
    };
}

@await Html.PartialAsync("_DashboardStyles")
@await Html.PartialAsync("_ReportsDashboardStyles")

<!-- Dashboard header -->
<div class="reports-dashboard-header">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <nav aria-label="Breadcrumb" class="reports-breadcrumb">
                <a href="/">Home</a> <span aria-hidden="true">/</span> Reports overview
            </nav>
            <h1 class="mb-1"><i class="fas fa-chart-bar mr-2" aria-hidden="true"></i>Reports overview</h1>
            <p class="mb-0 opacity-90">At-a-glance view of all projects, products, and portfolio health across the department</p>
            <p class="cache-age mb-0"><i class="fas fa-clock mr-1" aria-hidden="true"></i>Data cached for up to 5 minutes &mdash;
                <form method="post" action="@Url.Action("RefreshCache", "Reports")" style="display:inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                    <button type="submit" class="btn btn-refresh btn-sm py-0 px-1">Refresh now</button>
                </form>
            </p>
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap mt-2 mt-md-0">
            <button class="btn btn-intel" data-toggle="modal" data-target="#intelModal" title="Portfolio intelligence summary">
                <i class="fas fa-brain mr-1" aria-hidden="true"></i> Intel
            </button>
            <a href="https://app.powerbi.com/groups/me/reports/d941d6dd-6d6a-40b1-bf66-12ad51522131/ce0a78d00040090301b6?experience=power-bi"
               target="_blank" rel="noopener noreferrer" class="btn btn-powerbi">
                <i class="fas fa-external-link-alt mr-1" aria-hidden="true"></i> Standards (SHCA)
            </a>
        </div>
    </div>
</div>

<!-- Report navigation tabs -->
<div class="reports-nav-bar">
    <ul class="reports-nav-tabs" role="navigation" aria-label="Report sections">
            <li>
                <a href="@Url.Action("Index", "Reports")" class="active" aria-current="page">
                    <i class="fas fa-globe mr-1" aria-hidden="true"></i>Overview
                </a>
            </li>
            <li class="reports-nav-dropdown">
                <button class="reports-nav-dropdown-toggle" aria-haspopup="true" aria-expanded="false">
                    <i class="fas fa-sitemap mr-1" aria-hidden="true"></i>Division
                    <i class="fas fa-chevron-down caret-icon ml-1" aria-hidden="true"></i>
                </button>
                <div class="reports-nav-dropdown-menu" role="menu">
                    <a href="@Url.Action("DivisionReport", "Reports")" role="menuitem">
                        <i class="fas fa-th-list mr-1 text-muted" aria-hidden="true"></i>All divisions
                    </a>
                    <div class="dropdown-divider"></div>
                    @foreach (var div in divisions)
                    {
                        <a href="@Url.Action("DivisionReport", "Reports", new { divisionId = div.Id })" role="menuitem">@div.Name</a>
                    }
                </div>
                <div class="dropdown-scroll-hint" aria-hidden="true"><i class="fas fa-chevron-down"></i></div>
            </li>
            <li class="reports-nav-dropdown">
                <button class="reports-nav-dropdown-toggle" aria-haspopup="true" aria-expanded="false">
                    <i class="fas fa-building mr-1" aria-hidden="true"></i>Business area
                    <i class="fas fa-chevron-down caret-icon ml-1" aria-hidden="true"></i>
                </button>
                <div class="reports-nav-dropdown-menu" role="menu">
                    <a href="@Url.Action("BusinessAreaReport", "Reports")" role="menuitem">
                        <i class="fas fa-th-list mr-1 text-muted" aria-hidden="true"></i>All business areas
                    </a>
                    <div class="dropdown-divider"></div>
                    @foreach (var ba in businessAreas.Take(20))
                    {
                        <a href="@Url.Action("BusinessAreaReport", "Reports", new { businessAreaId = ba.Id })" role="menuitem">@ba.Name</a>
                    }
                </div>
                <div class="dropdown-scroll-hint" aria-hidden="true"><i class="fas fa-chevron-down"></i></div>
            </li>
            <li>
                <a href="@Url.Action("PriorityOutcomes", "Reports")">
                    <i class="fas fa-star mr-1" aria-hidden="true"></i>Priority outcomes
                </a>
            </li>
            <li>
                <a href="@Url.Action("PerformanceReporting", "Reports")">
                    <i class="fas fa-chart-line mr-1" aria-hidden="true"></i>Performance reporting
                </a>
            </li>
        </ul>
</div>

<div class="reports-body">

        <!-- Top stat cards – each links to the relevant view -->
        <div class="reports-stat-grid mb-4">

            <button type="button" class="reports-stat-card reports-stat-blue" data-stat="all" data-stat-label="All projects">
                <div class="reports-stat-icon"><i class="fas fa-project-diagram" aria-hidden="true"></i></div>
                <div class="reports-stat-value">@totalProjects</div>
                <div class="reports-stat-label">Total projects</div>
                <div class="reports-stat-sub">@activeProjects active</div>
            </button>

            <button type="button" class="reports-stat-card @(atRiskCount > 0 ? "reports-stat-red" : "reports-stat-green")" data-stat="at-risk" data-stat-label="At-risk projects (Red / Amber-Red)">
                <div class="reports-stat-icon"><i class="fas fa-traffic-light" aria-hidden="true"></i></div>
                <div class="reports-stat-value">@atRiskCount</div>
                <div class="reports-stat-label">At risk (Red / Amber-Red)</div>
                <div class="reports-stat-sub">@greenCount green, @amberCount amber</div>
            </button>

            <button type="button" class="reports-stat-card @(reportingPct >= 80 ? "reports-stat-green" : reportingPct >= 50 ? "reports-stat-amber" : "reports-stat-red")" data-stat="not-reported" data-stat-label="Projects not yet reported – @monthName">
                <div class="reports-stat-icon"><i class="fas fa-file-alt" aria-hidden="true"></i></div>
                <div class="reports-stat-value">@reportingPct<span style="font-size:1.2rem">%</span></div>
                <div class="reports-stat-label">Monthly reporting</div>
                <div class="reports-stat-sub">@submittedThisMonth of @totalActiveProjects – @monthName</div>
            </button>

            <a href="@Url.Action("AccessibilityOversight", "DesignOps")"
               class="reports-stat-card @(criticalAccessibilityIssues > 0 ? "reports-stat-amber" : "reports-stat-green")">
                <div class="reports-stat-icon"><i class="fas fa-universal-access" aria-hidden="true"></i></div>
                <div class="reports-stat-value">@totalOpenAccessibilityIssues</div>
                <div class="reports-stat-label">Open accessibility issues</div>
                <div class="reports-stat-sub">@criticalAccessibilityIssues critical / high</div>
            </a>

            <button type="button" class="reports-stat-card reports-stat-gold" data-stat="flagship" data-stat-label="Flagship projects">
                <div class="reports-stat-icon"><i class="fas fa-star" aria-hidden="true"></i></div>
                <div class="reports-stat-value">@flagshipCount</div>
                <div class="reports-stat-label">Flagship projects</div>
                <div class="reports-stat-sub">@multiDeptCount multi-department</div>
            </button>

            <button type="button" class="reports-stat-card @(highRiskProjects > 0 ? "reports-stat-red" : "reports-stat-green")" data-stat="high-risk" data-stat-label="Projects with high risks">
                <div class="reports-stat-icon"><i class="fas fa-exclamation-triangle" aria-hidden="true"></i></div>
                <div class="reports-stat-value">@highRiskProjects</div>
                <div class="reports-stat-label">Projects with high risks</div>
                <div class="reports-stat-sub">@highIssueProjects with high-priority issues</div>
            </button>

        </div>

        <div class="row">
            <!-- Left column -->
            <div class="col-lg-8">

                <!-- RAG status breakdown – accessible -->
                <div class="dashboard-section mb-4">
                    <div class="dashboard-section-header">
                        <h2><i class="fas fa-traffic-light" aria-hidden="true"></i>RAG status breakdown</h2>
                        <a href="@Url.Action("DivisionReport", "Reports")" class="section-link">View by division <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
                    </div>
                    <div class="rag-bar-container mb-3">
                        <div class="rag-stacked-bar" role="img" aria-label="RAG status bar: @string.Join(", ", ragOrder.Where(k => ragBreakdown.ContainsKey(k) && ragBreakdown[k] > 0).Select(k => $"{k}: {ragBreakdown[k]}"))">
                            @foreach (var key in ragOrder)
                            {
                                if (!ragBreakdown.ContainsKey(key) || ragBreakdown[key] == 0) continue;
                                var count = ragBreakdown[key];
                                var pct = count * 100.0 / ragTotal;
                                var sc = segClass.GetValueOrDefault(key, "rag-unknown");
                                <div class="rag-segment @sc" style="width:@(pct.ToString("F1"))%">
                                    @if (pct > 10)
                                    {
                                        <span aria-hidden="true">@count</span>
                                    }
                                </div>
                            }
                                        </div>
                        <!-- Accessible legend with text labels, not just colour -->
                        <div class="rag-legend" role="list" aria-label="RAG status key">
                            @foreach (var key in ragOrder)
                            {
                                if (!ragBreakdown.ContainsKey(key) || ragBreakdown[key] == 0) continue;
                                var swc = swatchClass.GetValueOrDefault(key, "rag-swatch-unknown");
                                <span class="rag-legend-item" role="listitem">
                                    <span class="rag-swatch @swc" aria-hidden="true"></span>
                                    <span>@key</span>
                                    <strong>@ragBreakdown[key]</strong>
                                </span>
                            }
                                        </div>
                                    </div>
                                </div>

                <!-- Division summary -->
                <div class="dashboard-section mb-4">
                    <div class="dashboard-section-header">
                        <h2><i class="fas fa-sitemap" aria-hidden="true"></i>Projects by division</h2>
                        <a href="@Url.Action("DivisionReport", "Reports")" class="section-link">Full division report <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
                                        </div>
                    <div class="table-responsive">
                        <table class="table table-hover reports-table mb-0">
                            <thead>
                                <tr>
                                    <th>Division</th>
                                    <th class="text-center">Projects</th>
                                    <th class="text-center">At risk</th>
                                    <th class="text-center">Flagship</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in divisionCounts)
                                {
                                    var divId = (int)item.Division.Id;
                                    var divName = (string)item.Division.Name;
                                    <tr>
                                        <td><strong>@divName</strong></td>
                                        <td class="text-center"><span class="badge badge-primary">@item.Count</span></td>
                                        <td class="text-center">
                                            @if (item.RedCount > 0)
                                            {
                                                <button type="button"
                                                        class="badge badge-danger border-0 cursor-pointer"
                                                        style="cursor:pointer"
                                                        data-toggle="modal"
                                                        data-target="#atRiskModal"
                                                        data-division="@divName"
                                                        title="View at-risk projects in @divName">
                                                    @item.RedCount at risk
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">–</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (item.FlagshipCount > 0)
                                            {
                                                <button type="button"
                                                        class="badge badge-warning border-0"
                                                        style="cursor:pointer"
                                                        data-toggle="modal"
                                                        data-target="#flagshipModal"
                                                        data-division="@divName"
                                                        title="View flagship projects in @divName">
                                                    <i class="fas fa-star mr-1" aria-hidden="true"></i>@item.FlagshipCount flagship
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">–</span>
                                            }
                                        </td>
                                        <td class="text-right">
                                            <a href="@Url.Action("DivisionReport", "Reports", new { divisionId = divId })" class="section-link">View <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                                        </div>
                                    </div>

                <!-- Business area summary – expandable rows -->
                <div class="dashboard-section mb-4">
                    <div class="dashboard-section-header">
                        <h2><i class="fas fa-building" aria-hidden="true"></i>Projects by business area</h2>
                        <a href="@Url.Action("BusinessAreaReport", "Reports")" class="section-link">Full business area report <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
                                </div>
                    <div class="table-responsive">
                        <table class="table reports-table mb-0" id="baTable">
                            <thead>
                                <tr>
                                    <th style="width:32px"></th>
                                    <th>Business area</th>
                                    <th class="text-center">Projects</th>
                                    <th class="text-center">At risk</th>
                                    <th class="text-center">Flagship</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var baProjectMap = new Dictionary<int, List<Project>>();
                                    foreach (var item in baCounts)
                                    {
                                        if (item.Count == 0) continue;
                                        int baId = (int)item.BusinessArea.Id;
                                        baProjectMap[baId] = allProjects.Where(p => p.BusinessAreaId == baId).ToList();
                                    }
                                }
                                @foreach (var item in baCounts)
                                {
                                    if (item.Count == 0) continue;
                                    int baId = (int)item.BusinessArea.Id;
                                    var baProjects = baProjectMap.ContainsKey(baId) ? baProjectMap[baId] : new List<Project>();
                                    <tr class="ba-summary-row" data-ba-id="@baId">
                                        <td>
                                            <button class="ba-expand-btn"
                                                    aria-expanded="false"
                                                    aria-controls="ba-expand-@baId"
                                                    aria-label="Expand @item.BusinessArea.Name projects"
                                                    data-ba-expand="@baId">+</button>
                                        </td>
                                        <td><strong>@item.BusinessArea.Name</strong></td>
                                        <td class="text-center"><span class="badge badge-primary">@item.Count</span></td>
                                        <td class="text-center">
                                            @if (item.RedCount > 0)
                                            {
                                                <span class="badge badge-danger">@item.RedCount</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">–</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (item.FlagshipCount > 0)
                                            {
                                                <span class="badge badge-warning"><i class="fas fa-star mr-1" aria-hidden="true"></i>@item.FlagshipCount</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">–</span>
                                            }
                                        </td>
                                    </tr>
                                    <tr class="ba-expand-row" id="ba-expand-@baId">
                                        <td colspan="5">
                                            <div class="ba-projects-inner">
                                                @if (baProjects.Any())
                                                {
                                                    <table class="ba-projects-table">
                                                        <thead>
                                                            <tr>
                                                                <th>Project</th>
                                                                <th>Status</th>
                                                                <th>Phase</th>
                                                                <th>RAG</th>
                                                                <th>Priority</th>
                                                                <th>Flags</th>
                                                                <th>Risks</th>
                                                                <th>Issues</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                        @foreach (var proj in baProjects.OrderBy(p => p.Title))
                                        {
                                            // Use lookup name first, fall back to legacy string field
                                            var rag = !string.IsNullOrEmpty(proj.RagStatusLookup?.Name)
                                                ? proj.RagStatusLookup!.Name
                                                : (!string.IsNullOrEmpty(proj.RagStatus)
                                                    ? proj.RagStatus.Trim().Replace(" / ", "-").Replace("/", "-")
                                                    : "Not set");
                                            // Use CssClass from lookup if available, otherwise derive from name
                                            var ragBadge = (!string.IsNullOrEmpty(proj.RagStatusLookup?.CssClass))
                                                ? proj.RagStatusLookup!.CssClass!
                                                : rag switch {
                                                    "Green"       => "badge badge-green",
                                                    "Amber-Green" => "badge badge-amber-green",
                                                    "Amber"       => "badge badge-amber",
                                                    "Amber-Red"   => "badge badge-amber-red",
                                                    "Red"         => "badge badge-red",
                                                    _             => "badge badge-secondary"
                                                };
                                            var statusBadge = proj.Status switch {
                                                "Active"    => "badge badge-success",
                                                "Paused"    => "badge badge-warning",
                                                "Completed" => "badge badge-primary",
                                                "Cancelled" => "badge badge-danger",
                                                _           => "badge badge-secondary"
                                            };
                                            var priorityBadge = proj.DeliveryPriority?.Name?.ToLowerInvariant() switch {
                                                "high"   => "badge badge-high",
                                                "medium" => "badge badge-medium",
                                                "low"    => "badge badge-low",
                                                _        => "badge badge-secondary"
                                            };
                                            var openRisks  = proj.Risks?.Count(r => !r.IsDeleted) ?? 0;
                                            var openIssues = proj.Issues?.Count(i => !i.IsDeleted && i.Status != "resolved" && i.Status != "closed") ?? 0;
                                            <tr>
                                                <td>
                                                    <a href="@Url.Action("Details", "Project", new { id = proj.Id })" class="ba-project-name">@proj.Title</a>
                                                    @if (!string.IsNullOrEmpty(proj.ProjectCode))
                                                    {
                                                        <div class="text-muted" style="font-size:0.72rem;">@proj.ProjectCode</div>
                                                    }
                                                </td>
                                                <td><span class="@statusBadge">@proj.Status</span></td>
                                                <td>
                                                    @if (proj.PhaseLookup != null)
                                                    {
                                                        <span class="badge badge-secondary">@proj.PhaseLookup.Name</span>
                                                    }
                                                    else { <span class="text-muted">–</span> }
                                                </td>
                                                <td>
                                                    <button type="button"
                                                            class="@ragBadge rag-detail-btn"
                                                            data-toggle="modal" data-target="#ragDetailModal"
                                                            data-project="@proj.Title"
                                                            data-rag="@rag"
                                                            data-justification="@(proj.RagJustification ?? "")"
                                                            data-path="@(proj.PathToGreen ?? "")"
                                                            data-project-url="@Url.Action("Details", "Project", new { id = proj.Id })"
                                                            style="border:none;cursor:pointer;">
                                                        @rag
                                                    </button>
                                                </td>
                                                <td>
                                                    @if (proj.DeliveryPriority != null)
                                                    {
                                                        <span class="@priorityBadge">@proj.DeliveryPriority.Name</span>
                                                    }
                                                    else { <span class="text-muted">–</span> }
                                                </td>
                                                <td>
                                                    @if (proj.IsFlagship)
                                                    {
                                                        <button type="button" class="badge badge-warning border-0 mr-1 flag-detail-btn"
                                                                data-toggle="modal" data-target="#flagDetailModal"
                                                                data-project="@proj.Title"
                                                                data-flag="flagship"
                                                                data-project-url="@Url.Action("Details", "Project", new { id = proj.Id })"
                                                                style="cursor:pointer;"
                                                                aria-label="Flagship – click for details">
                                                            <i class="fas fa-star" aria-hidden="true"></i> Flagship
                                                        </button>
                                                    }
                                                    @if (proj.IsMultiDepartmentProject)
                                                    {
                                                        <button type="button" class="badge badge-info border-0 flag-detail-btn"
                                                                data-toggle="modal" data-target="#flagDetailModal"
                                                                data-project="@proj.Title"
                                                                data-flag="multi-dept"
                                                                data-other-depts="@(proj.OtherDepartments ?? "")"
                                                                data-project-url="@Url.Action("Details", "Project", new { id = proj.Id })"
                                                                style="cursor:pointer;"
                                                                aria-label="Multi-department – click for details">
                                                            <i class="fas fa-globe" aria-hidden="true"></i> Multi-dept
                                                        </button>
                                                    }
                                                    @if (!proj.IsFlagship && !proj.IsMultiDepartmentProject)
                                                    {
                                                        <span class="text-muted">–</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (openRisks > 0)
                                                    {
                                                        <span class="badge badge-danger">@openRisks risk@(openRisks != 1 ? "s" : "")</span>
                                                    }
                                                    else { <span class="text-muted small">–</span> }
                                                </td>
                                                <td>
                                                    @if (openIssues > 0)
                                                    {
                                                        <span class="badge badge-warning">@openIssues issue@(openIssues != 1 ? "s" : "")</span>
                                                    }
                                                    else { <span class="text-muted small">–</span> }
                                                </td>
                                            </tr>
                                        }
                                                        </tbody>
                                                    </table>
                                                    <div class="ba-expand-footer">
                                                        <a href="@Url.Action("BusinessAreaReport", "Reports", new { businessAreaId = baId })" class="section-link">
                                                            Full business area report <i class="fas fa-arrow-right" aria-hidden="true"></i>
                                                        </a>
                            </div>
                        }
                        else
                        {
                                                    <p class="text-muted small mb-2">No projects found for this area.</p>
                                                    <div class="ba-expand-footer">
                                                        <a href="@Url.Action("BusinessAreaReport", "Reports", new { businessAreaId = baId })" class="section-link">
                                                            Full business area report <i class="fas fa-arrow-right" aria-hidden="true"></i>
                                                        </a>
                                                    </div>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>

            <!-- Right column -->
            <div class="col-lg-4">

                <!-- Monthly reporting status -->
                <div class="dashboard-section mb-4">
                    <div class="dashboard-section-header">
                        <h2><i class="fas fa-calendar-check" aria-hidden="true"></i>Monthly reporting</h2>
                    </div>
                    <p class="text-muted small mb-2">@monthName</p>
                    <div class="reporting-progress-wrap mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="small font-weight-bold">@submittedThisMonth of @totalActiveProjects submitted</span>
                            <span class="small font-weight-bold @(reportingPct >= 80 ? "text-success" : reportingPct >= 50 ? "text-warning" : "text-danger")">@reportingPct%</span>
                        </div>
                        <div class="progress" style="height:10px;border-radius:5px;">
                            <div class="progress-bar @(reportingPct >= 80 ? "bg-success" : reportingPct >= 50 ? "bg-warning" : "bg-danger")"
                                 role="progressbar" style="width:@reportingPct%"
                                 aria-valuenow="@reportingPct" aria-valuemin="0" aria-valuemax="100"
                                 aria-label="@reportingPct% of projects have submitted monthly reports"></div>
                        </div>
                    </div>
                    <a href="@Url.Action("MonthlyReporting", "CentralOps")" class="section-link d-block">
                        View monthly reporting <i class="fas fa-arrow-right" aria-hidden="true"></i>
                    </a>
                </div>

                <!-- Accessibility posture -->
                <div class="dashboard-section mb-4">
                    <div class="dashboard-section-header">
                        <h2><i class="fas fa-universal-access" aria-hidden="true"></i>Accessibility posture</h2>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Open issues</span>
                        <strong class="@(totalOpenAccessibilityIssues > 0 ? "text-warning" : "text-success")">@totalOpenAccessibilityIssues</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted small">Critical / high severity</span>
                        <strong class="@(criticalAccessibilityIssues > 0 ? "text-danger" : "text-success")">@criticalAccessibilityIssues</strong>
                    </div>
                    <a href="@Url.Action("AccessibilityOversight", "DesignOps")" class="section-link d-block">
                        View accessibility oversight <i class="fas fa-arrow-right" aria-hidden="true"></i>
                    </a>
                </div>

                <!-- Priority highlights -->
                <div class="dashboard-section mb-4">
                    <div class="dashboard-section-header">
                        <h2><i class="fas fa-star" aria-hidden="true"></i>Priority highlights</h2>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Flagship projects</span>
                        <a href="@Url.Action("PriorityOutcomes", "Reports")" class="font-weight-bold text-warning">@flagshipCount</a>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Multi-department</span>
                        <a href="@Url.Action("PriorityOutcomes", "Reports")" class="font-weight-bold text-info">@multiDeptCount</a>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted small">AI initiatives</span>
                        <a href="@Url.Action("PriorityOutcomes", "Reports")" class="font-weight-bold text-primary">@aiInitiativeCount</a>
                    </div>
                    <a href="@Url.Action("PriorityOutcomes", "Reports")" class="section-link d-block">
                        View priority outcomes <i class="fas fa-arrow-right" aria-hidden="true"></i>
                    </a>
                </div>

                <!-- Phase breakdown – each phase links to filtered project list -->
                <div class="dashboard-section mb-4">
                    <div class="dashboard-section-header">
                        <h2><i class="fas fa-layer-group" aria-hidden="true"></i>Projects by phase</h2>
                    </div>
                    @foreach (var kvp in phaseBreakdown.OrderByDescending(k => k.Value))
                    {
                        var phasePct = totalProjects > 0 ? (int)Math.Round(kvp.Value * 100.0 / totalProjects) : 0;
                        <div class="mb-2">
                            <div class="d-flex justify-content-between mb-1">
                                <a href="@Url.Action("Index", "Project", new { phase = kvp.Key })" class="small text-body">@kvp.Key</a>
                                <a href="@Url.Action("Index", "Project", new { phase = kvp.Key })" class="small font-weight-bold text-body">@kvp.Value</a>
                            </div>
                            <div class="progress" style="height:6px;border-radius:3px;" aria-hidden="true">
                                <div class="progress-bar bg-primary" role="progressbar" style="width:@phasePct%"
                                     aria-label="@kvp.Key: @kvp.Value projects (@phasePct%)"></div>
                            </div>
                        </div>
                    }
                </div>

            </div>
        </div>

</div><!-- /.reports-body -->

<!-- Stat detail modal (shared, populated by JS) -->
<div class="modal fade" id="statDetailModal" tabindex="-1" role="dialog" aria-labelledby="statDetailModalLabel">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable" role="document">
        <div class="modal-content">
            <div class="modal-header stat-detail-modal-header">
                <h5 class="modal-title" id="statDetailModalLabel">
                    <i class="fas fa-list mr-2" aria-hidden="true" id="statDetailModalIcon"></i>
                    <span id="statDetailModalTitle">Projects</span>
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body p-0">
                <div class="px-3 pt-3 pb-2">
                    <input type="text" id="statDetailSearch" class="form-control form-control-sm" placeholder="Filter by project name…" aria-label="Filter projects">
                </div>
                <div class="table-responsive">
                    <table class="table table-hover reports-table mb-0">
                        <thead>
                            <tr>
                                <th>Project</th>
                                <th>RAG</th>
                                <th>Status</th>
                                <th>Phase</th>
                                <th>Business area</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="statDetailProjectsList"></tbody>
                    </table>
                </div>
                <p class="text-muted small px-3 py-2 mb-0" id="statDetailEmpty" style="display:none">No projects match this filter.</p>
            </div>
            <div class="modal-footer">
                <span class="text-muted small mr-auto" id="statDetailCount"></span>
                <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- RAG detail modal -->
<div class="modal fade" id="ragDetailModal" tabindex="-1" role="dialog" aria-labelledby="ragDetailModalLabel">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header" id="ragDetailModalHeader">
                <h5 class="modal-title" id="ragDetailModalLabel">
                    <i class="fas fa-traffic-light mr-2" aria-hidden="true"></i>
                    RAG status – <span id="ragDetailProjectName"></span>
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <span class="font-weight-bold small text-muted d-block mb-1">Current status</span>
                    <span id="ragDetailBadge" class="badge"></span>
                </div>
                <div class="mb-3" id="ragJustificationBlock">
                    <span class="font-weight-bold small text-muted d-block mb-1">Justification</span>
                    <p id="ragDetailJustification" class="mb-0 small"></p>
                </div>
                <div id="ragPathToGreenBlock">
                    <span class="font-weight-bold small text-muted d-block mb-1"><i class="fas fa-road mr-1 text-success" aria-hidden="true"></i>Path to green</span>
                    <p id="ragDetailPathToGreen" class="mb-0 small"></p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Close</button>
                <a id="ragDetailProjectLink" href="#" class="btn btn-primary btn-sm">View project <i class="fas fa-arrow-right ml-1" aria-hidden="true"></i></a>
            </div>
        </div>
    </div>
</div>

<!-- Flag detail modal -->
<div class="modal fade" id="flagDetailModal" tabindex="-1" role="dialog" aria-labelledby="flagDetailModalLabel">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="flagDetailModalLabel">
                    <i class="fas fa-star mr-2 text-warning" aria-hidden="true" id="flagDetailIcon"></i>
                    <span id="flagDetailTitle">Project flag</span>
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
            </div>
            <div class="modal-body">
                <p class="mb-2"><strong id="flagDetailProjectName"></strong></p>
                <p id="flagDetailDescription" class="text-muted small mb-0"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Close</button>
                <a id="flagDetailProjectLink" href="#" class="btn btn-primary btn-sm">View project <i class="fas fa-arrow-right ml-1" aria-hidden="true"></i></a>
            </div>
        </div>
    </div>
</div>

@{
    // Serialise project data for JS-driven stat modal
    var projectsJson = System.Text.Json.JsonSerializer.Serialize(allProjects.Select(p => new {
        id = p.Id,
        title = p.Title ?? "",
        rag = !string.IsNullOrEmpty(p.RagStatusLookup?.Name) ? p.RagStatusLookup!.Name
              : (!string.IsNullOrEmpty(p.RagStatus) ? p.RagStatus.Trim().Replace(" / ", "-").Replace("/", "-") : "Not set"),
        status = p.Status ?? "",
        phase = p.PhaseLookup?.Name ?? "",
        businessArea = p.BusinessAreaLookup?.Name ?? "",
        isFlagship = p.IsFlagship,
        isMultiDept = p.IsMultiDepartmentProject,
        hasHighRisk = p.Risks != null && p.Risks.Any(r => r.LikelihoodRating >= 4 || r.ImpactRating >= 4),
        reportedThisMonth = p.MonthlyUpdates != null && p.MonthlyUpdates.Any(u => u.Year == DateTime.Now.Year && u.Month == DateTime.Now.Month),
        url = Url.Action("Details", "Project", new { id = p.Id })
    }));
}

<!-- Intel modal -->
@{
    var intelData = new ViewDataDictionary(Html.ViewData.ModelMetadata, Html.ViewData.ModelState)
    {
        { "Context", "overview" },
        { "TotalProjects", totalProjects },
        { "ActiveProjects", activeProjects },
        { "AtRiskCount", atRiskCount },
        { "RedCount", redCount },
        { "ReportingPct", reportingPct },
        { "SubmittedThisMonth", submittedThisMonth },
        { "TotalActiveProjects", totalActiveProjects },
        { "MonthName", monthName },
        { "TotalOpenAccessibilityIssues", totalOpenAccessibilityIssues },
        { "CriticalAccessibilityIssues", criticalAccessibilityIssues },
        { "FlagshipCount", flagshipCount },
        { "MultiDeptCount", multiDeptCount },
        { "HighRiskProjects", highRiskProjects },
        { "HighIssueProjects", highIssueProjects }
    };
}
@await Html.PartialAsync("_IntelModal", intelData)

@section Scripts {
<script nonce="@Context.Items["Nonce"]">
(function () {
    /* ── Reports nav dropdowns (click-to-open) ─────────────────────────── */
    var navBar = document.querySelector('.reports-nav-bar');
    if (navBar) {
        var toggles = navBar.querySelectorAll('.reports-nav-dropdown-toggle');
        toggles.forEach(function (toggle) {
            var menu = toggle.nextElementSibling;
            if (!menu || !menu.classList.contains('reports-nav-dropdown-menu')) return;
            var hint = menu.nextElementSibling;
            var hasHint = hint && hint.classList.contains('dropdown-scroll-hint');

            function updateScrollHint() {
                if (!hasHint) return;
                var canScroll = menu.scrollHeight > menu.clientHeight;
                var atBottom = menu.scrollTop + menu.clientHeight >= menu.scrollHeight - 4;
                hint.classList.toggle('visible', canScroll && !atBottom);
            }

            toggle.addEventListener('click', function (e) {
                e.stopPropagation();
                var isOpen = menu.classList.contains('open');
                // Close all other open menus first
                navBar.querySelectorAll('.reports-nav-dropdown-menu.open').forEach(function (m) {
                    m.classList.remove('open');
                    m.previousElementSibling.setAttribute('aria-expanded', 'false');
                    var h = m.nextElementSibling;
                    if (h && h.classList.contains('dropdown-scroll-hint')) h.classList.remove('visible');
                });
                if (!isOpen) {
                    menu.classList.add('open');
                    toggle.setAttribute('aria-expanded', 'true');
                    updateScrollHint();
                }
            });

            if (hasHint) {
                menu.addEventListener('scroll', updateScrollHint);
            }

            // Keyboard: close on Escape
            toggle.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') {
                    menu.classList.remove('open');
                    toggle.setAttribute('aria-expanded', 'false');
                    if (hasHint) hint.classList.remove('visible');
                    toggle.focus();
                }
            });
        });

        // Close dropdowns when clicking outside
        document.addEventListener('click', function () {
            navBar.querySelectorAll('.reports-nav-dropdown-menu.open').forEach(function (m) {
                m.classList.remove('open');
                m.previousElementSibling.setAttribute('aria-expanded', 'false');
                var h = m.nextElementSibling;
                if (h && h.classList.contains('dropdown-scroll-hint')) h.classList.remove('visible');
            });
        });
    }

    /* ── BA expand/collapse ────────────────────────────────────────────── */
    document.addEventListener('click', function (e) {
        var btn = e.target.closest('[data-ba-expand]');
        if (!btn) return;
        var baId = btn.getAttribute('data-ba-expand');
        var expandRow = document.getElementById('ba-expand-' + baId);
        var summaryRow = btn.closest('.ba-summary-row');
        if (!expandRow) return;
        var isOpen = expandRow.classList.contains('open');
        expandRow.classList.toggle('open', !isOpen);
        if (summaryRow) summaryRow.classList.toggle('is-open', !isOpen);
        btn.textContent = isOpen ? '+' : '\u2212';
        btn.setAttribute('aria-expanded', String(!isOpen));
    });

    /* ── Stat detail modal ─────────────────────────────────────────────── */
    var allProjectsData = @Html.Raw(projectsJson);

    var statConfigs = {
        'all':         { label: 'All projects',                    icon: 'fa-project-diagram', filter: function(p) { return true; } },
        'at-risk':     { label: 'At-risk projects (Red / Amber-Red)', icon: 'fa-traffic-light',  filter: function(p) { return p.rag === 'Red' || p.rag === 'Amber-Red'; } },
        'not-reported':{ label: 'Projects not yet reported',       icon: 'fa-file-alt',        filter: function(p) { return p.status === 'Active' && !p.reportedThisMonth; } },
        'flagship':    { label: 'Flagship projects',               icon: 'fa-star',            filter: function(p) { return p.isFlagship; } },
        'high-risk':   { label: 'Projects with high risks',        icon: 'fa-exclamation-triangle', filter: function(p) { return p.hasHighRisk; } }
    };

    function ragBadgeClass(rag) {
        if (rag === 'Green') return 'badge-green';
        if (rag === 'Amber-Green') return 'badge-amber-green';
        if (rag === 'Amber') return 'badge-amber';
        if (rag === 'Amber-Red') return 'badge-amber-red';
        if (rag === 'Red') return 'badge-red';
        return 'badge-secondary';
    }
    function statusBadgeClass(s) {
        if (s === 'Active') return 'badge-success';
        if (s === 'Paused') return 'badge-warning';
        if (s === 'Completed') return 'badge-primary';
        if (s === 'Cancelled') return 'badge-danger';
        return 'badge-secondary';
    }

    function renderStatModal(filter, label, icon) {
        var projects = allProjectsData.filter(filter);
        var tbody = document.getElementById('statDetailProjectsList');
        var html = '';
        projects.forEach(function(p) {
            html += '<tr>' +
                '<td><a href="' + p.url + '" class="project-link font-weight-bold">' + escHtml(p.title) + '</a>' +
                (p.isFlagship ? ' <span class="badge badge-warning ml-1" title="Flagship"><i class="fas fa-star"></i></span>' : '') +
                '</td>' +
                '<td><span class="badge ' + ragBadgeClass(p.rag) + '">' + escHtml(p.rag) + '</span></td>' +
                '<td><span class="badge ' + statusBadgeClass(p.status) + '">' + escHtml(p.status || '–') + '</span></td>' +
                '<td><span class="text-muted small">' + escHtml(p.phase || '–') + '</span></td>' +
                '<td><span class="text-muted small">' + escHtml(p.businessArea || '–') + '</span></td>' +
                '<td><a href="' + p.url + '" class="section-link">View <i class="fas fa-arrow-right" aria-hidden="true"></i></a></td>' +
                '</tr>';
        });
        tbody.innerHTML = html || '';
        document.getElementById('statDetailModalTitle').textContent = label;
        document.getElementById('statDetailModalIcon').className = 'fas ' + icon + ' mr-2';
        document.getElementById('statDetailCount').textContent = projects.length + ' project' + (projects.length !== 1 ? 's' : '');
        document.getElementById('statDetailEmpty').style.display = projects.length === 0 ? '' : 'none';
        document.getElementById('statDetailSearch').value = '';
    }

    function escHtml(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // Wire up stat cards
    document.querySelectorAll('[data-stat]').forEach(function(card) {
        card.addEventListener('click', function() {
            var key = card.getAttribute('data-stat');
            var cfg = statConfigs[key];
            if (!cfg) return;
            renderStatModal(cfg.filter, cfg.label, cfg.icon);
            $('#statDetailModal').modal('show');
        });
    });

    // Live search within modal
    document.getElementById('statDetailSearch').addEventListener('input', function() {
        var q = this.value.toLowerCase();
        var rows = document.querySelectorAll('#statDetailProjectsList tr');
        var visible = 0;
        rows.forEach(function(row) {
            var text = row.textContent.toLowerCase();
            var show = !q || text.indexOf(q) !== -1;
            row.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        document.getElementById('statDetailEmpty').style.display = (visible === 0) ? '' : 'none';
        document.getElementById('statDetailCount').textContent = visible + ' project' + (visible !== 1 ? 's' : '');
    });

    /* ── RAG detail modal ──────────────────────────────────────────────── */
    var ragHeaderColors = {
        'Green': '#1e7e34', 'Amber-Green': '#856404', 'Amber': '#856404',
        'Amber-Red': '#c0392b', 'Red': '#721c24'
    };
    document.querySelectorAll('.rag-detail-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var project = btn.getAttribute('data-project') || '';
            var rag = btn.getAttribute('data-rag') || 'Not set';
            var justification = btn.getAttribute('data-justification') || '';
            var path = btn.getAttribute('data-path') || '';
            var projectUrl = btn.getAttribute('data-project-url') || '#';

            document.getElementById('ragDetailProjectName').textContent = project;
            var badge = document.getElementById('ragDetailBadge');
            badge.className = 'badge badge ' + ragBadgeClass(rag);
            badge.textContent = rag;

            var header = document.getElementById('ragDetailModalHeader');
            header.style.background = ragHeaderColors[rag] || '#6c757d';
            header.style.color = '#fff';

            var justBlock = document.getElementById('ragJustificationBlock');
            if (justification) {
                document.getElementById('ragDetailJustification').textContent = justification;
                justBlock.style.display = '';
            } else {
                justBlock.style.display = 'none';
            }

            var pathBlock = document.getElementById('ragPathToGreenBlock');
            if (path && rag !== 'Green') {
                document.getElementById('ragDetailPathToGreen').textContent = path;
                pathBlock.style.display = '';
            } else {
                pathBlock.style.display = 'none';
            }

            document.getElementById('ragDetailProjectLink').href = projectUrl;
        });
    });

    /* ── Flag detail modal ─────────────────────────────────────────────── */
    document.querySelectorAll('.flag-detail-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var project = btn.getAttribute('data-project') || '';
            var flag = btn.getAttribute('data-flag') || '';
            var projectUrl = btn.getAttribute('data-project-url') || '#';

            document.getElementById('flagDetailProjectName').textContent = project;
            document.getElementById('flagDetailProjectLink').href = projectUrl;

            var icon = document.getElementById('flagDetailIcon');
            var title = document.getElementById('flagDetailTitle');
            var desc = document.getElementById('flagDetailDescription');

            if (flag === 'flagship') {
                icon.className = 'fas fa-star mr-2 text-warning';
                title.textContent = 'Flagship project';
                desc.textContent = 'This project has been designated as a flagship project. Flagship projects are high-visibility, strategically important deliverables that receive additional scrutiny and support.';
            } else if (flag === 'multi-dept') {
                icon.className = 'fas fa-globe mr-2 text-info';
                title.textContent = 'Multi-department project';
                var depts = btn.getAttribute('data-other-depts') || '';
                desc.textContent = 'This project involves collaboration across multiple government departments.' + (depts ? ' Other departments: ' + depts : '');
            }
        });
    });
}());
</script>
}
