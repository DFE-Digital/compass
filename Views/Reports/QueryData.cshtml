@{
    ViewData["Title"] = "Query data";
    var products = ViewBag.Products as List<Compass.Models.ProductDto> ?? new List<Compass.Models.ProductDto>();
    var businessAreas = ViewBag.BusinessAreas as List<string> ?? new List<string>();
    var objectives = ViewBag.Objectives as List<Compass.Models.Objective> ?? new List<Compass.Models.Objective>();
    var riskTypes = ViewBag.RiskTypes as List<Compass.Models.RiskType> ?? new List<Compass.Models.RiskType>();
    var riskTiers = ViewBag.RiskTiers as List<Compass.Models.RiskTier> ?? new List<Compass.Models.RiskTier>();
    var actionSources = ViewBag.ActionSources as List<Compass.Models.ActionSource> ?? new List<Compass.Models.ActionSource>();
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Query data</h1>
                <p class="text-muted">Build custom queries to analyse RAID data</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <!-- Query Builder -->
        <div class="row">
            <div class="col-lg-3 col-md-12">
                <!-- Step 1: Select Entity Type -->
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="card-title mb-0">1. Select data type</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-group">
                            <select id="entityType" class="form-control">
                                <option value="">-- Select type --</option>
                                <option value="risks">Risks</option>
                                <option value="issues">Issues</option>
                                <option value="actions">Actions</option>
                                <option value="milestones">Milestones</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Step 2: Select Fields -->
                <div class="card d-none" id="fieldsCard">
                    <div class="card-header bg-info text-white">
                        <h5 class="card-title mb-0">2. Select columns</h5>
                    </div>
                    <div class="card-body">
                        <div id="fieldsContainer"></div>
                        <button type="button" class="btn btn-sm btn-secondary mt-2" onclick="selectAllFields()">
                            Select all
                        </button>
                        <button type="button" class="btn btn-sm btn-secondary mt-2" onclick="clearAllFields()">
                            Clear all
                        </button>
                    </div>
                </div>

                <!-- Step 3: Add Filters -->
                <div class="card d-none" id="filtersCard">
                    <div class="card-header bg-warning">
                        <h5 class="card-title mb-0">3. Add filters</h5>
                    </div>
                    <div class="card-body">
                        <div id="filtersContainer"></div>
                        <button type="button" class="btn btn-sm btn-success mt-2" onclick="addFilter()">
                            Add filter
                        </button>
                    </div>
                </div>

                <!-- Step 4: Sort Options -->
                <div class="card d-none" id="sortCard">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="card-title mb-0">4. Sort results</h5>
                    </div>
                    <div class="card-body">
                        <div class="form-group">
                            <label>Sort by</label>
                            <select id="sortBy" class="form-control"></select>
                        </div>
                        <div class="form-group">
                            <label>Direction</label>
                            <select id="sortDirection" class="form-control">
                                <option value="asc">Ascending</option>
                                <option value="desc">Descending</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Generate Button -->
                <div class="card d-none" id="generateCard">
                    <div class="card-body">
                        <button type="button" class="btn btn-primary btn-block" onclick="generateReport()">
                            Generate report
                        </button>
                        <button type="button" class="btn btn-secondary btn-block" onclick="resetQuery()">
                            Reset
                        </button>
                    </div>
                </div>
            </div>

            <!-- Results -->
            <div class="col-lg-9 col-md-12">
                <div class="card d-none" id="resultsCard">
                    <div class="card-header">
                        <h5 class="card-title mb-0">
                            Results
                            <span class="badge badge-primary ml-2" id="resultCount">0</span>
                        </h5>
                        <div class="card-tools">
                            <button type="button" class="btn btn-sm btn-success" onclick="exportResults()">
                                Export CSV
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div id="loadingSpinner" class="text-center p-5 d-none">
                            <i class="fas fa-spinner fa-spin fa-3x text-primary"></i>
                            <p class="mt-3">Running query...</p>
                        </div>
                        <div id="resultsTable" class="table-responsive"></div>
                    </div>
                </div>

                <!-- Help Card -->
                <div class="card" id="helpCard">
                    <div class="card-header bg-light">
                        <h5 class="card-title mb-0">How to use</h5>
                    </div>
                    <div class="card-body">
                        <ol>
                            <li><strong>Select data type:</strong> Choose whether you want to query Risks, Issues, Actions, or Milestones</li>
                            <li><strong>Select columns:</strong> Choose which fields you want to see in your results</li>
                            <li><strong>Add filters:</strong> Add one or more filters to narrow down your results</li>
                            <li><strong>Sort results:</strong> Choose how to sort your results</li>
                            <li><strong>Generate report:</strong> Click to run your query and see the results</li>
                        </ol>
                        <div class="alert alert-info mb-0">
                            <strong>Tip:</strong> Use this to answer questions like "Show me all high-priority blocked issues" or "Which risks have a score above 15?"
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@Html.AntiForgeryToken()

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            var filterCount = 0;
            var currentQuery = null;
            var currentResults = null;
            
            var lookupData = {
                products: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(products.Select(p => new { value = p.FipsId, text = p.Title }))),
                businessAreas: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(businessAreas)),
                objectives: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(objectives.Select(o => new { value = o.Id, text = o.Title }))),
                riskTypes: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(riskTypes.Select(rt => new { value = rt.Id, text = rt.Name }))),
                riskTiers: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(riskTiers.Select(rt => new { value = rt.Id, text = rt.Name }))),
                actionSources: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(actionSources.Select(a => new { value = a.Id, text = a.Name })))
            };
        
        var fieldDefinitions = {
            risks: [
                { value: 'title', text: 'Title', sortable: true },
                { value: 'riskScore', text: 'Risk Score', sortable: true },
                { value: 'impactRating', text: 'Impact', sortable: false },
                { value: 'likelihoodRating', text: 'Likelihood', sortable: false },
                { value: 'status', text: 'Status', sortable: true },
                { value: 'businessArea', text: 'Business Area', sortable: false },
                { value: 'fipsId', text: 'Product', sortable: false },
                { value: 'riskTier', text: 'Risk Tier', sortable: false },
                { value: 'riskTypes', text: 'Risk Types', sortable: false },
                { value: 'objective', text: 'Objective', sortable: false },
                { value: 'proximityDate', text: 'Proximity Date', sortable: false },
                { value: 'createdAt', text: 'Created Date', sortable: true }
            ],
            issues: [
                { value: 'title', text: 'Title', sortable: true },
                { value: 'severity', text: 'Severity', sortable: true },
                { value: 'priority', text: 'Priority', sortable: false },
                { value: 'status', text: 'Status', sortable: true },
                { value: 'businessArea', text: 'Business Area', sortable: false },
                { value: 'fipsId', text: 'Product', sortable: false },
                { value: 'blocked', text: 'Blocked', sortable: false },
                { value: 'objective', text: 'Objective', sortable: false },
                { value: 'owner', text: 'Owner', sortable: false },
                { value: 'detectedDate', text: 'Detected Date', sortable: true },
                { value: 'targetResolutionDate', text: 'Target Resolution', sortable: false },
                { value: 'createdAt', text: 'Created Date', sortable: true }
            ],
            actions: [
                { value: 'title', text: 'Title', sortable: true },
                { value: 'status', text: 'Status', sortable: true },
                { value: 'businessArea', text: 'Business Area', sortable: false },
                { value: 'fipsId', text: 'Product', sortable: false },
                { value: 'actionSource', text: 'Action Source', sortable: false },
                { value: 'assignedTo', text: 'Assigned To', sortable: false },
                { value: 'objective', text: 'Objective', sortable: false },
                { value: 'priority', text: 'Priority', sortable: false },
                { value: 'dueDate', text: 'Due Date', sortable: true },
                { value: 'completedDate', text: 'Completed Date', sortable: false },
                { value: 'createdAt', text: 'Created Date', sortable: true }
            ],
            milestones: [
                { value: 'name', text: 'Name', sortable: true },
                { value: 'status', text: 'Status', sortable: true },
                { value: 'businessArea', text: 'Business Area', sortable: false },
                { value: 'fipsId', text: 'Product', sortable: false },
                { value: 'owner', text: 'Owner', sortable: false },
                { value: 'objective', text: 'Objective', sortable: false },
                { value: 'dueDate', text: 'Due Date', sortable: true },
                { value: 'progressPercent', text: 'Progress %', sortable: true },
                { value: 'createdAt', text: 'Created Date', sortable: true }
            ]
        };
        
        var filterDefinitions = {
            risks: [
                { value: 'status', text: 'Status', type: 'select', options: ['new', 'open', 'treating', 'monitoring', 'closed'] },
                { value: 'businessArea', text: 'Business Area', type: 'select', options: 'businessAreas' },
                { value: 'fipsId', text: 'Product', type: 'select', options: 'products' },
                { value: 'riskScoreMin', text: 'Min Risk Score', type: 'number' },
                { value: 'riskScoreMax', text: 'Max Risk Score', type: 'number' },
                { value: 'riskTierId', text: 'Risk Tier', type: 'select', options: 'riskTiers' },
                { value: 'objectiveId', text: 'Objective', type: 'select', options: 'objectives' }
            ],
            issues: [
                { value: 'status', text: 'Status', type: 'select', options: ['open', 'in_progress', 'blocked', 'resolved', 'closed'] },
                { value: 'severity', text: 'Severity', type: 'select', options: ['critical', 'high', 'medium', 'low'] },
                { value: 'priority', text: 'Priority', type: 'select', options: ['high', 'medium', 'low'] },
                { value: 'businessArea', text: 'Business Area', type: 'select', options: 'businessAreas' },
                { value: 'fipsId', text: 'Product', type: 'select', options: 'products' },
                { value: 'blocked', text: 'Blocked', type: 'select', options: [{ value: 'true', text: 'Yes' }, { value: 'false', text: 'No' }] },
                { value: 'objectiveId', text: 'Objective', type: 'select', options: 'objectives' }
            ],
            actions: [
                { value: 'status', text: 'Status', type: 'select', options: ['not_started', 'in_progress', 'done', 'blocked', 'cancelled'] },
                { value: 'businessArea', text: 'Business Area', type: 'select', options: 'businessAreas' },
                { value: 'fipsId', text: 'Product', type: 'select', options: 'products' },
                { value: 'actionSourceId', text: 'Action Source', type: 'select', options: 'actionSources' },
                { value: 'objectiveId', text: 'Objective', type: 'select', options: 'objectives' },
                { value: 'overdue', text: 'Overdue', type: 'select', options: [{ value: 'true', text: 'Yes' }, { value: 'false', text: 'No' }] }
            ],
            milestones: [
                { value: 'status', text: 'Status', type: 'select', options: ['not_started', 'on_track', 'at_risk', 'delayed', 'complete', 'cancelled'] },
                { value: 'businessArea', text: 'Business Area', type: 'select', options: 'businessAreas' },
                { value: 'fipsId', text: 'Product', type: 'select', options: 'products' },
                { value: 'objectiveId', text: 'Objective', type: 'select', options: 'objectives' },
                { value: 'overdue', text: 'Overdue', type: 'select', options: [{ value: 'true', text: 'Yes' }, { value: 'false', text: 'No' }] }
            ]
        };
        
            // Make functions global so onclick handlers can access them
            window.selectAllFields = selectAllFields;
            window.clearAllFields = clearAllFields;
            window.addFilter = addFilter;
            window.removeFilter = removeFilter;
            window.generateReport = generateReport;
            window.exportResults = exportResults;
            window.resetQuery = resetQuery;
            
            $('#entityType').change(function() {
                var entityType = $(this).val();
                if (entityType) {
                    populateFields(entityType);
                    $('#fieldsCard, #filtersCard, #sortCard, #generateCard').removeClass('d-none');
                    $('#helpCard').addClass('d-none');
                } else {
                    $('#fieldsCard, #filtersCard, #sortCard, #generateCard').addClass('d-none');
                    $('#helpCard').removeClass('d-none');
                }
            });
        
        function populateFields(entityType) {
            var fields = fieldDefinitions[entityType];
            var html = '';
            
            fields.forEach(function(field) {
                html += '<div class="custom-control custom-checkbox">';
                html += '<input type="checkbox" class="custom-control-input field-checkbox" id="field_' + field.value + '" value="' + field.value + '">';
                html += '<label class="custom-control-label" for="field_' + field.value + '">' + field.text + '</label>';
                html += '</div>';
            });
            
            $('#fieldsContainer').html(html);
            
            // Populate sort options
            var sortHtml = '<option value="">-- Select field --</option>';
            fields.filter(f => f.sortable).forEach(function(field) {
                sortHtml += '<option value="' + field.value + '">' + field.text + '</option>';
            });
            $('#sortBy').html(sortHtml);
            
            // Clear filters
            $('#filtersContainer').html('');
            filterCount = 0;
        }
        
        function selectAllFields() {
            $('.field-checkbox').prop('checked', true);
        }
        
        function clearAllFields() {
            $('.field-checkbox').prop('checked', false);
        }
        
        function addFilter() {
            var entityType = $('#entityType').val();
            var filters = filterDefinitions[entityType];
            
            filterCount++;
            var html = '<div class="filter-row mb-2" id="filter_' + filterCount + '">';
            html += '<div class="input-group input-group-sm">';
            html += '<select class="form-control filter-field" data-filter-id="' + filterCount + '">';
            html += '<option value="">-- Select filter --</option>';
            
            filters.forEach(function(filter) {
                html += '<option value="' + filter.value + '" data-type="' + filter.type + '" data-options="' + JSON.stringify(filter.options).replace(/"/g, '&quot;') + '">' + filter.text + '</option>';
            });
            
            html += '</select>';
            html += '<div class="filter-value-container" data-filter-id="' + filterCount + '"></div>';
            html += '<div class="input-group-append">';
            html += '<button class="btn btn-danger" type="button" onclick="removeFilter(' + filterCount + ')"><i class="fas fa-times"></i></button>';
            html += '</div>';
            html += '</div>';
            html += '</div>';
            
            $('#filtersContainer').append(html);
            
            $('.filter-field[data-filter-id="' + filterCount + '"]').change(function() {
                updateFilterValue($(this));
            });
        }
        
        function updateFilterValue(selectElement) {
            var filterId = selectElement.data('filter-id');
            var selected = selectElement.find(':selected');
            var type = selected.data('type');
            var options = selected.data('options');
            
            var container = $('.filter-value-container[data-filter-id="' + filterId + '"]');
            var html = '';
            
            if (type === 'select') {
                html = '<select class="form-control filter-value">';
                html += '<option value="">-- Select value --</option>';
                
                if (typeof options === 'string') {
                    // Lookup from lookupData
                    if (options === 'businessAreas') {
                        lookupData.businessAreas.forEach(function(ba) {
                            html += '<option value="' + ba + '">' + ba + '</option>';
                        });
                    } else if (lookupData[options]) {
                        lookupData[options].forEach(function(item) {
                            html += '<option value="' + item.value + '">' + item.text + '</option>';
                        });
                    }
                } else if (Array.isArray(options)) {
                    options.forEach(function(opt) {
                        if (typeof opt === 'string') {
                            html += '<option value="' + opt + '">' + opt.replace('_', ' ') + '</option>';
                        } else {
                            html += '<option value="' + opt.value + '">' + opt.text + '</option>';
                        }
                    });
                }
                
                html += '</select>';
            } else if (type === 'number') {
                html = '<input type="number" class="form-control filter-value" placeholder="Enter value">';
            } else {
                html = '<input type="text" class="form-control filter-value" placeholder="Enter value">';
            }
            
            container.html(html);
        }
        
        function removeFilter(filterId) {
            $('#filter_' + filterId).remove();
        }
        
        function generateReport() {
            var entityType = $('#entityType').val();
            var fields = [];
            $('.field-checkbox:checked').each(function() {
                fields.push($(this).val());
            });
            
            if (fields.length === 0) {
                alert('Please select at least one field');
                return;
            }
            
            var filters = [];
            $('.filter-row').each(function() {
                var field = $(this).find('.filter-field').val();
                var value = $(this).find('.filter-value').val();
                if (field && value) {
                    filters.push({ field: field, value: value });
                }
            });
            
            var sortBy = $('#sortBy').val();
            var sortDirection = $('#sortDirection').val();
            
            currentQuery = {
                entityType: entityType,
                fields: fields,
                filters: filters,
                sortBy: sortBy,
                sortDirection: sortDirection
            };
            
            $('#loadingSpinner').removeClass('d-none');
            $('#resultsTable').addClass('d-none');
            $('#resultsCard').removeClass('d-none');
            
            $.ajax({
                url: '/Reports/ExecuteQuery',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify(currentQuery),
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    $('#loadingSpinner').addClass('d-none');
                    if (response.success) {
                        currentResults = response.data;
                        displayResults(response.data, fields);
                        $('#resultCount').text(response.count);
                    } else {
                        alert('Error: ' + response.error);
                    }
                },
                error: function() {
                    $('#loadingSpinner').addClass('d-none');
                    alert('Failed to execute query');
                }
            });
        }
        
        function displayResults(data, fields) {
            if (data.length === 0) {
                $('#resultsTable').html('<div class="p-4 text-center text-muted">No results found</div>').removeClass('d-none');
                return;
            }
            
            var html = '<table class="table table-striped table-hover mb-0">';
            html += '<thead><tr>';
            
            fields.forEach(function(field) {
                var fieldDef = fieldDefinitions[$('#entityType').val()].find(f => f.value === field);
                html += '<th>' + fieldDef.text + '</th>';
            });
            
            html += '<th>Actions</th></tr></thead><tbody>';
            
            data.forEach(function(row) {
                html += '<tr>';
                fields.forEach(function(field) {
                    html += '<td>' + (row[field] || '-') + '</td>';
                });
                html += '<td><a href="' + row._detailsUrl + '" class="btn btn-sm btn-info">View</a></td>';
                html += '</tr>';
            });
            
            html += '</tbody></table>';
            $('#resultsTable').html(html).removeClass('d-none');
        }
        
        function exportResults() {
            if (!currentResults || currentResults.length === 0) {
                alert('No results to export');
                return;
            }
            
            var csv = [];
            var fields = currentQuery.fields;
            var fieldDefs = fieldDefinitions[currentQuery.entityType];
            
            // Header row
            var headers = fields.map(function(field) {
                var fieldDef = fieldDefs.find(f => f.value === field);
                return fieldDef.text;
            });
            csv.push(headers.join(','));
            
            // Data rows
            currentResults.forEach(function(row) {
                var values = fields.map(function(field) {
                    var value = row[field] || '';
                    // Escape commas and quotes
                    if (value.toString().includes(',') || value.toString().includes('"')) {
                        value = '"' + value.toString().replace(/"/g, '""') + '"';
                    }
                    return value;
                });
                csv.push(values.join(','));
            });
            
            // Download
            var csvContent = csv.join('\n');
            var blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            var link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = currentQuery.entityType + '_query_' + new Date().toISOString().split('T')[0] + '.csv';
            link.click();
        }
        
        function resetQuery() {
            $('#entityType').val('');
            $('#fieldsCard, #filtersCard, #sortCard, #generateCard, #resultsCard').addClass('d-none');
            $('#helpCard').removeClass('d-none');
            $('#fieldsContainer').html('');
            $('#filtersContainer').html('');
            $('#resultsTable').html('');
            filterCount = 0;
            currentQuery = null;
            currentResults = null;
        }
        
        }); // End document.ready
    </script>
}

