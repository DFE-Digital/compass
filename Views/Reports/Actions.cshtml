@model List<Compass.Models.Action>
@{
    ViewData["Title"] = "Actions report";
    var groupBy = ViewBag.GroupBy as string ?? "status";
    var products = ViewBag.Products as List<Compass.Models.ProductDto> ?? new List<Compass.Models.ProductDto>();
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Actions report</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <!-- Summary Cards -->
        <div class="row mb-3">
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-info">
                    <div class="inner">
                        <h3>@ViewBag.TotalActions</h3>
                        <p>Total actions</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-tasks"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-success">
                    <div class="inner">
                        <h3>@ViewBag.DoneActions</h3>
                        <p>Done</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-primary">
                    <div class="inner">
                        <h3>@ViewBag.InProgressActions</h3>
                        <p>In progress</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-spinner"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-secondary">
                    <div class="inner">
                        <h3>@ViewBag.NotStartedActions</h3>
                        <p>Not started</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-pause-circle"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-danger">
                    <div class="inner">
                        <h3>@ViewBag.BlockedActions</h3>
                        <p>Blocked</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-ban"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-warning">
                    <div class="inner">
                        <h3>@ViewBag.OverdueActions</h3>
                        <p>Overdue</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-clock"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Grouping Options -->
        <div class="row mb-3">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Group by</h5>
                    </div>
                    <div class="card-body">
                        <div class="btn-group" role="group">
                            <a href="@Url.Action("Actions", new { groupBy = "status" })" class="btn btn-@(groupBy == "status" ? "primary" : "outline-primary")">
                                <i class="fas fa-flag"></i> Status
                            </a>
                            <a href="@Url.Action("Actions", new { groupBy = "action-source" })" class="btn btn-@(groupBy == "action-source" ? "primary" : "outline-primary")">
                                <i class="fas fa-sitemap"></i> Action source
                            </a>
                            <a href="@Url.Action("Actions", new { groupBy = "business-area" })" class="btn btn-@(groupBy == "business-area" ? "primary" : "outline-primary")">
                                <i class="fas fa-building"></i> Business area
                            </a>
                            <a href="@Url.Action("Actions", new { groupBy = "product" })" class="btn btn-@(groupBy == "product" ? "primary" : "outline-primary")">
                                <i class="fas fa-box"></i> Product
                            </a>
                            <a href="@Url.Action("Actions", new { groupBy = "assigned-to" })" class="btn btn-@(groupBy == "assigned-to" ? "primary" : "outline-primary")">
                                <i class="fas fa-user"></i> Assigned to
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Grouped Results -->
        @if (groupBy == "status")
        {
            var grouped = Model.GroupBy(a => a.Status ?? "unknown")
                .OrderBy(g => g.Key == "blocked" ? 0 : g.Key == "in_progress" ? 1 : g.Key == "not_started" ? 2 : 3);
            
            <div class="row">
                @foreach (var group in grouped)
                {
                    var badgeClass = group.Key == "done" ? "success" : group.Key == "in_progress" ? "primary" : group.Key == "blocked" ? "danger" : "secondary";
                    
                    <div class="col-xxl-3 col-xl-4 col-lg-6 col-md-6 col-sm-12 col-12 mb-3">
                        <div class="card">
                            <div class="card-header bg-@badgeClass text-white">
                                <h5 class="card-title mb-0 text-capitalize">@group.Key.Replace("_", " ")</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Total: @group.Count()</strong></p>
                                <ul class="list-unstyled mb-0">
                                    <li><i class="fas fa-clock text-warning"></i> @group.Count(a => a.DueDate.HasValue && a.DueDate < DateTime.Today && a.Status != "done" && a.Status != "cancelled") Overdue</li>
                                    <li><i class="fas fa-calendar text-info"></i> @group.Count(a => a.DueDate.HasValue) With due date</li>
                                </ul>
                                <button class="btn btn-sm btn-outline-primary mt-2" onclick="showGroupActions('@group.Key', 'status')">View actions</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (groupBy == "action-source")
        {
            var grouped = Model.GroupBy(a => a.ActionSource?.Name ?? "No source")
                .OrderBy(g => g.Key);
            
            <div class="row">
                @foreach (var group in grouped)
                {
                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-12 col-sm-12 col-12 mb-3">
                        <div class="card">
                            <div class="card-header bg-info text-white">
                                <h5 class="card-title mb-0">@group.Key</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Total: @group.Count()</strong></p>
                                <ul class="list-unstyled mb-0">
                                    <li><span class="badge badge-success">@group.Count(a => a.Status == "done")</span> Done</li>
                                    <li><span class="badge badge-primary">@group.Count(a => a.Status == "in_progress")</span> In progress</li>
                                    <li><span class="badge badge-danger">@group.Count(a => a.Status == "blocked")</span> Blocked</li>
                                </ul>
                                <button class="btn btn-sm btn-outline-primary mt-2" onclick="showGroupActions('@group.Key', 'action-source')">View actions</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (groupBy == "business-area")
        {
            var grouped = Model.GroupBy(a => string.IsNullOrEmpty(a.BusinessArea) ? "Unspecified" : a.BusinessArea)
                .OrderBy(g => g.Key);
            
            <div class="row">
                @foreach (var group in grouped)
                {
                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-12 col-sm-12 col-12 mb-3">
                        <div class="card">
                            <div class="card-header bg-primary text-white">
                                <h5 class="card-title mb-0">@group.Key</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Total: @group.Count()</strong></p>
                                <ul class="list-unstyled mb-0">
                                    <li><span class="badge badge-success">@group.Count(a => a.Status == "done")</span> Done</li>
                                    <li><span class="badge badge-primary">@group.Count(a => a.Status == "in_progress")</span> In progress</li>
                                    <li><span class="badge badge-danger">@group.Count(a => a.Status == "blocked")</span> Blocked</li>
                                </ul>
                                <button class="btn btn-sm btn-outline-primary mt-2" onclick="showGroupActions('@group.Key', 'business-area')">View actions</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (groupBy == "product")
        {
            var grouped = Model.GroupBy(a => a.FipsId ?? "No product").OrderBy(g => g.Key);
            
            <div class="row">
                @foreach (var group in grouped)
                {
                    var product = products.FirstOrDefault(p => p.FipsId == group.Key);
                    var displayName = product?.Title ?? group.Key;
                    
                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-12 col-sm-12 col-12 mb-3">
                        <div class="card">
                            <div class="card-header bg-info text-white">
                                <h5 class="card-title mb-0">@displayName</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Total: @group.Count()</strong></p>
                                <ul class="list-unstyled mb-0">
                                    <li><span class="badge badge-success">@group.Count(a => a.Status == "done")</span> Done</li>
                                    <li><span class="badge badge-primary">@group.Count(a => a.Status == "in_progress")</span> In progress</li>
                                    <li><span class="badge badge-danger">@group.Count(a => a.Status == "blocked")</span> Blocked</li>
                                </ul>
                                <button class="btn btn-sm btn-outline-primary mt-2" onclick="showGroupActions('@group.Key', 'product')">View actions</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (groupBy == "assigned-to")
        {
            var grouped = Model.GroupBy(a => !string.IsNullOrEmpty(a.AssignedToEmail) ? a.AssignedToEmail : "Unassigned")
                .OrderBy(g => g.Key);
            
            <div class="row">
                @foreach (var group in grouped)
                {
                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-12 col-sm-12 col-12 mb-3">
                        <div class="card">
                            <div class="card-header bg-secondary text-white">
                                <h5 class="card-title mb-0">@group.Key</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Total: @group.Count()</strong></p>
                                <ul class="list-unstyled mb-0">
                                    <li><span class="badge badge-success">@group.Count(a => a.Status == "done")</span> Done</li>
                                    <li><span class="badge badge-primary">@group.Count(a => a.Status == "in_progress")</span> In progress</li>
                                    <li><span class="badge badge-warning">@group.Count(a => a.DueDate.HasValue && a.DueDate < DateTime.Today && a.Status != "done" && a.Status != "cancelled")</span> Overdue</li>
                                </ul>
                                <button class="btn btn-sm btn-outline-primary mt-2" onclick="showGroupActions('@group.Key', 'assigned-to')">View actions</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Detailed List Modal -->
        <div class="modal fade" id="actionDetailModal" tabindex="-1">
            <div class="modal-dialog modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Actions</h5>
                        <button type="button" class="close" data-dismiss="modal">
                            <span>&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <div id="actionDetailContent"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        var allActions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(a => new {
            id = a.Id,
            title = a.Title,
            fipsId = a.FipsId,
            businessArea = a.BusinessArea,
            status = a.Status,
            actionSource = a.ActionSource != null ? a.ActionSource.Name : null,
            assignedTo = a.AssignedToEmail,
            dueDate = a.DueDate
        })));

        function showGroupActions(groupValue, groupType) {
            var filtered = [];
            
            if (groupType === 'status') {
                filtered = allActions.filter(a => a.status === groupValue);
            } else if (groupType === 'action-source') {
                filtered = allActions.filter(a => (a.actionSource || 'No source') === groupValue);
            } else if (groupType === 'business-area') {
                filtered = allActions.filter(a => (a.businessArea || 'Unspecified') === groupValue);
            } else if (groupType === 'product') {
                filtered = allActions.filter(a => (a.fipsId || 'No product') === groupValue);
            } else if (groupType === 'assigned-to') {
                filtered = allActions.filter(a => (a.assignedTo || 'Unassigned') === groupValue);
            }
            
            displayActions(filtered, groupValue);
        }

        function displayActions(actions, title) {
            var html = '<h6>' + title + ' (' + actions.length + ' actions)</h6>';
            html += '<div class="table-responsive"><table class="table table-hover table-striped"><thead><tr>';
            html += '<th>Title</th><th>Status</th><th>Due Date</th><th>Assigned To</th><th>Actions</th></tr></thead><tbody>';
            
            actions.forEach(function(action) {
                var statusClass = action.status === 'done' ? 'success' : action.status === 'in_progress' ? 'primary' : action.status === 'blocked' ? 'danger' : 'secondary';
                var today = new Date();
                today.setHours(0, 0, 0, 0);
                var dueDate = action.dueDate ? new Date(action.dueDate) : null;
                var isOverdue = dueDate && dueDate < today && action.status !== 'done' && action.status !== 'cancelled';
                
                html += '<tr' + (isOverdue ? ' class="table-warning"' : '') + '>';
                html += '<td>' + action.title + '</td>';
                html += '<td><span class="badge badge-' + statusClass + '">' + (action.status || '-').replace('_', ' ') + '</span></td>';
                html += '<td>' + (action.dueDate ? new Date(action.dueDate).toLocaleDateString('en-GB') : '-') + (isOverdue ? ' <i class="fas fa-clock text-danger"></i>' : '') + '</td>';
                html += '<td>' + (action.assignedTo || '-') + '</td>';
                html += '<td><a href="/Action/Details/' + action.id + '" class="btn btn-sm btn-info">View</a></td>';
                html += '</tr>';
            });
            
            html += '</tbody></table></div>';
            $('#actionDetailContent').html(html);
            $('#actionDetailModal').modal('show');
        }
    </script>
}

