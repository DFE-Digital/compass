@model List<Compass.Models.Action>
@{
    ViewData["Title"] = "Actions report";
    var groupBy = ViewBag.GroupBy as string ?? "status";
    var products = ViewBag.Products as List<Compass.Models.ProductDto> ?? new List<Compass.Models.ProductDto>();
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Reports</a></li>
                    <li class="breadcrumb-item active">Actions</li>
                </ol>
                <h1 class="m-0">Actions report</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <!-- Summary -->
        <div class="row mb-3">
            <div class="col-lg-2 col-md-4 col-6">
                <div class="card">
                    <div class="card-body text-center">
                        <h3 class="mb-0">@ViewBag.TotalActions</h3>
                        <p class="text-muted mb-0"><small>Total</small></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="card">
                    <div class="card-body text-center">
                        <h3 class="mb-0">@ViewBag.DoneActions</h3>
                        <p class="text-muted mb-0"><small>Done</small></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="card">
                    <div class="card-body text-center">
                        <h3 class="mb-0">@ViewBag.InProgressActions</h3>
                        <p class="text-muted mb-0"><small>In progress</small></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="card">
                    <div class="card-body text-center">
                        <h3 class="mb-0">@ViewBag.NotStartedActions</h3>
                        <p class="text-muted mb-0"><small>Not started</small></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="card">
                    <div class="card-body text-center">
                        <h3 class="mb-0">@ViewBag.BlockedActions</h3>
                        <p class="text-muted mb-0"><small>Blocked</small></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="card">
                    <div class="card-body text-center">
                        <h3 class="mb-0">@ViewBag.OverdueActions</h3>
                        <p class="text-muted mb-0"><small>Overdue</small></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Left Sidebar: Grouping Options -->
            <div class="col-lg-2 col-md-3 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Group by</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <a href="@Url.Action("Actions", new { groupBy = "status" })" class="list-group-item list-group-item-action @(groupBy == "status" ? "active" : "")">Status</a>
                            <a href="@Url.Action("Actions", new { groupBy = "action-source" })" class="list-group-item list-group-item-action @(groupBy == "action-source" ? "active" : "")">Action source</a>
                            <a href="@Url.Action("Actions", new { groupBy = "business-area" })" class="list-group-item list-group-item-action @(groupBy == "business-area" ? "active" : "")">Business area</a>
                            <a href="@Url.Action("Actions", new { groupBy = "product" })" class="list-group-item list-group-item-action @(groupBy == "product" ? "active" : "")">Product</a>
                            <a href="@Url.Action("Actions", new { groupBy = "assigned-to" })" class="list-group-item list-group-item-action @(groupBy == "assigned-to" ? "active" : "")">Assigned to</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Content: Grouped Results -->
            <div class="col-lg-10 col-md-9 col-12">
                @if (groupBy == "status")
                {
                    var grouped = Model.GroupBy(a => a.Status ?? "unknown")
                        .OrderBy(g => g.Key == "blocked" ? 0 : g.Key == "in_progress" ? 1 : g.Key == "not_started" ? 2 : 3);
                    
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Actions by status</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Status</th>
                                        <th style="width: 100px;" class="text-center">Total</th>
                                        <th style="width: 120px;" class="text-center">Overdue</th>
                                        <th style="width: 120px;" class="text-center">With due date</th>
                                        <th style="width: 100px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var group in grouped)
                                    {
                                        <tr>
                                            <td><strong class="text-capitalize">@group.Key.Replace("_", " ")</strong></td>
                                            <td class="text-center">@group.Count()</td>
                                            <td class="text-center">
                                                @{
                                                    var overdueCount = group.Count(a => a.DueDate.HasValue && a.DueDate < DateTime.Today && a.Status != "done" && a.Status != "cancelled");
                                                }
                                                @if (overdueCount > 0)
                                                {
                                                    <span class="text-danger">@overdueCount</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td class="text-center">@group.Count(a => a.DueDate.HasValue)</td>
                                            <td><button class="btn btn-sm btn-outline-primary" onclick="showGroupActions('@group.Key', 'status')">View</button></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else if (groupBy == "action-source")
                {
                    var grouped = Model.GroupBy(a => a.ActionSource?.Name ?? "No source")
                        .OrderBy(g => g.Key);
                    
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Actions by source</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Source</th>
                                        <th style="width: 100px;" class="text-center">Total</th>
                                        <th style="width: 100px;" class="text-center">Done</th>
                                        <th style="width: 120px;" class="text-center">In progress</th>
                                        <th style="width: 100px;" class="text-center">Blocked</th>
                                        <th style="width: 100px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var group in grouped)
                                    {
                                        <tr>
                                            <td><strong>@group.Key</strong></td>
                                            <td class="text-center">@group.Count()</td>
                                            <td class="text-center">@group.Count(a => a.Status == "done")</td>
                                            <td class="text-center">@group.Count(a => a.Status == "in_progress")</td>
                                            <td class="text-center">@group.Count(a => a.Status == "blocked")</td>
                                            <td><button class="btn btn-sm btn-outline-primary" onclick="showGroupActions('@group.Key', 'action-source')">View</button></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else if (groupBy == "business-area")
                {
                    var grouped = Model.GroupBy(a => string.IsNullOrEmpty(a.BusinessArea) ? "Unspecified" : a.BusinessArea)
                        .OrderBy(g => g.Key);
                    
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Actions by business area</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Business area</th>
                                        <th style="width: 100px;" class="text-center">Total</th>
                                        <th style="width: 100px;" class="text-center">Done</th>
                                        <th style="width: 120px;" class="text-center">In progress</th>
                                        <th style="width: 100px;" class="text-center">Blocked</th>
                                        <th style="width: 100px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var group in grouped)
                                    {
                                        <tr>
                                            <td><strong>@group.Key</strong></td>
                                            <td class="text-center">@group.Count()</td>
                                            <td class="text-center">@group.Count(a => a.Status == "done")</td>
                                            <td class="text-center">@group.Count(a => a.Status == "in_progress")</td>
                                            <td class="text-center">@group.Count(a => a.Status == "blocked")</td>
                                            <td><button class="btn btn-sm btn-outline-primary" onclick="showGroupActions('@group.Key', 'business-area')">View</button></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else if (groupBy == "product")
                {
                    var grouped = Model.GroupBy(a => a.FipsId ?? "No product").OrderBy(g => g.Key);
                    
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Actions by product</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th style="width: 100px;" class="text-center">Total</th>
                                        <th style="width: 100px;" class="text-center">Done</th>
                                        <th style="width: 120px;" class="text-center">In progress</th>
                                        <th style="width: 100px;" class="text-center">Blocked</th>
                                        <th style="width: 100px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var group in grouped)
                                    {
                                        var product = products.FirstOrDefault(p => p.FipsId == group.Key);
                                        var displayName = product?.Title ?? group.Key;
                                        
                                        <tr>
                                            <td><strong>@displayName</strong></td>
                                            <td class="text-center">@group.Count()</td>
                                            <td class="text-center">@group.Count(a => a.Status == "done")</td>
                                            <td class="text-center">@group.Count(a => a.Status == "in_progress")</td>
                                            <td class="text-center">@group.Count(a => a.Status == "blocked")</td>
                                            <td><button class="btn btn-sm btn-outline-primary" onclick="showGroupActions('@group.Key', 'product')">View</button></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else if (groupBy == "assigned-to")
                {
                    var grouped = Model.GroupBy(a => !string.IsNullOrEmpty(a.AssignedToEmail) ? a.AssignedToEmail : "Unassigned")
                        .OrderBy(g => g.Key);
                    
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Actions by assigned to</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Assigned to</th>
                                        <th style="width: 100px;" class="text-center">Total</th>
                                        <th style="width: 100px;" class="text-center">Done</th>
                                        <th style="width: 120px;" class="text-center">In progress</th>
                                        <th style="width: 100px;" class="text-center">Overdue</th>
                                        <th style="width: 100px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var group in grouped)
                                    {
                                        <tr>
                                            <td><strong>@group.Key</strong></td>
                                            <td class="text-center">@group.Count()</td>
                                            <td class="text-center">@group.Count(a => a.Status == "done")</td>
                                            <td class="text-center">@group.Count(a => a.Status == "in_progress")</td>
                                            <td class="text-center">@group.Count(a => a.DueDate.HasValue && a.DueDate < DateTime.Today && a.Status != "done" && a.Status != "cancelled")</td>
                                            <td><button class="btn btn-sm btn-outline-primary" onclick="showGroupActions('@group.Key', 'assigned-to')">View</button></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Detailed List Modal -->
        <div class="modal fade" id="actionDetailModal" tabindex="-1">
            <div class="modal-dialog modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Actions</h5>
                        <button type="button" class="close" data-dismiss="modal">
                            <span>&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <div id="actionDetailContent"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        var allActions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(a => new {
            id = a.Id,
            title = a.Title,
            fipsId = a.FipsId,
            businessArea = a.BusinessArea,
            status = a.Status,
            actionSource = a.ActionSource != null ? a.ActionSource.Name : null,
            assignedTo = a.AssignedToEmail,
            dueDate = a.DueDate
        })));

        function showGroupActions(groupValue, groupType) {
            var filtered = [];
            
            if (groupType === 'status') {
                filtered = allActions.filter(a => a.status === groupValue);
            } else if (groupType === 'action-source') {
                filtered = allActions.filter(a => (a.actionSource || 'No source') === groupValue);
            } else if (groupType === 'business-area') {
                filtered = allActions.filter(a => (a.businessArea || 'Unspecified') === groupValue);
            } else if (groupType === 'product') {
                filtered = allActions.filter(a => (a.fipsId || 'No product') === groupValue);
            } else if (groupType === 'assigned-to') {
                filtered = allActions.filter(a => (a.assignedTo || 'Unassigned') === groupValue);
            }
            
            displayActions(filtered, groupValue);
        }

        function displayActions(actions, title) {
            var html = '<h6>' + title + ' (' + actions.length + ' actions)</h6>';
            html += '<div class="table-responsive"><table class="table table-hover"><thead><tr>';
            html += '<th>Title</th><th>Status</th><th>Due date</th><th>Assigned to</th><th>Actions</th></tr></thead><tbody>';
            
            actions.forEach(function(action) {
                var statusClass = action.status === 'done' ? 'success' : action.status === 'in_progress' ? 'primary' : action.status === 'blocked' ? 'danger' : 'secondary';
                var today = new Date();
                today.setHours(0, 0, 0, 0);
                var dueDate = action.dueDate ? new Date(action.dueDate) : null;
                var isOverdue = dueDate && dueDate < today && action.status !== 'done' && action.status !== 'cancelled';
                
                html += '<tr' + (isOverdue ? ' class="table-danger"' : '') + '>';
                html += '<td>' + action.title + '</td>';
                html += '<td><span class="badge badge-' + statusClass + '">' + (action.status || '-').replace('_', ' ') + '</span></td>';
                html += '<td>' + (action.dueDate ? new Date(action.dueDate).toLocaleDateString('en-GB') : '-') + '</td>';
                html += '<td>' + (action.assignedTo || '-') + '</td>';
                html += '<td><a href="/Action/Details/' + action.id + '" class="btn btn-sm btn-info">View</a></td>';
                html += '</tr>';
            });
            
            html += '</tbody></table></div>';
            $('#actionDetailContent').html(html);
            $('#actionDetailModal').modal('show');
        }
    </script>
}
