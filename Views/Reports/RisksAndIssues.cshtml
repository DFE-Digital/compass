@model IEnumerable<ProductRaidReport>
@{
    ViewData["Title"] = "Risks and issues by product";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item">Reports</li>
                    <li class="breadcrumb-item active">Risks and issues</li>
                </ol>
                <h1 class="m-0">Risks and issues by product</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <!-- Summary Cards -->
        <div class="row">
            <div class="col-xxl-3 col-xl-3 col-lg-3 col-md-3 col-sm-12 col-12">
                <div class="small-box bg-info">
                    <div class="inner">
                        <h3>@Model.Sum(p => p.TotalRisks)</h3>
                        <p>Total risks</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-3 col-xl-3 col-lg-3 col-md-3 col-sm-12 col-12">
                <div class="small-box bg-danger">
                    <div class="inner">
                        <h3>@Model.Sum(p => p.HighRisks)</h3>
                        <p>High risks (15+)</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-fire"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-3 col-xl-3 col-lg-3 col-md-3 col-sm-12 col-12">
                <div class="small-box bg-warning">
                    <div class="inner">
                        <h3>@Model.Sum(p => p.TotalIssues)</h3>
                        <p>Total issues</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-bug"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-3 col-xl-3 col-lg-3 col-md-3 col-sm-12 col-12">
                <div class="small-box bg-danger">
                    <div class="inner">
                        <h3>@Model.Sum(p => p.CriticalIssues)</h3>
                        <p>Critical issues</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-exclamation-circle"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- League Table -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Product league table</h3>
                <div class="card-tools">
                    <span class="badge badge-info">@Model.Count() products</span>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th style="width: 30%;">Product</th>
                            <th style="width: 14%;">Health score</th>
                            <th style="width: 14%;">Risks</th>
                            <th style="width: 14%;">Issues</th>
                            <th style="width: 14%;">Actions</th>
                            <th style="width: 14%;">Milestones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var product in Model.OrderBy(p => p.HealthScore))
                            {
                                var rowClass = product.HealthScore < 30 ? "table-danger" : 
                                             product.HealthScore < 60 ? "table-warning" : "";
                                <tr class="@rowClass">
                                    <td>
                                        <a href="/Products/Dashboard/@product.FipsId" class="font-weight-bold">
                                            @product.ProductTitle
                                        </a>
                                        <br /><small class="text-muted">@product.FipsId</small>
                                    </td>
                                    <td>
                                        @{
                                            var healthBadgeClass = product.HealthScore >= 80 ? "badge-success" :
                                                                   product.HealthScore >= 60 ? "badge-info" :
                                                                   product.HealthScore >= 40 ? "badge-warning" :
                                                                   product.HealthScore >= 20 ? "badge-danger" : "badge-dark";
                                        }
                                        <span class="badge @healthBadgeClass">@product.HealthScore</span>
                                    </td>
                                    <td>
                                        @if (product.OpenRisks > 0)
                                        {
                                            <span class="badge badge-info">@product.OpenRisks</span>
                                            @if (product.HighRisks > 0)
                                            {
                                                <br /><small class="text-danger">@product.HighRisks high</small>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">0</span>
                                        }
                                    </td>
                                    <td>
                                        @if (product.TotalIssues > 0)
                                        {
                                            <span class="badge badge-warning">@product.TotalIssues</span>
                                            @if (product.CriticalIssues > 0)
                                            {
                                                <br /><small class="text-danger">@product.CriticalIssues critical</small>
                                            }
                                            else if (product.BlockedIssues > 0)
                                            {
                                                <br /><small class="text-danger">@product.BlockedIssues blocked</small>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">0</span>
                                        }
                                    </td>
                                    <td>
                                        @if (product.TotalActions > 0)
                                        {
                                            <span class="badge badge-primary">@product.TotalActions</span>
                                            @if (product.OverdueActions > 0)
                                            {
                                                <br /><small class="text-danger">@product.OverdueActions overdue</small>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">0</span>
                                        }
                                    </td>
                                    <td>
                                        @if (product.TotalMilestones > 0)
                                        {
                                            <span class="badge badge-success">@product.TotalMilestones</span>
                                            @if (product.OverdueMilestones > 0)
                                            {
                                                <br /><small class="text-danger">@product.OverdueMilestones delayed</small>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">0</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center">No data available</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer">
                <small class="text-muted">
                    <i class="fas fa-info-circle"></i> 
                    Health score: 100 = perfect, 0 = critical. Products are ranked by health score (worst first).
                </small>
            </div>
        </div>

        <!-- Legend -->
        <div class="row">
            <div class="col-xxl-12 col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12">
                <div class="card card-outline card-info">
                    <div class="card-header">
                        <h3 class="card-title">Legend</h3>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-xxl-4 col-xl-4 col-lg-4 col-md-4 col-sm-12 col-12">
                                <h5>Health score calculation</h5>
                                <ul class="list-unstyled">
                                    <li><i class="fas fa-minus text-danger"></i> Open risks: -2 points each</li>
                                    <li><i class="fas fa-minus text-danger"></i> High risks (15+): -5 points each</li>
                                    <li><i class="fas fa-minus text-danger"></i> Open issues: -3 points each</li>
                                    <li><i class="fas fa-minus text-danger"></i> Critical issues: -10 points each</li>
                                    <li><i class="fas fa-minus text-danger"></i> Blocked issues: -8 points each</li>
                                    <li><i class="fas fa-minus text-warning"></i> Overdue actions: -2 points each</li>
                                    <li><i class="fas fa-minus text-warning"></i> Overdue milestones: -5 points each</li>
                                </ul>
                            </div>
                            <div class="col-xxl-4 col-xl-4 col-lg-4 col-md-4 col-sm-12 col-12">
                                <h5>Risk ratings</h5>
                                <ul class="list-unstyled">
                                    <li><span class="badge badge-danger">High</span> Risk score 15-25</li>
                                    <li><span class="badge badge-warning">Medium</span> Risk score 10-14</li>
                                    <li><span class="badge badge-success">Low</span> Risk score 1-9</li>
                                </ul>
                                <h5 class="mt-3">Issue severity</h5>
                                <ul class="list-unstyled">
                                    <li><span class="badge badge-danger">Critical</span> System down or major impact</li>
                                    <li><span class="badge badge-warning">High</span> Significant impact</li>
                                    <li><span class="badge badge-info">Medium</span> Moderate impact</li>
                                    <li><span class="badge badge-secondary">Low</span> Minor impact</li>
                                </ul>
                            </div>
                            <div class="col-xxl-4 col-xl-4 col-lg-4 col-md-4 col-sm-12 col-12">
                                <h5>Health score ranges</h5>
                                <ul class="list-unstyled">
                                    <li><span class="badge badge-success">80-100</span> Good health</li>
                                    <li><span class="badge badge-info">60-79</span> Fair health</li>
                                    <li><span class="badge badge-warning">40-59</span> Needs monitoring</li>
                                    <li><span class="badge badge-danger">20-39</span> Urgent attention required</li>
                                    <li><span class="badge badge-dark">0-19</span> Critical</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

