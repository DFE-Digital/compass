@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
    (function () {
        /* ── Reports nav dropdowns ─────────────────────────────────────────── */
        var navBar = document.querySelector('.reports-nav-bar');
        if (navBar) {
            var toggles = navBar.querySelectorAll('.reports-nav-dropdown-toggle');
            toggles.forEach(function (toggle) {
                var menu = toggle.nextElementSibling;
                if (!menu || !menu.classList.contains('reports-nav-dropdown-menu')) return;
                var hint = menu.nextElementSibling;
                var hasHint = hint && hint.classList.contains('dropdown-scroll-hint');

                function updateScrollHint() {
                    if (!hasHint) return;
                    var canScroll = menu.scrollHeight > menu.clientHeight;
                    var atBottom = menu.scrollTop + menu.clientHeight >= menu.scrollHeight - 4;
                    hint.classList.toggle('visible', canScroll && !atBottom);
                }

                toggle.addEventListener('click', function (e) {
                    e.stopPropagation();
                    var isOpen = menu.classList.contains('open');
                    navBar.querySelectorAll('.reports-nav-dropdown-menu.open').forEach(function (m) {
                        m.classList.remove('open');
                        m.previousElementSibling.setAttribute('aria-expanded', 'false');
                        var h = m.nextElementSibling;
                        if (h && h.classList.contains('dropdown-scroll-hint')) h.classList.remove('visible');
                    });
                    if (!isOpen) {
                        menu.classList.add('open');
                        toggle.setAttribute('aria-expanded', 'true');
                        updateScrollHint();
                    }
                });

                if (hasHint) menu.addEventListener('scroll', updateScrollHint);

                toggle.addEventListener('keydown', function (e) {
                    if (e.key === 'Escape') {
                        menu.classList.remove('open');
                        toggle.setAttribute('aria-expanded', 'false');
                        if (hasHint) hint.classList.remove('visible');
                        toggle.focus();
                    }
                });
            });
            document.addEventListener('click', function () {
                navBar.querySelectorAll('.reports-nav-dropdown-menu.open').forEach(function (m) {
                    m.classList.remove('open');
                    m.previousElementSibling.setAttribute('aria-expanded', 'false');
                    var h = m.nextElementSibling;
                    if (h && h.classList.contains('dropdown-scroll-hint')) h.classList.remove('visible');
                });
            });
        }

        /* ── Filters panel toggle ───────────────────────────────────────────── */
        (function () {
            var toggle = document.getElementById('baFiltersToggle');
            var panel = document.getElementById('baFiltersPanel');
            if (toggle && panel) {
                toggle.addEventListener('click', function () {
                    var expanded = panel.classList.toggle('show');
                    toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
                });
            }
        })();

        /* ── Stat detail modal ─────────────────────────────────────────────── */
        var scopedProjects = @Html.Raw(baProjectsJson);

        var statConfigs = {
            'all':          { label: document.querySelector('[data-stat="all"]')?.getAttribute('data-stat-label') || 'All projects', icon: 'fa-project-diagram', filter: function(p) { return true; } },
            'at-risk':      { label: document.querySelector('[data-stat="at-risk"]')?.getAttribute('data-stat-label') || 'At-risk projects', icon: 'fa-traffic-light', filter: function(p) { return p.rag === 'Red' || p.rag === 'Amber-Red'; } },
            'not-reported': { label: document.querySelector('[data-stat="not-reported"]')?.getAttribute('data-stat-label') || 'Not reported', icon: 'fa-file-alt', filter: function(p) { return p.status === 'Active' && !p.reportedThisMonth; } },
            'flagship':     { label: document.querySelector('[data-stat="flagship"]')?.getAttribute('data-stat-label') || 'Flagship projects', icon: 'fa-star', filter: function(p) { return p.isFlagship; } },
            'high-risk':    { label: document.querySelector('[data-stat="high-risk"]')?.getAttribute('data-stat-label') || 'High risks', icon: 'fa-exclamation-triangle', filter: function(p) { return p.hasHighRisk; } }
        };

        function ragBadgeClass(rag) {
            if (rag === 'Green') return 'badge-green';
            if (rag === 'Amber-Green') return 'badge-amber-green';
            if (rag === 'Amber') return 'badge-amber';
            if (rag === 'Amber-Red') return 'badge-amber-red';
            if (rag === 'Red') return 'badge-red';
            return 'badge-secondary';
        }
        function statusBadgeClass(s) {
            if (s === 'Active') return 'badge-success';
            if (s === 'Paused') return 'badge-warning';
            if (s === 'Completed') return 'badge-primary';
            if (s === 'Cancelled') return 'badge-danger';
            return 'badge-secondary';
        }
        function escHtml(s) {
            return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        function renderStatModal(filter, label, icon) {
            var filtered = scopedProjects.filter(filter);
            var html = '';
            filtered.forEach(function(p) {
                html += '<tr><td><a href="' + p.url + '" class="project-link font-weight-bold">' + escHtml(p.title) + '</a>' +
                    (p.isFlagship ? ' <span class="badge badge-warning ml-1" title="Flagship"><i class="fas fa-star"></i></span>' : '') +
                    '</td><td><span class="badge ' + ragBadgeClass(p.rag) + '">' + escHtml(p.rag) + '</span></td>' +
                    '<td><span class="badge ' + statusBadgeClass(p.status) + '">' + escHtml(p.status || '–') + '</span></td>' +
                    '<td><span class="text-muted small">' + escHtml(p.phase || '–') + '</span></td>' +
                    '<td><span class="text-muted small">' + escHtml(p.businessArea || '–') + '</span></td>' +
                    '<td><a href="' + p.url + '" class="section-link">View <i class="fas fa-arrow-right"></i></a></td></tr>';
            });
            document.getElementById('statDetailProjectsList').innerHTML = html;
            document.getElementById('statDetailModalTitle').textContent = label;
            document.getElementById('statDetailModalIcon').className = 'fas ' + icon + ' mr-2';
            document.getElementById('statDetailCount').textContent = filtered.length + ' project' + (filtered.length !== 1 ? 's' : '');
            document.getElementById('statDetailEmpty').style.display = filtered.length === 0 ? '' : 'none';
            document.getElementById('statDetailSearch').value = '';
        }

        document.querySelectorAll('[data-stat]').forEach(function(card) {
            card.addEventListener('click', function() {
                var key = card.getAttribute('data-stat');
                var cfg = statConfigs[key];
                if (!cfg) return;
                renderStatModal(cfg.filter, cfg.label, cfg.icon);
                $('#statDetailModal').modal('show');
            });
        });

        document.getElementById('statDetailSearch').addEventListener('input', function() {
            var q = this.value.toLowerCase();
            var rows = document.querySelectorAll('#statDetailProjectsList tr');
            var visible = 0;
            rows.forEach(function(row) {
                var show = !q || row.textContent.toLowerCase().indexOf(q) !== -1;
                row.style.display = show ? '' : 'none';
                if (show) visible++;
            });
            document.getElementById('statDetailEmpty').style.display = visible === 0 ? '' : 'none';
            document.getElementById('statDetailCount').textContent = visible + ' project' + (visible !== 1 ? 's' : '');
        });

        /* ── RAG detail modal ──────────────────────────────────────────────── */
        var ragHeaderColors = {
            'Green': '#1e7e34', 'Amber-Green': '#856404', 'Amber': '#856404',
            'Amber-Red': '#c0392b', 'Red': '#721c24'
        };
        document.querySelectorAll('.rag-detail-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var project = btn.getAttribute('data-project') || '';
                var rag = btn.getAttribute('data-rag') || 'Not set';
                var justification = btn.getAttribute('data-justification') || '';
                var path = btn.getAttribute('data-path') || '';
                var projectLink = btn.closest('tr')?.querySelector('a.project-link')?.getAttribute('href') || '#';

                document.getElementById('ragDetailProjectName').textContent = project;
                var badge = document.getElementById('ragDetailBadge');
                badge.className = 'badge badge ' + ragBadgeClass(rag);
                badge.textContent = rag;

                var header = document.getElementById('ragDetailModalHeader');
                header.style.background = ragHeaderColors[rag] || '#6c757d';
                header.style.color = '#fff';

                var justBlock = document.getElementById('ragJustificationBlock');
                var justText = document.getElementById('ragDetailJustification');
                if (justification) {
                    justText.textContent = justification;
                    justBlock.style.display = '';
                } else {
                    justBlock.style.display = 'none';
                }

                var pathBlock = document.getElementById('ragPathToGreenBlock');
                var pathText = document.getElementById('ragDetailPathToGreen');
                if (path && rag !== 'Green') {
                    pathText.textContent = path;
                    pathBlock.style.display = '';
                } else {
                    pathBlock.style.display = 'none';
                }

                document.getElementById('ragDetailProjectLink').href = projectLink;
            });
        });

        /* ── Flag detail modal ─────────────────────────────────────────────── */
        document.querySelectorAll('.flag-detail-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var project = btn.getAttribute('data-project') || '';
                var flag = btn.getAttribute('data-flag') || '';
                var projectLink = btn.closest('tr')?.querySelector('a.project-link')?.getAttribute('href') || '#';

                document.getElementById('flagDetailProjectName').textContent = project;
                document.getElementById('flagDetailProjectLink').href = projectLink;

                var icon = document.getElementById('flagDetailIcon');
                var title = document.getElementById('flagDetailTitle');
                var desc = document.getElementById('flagDetailDescription');

                if (flag === 'flagship') {
                    icon.className = 'fas fa-star mr-2 text-warning';
                    title.textContent = 'Flagship project';
                    desc.textContent = 'This project has been designated as a flagship project. Flagship projects are high-visibility, strategically important deliverables that receive additional scrutiny and support.';
                } else if (flag === 'multi-dept') {
                    icon.className = 'fas fa-globe mr-2 text-info';
                    title.textContent = 'Multi-department project';
                    var depts = btn.getAttribute('data-other-depts') || '';
                    desc.textContent = 'This project involves collaboration across multiple government departments.' + (depts ? ' Other departments: ' + depts : '');
                }
            });
        });
    }());
    </script>
}
