@using Compass.Models
@{
    ViewData["Title"] = ViewBag.SelectedBusinessArea != null ? $"{((BusinessAreaLookup)ViewBag.SelectedBusinessArea).Name} – business area report" : "Business area report";
    ViewData["BodyClass"] = "reports-page";
    var availableBusinessAreas = ViewBag.AvailableBusinessAreas as List<BusinessAreaLookup> ?? new List<BusinessAreaLookup>();
    var allDivisions = ViewBag.AllDivisions as List<Division> ?? new List<Division>();
    var allBusinessAreas = ViewBag.AllBusinessAreas as List<BusinessAreaLookup> ?? availableBusinessAreas;
    var selectedBa = ViewBag.SelectedBusinessArea as BusinessAreaLookup;
    var projects = ViewBag.Projects as List<Project> ?? new List<Project>();
    var projectCount = ViewBag.ProjectCount as int? ?? 0;
    var ragBreakdown = ViewBag.RagBreakdown as Dictionary<string, int> ?? new Dictionary<string, int>();
    var phaseBreakdown = ViewBag.PhaseBreakdown as Dictionary<string, int> ?? new Dictionary<string, int>();
    var submittedThisMonth = ViewBag.SubmittedThisMonth as int? ?? 0;
    var monthName = ViewBag.MonthName as string ?? "";
    var leadershipAssignments = ViewBag.LeadershipAssignments as List<UserBusinessAreaRoleAssignment> ?? new List<UserBusinessAreaRoleAssignment>();
    var accessibilityIssues = ViewBag.AccessibilityIssues as List<AccessibilityIssue> ?? new List<AccessibilityIssue>();
    var flagshipCount = ViewBag.FlagshipCount as int? ?? 0;
    var multiDeptCount = ViewBag.MultiDeptCount as int? ?? 0;
    var highRiskCount = ViewBag.HighRiskCount as int? ?? 0;
    var highIssueCount = ViewBag.HighIssueCount as int? ?? 0;
    var isAdmin = ViewBag.IsAdmin as bool? ?? false;

    var redCount = ragBreakdown.GetValueOrDefault("Red", 0);
    var amberRedCount = ragBreakdown.GetValueOrDefault("Amber-Red", 0);
    var amberCount = ragBreakdown.GetValueOrDefault("Amber", 0);
    var greenCount = ragBreakdown.GetValueOrDefault("Green", 0);
    var amberGreenCount = ragBreakdown.GetValueOrDefault("Amber-Green", 0);
    var atRiskCount = redCount + amberRedCount;
    var reportingPct = projectCount > 0 ? (int)Math.Round(submittedThisMonth * 100.0 / projectCount) : 0;
    var openAccessibilityIssues = accessibilityIssues.Count(i => i.Status != "resolved" && i.Status != "wont_fix");
    var displayScopeName = selectedBa?.Name ?? "All business areas";
    var productsForBusinessArea = ViewBag.ProductsForBusinessArea as List<ProductDto> ?? new List<ProductDto>();
    var filteredProjectCount = ViewBag.FilteredProjectCount as int? ?? projectCount;
    var projectPage = ViewBag.ProjectPage as int? ?? 1;
    var projectPageSize = ViewBag.ProjectPageSize as int? ?? 15;
    var projectTotalPages = ViewBag.ProjectTotalPages as int? ?? 1;
    var projectStatus = ViewBag.ProjectStatus as string;
    var projectPhase = ViewBag.ProjectPhase as string;
    var projectRag = ViewBag.ProjectRag as string;
    var projectDivision = ViewBag.ProjectDivision as string;
    var projectBusinessArea = ViewBag.ProjectBusinessArea as string;
    var projectSearch = ViewBag.ProjectSearch as string;
    var projectDivisionNames = ViewBag.ProjectDivisionNames as List<string> ?? new List<string>();
    var projectPhaseNames = ViewBag.ProjectPhaseNames as List<string> ?? new List<string>();
    var projectRagNames = ViewBag.ProjectRagNames as List<string> ?? new List<string>();
    var projectStatusNames = ViewBag.ProjectStatusNames as List<string> ?? new List<string>();
    var filteredProductCount = ViewBag.FilteredProductCount as int? ?? productsForBusinessArea.Count;
    var productPage = ViewBag.ProductPage as int? ?? 1;
    var productPageSize = ViewBag.ProductPageSize as int? ?? 15;
    var productTotalPages = ViewBag.ProductTotalPages as int? ?? 1;
    var productPhaseFilter = ViewBag.ProductPhase as string;
    var productBusinessAreaFilter = ViewBag.ProductBusinessArea as string;
    var productSearchFilter = ViewBag.ProductSearch as string;
    var productPhaseNames = ViewBag.ProductPhaseNames as List<string> ?? new List<string>();
    var productBusinessAreaNames = ViewBag.ProductBusinessAreaNames as List<string> ?? new List<string>();
    var allFilteredProjectsForModal = ViewBag.AllFilteredProjectsForModal as List<Project> ?? projects;
    var hasActiveFilters = !string.IsNullOrWhiteSpace(projectStatus) || !string.IsNullOrWhiteSpace(projectPhase) || !string.IsNullOrWhiteSpace(projectRag) || !string.IsNullOrWhiteSpace(projectDivision) || !string.IsNullOrWhiteSpace(projectBusinessArea) || !string.IsNullOrWhiteSpace(projectSearch) || !string.IsNullOrWhiteSpace(productPhaseFilter) || !string.IsNullOrWhiteSpace(productBusinessAreaFilter) || !string.IsNullOrWhiteSpace(productSearchFilter);
}

@functions {
    string GetRagBadgeClass(RagStatusLookup? ragStatusLookup, string? ragStatusStr = null)
    {
        if (ragStatusLookup != null && !string.IsNullOrEmpty(ragStatusLookup.CssClass))
            return ragStatusLookup.CssClass;
        var name = ragStatusLookup?.Name?.Trim();
        if (string.IsNullOrEmpty(name))
            name = ragStatusStr?.Trim().Replace(" / ", "-").Replace("/", "-").Replace(" /", "-").Replace("/ ", "-");
        return name switch
        {
            "Green"       => "badge badge-green",
            "Amber-Green" => "badge badge-amber-green",
            "Amber"       => "badge badge-amber",
            "Amber-Red"   => "badge badge-amber-red",
            "Red"         => "badge badge-red",
            _             => "badge badge-secondary"
        };
    }
    string GetRagDisplayName(RagStatusLookup? ragStatusLookup, string? ragStatusStr = null)
    {
        if (ragStatusLookup != null && !string.IsNullOrEmpty(ragStatusLookup.Name))
            return ragStatusLookup.Name;
        if (!string.IsNullOrEmpty(ragStatusStr))
            return ragStatusStr.Trim().Replace(" / ", "-").Replace("/", "-");
        return "Not set";
    }
    string GetRagRowClass(RagStatusLookup? ragStatusLookup, string? ragStatusStr = null)
    {
        var name = ragStatusLookup?.Name?.Trim() ?? ragStatusStr?.Trim() ?? "";
        return name switch
        {
            "Red"       => "table-danger",
            "Amber-Red" => "table-warning",
            _           => ""
        };
    }
    string GetStatusBadgeClass(string? status)
    {
        return (status ?? "") switch
        {
            "Active" => "badge badge-success",
            "Paused" => "badge badge-warning",
            "Completed" => "badge badge-primary",
            "Cancelled" => "badge badge-danger",
            _ => "badge badge-secondary"
        };
    }
    string GetLeadershipRoleLabel(LeadershipRoleTier role)
    {
        return role switch
        {
            LeadershipRoleTier.PortfolioLead => "Portfolio lead",
            LeadershipRoleTier.HeadOfProfession => "Head of profession",
            LeadershipRoleTier.DeputyDirectorOrSro => "Deputy director / SRO",
            LeadershipRoleTier.CLevel => "C-level",
            LeadershipRoleTier.DirectorGeneral => "Director general",
            LeadershipRoleTier.PermanentSecretary => "Permanent secretary",
            _ => role.ToString()
        };
    }
}

@await Html.PartialAsync("_DashboardStyles")
@await Html.PartialAsync("_ReportsDashboardStyles")

<!-- Dashboard header -->
<div class="reports-dashboard-header">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div>
            <nav aria-label="Breadcrumb" class="reports-breadcrumb">
                <a href="/">Home</a> <span aria-hidden="true">/</span>
                <a href="@Url.Action("Index", "Reports")">Reports overview</a> <span aria-hidden="true">/</span>
                Business area report
            </nav>
            <h1 class="mb-1"><i class="fas fa-building mr-2" aria-hidden="true"></i>
                @displayScopeName
            </h1>
            <p class="mb-0 opacity-90">Granular view of projects, products, and leadership for this business area</p>
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <button class="btn btn-intel" data-toggle="modal" data-target="#intelModal" title="Portfolio intelligence summary">
                <i class="fas fa-brain mr-1" aria-hidden="true"></i> Intel
            </button>
            <a href="https://app.powerbi.com/groups/me/reports/d941d6dd-6d6a-40b1-bf66-12ad51522131/ce0a78d00040090301b6?experience=power-bi" target="_blank" rel="noopener noreferrer" class="btn btn-powerbi">
                <i class="fas fa-external-link-alt mr-1" aria-hidden="true"></i> Standards (SHCA)
            </a>
        </div>
    </div>
</div>

<!-- Report navigation tabs -->
<div class="reports-nav-bar">
    <ul class="reports-nav-tabs" role="navigation" aria-label="Report sections">
            <li><a href="@Url.Action("Index", "Reports")"><i class="fas fa-globe mr-1" aria-hidden="true"></i>Overview</a></li>
            <li class="reports-nav-dropdown">
                <button class="reports-nav-dropdown-toggle" aria-haspopup="true" aria-expanded="false">
                    <i class="fas fa-sitemap mr-1" aria-hidden="true"></i>Division
                    <i class="fas fa-chevron-down caret-icon ml-1" aria-hidden="true"></i>
                </button>
                <div class="reports-nav-dropdown-menu" role="menu">
                    <a href="@Url.Action("DivisionReport", "Reports")" role="menuitem">
                        <i class="fas fa-th-list mr-1 text-muted" aria-hidden="true"></i>All divisions
                    </a>
                    @if (allDivisions.Any())
                    {
                        <div class="dropdown-divider"></div>
                        @foreach (var div in allDivisions)
                        {
                            <a href="@Url.Action("DivisionReport", "Reports", new { divisionId = div.Id })" role="menuitem">@div.Name</a>
                        }
                    }
                </div>
                <div class="dropdown-scroll-hint" aria-hidden="true"><i class="fas fa-chevron-down"></i></div>
            </li>
            <li class="reports-nav-dropdown">
                <button class="reports-nav-dropdown-toggle active" aria-haspopup="true" aria-expanded="false" aria-current="page">
                    <i class="fas fa-building mr-1" aria-hidden="true"></i>Business area
                    <i class="fas fa-chevron-down caret-icon ml-1" aria-hidden="true"></i>
                </button>
                <div class="reports-nav-dropdown-menu" role="menu">
                    <a href="@Url.Action("BusinessAreaReport", "Reports")"
                       class="@(selectedBa == null ? "active" : "")"
                       role="menuitem">
                        <i class="fas fa-th-list mr-1 text-muted" aria-hidden="true"></i>All business areas
                    </a>
                    <div class="dropdown-divider"></div>
                    @foreach (var ba in availableBusinessAreas)
                    {
                        <a href="@Url.Action("BusinessAreaReport", "Reports", new { businessAreaId = ba.Id })"
                           class="@(selectedBa?.Id == ba.Id ? "active" : "")"
                           role="menuitem">@ba.Name</a>
                    }
                </div>
                <div class="dropdown-scroll-hint" aria-hidden="true"><i class="fas fa-chevron-down"></i></div>
            </li>
            <li><a href="@Url.Action("PriorityOutcomes", "Reports")"><i class="fas fa-star mr-1" aria-hidden="true"></i>Priority outcomes</a></li>
            <li><a href="@Url.Action("PerformanceReporting", "Reports")"><i class="fas fa-chart-line mr-1" aria-hidden="true"></i>Performance reporting</a></li>
        </ul>
</div>

<div class="reports-body">

        @if (selectedBa == null && !projects.Any())
        {
            <div class="alert alert-info">No business area selected. Please choose one from the tabs above.</div>
        }
        else
        {
            <!-- Stat cards -->
            <div class="reports-stat-grid mb-4">
                <button type="button" class="reports-stat-card reports-stat-blue" data-stat="all" data-stat-label="All projects in @displayScopeName">
                    <div class="reports-stat-icon"><i class="fas fa-project-diagram" aria-hidden="true"></i></div>
                    <div class="reports-stat-value">@projectCount</div>
                    <div class="reports-stat-label">Projects</div>
                    <div class="reports-stat-sub">in @displayScopeName</div>
                </button>
                <button type="button" class="reports-stat-card @(atRiskCount > 0 ? "reports-stat-red" : "reports-stat-green")" data-stat="at-risk" data-stat-label="At-risk projects in @displayScopeName">
                    <div class="reports-stat-icon"><i class="fas fa-traffic-light" aria-hidden="true"></i></div>
                    <div class="reports-stat-value">@atRiskCount</div>
                    <div class="reports-stat-label">At risk</div>
                    <div class="reports-stat-sub">@greenCount green, @amberCount amber</div>
                </button>
                <button type="button" class="reports-stat-card @(reportingPct >= 80 ? "reports-stat-green" : reportingPct >= 50 ? "reports-stat-amber" : "reports-stat-red")" data-stat="not-reported" data-stat-label="Projects not yet reported – @monthName">
                    <div class="reports-stat-icon"><i class="fas fa-file-alt" aria-hidden="true"></i></div>
                    <div class="reports-stat-value">@reportingPct<span style="font-size:1.2rem">%</span></div>
                    <div class="reports-stat-label">Monthly reporting</div>
                    <div class="reports-stat-sub">@submittedThisMonth of @projectCount – @monthName</div>
                </button>
                <div class="reports-stat-card @(openAccessibilityIssues > 0 ? "reports-stat-amber" : "reports-stat-green")">
                    <div class="reports-stat-icon"><i class="fas fa-universal-access" aria-hidden="true"></i></div>
                    <div class="reports-stat-value">@openAccessibilityIssues</div>
                    <div class="reports-stat-label">Open accessibility issues</div>
                    <div class="reports-stat-sub">across business area projects</div>
                </div>
                <button type="button" class="reports-stat-card reports-stat-purple" data-stat="flagship" data-stat-label="Flagship projects in @displayScopeName">
                    <div class="reports-stat-icon"><i class="fas fa-star" aria-hidden="true"></i></div>
                    <div class="reports-stat-value">@flagshipCount</div>
                    <div class="reports-stat-label">Flagship projects</div>
                    <div class="reports-stat-sub">@multiDeptCount multi-department</div>
                </button>
                <button type="button" class="reports-stat-card @(highRiskCount > 0 ? "reports-stat-red" : "reports-stat-green")" data-stat="high-risk" data-stat-label="Projects with high risks in @displayScopeName">
                    <div class="reports-stat-icon"><i class="fas fa-exclamation-triangle" aria-hidden="true"></i></div>
                    <div class="reports-stat-value">@highRiskCount</div>
                    <div class="reports-stat-label">Projects with high risks</div>
                    <div class="reports-stat-sub">@highIssueCount with high-priority issues</div>
                </button>
            </div>

            <div class="row">
                <!-- Main content -->
                <div class="col-lg-8">

                    <!-- RAG bar -->
                    <div class="dashboard-section mb-4">
                        <div class="dashboard-section-header">
                            <h2><i class="fas fa-traffic-light" aria-hidden="true"></i>RAG status breakdown</h2>
                        </div>
                        @{
                            var ragTotal = ragBreakdown.Values.Sum();
                            if (ragTotal == 0) ragTotal = 1;
                        }
                        @{
                            var baRagOrder = new[] { "Green", "Amber-Green", "Amber", "Amber-Red", "Red", "Not set" };
                            var baSwatchClass = new Dictionary<string, string> {
                                ["Green"] = "rag-swatch-green", ["Amber-Green"] = "rag-swatch-amber-green",
                                ["Amber"] = "rag-swatch-amber", ["Amber-Red"] = "rag-swatch-amber-red",
                                ["Red"] = "rag-swatch-red", ["Not set"] = "rag-swatch-unknown"
                            };
                            var baSegClass = new Dictionary<string, string> {
                                ["Green"] = "rag-green", ["Amber-Green"] = "rag-amber-green",
                                ["Amber"] = "rag-amber", ["Amber-Red"] = "rag-amber-red",
                                ["Red"] = "rag-red", ["Not set"] = "rag-unknown"
                            };
                        }
                        <div class="rag-stacked-bar mb-2" role="img" aria-label="RAG status bar">
                            @foreach (var key in baRagOrder)
                            {
                                if (!ragBreakdown.ContainsKey(key) || ragBreakdown[key] == 0) continue;
                                var cnt = ragBreakdown[key];
                                var pct = cnt * 100.0 / ragTotal;
                                <div class="rag-segment @baSegClass.GetValueOrDefault(key, "rag-unknown")" style="width:@(pct.ToString("F1"))%">
                                    @if (pct > 10) { <span aria-hidden="true">@cnt</span> }
                                </div>
                            }
                        </div>
                        <div class="rag-legend" role="list" aria-label="RAG status key">
                            @foreach (var key in baRagOrder)
                            {
                                if (!ragBreakdown.ContainsKey(key) || ragBreakdown[key] == 0) continue;
                                <span class="rag-legend-item" role="listitem">
                                    <span class="rag-swatch @baSwatchClass.GetValueOrDefault(key, "rag-swatch-unknown")" aria-hidden="true"></span>
                                    <span>@key</span> <strong>@ragBreakdown[key]</strong>
                                </span>
                            }
                        </div>
                    </div>

                    <!-- Expandable filters -->
                    <div class="dashboard-section mb-4">
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="baFiltersToggle" aria-expanded="@(hasActiveFilters ? "true" : "false")" aria-controls="baFiltersPanel">
                                <i class="fas fa-filter mr-1" aria-hidden="true"></i> Filters
                                @if (hasActiveFilters)
                                {
                                    <span class="badge badge-primary ml-1">Active</span>
                                }
                            </button>
                            @if (hasActiveFilters)
                            {
                                <a href="@Url.Action("BusinessAreaReport", "Reports", new { businessAreaId = selectedBa?.Id })" class="btn btn-link btn-sm text-muted">Clear all filters</a>
                            }
                        </div>
                        <div id="baFiltersPanel" class="collapse mt-3 @(hasActiveFilters ? "show" : "")" aria-labelledby="baFiltersToggle">
                            <form method="get" action="@Url.Action("BusinessAreaReport", "Reports")" class="card card-body bg-light">
                                @if (selectedBa != null)
                                {
                                    <input type="hidden" name="businessAreaId" value="@selectedBa.Id" />
                                }
                                <input type="hidden" name="projectPage" value="1" />
                                <input type="hidden" name="productPage" value="1" />
                                <input type="hidden" name="projectPageSize" value="@projectPageSize" />
                                <input type="hidden" name="productPageSize" value="@productPageSize" />
                                <div class="row">
                                    <div class="col-md-6">
                                        <h6 class="text-muted mb-2"><i class="fas fa-project-diagram mr-1"></i> Projects</h6>
                                        <div class="form-row">
                                            <div class="form-group col-6 col-sm-4">
                                                <label class="small mb-0">Status</label>
                                                <select name="projectStatus" class="form-control form-control-sm">
                                                    <option value="">All</option>
                                                    @foreach (var s in projectStatusNames)
                                                    {
                                                        <option value="@s" selected="@(s == projectStatus)">@s</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="form-group col-6 col-sm-4">
                                                <label class="small mb-0">Phase</label>
                                                <select name="projectPhase" class="form-control form-control-sm">
                                                    <option value="">All</option>
                                                    @foreach (var ph in projectPhaseNames)
                                                    {
                                                        <option value="@ph" selected="@(ph == projectPhase)">@ph</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="form-group col-6 col-sm-4">
                                                <label class="small mb-0">RAG</label>
                                                <select name="projectRag" class="form-control form-control-sm">
                                                    <option value="">All</option>
                                                    @foreach (var r in projectRagNames)
                                                    {
                                                        <option value="@r" selected="@(r == projectRag)">@r</option>
                                                    }
                                                </select>
                                            </div>
                                            <div class="form-group col-6 col-sm-4">
                                                <label class="small mb-0">Division</label>
                                                <select name="projectDivision" class="form-control form-control-sm">
                                                    <option value="">All</option>
                                                    @foreach (var d in projectDivisionNames)
                                                    {
                                                        <option value="@d" selected="@(d == projectDivision)">@d</option>
                                                    }
                                                </select>
                                            </div>
                                            @if (selectedBa == null)
                                            {
                                                <div class="form-group col-6 col-sm-4">
                                                    <label class="small mb-0">Business area</label>
                                                    <select name="projectBusinessArea" class="form-control form-control-sm">
                                                        <option value="">All</option>
                                                        @foreach (var ba in allBusinessAreas)
                                                        {
                                                            <option value="@ba.Name" selected="@(ba.Name == projectBusinessArea)">@ba.Name</option>
                                                        }
                                                    </select>
                                                </div>
                                            }
                                            <div class="form-group col-12 col-sm-4">
                                                <label class="small mb-0">Search</label>
                                                <input type="text" name="projectSearch" class="form-control form-control-sm" placeholder="Project name or code" value="@projectSearch" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <h6 class="text-muted mb-2"><i class="fas fa-box-open mr-1"></i> Products</h6>
                                        <div class="form-row">
                                            <div class="form-group col-6 col-sm-4">
                                                <label class="small mb-0">Phase</label>
                                                <select name="productPhase" class="form-control form-control-sm">
                                                    <option value="">All</option>
                                                    @foreach (var ph in productPhaseNames)
                                                    {
                                                        <option value="@ph" selected="@(ph == productPhaseFilter)">@ph</option>
                                                    }
                                                </select>
                                            </div>
                                            @if (selectedBa == null && productBusinessAreaNames.Any())
                                            {
                                                <div class="form-group col-6 col-sm-4">
                                                    <label class="small mb-0">Business area</label>
                                                    <select name="productBusinessArea" class="form-control form-control-sm">
                                                        <option value="">All</option>
                                                        @foreach (var ba in productBusinessAreaNames)
                                                        {
                                                            <option value="@ba" selected="@(ba == productBusinessAreaFilter)">@ba</option>
                                                        }
                                                    </select>
                                                </div>
                                            }
                                            <div class="form-group col-12 col-sm-4">
                                                <label class="small mb-0">Search</label>
                                                <input type="text" name="productSearch" class="form-control form-control-sm" placeholder="Product name or FIPS ID" value="@productSearchFilter" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="mt-2">
                                    <button type="submit" class="btn btn-primary btn-sm">Apply filters</button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <!-- Projects table -->
                    <div class="dashboard-section mb-4">
                        <div class="dashboard-section-header d-flex flex-wrap align-items-center justify-content-between gap-2">
                            <h2 class="mb-0"><i class="fas fa-list" aria-hidden="true"></i> Projects (@filteredProjectCount@(filteredProjectCount != projectCount ? " of " + projectCount : ""))</h2>
                            <div class="d-flex align-items-center gap-2">
                                <form method="get" action="@Url.Action("BusinessAreaReport", "Reports")" class="d-inline" id="projectPageSizeForm">
                                    @if (selectedBa != null) { <input type="hidden" name="businessAreaId" value="@selectedBa.Id" /> }
                                    <input type="hidden" name="projectPage" value="1" />
                                    <input type="hidden" name="productPage" value="@productPage" />
                                    <input type="hidden" name="projectStatus" value="@projectStatus" />
                                    <input type="hidden" name="projectPhase" value="@projectPhase" />
                                    <input type="hidden" name="projectRag" value="@projectRag" />
                                    <input type="hidden" name="projectDivision" value="@projectDivision" />
                                    <input type="hidden" name="projectBusinessArea" value="@projectBusinessArea" />
                                    <input type="hidden" name="projectSearch" value="@projectSearch" />
                                    <input type="hidden" name="productPageSize" value="@productPageSize" />
                                    <input type="hidden" name="productPhase" value="@productPhaseFilter" />
                                    <input type="hidden" name="productBusinessArea" value="@productBusinessAreaFilter" />
                                    <input type="hidden" name="productSearch" value="@productSearchFilter" />
                                    <label class="small mb-0 mr-1">Show</label>
                                    <select name="projectPageSize" class="form-control form-control-sm d-inline-block" style="width:auto;" onchange="this.form.submit()">
                                        @foreach (var size in new[] { 10, 15, 25, 50 })
                                        {
                                            <option value="@size" selected="@(projectPageSize == size)">@size</option>
                                        }
                                    </select>
                                    <span class="small ml-1">per page</span>
                                </form>
                            </div>
                        </div>
                        @if (projects.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover reports-table" id="baProjectsTable">
                                    <thead>
                                        <tr>
                                            <th>Project</th>
                                            <th>Status</th>
                                            @if (selectedBa == null)
                                            {
                                                <th>Business area</th>
                                            }
                                            <th>Division</th>
                                            <th>Phase</th>
                                            <th>RAG</th>
                                            <th>Flags</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var project in projects)
                                        {
                                            var rowClass = GetRagRowClass(project.RagStatusLookup, project.RagStatus);
