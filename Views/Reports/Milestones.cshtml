@model List<Compass.Models.Milestone>
@{
    ViewData["Title"] = "Milestones report";
    var groupBy = ViewBag.GroupBy as string ?? "status";
    var products = ViewBag.Products as List<Compass.Models.ProductDto> ?? new List<Compass.Models.ProductDto>();
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Milestones report</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <!-- Summary Cards -->
        <div class="row mb-3">
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-info">
                    <div class="inner">
                        <h3>@ViewBag.TotalMilestones</h3>
                        <p>Total milestones</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-flag-checkered"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-success">
                    <div class="inner">
                        <h3>@ViewBag.CompleteMillestones</h3>
                        <p>Complete</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-primary">
                    <div class="inner">
                        <h3>@ViewBag.OnTrackMilestones</h3>
                        <p>On track</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-thumbs-up"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-warning">
                    <div class="inner">
                        <h3>@ViewBag.AtRiskMilestones</h3>
                        <p>At risk</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-danger">
                    <div class="inner">
                        <h3>@ViewBag.DelayedMilestones</h3>
                        <p>Delayed</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-exclamation-circle"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-dark">
                    <div class="inner">
                        <h3>@ViewBag.OverdueMilestones</h3>
                        <p>Overdue</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-clock"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Grouping Options -->
        <div class="row mb-3">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Group by</h5>
                    </div>
                    <div class="card-body">
                        <div class="btn-group" role="group">
                            <a href="@Url.Action("Milestones", new { groupBy = "status" })" class="btn btn-@(groupBy == "status" ? "primary" : "outline-primary")">
                                <i class="fas fa-flag"></i> Status
                            </a>
                            <a href="@Url.Action("Milestones", new { groupBy = "business-area" })" class="btn btn-@(groupBy == "business-area" ? "primary" : "outline-primary")">
                                <i class="fas fa-building"></i> Business area
                            </a>
                            <a href="@Url.Action("Milestones", new { groupBy = "product" })" class="btn btn-@(groupBy == "product" ? "primary" : "outline-primary")">
                                <i class="fas fa-box"></i> Product
                            </a>
                            <a href="@Url.Action("Milestones", new { groupBy = "quarter" })" class="btn btn-@(groupBy == "quarter" ? "primary" : "outline-primary")">
                                <i class="fas fa-calendar-alt"></i> Quarter
                            </a>
                            <a href="@Url.Action("Milestones", new { groupBy = "owner" })" class="btn btn-@(groupBy == "owner" ? "primary" : "outline-primary")">
                                <i class="fas fa-user"></i> Owner
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Grouped Results -->
        @if (groupBy == "status")
        {
            var grouped = Model.GroupBy(m => m.Status ?? "unknown")
                .OrderBy(g => g.Key == "delayed" ? 0 : g.Key == "at_risk" ? 1 : g.Key == "on_track" ? 2 : 3);
            
            <div class="row">
                @foreach (var group in grouped)
                {
                    var badgeClass = group.Key == "complete" ? "success" : group.Key == "on_track" ? "primary" : group.Key == "at_risk" ? "warning" : group.Key == "delayed" ? "danger" : "secondary";
                    
                    <div class="col-xxl-3 col-xl-4 col-lg-6 col-md-6 col-sm-12 col-12 mb-3">
                        <div class="card">
                            <div class="card-header bg-@badgeClass text-white">
                                <h5 class="card-title mb-0 text-capitalize">@group.Key.Replace("_", " ")</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Total: @group.Count()</strong></p>
                                <ul class="list-unstyled mb-0">
                                    <li><i class="fas fa-clock text-warning"></i> @group.Count(m => m.DueDate < DateTime.Today && m.Status != "complete" && m.Status != "cancelled") Overdue</li>
                                    <li><i class="fas fa-percentage text-info"></i> Avg progress: @(group.Any() ? Math.Round(group.Average(m => m.ProgressPercent ?? 0), 1) : 0)%</li>
                                </ul>
                                <button class="btn btn-sm btn-outline-primary mt-2" onclick="showGroupMilestones('@group.Key', 'status')">View milestones</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (groupBy == "business-area")
        {
            var grouped = Model.GroupBy(m => string.IsNullOrEmpty(m.BusinessArea) ? "Unspecified" : m.BusinessArea)
                .OrderBy(g => g.Key);
            
            <div class="row">
                @foreach (var group in grouped)
                {
                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-12 col-sm-12 col-12 mb-3">
                        <div class="card">
                            <div class="card-header bg-primary text-white">
                                <h5 class="card-title mb-0">@group.Key</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Total: @group.Count()</strong></p>
                                <ul class="list-unstyled mb-0">
                                    <li><span class="badge badge-success">@group.Count(m => m.Status == "complete")</span> Complete</li>
                                    <li><span class="badge badge-primary">@group.Count(m => m.Status == "on_track")</span> On track</li>
                                    <li><span class="badge badge-warning">@group.Count(m => m.Status == "at_risk")</span> At risk</li>
                                    <li><span class="badge badge-danger">@group.Count(m => m.Status == "delayed")</span> Delayed</li>
                                </ul>
                                <button class="btn btn-sm btn-outline-primary mt-2" onclick="showGroupMilestones('@group.Key', 'business-area')">View milestones</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (groupBy == "product")
        {
            var grouped = Model.GroupBy(m => m.FipsId ?? "No product").OrderBy(g => g.Key);
            
            <div class="row">
                @foreach (var group in grouped)
                {
                    var product = products.FirstOrDefault(p => p.FipsId == group.Key);
                    var displayName = product?.Title ?? group.Key;
                    
                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-12 col-sm-12 col-12 mb-3">
                        <div class="card">
                            <div class="card-header bg-info text-white">
                                <h5 class="card-title mb-0">@displayName</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Total: @group.Count()</strong></p>
                                <ul class="list-unstyled mb-0">
                                    <li><span class="badge badge-success">@group.Count(m => m.Status == "complete")</span> Complete</li>
                                    <li><span class="badge badge-primary">@group.Count(m => m.Status == "on_track")</span> On track</li>
                                    <li><span class="badge badge-warning">@group.Count(m => m.Status == "at_risk")</span> At risk</li>
                                    <li><span class="badge badge-danger">@group.Count(m => m.Status == "delayed")</span> Delayed</li>
                                </ul>
                                <button class="btn btn-sm btn-outline-primary mt-2" onclick="showGroupMilestones('@group.Key', 'product')">View milestones</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (groupBy == "quarter")
        {
            var grouped = Model.GroupBy(m => {
                var year = m.DueDate.Year;
                var quarter = (m.DueDate.Month - 1) / 3 + 1;
                return $"Q{quarter} {year}";
            }).OrderBy(g => g.Key);
            
            <div class="row">
                @foreach (var group in grouped)
                {
                    <div class="col-xxl-3 col-xl-4 col-lg-6 col-md-6 col-sm-12 col-12 mb-3">
                        <div class="card">
                            <div class="card-header bg-secondary text-white">
                                <h5 class="card-title mb-0">@group.Key</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Total: @group.Count()</strong></p>
                                <ul class="list-unstyled mb-0">
                                    <li><span class="badge badge-success">@group.Count(m => m.Status == "complete")</span> Complete</li>
                                    <li><span class="badge badge-warning">@group.Count(m => m.Status == "at_risk" || m.Status == "delayed")</span> At risk/Delayed</li>
                                    <li><i class="fas fa-percentage text-info"></i> Avg progress: @(group.Any() ? Math.Round(group.Average(m => m.ProgressPercent ?? 0), 1) : 0)%</li>
                                </ul>
                                <button class="btn btn-sm btn-outline-primary mt-2" onclick="showGroupMilestones('@group.Key', 'quarter')">View milestones</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (groupBy == "owner")
        {
            var grouped = Model.GroupBy(m => m.OwnerUser != null ? m.OwnerUser.Email : m.OwnerEmail ?? "Unassigned")
                .OrderBy(g => g.Key);
            
            <div class="row">
                @foreach (var group in grouped)
                {
                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-12 col-sm-12 col-12 mb-3">
                        <div class="card">
                            <div class="card-header bg-secondary text-white">
                                <h5 class="card-title mb-0">@group.Key</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Total: @group.Count()</strong></p>
                                <ul class="list-unstyled mb-0">
                                    <li><span class="badge badge-success">@group.Count(m => m.Status == "complete")</span> Complete</li>
                                    <li><span class="badge badge-primary">@group.Count(m => m.Status == "on_track")</span> On track</li>
                                    <li><span class="badge badge-danger">@group.Count(m => m.Status == "delayed" || m.DueDate < DateTime.Today && m.Status != "complete")</span> Delayed/Overdue</li>
                                </ul>
                                <button class="btn btn-sm btn-outline-primary mt-2" onclick="showGroupMilestones('@group.Key', 'owner')">View milestones</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Detailed List Modal -->
        <div class="modal fade" id="milestoneDetailModal" tabindex="-1">
            <div class="modal-dialog modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Milestones</h5>
                        <button type="button" class="close" data-dismiss="modal">
                            <span>&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <div id="milestoneDetailContent"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        var allMilestones = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(m => new {
            id = m.Id,
            name = m.Name,
            fipsId = m.FipsId,
            businessArea = m.BusinessArea,
            status = m.Status,
            owner = m.OwnerUser != null ? m.OwnerUser.Email : m.OwnerEmail,
            dueDate = m.DueDate,
            progressPercent = m.ProgressPercent,
            quarter = $"Q{((m.DueDate.Month - 1) / 3 + 1)} {m.DueDate.Year}"
        })));

        function showGroupMilestones(groupValue, groupType) {
            var filtered = [];
            
            if (groupType === 'status') {
                filtered = allMilestones.filter(m => m.status === groupValue);
            } else if (groupType === 'business-area') {
                filtered = allMilestones.filter(m => (m.businessArea || 'Unspecified') === groupValue);
            } else if (groupType === 'product') {
                filtered = allMilestones.filter(m => (m.fipsId || 'No product') === groupValue);
            } else if (groupType === 'quarter') {
                filtered = allMilestones.filter(m => m.quarter === groupValue);
            } else if (groupType === 'owner') {
                filtered = allMilestones.filter(m => (m.owner || 'Unassigned') === groupValue);
            }
            
            displayMilestones(filtered, groupValue);
        }

        function displayMilestones(milestones, title) {
            var html = '<h6>' + title + ' (' + milestones.length + ' milestones)</h6>';
            html += '<div class="table-responsive"><table class="table table-hover table-striped"><thead><tr>';
            html += '<th>Name</th><th>Status</th><th>Due Date</th><th>Progress</th><th>Owner</th><th>Actions</th></tr></thead><tbody>';
            
            milestones.forEach(function(milestone) {
                var statusClass = milestone.status === 'complete' ? 'success' : milestone.status === 'on_track' ? 'primary' : milestone.status === 'at_risk' ? 'warning' : milestone.status === 'delayed' ? 'danger' : 'secondary';
                var today = new Date();
                today.setHours(0, 0, 0, 0);
                var dueDate = new Date(milestone.dueDate);
                var isOverdue = dueDate < today && milestone.status !== 'complete' && milestone.status !== 'cancelled';
                
                html += '<tr' + (isOverdue ? ' class="table-warning"' : '') + '>';
                html += '<td>' + milestone.name + '</td>';
                html += '<td><span class="badge badge-' + statusClass + '">' + (milestone.status || '-').replace('_', ' ') + '</span></td>';
                html += '<td>' + dueDate.toLocaleDateString('en-GB') + (isOverdue ? ' <i class="fas fa-clock text-danger"></i>' : '') + '</td>';
                html += '<td>' + (milestone.progressPercent || 0) + '%</td>';
                html += '<td>' + (milestone.owner || '-') + '</td>';
                html += '<td><a href="/Milestone/Details/' + milestone.id + '" class="btn btn-sm btn-info">View</a></td>';
                html += '</tr>';
            });
            
            html += '</tbody></table></div>';
            $('#milestoneDetailContent').html(html);
            $('#milestoneDetailModal').modal('show');
        }
    </script>
}

