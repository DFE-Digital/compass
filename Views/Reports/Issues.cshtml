@model List<Compass.Models.Issue>
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Issues report";
    var groupBy = ViewBag.GroupBy as string ?? "severity";
    var products = ViewBag.Products as List<Compass.Models.ProductDto> ?? new List<Compass.Models.ProductDto>();
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Reports</a></li>
                    <li class="breadcrumb-item active">Issues</li>
                </ol>
                <h1 class="m-0">Issues report</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <!-- Summary -->
        <div class="row mb-3">
            <div class="col-lg-2 col-md-4 col-6">
                <div class="card">
                    <div class="card-body text-center">
                        <h3 class="mb-0">@ViewBag.TotalIssues</h3>
                        <p class="text-muted mb-0"><small>Total</small></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="card">
                    <div class="card-body text-center">
                        <h3 class="mb-0">@ViewBag.CriticalIssues</h3>
                        <p class="text-muted mb-0"><small>Critical</small></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="card">
                    <div class="card-body text-center">
                        <h3 class="mb-0">@ViewBag.HighIssues</h3>
                        <p class="text-muted mb-0"><small>High</small></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="card">
                    <div class="card-body text-center">
                        <h3 class="mb-0">@ViewBag.OpenIssues</h3>
                        <p class="text-muted mb-0"><small>Open</small></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="card">
                    <div class="card-body text-center">
                        <h3 class="mb-0">@ViewBag.ResolvedIssues</h3>
                        <p class="text-muted mb-0"><small>Resolved</small></p>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-6">
                <div class="card">
                    <div class="card-body text-center">
                        <h3 class="mb-0">@ViewBag.BlockedIssues</h3>
                        <p class="text-muted mb-0"><small>Blocked</small></p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Left Sidebar: Grouping Options -->
            <div class="col-lg-2 col-md-3 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Group by</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <a href="@Url.Action("Issues", new { groupBy = "severity" })" class="list-group-item list-group-item-action @(groupBy == "severity" ? "active" : "")">Severity</a>
                            <a href="@Url.Action("Issues", new { groupBy = "status" })" class="list-group-item list-group-item-action @(groupBy == "status" ? "active" : "")">Status</a>
                            <a href="@Url.Action("Issues", new { groupBy = "business-area" })" class="list-group-item list-group-item-action @(groupBy == "business-area" ? "active" : "")">Business area</a>
                            <a href="@Url.Action("Issues", new { groupBy = "product" })" class="list-group-item list-group-item-action @(groupBy == "product" ? "active" : "")">Product</a>
                            <a href="@Url.Action("Issues", new { groupBy = "priority" })" class="list-group-item list-group-item-action @(groupBy == "priority" ? "active" : "")">Priority</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Content: Grouped Results -->
            <div class="col-lg-10 col-md-9 col-12">
                @if (groupBy == "severity")
                {
                    var grouped = Model.GroupBy(i => i.Severity ?? "unspecified")
                        .OrderByDescending(g => g.Key == "critical" ? 4 : g.Key == "high" ? 3 : g.Key == "medium" ? 2 : 1);
                    
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Issues by severity</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Severity</th>
                                        <th style="width: 100px;" class="text-center">Total</th>
                                        <th style="width: 100px;" class="text-center">Open</th>
                                        <th style="width: 100px;" class="text-center">Resolved</th>
                                        <th style="width: 100px;" class="text-center">Blocked</th>
                                        <th style="width: 100px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var group in grouped)
                                    {
                                        <tr>
                                            <td><strong class="text-capitalize">@group.Key</strong></td>
                                            <td class="text-center">@group.Count()</td>
                                            <td class="text-center">@group.Count(i => i.Status == "open" || i.Status == "in_progress")</td>
                                            <td class="text-center">@group.Count(i => i.Status == "resolved" || i.Status == "closed")</td>
                                            <td class="text-center">@group.Count(i => i.BlockedFlag)</td>
                                            <td><button class="btn btn-sm btn-outline-primary" onclick="showGroupIssues('@group.Key', 'severity')">View</button></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else if (groupBy == "status")
                {
                    var grouped = Model.GroupBy(i => i.Status ?? "unknown").OrderBy(g => g.Key);
                    
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Issues by status</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Status</th>
                                        <th style="width: 100px;" class="text-center">Total</th>
                                        <th style="width: 100px;" class="text-center">Critical</th>
                                        <th style="width: 100px;" class="text-center">High</th>
                                        <th style="width: 100px;" class="text-center">Medium</th>
                                        <th style="width: 100px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var group in grouped)
                                    {
                                        <tr>
                                            <td><strong class="text-capitalize">@group.Key.Replace("_", " ")</strong></td>
                                            <td class="text-center">@group.Count()</td>
                                            <td class="text-center">@group.Count(i => i.Severity == "critical")</td>
                                            <td class="text-center">@group.Count(i => i.Severity == "high")</td>
                                            <td class="text-center">@group.Count(i => i.Severity == "medium")</td>
                                            <td><button class="btn btn-sm btn-outline-primary" onclick="showGroupIssues('@group.Key', 'status')">View</button></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else if (groupBy == "business-area")
                {
                    var grouped = Model.GroupBy(i => string.IsNullOrEmpty(i.BusinessArea) ? "Unspecified" : i.BusinessArea)
                        .OrderBy(g => g.Key);
                    
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Issues by business area</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Business area</th>
                                        <th style="width: 100px;" class="text-center">Total</th>
                                        <th style="width: 100px;" class="text-center">Critical</th>
                                        <th style="width: 100px;" class="text-center">High</th>
                                        <th style="width: 100px;" class="text-center">Blocked</th>
                                        <th style="width: 100px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var group in grouped)
                                    {
                                        <tr>
                                            <td><strong>@group.Key</strong></td>
                                            <td class="text-center">@group.Count()</td>
                                            <td class="text-center">@group.Count(i => i.Severity == "critical")</td>
                                            <td class="text-center">@group.Count(i => i.Severity == "high")</td>
                                            <td class="text-center">@group.Count(i => i.BlockedFlag)</td>
                                            <td><button class="btn btn-sm btn-outline-primary" onclick="showGroupIssues('@group.Key', 'business-area')">View</button></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else if (groupBy == "product")
                {
                    var grouped = Model.GroupBy(i => i.FipsId ?? "No product").OrderBy(g => g.Key);
                    
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Issues by product</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th style="width: 100px;" class="text-center">Total</th>
                                        <th style="width: 100px;" class="text-center">Critical</th>
                                        <th style="width: 100px;" class="text-center">High</th>
                                        <th style="width: 100px;" class="text-center">Blocked</th>
                                        <th style="width: 100px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var group in grouped)
                                    {
                                        var product = products.FirstOrDefault(p => p.FipsId == group.Key);
                                        var displayName = product?.Title ?? group.Key;
                                        
                                        <tr>
                                            <td><strong>@displayName</strong></td>
                                            <td class="text-center">@group.Count()</td>
                                            <td class="text-center">@group.Count(i => i.Severity == "critical")</td>
                                            <td class="text-center">@group.Count(i => i.Severity == "high")</td>
                                            <td class="text-center">@group.Count(i => i.BlockedFlag)</td>
                                            <td><button class="btn btn-sm btn-outline-primary" onclick="showGroupIssues('@group.Key', 'product')">View</button></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else if (groupBy == "priority")
                {
                    var grouped = Model.GroupBy(i => i.Priority ?? "unspecified")
                        .OrderByDescending(g => g.Key == "high" ? 3 : g.Key == "medium" ? 2 : 1);
                    
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Issues by priority</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Priority</th>
                                        <th style="width: 100px;" class="text-center">Total</th>
                                        <th style="width: 100px;" class="text-center">Critical</th>
                                        <th style="width: 100px;" class="text-center">High</th>
                                        <th style="width: 100px;" class="text-center">Blocked</th>
                                        <th style="width: 100px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var group in grouped)
                                    {
                                        <tr>
                                            <td><strong class="text-capitalize">@group.Key</strong></td>
                                            <td class="text-center">@group.Count()</td>
                                            <td class="text-center">@group.Count(i => i.Severity == "critical")</td>
                                            <td class="text-center">@group.Count(i => i.Severity == "high")</td>
                                            <td class="text-center">@group.Count(i => i.BlockedFlag)</td>
                                            <td><button class="btn btn-sm btn-outline-primary" onclick="showGroupIssues('@group.Key', 'priority')">View</button></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Detailed List Modal -->
        <div class="modal fade" id="issueDetailModal" tabindex="-1">
            <div class="modal-dialog modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Issues</h5>
                        <button type="button" class="close" data-dismiss="modal">
                            <span>&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <div id="issueDetailContent"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        var allIssues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(i => new {
            id = i.Id,
            title = i.Title,
            fipsId = i.FipsId,
            businessArea = i.BusinessArea,
            severity = i.Severity,
            priority = i.Priority,
            status = i.Status,
            blockedFlag = i.BlockedFlag
        })));

        function showGroupIssues(groupValue, groupType) {
            var filtered = [];
            
            if (groupType === 'severity') {
                filtered = allIssues.filter(i => (i.severity || 'unspecified') === groupValue);
            } else if (groupType === 'status') {
                filtered = allIssues.filter(i => i.status === groupValue);
            } else if (groupType === 'business-area') {
                filtered = allIssues.filter(i => (i.businessArea || 'Unspecified') === groupValue);
            } else if (groupType === 'product') {
                filtered = allIssues.filter(i => (i.fipsId || 'No product') === groupValue);
            } else if (groupType === 'priority') {
                filtered = allIssues.filter(i => (i.priority || 'unspecified') === groupValue);
            }
            
            displayIssues(filtered, groupValue);
        }

        function displayIssues(issues, title) {
            var html = '<h6>' + title + ' (' + issues.length + ' issues)</h6>';
            html += '<div class="table-responsive"><table class="table table-hover"><thead><tr>';
            html += '<th>Title</th><th>Severity</th><th>Status</th><th>Blocked</th><th>Business area</th><th>Actions</th></tr></thead><tbody>';
            
            issues.forEach(function(issue) {
                var severityClass = issue.severity === 'critical' ? 'danger' : issue.severity === 'high' ? 'warning' : 'info';
                html += '<tr>';
                html += '<td>' + issue.title + '</td>';
                html += '<td><span class="badge badge-' + severityClass + '">' + (issue.severity || '-') + '</span></td>';
                html += '<td>' + (issue.status || '-') + '</td>';
                html += '<td>' + (issue.blockedFlag ? 'Yes' : 'No') + '</td>';
                html += '<td>' + (issue.businessArea || '-') + '</td>';
                html += '<td><a href="/Issue/Details/' + issue.id + '" class="btn btn-sm btn-info">View</a></td>';
                html += '</tr>';
            });
            
            html += '</tbody></table></div>';
            $('#issueDetailContent').html(html);
            $('#issueDetailModal').modal('show');
        }
    </script>
}
