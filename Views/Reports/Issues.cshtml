@model List<Compass.Models.Issue>
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Issues report";
    var groupBy = ViewBag.GroupBy as string ?? "severity";
    var products = ViewBag.Products as List<Compass.Models.ProductDto> ?? new List<Compass.Models.ProductDto>();
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Issues report</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <!-- Summary Cards -->
        <div class="row mb-3">
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-info">
                    <div class="inner">
                        <h3>@ViewBag.TotalIssues</h3>
                        <p>Total issues</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-bug"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-danger">
                    <div class="inner">
                        <h3>@ViewBag.CriticalIssues</h3>
                        <p>Critical</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-exclamation-circle"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-warning">
                    <div class="inner">
                        <h3>@ViewBag.HighIssues</h3>
                        <p>High</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-primary">
                    <div class="inner">
                        <h3>@ViewBag.OpenIssues</h3>
                        <p>Open</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-folder-open"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-success">
                    <div class="inner">
                        <h3>@ViewBag.ResolvedIssues</h3>
                        <p>Resolved</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                </div>
            </div>
            <div class="col-xxl-2 col-xl-3 col-lg-4 col-md-6 col-sm-12 col-12">
                <div class="small-box bg-dark">
                    <div class="inner">
                        <h3>@ViewBag.BlockedIssues</h3>
                        <p>Blocked</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-ban"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Grouping Options -->
        <div class="row mb-3">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0">Group by</h5>
                    </div>
                    <div class="card-body">
                        <div class="btn-group" role="group">
                            <a href="@Url.Action("Issues", new { groupBy = "severity" })" class="btn btn-@(groupBy == "severity" ? "primary" : "outline-primary")">
                                <i class="fas fa-exclamation-triangle"></i> Severity
                            </a>
                            <a href="@Url.Action("Issues", new { groupBy = "status" })" class="btn btn-@(groupBy == "status" ? "primary" : "outline-primary")">
                                <i class="fas fa-flag"></i> Status
                            </a>
                            <a href="@Url.Action("Issues", new { groupBy = "business-area" })" class="btn btn-@(groupBy == "business-area" ? "primary" : "outline-primary")">
                                <i class="fas fa-building"></i> Business area
                            </a>
                            <a href="@Url.Action("Issues", new { groupBy = "product" })" class="btn btn-@(groupBy == "product" ? "primary" : "outline-primary")">
                                <i class="fas fa-box"></i> Product
                            </a>
                            <a href="@Url.Action("Issues", new { groupBy = "priority" })" class="btn btn-@(groupBy == "priority" ? "primary" : "outline-primary")">
                                <i class="fas fa-star"></i> Priority
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Grouped Results -->
        @if (groupBy == "severity")
        {
            var grouped = Model.GroupBy(i => i.Severity ?? "unspecified")
                .OrderByDescending(g => g.Key == "critical" ? 4 : g.Key == "high" ? 3 : g.Key == "medium" ? 2 : 1);
            
            <div class="row">
                @foreach (var group in grouped)
                {
                    var badgeClass = group.Key == "critical" ? "danger" : group.Key == "high" ? "warning" : group.Key == "medium" ? "info" : "secondary";
                    
                    <div class="col-xxl-3 col-xl-4 col-lg-6 col-md-6 col-sm-12 col-12 mb-3">
                        <div class="card">
                            <div class="card-header bg-@badgeClass text-white">
                                <h5 class="card-title mb-0 text-capitalize">@group.Key</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Total: @group.Count()</strong></p>
                                <ul class="list-unstyled mb-0">
                                    <li><i class="fas fa-folder-open text-primary"></i> @group.Count(i => i.Status == "open" || i.Status == "in_progress") Open</li>
                                    <li><i class="fas fa-check-circle text-success"></i> @group.Count(i => i.Status == "resolved" || i.Status == "closed") Resolved</li>
                                    <li><i class="fas fa-ban text-danger"></i> @group.Count(i => i.BlockedFlag) Blocked</li>
                                </ul>
                                <button class="btn btn-sm btn-outline-primary mt-2" onclick="showGroupIssues('@group.Key', 'severity')">View issues</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (groupBy == "status")
        {
            var grouped = Model.GroupBy(i => i.Status ?? "unknown").OrderBy(g => g.Key);
            
            <div class="row">
                @foreach (var group in grouped)
                {
                    var badgeClass = group.Key == "open" ? "danger" : group.Key == "in_progress" ? "warning" : group.Key == "resolved" ? "success" : "secondary";
                    
                    <div class="col-xxl-3 col-xl-4 col-lg-6 col-md-6 col-sm-12 col-12 mb-3">
                        <div class="card">
                            <div class="card-header bg-@badgeClass text-white">
                                <h5 class="card-title mb-0 text-capitalize">@group.Key.Replace("_", " ")</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Total: @group.Count()</strong></p>
                                <ul class="list-unstyled mb-0">
                                    <li><span class="badge badge-danger">@group.Count(i => i.Severity == "critical")</span> Critical</li>
                                    <li><span class="badge badge-warning">@group.Count(i => i.Severity == "high")</span> High</li>
                                    <li><span class="badge badge-info">@group.Count(i => i.Severity == "medium")</span> Medium</li>
                                </ul>
                                <button class="btn btn-sm btn-outline-primary mt-2" onclick="showGroupIssues('@group.Key', 'status')">View issues</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (groupBy == "business-area")
        {
            var grouped = Model.GroupBy(i => string.IsNullOrEmpty(i.BusinessArea) ? "Unspecified" : i.BusinessArea)
                .OrderBy(g => g.Key);
            
            <div class="row">
                @foreach (var group in grouped)
                {
                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-12 col-sm-12 col-12 mb-3">
                        <div class="card">
                            <div class="card-header bg-primary text-white">
                                <h5 class="card-title mb-0">@group.Key</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Total: @group.Count()</strong></p>
                                <ul class="list-unstyled mb-0">
                                    <li><span class="badge badge-danger">@group.Count(i => i.Severity == "critical")</span> Critical</li>
                                    <li><span class="badge badge-warning">@group.Count(i => i.Severity == "high")</span> High</li>
                                    <li><i class="fas fa-ban text-danger"></i> @group.Count(i => i.BlockedFlag) Blocked</li>
                                </ul>
                                <button class="btn btn-sm btn-outline-primary mt-2" onclick="showGroupIssues('@group.Key', 'business-area')">View issues</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (groupBy == "product")
        {
            var grouped = Model.GroupBy(i => i.FipsId ?? "No product").OrderBy(g => g.Key);
            
            <div class="row">
                @foreach (var group in grouped)
                {
                    var product = products.FirstOrDefault(p => p.FipsId == group.Key);
                    var displayName = product?.Title ?? group.Key;
                    
                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-12 col-sm-12 col-12 mb-3">
                        <div class="card">
                            <div class="card-header bg-info text-white">
                                <h5 class="card-title mb-0">@displayName</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Total: @group.Count()</strong></p>
                                <ul class="list-unstyled mb-0">
                                    <li><span class="badge badge-danger">@group.Count(i => i.Severity == "critical")</span> Critical</li>
                                    <li><span class="badge badge-warning">@group.Count(i => i.Severity == "high")</span> High</li>
                                    <li><i class="fas fa-ban text-danger"></i> @group.Count(i => i.BlockedFlag) Blocked</li>
                                </ul>
                                <button class="btn btn-sm btn-outline-primary mt-2" onclick="showGroupIssues('@group.Key', 'product')">View issues</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (groupBy == "priority")
        {
            var grouped = Model.GroupBy(i => i.Priority ?? "unspecified")
                .OrderByDescending(g => g.Key == "high" ? 3 : g.Key == "medium" ? 2 : 1);
            
            <div class="row">
                @foreach (var group in grouped)
                {
                    var badgeClass = group.Key == "high" ? "danger" : group.Key == "medium" ? "warning" : "secondary";
                    
                    <div class="col-xxl-4 col-xl-6 col-lg-6 col-md-12 col-sm-12 col-12 mb-3">
                        <div class="card">
                            <div class="card-header bg-@badgeClass text-white">
                                <h5 class="card-title mb-0 text-capitalize">@group.Key</h5>
                            </div>
                            <div class="card-body">
                                <p><strong>Total: @group.Count()</strong></p>
                                <ul class="list-unstyled mb-0">
                                    <li><span class="badge badge-danger">@group.Count(i => i.Severity == "critical")</span> Critical</li>
                                    <li><span class="badge badge-warning">@group.Count(i => i.Severity == "high")</span> High</li>
                                    <li><i class="fas fa-ban text-danger"></i> @group.Count(i => i.BlockedFlag) Blocked</li>
                                </ul>
                                <button class="btn btn-sm btn-outline-primary mt-2" onclick="showGroupIssues('@group.Key', 'priority')">View issues</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Detailed List Modal -->
        <div class="modal fade" id="issueDetailModal" tabindex="-1">
            <div class="modal-dialog modal-xl">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Issues</h5>
                        <button type="button" class="close" data-dismiss="modal">
                            <span>&times;</span>
                        </button>
                    </div>
                    <div class="modal-body">
                        <div id="issueDetailContent"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        var allIssues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(i => new {
            id = i.Id,
            title = i.Title,
            fipsId = i.FipsId,
            businessArea = i.BusinessArea,
            severity = i.Severity,
            priority = i.Priority,
            status = i.Status,
            blockedFlag = i.BlockedFlag
        })));

        function showGroupIssues(groupValue, groupType) {
            var filtered = [];
            
            if (groupType === 'severity') {
                filtered = allIssues.filter(i => (i.severity || 'unspecified') === groupValue);
            } else if (groupType === 'status') {
                filtered = allIssues.filter(i => i.status === groupValue);
            } else if (groupType === 'business-area') {
                filtered = allIssues.filter(i => (i.businessArea || 'Unspecified') === groupValue);
            } else if (groupType === 'product') {
                filtered = allIssues.filter(i => (i.fipsId || 'No product') === groupValue);
            } else if (groupType === 'priority') {
                filtered = allIssues.filter(i => (i.priority || 'unspecified') === groupValue);
            }
            
            displayIssues(filtered, groupValue);
        }

        function displayIssues(issues, title) {
            var html = '<h6>' + title + ' (' + issues.length + ' issues)</h6>';
            html += '<div class="table-responsive"><table class="table table-hover table-striped"><thead><tr>';
            html += '<th>Title</th><th>Severity</th><th>Status</th><th>Blocked</th><th>Business Area</th><th>Actions</th></tr></thead><tbody>';
            
            issues.forEach(function(issue) {
                var severityClass = issue.severity === 'critical' ? 'danger' : issue.severity === 'high' ? 'warning' : 'info';
                html += '<tr>';
                html += '<td>' + issue.title + '</td>';
                html += '<td><span class="badge badge-' + severityClass + '">' + (issue.severity || '-') + '</span></td>';
                html += '<td>' + (issue.status || '-') + '</td>';
                html += '<td>' + (issue.blockedFlag ? '<i class="fas fa-ban text-danger"></i>' : '') + '</td>';
                html += '<td>' + (issue.businessArea || '-') + '</td>';
                html += '<td><a href="/Issue/Details/' + issue.id + '" class="btn btn-sm btn-info">View</a></td>';
                html += '</tr>';
            });
            
            html += '</tbody></table></div>';
            $('#issueDetailContent').html(html);
            $('#issueDetailModal').modal('show');
        }
    </script>
}

