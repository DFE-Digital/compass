@model List<Compass.Models.TrainingRequest>

@{
    ViewData["Title"] = "Profession requests";
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Profession requests</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-12">
                    <h1 class="m-0">Profession requests</h1>
                    <p class="text-muted mb-0">Review and approve training requests</p>
                </div>
            </div>
        </div>
    </div>
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }

        <div class="row">
            <!-- Left Column: Status Navigation -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title">Status</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <a asp-action="AdminRequests" asp-route-statusFilter="Submitted" asp-route-search="@ViewBag.Search"
                               class="list-group-item list-group-item-action @(ViewBag.StatusFilter == "Submitted" ? "active" : "")">
                                Submitted
                                <span class="badge badge-light float-right">@ViewBag.SubmittedCount</span>
                            </a>
                            <a asp-action="AdminRequests" asp-route-statusFilter="Approved" asp-route-search="@ViewBag.Search"
                               class="list-group-item list-group-item-action @(ViewBag.StatusFilter == "Approved" ? "active" : "")">
                                Approved
                                <span class="badge badge-light float-right">@ViewBag.ApprovedCount</span>
                            </a>
                            <a asp-action="AdminRequests" asp-route-statusFilter="Rejected" asp-route-search="@ViewBag.Search"
                               class="list-group-item list-group-item-action @(ViewBag.StatusFilter == "Rejected" ? "active" : "")">
                                Rejected
                                <span class="badge badge-light float-right">@ViewBag.RejectedCount</span>
                            </a>
                            <a asp-action="AdminRequests" asp-route-statusFilter="Cancelled" asp-route-search="@ViewBag.Search"
                               class="list-group-item list-group-item-action @(ViewBag.StatusFilter == "Cancelled" ? "active" : "")">
                                Cancelled
                                <span class="badge badge-light float-right">@ViewBag.CancelledCount</span>
                            </a>
                            <a asp-action="AdminRequests" asp-route-statusFilter="Completed" asp-route-search="@ViewBag.Search"
                               class="list-group-item list-group-item-action @(ViewBag.StatusFilter == "Completed" ? "active" : "")">
                                Completed
                                <span class="badge badge-light float-right">@ViewBag.CompletedCount</span>
                            </a>
                            <a asp-action="AdminRequests" asp-route-statusFilter="On-hold" asp-route-search="@ViewBag.Search"
                               class="list-group-item list-group-item-action @(ViewBag.StatusFilter == "On-hold" ? "active" : "")">
                                On-hold
                                <span class="badge badge-light float-right">@ViewBag.OnHoldCount</span>
                            </a>
                        </div>
                    </div>
                </div>
                <!-- Search Filter -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Search</h3>
                    </div>
                    <div class="card-body">
                        <form method="get" asp-action="AdminRequests">
                            <input type="hidden" name="statusFilter" value="@ViewBag.StatusFilter" />
                            <div class="form-group">
                                <input type="text" name="search" class="form-control form-control-sm" value="@ViewBag.Search" placeholder="Search by user or course..." />
                            </div>
                            <div class="form-group">
                                <button type="submit" class="btn btn-primary btn-sm btn-block">Apply</button>
                                <a asp-action="AdminRequests" asp-route-statusFilter="@ViewBag.StatusFilter" class="btn btn-default btn-sm btn-block">Clear</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Column: Requests List -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <!-- Withdrawal Requests Table -->
                @if (ViewBag.WithdrawalRequests != null && ((List<Compass.Models.TrainingRequest>)ViewBag.WithdrawalRequests).Any())
                {
                    <div class="card mb-4">
                        <div class="card-header bg-warning">
                            <h3 class="card-title">Withdrawal requests (@(((List<Compass.Models.TrainingRequest>)ViewBag.WithdrawalRequests).Count))</h3>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>User</th>
                                        <th>Course</th>
                                        <th>Cost</th>
                                        <th>Withdrawal reason</th>
                                        <th>Requested</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var request in (List<Compass.Models.TrainingRequest>)ViewBag.WithdrawalRequests)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@(request.User?.Name ?? "Unknown")</strong><br>
                                                <small class="text-muted">@(request.User?.Email ?? "N/A")</small>
                                            </td>
                                            <td>
                                                <strong>@(request.Course?.Title ?? request.CustomCourseTitle ?? "Custom course")</strong>
                                            </td>
                                            <td>
                                                @{
                                                    var cost = request.ActualCost ?? request.Course?.Cost ?? request.CustomCourseCost ?? 0;
                                                }
                                                @if (cost > 0)
                                                {
                                                    <span class="text-danger">£@cost.ToString("N0")</span>
                                                }
                                                else
                                                {
                                                    <span class="text-success">Free</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(request.WithdrawalReason))
                                                {
                                                    <span title="@request.WithdrawalReason">
                                                        @(request.WithdrawalReason.Length > 50 ? request.WithdrawalReason.Substring(0, 50) + "..." : request.WithdrawalReason)
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (request.WithdrawalRequestedAt.HasValue)
                                                {
                                                    @request.WithdrawalRequestedAt.Value.ToString("dd MMM yyyy")
                                                }
                                            </td>
                                            <td>
                                                <a asp-action="ViewWithdrawalRequest" asp-route-id="@request.Id" class="btn btn-sm btn-primary">Manage</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                <div class="card">
            <div class="card-header">
                <h3 class="card-title">Training requests@(ViewBag.StatusFilter != null ? $" - {ViewBag.StatusFilter}" : "")</h3>
                <div class="card-tools">
                    <a asp-action="ExportRequests" 
                       asp-route-statusFilter="@ViewBag.StatusFilter" 
                       asp-route-professionFilter="@ViewBag.ProfessionFilter" 
                       asp-route-search="@ViewBag.Search">
                        Export CSV
                    </a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (Model.Any())
                {
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Course</th>
                                <th>Status</th>
                                <th>Requested / Training Date</th>
                                <th>Cost</th>
                                <th>Completed</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@(request.User?.Name ?? "Unknown")</strong><br>
                                        <small class="text-muted">@(request.User?.Email ?? "N/A")</small>
                                    </td>
                                    <td>
                                        <strong>@(request.Course?.Title ?? request.CustomCourseTitle ?? "Custom course")</strong>
                                        @if (request.Course != null && request.Course.Cost.HasValue)
                                        {
                                            <br><small class="text-muted">Cost: £@request.Course.Cost.Value.ToString("N0")</small>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge badge-light">@request.Status</span>
                                    </td>
                                    <td>
                                        <div>Requested: @request.CreatedAt.ToString("dd MMM yyyy")</div>
                                        @if (request.PlannedDate.HasValue)
                                        {
                                            <div><small class="text-muted">Training: @request.PlannedDate.Value.ToString("dd MMM yyyy")</small></div>
                                        }
                                    </td>
                                    <td>
                                        @if (request.ActualCost.HasValue)
                                        {
                                            <span class="text-success">£@request.ActualCost.Value.ToString("N0")</span>
                                            @if (request.Course != null && request.Course.Cost.HasValue && request.ActualCost.Value != request.Course.Cost.Value)
                                            {
                                                <br><small class="text-muted">Potential: £@request.Course.Cost.Value.ToString("N0")</small>
                                            }
                                        }
                                        else if (request.Course != null && request.Course.Cost.HasValue)
                                        {
                                            <span>£@request.Course.Cost.Value.ToString("N0")</span>
                                        }
                                        else if (request.CustomCourseCost.HasValue)
                                        {
                                            <span>£@request.CustomCourseCost.Value.ToString("N0")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                            <td>
                                                @if (request.TrainingCompleted == true)
                                                {
                                                    <span class="badge badge-light">Yes</span>
                                                }
                                                else if (request.TrainingCompleted == false)
                                                {
                                                    <span class="badge badge-light">No</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                    <td>
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-secondary dropdown-toggle" type="button" id="actionsDropdown@(request.Id)" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                Actions
                                            </button>
                                            <div class="dropdown-menu" aria-labelledby="actionsDropdown@(request.Id)">
                                                @if (request.Status == "Approved")
                                                {
                                                    <a class="dropdown-item" href="#" data-toggle="modal" data-target="#transferModal@(request.Id)">Transfer request</a>
                                                }
                                                <a class="dropdown-item" asp-action="UpdateRequestDetails" asp-route-id="@request.Id">Manage</a>
                                                @if (request.Status == "Submitted")
                                                {
                                                    <div class="dropdown-divider"></div>
                                                    <a class="dropdown-item" href="#" data-toggle="modal" data-target="#approveModal@(request.Id)">Approve</a>
                                                    <a class="dropdown-item" href="#" data-toggle="modal" data-target="#rejectModal@(request.Id)">Reject</a>
                                                }
                                                <div class="dropdown-divider"></div>
                                                <a class="dropdown-item" href="#" data-toggle="modal" data-target="#detailsModal@(request.Id)">View details</a>
                                            </div>
                                        </div>
                                    </td>
                                </tr>

                                <!-- Approve Modal -->
                                <div class="modal fade" id="approveModal@(request.Id)" tabindex="-1" role="dialog">
                                    <div class="modal-dialog" role="document">
                                        <div class="modal-content">
                                            <form asp-action="ApproveRequest" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@request.Id" />
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Approve training request</h5>
                                                    <button type="button" class="close" data-dismiss="modal">
                                                        <span>&times;</span>
                                                    </button>
                                                </div>
                                                <div class="modal-body">
                                                    <p>Approve training request for <strong>@(request.User?.Name ?? "Unknown")</strong>?</p>
                                                    <div class="form-group">
                                                        <label for="comments@(request.Id)">Comments (optional)</label>
                                                        <textarea id="comments@(request.Id)" name="comments" class="form-control" rows="3"></textarea>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-success">Approve</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                                <!-- Reject Modal -->
                                <div class="modal fade" id="rejectModal@(request.Id)" tabindex="-1" role="dialog">
                                    <div class="modal-dialog" role="document">
                                        <div class="modal-content">
                                            <form asp-action="RejectRequest" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@request.Id" />
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Reject training request</h5>
                                                    <button type="button" class="close" data-dismiss="modal">
                                                        <span>&times;</span>
                                                    </button>
                                                </div>
                                                <div class="modal-body">
                                                    <p>Reject training request for <strong>@(request.User?.Name ?? "Unknown")</strong>?</p>
                                                    <div class="form-group">
                                                        <label for="rejectComments@(request.Id)">Reason for rejection</label>
                                                        <textarea id="rejectComments@(request.Id)" name="comments" class="form-control" rows="3" required></textarea>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-danger">Reject</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                                <!-- Details Modal -->
                                <div class="modal fade" id="detailsModal@(request.Id)" tabindex="-1" role="dialog">
                                    <div class="modal-dialog modal-lg" role="document">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Request details</h5>
                                                <button type="button" class="close" data-dismiss="modal">
                                                    <span>&times;</span>
                                                </button>
                                            </div>
                                            <div class="modal-body">
                                                <dl class="row">
                                                    <dt class="col-sm-3">User:</dt>
                                                    <dd class="col-sm-9">@(request.User?.Name ?? "Unknown") (@(request.User?.Email ?? "N/A"))</dd>
                                                    <dt class="col-sm-3">Course:</dt>
                                                    <dd class="col-sm-9">@(request.Course?.Title ?? request.CustomCourseTitle ?? "Custom course")</dd>
                                                    <dt class="col-sm-3">Status:</dt>
                                                    <dd class="col-sm-9">@request.Status</dd>
                                                    <dt class="col-sm-3">Requested:</dt>
                                                    <dd class="col-sm-9">@request.CreatedAt.ToString("dd MMM yyyy HH:mm")</dd>
                                                    <dt class="col-sm-3">Justification:</dt>
                                                    <dd class="col-sm-9">@(request.Justification ?? "N/A")</dd>
                                                    @if (!string.IsNullOrEmpty(request.ProfessionAlignment))
                                                    {
                                                        <dt class="col-sm-3">Profession alignment:</dt>
                                                        <dd class="col-sm-9">@request.ProfessionAlignment</dd>
                                                    }
                                                    @if (!string.IsNullOrEmpty(request.ApproverComments))
                                                    {
                                                        <dt class="col-sm-3">Approver comments:</dt>
                                                        <dd class="col-sm-9">@request.ApproverComments</dd>
                                                    }
                                                    @if (request.Course != null && request.Course.Cost.HasValue)
                                                    {
                                                        <dt class="col-sm-3">Potential cost:</dt>
                                                        <dd class="col-sm-9">£@request.Course.Cost.Value.ToString("N0")</dd>
                                                    }
                                                    @if (request.ActualCost.HasValue)
                                                    {
                                                        <dt class="col-sm-3">Actual cost:</dt>
                                                        <dd class="col-sm-9">£@request.ActualCost.Value.ToString("N0")</dd>
                                                    }
                                                    @if (request.PlannedDate.HasValue)
                                                    {
                                                        <dt class="col-sm-3">Planned date:</dt>
                                                        <dd class="col-sm-9">@request.PlannedDate.Value.ToString("dd MMM yyyy")</dd>
                                                    }
                                                    @if (request.TrainingCompleted.HasValue)
                                                    {
                                                        <dt class="col-sm-3">Training completed:</dt>
                                                        <dd class="col-sm-9">
                                                            @if (request.TrainingCompleted.Value)
                                                            {
                                                                <span class="badge badge-light">Yes</span>
                                                                @if (request.CompletedDate.HasValue)
                                                                {
                                                                    <span class="ml-2">(@request.CompletedDate.Value.ToString("dd MMM yyyy"))</span>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <span class="badge badge-light">No</span>
                                                            }
                                                        </dd>
                                                    }
                                                </dl>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Transfer Modal -->
                                @if (request.Status == "Approved")
                                {
                                    <div class="modal fade" id="transferModal@(request.Id)" tabindex="-1" role="dialog">
                                        <div class="modal-dialog modal-lg" role="document">
                                            <div class="modal-content">
                                                <form asp-action="TransferRequest" method="post" id="transferForm@(request.Id)">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@request.Id" />
                                                    <div class="modal-header">
                                                        <h5 class="modal-title">Transfer training request</h5>
                                                        <button type="button" class="close" data-dismiss="modal">
                                                            <span>&times;</span>
                                                        </button>
                                                    </div>
                                                    <div class="modal-body">
                                                        <p>Transfer training request for <strong>@(request.User?.Name ?? "Unknown")</strong> to another user.</p>
                                                        <div class="form-group">
                                                            <label class="control-label" for="transferSearch@(request.Id)">Search for a colleague</label>
                                                            <small class="form-text text-muted">Start typing a name or email address to look up someone in Entra ID.</small>
                                                            <div class="user-picker" data-user-picker data-search-url="/api/users/search" data-select-url="/api/users/select">
                                                                <div class="position-relative">
                                                                    <input type="text"
                                                                           class="form-control js-user-picker-input"
                                                                           id="transferSearch@(request.Id)"
                                                                           autocomplete="off"
                                                                           placeholder="e.g. Alex Smith or alex.smith@education.gov.uk" />
                                                                    <span class="user-picker__spinner js-user-picker-spinner" aria-hidden="true">Searching…</span>
                                                                    <div class="user-picker__results js-user-picker-results" role="listbox" aria-live="polite"></div>
                                                                </div>
                                                                <p class="form-text text-muted js-user-picker-message"></p>
                                                                <input type="hidden" id="transferToUserId@(request.Id)" name="transferToUserId" class="js-user-picker-value" />
                                                                <div class="user-picker__selected js-user-picker-summary" data-default-text="No user selected.">
                                                                    <span class="text-muted">No user selected.</span>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                                                        <button type="submit" class="btn btn-success">Transfer</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-3">
                        <p class="text-muted mb-0">No training requests found.</p>
                    </div>
                }
            </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/js/user-picker.js" asp-append-version="true"></script>
}

