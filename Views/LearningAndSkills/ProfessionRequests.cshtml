@model List<Compass.Models.TrainingRequest>

@{
    ViewData["Title"] = "Profession requests";
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Profession requests</li>
        </ol>
    </nav>
}

<div class="dashboard-header">
    <div>
        <h1>Profession requests</h1>
        <p>Review and approve training requests</p>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }

        <div class="row">
            <!-- Left Column: Filters -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <!-- Filters -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Filters</h3>
                    </div>
                    <div class="card-body">
                        <form method="get" asp-action="ProfessionRequests">
                            <div class="form-group">
                                <label>Status</label>
                                <select name="statusFilter" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    <option value="Submitted" selected="@(ViewBag.StatusFilter == "Submitted")">Submitted</option>
                                    <option value="Approved" selected="@(ViewBag.StatusFilter == "Approved")">Approved</option>
                                    <option value="Rejected" selected="@(ViewBag.StatusFilter == "Rejected")">Rejected</option>
                                    <option value="On-hold" selected="@(ViewBag.StatusFilter == "On-hold")">On-hold</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Search</label>
                                <input type="text" name="search" class="form-control form-control-sm" value="@ViewBag.Search" placeholder="Search by user or course..." />
                            </div>
                            <div class="form-group">
                                <button type="submit" class="btn btn-primary btn-sm btn-block">Apply filters</button>
                                <a asp-action="ProfessionRequests" class="btn btn-default btn-sm btn-block">Clear all filters</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Column: Requests List -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <div class="card">
            <div class="card-header">
                <h3 class="card-title">Training requests (@Model.Count)</h3>
                <div class="card-tools">
                    <a asp-action="ExportRequests" 
                       asp-route-statusFilter="@ViewBag.StatusFilter" 
                       asp-route-professionFilter="@ViewBag.ProfessionFilter" 
                       asp-route-search="@ViewBag.Search" 
                       class="btn btn-sm btn-success">
                        <i class="fas fa-download"></i> Export CSV
                    </a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (Model.Any())
                {
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Course</th>
                                <th>Status</th>
                                <th>Requested</th>
                                <th>Justification</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@(request.User?.Name ?? "Unknown")</strong><br>
                                        <small class="text-muted">@(request.User?.Email ?? "N/A")</small>
                                    </td>
                                    <td>
                                        <strong>@(request.Course?.Title ?? request.CustomCourseTitle ?? "Custom course")</strong>
                                        @if (request.Course != null && request.Course.Cost.HasValue)
                                        {
                                            <br><small class="text-muted">Cost: £@request.Course.Cost.Value.ToString("F2")</small>
                                        }
                                    </td>
                                    <td>
                                        @switch (request.Status)
                                        {
                                            case "Submitted":
                                                <span class="badge badge-info">Submitted</span>
                                                break;
                                            case "Approved":
                                                <span class="badge badge-success">Approved</span>
                                                break;
                                            case "Rejected":
                                                <span class="badge badge-danger">Rejected</span>
                                                break;
                                            case "On-hold":
                                                <span class="badge badge-warning">On-hold</span>
                                                break;
                                            default:
                                                <span class="badge badge-secondary">@request.Status</span>
                                                break;
                                        }
                                    </td>
                                    <td>@request.CreatedAt.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(request.Justification))
                                        {
                                            <span title="@request.Justification">
                                                @(request.Justification.Length > 50 ? request.Justification.Substring(0, 50) + "..." : request.Justification)
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @if (request.Status == "Submitted")
                                        {
                                            <button type="button" class="btn btn-sm btn-success" data-toggle="modal" data-target="#approveModal@(request.Id)">Approve</button>
                                            <button type="button" class="btn btn-sm btn-danger" data-toggle="modal" data-target="#rejectModal@(request.Id)">Reject</button>
                                        }
                                        <button type="button" class="btn btn-sm btn-info" data-toggle="modal" data-target="#detailsModal@(request.Id)">Details</button>
                                    </td>
                                </tr>

                                <!-- Approve Modal -->
                                <div class="modal fade" id="approveModal@(request.Id)" tabindex="-1" role="dialog">
                                    <div class="modal-dialog" role="document">
                                        <div class="modal-content">
                                            <form asp-action="ApproveRequest" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@request.Id" />
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Approve training request</h5>
                                                    <button type="button" class="close" data-dismiss="modal">
                                                        <span>&times;</span>
                                                    </button>
                                                </div>
                                                <div class="modal-body">
                                                    <p>Approve training request for <strong>@(request.User?.Name ?? "Unknown")</strong>?</p>
                                                    <div class="form-group">
                                                        <label for="comments@(request.Id)">Comments (optional)</label>
                                                        <textarea id="comments@(request.Id)" name="comments" class="form-control" rows="3"></textarea>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-success">Approve</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                                <!-- Reject Modal -->
                                <div class="modal fade" id="rejectModal@(request.Id)" tabindex="-1" role="dialog">
                                    <div class="modal-dialog" role="document">
                                        <div class="modal-content">
                                            <form asp-action="RejectRequest" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@request.Id" />
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Reject training request</h5>
                                                    <button type="button" class="close" data-dismiss="modal">
                                                        <span>&times;</span>
                                                    </button>
                                                </div>
                                                <div class="modal-body">
                                                    <p>Reject training request for <strong>@(request.User?.Name ?? "Unknown")</strong>?</p>
                                                    <div class="form-group">
                                                        <label for="rejectComments@(request.Id)">Reason for rejection</label>
                                                        <textarea id="rejectComments@(request.Id)" name="comments" class="form-control" rows="3" required></textarea>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                                                    <button type="submit" class="btn btn-danger">Reject</button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                                <!-- Details Modal -->
                                <div class="modal fade" id="detailsModal@(request.Id)" tabindex="-1" role="dialog">
                                    <div class="modal-dialog modal-lg" role="document">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title">Request details</h5>
                                                <button type="button" class="close" data-dismiss="modal">
                                                    <span>&times;</span>
                                                </button>
                                            </div>
                                            <div class="modal-body">
                                                <dl class="row">
                                                    <dt class="col-sm-3">User:</dt>
                                                    <dd class="col-sm-9">@(request.User?.Name ?? "Unknown") (@(request.User?.Email ?? "N/A"))</dd>
                                                    <dt class="col-sm-3">Course:</dt>
                                                    <dd class="col-sm-9">@(request.Course?.Title ?? request.CustomCourseTitle ?? "Custom course")</dd>
                                                    <dt class="col-sm-3">Status:</dt>
                                                    <dd class="col-sm-9">@request.Status</dd>
                                                    <dt class="col-sm-3">Requested:</dt>
                                                    <dd class="col-sm-9">@request.CreatedAt.ToString("dd MMM yyyy HH:mm")</dd>
                                                    <dt class="col-sm-3">Justification:</dt>
                                                    <dd class="col-sm-9">@(request.Justification ?? "N/A")</dd>
                                                    @if (!string.IsNullOrEmpty(request.ProfessionAlignment))
                                                    {
                                                        <dt class="col-sm-3">Profession alignment:</dt>
                                                        <dd class="col-sm-9">@request.ProfessionAlignment</dd>
                                                    }
                                                    @if (!string.IsNullOrEmpty(request.ApproverComments))
                                                    {
                                                        <dt class="col-sm-3">Approver comments:</dt>
                                                        <dd class="col-sm-9">@request.ApproverComments</dd>
                                                    }
                                                </dl>
                                            </div>
                                            <div class="modal-footer">
                                                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-3">
                        <p class="text-muted mb-0">No training requests found.</p>
                    </div>
                }
            </div>
                </div>
            </div>
        </div>
    </div>
</section>

