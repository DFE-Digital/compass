@{
    ViewData["Title"] = "Training gaps";
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" style="color: #005ea5; text-decoration: none;">Learning & Skills</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Training gaps</li>
        </ol>
    </nav>
}

<div class="dashboard-header">
    <div>
        <h1>Training gaps</h1>
        <p>Identify training gaps and plan workforce development</p>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Users with capability gaps</h3>
                    </div>
                    <div class="card-body p-0">
                        @if (ViewBag.UsersWithGaps != null && ((List<Compass.Models.UserProfessionalProfile>)ViewBag.UsersWithGaps).Any())
                        {
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>User</th>
                                        <th>Profession</th>
                                        <th>Gaps</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var profile in (List<Compass.Models.UserProfessionalProfile>)ViewBag.UsersWithGaps)
                                    {
                                        <tr>
                                            <td>@(profile.User?.Name ?? "Unknown")</td>
                                            <td>@(profile.Profession ?? "N/A")</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(profile.CapabilityGaps))
                                                {
                                                    <span title="@profile.CapabilityGaps">
                                                        @(profile.CapabilityGaps.Length > 50 ? profile.CapabilityGaps.Substring(0, 50) + "..." : profile.CapabilityGaps)
                                                    </span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="p-3">
                                <p class="text-muted mb-0">No users with identified capability gaps.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Users with no recent training</h3>
                        <small class="text-muted">No training in last 12 months</small>
                    </div>
                    <div class="card-body p-0">
                        @if (ViewBag.UsersWithNoRecentTraining != null && ((List<Compass.Models.User>)ViewBag.UsersWithNoRecentTraining).Any())
                        {
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>User</th>
                                        <th>Email</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in (List<Compass.Models.User>)ViewBag.UsersWithNoRecentTraining)
                                    {
                                        <tr>
                                            <td>@user.Name</td>
                                            <td>@user.Email</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="p-3">
                                <p class="text-muted mb-0">All users have recent training records.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

