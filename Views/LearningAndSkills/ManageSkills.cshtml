@{
    ViewData["Title"] = "Manage skills and learning";
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" style="color: #005ea5; text-decoration: none;">Learning & Skills</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Manage skills</li>
        </ol>
    </nav>
}

<div class="dashboard-header">
    <div>
        <h1>Manage skills and learning</h1>
        <p>Track profession-level capability development</p>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Profession-level statistics</h3>
            </div>
            <div class="card-body p-0">
                @if (ViewBag.Professions != null)
                {
                    var professionsList = ViewBag.Professions as System.Collections.IEnumerable;
                    var hasProfessions = professionsList != null && professionsList.Cast<dynamic>().Any();
                    if (hasProfessions)
                    {
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Profession</th>
                                    <th>Total users</th>
                                    <th>Users with training</th>
                                    <th>Training coverage</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (dynamic profession in professionsList)
                                {
                                    var coverage = profession.UserCount > 0 ? (profession.UsersWithTraining * 100.0 / profession.UserCount) : 0;
                                    <tr>
                                        <td><strong>@profession.Profession</strong></td>
                                        <td>@profession.UserCount</td>
                                        <td>@profession.UsersWithTraining</td>
                                        <td>
                                            <div class="progress" style="height: 20px;">
                                                <div class="progress-bar @(coverage >= 80 ? "bg-success" : coverage >= 50 ? "bg-warning" : "bg-danger")" 
                                                     role="progressbar" 
                                                     style="width: @coverage%" 
                                                     aria-valuenow="@coverage" 
                                                     aria-valuemin="0" 
                                                     aria-valuemax="100">
                                                    @coverage.ToString("F1")%
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="p-3">
                            <p class="text-muted mb-0">No profession data available.</p>
                        </div>
                    }
                }
                else
                {
                    <div class="p-3">
                        <p class="text-muted mb-0">No profession data available.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

