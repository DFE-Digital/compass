@model Compass.Models.UserInfoViewModel
@{
    ViewData["Title"] = "User information";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">User information</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item active">User information</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (Model.IsAuthenticated)
        {
            <div class="row">
                <div class="col-xxl-12 col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Microsoft Entra ID account details</h3>
                        </div>
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-xxl-3 col-xl-3 col-lg-3 col-md-3 col-sm-12 col-12">
                                    <strong>Display name:</strong>
                                </div>
                                <div class="col-xxl-9 col-xl-9 col-lg-9 col-md-9 col-sm-12 col-12">
                                    @(Model.Name ?? "Not available")
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-xxl-3 col-xl-3 col-lg-3 col-md-3 col-sm-12 col-12">
                                    <strong>Email:</strong>
                                </div>
                                <div class="col-xxl-9 col-xl-9 col-lg-9 col-md-9 col-sm-12 col-12">
                                    @(Model.Email ?? "Not available")
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.UserPrincipalName))
                            {
                                <div class="row mb-3">
                                    <div class="col-xxl-3 col-xl-3 col-lg-3 col-md-3 col-sm-12 col-12">
                                        <strong>User principal name:</strong>
                                    </div>
                                    <div class="col-xxl-9 col-xl-9 col-lg-9 col-md-9 col-sm-12 col-12">
                                        @Model.UserPrincipalName
                                    </div>
                                </div>
                            }
                            <div class="row mb-3">
                                <div class="col-xxl-3 col-xl-3 col-lg-3 col-md-3 col-sm-12 col-12">
                                    <strong>Object ID:</strong>
                                </div>
                                <div class="col-xxl-9 col-xl-9 col-lg-9 col-md-9 col-sm-12 col-12">
                                    <code>@(Model.ObjectId ?? "Not available")</code>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-xxl-3 col-xl-3 col-lg-3 col-md-3 col-sm-12 col-12">
                                    <strong>Tenant ID:</strong>
                                </div>
                                <div class="col-xxl-9 col-xl-9 col-lg-9 col-md-9 col-sm-12 col-12">
                                    <code>@(Model.TenantId ?? "Not available")</code>
                                </div>
                            </div>
                            @if (Model.Roles != null && Model.Roles.Any())
                            {
                                <div class="row mb-3">
                                    <div class="col-xxl-3 col-xl-3 col-lg-3 col-md-3 col-sm-12 col-12">
                                        <strong>Roles:</strong>
                                    </div>
                                    <div class="col-xxl-9 col-xl-9 col-lg-9 col-md-9 col-sm-12 col-12">
                                        @foreach (var role in Model.Roles)
                                        {
                                            <span class="badge badge-primary mr-1">@role</span>
                                        }
                                    </div>
                                </div>
                            }
                            <div class="row mb-3">
                                <div class="col-xxl-3 col-xl-3 col-lg-3 col-md-3 col-sm-12 col-12">
                                    <strong>Authentication status:</strong>
                                </div>
                                <div class="col-xxl-9 col-xl-9 col-lg-9 col-md-9 col-sm-12 col-12">
                                    <span class="badge badge-success">
                                        <i class="fas fa-check-circle"></i> Authenticated via Microsoft Entra ID
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Authentication claims</h3>
                            <div class="card-tools">
                                <button type="button" class="btn btn-tool" data-card-widget="collapse" title="Collapse">
                                    <i class="fas fa-minus"></i>
                                </button>
                            </div>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover text-nowrap">
                                <thead>
                                    <tr>
                                        <th>Claim type</th>
                                        <th>Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Claims != null && Model.Claims.Any())
                                    {
                                        @foreach (var claim in Model.Claims)
                                        {
                                            <tr>
                                                <td><code>@claim.Key</code></td>
                                                <td>@claim.Value</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="2" class="text-center">No claims available</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                <h4><i class="icon fas fa-exclamation-triangle"></i> Not authenticated</h4>
                You are not currently signed in. Please sign in to view your user information.
            </div>
        }
    </div>
</section>

