@{ var apiDocsStylesNonce = Context.Items["Nonce"]?.ToString() ?? ""; }
<style nonce="@apiDocsStylesNonce">
    /* =================================================================
       API documentation styles.
       Designed to render inside Views/Docs/_DocShell.cshtml (the
       AISS-style Stripe-inspired shell). All colours are driven by the
       --dd-* CSS custom properties set on .developers-doc-app--theme-dark
       and --theme-light, with fallback values so the styles still work
       outside the shell (e.g. on legacy pages).
       ================================================================= */

    /* ---------- Endpoint cards ---------- */
    .api-endpoint {
        border: 1px solid var(--dd-border, #e1e4e8);
        background: var(--dd-bg-elevated, #ffffff);
        color: var(--dd-text, inherit);
        border-radius: 6px;
        margin-bottom: 1.5rem;
        overflow: hidden;
    }

    .api-endpoint-header {
        background: var(--dd-bg-toolbar, #f6f8fa);
        color: var(--dd-text, inherit);
        padding: 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: background 0.2s;
    }

    .api-endpoint-header:hover {
        background: var(--dd-accent-soft, #e1e4e8);
    }

    .api-endpoint-header:focus-visible {
        outline: 3px solid var(--dd-focus, #ffdd00);
        outline-offset: -3px;
        background: var(--dd-accent-soft, #e1e4e8);
    }

    .api-endpoint.active .api-endpoint-header {
        background: var(--dd-bg-elevated, #ffffff);
        border-bottom: 1px solid var(--dd-border, #e1e4e8);
    }

    /* Show / Hide details hint + CSS chevron — only rendered once the
       enhancement script has wired up click handlers. */
    .api-endpoint--enhanced .api-endpoint-header::after {
        content: "Show details";
        margin-left: auto;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8125rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: var(--dd-text-muted, #586069);
        white-space: nowrap;
    }

    .api-endpoint--enhanced.active .api-endpoint-header::after {
        content: "Hide details";
        color: var(--dd-accent, #0366d6);
    }

    .api-endpoint--enhanced .api-endpoint-header::before {
        content: "";
        order: 99;
        width: 0.55rem;
        height: 0.55rem;
        border-right: 2px solid currentColor;
        border-bottom: 2px solid currentColor;
        color: var(--dd-text-muted, #586069);
        transform: rotate(45deg);
        transform-origin: 60% 60%;
        transition: transform 0.18s ease, color 0.18s ease;
        flex: 0 0 auto;
    }

    .api-endpoint--enhanced.active .api-endpoint-header::before {
        transform: rotate(-135deg);
        color: var(--dd-accent, #0366d6);
    }

    .api-endpoint--enhanced .api-endpoint-header > .ml-auto {
        display: none;
    }

    .api-endpoint-body {
        padding: 1.5rem;
        display: none;
        color: var(--dd-text, inherit);
    }

    .api-endpoint.active .api-endpoint-body {
        display: block;
    }

    /* ---------- HTTP method pills ---------- */
    .api-method {
        font-weight: 700;
        font-size: 0.875rem;
        padding: 0.25rem 0.75rem;
        border-radius: 4px;
        text-transform: uppercase;
        font-family: 'Courier New', monospace;
        color: #ffffff;
    }

    .api-method-get { background: #1f6feb; }
    .api-method-post { background: #2ea043; }
    .api-method-put { background: #d29922; }
    .api-method-delete { background: #da3633; }

    .api-path {
        font-family: 'Courier New', monospace;
        font-size: 1rem;
        font-weight: 500;
        color: var(--dd-text, inherit);
        flex: 1;
        word-break: break-all;
    }

    /* ---------- Section tabs (Bootstrap nav-tabs) ---------- */
    .api-section-tabs {
        border-bottom: 1px solid var(--dd-border, #e1e4e8);
        margin-bottom: 1rem;
        list-style: none;
        padding: 0;
        display: flex;
        gap: 0;
    }

    .api-section-tabs .nav-item {
        margin: 0;
    }

    .api-section-tabs .nav-link {
        display: inline-block;
        border: none;
        background: transparent;
        color: var(--dd-text-muted, #586069);
        padding: 0.5rem 1rem;
        border-bottom: 2px solid transparent;
        text-decoration: none;
        cursor: pointer;
        font: inherit;
        font-weight: 600;
    }

    .api-section-tabs .nav-link:hover {
        color: var(--dd-text, inherit);
        background: var(--dd-accent-soft, rgba(29, 112, 184, 0.08));
    }

    .api-section-tabs .nav-link:focus-visible {
        outline: 3px solid var(--dd-focus, #ffdd00);
        outline-offset: -3px;
    }

    .api-section-tabs .nav-link.active {
        color: var(--dd-accent, #0366d6);
        border-bottom-color: var(--dd-accent, #0366d6);
        background: transparent;
    }

    /* ---------- Parameter tables ---------- */
    .api-param-table {
        width: 100%;
        font-size: 0.875rem;
        color: var(--dd-text, inherit);
        border-collapse: collapse;
    }

    .api-param-table th {
        background: var(--dd-bg-toolbar, #f6f8fa);
        color: var(--dd-text, inherit);
        padding: 0.5rem;
        font-weight: 600;
        text-align: left;
        border-bottom: 1px solid var(--dd-border, #e1e4e8);
    }

    .api-param-table td {
        padding: 0.5rem;
        border-top: 1px solid var(--dd-border, #e1e4e8);
        vertical-align: top;
        color: var(--dd-text, inherit);
    }

    .api-param-name {
        font-family: 'Courier New', monospace;
        font-weight: 600;
        color: var(--dd-text, inherit);
    }

    .api-param-type {
        font-family: 'Courier New', monospace;
        color: var(--dd-accent, #6f42c1);
        font-size: 0.8125rem;
    }

    .api-param-required {
        color: #ff6b6b;
        font-size: 0.75rem;
        font-weight: 600;
    }

    /* ---------- Code blocks ---------- */
    .api-code-block {
        background: var(--dd-code-bg, #f6f8fa);
        border: 1px solid var(--dd-code-border, #e1e4e8);
        color: var(--dd-text, inherit);
        border-radius: 6px;
        padding: 1rem;
        margin: 1rem 0;
        font-family: 'Courier New', monospace;
        font-size: 0.875rem;
        overflow-x: auto;
    }

    .api-code-block pre {
        margin: 0;
        background: transparent;
        border: none;
        color: inherit;
        white-space: pre-wrap;
        word-break: break-word;
    }

    /* ---------- Response status chips ---------- */
    .api-response-code {
        display: inline-block;
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        font-family: 'Courier New', monospace;
        font-weight: 600;
        font-size: 0.875rem;
        border: 1px solid transparent;
    }

    .api-response-200,
    .api-response-201 {
        background: rgba(46, 160, 67, 0.15);
        color: #6fdd8b;
        border-color: rgba(46, 160, 67, 0.35);
    }

    .api-response-400,
    .api-response-404 {
        background: rgba(218, 54, 51, 0.15);
        color: #ff7b72;
        border-color: rgba(218, 54, 51, 0.35);
    }

    .api-response-401 {
        background: rgba(210, 153, 34, 0.15);
        color: #f1c45a;
        border-color: rgba(210, 153, 34, 0.35);
    }

    /* Light theme variants — better contrast on white surfaces */
    .developers-doc-app--theme-light .api-response-200,
    .developers-doc-app--theme-light .api-response-201 {
        background: #d4edda;
        color: #155724;
        border-color: rgba(21, 87, 36, 0.2);
    }

    .developers-doc-app--theme-light .api-response-400,
    .developers-doc-app--theme-light .api-response-404 {
        background: #f8d7da;
        color: #721c24;
        border-color: rgba(114, 28, 36, 0.2);
    }

    .developers-doc-app--theme-light .api-response-401 {
        background: #fff3cd;
        color: #856404;
        border-color: rgba(133, 100, 4, 0.2);
    }

    .developers-doc-app--theme-light .api-param-required {
        color: #d73a49;
    }

    /* ---------- Badges ---------- */
    .api-badge {
        display: inline-block;
        padding: 0.25rem 0.5rem;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .api-badge-beta {
        background: rgba(210, 153, 34, 0.2);
        color: #f1c45a;
    }

    .developers-doc-app--theme-light .api-badge-beta {
        background: #ffeaa7;
        color: #856404;
    }

    /* ---------- Try-It panel ---------- */
    .try-it-section {
        background: var(--dd-bg-elevated, #f6f8fa);
        border: 1px solid var(--dd-border, #e1e4e8);
        color: var(--dd-text, inherit);
        border-radius: 6px;
        padding: 1rem;
        margin-top: 1rem;
    }

    .try-it-input {
        font-family: 'Courier New', monospace;
        font-size: 0.875rem;
    }

    /* =================================================================
       Bootstrap-style fallback rules.
       The _ApiDocsBody partial was originally written for AdminLTE +
       Bootstrap. The new docs shell does not load Bootstrap, so without
       these rules alerts, tabs and tables render as unstyled HTML.
       Scoped to .developers-doc-app so they cannot leak into other
       pages.
       ================================================================= */
    .developers-doc-app .doc-page-title {
        color: var(--dd-text);
        font-size: clamp(1.75rem, 2.5vw, 2.25rem);
        font-weight: 700;
        line-height: 1.2;
        letter-spacing: -0.02em;
        margin: 0 0 1rem;
    }

    .developers-doc-app .doc-page-lead {
        color: var(--dd-text-muted);
        font-size: 1.125rem;
        line-height: 1.6;
        margin: 0 0 2rem;
        max-width: 75ch;
    }

    .developers-doc-app h2,
    .developers-doc-app h3,
    .developers-doc-app h4,
    .developers-doc-app h5,
    .developers-doc-app h6 {
        color: var(--dd-text);
    }

    .developers-doc-app h2 {
        font-size: 1.5rem;
        margin: 2.5rem 0 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--dd-border);
        scroll-margin-top: 4rem;
    }

    .developers-doc-app h3 {
        font-size: 1.25rem;
        margin: 2rem 0 0.75rem;
        scroll-margin-top: 4rem;
    }

    .developers-doc-app h4,
    .developers-doc-app h5,
    .developers-doc-app h6 {
        font-size: 1rem;
        margin: 1.25rem 0 0.5rem;
    }

    .developers-doc-app p,
    .developers-doc-app li {
        color: var(--dd-text);
        line-height: 1.6;
    }

    .developers-doc-app a {
        color: var(--dd-accent);
    }

    .developers-doc-app a:hover {
        color: var(--dd-accent-hover);
    }

    .developers-doc-app hr {
        border: 0;
        border-top: 1px solid var(--dd-border);
        margin: 2rem 0;
    }

    /* Inline code inside paragraphs, lists, tables, etc. */
    .developers-doc-app :not(pre) > code {
        background: var(--dd-code-bg);
        border: 1px solid var(--dd-code-border);
        color: var(--dd-text);
        padding: 0.1rem 0.35rem;
        border-radius: 3px;
        font-size: 0.875em;
        font-family: 'Courier New', Courier, monospace;
    }

    /* Bootstrap alerts (alert, alert-info, alert-warning, alert-primary) */
    .developers-doc-app .alert {
        position: relative;
        padding: 1rem 1.25rem;
        margin: 1rem 0;
        border: 1px solid var(--dd-border);
        border-left-width: 4px;
        border-radius: 4px;
        background: var(--dd-bg-elevated);
        color: var(--dd-text);
    }

    .developers-doc-app .alert > :last-child { margin-bottom: 0; }

    .developers-doc-app .alert-info {
        border-left-color: var(--dd-accent);
        background: var(--dd-accent-soft);
    }

    .developers-doc-app .alert-warning {
        border-left-color: #d29922;
        background: rgba(210, 153, 34, 0.12);
    }

    .developers-doc-app .alert-danger {
        border-left-color: #da3633;
        background: rgba(218, 54, 51, 0.12);
    }

    .developers-doc-app .alert-success,
    .developers-doc-app .alert-primary {
        border-left-color: #2ea043;
        background: rgba(46, 160, 67, 0.12);
    }

    /* Bootstrap tabs (nav nav-tabs + tab-content/tab-pane).
       JavaScript-driven activation is preserved via .active. */
    .developers-doc-app .nav.nav-tabs {
        list-style: none;
        padding: 0;
        margin: 1rem 0 0;
        display: flex;
        gap: 0;
    }

    .developers-doc-app .tab-content > .tab-pane {
        display: none;
    }

    .developers-doc-app .tab-content > .tab-pane.active,
    .developers-doc-app .tab-content > .tab-pane.show.active {
        display: block;
    }

    /* Bootstrap tables (table, table-bordered) */
    .developers-doc-app table.table {
        width: 100%;
        margin: 1rem 0;
        border-collapse: collapse;
        color: var(--dd-text);
    }

    .developers-doc-app table.table th,
    .developers-doc-app table.table td {
        padding: 0.5rem 0.75rem;
        text-align: left;
        vertical-align: top;
        border-top: 1px solid var(--dd-border);
        color: var(--dd-text);
    }

    .developers-doc-app table.table thead th {
        background: var(--dd-bg-toolbar);
        border-bottom: 2px solid var(--dd-border);
        font-weight: 600;
    }

    .developers-doc-app table.table-bordered,
    .developers-doc-app table.table-bordered th,
    .developers-doc-app table.table-bordered td {
        border: 1px solid var(--dd-border);
    }

    .developers-doc-app table.table tbody tr:nth-child(odd) td {
        background: var(--dd-row-alt);
    }

    /* Bootstrap utility classes used in the body */
    .developers-doc-app .mt-3 { margin-top: 1rem !important; }
    .developers-doc-app .mt-4 { margin-top: 1.5rem !important; }
    .developers-doc-app .mt-5 { margin-top: 2rem !important; }
    .developers-doc-app .mb-0 { margin-bottom: 0 !important; }
    .developers-doc-app .my-4 { margin-top: 1.5rem !important; margin-bottom: 1.5rem !important; }
    .developers-doc-app .ml-auto { margin-left: auto !important; }
    .developers-doc-app .small,
    .developers-doc-app small { font-size: 0.875em; }
    .developers-doc-app .text-muted { color: var(--dd-text-muted) !important; }

    /* Hide AdminLTE chevron icons (FontAwesome isn't loaded inside the
       new shell). The endpoint cards still expand/collapse via the
       existing inline script. */
    .developers-doc-app .api-endpoint-header .fas,
    .developers-doc-app .api-endpoint-header .fa {
        display: none;
    }
</style>
