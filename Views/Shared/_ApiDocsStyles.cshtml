@{ var apiDocsStylesNonce = Context.Items["Nonce"]?.ToString() ?? ""; }
<style nonce="@apiDocsStylesNonce">
    /* API Documentation Specific Styles */
    .api-endpoint {
        border: 1px solid #e1e4e8;
        border-radius: 6px;
        margin-bottom: 1.5rem;
        overflow: hidden;
    }
    
    .api-endpoint-header {
        background: #f6f8fa;
        padding: 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: background 0.2s;
    }
    
    .api-endpoint-header:hover {
        background: #e1e4e8;
    }
    
    .api-method {
        font-weight: 700;
        font-size: 0.875rem;
        padding: 0.25rem 0.75rem;
        border-radius: 4px;
        text-transform: uppercase;
        font-family: 'Courier New', monospace;
    }
    
    .api-method-get {
        background: #61affe;
        color: white;
    }
    
    .api-method-post {
        background: #49cc90;
        color: white;
    }
    
    .api-method-put {
        background: #fca130;
        color: white;
    }
    
    .api-method-delete {
        background: #f93e3e;
        color: white;
    }
    
    .api-path {
        font-family: 'Courier New', monospace;
        font-size: 1rem;
        font-weight: 500;
        flex: 1;
    }
    
    .api-endpoint-body {
        padding: 1.5rem;
        display: none;
    }
    
    .api-endpoint.active .api-endpoint-body {
        display: block;
    }
    
    .api-endpoint.active .api-endpoint-header {
        background: #fff;
        border-bottom: 1px solid #e1e4e8;
    }
    
    .api-section-tabs {
        border-bottom: 1px solid #e1e4e8;
        margin-bottom: 1rem;
    }
    
    .api-section-tabs .nav-link {
        border: none;
        color: #586069;
        padding: 0.5rem 1rem;
        border-bottom: 2px solid transparent;
    }
    
    .api-section-tabs .nav-link.active {
        color: #0366d6;
        border-bottom-color: #0366d6;
    }
    
    .api-param-table {
        width: 100%;
        font-size: 0.875rem;
    }
    
    .api-param-table th {
        background: #f6f8fa;
        padding: 0.5rem;
        font-weight: 600;
    }
    
    .api-param-table td {
        padding: 0.5rem;
        border-top: 1px solid #e1e4e8;
        vertical-align: top;
    }
    
    .api-param-name {
        font-family: 'Courier New', monospace;
        font-weight: 600;
    }
    
    .api-param-type {
        font-family: 'Courier New', monospace;
        color: #6f42c1;
        font-size: 0.8125rem;
    }
    
    .api-param-required {
        color: #d73a49;
        font-size: 0.75rem;
        font-weight: 600;
    }
    
    .api-code-block {
        background: #f6f8fa;
        border: 1px solid #e1e4e8;
        border-radius: 6px;
        padding: 1rem;
        margin: 1rem 0;
        font-family: 'Courier New', monospace;
        font-size: 0.875rem;
        overflow-x: auto;
    }
    
    .api-code-block pre {
        margin: 0;
        background: transparent;
        border: none;
    }
    
    .api-response-code {
        display: inline-block;
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        font-family: 'Courier New', monospace;
        font-weight: 600;
        font-size: 0.875rem;
    }
    
    .api-response-200 {
        background: #d4edda;
        color: #155724;
    }
    
    .api-response-201 {
        background: #d4edda;
        color: #155724;
    }
    
    .api-response-400 {
        background: #f8d7da;
        color: #721c24;
    }
    
    .api-response-401 {
        background: #fff3cd;
        color: #856404;
    }
    
    .api-response-404 {
        background: #f8d7da;
        color: #721c24;
    }
    
    .api-badge {
        display: inline-block;
        padding: 0.25rem 0.5rem;
        border-radius: 12px;
        font-size: 0.75rem;
        font-weight: 600;
    }
    
    .api-badge-beta {
        background: #ffeaa7;
        color: #856404;
    }
    
    .try-it-section {
        background: #f6f8fa;
        border: 1px solid #e1e4e8;
        border-radius: 6px;
        padding: 1rem;
        margin-top: 1rem;
    }
    
    .try-it-input {
        font-family: 'Courier New', monospace;
        font-size: 0.875rem;
    }
</style>
