@model Compass.Models.ChromeRagSnapshot?
@using Compass.Models
@{
    string RagBadgeClass(string? name) {
        if (string.IsNullOrEmpty(name)) return "rag-badge rag-none";
        var n = (name ?? "").ToLowerInvariant();
        if (n.Contains("green")) return "rag-badge rag-green";
        if (n.Contains("amber") && n.Contains("red")) return "rag-badge rag-amber-red";
        if (n.Contains("red")) return "rag-badge rag-red";
        if (n.Contains("amber")) return "rag-badge rag-amber";
        return "rag-badge rag-none";
    }
    var rs = Model?.RagStatus;
    var name = rs?.Name;
}
@if (rs != null && (!string.IsNullOrEmpty(rs.BackgroundColourKey) || !string.IsNullOrEmpty(rs.TextColourKey)))
{
    <span class="rag-badge" style="@(string.IsNullOrEmpty(rs.BackgroundColourKey) ? "" : "background-color: var(--govuk-colour-" + rs.BackgroundColourKey + ");")@(string.IsNullOrEmpty(rs.TextColourKey) ? "" : " color: var(--govuk-colour-" + rs.TextColourKey + ");")">@(name ?? "—")</span>
}
else if (!string.IsNullOrEmpty(name))
{
    <span class="@RagBadgeClass(name)">@name</span>
}
else
{
    <span class="rag-badge rag-none">—</span>
}
