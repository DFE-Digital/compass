@model Compass.Models.ChromeRagSnapshot?
@using Compass.Models.Modern.Work
@{
    var rs = Model?.RagStatus;
    var name = rs?.Name;
    var badgeClass = WorkBadgeCss.RagDfeFrontendBadgeClass(rs?.CssClass, string.IsNullOrEmpty(name) ? "—" : name);
    var label = string.IsNullOrEmpty(name) ? "—" : name.ToUpperInvariant();
}
<span class="@badgeClass">@label</span>
