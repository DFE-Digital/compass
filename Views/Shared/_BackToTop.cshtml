@{
    var nonce = Context.Items["Nonce"]?.ToString() ?? "";
}

<div id="compass-back-to-top" class="compass-back-to-top" hidden>
  <button type="button" class="compass-back-to-top__button" aria-label="Back to top">
    Back to top
  </button>
</div>

<style>
  .compass-back-to-top {
    position: fixed;
    right: 1rem;
    bottom: 1rem;
    z-index: 900;
  }

  .compass-back-to-top__button {
    border: 0;
    border-radius: 999px;
    background: #1d70b8;
    color: #fff;
    font: inherit;
    font-weight: 600;
    line-height: 1;
    padding: 0.7rem 1rem;
    cursor: pointer;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2);
  }

  .compass-back-to-top__button:hover {
    background: #003078;
  }

  .compass-back-to-top__button:focus {
    outline: 3px solid #fd0;
    outline-offset: 2px;
    box-shadow: none;
  }
</style>

<script nonce="@nonce">
  (function () {
    var container = document.getElementById('compass-back-to-top');
    if (!container) return;

    var button = container.querySelector('.compass-back-to-top__button');
    if (!button) return;

    function updateVisibility() {
      var doc = document.documentElement;
      var scrollTop = window.pageYOffset || doc.scrollTop || 0;
      var scrollable = (doc.scrollHeight - window.innerHeight) > 500;
      container.hidden = !(scrollable && scrollTop > 300);
    }

    button.addEventListener('click', function () {
      window.scrollTo({ top: 0, behavior: 'smooth' });
      var main = document.getElementById('main-content');
      if (main && typeof main.focus === 'function') {
        if (!main.hasAttribute('tabindex')) main.setAttribute('tabindex', '-1');
        main.focus({ preventScroll: true });
      }
    });

    window.addEventListener('scroll', updateVisibility, { passive: true });
    window.addEventListener('resize', updateVisibility);
    updateVisibility();
  })();
</script>
