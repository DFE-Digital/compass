@*
 * Shared Top Navigation Bar
 * Used by both _Layout.cshtml and _AdminLayout.cshtml
 *@

@using System
@using Compass.Services
@using Compass.Data
@inject IConfiguration Configuration
@inject IPermissionService PermissionService
@inject CompassDbContext DbContext


@{
    Compass.Models.User? currentUser = null;
    string? userPhotoDataUrl = null;
    string? currentUserDisplayName = User.Identity?.Name;
    string? currentUserEmail = null;
    bool hasAdminRole = false;
    int taskCount = 0;
    
    var controllerName = ViewContext.RouteData.Values["Controller"]?.ToString();
    var actionName = ViewContext.RouteData.Values["Action"]?.ToString();
    var isDdtReportsController = controllerName == "DdtReports";
    var reportActions = new[] { "Index", "AllCmsData" };
    var isReportAction = controllerName == "DdtReports" && reportActions.Contains(actionName ?? string.Empty);
    var isAnalysisController = controllerName == "Analysis";
    var analysisActions = new[] { "Delivery", "Operational", "ServiceStandards", "Index" };
    var isAnalysisAction = isAnalysisController && analysisActions.Contains(actionName ?? string.Empty);
    // Combined Analysis section includes both DdtReports and Analysis
    var isAnalysisSection = isDdtReportsController || isAnalysisController;
    var isHelpController = controllerName == "Help";

    try
    {
        currentUserEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
            ?? User.Identity?.Name
            ?? string.Empty;

        if (!string.IsNullOrEmpty(currentUserEmail))
        {
            currentUser = DbContext.Users
                .FirstOrDefault(u => u.Email.ToLower() == currentUserEmail.ToLower());

            if (currentUser != null)
            {
                currentUserDisplayName = currentUser.Name;
                hasAdminRole = currentUser.Role == UserRole.Admin ||
                    currentUser.Role == UserRole.SuperAdmin;

                if (currentUser.Photo != null && currentUser.Photo.Length > 0)
                {
                    userPhotoDataUrl = $"data:image/png;base64,{Convert.ToBase64String(currentUser.Photo)}";
                }
                
                // Calculate task count
                try
                {
                    var userProjects = DbContext.Projects
                        .Where(p => !p.IsDeleted && (
                            p.PrimaryContactUserId == currentUser.Id ||
                            p.SeniorResponsibleOfficers.Any(sro => sro.UserId == currentUser.Id) ||
                            p.ServiceOwners.Any(so => so.UserId == currentUser.Id)
                        ))
                        .Include(p => p.ProjectContacts)
                        .Include(p => p.SeniorResponsibleOfficers)
                        .Include(p => p.ServiceOwners)
                        .Include(p => p.Directorates)
                        .Include(p => p.BudgetOwners)
                        .AsNoTracking()
                        .ToList();
                    
                    foreach (var project in userProjects)
                    {
                        var currentTeamMembers = project.ProjectContacts
                            .Where(pc => string.IsNullOrEmpty(pc.TeamStatus) || 
                                         pc.TeamStatus.ToLower() == "current")
                            .ToList();
                        if (!currentTeamMembers.Any()) taskCount++;
                        if (!project.SeniorResponsibleOfficers.Any()) taskCount++;
                        if (!project.Directorates.Any()) taskCount++;
                        if (project.ActivityTypeLookupId == null) taskCount++;
                        if (string.IsNullOrWhiteSpace(project.RagStatus)) taskCount++;
                        if (project.BusinessAreaId == null) taskCount++;
                        if (string.IsNullOrWhiteSpace(project.Aim)) taskCount++;
                        if (project.PrimaryContactUserId == null) taskCount++;
                        if (!project.BudgetOwners.Any()) taskCount++;
                    }
                }
                catch
                {
                    // Non-blocking: task count will remain 0
                }
            }
        }
    }
    catch
    {
        // Non-blocking: fallback handled below.
    }

    // Additional admin role checks
    if (!hasAdminRole && User?.Identity?.IsAuthenticated == true)
    {
        var roleClaims = User.FindAll(System.Security.Claims.ClaimTypes.Role)
            .Concat(User.FindAll("role"))
            .Concat(User.FindAll("roles"))
            .Select(c => c.Value)
            .Distinct()
            .ToList();

        var validRoles = new[] { "super_admin", "admin", "Super admin", "SuperAdmin", "Admin", "Super Admin" };
        hasAdminRole = validRoles.Any(role =>
            User.IsInRole(role) ||
            roleClaims.Any(rc => rc.Equals(role, StringComparison.OrdinalIgnoreCase)));

        if (!hasAdminRole)
        {
            hasAdminRole = roleClaims.Any(role =>
                role.Contains("super", StringComparison.OrdinalIgnoreCase) &&
                role.Contains("admin", StringComparison.OrdinalIgnoreCase));
        }

        if (!hasAdminRole)
        {
            var fallbackEmail = User.Identity?.Name
                ?? User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                ?? User.FindFirst("preferred_username")?.Value
                ?? User.FindFirst("email")?.Value
                ?? string.Empty;

            if (!string.IsNullOrEmpty(fallbackEmail))
            {
                try
                {
                    var user = DbContext.Users
                        .FirstOrDefault(u => u.Email.ToLower() == fallbackEmail.ToLower());

                    if (user != null)
                    {
                        hasAdminRole = user.Role == UserRole.Admin ||
                            user.Role == UserRole.SuperAdmin;
                    }
                }
                catch
                {
                    // ignore
                }
            }
        }
    }
}

<!-- Navbar -->
<nav class="main-header navbar navbar-expand navbar-white navbar-light navbar-gov">
    <div class="container-fluid">
        <!-- Left navbar links -->
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" data-widget="pushmenu" href="#" role="button" aria-label="Toggle sidebar menu"><i class="fas fa-bars" aria-hidden="true"></i></a>
            </li>
            <li class="nav-item d-none d-sm-inline-block">
                <a href="@Url.Action("Index", "Home")" class="nav-link">Home</a>
            </li>
            <li class="nav-item dropdown d-none d-sm-inline-block">
                <a class="nav-link dropdown-toggle @(isAnalysisSection ? "active" : "")" href="#" id="analysisDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    Analysis
                </a>
                <div class="dropdown-menu" aria-labelledby="analysisDropdown">
                    <h6 class="dropdown-header">Reports</h6>
                    <a class="dropdown-item @(controllerName == "DdtReports" && actionName == "Index" ? "active" : "")" href="@Url.Action("Index", "DdtReports")">
                        Reports overview
                    </a>
                    <div class="dropdown-divider"></div>
                    <h6 class="dropdown-header">Analysis</h6>
                    <a class="dropdown-item @(controllerName == "Analysis" && actionName == "Index" ? "active" : "")" href="@Url.Action("Index", "Analysis")">
                        Analysis overview
                    </a>
                    <a class="dropdown-item @(controllerName == "Analysis" && actionName == "Delivery" ? "active" : "")" href="@Url.Action("Delivery", "Analysis")">
                        Delivery
                    </a>
                    <a class="dropdown-item @(controllerName == "Analysis" && actionName == "Operational" ? "active" : "")" href="@Url.Action("Operational", "Analysis")">
                        Operational
                    </a>
                    <a class="dropdown-item @(controllerName == "Analysis" && actionName == "ServiceStandards" ? "active" : "")" href="@Url.Action("ServiceStandards", "Analysis")">
                        Service Standards
                    </a>
                </div>
            </li>
            <li class="nav-item dropdown d-none d-sm-inline-block">
                <a class="nav-link dropdown-toggle @(isHelpController ? "active" : "")" href="#" id="helpDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                    Help
                </a>
                <div class="dropdown-menu" aria-labelledby="helpDropdown">
                    <a class="dropdown-item @(isHelpController && actionName == "Index" ? "active" : "")" href="@Url.Action("Index", "Help")">
                        How do I...
                    </a>
                </div>
            </li>
            @if (hasAdminRole)
            {
                <li class="nav-item d-none d-sm-inline-block">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")" href="@Url.Action("Index", "Admin")">
                        Admin
                    </a>
                </li>
            }
        </ul>

        <!-- Right navbar links -->
        <ul class="navbar-nav ml-auto">
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle d-flex align-items-center justify-content-center" href="#" id="userDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" aria-label="User menu">
                    @if (!string.IsNullOrEmpty(userPhotoDataUrl))
                    {
                        <img src="@userPhotoDataUrl" alt="User profile" class="navbar-user-avatar" />
                    }
                    else
                    {
                        <div class="navbar-user-avatar d-flex align-items-center justify-content-center">
                            <i class="fas fa-user" aria-hidden="true"></i>
                        </div>
                    }
                </a>
                <div class="dropdown-menu dropdown-menu-right" aria-labelledby="userDropdown">
                    <h6 class="dropdown-header">
                        @(currentUserDisplayName ?? "Signed in user")
                        @if (!string.IsNullOrWhiteSpace(currentUserEmail))
                        {
                            <br />
                            <small class="text-muted">@currentUserEmail</small>
                        }
                    </h6>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "StaffRoleReturn" ? "active" : "")" href="@Url.Action("Index", "StaffRoleReturn")">
                        Role profile
                    </a>
                    <a class="dropdown-item" href="~/User/MySettings">
                        My settings
                    </a>
                    <div class="dropdown-divider"></div>
                    <a class="dropdown-item" href="~/MicrosoftIdentity/Account/SignOut">
                        Sign out
                    </a>
                </div>
            </li>
        </ul>
    </div>
</nav>

