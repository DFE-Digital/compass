    <title>@ViewData["Title"] - COMPASS ADMIN</title>

 <link rel="icon" sizes="any" href="~/images/favicon.svg" type="image/svg+xml">
    <!-- Google Font: Inter -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" nonce="@Context.Items["Nonce"]">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Theme style -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" nonce="@Context.Items["Nonce"]">
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap4.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Select2 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/css/select2.min.css" nonce="@Context.Items["Nonce"]">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/select2-bootstrap-theme/0.1.0-beta.10/select2-bootstrap.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Custom COMPASS theme -->
    <link href="~/css/compass-theme.css" rel="stylesheet" nonce="@Context.Items["Nonce"]" />
    <!-- Custom styles -->
    <link href="~/css/custom.css" rel="stylesheet" nonce="@Context.Items["Nonce"]" />
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="hold-transition sidebar-mini layout-fixed compass-theme">
    <!-- Skip link for keyboard navigation -->
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class="wrapper">

        @{
            Compass.Models.User? currentUser = null;
            string? userPhotoDataUrl = null;
            string? currentUserDisplayName = User.Identity?.Name;
            string? currentUserEmail = null;
            bool hasAdminRole = false;
            
            // Sidebar active state helpers
            var controller = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
            var action = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
            var path = Context.Request.Path.Value ?? "";
            
            // User management
            var isUserManagement = controller == "Admin" && (action.Contains("User") || action == "Users" || path.Contains("/Admin/User"));
            
            // Reporting
            var isPerformanceMetric = controller == "PerformanceMetric";
            var isEnterpriseMetric = controller == "EnterpriseMetric";
            var isReporting = isPerformanceMetric || isEnterpriseMetric;
            
            // Configuration
            var isFunctionalStandard = controller == "FunctionalStandard";
            var isObjective = action.StartsWith("Objective", StringComparison.OrdinalIgnoreCase);
            var isMission = action.StartsWith("Mission", StringComparison.OrdinalIgnoreCase);
            var isFundingSource = action.StartsWith("FundingSource", StringComparison.OrdinalIgnoreCase);
            var isGovernmentDepartment = controller == "GovernmentDepartment";
            var isOrganizational = controller == "Organizational";
            
            // Settings
            var isSettings = action == "Settings" || action == "Index" && controller == "Admin" && path.Contains("/Admin/Settings");
            var isRiskType = action.Contains("RiskType");
            var isRiskTier = action.Contains("RiskTier");
            var isActionSource = action.Contains("ActionSource");
            var isWcag = action.Contains("Wcag");
            var isBusinessArea = action.Contains("BusinessArea") && !action.Contains("Phase");
            var isPhase = action.Contains("Phase") && !action.Contains("PhaseLookup");
            var isGddRole = action.Contains("GddRole");
            var isSkill = action.Contains("Skill");
            var isKpiCategory = action.Contains("KpiCategor");
            var isDeliveryPriority = action.Contains("DeliveryPriorit");
            var isSettingsSection = isSettings || isRiskType || isRiskTier || isActionSource || isWcag || isBusinessArea || isPhase || isGddRole || isSkill || isKpiCategory || isDeliveryPriority;
            
            // RAID
            var isRaidSettings = action == "RaidSettings";
            
            // Apps
            var isAccessibilityService = controller == "AccessibilityService" || path.Contains("/Admin/AccessibilityService");
            var isUserSatisfaction = action.StartsWith("UserSatisfaction", StringComparison.OrdinalIgnoreCase);
            var isApiToken = action.StartsWith("ApiToken") || action.StartsWith("CreateApiToken") || action.StartsWith("ConfigurePermissions") || action.StartsWith("SavePermissions");
            
            // Performance Reporting Management
            var isPerformanceReportingManagement = controller == "PerformanceReportingManagement" || path.Contains("/Admin/PerformanceReportingManagement");
            
            // Group Management
            var isGroupManagement = controller == "GroupManagement" || path.Contains("/Admin/GroupManagement");
        }

