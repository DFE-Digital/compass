                                        <p>Skills</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("KpiCategories", "Admin")" class="nav-link @(isKpiCategory ? "active" : "")" role="menuitem">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>KPI categories</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- RAID -->
                        <li class="nav-header">RAID</li>
                        <li class="nav-item">
                            <a href="@Url.Action("RaidSettings", "Admin")" class="nav-link @(isRaidSettings ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-database" aria-hidden="true"></i>
                                <p>RAID settings</p>
                            </a>
                        </li>

                        <!-- Apps & Services -->
                        <li class="nav-header">Apps & Services</li>
                        <li class="nav-item">
                            <a href="/Admin/AccessibilityService" class="nav-link @(isAccessibilityService ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-universal-access" aria-hidden="true"></i>
                                <p>Accessibility service</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="@Url.Action("UserSatisfaction", "Admin")" class="nav-link @(isUserSatisfaction ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-poll" aria-hidden="true"></i>
                                <p>User satisfaction</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="@Url.Action("ApiTokens", "Admin")" class="nav-link @(isApiToken ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-key" aria-hidden="true"></i>
