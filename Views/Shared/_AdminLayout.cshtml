@*
 * ROUTE: Shared Admin Layout
 * CONTROLLER: N/A (Shared Layout)
 * MODEL: N/A
 * 
 * DESCRIPTION:
 * Main layout template for admin pages in COMPASS.
 * Provides consistent HTML structure with left-hand navigation sidebar.
 * 
 * AUTHOR: Auto-generated
 * CREATED: 2025-01-31
 *@

@using System
@inject IWebHostEnvironment env

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - COMPASS ADMIN</title>

 <link rel="icon" sizes="any" href="~/images/favicon.svg" type="image/svg+xml">
    <!-- Google Font: Inter -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" nonce="@Context.Items["Nonce"]">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Theme style -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" nonce="@Context.Items["Nonce"]">
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap4.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Select2 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/css/select2.min.css" nonce="@Context.Items["Nonce"]">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/select2-bootstrap-theme/0.1.0-beta.10/select2-bootstrap.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Custom COMPASS theme -->
    <link href="~/css/compass-theme.css" rel="stylesheet" nonce="@Context.Items["Nonce"]" />
    <!-- Custom styles -->
    <link href="~/css/custom.css" rel="stylesheet" nonce="@Context.Items["Nonce"]" />
    @if (env.IsProduction())
    {
        <script type="text/javascript" nonce="@Context.Items["Nonce"]">
        (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            t.setAttribute("nonce", "@Context.Items["Nonce"]");
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "ug8dgpkuqz");
        </script>
    }
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="hold-transition sidebar-mini layout-fixed compass-theme">
    <!-- Skip link for keyboard navigation -->
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class="wrapper">

        @{
            // Sidebar active state helpers
            var controller = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
            var action = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
            var path = Context.Request.Path.Value ?? "";
            
            // User management
            var isUserManagement = controller == "Admin" && (action.Contains("User") || action == "Users" || path.Contains("/Admin/User"));
            
            // Reporting
            var isPerformanceMetric = controller == "PerformanceMetric";
            var isEnterpriseMetric = controller == "EnterpriseMetric";
            var isReporting = isPerformanceMetric || isEnterpriseMetric;
            
            // Configuration
            var isFunctionalStandard = controller == "FunctionalStandard";
            var isObjective = action.StartsWith("Objective", StringComparison.OrdinalIgnoreCase);
            var isMission = action.StartsWith("Mission", StringComparison.OrdinalIgnoreCase);
            var isFundingSource = action.StartsWith("FundingSource", StringComparison.OrdinalIgnoreCase);
            var isGovernmentDepartment = controller == "GovernmentDepartment";
            var isOrganizational = controller == "Organizational";
            
            // Settings
            var isSettings = action == "Settings" || action == "Index" && controller == "Admin" && path.Contains("/Admin/Settings");
            var isRiskType = action.Contains("RiskType");
            var isRiskTier = action.Contains("RiskTier");
            var isActionSource = action.Contains("ActionSource");
            var isWcag = action.Contains("Wcag");
            var isBusinessArea = action.Contains("BusinessArea") && !action.Contains("Phase");
            var isPhase = action.Contains("Phase") && !action.Contains("PhaseLookup");
            var isGddRole = action.Contains("GddRole");
            var isSkill = action.Contains("Skill");
            var isKpiCategory = action.Contains("KpiCategor");
            var isDeliveryPriority = action.Contains("DeliveryPriorit");
            var isSettingsSection = isSettings || isRiskType || isRiskTier || isActionSource || isWcag || isBusinessArea || isPhase || isGddRole || isSkill || isKpiCategory || isDeliveryPriority;
            
            // Learning & Development
            var isTrainingCourse = controller == "TrainingCourse" || path.Contains("/Admin/TrainingCourse");
            
            // RAID
            var isRaidSettings = action == "RaidSettings";
            
            // Apps
            var isAccessibilityService = controller == "AccessibilityService" || path.Contains("/Admin/AccessibilityService");
            var isUserSatisfaction = action.StartsWith("UserSatisfaction", StringComparison.OrdinalIgnoreCase);
            var isApiToken = action.StartsWith("ApiToken") || action.StartsWith("CreateApiToken") || action.StartsWith("ConfigurePermissions") || action.StartsWith("SavePermissions");
            
            // Performance Reporting Management
            var isPerformanceReportingManagement = controller == "PerformanceReportingManagement" || path.Contains("/Admin/PerformanceReportingManagement");
            
            // Monthly Update Deadline Config
            var isMonthlyUpdateDeadlineConfig = controller == "MonthlyUpdateDeadlineConfig" || path.Contains("/Admin/MonthlyUpdateDeadlineConfig");
            
            // Group Management
            var isGroupManagement = controller == "GroupManagement" || path.Contains("/Admin/GroupManagement");
        }

        @await Html.PartialAsync("_TopNav")

        <!-- Main Sidebar Container -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <!-- Brand Logo -->
            <a href="@Url.Action("Index", "Home")" class="brand-link">
                <img src="~/images/govuk-crown.svg" alt="GOV.UK Crown" class="brand-image">
                <span class="brand-text ml-2">COMPASS <strong style="color: #ff6b35;">ADMIN</strong></span>
            </a>

            <!-- Sidebar -->
            <div class="sidebar text-md">
                <!-- Sidebar Menu -->
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menubar" data-accordion="false">
                        <!-- Dashboard -->
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "Admin")" class="nav-link @(controller == "Admin" && action == "Index" ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-tachometer-alt" aria-hidden="true"></i>
                                <p>Dashboard</p>
                            </a>
                        </li>

                        <!-- User Management -->
                        <li class="nav-header">User Management</li>
                        <li class="nav-item">
                            <a href="@Url.Action("Users", "Admin")" class="nav-link @(isUserManagement ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-users" aria-hidden="true"></i>
                                <p>Users</p>
                            </a>
                        </li>
                        @if (isGroupManagement)
                        {
                            <li class="nav-item">
                                <a href="@Url.Action("Index", "GroupManagement")" class="nav-link active" role="menuitem">
                                    <i class="nav-icon fas fa-user-friends" aria-hidden="true"></i>
                                    <p>Groups</p>
                                </a>
                            </li>
                        }

                        <!-- Reporting -->
                        <li class="nav-header">Reporting</li>
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "PerformanceMetric")" class="nav-link @(isPerformanceMetric ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-chart-line" aria-hidden="true"></i>
                                <p>Operational reports</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "EnterpriseMetric")" class="nav-link @(isEnterpriseMetric ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-chart-bar" aria-hidden="true"></i>
                                <p>Enterprise metrics</p>
                            </a>
                        </li>
                        @if (isPerformanceReportingManagement)
                        {
                            <li class="nav-item">
                                <a href="@Url.Action("Index", "PerformanceReportingManagement")" class="nav-link active" role="menuitem">
                                    <i class="nav-icon fas fa-cog" aria-hidden="true"></i>
                                    <p>Performance reporting</p>
                                </a>
                            </li>
                        }
                        @if (isMonthlyUpdateDeadlineConfig)
                        {
                            <li class="nav-item">
                                <a href="@Url.Action("Index", "MonthlyUpdateDeadlineConfig")" class="nav-link active" role="menuitem">
                                    <i class="nav-icon fas fa-calendar-check" aria-hidden="true"></i>
                                    <p>Monthly update deadlines</p>
                                </a>
                            </li>
                        }

                        <!-- Configuration -->
                        <li class="nav-header">Configuration</li>
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "FunctionalStandard")" class="nav-link @(isFunctionalStandard ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-book" aria-hidden="true"></i>
                                <p>Functional standards</p>
                            </a>
                        </li>
                        @{
                            var isStandardsConfig = controller == "StandardsConfig";
                            var isStandardProducts = controller == "StandardProducts";
                            var isStandardsManagement = isStandardsConfig || isStandardProducts;
                        }
                        <li class="nav-item @(isStandardsManagement ? "menu-open" : "")">
                            <a href="#" class="nav-link @(isStandardsManagement ? "active" : "")" role="menuitem" aria-haspopup="true" aria-expanded="@(isStandardsManagement ? "true" : "false")">
                                <i class="nav-icon fas fa-compass" aria-hidden="true"></i>
                                <p>
                                    Standards management
                                    <i class="right fas fa-angle-left"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview" role="menu">
                                <li class="nav-item">
                                    <a href="@Url.Action("Index", "StandardsConfig", new { area = "Admin" })" class="nav-link @(isStandardsConfig ? "active" : "")" role="menuitem">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Standards config</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("Index", "StandardProducts", new { area = "Admin" })" class="nav-link @(isStandardProducts ? "active" : "")" role="menuitem">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Standard products</p>
                                    </a>
                                </li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a href="@Url.Action("Objectives", "Admin")" class="nav-link @(isObjective ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-bullseye" aria-hidden="true"></i>
                                <p>Priority outcomes</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="@Url.Action("Missions", "Admin")" class="nav-link @(isMission ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-rocket" aria-hidden="true"></i>
                                <p>Missions</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="@Url.Action("FundingSources", "Admin")" class="nav-link @(isFundingSource ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-pound-sign" aria-hidden="true"></i>
                                <p>Funding sources</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "GovernmentDepartment")" class="nav-link @(isGovernmentDepartment ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-building" aria-hidden="true"></i>
                                <p>Government departments</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "Organizational")" class="nav-link @(isOrganizational ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-sitemap" aria-hidden="true"></i>
                                <p>Organizational structure</p>
                            </a>
                        </li>

                        <!-- Settings -->
                        <li class="nav-header">Settings</li>
                        <li class="nav-item @(isSettingsSection ? "menu-open" : "")">
                            <a href="#" class="nav-link @(isSettingsSection ? "active" : "")" role="menuitem" aria-haspopup="true" aria-expanded="@(isSettingsSection ? "true" : "false")">
                                <i class="nav-icon fas fa-sliders-h" aria-hidden="true"></i>
                                <p>
                                    System settings
                                    <i class="right fas fa-angle-left"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview" role="menu">
                                <li class="nav-item">
                                    <a href="@Url.Action("Settings", "Admin")" class="nav-link @(isSettings && !isSettingsSection ? "active" : "")" role="menuitem">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Settings overview</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("RiskTypes", "Admin")" class="nav-link @(isRiskType ? "active" : "")" role="menuitem">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Risk types</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("RiskTiers", "Admin")" class="nav-link @(isRiskTier ? "active" : "")" role="menuitem">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Risk tiers</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("ActionSources", "Admin")" class="nav-link @(isActionSource ? "active" : "")" role="menuitem">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Action sources</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("DeliveryPriorities", "Admin")" class="nav-link @(isDeliveryPriority ? "active" : "")" role="menuitem">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Delivery priorities</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("WcagCriteria", "Admin")" class="nav-link @(isWcag ? "active" : "")" role="menuitem">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>WCAG criteria</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("BusinessAreas", "Admin")" class="nav-link @(isBusinessArea ? "active" : "")" role="menuitem">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Business areas</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("Phases", "Admin")" class="nav-link @(isPhase ? "active" : "")" role="menuitem">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Phases</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("GddRoles", "Admin")" class="nav-link @(isGddRole ? "active" : "")" role="menuitem">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>GDD roles</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("Skills", "Admin")" class="nav-link @(isSkill ? "active" : "")" role="menuitem">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Skills</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("KpiCategories", "Admin")" class="nav-link @(isKpiCategory ? "active" : "")" role="menuitem">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>KPI categories</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- Learning & Development -->
                        <li class="nav-header">Learning & Development</li>
                        <li class="nav-item">
                            <a href="/Admin/TrainingCourse" class="nav-link @(isTrainingCourse ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-graduation-cap" aria-hidden="true"></i>
                                <p>Training courses</p>
                            </a>
                        </li>

                        <!-- RAID -->
                        <li class="nav-header">RAID</li>
                        <li class="nav-item">
                            <a href="@Url.Action("RaidSettings", "Admin")" class="nav-link @(isRaidSettings ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-database" aria-hidden="true"></i>
                                <p>RAID settings</p>
                            </a>
                        </li>

                        <!-- Apps & Services -->
                        <li class="nav-header">Apps & Services</li>
                        <li class="nav-item">
                            <a href="/Admin/AccessibilityService" class="nav-link @(isAccessibilityService ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-universal-access" aria-hidden="true"></i>
                                <p>Accessibility service</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="@Url.Action("UserSatisfaction", "Admin")" class="nav-link @(isUserSatisfaction ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-poll" aria-hidden="true"></i>
                                <p>User satisfaction</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="@Url.Action("ApiTokens", "Admin")" class="nav-link @(isApiToken ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-key" aria-hidden="true"></i>
                                <p>API tokens</p>
                            </a>
                        </li>
                    </ul>
                </nav>
                <!-- /.sidebar-menu -->
            </div>
            <!-- /.sidebar -->
        </aside>

        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            <!-- Breadcrumb Section -->
            <div class="content-header">
                <div class="container-fluid">
                    <div class="row mb-2">
                        <div class="col-sm-12">
                            @RenderSection("Breadcrumbs", required: false)
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main content -->
            <section class="content" id="main-content">
                <div class="container-fluid">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["ErrorMessage"]
                            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                    }

                    @RenderBody()
                </div><!-- /.container-fluid -->
            </section>
            <!-- /.content -->
        </div>
        <!-- /.content-wrapper -->
        <footer class="main-footer">
            <a href="#" class="footer-link">Cookies</a>
            <a href="@Url.Action("Accessibility", "Home")" class="footer-link">Accessibility</a>
            <a href="#" class="footer-link">Support</a>
            <a href="#" class="footer-link">Feedback</a>
            <a href="@Url.Action("UserInfo", "Profile")" class="footer-link">User</a>
        </footer>

        <!-- Control Sidebar -->
        <aside class="control-sidebar control-sidebar-dark">
            <!-- Control sidebar content goes here -->
        </aside>
        <!-- /.control-sidebar -->
    </div>
    <!-- ./wrapper -->

    <!-- jQuery -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- Bootstrap 4 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/4.6.2/js/bootstrap.bundle.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js" nonce="@Context.Items["Nonce"]"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap4.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- Select2 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/js/select2.full.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- AdminLTE App -->
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- Custom scripts -->
    <script src="~/js/custom.js" nonce="@Context.Items["Nonce"]"></script>
    <script src="~/js/staff-autocomplete.js" nonce="@Context.Items["Nonce"]"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

