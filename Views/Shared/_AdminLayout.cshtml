                                <i class="fas fa-seedling mr-2" aria-hidden="true"></i>
                                Service Standards
                            </a>
                        </div>
                    </li>
                    <li class="nav-item dropdown d-none d-sm-inline-block">
                        <a class="nav-link dropdown-toggle @(isDdtReportsController ? "active" : "")" href="#" id="reportsDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            Reports
                        </a>
                        <div class="dropdown-menu" aria-labelledby="reportsDropdown">
                            <a class="dropdown-item @(controllerName == "DdtReports" && actionName == "Index" ? "active" : "")" href="@Url.Action("Index", "DdtReports")">
                                <i class="fas fa-chart-line mr-2" aria-hidden="true"></i>
                                Reports overview
                            </a>
