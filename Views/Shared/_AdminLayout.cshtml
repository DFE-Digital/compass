                                <i class="fas fa-user-circle mr-2" aria-hidden="true"></i>
                                My reports
                            </a>
                            <a class="dropdown-item @(controllerName == "DdtReports" && actionName == "ViewReport" ? "active" : "")" href="@Url.Action("ViewReport", "DdtReports")">
                                <i class="fas fa-chart-line mr-2" aria-hidden="true"></i>
                                All DDT
                            </a>
                            <a class="dropdown-item @(controllerName == "DdtReports" && actionName == "FlagshipProjects" ? "active" : "")" href="@Url.Action("FlagshipProjects", "DdtReports")">
                                <i class="fas fa-flag mr-2" aria-hidden="true"></i>
                                Flagship projects
                            </a>
                            <a class="dropdown-item @(controllerName == "DdtReports" && actionName == "AccessibilityReport" ? "active" : "")" href="@Url.Action("AccessibilityReport", "DdtReports")">
                                <i class="fas fa-universal-access mr-2" aria-hidden="true"></i>
                                Accessibility report
                            </a>
                            <a class="dropdown-item @(controllerName == "DdtReports" && actionName == "BusinessArea" ? "active" : "")" href="@Url.Action("BusinessArea", "DdtReports")">
                                <i class="fas fa-building mr-2" aria-hidden="true"></i>
                                Business area reports
                            </a>
                        </div>
                    </li>
                    @{
                        if (!hasAdminRole && User?.Identity?.IsAuthenticated == true)
                        {
                            var roleClaims = User.FindAll(System.Security.Claims.ClaimTypes.Role)
                                .Concat(User.FindAll("role"))
                                .Concat(User.FindAll("roles"))
                                .Select(c => c.Value)
                                .Distinct()
                                .ToList();

                            var validRoles = new[] { "super_admin", "admin", "Super admin", "SuperAdmin", "Admin", "Super Admin" };
                            hasAdminRole = validRoles.Any(role =>
                                User.IsInRole(role) ||
                                roleClaims.Any(rc => rc.Equals(role, StringComparison.OrdinalIgnoreCase)));

                            if (!hasAdminRole)
                            {
                                hasAdminRole = roleClaims.Any(role =>
                                    role.Contains("super", StringComparison.OrdinalIgnoreCase) &&
                                    role.Contains("admin", StringComparison.OrdinalIgnoreCase));
                            }

                            if (!hasAdminRole)
                            {
                                var fallbackEmail = User.Identity?.Name
                                    ?? User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                                    ?? User.FindFirst("preferred_username")?.Value
                                    ?? User.FindFirst("email")?.Value
                                    ?? string.Empty;

                                if (!string.IsNullOrEmpty(fallbackEmail))
                                {
                                    try
                                    {
                                        var user = DbContext.Users
                                            .FirstOrDefault(u => u.Email.ToLower() == fallbackEmail.ToLower());

                                        if (user != null)
                                        {
                                            hasAdminRole = user.Role == UserRole.Admin ||
                                                user.Role == UserRole.SuperAdmin;
                                        }
                                    }
                                    catch
                                    {
                                        // ignore
                                    }
                                }
                            }
                        }
                    }
                    @if (hasAdminRole)
                    {
                        <li class="nav-item d-none d-sm-inline-block">
                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")" href="@Url.Action("Index", "Admin")">
                                Admin
                            </a>
                        </li>
                    }
                </ul>

