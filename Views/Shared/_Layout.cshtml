@*
 * ROUTE: Shared Layout
 * CONTROLLER: N/A (Shared Layout)
 * MODEL: N/A
 * 
 * DESCRIPTION:
 * Main layout template for the COMPASS application.
 * Provides consistent HTML structure, navigation, and styling across all pages.
 * Includes GOV.UK design system compliance and security features.
 * 
 * AUTHOR: Andy Jones
 * CREATED: 2025-09-26
 * LAST MODIFIED: 2025-10-14
 *@

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - COMPASS</title>

    <!-- Google Font: Inter -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" nonce="@Context.Items["Nonce"]">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Theme style -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" nonce="@Context.Items["Nonce"]">
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap4.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Select2 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/css/select2.min.css" nonce="@Context.Items["Nonce"]">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/select2-bootstrap-theme/0.1.0-beta.10/select2-bootstrap.min.css" nonce="@Context.Items["Nonce"]">
    <!-- jQuery UI (for autocomplete) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.13.2/themes/ui-lightness/jquery-ui.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Custom COMPASS theme -->
    <link href="~/css/compass-theme.css" rel="stylesheet" nonce="@Context.Items["Nonce"]" />
    <!-- Custom styles -->
    <link href="~/css/custom.css" rel="stylesheet" nonce="@Context.Items["Nonce"]" />
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="hold-transition sidebar-mini layout-fixed compass-theme">
    <!-- Skip link for keyboard navigation -->
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class="wrapper">

        <!-- Preloader -->
        <div class="preloader flex-column justify-content-center align-items-center">
            <img class="animation__shake" src="~/images/govuk-crown.svg" alt="GOV.UK Crown" height="60" width="60">
        </div>

        <!-- Navbar -->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light navbar-gov">
            <div class="container-fluid">
                <!-- Left navbar links -->
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" data-widget="pushmenu" href="#" role="button" aria-label="Toggle sidebar menu"><i class="fas fa-bars" aria-hidden="true"></i></a>
                    </li>
                    <li class="nav-item d-none d-sm-inline-block">
                        <a href="@Url.Action("Index", "Home")" class="nav-link">Home</a>
                    </li>
                    <li class="nav-item dropdown d-none d-sm-inline-block">
                        <a class="nav-link dropdown-toggle" href="#" id="appsDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            Apps
                        </a>
                        <div class="dropdown-menu" aria-labelledby="appsDropdown">
                            <a class="dropdown-item" href="@Url.Action("Index", "Apps")">
                                <i class="fas fa-th mr-2" aria-hidden="true"></i>
                                All Apps
                            </a>
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item" href="https://find-products-services.education.gov.uk" target="_blank" rel="noopener noreferrer">
                                <i class="fas fa-search mr-2" aria-hidden="true"></i>
                                Find information about Products and Services
                            </a>
                            <a class="dropdown-item" href="@Url.Action("Index", "Accessibility")">
                                <i class="fas fa-universal-access mr-2" aria-hidden="true"></i>
                                Accessibility issues and statements
                            </a>
                        </div>
                    </li>
                    @{
                        var isAdminView = ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin";
                        var isStandardController = ViewContext.RouteData.Values["Controller"]?.ToString() == "Standard";
                        var isDdtStandardsActive = isStandardController;
                    }
                    @if (!isAdminView)
                    {
                        <li class="nav-item dropdown d-none d-sm-inline-block">
                            <a class="nav-link dropdown-toggle @(isDdtStandardsActive ? "active" : "")" href="#" id="ddtStandardsDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                DDT Standards
                            </a>
                            <div class="dropdown-menu" aria-labelledby="ddtStandardsDropdown">
                                <a class="dropdown-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Standard" && ViewContext.RouteData.Values["Action"]?.ToString() == "Published" ? "active" : "")" href="@Url.Action("Published", "Standard")">
                                    <i class="fas fa-check-circle mr-2" aria-hidden="true"></i>
                                    Published standards
                                </a>
                                <a class="dropdown-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Standard" && ViewContext.RouteData.Values["Action"]?.ToString() == "Draft" ? "active" : "")" href="@Url.Action("Draft", "Standard")">
                                    <i class="fas fa-file-alt mr-2" aria-hidden="true"></i>
                                    Draft standards
                                </a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Standard" && ViewContext.RouteData.Values["Action"]?.ToString() == "Create" ? "active" : "")" href="@Url.Action("Create", "Standard")">
                                    <i class="fas fa-plus-circle mr-2" aria-hidden="true"></i>
                                    Publish a standard
                                </a>
                            </div>
                        </li>
                    }
                    @{
                        // Check if user has Admin or SuperAdmin role
                        bool hasAdminRole = false;
                        
                        if (User?.Identity?.IsAuthenticated == true)
                        {
                            // Get all role claims from various claim types
                            var roleClaims = User.FindAll(System.Security.Claims.ClaimTypes.Role)
                                .Concat(User.FindAll("role"))
                                .Concat(User.FindAll("roles"))
                                .Select(c => c.Value)
                                .Distinct()
                                .ToList();
                            
                            // Check for admin roles in claims - supporting various formats
                            var validRoles = new[] { "super_admin", "admin", "Super admin", "SuperAdmin", "Admin", "Super Admin" };
                            hasAdminRole = validRoles.Any(role =>
                                User.IsInRole(role) ||
                                roleClaims.Any(rc => rc.Equals(role, StringComparison.OrdinalIgnoreCase)));
                            
                            // Also check if any role contains both "super" and "admin" (case-insensitive)
                            if (!hasAdminRole)
                            {
                                hasAdminRole = roleClaims.Any(role =>
                                    role.Contains("super", StringComparison.OrdinalIgnoreCase) &&
                                    role.Contains("admin", StringComparison.OrdinalIgnoreCase));
                            }
                            
                            // If still not found in claims, check User model in database
                            if (!hasAdminRole)
                            {
                                var userEmail = User.Identity?.Name 
                                    ?? User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value 
                                    ?? User.FindFirst("preferred_username")?.Value
                                    ?? User.FindFirst("email")?.Value
                                    ?? string.Empty;
                                
                                if (!string.IsNullOrEmpty(userEmail))
                                {
                                    try
                                    {
                                        var user = DbContext.Users
                                            .FirstOrDefault(u => u.Email.ToLower() == userEmail.ToLower());
                                        
                                        if (user != null)
                                        {
                                            // User model uses enum: Admin = 2, SuperAdmin = 3
                                            hasAdminRole = user.Role == UserRole.Admin || 
                                                          user.Role == UserRole.SuperAdmin;
                                        }
                                    }
                                    catch
                                    {
                                        // If database check fails, fall back to claims only
                                    }
                                }
                            }
                        }
                    }
                    @if (hasAdminRole)
                    {
                        <li class="nav-item d-none d-sm-inline-block">
                            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")" href="@Url.Action("Index", "Admin")">
                                Admin
                            </a>
                        </li>
                    }
                </ul>

                <!-- Right navbar links -->
                <ul class="navbar-nav ml-auto">
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" aria-label="User menu">
                        <i class="fas fa-user" aria-hidden="true"></i>
                    </a>
                    <div class="dropdown-menu dropdown-menu-right" aria-labelledby="userDropdown">
                        <h6 class="dropdown-header">@User.Identity?.Name</h6>
                        <div class="dropdown-divider"></div>
                        <a class="dropdown-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "StaffRoleReturn" ? "active" : "")" href="@Url.Action("Index", "StaffRoleReturn")">
                            <i class="fas fa-id-card" aria-hidden="true"></i> Role profile
                        </a>
                        <a class="dropdown-item" href="~/User/MySettings">
                            <i class="fas fa-cog" aria-hidden="true"></i> My settings
                        </a>
                        <div class="dropdown-divider"></div>
                        <a class="dropdown-item" href="~/MicrosoftIdentity/Account/SignOut">
                            <i class="fas fa-sign-out-alt" aria-hidden="true"></i> Sign out
                        </a>
                    </div>
                </li>
                </ul>
            </div>
        </nav>

        <!-- Main Sidebar Container -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <!-- Brand Logo -->
            <a href="@Url.Action("Index", "Home")" class="brand-link">
                <img src="~/images/govuk-crown.svg" alt="GOV.UK Crown" class="brand-image">
                <span class="brand-text ml-2">COMPASS</span>
            </a>

            <!-- Sidebar -->
            <div class="sidebar text-md">
                <!-- Sidebar Menu -->
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menubar" data-accordion="false">
                        <!-- Home -->
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "Home")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-home" aria-hidden="true"></i>
                                <p>Home</p>
                            </a>
                        </li>

                        <!-- Reporting Section -->
                        <li class="nav-header">Reporting</li>
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "Project")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Project" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-hammer" aria-hidden="true"></i>
                                <p>Delivery reporting</p>
                            </a>
                        </li>
                        @{
                            var operationalReportingActions = new[] { "PerformanceMetrics", "Index", "ProductHistory", "SubmitMetrics" };
                            var isOperationalReportingActive = ViewContext.RouteData.Values["Controller"]?.ToString() == "ProductReporting" && 
                                                               operationalReportingActions.Contains(ViewContext.RouteData.Values["Action"]?.ToString());
                        }
                        <li class="nav-item">
                            <a href="@Url.Action("PerformanceMetrics", "ProductReporting")" class="nav-link @(isOperationalReportingActive ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-square-check" aria-hidden="true"></i>
                                <p>Operational reporting</p>
                            </a>
                        </li>
                        @{
                            var functionalStandardsActions = new[] { "FunctionalStandards", "SelectStandard", "ConductAssessment", "ViewAssessmentSummary", "StartAssessment" };
                            var isFunctionalStandardsActive = ViewContext.RouteData.Values["Controller"]?.ToString() == "EnterpriseReporting" && 
                                                              functionalStandardsActions.Contains(ViewContext.RouteData.Values["Action"]?.ToString());
                        }
                        <li class="nav-item">
                            <a href="@Url.Action("FunctionalStandards", "EnterpriseReporting")" class="nav-link @(isFunctionalStandardsActive ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-clipboard-check" aria-hidden="true"></i>
                                <p>Functional standards</p>
                            </a>
                        </li>


                        <!-- DDT Reports -->
                        <li class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "DdtReports" ? "menu-open" : "")" >
                            <a href="#" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "DdtReports" ? "active" : "")" role="menuitem" aria-haspopup="true" aria-expanded="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "DdtReports" ? "true" : "false")">
                                <i class="nav-icon fas fa-file-contract" aria-hidden="true"></i>
                                <p>
                                    DDT Reports
                                    <i class="right fas fa-angle-left"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview" role="menu">
                                @await Component.InvokeAsync("BusinessAreasNavigation")
                            </ul>
                        </li>


                        <!-- Product Governance - Hidden from navigation -->
                        <!--
                        <li class="nav-item @(new[] { "Products", "Risk", "Issue", "Milestone", "Action" }.Contains(ViewContext.RouteData.Values["Controller"]?.ToString()) ? "menu-open" : "")" >
                            <a href="#" class="nav-link @(new[] { "Products", "Risk", "Issue", "Milestone", "Action" }.Contains(ViewContext.RouteData.Values["Controller"]?.ToString()) ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-shield-alt" aria-hidden="true"></i>
                                <p>
                                    Product governance
                                    <i class="right fas fa-angle-left"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview" role="menu">
                                <li class="nav-item" >
                                    <a href="@Url.Action("Index", "Products")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Products" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-box" aria-hidden="true"></i>
                                        <p>Products</p>
                                    </a>
                                </li>
                                <li class="nav-item" >
                                    <a href="@Url.Action("Index", "Risk")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Risk" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-exclamation-triangle" aria-hidden="true"></i>
                                        <p>Risks</p>
                                    </a>
                                </li>
                                <li class="nav-item" >
                                    <a href="@Url.Action("Index", "Issue")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Issue" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-bug" aria-hidden="true"></i>
                                        <p>Issues</p>
                                    </a>
                                </li>
                                <li class="nav-item" >
                                    <a href="@Url.Action("Index", "Milestone")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Milestone" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-flag-checkered" aria-hidden="true"></i>
                                        <p>Milestones</p>
                                    </a>
                                </li>
                                <li class="nav-item" >
                                    <a href="@Url.Action("Index", "Action")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Action" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-tasks" aria-hidden="true"></i>
                                        <p>Actions</p>
                                    </a>
                                </li>
                            </ul>
                        </li>
                        -->

                    </ul>
                </nav>
                <!-- /.sidebar-menu -->
            </div>
            <!-- /.sidebar -->
        </aside>

        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            <!-- Breadcrumb Section -->
            <div class="content-header">
                <div class="container-fluid">
                    <div class="row mb-2">
                        <div class="col-sm-12">
                            @RenderSection("Breadcrumbs", required: false)
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main content -->
            <section class="content" id="main-content">
                <div class="container-fluid">
                    @RenderBody()
                </div><!-- /.container-fluid -->
            </section>
            <!-- /.content -->
        </div>
        <!-- /.content-wrapper -->
        <footer class="main-footer">
            <a href="#" class="footer-link">Cookies</a>
            <a href="@Url.Action("Accessibility", "Home")" class="footer-link">Accessibility</a>
            <a href="@Url.Action("Index", "Documentation")" class="footer-link">Documentation</a>
            <a href="@Url.Action("Roadmap", "Home")" class="footer-link">Roadmap</a>
            <a href="#" class="footer-link">Support</a>
            <a href="#" class="footer-link">Feedback</a>

            <a href="@Url.Action("UserInfo", "Profile")" class="footer-link">User</a>
        </footer>

        <!-- Control Sidebar -->
        <aside class="control-sidebar control-sidebar-dark">
            <!-- Control sidebar content goes here -->
        </aside>
        <!-- /.control-sidebar -->
    </div>
    <!-- ./wrapper -->

    <!-- jQuery -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- Bootstrap 4 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/4.6.2/js/bootstrap.bundle.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js" nonce="@Context.Items["Nonce"]"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap4.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- Select2 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/js/select2.full.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- jQuery UI (for autocomplete) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.13.2/jquery-ui.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- AdminLTE App -->
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- Custom scripts -->
    <script src="~/js/custom.js" nonce="@Context.Items["Nonce"]"></script>
    <script src="~/js/staff-autocomplete.js" nonce="@Context.Items["Nonce"]"></script>
    
    <!-- Sidebar state persistence -->
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Check localStorage for sidebar state on page load
            var sidebarState = localStorage.getItem('sidebar-collapsed');
            
            // Apply the saved state
            if (sidebarState === 'true') {
                $('body').addClass('sidebar-collapse');
            } else if (sidebarState === 'false') {
                $('body').removeClass('sidebar-collapse');
            }
            
            // Listen for sidebar toggle events and save the state
            $(document).on('collapsed.lte.pushmenu', function() {
                localStorage.setItem('sidebar-collapsed', 'true');
            });
            
            $(document).on('shown.lte.pushmenu', function() {
                localStorage.setItem('sidebar-collapsed', 'false');
            });
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
