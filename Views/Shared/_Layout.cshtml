@*
 * ROUTE: Shared Layout
 * CONTROLLER: N/A (Shared Layout)
 * MODEL: N/A
 * 
 * DESCRIPTION:
 * Main layout template for the COMPASS application.
 * Provides consistent HTML structure, navigation, and styling across all pages.
 * Includes GOV.UK design system compliance and security features.
 * 
 * AUTHOR: Andy Jones
 * CREATED: 2025-09-26
 * LAST MODIFIED: 2025-10-14
 *@

@using System
@using Compass.Services
@using Compass.Data
@inject IConfiguration Configuration
@inject IPermissionService PermissionService
@inject CompassDbContext DbContext

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - COMPASS</title>
 <link rel="icon" sizes="any" href="~/images/favicon.svg" type="image/svg+xml">
    <!-- Google Font: Inter -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" nonce="@Context.Items["Nonce"]">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Theme style -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" nonce="@Context.Items["Nonce"]">
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap4.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Select2 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/css/select2.min.css" nonce="@Context.Items["Nonce"]">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/select2-bootstrap-theme/0.1.0-beta.10/select2-bootstrap.min.css" nonce="@Context.Items["Nonce"]">
    <!-- jQuery UI (for autocomplete) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.13.2/themes/ui-lightness/jquery-ui.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Custom COMPASS theme -->
    <link href="~/css/compass-theme.css" rel="stylesheet" nonce="@Context.Items["Nonce"]" />
    <!-- Custom styles -->
    <link href="~/css/custom.css" rel="stylesheet" nonce="@Context.Items["Nonce"]" />
    <!-- Help Chatbot styles -->
    <!-- <link href="~/css/chatbot.css" rel="stylesheet" nonce="@Context.Items["Nonce"]" /> -->
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="hold-transition sidebar-mini layout-fixed compass-theme">
    <!-- Skip link for keyboard navigation -->
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class="wrapper">

        @{
            Compass.Models.User? currentUser = null;
            string? currentUserEmail = null;
            int taskCount = 0;
            
            // Variables needed for sidebar navigation
                        var controllerName = ViewContext.RouteData.Values["Controller"]?.ToString();
                        var actionName = ViewContext.RouteData.Values["Action"]?.ToString();
                        var isAdminView = controllerName == "Admin";
                        var functionalStandardsActions = new[] { "FunctionalStandards", "SelectStandard", "ConductAssessment", "ViewAssessmentSummary", "StartAssessment" };
            
            // Calculate task count for standard layout only
            if (!isAdminView)
            {
                        try
                        {
                            currentUserEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                                ?? User.Identity?.Name
                                ?? string.Empty;

                            if (!string.IsNullOrEmpty(currentUserEmail))
                            {
                                currentUser = DbContext.Users
                                    .FirstOrDefault(u => u.Email.ToLower() == currentUserEmail.ToLower());

                                if (currentUser != null)
                                    {
                                        var userProjects = DbContext.Projects
                                            .Where(p => !p.IsDeleted && (
                                                p.PrimaryContactUserId == currentUser.Id ||
                                                p.SeniorResponsibleOfficers.Any(sro => sro.UserId == currentUser.Id) ||
                                                p.ServiceOwners.Any(so => so.UserId == currentUser.Id)
                                            ))
                                            .Include(p => p.ProjectContacts)
                                            .Include(p => p.SeniorResponsibleOfficers)
                                            .Include(p => p.ServiceOwners)
                                            .Include(p => p.Directorates)
                                            .Include(p => p.BudgetOwners)
                                            .AsNoTracking()
                                            .ToList();
                                        
                                        foreach (var project in userProjects)
                                        {
                                            var currentTeamMembers = project.ProjectContacts
                                                .Where(pc => string.IsNullOrEmpty(pc.TeamStatus) || 
                                                             pc.TeamStatus.ToLower() == "current")
                                                .ToList();
                                            if (!currentTeamMembers.Any()) taskCount++;
                                            if (!project.SeniorResponsibleOfficers.Any()) taskCount++;
                                            if (!project.Directorates.Any()) taskCount++;
                                            if (project.ActivityTypeLookupId == null) taskCount++;
                                            if (string.IsNullOrWhiteSpace(project.RagStatus)) taskCount++;
                                            if (project.BusinessAreaId == null) taskCount++;
                                            if (string.IsNullOrWhiteSpace(project.Aim)) taskCount++;
                                            if (project.PrimaryContactUserId == null) taskCount++;
                                            if (!project.BudgetOwners.Any()) taskCount++;
                            }
                        }
                                        }
                                    }
                                    catch
                                    {
                                        // Non-blocking: task count will remain 0
                                    }
                                }
                            }

        <!-- Preloader -->
        <div class="preloader flex-column justify-content-center align-items-center">
            <img class="animation__shake" src="~/images/govuk-crown.svg" alt="GOV.UK Crown" height="60" width="60">
                        </div>

        @await Html.PartialAsync("_TopNav")

        <!-- Main Sidebar Container -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <!-- Brand Logo -->
            <a href="@Url.Action("Index", "Home")" class="brand-link">
                <img src="~/images/govuk-crown.svg" alt="GOV.UK Crown" class="brand-image">
                <span class="brand-text ml-2">COMPASS</span>
            </a>

            <!-- Sidebar -->
            <div class="sidebar text-md">
                <!-- Sidebar Menu -->
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="list" data-accordion="false">
                        <!-- Home -->
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "Home")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                                <i class="nav-icon fas fa-home" aria-hidden="true"></i>
                                <p>Home</p>
                            </a>
                        </li>

                        <!-- Tasks -->
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "Tasks")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Tasks" ? "active" : "")" style="display: flex; align-items: center;">
                                <i class="nav-icon fas fa-tasks" aria-hidden="true"></i>
                                <p style="display: flex; align-items: center; justify-content: space-between; flex: 1; margin-bottom: 0; margin-left: 0.5rem;">
                                    <span>Tasks</span>
                                    @if (taskCount > 0)
                                    {
                                        <span class="badge badge-warning badge-pill ml-2" style="font-size: 0.7rem; padding: 0.2rem 0.4rem; line-height: 1.2;">@taskCount</span>
                                    }
                                </p>
                            </a>
                        </li>

                        <!-- Demand Management Section -->
                        @if (Configuration.GetValue<bool>("FeatureFlags:EnableDemandManagement", false))
                        {
                            var demandRequestActions = new[] { "Requests", "CreateRequest", "Details", "Edit" };
                            var demandPrioritisationActions = new[] { "Prioritisation", "ScoreRequest" };
                            var demandTriageActions = new[] { "Triage" };
                            var isDemandSectionActive = controllerName == "DemandManagement";
                            var isDemandRequestsActive = controllerName == "DemandManagement" && demandRequestActions.Contains(actionName ?? string.Empty);
                            var isDemandPrioritisationActive = controllerName == "DemandManagement" && demandPrioritisationActions.Contains(actionName ?? string.Empty);
                            var isDemandTriageActive = controllerName == "DemandManagement" && demandTriageActions.Contains(actionName ?? string.Empty);
                            var isDemandReportingActive = controllerName == "DemandManagement" && string.Equals(actionName, "Reporting", StringComparison.OrdinalIgnoreCase);
                            <li class="nav-header">Demand management</li>
                            <li class="nav-item @(isDemandSectionActive ? "menu-open" : "")">
                                <a href="#" class="nav-link @(isDemandSectionActive ? "active" : "")" aria-haspopup="true" aria-expanded="@(isDemandSectionActive ? "true" : "false")">
                                    <i class="nav-icon fas fa-clipboard-list" aria-hidden="true"></i>
                                    <p>
                                        Demand management
                                        <i class="right fas fa-angle-left"></i>
                                    </p>
                                </a>
                                <ul class="nav nav-treeview" role="list">
                                    <li class="nav-item">
                                        <a href="@Url.Action("Requests", "DemandManagement")" class="nav-link @(isDemandRequestsActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>Requests</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("Prioritisation", "DemandManagement")" class="nav-link @(isDemandPrioritisationActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>Prioritisation</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("Triage", "DemandManagement")" class="nav-link @(isDemandTriageActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>Triage</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("Reporting", "DemandManagement")" class="nav-link @(isDemandReportingActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>Reporting</p>
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                        <!-- RAID Management Section -->
                        @if (Configuration.GetValue<bool>("FeatureFlags:EnableRAIDManagement", false))
                        {
                            var isRaidSectionActive = controllerName == "Raid";
                            <li class="nav-header">RAID Management</li>
                            <li class="nav-item">
                                <a href="@Url.Action("Index", "Raid")" class="nav-link @(isRaidSectionActive ? "active" : "")">
                                    <i class="nav-icon fas fa-shield-alt" aria-hidden="true"></i>
                                    <p>RAID Management</p>
                                </a>
                            </li>
                        }

                        <!-- Reporting Section -->
                        <li class="nav-header">Reporting</li>
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "Project")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Project" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                                <i class="nav-icon fas fa-hammer" aria-hidden="true"></i>
                                <p>Work reporting</p>
                            </a>
                        </li>
                        @{
                            var operationalReportingActions = new[] { "PerformanceMetrics", "Index", "ProductHistory", "SubmitMetrics" };
                            var isOperationalReportingActive = ViewContext.RouteData.Values["Controller"]?.ToString() == "ProductReporting" && 
                                                               operationalReportingActions.Contains(ViewContext.RouteData.Values["Action"]?.ToString());
                        }
                        <li class="nav-item">
                            <a href="@Url.Action("PerformanceMetrics", "ProductReporting")" class="nav-link @(isOperationalReportingActive ? "active" : "")">
                                <i class="nav-icon fas fa-square-check" aria-hidden="true"></i>
                                <p>Operational reporting</p>
                            </a>
                        </li>
                        @{
                            var isFunctionalStandardsActive = controllerName == "EnterpriseReporting" &&
                                                              functionalStandardsActions.Contains(actionName ?? string.Empty);
                        }
                        @* Functional standards navigation moved to the header dropdown *@

                        <!-- Central Operations Section -->
                        @{
                            bool isCentralOpsAdmin = false;
                            bool enableCentralOps = Configuration.GetValue<bool>("FeatureFlags:EnableCentralOps", false);
                            try
                            {
                                if (currentUser != null && !string.IsNullOrEmpty(currentUserEmail) && enableCentralOps)
                                {
                                    isCentralOpsAdmin = await PermissionService.IsSuperAdminAsync(currentUserEmail) ||
                                                       await PermissionService.IsInGroupAsync(currentUserEmail, "Central Operations Admin");
                                }
                            }
                            catch
                            {
                                // Non-blocking: section will not be shown
                            }
                        }
                        @if (isCentralOpsAdmin && enableCentralOps)
                        {
                            var isCentralOpsSectionActive = controllerName == "CentralOps";
                            var isCentralOpsDashboardActive = controllerName == "CentralOps" && actionName == "Dashboard";
                            var isCentralOpsManageWorkActive = controllerName == "CentralOps" && actionName == "ManageWork";
                            var isCentralOpsSltReportActive = controllerName == "CentralOps" && actionName == "SltWeeklyReport";
                            <li class="nav-header">Central Operations</li>
                            <li class="nav-item @(isCentralOpsSectionActive ? "menu-open" : "")">
                                <a href="#" class="nav-link @(isCentralOpsSectionActive ? "active" : "")" aria-haspopup="true" aria-expanded="@(isCentralOpsSectionActive ? "true" : "false")">
                                    <i class="nav-icon fas fa-cog" aria-hidden="true"></i>
                                    <p>
                                        Central Operations
                                        <i class="right fas fa-angle-left"></i>
                                    </p>
                                </a>
                                <ul class="nav nav-treeview" role="list">
                                    <li class="nav-item">
                                        <a href="@Url.Action("Dashboard", "CentralOps")" class="nav-link @(isCentralOpsDashboardActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>Dashboard</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("ManageWork", "CentralOps")" class="nav-link @(isCentralOpsManageWorkActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>Manage work</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("SltWeeklyReport", "CentralOps")" class="nav-link @(isCentralOpsSltReportActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>SLT weekly report</p>
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                        <!-- Design Operations Section -->
                        @{
                            bool isDesignOpsAdmin = false;
                            try
                            {
                                if (currentUser != null && !string.IsNullOrEmpty(currentUserEmail))
                                {
                                    isDesignOpsAdmin = await PermissionService.IsSuperAdminAsync(currentUserEmail) ||
                                                       await PermissionService.IsInGroupAsync(currentUserEmail, "Design Operations");
                                }
                            }
                            catch
                            {
                                // Non-blocking: section will not be shown
                            }
                        }
                        @if (isDesignOpsAdmin)
                        {
                            var isDesignOpsSectionActive = controllerName == "DesignOps";
                            var isDesignOpsDashboardActive = controllerName == "DesignOps" && actionName == "Dashboard";
                            <li class="nav-header">Design Operations</li>
                            <li class="nav-item @(isDesignOpsSectionActive ? "menu-open" : "")">
                                <a href="#" class="nav-link @(isDesignOpsSectionActive ? "active" : "")" aria-haspopup="true" aria-expanded="@(isDesignOpsSectionActive ? "true" : "false")">
                                    <i class="nav-icon fas fa-palette" aria-hidden="true"></i>
                                    <p>
                                        Design Operations
                                        <i class="right fas fa-angle-left"></i>
                                    </p>
                                </a>
                                <ul class="nav nav-treeview" role="list">
                                    <li class="nav-item">
                                        <a href="@Url.Action("Dashboard", "DesignOps")" class="nav-link @(isDesignOpsDashboardActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>Dashboard</p>
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                        <!-- Product Governance - Hidden from navigation -->
                        <!--
                        <li class="nav-item @(new[] { "Products", "Risk", "Issue", "Milestone", "Action" }.Contains(ViewContext.RouteData.Values["Controller"]?.ToString()) ? "menu-open" : "")" >
                            <a href="#" class="nav-link @(new[] { "Products", "Risk", "Issue", "Milestone", "Action" }.Contains(ViewContext.RouteData.Values["Controller"]?.ToString()) ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-shield-alt" aria-hidden="true"></i>
                                <p>
                                    Product governance
                                    <i class="right fas fa-angle-left"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview" role="menu">
                                <li class="nav-item" >
                                    <a href="@Url.Action("Index", "Products")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Products" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-box" aria-hidden="true"></i>
                                        <p>Products</p>
                                    </a>
                                </li>
                                <li class="nav-item" >
                                    <a href="@Url.Action("Index", "Risk")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Risk" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-exclamation-triangle" aria-hidden="true"></i>
                                        <p>Risks</p>
                                    </a>
                                </li>
                                <li class="nav-item" >
                                    <a href="@Url.Action("Index", "Issue")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Issue" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-bug" aria-hidden="true"></i>
                                        <p>Issues</p>
                                    </a>
                                </li>
                                <li class="nav-item" >
                                    <a href="@Url.Action("Index", "Milestone")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Milestone" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-flag-checkered" aria-hidden="true"></i>
                                        <p>Milestones</p>
                                    </a>
                                </li>
                                <li class="nav-item" >
                                    <a href="@Url.Action("Index", "Action")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Action" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-tasks" aria-hidden="true"></i>
                                        <p>Actions</p>
                                    </a>
                                </li>
                            </ul>
                        </li>
                        -->

                    </ul>
                </nav>
                <!-- /.sidebar-menu -->
            </div>
            <!-- /.sidebar -->
        </aside>

        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper p-0">
            <!-- Breadcrumb Section -->
            <div class="content-header p-0">
                <div class="container-fluid p-0">
                    <div class="row mb-2">
                        <div class="col-sm-12 ">
                            @RenderSection("Breadcrumbs", required: false)
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main content -->
            <section class="content" id="main-content">
                
                    @RenderBody()
              
            </section>
            <!-- /.content -->
        </div>
        <!-- /.content-wrapper -->
        <footer class="main-footer">
            <a href="https://accessibility-statements.education.gov.uk/s/52" class="footer-link">Accessibility</a>
            <a href="@Url.Action("Index", "Documentation")" class="footer-link">Documentation</a>
            <a href="@Url.Action("Roadmap", "Home")" class="footer-link">Roadmap</a>
            <a href="@Url.Action("Support", "Home")" class="footer-link">Support</a>
            <a href="https://forms.office.com/e/FvpYB3NdeZ" class="footer-link">Feedback</a>
        </footer>

        <!-- Control Sidebar -->
        <aside class="control-sidebar control-sidebar-dark">
            <!-- Control sidebar content goes here -->
        </aside>
        <!-- /.control-sidebar -->
    </div>
    <!-- ./wrapper -->

    <!-- jQuery -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- Bootstrap 4 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/4.6.2/js/bootstrap.bundle.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js" nonce="@Context.Items["Nonce"]"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap4.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- Select2 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/js/select2.full.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- jQuery UI (for autocomplete) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.13.2/jquery-ui.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- AdminLTE App -->
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- Custom scripts -->
    <script src="~/js/custom.js" nonce="@Context.Items["Nonce"]"></script>
    <script src="~/js/staff-autocomplete.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- Help Chatbot -->
    <!-- <script src="~/js/chatbot.js" nonce="@Context.Items["Nonce"]"></script> -->
    
    <!-- Sidebar state persistence -->
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Check localStorage for sidebar state on page load
            var sidebarState = localStorage.getItem('sidebar-collapsed');
            
            // Apply the saved state
            if (sidebarState === 'true') {
                $('body').addClass('sidebar-collapse');
            } else if (sidebarState === 'false') {
                $('body').removeClass('sidebar-collapse');
            }
            
            // Listen for sidebar toggle events and save the state
            $(document).on('collapsed.lte.pushmenu', function() {
                localStorage.setItem('sidebar-collapsed', 'true');
            });
            
            $(document).on('shown.lte.pushmenu', function() {
                localStorage.setItem('sidebar-collapsed', 'false');
            });
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
