@*
 * ROUTE: Shared Layout
 * CONTROLLER: N/A (Shared Layout)
 * MODEL: N/A
 * 
 * DESCRIPTION:
 * Main layout template for the COMPASS application.
 * Provides consistent HTML structure, navigation, and styling across all pages.
 * Includes GOV.UK design system compliance and security features.
 * 
 * AUTHOR: Andy Jones
 * CREATED: 2025-09-26
 * LAST MODIFIED: 2025-10-14
 *@

@using System
@using Compass.Services
@using Compass.Data
@inject IConfiguration Configuration
@inject IPermissionService PermissionService
@inject CompassDbContext DbContext
@inject IWebHostEnvironment env

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - COMPASS</title>
 <link rel="icon" sizes="any" href="~/images/favicon.svg" type="image/svg+xml">
    <!-- Google Font: Inter -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" nonce="@Context.Items["Nonce"]">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Theme style -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" nonce="@Context.Items["Nonce"]">
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap4.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Select2 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/css/select2.min.css" nonce="@Context.Items["Nonce"]">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/select2-bootstrap-theme/0.1.0-beta.10/select2-bootstrap.min.css" nonce="@Context.Items["Nonce"]">
    <!-- jQuery UI (for autocomplete) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jqueryui/1.13.2/themes/ui-lightness/jquery-ui.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Custom COMPASS theme -->
    <link href="~/css/compass-theme.css" rel="stylesheet" nonce="@Context.Items["Nonce"]" />
    <!-- Custom styles -->
    <link href="~/css/custom.css" rel="stylesheet" nonce="@Context.Items["Nonce"]" />
    <!-- Help Chatbot styles -->
    <!-- <link href="~/css/chatbot.css" rel="stylesheet" nonce="@Context.Items["Nonce"]" /> -->
    @if (env.IsProduction())
    {
        <script type="text/javascript" nonce="@Context.Items["Nonce"]">
        (function(c,l,a,r,i,t,y){
            c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
            t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
            t.setAttribute("nonce", "@Context.Items["Nonce"]");
            y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", "ug8dgpkuqz");
        </script>
    }
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="hold-transition sidebar-mini layout-fixed compass-theme">
    <!-- Skip link for keyboard navigation -->
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class="wrapper">

        @{
            Compass.Models.User? currentUser = null;
            string? currentUserEmail = null;
            int taskCount = 0;
            
            // Variables needed for sidebar navigation
                        var controllerName = ViewContext.RouteData.Values["Controller"]?.ToString();
                        var actionName = ViewContext.RouteData.Values["Action"]?.ToString();
                        var isAdminView = controllerName == "Admin";
                        var functionalStandardsActions = new[] { "FunctionalStandards", "SelectStandard", "ConductAssessment", "ViewAssessmentSummary", "StartAssessment" };
            
            // Calculate task count for standard layout only
            if (!isAdminView)
            {
                        try
                        {
                            currentUserEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
                                ?? User.Identity?.Name
                                ?? string.Empty;

                            if (!string.IsNullOrEmpty(currentUserEmail))
                            {
                                currentUser = DbContext.Users
                                    .FirstOrDefault(u => u.Email.ToLower() == currentUserEmail.ToLower());

                                if (currentUser != null)
                                    {
                                        var userProjects = DbContext.Projects
                                            .Where(p => !p.IsDeleted && (
                                                p.PrimaryContactUserId == currentUser.Id ||
                                                p.SeniorResponsibleOfficers.Any(sro => sro.UserId == currentUser.Id) ||
                                                p.ServiceOwners.Any(so => so.UserId == currentUser.Id)
                                            ))
                                            .Include(p => p.ProjectContacts)
                                            .Include(p => p.SeniorResponsibleOfficers)
                                            .Include(p => p.ServiceOwners)
                                            .Include(p => p.Directorates)
                                            .Include(p => p.BudgetOwners)
                                            .AsNoTracking()
                                            .ToList();
                                        
                                        foreach (var project in userProjects)
                                        {
                                            var currentTeamMembers = project.ProjectContacts
                                                .Where(pc => string.IsNullOrEmpty(pc.TeamStatus) || 
                                                             pc.TeamStatus.ToLower() == "current")
                                                .ToList();
                                            if (!currentTeamMembers.Any()) taskCount++;
                                            if (!project.SeniorResponsibleOfficers.Any()) taskCount++;
                                            if (!project.Directorates.Any()) taskCount++;
                                            if (project.ActivityTypeLookupId == null) taskCount++;
                                            if (string.IsNullOrWhiteSpace(project.RagStatus)) taskCount++;
                                            if (project.BusinessAreaId == null) taskCount++;
                                            if (string.IsNullOrWhiteSpace(project.Aim)) taskCount++;
                                            if (project.PrimaryContactUserId == null) taskCount++;
                                            if (!project.BudgetOwners.Any()) taskCount++;
                            }
                        }
                                        }
                                    }
                                    catch
                                    {
                                        // Non-blocking: task count will remain 0
                                    }
                                }
                            }

        @await Html.PartialAsync("_TopNav")

        <!-- Main Sidebar Container -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <!-- Brand Logo -->
            <a href="@Url.Action("Index", "Home")" class="brand-link">
                <img src="~/images/govuk-crown.svg" alt="GOV.UK Crown" class="brand-image">
                <span class="brand-text ml-2">COMPASS</span>
            </a>

            <!-- Sidebar -->
            <div class="sidebar text-md">
                <!-- Sidebar Menu -->
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="list" data-accordion="false">
                        <!-- Home -->
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "Home")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                                <i class="nav-icon fas fa-home" aria-hidden="true"></i>
                                <p>Home</p>
                            </a>
                        </li>


                        <!-- Demand Triage Section -->
                        @if (Configuration.GetValue<bool>("FeatureFlags:EnableDemandManagement", false))
                        {
                            var isDemandTriageSectionActive = controllerName == "DemandTriage";
                            <li class="nav-item">
                                <a href="@Url.Action("Index", "DemandTriage")" class="nav-link @(isDemandTriageSectionActive ? "active" : "")">
                                    <i class="nav-icon fas fa-clipboard-list" aria-hidden="true"></i>
                                    <p>Demand triage</p>
                                </a>
                            </li>
                        }

                        <!-- RAID Management Section -->
                        @if (Configuration.GetValue<bool>("FeatureFlags:EnableRAIDManagement", false))
                        {
                            var isRaidSectionActive = controllerName == "Raid";
                            <li class="nav-item">
                                <a href="@Url.Action("Index", "Raid")" class="nav-link @(isRaidSectionActive ? "active" : "")">
                                    <i class="nav-icon fas fa-shield-alt" aria-hidden="true"></i>
                                    <p>RAID Management</p>
                                </a>
                            </li>
                        }

                        <!-- Reporting Section -->
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "Project")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Project" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                                <i class="nav-icon fas fa-hammer" aria-hidden="true"></i>
                                <p>Work reporting</p>
                            </a>
                        </li>
                        @if (Configuration.GetValue<bool>("FeatureFlags:EnableMonthlyPerformanceReporting", true))
                        {
                            var operationalReportingActions = new[] { "PerformanceMetrics", "Index", "ProductHistory", "SubmitMetrics" };
                            var isOperationalReportingActive = ViewContext.RouteData.Values["Controller"]?.ToString() == "ProductReporting" && 
                                                               operationalReportingActions.Contains(ViewContext.RouteData.Values["Action"]?.ToString());
                            <li class="nav-item">
                                <a href="/Performance" class="nav-link @(isOperationalReportingActive ? "active" : "")">
                                    <i class="nav-icon fas fa-square-check" aria-hidden="true"></i>
                                    <p>Operational reporting</p>
                                </a>
                            </li>
                        }
                        @{
                            var commissionReportingActions = new[] { "Commission", "CommissionReporting", "SubmitCommission", "SubmitCommissionSubmission", "SaveCommissionMetricValue", "ProductCommissions" };
                            var isCommissionReportingActive = ViewContext.RouteData.Values["Controller"]?.ToString() == "ProductReporting" && 
                                                              commissionReportingActions.Contains(ViewContext.RouteData.Values["Action"]?.ToString());
                        }
                        <li class="nav-item">
                            <a href="@Url.Action("Commission", "ProductReporting")" class="nav-link @(isCommissionReportingActive ? "active" : "")">
                                <i class="nav-icon fas fa-file-invoice" aria-hidden="true"></i>
                                <p>Performance reporting</p>
                            </a>
                        </li>
                        @{
                            var isFunctionalStandardsActive = controllerName == "EnterpriseReporting" &&
                                                              functionalStandardsActions.Contains(actionName ?? string.Empty);
                        }
                        @* Functional standards navigation moved to the header dropdown *@

                        <!-- Standards Section -->
                        @{
                            bool canDraftStandards = false;
                            bool canManageStandards = false;
                            bool canApproveStandards = false;
                            bool canPublishStandards = false;
                            try
                            {
                                if (currentUser != null && !string.IsNullOrEmpty(currentUserEmail))
                                {
                                    canDraftStandards = await Compass.Helpers.StandardsPermissionHelper.CanDraftStandardsAsync(PermissionService, User);
                                    canManageStandards = await Compass.Helpers.StandardsPermissionHelper.CanManageStandardsAsync(PermissionService, User);
                                    canApproveStandards = await Compass.Helpers.StandardsPermissionHelper.CanApproveStandardsAsync(PermissionService, User);
                                    canPublishStandards = await Compass.Helpers.StandardsPermissionHelper.CanPublishStandardsAsync(PermissionService, User);
                                }
                            }
                            catch
                            {
                                // Non-blocking: section will not be shown
                            }
                            
                            // User has management permissions if they can manage, approve, or publish
                            bool hasManagementPermissions = canManageStandards || canApproveStandards || canPublishStandards;
                        }
                        @{
                            var isStandardsSectionActive = controllerName == "DdtStandards" || controllerName == "DdtStandardsView" || (controllerName == "DdtStandardsManagement" && (actionName == "Drafts" || actionName == "Create"));
                            var isStandardsViewActive = controllerName == "DdtStandardsView" && actionName == "Published";
                            var isStandardsDraftActive = controllerName == "DdtStandardsManagement" && (actionName == "Drafts" || actionName == "Create");
                            
                            var isStandardsManagementSectionActive = controllerName == "DdtStandardsManagement" && actionName != "Drafts" && actionName != "Create" || controllerName == "DdtStandards" && (actionName == "ApprovedProducts" || actionName == "Exceptions");
                            var isStandardsManageActive = controllerName == "DdtStandardsManagement" && actionName == "Index";
                            var isProductsActive = controllerName == "DdtStandards" && actionName == "ApprovedProducts";
                            var isExceptionsActive = controllerName == "DdtStandards" && actionName == "Exceptions";
                        }
                        
                        <!-- Standards Section (for all users) -->
                        <li class="nav-item @(isStandardsSectionActive ? "menu-open" : "")">
                            <a href="#" class="nav-link @(isStandardsSectionActive ? "active" : "")" aria-haspopup="true" aria-expanded="@(isStandardsSectionActive ? "true" : "false")">
                                <i class="nav-icon fas fa-book" aria-hidden="true"></i>
                                <p>
                                    Standards
                                    <i class="right fas fa-angle-left"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview" role="list">
                                <li class="nav-item">
                                    <a href="@Url.Action("Published", "DdtStandardsView")" class="nav-link @(isStandardsViewActive ? "active" : "")">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Standards</p>
                                    </a>
                                </li>
                                @if (canDraftStandards)
                                {
                                <li class="nav-item">
                                    <a href="@Url.Action("Drafts", "DdtStandardsManagement")" class="nav-link @(isStandardsDraftActive ? "active" : "")">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Draft a standard</p>
                                    </a>
                                </li>
                                }
                            </ul>
                        </li>
                        
                        <!-- Standards Management Section (for users with management permissions) -->
                        @if (hasManagementPermissions)
                        {
                            <li class="nav-item @(isStandardsManagementSectionActive ? "menu-open" : "")">
                                <a href="#" class="nav-link @(isStandardsManagementSectionActive ? "active" : "")" aria-haspopup="true" aria-expanded="@(isStandardsManagementSectionActive ? "true" : "false")">
                                    <i class="nav-icon fas fa-cog" aria-hidden="true"></i>
                                    <p>
                                        Standards management
                                        <i class="right fas fa-angle-left"></i>
                                    </p>
                                </a>
                                <ul class="nav nav-treeview" role="list">
                                    <li class="nav-item">
                                        <a href="@Url.Action("Index", "DdtStandardsManagement")" class="nav-link @(isStandardsManageActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>Manage standards</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("ApprovedProducts", "DdtStandards")" class="nav-link @(isProductsActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>Products</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("Exceptions", "DdtStandards")" class="nav-link @(isExceptionsActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>Exemptions</p>
                                        </a>
                                    </li>
                            </ul>
                        </li>
                        }

                        <!-- Central Operations Section -->
                        @{
                            bool isCentralOpsAdmin = false;
                            bool enableCentralOps = Configuration.GetValue<bool>("FeatureFlags:EnableCentralOps", false);
                            try
                            {
                                if (currentUser != null && !string.IsNullOrEmpty(currentUserEmail) && enableCentralOps)
                                {
                                    isCentralOpsAdmin = await PermissionService.IsSuperAdminAsync(currentUserEmail) ||
                                                       await PermissionService.IsInGroupAsync(currentUserEmail, "Central Operations Admin");
                                }
                            }
                            catch
                            {
                                // Non-blocking: section will not be shown
                            }
                        }
                        @if (isCentralOpsAdmin && enableCentralOps)
                        {
                            var isCentralOpsSectionActive = controllerName == "CentralOps";
                            var isCentralOpsDashboardActive = controllerName == "CentralOps" && actionName == "Dashboard";
                            var isCentralOpsManageWorkActive = controllerName == "CentralOps" && actionName == "ManageWork";
                            var isCentralOpsMonthlySummaryActive = controllerName == "CentralOps" && (actionName == "MonthlySummaryV2" || actionName == "MonthlySummary");
                            var isCentralOpsPerformanceReportingActive = controllerName == "CentralOps" && actionName == "PerformanceReporting";
                            var isCentralOpsSltReportActive = controllerName == "CentralOps" && actionName == "SltWeeklyReport";
                            <li class="nav-item @(isCentralOpsSectionActive ? "menu-open" : "")">
                                <a href="#" class="nav-link @(isCentralOpsSectionActive ? "active" : "")" aria-haspopup="true" aria-expanded="@(isCentralOpsSectionActive ? "true" : "false")">
                                    <i class="nav-icon fas fa-cog" aria-hidden="true"></i>
                                    <p>
                                        Central Operations
                                        <i class="right fas fa-angle-left"></i>
                                    </p>
                                </a>
                                <ul class="nav nav-treeview" role="list">
                                    <li class="nav-item">
                                        <a href="@Url.Action("Dashboard", "CentralOps")" class="nav-link @(isCentralOpsDashboardActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>Dashboard</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("ManageWork", "CentralOps")" class="nav-link @(isCentralOpsManageWorkActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>Manage work</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("MonthlySummaryV2", "CentralOps")" class="nav-link @(isCentralOpsMonthlySummaryActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>Monthly Summary</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("PerformanceReporting", "CentralOps")" class="nav-link @(isCentralOpsPerformanceReportingActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>Performance reporting</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("SltWeeklyReport", "CentralOps")" class="nav-link @(isCentralOpsSltReportActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>SLT weekly report</p>
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                        <!-- Design Operations Section -->
                        @{
                            bool isDesignOpsAdmin = false;
                            try
                            {
                                if (currentUser != null && !string.IsNullOrEmpty(currentUserEmail))
                                {
                                    isDesignOpsAdmin = await PermissionService.IsSuperAdminAsync(currentUserEmail) ||
                                                       await PermissionService.IsInGroupAsync(currentUserEmail, "Design Operations");
                                }
                            }
                            catch
                            {
                                // Non-blocking: section will not be shown
                            }
                        }
                        @if (isDesignOpsAdmin)
                        {
                            var isDesignOpsSectionActive = controllerName == "DesignOps";
                            var isDesignOpsDashboardActive = controllerName == "DesignOps" && actionName == "Dashboard";
                            var isDesignOpsAccessibilityActive = controllerName == "DesignOps" && actionName == "AccessibilityOversight";
                            <li class="nav-item @(isDesignOpsSectionActive ? "menu-open" : "")">
                                <a href="#" class="nav-link @(isDesignOpsSectionActive ? "active" : "")" aria-haspopup="true" aria-expanded="@(isDesignOpsSectionActive ? "true" : "false")">
                                    <i class="nav-icon fas fa-palette" aria-hidden="true"></i>
                                    <p>
                                        Design Operations
                                        <i class="right fas fa-angle-left"></i>
                                    </p>
                                </a>
                                <ul class="nav nav-treeview" role="list">
                                    <li class="nav-item">
                                        <a href="@Url.Action("Dashboard", "DesignOps")" class="nav-link @(isDesignOpsDashboardActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>Dashboard</p>
                                        </a>
                                    </li>
                                    <li class="nav-item">
                                        <a href="@Url.Action("AccessibilityOversight", "DesignOps")" class="nav-link @(isDesignOpsAccessibilityActive ? "active" : "")">
                                            <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                            <p>Accessibility issues</p>
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }

                        <!-- Reports Section -->
                        @{
                            var isReportsSectionActive = controllerName == "Reports";
                            var isReportsIndexActive = controllerName == "Reports" && actionName == "Index";
                            var isReportsDivisionActive = controllerName == "Reports" && actionName == "DivisionReport";
                            var isReportsBusinessAreaActive = controllerName == "Reports" && actionName == "BusinessAreaReport";
                            var isReportsPriorityActive = controllerName == "Reports" && actionName == "PriorityOutcomes";
                        }
                        <li class="nav-item @(isReportsSectionActive ? "menu-open" : "")">
                            <a href="#" class="nav-link @(isReportsSectionActive ? "active" : "")" aria-haspopup="true" aria-expanded="@(isReportsSectionActive ? "true" : "false")">
                                <i class="nav-icon fas fa-chart-bar" aria-hidden="true"></i>
                                <p>
                                    Reports
                                    <i class="right fas fa-angle-left"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview" role="list">
                                <li class="nav-item">
                                    <a href="@Url.Action("Index", "Reports")" class="nav-link @(isReportsIndexActive ? "active" : "")">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Overview</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("DivisionReport", "Reports")" class="nav-link @(isReportsDivisionActive ? "active" : "")">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Division report</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("BusinessAreaReport", "Reports")" class="nav-link @(isReportsBusinessAreaActive ? "active" : "")">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Business area report</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("PriorityOutcomes", "Reports")" class="nav-link @(isReportsPriorityActive ? "active" : "")">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Priority outcomes</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- FIPS Manager Section -->
                        @if (Configuration.GetValue<bool>("FeatureFlags:EnableFIPSManager", false))
                        {
                            var hasFipsManagerAccess = false;
                            
                            if (currentUser != null && !string.IsNullOrEmpty(currentUserEmail))
                            {
                                try
                                {
                                    // Check if user is in allowed groups: "Central Operations Admin", "HOP", or "Design Operations"
                                    var allowedGroups = new[] { "Central Operations Admin", "HOP", "Design Operations" };
                                    foreach (var groupName in allowedGroups)
                                    {
                                        if (await PermissionService.IsInGroupAsync(currentUserEmail, groupName))
                                        {
                                            hasFipsManagerAccess = true;
                                            break;
                                        }
                                    }
                                }
                                catch
                                {
                                    // If there's an error checking permissions, default to false
                                    hasFipsManagerAccess = false;
                                }
                            }
                            
                            @if (hasFipsManagerAccess)
                            {
                                var isFipsManagerSectionActive = controllerName == "FipsManager";
                                var isFipsManagerIndexActive = controllerName == "FipsManager" && actionName == "Index";
                                var isFipsManagerProductActive = controllerName == "FipsManager" && actionName == "ProductDetails";
                                var isFipsManagerDqManagerActive = controllerName == "FipsManager" && (actionName == "ProductDqManagerMyServices" || actionName == "ProductDqManagerAllProducts" || actionName == "StartDqReview" || actionName == "DqReviewInterstitial" || actionName == "DqReviewCheck" || actionName == "DqReviewConfirmation" || actionName == "SubmitDqReview");
                                <li class="nav-item @(isFipsManagerSectionActive ? "menu-open" : "")">
                                    <a href="#" class="nav-link @(isFipsManagerSectionActive ? "active" : "")" aria-haspopup="true" aria-expanded="@(isFipsManagerSectionActive ? "true" : "false")">
                                        <i class="nav-icon fas fa-cog" aria-hidden="true"></i>
                                        <p>
                                            FIPS Manager
                                            <i class="right fas fa-angle-left"></i>
                                        </p>
                                    </a>
                                    <ul class="nav nav-treeview" role="list">
                                        <li class="nav-item">
                                            <a href="@Url.Action("Index", "FipsManager")" class="nav-link @(isFipsManagerIndexActive ? "active" : "")">
                                                <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                                <p>Active products</p>
                                            </a>
                                        </li>
                                        <li class="nav-item">
                                            @{
                                                var isFipsManagerNewProductsActive = controllerName == "FipsManager" && actionName == "NewProducts";
                                            }
                                            <a href="@Url.Action("NewProducts", "FipsManager")" class="nav-link @(isFipsManagerNewProductsActive ? "active" : "")">
                                                <i class="far fa-circle nav-icon" aria-hidden="true"></i>
