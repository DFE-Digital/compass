@*
 * ROUTE: Shared Layout
 * CONTROLLER: N/A (Shared Layout)
 * MODEL: N/A
 * 
 * DESCRIPTION:
 * Main layout template for the COMPASS application.
 * Provides consistent HTML structure, navigation, and styling across all pages.
 * Includes GOV.UK design system compliance and security features.
 * 
 * AUTHOR: Andy Jones
 * CREATED: 2025-09-26
 * LAST MODIFIED: 2025-10-14
 *@

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - COMPASS</title>

    <!-- Google Font: Inter -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" nonce="@Context.Items["Nonce"]">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Theme style -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" nonce="@Context.Items["Nonce"]">
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.13.7/css/dataTables.bootstrap4.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Select2 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/css/select2.min.css" nonce="@Context.Items["Nonce"]">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/select2-bootstrap-theme/0.1.0-beta.10/select2-bootstrap.min.css" nonce="@Context.Items["Nonce"]">
    <!-- Custom COMPASS theme -->
    <link href="~/css/compass-theme.css" rel="stylesheet" nonce="@Context.Items["Nonce"]" />
    <!-- Custom styles -->
    <link href="~/css/custom.css" rel="stylesheet" nonce="@Context.Items["Nonce"]" />
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="hold-transition sidebar-mini layout-fixed compass-theme">
    <!-- Skip link for keyboard navigation -->
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class="wrapper">

        <!-- Preloader -->
        <div class="preloader flex-column justify-content-center align-items-center">
            <img class="animation__shake" src="~/images/govuk-crown.svg" alt="GOV.UK Crown" height="60" width="60">
        </div>

        <!-- Navbar -->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light navbar-gov">
            <div class="container-fluid">
                <!-- Left navbar links -->
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" data-widget="pushmenu" href="#" role="button" aria-label="Toggle sidebar menu"><i class="fas fa-bars" aria-hidden="true"></i></a>
                    </li>
                    <li class="nav-item d-none d-sm-inline-block">
                        <a href="@Url.Action("Index", "Home")" class="nav-link">Home</a>
                    </li>
                    <li class="nav-item dropdown d-none d-sm-inline-block">
                        <a class="nav-link dropdown-toggle" href="#" id="administrationDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            Administration
                        </a>
                        <div class="dropdown-menu" aria-labelledby="administrationDropdown">
                            <a class="dropdown-item" href="@Url.Action("Users", "Admin")">
                                <i class="fas fa-users mr-2"></i> Users
                            </a>
                            <a class="dropdown-item" href="@Url.Action("Index", "PerformanceMetric")">
                                <i class="fas fa-chart-line mr-2"></i> Operational reports
                            </a>
                            <a class="dropdown-item" href="@Url.Action("Index", "EnterpriseMetric")">
                                <i class="fas fa-chart-bar mr-2"></i> Enterprise metrics
                            </a>
                            <a class="dropdown-item" href="@Url.Action("Index", "FunctionalStandard")">
                                <i class="fas fa-book mr-2"></i> Functional standards
                            </a>
                            <a class="dropdown-item" href="@Url.Action("Objectives", "Admin")">
                                <i class="fas fa-bullseye mr-2"></i> Strategic objectives
                            </a>
                            <a class="dropdown-item" href="@Url.Action("Missions", "Admin")">
                                <i class="fas fa-rocket mr-2"></i> Missions
                            </a>
                            <a class="dropdown-item" href="@Url.Action("FundingSources", "Admin")">
                                <i class="fas fa-pound-sign mr-2"></i> Funding sources
                            </a>
                            <a class="dropdown-item" href="@Url.Action("ApiTokens", "Admin")">
                                <i class="fas fa-key mr-2"></i> API tokens
                            </a>
                            <a class="dropdown-item" href="@Url.Action("Settings", "Admin")">
                                <i class="fas fa-sliders-h mr-2"></i> Settings
                            </a>
                        </div>
                    </li>
                    <li class="nav-item d-none d-sm-inline-block">
                        <a href="@Url.Action("Index", "Documentation")" class="nav-link">Documentation</a>
                    </li>
                    <li class="nav-item dropdown d-none d-sm-inline-block">
                        <a class="nav-link dropdown-toggle" href="#" id="appsDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            Apps
                        </a>
                        <div class="dropdown-menu" aria-labelledby="appsDropdown">
                            <a class="dropdown-item" href="@Url.Action("Index", "Accessibility")">
                                <i class="fas fa-universal-access mr-2" aria-hidden="true"></i>
                                Accessibility issues and statements
                            </a>
                        </div>
                    </li>
                </ul>

                <!-- Right navbar links -->
                <ul class="navbar-nav ml-auto">
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" aria-label="User menu">
                        <i class="fas fa-user" aria-hidden="true"></i>
                    </a>
                    <div class="dropdown-menu dropdown-menu-right" aria-labelledby="userDropdown">
                        <h6 class="dropdown-header">@User.Identity?.Name</h6>
                        <div class="dropdown-divider"></div>
                        <a class="dropdown-item" href="~/User/MySettings">
                            <i class="fas fa-cog" aria-hidden="true"></i> My settings
                        </a>
                        <div class="dropdown-divider"></div>
                        <a class="dropdown-item" href="~/MicrosoftIdentity/Account/SignOut">
                            <i class="fas fa-sign-out-alt" aria-hidden="true"></i> Sign out
                        </a>
                    </div>
                </li>
                </ul>
            </div>
        </nav>

        <!-- Main Sidebar Container -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <!-- Brand Logo -->
            <a href="@Url.Action("Index", "Home")" class="brand-link">
                <img src="~/images/govuk-crown.svg" alt="GOV.UK Crown" class="brand-image">
                <span class="brand-text ml-2">COMPASS</span>
            </a>

            <!-- Sidebar -->
            <div class="sidebar text-md">
                <!-- Sidebar Menu -->
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menubar" data-accordion="false">
                        <!-- Home -->
                        <li class="nav-item">
                            <a href="@Url.Action("Index", "Home")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-home" aria-hidden="true"></i>
                                <p>Home</p>
                            </a>
                        </li>

                        <!-- Delivery Reporting -->
                        <li class="nav-item @(new[] { "ProductReporting", "Project" }.Contains(ViewContext.RouteData.Values["Controller"]?.ToString()) ? "menu-open" : "")">
                            <a href="#" class="nav-link @(new[] { "ProductReporting", "Project" }.Contains(ViewContext.RouteData.Values["Controller"]?.ToString()) ? "active" : "")" role="menuitem" aria-haspopup="true" aria-expanded="@(new[] { "ProductReporting", "Project" }.Contains(ViewContext.RouteData.Values["Controller"]?.ToString()) ? "true" : "false")">
                                <i class="nav-icon fas fa-list-check" aria-hidden="true"></i>
                                <p>
                                     Reporting
                                    <i class="right fas fa-angle-left"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview" role="menu">
                                <li class="nav-item">
                                    <a href="@Url.Action("Index", "Project")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Project" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-hammer" aria-hidden="true"></i>
                                        <p>Project delivery reporting</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("PerformanceMetrics", "ProductReporting")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "ProductReporting" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-square-check" aria-hidden="true"></i>
                                        <p>Operational reporting</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- Enterprise Reporting -->
                        <li class="nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "EnterpriseReporting" ? "menu-open" : "")" >
                            <a href="#" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "EnterpriseReporting" ? "active" : "")" role="menuitem" aria-haspopup="true" aria-expanded="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "EnterpriseReporting" ? "true" : "false")">
                                <i class="nav-icon fas fa-building" aria-hidden="true"></i>
                                <p>
                                    Enterprise reporting
                                    <i class="right fas fa-angle-left"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview" role="menu">
                                <!-- Strategic objectives - Hidden from navigation -->
                                <!--
                                <li class="nav-item" >
                                    <a href="@Url.Action("Objectives", "EnterpriseReporting")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "EnterpriseReporting" && ViewContext.RouteData.Values["Action"]?.ToString() == "Objectives" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-bullseye" aria-hidden="true"></i>
                                        <p>Strategic objectives</p>
                                    </a>
                                </li>
                                -->
                                <li class="nav-item" >
                                    <a href="@Url.Action("EnterpriseMetrics", "EnterpriseReporting")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "EnterpriseReporting" && ViewContext.RouteData.Values["Action"]?.ToString() == "EnterpriseMetrics" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-chart-bar" aria-hidden="true"></i>
                                        <p>Enterprise metrics</p>
                                    </a>
                                </li>
                                <li class="nav-item" >
                                    <a href="@Url.Action("FunctionalStandards", "EnterpriseReporting")" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "FunctionalStandards" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-clipboard-check" aria-hidden="true"></i>
                                        <p>Functional standards</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <!-- SLT Reports -->
                        <li class="nav-item" >
                            <a href="@Url.Action("Index", "SltReports")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "SltReports" ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-file-contract" aria-hidden="true"></i>
                                <p>SLT Reports</p>
                            </a>
                        </li>

                        <!-- Product Governance - Hidden from navigation -->
                        <!--
                        <li class="nav-item @(new[] { "Products", "Risk", "Issue", "Milestone", "Action" }.Contains(ViewContext.RouteData.Values["Controller"]?.ToString()) ? "menu-open" : "")" >
                            <a href="#" class="nav-link @(new[] { "Products", "Risk", "Issue", "Milestone", "Action" }.Contains(ViewContext.RouteData.Values["Controller"]?.ToString()) ? "active" : "")" role="menuitem">
                                <i class="nav-icon fas fa-shield-alt" aria-hidden="true"></i>
                                <p>
                                    Product governance
                                    <i class="right fas fa-angle-left"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview" role="menu">
                                <li class="nav-item" >
                                    <a href="@Url.Action("Index", "Products")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Products" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-box" aria-hidden="true"></i>
                                        <p>Products</p>
                                    </a>
                                </li>
                                <li class="nav-item" >
                                    <a href="@Url.Action("Index", "Risk")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Risk" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-exclamation-triangle" aria-hidden="true"></i>
                                        <p>Risks</p>
                                    </a>
                                </li>
                                <li class="nav-item" >
                                    <a href="@Url.Action("Index", "Issue")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Issue" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-bug" aria-hidden="true"></i>
                                        <p>Issues</p>
                                    </a>
                                </li>
                                <li class="nav-item" >
                                    <a href="@Url.Action("Index", "Milestone")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Milestone" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-flag-checkered" aria-hidden="true"></i>
                                        <p>Milestones</p>
                                    </a>
                                </li>
                                <li class="nav-item" >
                                    <a href="@Url.Action("Index", "Action")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Action" ? "active" : "")" role="menuitem">
                                        <i class="nav-icon fas fa-tasks" aria-hidden="true"></i>
                                        <p>Actions</p>
                                    </a>
                                </li>
                            </ul>
                        </li>
                        -->

                    </ul>
                </nav>
                <!-- /.sidebar-menu -->
            </div>
            <!-- /.sidebar -->
        </aside>

        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            <!-- Breadcrumb Section -->
            <div class="content-header">
                <div class="container-fluid">
                    <div class="row mb-2">
                        <div class="col-sm-12">
                            @RenderSection("Breadcrumbs", required: false)
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main content -->
            <section class="content" id="main-content">
                <div class="container-fluid">
                    @RenderBody()
                </div><!-- /.container-fluid -->
            </section>
            <!-- /.content -->
        </div>
        <!-- /.content-wrapper -->
        <footer class="main-footer">
            <a href="#" class="footer-link">Cookies</a>
            <a href="@Url.Action("Accessibility", "Home")" class="footer-link">Accessibility</a>
            <a href="#" class="footer-link">Support</a>
            <a href="#" class="footer-link">Feedback</a>

            <a href="@Url.Action("UserInfo", "Profile")" class="footer-link">User</a>
        </footer>

        <!-- Control Sidebar -->
        <aside class="control-sidebar control-sidebar-dark">
            <!-- Control sidebar content goes here -->
        </aside>
        <!-- /.control-sidebar -->
    </div>
    <!-- ./wrapper -->

    <!-- jQuery -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- Bootstrap 4 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/4.6.2/js/bootstrap.bundle.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- DataTables -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.13.7/js/jquery.dataTables.min.js" nonce="@Context.Items["Nonce"]"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.13.7/js/dataTables.bootstrap4.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- Select2 -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.13/js/select2.full.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- AdminLTE App -->
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js" nonce="@Context.Items["Nonce"]"></script>
    <!-- Custom scripts -->
    <script src="~/js/custom.js" nonce="@Context.Items["Nonce"]"></script>
    <script src="~/js/staff-autocomplete.js" nonce="@Context.Items["Nonce"]"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
