@model string

@{
    var activeKey = Model ?? string.Empty;

    bool IsActive(string key) =>
        string.Equals(activeKey, key, System.StringComparison.OrdinalIgnoreCase);
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title mb-0">Standards navigation</h3>
    </div>
    <div class="card-body p-0">
        <ul class="nav nav-pills flex-column">
            <li class="nav-item">
                <a class="nav-link @(IsActive("Index") ? "active" : string.Empty)"
                   aria-current="@(IsActive("Index") ? "page" : null)"
                   href="@Url.Action("Index", "Standard")">
                    Standards overview
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(IsActive("Published") ? "active" : string.Empty)"
                   aria-current="@(IsActive("Published") ? "page" : null)"
                   href="@Url.Action("Published", "Standard")">
                    Published DDT standards
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(IsActive("Draft") ? "active" : string.Empty)"
                   aria-current="@(IsActive("Draft") ? "page" : null)"
                   href="@Url.Action("Draft", "Standard")">
                    Draft DDT standards
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(IsActive("Create") ? "active" : string.Empty)"
                   aria-current="@(IsActive("Create") ? "page" : null)"
                   href="@Url.Action("Create", "Standard")">
                    Create DDT standard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(IsActive("Functional") ? "active" : string.Empty)"
                   aria-current="@(IsActive("Functional") ? "page" : null)"
                   href="@Url.Action("FunctionalStandards", "EnterpriseReporting")">
                    Functional standards
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(IsActive("Service") ? "active" : string.Empty)"
                   aria-current="@(IsActive("Service") ? "page" : null)"
                   href="@Url.Action("Index", "ServiceStandards")">
                    Service standards
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(IsActive("TechnologyCodeOfPractice") ? "active" : string.Empty)"
                   aria-current="@(IsActive("TechnologyCodeOfPractice") ? "page" : null)"
                   href="@Url.Action("Index", "TechnologyCodeOfPractice")">
                    Technology Code of Practice
                </a>
            </li>
        </ul>
    </div>
</div>
