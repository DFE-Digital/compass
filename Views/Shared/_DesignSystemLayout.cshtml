                                        <p>Screen readers</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("KeyboardUsers", "DesignSystem")" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "KeyboardUsers" ? "active" : "")" role="menuitem">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Keyboard users</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("Zoom", "DesignSystem")" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Zoom" ? "active" : "")" role="menuitem">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Zoom</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("Reflow", "DesignSystem")" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Reflow" ? "active" : "")" role="menuitem">
                                        <i class="far fa-circle nav-icon" aria-hidden="true"></i>
                                        <p>Reflow</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("VoiceControl", "DesignSystem")" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "VoiceControl" ? "active" : "")" role="menuitem">
