@* Shared styles for the Reports dashboard suite *@
<style>
    /* ─── Dashboard header ─────────────────────────────────────────────────── */
    .reports-dashboard-header {
        background: #16548a;
        color: white;
        padding: 1.75rem 1.5rem;
        margin-bottom: 0;
    }
    /* Inline breadcrumb inside the header */
    .reports-breadcrumb {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.65);
        margin-bottom: 0.4rem;
    }
    .reports-breadcrumb a {
        color: rgba(255,255,255,0.75);
        text-decoration: none;
    }
    .reports-breadcrumb a:hover {
        color: white;
        text-decoration: underline;
    }
    .reports-breadcrumb span {
        margin: 0 0.3rem;
        opacity: 0.5;
    }
    .reports-dashboard-header h1 {
        color: white;
        font-size: 1.75rem;
        font-weight: 700;
        margin: 0;
    }
    .reports-dashboard-header p {
        color: rgba(255,255,255,0.85);
        margin: 0;
        font-size: 0.95rem;
    }
    .opacity-90 { opacity: 0.9; }

    /* ─── Stat detail modal ────────────────────────────────────────────────── */
    .stat-detail-modal-header {
        background: #16548a;
        color: white;
    }
    .stat-detail-modal-header .close {
        color: white;
        opacity: 0.8;
        text-shadow: none;
    }
    .stat-detail-modal-header .close:hover { opacity: 1; }
    /* Make stat cards behave as buttons visually */
    button.reports-stat-card {
        border: none;
        text-align: left;
        cursor: pointer;
        width: 100%;
    }
    button.reports-stat-card:focus {
        outline: 3px solid rgba(255,255,255,0.6);
        outline-offset: 2px;
    }

    /* ─── Intel button ─────────────────────────────────────────────────────── */
    .btn-intel {
        background: rgba(255,255,255,0.15);
        color: white;
        border: 2px solid rgba(255,255,255,0.5);
        border-radius: 8px;
        font-weight: 600;
        padding: 0.5rem 1.25rem;
        font-size: 0.9rem;
        box-shadow: none;
        transition: background 0.2s ease, border-color 0.2s ease;
    }
    .btn-intel:hover, .btn-intel:focus {
        background: rgba(255,255,255,0.28);
        color: white;
        border-color: white;
        box-shadow: none;
    }
    .btn-powerbi {
        background: #f2c811;
        color: #1a1a1a;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        padding: 0.5rem 1.25rem;
        font-size: 0.9rem;
        box-shadow: none;
        transition: background 0.2s ease;
    }
    .btn-powerbi:hover {
        background: #e8b800;
        color: #1a1a1a;
        box-shadow: none;
    }
    .btn-refresh {
        background: rgba(255,255,255,0.08);
        color: rgba(255,255,255,0.75);
        border: 1px solid rgba(255,255,255,0.25);
        border-radius: 6px;
        font-size: 0.8rem;
        padding: 0.35rem 0.75rem;
        box-shadow: none;
        transition: background 0.15s ease, color 0.15s ease;
    }
    .btn-refresh:hover {
        background: rgba(255,255,255,0.18);
        color: white;
        box-shadow: none;
    }
    .cache-age {
        font-size: 0.75rem;
        color: rgba(255,255,255,0.55);
        margin-top: 0.25rem;
    }

    /* ─── Navigation tabs bar ──────────────────────────────────────────────── */
    .reports-nav-bar {
        background: #f4f8fb;
        border-bottom: 2px solid #d0dde8;
        z-index: 200;  /* high enough for dropdowns to clear content below */
        box-shadow: none;
        position: relative; /* establish stacking context */
        padding-left: 1.5rem;
        padding-right: 1.5rem;
    }
    .reports-nav-tabs {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        /* NO overflow-x: auto – that clips absolute dropdowns */
        gap: 0;
        align-items: stretch;
        flex-wrap: wrap; /* wrap on small screens instead of clipping */
    }
    .reports-nav-tabs li {
        position: relative;
    }
    .reports-nav-tabs li a {
        display: block;
        padding: 0.875rem 1.1rem;
        color: #374151;
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        border-bottom: 3px solid transparent;
        white-space: nowrap;
        line-height: 1.4;
        transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
    }
    .reports-nav-tabs li a:hover {
        color: #16548a;
        background: #e8f0f8;
        border-bottom-color: #7aaed4;
    }
    .reports-nav-tabs li a.active {
        color: #16548a;
        border-bottom-color: #16548a;
        font-weight: 700;
        background: transparent;
    }

    /* ─── Nav dropdown – JS-driven (click to open) ─────────────────────────── */
    .reports-nav-dropdown {
        position: relative; /* menu anchors to this li, not the whole bar */
    }
    .reports-nav-dropdown-toggle {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.875rem 1.1rem;
        color: #374151;
        font-size: 0.875rem;
        font-weight: 500;
        border: none;
        border-bottom: 3px solid transparent;
        white-space: nowrap;
        cursor: pointer;
        background: none;
        transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
        line-height: 1.4;
        height: 100%;
    }
    .reports-nav-dropdown-toggle:hover {
        color: #16548a;
        background: #e8f0f8;
        border-bottom-color: #7aaed4;
    }
    .reports-nav-dropdown-toggle.active {
        color: #16548a;
        border-bottom-color: #16548a;
        font-weight: 700;
        background: transparent;
    }
    .reports-nav-dropdown-toggle[aria-expanded="true"] {
        color: #16548a;
        background: #e8f0f8;
        border-bottom-color: #16548a;
    }
    .reports-nav-dropdown-menu {
        display: none;
        position: absolute;
        top: 100%;
        left: 0; /* flush with the left edge of the li */
        background: white;
        border: 1px solid #e5e7eb;
        border-top: none;
        border-radius: 0 0 6px 6px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.12);
        min-width: 180px;
        max-height: 280px;
        overflow-y: auto;
        z-index: 9999;
        padding: 0.15rem 0;
    }
    .reports-nav-dropdown-menu.open {
        display: block;
    }
    .reports-nav-dropdown-menu a {
        display: block;
        padding: 0.25rem 0.9rem;
        color: #374151;
        font-size: 0.8rem;
        text-decoration: none;
        transition: background 0.1s ease;
        white-space: nowrap;
    }
    .reports-nav-dropdown-menu a:hover {
        background: #f0f7ff;
        color: #005ea5;
    }
    .reports-nav-dropdown-menu a.active {
        background: #e8f0fe;
        color: #005ea5;
        font-weight: 600;
    }
    .reports-nav-dropdown-menu .dropdown-divider {
        border-top: 1px solid #f3f4f6;
        margin: 0.25rem 0;
    }
    /* Scroll-more indicator */
    .reports-nav-dropdown {
        /* already position:relative from earlier rule */
    }
    .dropdown-scroll-hint {
        display: none;
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 2rem;
        background: linear-gradient(to bottom, rgba(255,255,255,0) 0%, rgba(255,255,255,0.95) 60%, rgba(255,255,255,1) 100%);
        pointer-events: none;
        border-radius: 0 0 6px 6px;
        z-index: 10000;
        text-align: center;
        line-height: 2.4rem;
        color: #6b7280;
        font-size: 0.65rem;
    }
    .dropdown-scroll-hint i {
        animation: bounce-down 1.2s ease-in-out infinite;
    }
    @@keyframes bounce-down {
        0%, 100% { transform: translateY(0); }
        50%       { transform: translateY(3px); }
    }
    .reports-nav-dropdown-menu.open ~ .dropdown-scroll-hint.visible {
        display: block;
    }
    .caret-icon {
        font-size: 0.65rem;
        opacity: 0.6;
        transition: transform 0.2s ease;
    }
    .reports-nav-dropdown-toggle[aria-expanded="true"] .caret-icon {
        transform: rotate(180deg);
    }

    /* ─── Inner tabs (within a view) ──────────────────────────────────────── */
    .reports-inner-tabs {
        border-bottom: 2px solid #e5e7eb;
    }
    .reports-inner-tabs .nav-link {
        color: #4b5563;
        font-weight: 500;
        border: none;
        border-bottom: 3px solid transparent;
        padding: 0.75rem 1.25rem;
        border-radius: 0;
    }
    .reports-inner-tabs .nav-link.active {
        color: #005ea5;
        border-bottom-color: #005ea5;
        background: transparent;
        font-weight: 700;
    }
    .reports-inner-tabs .nav-link:hover {
        color: #005ea5;
        background: #f0f7ff;
    }

    /* ─── Stat cards grid ──────────────────────────────────────────────────── */
    .reports-stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 1rem;
    }
    .reports-stat-card {
        border-radius: 12px;
        padding: 1.25rem;
        color: white;
        position: relative;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.12);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        text-decoration: none;
        display: block;
    }
    a.reports-stat-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(0,0,0,0.18);
        color: white;
        text-decoration: none;
    }
    .reports-stat-blue  { background: linear-gradient(135deg, #005ea5 0%, #003078 100%); }
    .reports-stat-green { background: linear-gradient(135deg, #00703c 0%, #005a30 100%); }
    .reports-stat-red   { background: linear-gradient(135deg, #d4351c 0%, #aa2a12 100%); }
    .reports-stat-amber { background: linear-gradient(135deg, #f47738 0%, #d4351c 100%); }
    .reports-stat-purple{ background: linear-gradient(135deg, #4a1d96 0%, #7c3aed 100%); }
    .reports-stat-gold  { background: linear-gradient(135deg, #b45309 0%, #d97706 100%); }
    .reports-stat-teal  { background: linear-gradient(135deg, #0f766e 0%, #0d9488 100%); }
    .reports-stat-icon {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        font-size: 2.5rem;
        opacity: 0.2;
    }
    .reports-stat-value {
        font-size: 2.25rem;
        font-weight: 800;
        line-height: 1;
        margin-bottom: 0.25rem;
    }
    .reports-stat-label {
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        opacity: 0.9;
    }
    .reports-stat-sub {
        font-size: 0.75rem;
        opacity: 0.75;
        margin-top: 0.25rem;
    }

    /* ─── RAG stacked bar – accessible ────────────────────────────────────── */
    .rag-bar-container { }
    .rag-stacked-bar {
        display: flex;
        height: 32px;
        border-radius: 6px;
        overflow: hidden;
        background: #e5e7eb;
    }
    .rag-segment {
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.72rem;
        font-weight: 700;
        color: white;
        transition: flex 0.3s ease;
        min-width: 0;
        overflow: hidden;
        gap: 0.2rem;
    }
    .rag-segment span { white-space: nowrap; }
    .rag-segment-label { white-space: nowrap; font-size: 0.68rem; font-weight: 600; }
    .rag-green      { background: #00703c; }
    .rag-amber-green{ background: #85994b; }
    .rag-amber      { background: #f47738; }
    .rag-amber-red  { background: #b5400a; }
    .rag-red        { background: #d4351c; }
    .rag-unknown    { background: #9ca3af; color: #1f2937; }

    .rag-legend {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem 1rem;
        font-size: 0.8rem;
        margin-top: 0.6rem;
    }
    .rag-legend-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        color: #374151;
    }
    .rag-swatch {
        width: 14px;
        height: 14px;
        border-radius: 3px;
        display: inline-block;
        flex-shrink: 0;
        border: 1px solid rgba(0,0,0,0.1);
    }
    .rag-swatch-green      { background: #00703c; }
    .rag-swatch-amber-green{ background: #85994b; }
    .rag-swatch-amber      { background: #f47738; }
    .rag-swatch-amber-red  { background: #b5400a; }
    .rag-swatch-red        { background: #d4351c; }
    .rag-swatch-unknown    { background: #9ca3af; }

    /* ─── Reports table ────────────────────────────────────────────────────── */
    .reports-table {
        font-size: 0.875rem;
    }
    .reports-table thead th {
        background: #f8fafc;
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #6b7280;
        border-bottom: 2px solid #e5e7eb;
        padding: 0.65rem 0.9rem;
    }
    .reports-table tbody td {
        padding: 0.65rem 0.9rem;
        vertical-align: middle;
    }
    .reports-table tbody tr:hover {
        background: #f0f7ff;
    }
    .project-link {
        text-decoration: none;
    }
    .project-link:hover {
        text-decoration: underline;
        color: #005ea5 !important;
    }

    /* ─── Expandable BA rows ───────────────────────────────────────────────── */
    .ba-expand-btn {
        background: none;
        border: 1px solid #d1d5db;
        border-radius: 4px;
        width: 22px;
        height: 22px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        line-height: 1;
        color: #374151;
        cursor: pointer;
        transition: all 0.15s ease;
        font-weight: 400;
        flex-shrink: 0;
        padding: 0;
    }
    .ba-expand-btn:hover {
        background: #005ea5;
        border-color: #005ea5;
        color: white;
    }
    /* Parent row stays highlighted when its child is open */
    .ba-summary-row.is-open {
        background: #e8f4ff !important;
    }
    .ba-summary-row.is-open td {
        border-bottom: none;
    }
    .ba-expand-row {
        display: none;
    }
    .ba-expand-row.open {
        display: table-row;
    }
    .ba-expand-row.open td {
        background: white;
        padding: 0;
        border-bottom: 2px solid #e5e7eb;
    }
    .ba-projects-inner {
        padding: 0.75rem 1.25rem 1rem 1.25rem;
    }
    /* Mini table inside expanded row */
    .ba-projects-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.83rem;
    }
    .ba-projects-table thead th {
        padding: 0.5rem 0.75rem;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        color: #6b7280;
        border-bottom: 2px solid #e5e7eb;
        white-space: nowrap;
        background: #f8fafc;
    }
    .ba-projects-table tbody td {
        padding: 0.6rem 0.75rem;
        vertical-align: middle;
        border-bottom: 1px solid #f3f4f6;
        color: #374151;
        background: white;
    }
    .ba-projects-table tbody tr:last-child td {
        border-bottom: none;
    }
    .ba-projects-table tbody tr:hover td {
        background: #f0f7ff;
    }
    .ba-project-name {
        font-weight: 600;
        color: #1f2937;
        text-decoration: none;
        font-size: 0.875rem;
    }
    .ba-project-name:hover { color: #005ea5; text-decoration: underline; }
    .ba-expand-footer {
        padding: 0.6rem 0.75rem 0.25rem;
        border-top: 1px solid #e5e7eb;
        margin-top: 0.25rem;
    }

    /* ─── Priority cards grid ──────────────────────────────────────────────── */
    .priority-cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
        gap: 1.25rem;
    }
    .priority-card {
        background: white;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
        border-left-width: 4px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.06);
        transition: box-shadow 0.2s ease, transform 0.2s ease;
        display: flex;
        flex-direction: column;
    }
    .priority-card:hover {
        box-shadow: 0 4px 16px rgba(0,0,0,0.12);
        transform: translateY(-2px);
    }
    .border-left-success { border-left-color: #00703c; }
    .border-left-warning { border-left-color: #f47738; }
    .border-left-danger  { border-left-color: #d4351c; }
    .border-left-secondary { border-left-color: #9ca3af; }
    .priority-card-header {
        padding: 1rem 1rem 0.5rem;
        border-bottom: 1px solid #f3f4f6;
    }
    .priority-card-title-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.5rem;
        margin-bottom: 0.25rem;
    }
    .priority-card-title {
        font-weight: 700;
        color: #1f2937;
        text-decoration: none;
        font-size: 0.95rem;
        line-height: 1.4;
        flex: 1;
    }
    .priority-card-title:hover { color: #005ea5; text-decoration: underline; }
    .priority-card-badges { display: flex; gap: 0.25rem; flex-shrink: 0; flex-wrap: wrap; }
    .priority-card-body {
        padding: 0.75rem 1rem;
        flex: 1;
    }
    .priority-card-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }
    .priority-meta-item {
        font-size: 0.75rem;
        color: #6b7280;
        display: flex;
        align-items: center;
    }
    .priority-card-aim {
        font-size: 0.85rem;
        color: #4b5563;
        line-height: 1.5;
        margin-bottom: 0.5rem;
    }
    .priority-card-people {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    .priority-person-item {
        font-size: 0.8rem;
        color: #6b7280;
    }
    .priority-card-footer {
        padding: 0.65rem 1rem;
        background: #f9fafb;
        border-top: 1px solid #f3f4f6;
        border-radius: 0 0 10px 10px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem;
    }
    .priority-card-indicators {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }
    .priority-indicator {
        font-size: 0.75rem;
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        font-weight: 500;
    }
    .priority-indicator-danger  { background: #fef2f2; color: #d4351c; }
    .priority-indicator-warning { background: #fffbeb; color: #b45309; }
    .priority-indicator-success { background: #f0fdf4; color: #00703c; }

    /* ─── Priority group heading ───────────────────────────────────────────── */
    .priority-group-heading {
        font-size: 1rem;
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .priority-badge {
        background: linear-gradient(135deg, #005ea5 0%, #003078 100%);
        color: white;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    /* ─── Leadership avatar ────────────────────────────────────────────────── */
    .leadership-avatar-placeholder {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, #005ea5 0%, #003078 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.875rem;
    }

    /* ─── Intel modal ──────────────────────────────────────────────────────── */
    .intel-modal-content {
        border: none;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
    .intel-modal-header {
        background: linear-gradient(135deg, #003078 0%, #005ea5 100%);
        color: white;
        border: none;
        padding: 1.25rem 1.5rem;
    }
    .intel-icon {
        width: 44px;
        height: 44px;
        background: rgba(255,255,255,0.2);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
    }
    .intel-modal-body {
        padding: 1.5rem;
        background: #fafafa;
    }
    .intel-modal-footer {
        background: #f3f4f6;
        border-top: 1px solid #e5e7eb;
        padding: 1rem 1.5rem;
    }
    .intel-status-banner {
        border-radius: 10px;
        padding: 1rem 1.25rem;
        font-size: 0.95rem;
    }
    .intel-status-good  { background: #f0fdf4; color: #00703c; border: 1px solid #bbf7d0; }
    .intel-status-watch { background: #fffbeb; color: #92400e; border: 1px solid #fde68a; }
    .intel-status-risk  { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
    .intel-section {
        background: white;
        border-radius: 10px;
        padding: 1rem 1.25rem;
        border: 1px solid #e5e7eb;
    }
    .intel-section-title {
        font-size: 0.875rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.75rem;
        display: flex;
        align-items: center;
    }
    .intel-positive { color: #00703c; }
    .intel-watch    { color: #92400e; }
    .intel-risk     { color: #991b1b; }
    .intel-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .intel-list-item {
        font-size: 0.9rem;
        line-height: 1.5;
        display: flex;
        align-items: flex-start;
        gap: 0.25rem;
    }
    .intel-list-positive { color: #1f2937; }
    .intel-list-watch    { color: #1f2937; }
    .intel-list-risk     { color: #1f2937; }
    .intel-disclaimer {
        font-size: 0.8rem;
        color: #9ca3af;
        font-style: italic;
    }

