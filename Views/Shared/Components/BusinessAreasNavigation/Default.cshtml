@model List<string>

<!-- All DDT option -->
<li class="nav-item">
    <a href="@Url.Action("ViewReport", "DdtReports")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "DdtReports" && ViewContext.RouteData.Values["Action"]?.ToString() == "ViewReport" ? "active" : "")" role="menuitem">
        <i class="nav-icon fas fa-chart-line" aria-hidden="true"></i>
        <p>All DDT</p>
    </a>
</li>

<!-- Flagship Projects option -->
<li class="nav-item">
    <a href="@Url.Action("FlagshipProjects", "DdtReports")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "DdtReports" && ViewContext.RouteData.Values["Action"]?.ToString() == "FlagshipProjects" ? "active" : "")" role="menuitem">
        <i class="nav-icon fas fa-flag text-primary" aria-hidden="true"></i>
        <p>Flagship Projects</p>
    </a>
</li>

@if (Model != null && Model.Any())
{
    foreach (var area in Model.OrderBy(a => a))
    {
        <li class="nav-item">
            <a href="@Url.Action("BusinessArea", "DdtReports", new { area = area })" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "DdtReports" && ViewContext.RouteData.Values["Action"]?.ToString() == "BusinessArea" && Context.Request.Query["area"] == area ? "active" : "")" role="menuitem">
                <i class="nav-icon fas fa-building" aria-hidden="true"></i>
                <p>@area</p>
            </a>
        </li>
    }
}

