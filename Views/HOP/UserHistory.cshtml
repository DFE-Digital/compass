@model List<Compass.Models.TrainingRecord>

@{
    ViewData["Title"] = "User history";
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="HOPDashboard" asp-controller="SkillsAndLearning" style="color: #005ea5; text-decoration: none;">HOP dashboard</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">User history</li>
        </ol>
    </nav>
}

<div class="dashboard-header">
    <div>
        <h1>User history</h1>
        <p>View training history for users in your profession scope</p>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <!-- Left Column: Filters -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <!-- Filters -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Filters</h3>
                    </div>
                    <div class="card-body">
                        <form method="get" asp-action="UserHistory">
                            <div class="form-group">
                                <label>Search</label>
                                <input type="text" name="search" class="form-control form-control-sm" value="@ViewBag.Search" placeholder="Search by user or course..." />
                            </div>
                            <div class="form-group">
                                <button type="submit" class="btn btn-primary btn-sm btn-block">Apply filters</button>
                                <a asp-action="UserHistory" class="btn btn-default btn-sm btn-block">Clear all filters</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Column: Records List -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <div class="card">
            <div class="card-header">
                <h3 class="card-title">Training records (@Model.Count)</h3>
            </div>
            <div class="card-body p-0">
                @if (Model.Any())
                {
                    <table class="table table-hover text-nowrap sortable-table mb-0">
                        <thead>
                            <tr>
                                <th class="sortable" data-column="User">User</th>
                                <th class="sortable" data-column="Course">Course</th>
                                <th class="sortable" data-column="Status">Status</th>
                                <th class="sortable" data-column="DateAttended">Date attended</th>
                                <th class="sortable" data-column="Cost">Cost</th>
                                <th class="sortable" data-column="Rating">Rating</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var record in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@(record.User?.Name ?? "Unknown")</strong><br>
                                        <small class="text-muted">@(record.User?.Email ?? "N/A")</small>
                                    </td>
                                    <td>@(record.Course?.Title ?? "Custom course")</td>
                                    <td>
                                        @switch (record.Status)
                                        {
                                            case "Booked":
                                                <span class="badge badge-info">Booked</span>
                                                break;
                                            case "Completed":
                                                <span class="badge badge-success">Completed</span>
                                                break;
                                            case "Cancelled":
                                                <span class="badge badge-danger">Cancelled</span>
                                                break;
                                            default:
                                                <span class="badge badge-secondary">@record.Status</span>
                                                break;
                                        }
                                    </td>
                                    <td>@((record.DateAttended ?? record.DateRequested)?.ToString("dd MMM yyyy") ?? "N/A")</td>
                                    <td>@(record.CostActual.HasValue ? $"£{record.CostActual.Value:N0}" : "N/A")</td>
                                    <td>
                                        @if (record.OutcomeRating.HasValue)
                                        {
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="fas fa-star @(i <= record.OutcomeRating.Value ? "text-warning" : "text-muted")"></i>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-3">
                        <p class="text-muted mb-0">No training records found.</p>
                    </div>
                }
            </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            $('.sortable-table').each(function() {
                initializeSortableTable($(this));
            });
        });
    </script>
}

