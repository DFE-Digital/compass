@{
    ViewData["Title"] = "Capability trends";
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="HOPDashboard" asp-controller="SkillsAndLearning" style="color: #005ea5; text-decoration: none;">HOP dashboard</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Capability trends</li>
        </ol>
    </nav>
}

<div class="dashboard-header">
    <div>
        <h1>Capability trends</h1>
        <p>Identify department-wide capability trends</p>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Capability gaps by profession</h3>
                    </div>
                    <div class="card-body p-0">
                        @if (ViewBag.GapsByProfession != null)
                        {
                            var gapsList = ViewBag.GapsByProfession as System.Collections.IEnumerable;
                            var hasGaps = gapsList != null && gapsList.Cast<dynamic>().Any();
                            if (hasGaps)
                            {
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Profession</th>
                                            <th>Users with gaps</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (dynamic item in gapsList)
                                        {
                                            <tr>
                                                <td><strong>@item.Profession</strong></td>
                                                <td>@item.UsersWithGaps</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="p-3">
                                    <p class="text-muted mb-0">No capability gap data available.</p>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="p-3">
                                <p class="text-muted mb-0">No capability gap data available.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Training trends by profession</h3>
                    </div>
                    <div class="card-body p-0">
                        @if (ViewBag.TrainingTrends != null)
                        {
                            var trendsList = ViewBag.TrainingTrends as System.Collections.IEnumerable;
                            var hasTrends = trendsList != null && trendsList.Cast<dynamic>().Any();
                            if (hasTrends)
                            {
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Profession</th>
                                            <th>Year</th>
                                            <th>Training count</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (dynamic item in trendsList)
                                        {
                                            <tr>
                                                <td><strong>@item.Profession</strong></td>
                                                <td>@item.Year</td>
                                                <td>@item.Count</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="p-3">
                                    <p class="text-muted mb-0">No training trend data available.</p>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="p-3">
                                <p class="text-muted mb-0">No training trend data available.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

