@using Compass.Controllers
@{
    ViewData["Title"] = "Central Operations Dashboard";
    var businessAreaSummary = ViewBag.BusinessAreaSummary as List<BusinessAreaSummaryItem> ?? new List<BusinessAreaSummaryItem>();
    var activeWorkItems = ViewBag.ActiveWorkItems as int? ?? 0;
    var allProjects = ViewBag.AllProjects as List<Compass.Models.Project> ?? new List<Compass.Models.Project>();
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="CentralOps" asp-action="Dashboard" style="color: #005ea5; text-decoration: none;">Central Operations</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Dashboard</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Central Operations Dashboard</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <!-- Summary Cards -->
        <div class="row mb-4">
            <div class="col-lg-4 col-6">
                <div class="small-box bg-success">
                    <div class="inner">
                        <h3>@activeWorkItems</h3>
                        <p>Active Work Items</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-6">
                <div class="small-box bg-info">
                    <div class="inner">
                        @{
                            var totalProjects = allProjects.Count;
                        }
                        <h3>@totalProjects</h3>
                        <p>Total Work Items</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-list"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-6">
                <div class="small-box bg-danger">
                    <div class="inner">
                        @{
                            var redItems = allProjects.Count(p => {
                                if (string.IsNullOrEmpty(p.RagStatus)) return false;
                                var normalized = p.RagStatus.Trim()
                                    .Replace(" / ", "-")
                                    .Replace("/", "-")
                                    .Replace(" /", "-")
                                    .Replace("/ ", "-");
                                return normalized == "Red" || normalized == "Amber-Red";
                            });
                        }
                        <h3>@redItems</h3>
                        <p>Red/Amber-Red Items</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-times-circle"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Business Area Summary -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Summary by Business Area</h3>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover mb-0 sortable-table">
                            <thead>
                                <tr>
                                    <th rowspan="2" class="sortable" data-column="BusinessArea" tabindex="0" role="button" aria-label="Sort by Business Area">Business Area</th>
                                    <th rowspan="2" style="width: 100px;" class="sortable" data-column="Total" tabindex="0" role="button" aria-label="Sort by Work items">Work items</th>
                                    <th colspan="5" style="text-align: center; background-color: #f8f9fa; font-weight: 600;">RAG Ratings</th>
                                    <th colspan="4" style="text-align: center; background-color: #f8f9fa; font-weight: 600;">Priority</th>
                                    <th rowspan="2" style="width: 120px;" class="sortable" data-column="Blocked" tabindex="0" role="button" aria-label="Sort by Blocked">Blocked</th>
                                </tr>
                                <tr>
                                    <th style="width: 120px;" class="sortable" data-column="Red" tabindex="0" role="button" aria-label="Sort by Red">Red</th>
                                    <th style="width: 140px;" class="sortable" data-column="AmberRed" tabindex="0" role="button" aria-label="Sort by Amber-Red">Amber-Red</th>
                                    <th style="width: 120px;" class="sortable" data-column="Amber" tabindex="0" role="button" aria-label="Sort by Amber">Amber</th>
                                    <th style="width: 140px;" class="sortable" data-column="AmberGreen" tabindex="0" role="button" aria-label="Sort by Amber-Green">Amber-Green</th>
                                    <th style="width: 120px;" class="sortable" data-column="Green" tabindex="0" role="button" aria-label="Sort by Green">Green</th>
                                    <th style="width: 120px;" class="sortable" data-column="CriticalPriority" tabindex="0" role="button" aria-label="Sort by Critical Priority">Critical</th>
                                    <th style="width: 120px;" class="sortable" data-column="HighPriority" tabindex="0" role="button" aria-label="Sort by High Priority">High</th>
                                    <th style="width: 120px;" class="sortable" data-column="MediumPriority" tabindex="0" role="button" aria-label="Sort by Medium Priority">Medium</th>
                                    <th style="width: 120px;" class="sortable" data-column="LowPriority" tabindex="0" role="button" aria-label="Sort by Low Priority">Low</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (businessAreaSummary != null && businessAreaSummary.Any())
                                {
                                    @foreach (var item in businessAreaSummary)
                                    {
                                        <tr>
                                            <td><strong>@item.BusinessArea</strong></td>
                                            <td>@item.Count</td>
                                            <td>
                                                @if (item.RedCount > 0)
                                                {
                                                    <span class="badge badge-danger">@item.RedCount</span>
                                                }
                                                else
                                                {
                                                    <span>0</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.AmberRedCount > 0)
                                                {
                                                    <span class="badge badge-amber-red">@item.AmberRedCount</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">0</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.AmberCount > 0)
                                                {
                                                    <span class="badge badge-warning">@item.AmberCount</span>
                                                }
                                                else
                                                {
                                                    <span>0</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.AmberGreenCount > 0)
                                                {
                                                    <span class="badge badge-amber-green">@item.AmberGreenCount</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">0</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.GreenCount > 0)
                                                {
                                                    <span class="badge badge-success">@item.GreenCount</span>
                                                }
                                                else
                                                {
                                                    <span>0</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.CriticalPriorityCount > 0)
                                                {
                                                    <span class="badge badge-danger">@item.CriticalPriorityCount</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">0</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.HighPriorityCount > 0)
                                                {
                                                    <span class="badge badge-danger">@item.HighPriorityCount</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">0</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.MediumPriorityCount > 0)
                                                {
                                                    <span class="badge badge-warning">@item.MediumPriorityCount</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">0</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.LowPriorityCount > 0)
                                                {
                                                    <span class="badge badge-secondary">@item.LowPriorityCount</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">0</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.BlockedCount > 0)
                                                {
                                                    <span class="badge badge-danger">@item.BlockedCount</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">0</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="12" class="text-center text-muted py-3">No business area data available</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- All Work Items -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">All Work Items</h3>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover mb-0 sortable-table">
                            <thead>
                                <tr>
                                    <th style="width: 250px;" class="sortable" data-column="Title" tabindex="0" role="button" aria-label="Sort by Title">Title</th>
                                    <th style="width: 100px;" class="sortable" data-column="Priority" tabindex="0" role="button" aria-label="Sort by Priority">Priority</th>
                                    <th style="width: 120px;" class="sortable" data-column="Rag" tabindex="0" role="button" aria-label="Sort by RAG">RAG</th>
                                    <th style="width: 150px;" class="sortable" data-column="BusinessArea" tabindex="0" role="button" aria-label="Sort by Business Area">Business Area</th>
                                    <th style="width: 150px;" class="sortable" data-column="PrimaryContact" tabindex="0" role="button" aria-label="Sort by Primary Contact">Primary Contact</th>
                                    <th style="width: 200px;" class="sortable" data-column="ServiceOwner" tabindex="0" role="button" aria-label="Sort by Service Owner">Service Owner</th>
                                    <th style="width: 100px;" class="sortable" data-column="Flagship" tabindex="0" role="button" aria-label="Sort by Flagship">Flagship</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (allProjects != null && allProjects.Any())
                                {
                                    @foreach (var item in allProjects)
                                    {
                                        <tr>
                                            <td>
                                                <a asp-controller="Project" asp-action="Details" asp-route-id="@item.Id" style="font-weight: bold; color: #005ea5; text-decoration: none;">@item.Title</a>
                                                <br />
                                                <small class="text-muted">DFE-DDT-@item.Id</small>
                                            </td>
                                            <td>
                                                @if (item.DeliveryPriority != null && !string.IsNullOrEmpty(item.DeliveryPriority.Name))
                                                {
                                                    var priorityClass = item.DeliveryPriority.Name.ToLower() switch {
                                                        var p when p.Contains("critical") => "badge-danger",
                                                        var p when p.Contains("high") => "badge-danger",
                                                        var p when p.Contains("medium") => "badge-warning",
                                                        var p when p.Contains("low") => "badge-secondary",
                                                        _ => "badge-secondary"
                                                    };
                                                    <span class="badge @priorityClass">@item.DeliveryPriority.Name</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.RagStatus))
                                                {
                                                    var normalized = item.RagStatus.Trim()
                                                        .Replace(" / ", "-")
                                                        .Replace("/", "-")
                                                        .Replace(" /", "-")
                                                        .Replace("/ ", "-");
                                                    
                                                    var ragClass = normalized switch {
                                                        "Red" => "badge badge-red",
                                                        "Amber-Red" => "badge badge-amber-red",
                                                        "Amber" => "badge badge-amber",
                                                        "Amber-Green" => "badge badge-amber-green",
                                                        "Green" => "badge badge-green",
                                                        _ => "badge badge-secondary"
                                                    };
                                                    <span class="@ragClass">@item.RagStatus</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>@(item.BusinessAreaLookup?.Name ?? "-")</td>
                                            <td>
                                                @if (item.PrimaryContactUser != null)
                                                {
                                                    @item.PrimaryContactUser.Name
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.ServiceOwners != null && item.ServiceOwners.Any())
                                                {
                                                    var serviceOwners = item.ServiceOwners.Where(so => so.User != null).Take(2).ToList();
                                                    @foreach (var so in serviceOwners)
                                                    {
                                                        <div>@so.User.Name</div>
                                                    }
                                                    @if (item.ServiceOwners.Count > 2)
                                                    {
                                                        <small class="text-muted">+ @(item.ServiceOwners.Count - 2) more</small>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.IsFlagship)
                                                {
                                                    <span class="badge badge-info">Yes</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="7" class="text-center text-muted py-3">No work items found</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Initialize sortable tables
            $('.sortable-table').each(function() {
                initializeSortableTable($(this));
            });
        });

        function initializeSortableTable(table) {
            var currentSort = { column: null, direction: 'asc' };

            table.find('.sortable').on('click keypress', function(e) {
                if (e.type === 'keypress' && e.which !== 13 && e.which !== 32) {
                    return;
                }
                
                var column = $(this).data('column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(table, column, direction);
                currentSort = { column: column, direction: direction };
            });

            function sortTable(table, column, direction) {
                var tbody = table.find('tbody');
                var rows = tbody.find('tr').toArray();
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var colIndex = table.find('thead th[data-column="' + column + '"]').index();
                    
                    if (column === 'DueDate') {
                        var aDate = $(a).find('td').eq(colIndex).text().trim();
                        var bDate = $(b).find('td').eq(colIndex).text().trim();
                        aVal = aDate === '-' ? new Date(9999, 11, 31) : new Date(aDate);
                        bVal = bDate === '-' ? new Date(9999, 11, 31) : new Date(bDate);
                    } else if (['Total', 'Red', 'AmberRed', 'Amber', 'AmberGreen', 'Green', 'CriticalPriority', 'HighPriority', 'MediumPriority', 'LowPriority', 'Blocked'].includes(column)) {
                        // Numeric sorting for summary columns
                        aVal = parseInt($(a).find('td').eq(colIndex).text().trim()) || 0;
                        bVal = parseInt($(b).find('td').eq(colIndex).text().trim()) || 0;
                    } else if (column === 'Flagship') {
                        // Sort by Yes/No for Flagship
                        var aText = $(a).find('td').eq(colIndex).text().trim().toLowerCase();
                        var bText = $(b).find('td').eq(colIndex).text().trim().toLowerCase();
                        aVal = aText === 'yes' ? 1 : 0;
                        bVal = bText === 'yes' ? 1 : 0;
                    } else {
                        aVal = $(a).find('td').eq(colIndex).text().trim().toLowerCase();
                        bVal = $(b).find('td').eq(colIndex).text().trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.empty();
                rows.forEach(function(row) {
                    tbody.append(row);
                });
                
                updateSortIcons(table, column, direction);
            }

            function updateSortIcons(table, column, direction) {
                table.find('.sortable i').remove();
                var header = table.find('.sortable[data-column="' + column + '"]');
                var iconClass = direction === 'asc' ? 'fa-sort-up' : 'fa-sort-down';
                header.append(' <i class="fas ' + iconClass + '"></i>');
            }
        }
    </script>
}

