@section Scripts {
    <script src="~/js/user-picker.js" asp-append-version="true"></script>
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Tab navigation
            $('.list-group-item[data-tab]').on('click', function(e) {
                e.preventDefault();
                var tab = $(this).data('tab');
                
                // Update active nav item
                $('.list-group-item').removeClass('active');
                $(this).addClass('active');
                
                // Show/hide sections
                $('.tab-section').addClass('d-none');
                $('#' + tab + '-section').removeClass('d-none');
                
                // Update URL without reload
                if (history.pushState) {
                    var newUrl = window.location.pathname + '?tab=' + tab;
                    window.history.pushState({path: newUrl}, '', newUrl);
                }
            });
            
            // Handle change link clicks
            $(document).on('click', '.change-link', function(e) {
                e.preventDefault();
                var field = $(this).data('field');
                // Map field names to modal IDs
                var modalMap = {
                    'title': '#editTitleModal',
                    'aim': '#editAimModal',
                    'businessArea': '#editBusinessAreaModal',
                    'phase': '#editPhaseModal',
                    'activityType': '#editActivityTypeModal',
                    'status': '#editStatusModal',
                    'priority': '#editPriorityModal',
                    'ragStatus': '#editRagStatusModal',
                    'primaryContact': '#editPrimaryContactModal',
                    'flagship': '#editFlagshipModal',
                    'startDate': '#editStartDateModal',
                    'targetDate': '#editTargetDateModal',
                    'sros': '#editSrosModal',
                    'serviceOwners': '#editServiceOwnersModal',
                    'pmoContacts': '#editPmoContactsModal',
                    'directorates': '#editDirectoratesModal',
                    'missionPillars': '#editMissionPillarsModal',
                    'priorityOutcomes': '#editPriorityOutcomesModal'
                };
                var modalId = modalMap[field] || '#edit' + field.charAt(0).toUpperCase() + field.slice(1) + 'Modal';
                $(modalId).modal('show');
            });
            
            // Handle status change to show/hide reason field
            $('#statusInput').on('change', function() {
                var status = $(this).val();
                var $reasonGroup = $('#statusReasonGroup');
                var $reasonField = $('#statusReasonInput');
                
                if (status === 'Paused' || status === 'Completed' || status === 'Cancelled') {
                    $reasonGroup.show();
                    $reasonField.prop('required', true);
                } else {
                    $reasonGroup.hide();
                    $reasonField.prop('required', false);
                    $reasonField.val('');
                }
            });
            
            // Auto-dismiss alerts
            setTimeout(function() {
                $('.alert').fadeOut('slow');
            }, 5000);
        });
    </script>
}
