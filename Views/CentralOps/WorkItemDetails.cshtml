@model Compass.Models.Project
@{
    ViewData["Title"] = "Work Item Details";
    var priorities = ViewBag.Priorities as List<Compass.Models.DeliveryPriority> ?? new List<Compass.Models.DeliveryPriority>();
    var businessAreas = ViewBag.BusinessAreas as List<Compass.Models.BusinessAreaLookup> ?? new List<Compass.Models.BusinessAreaLookup>();
    var phases = ViewBag.Phases as List<Compass.Models.PhaseLookup> ?? new List<Compass.Models.PhaseLookup>();
    var activityTypes = ViewBag.ActivityTypes as List<Compass.Models.ActivityTypeLookup> ?? new List<Compass.Models.ActivityTypeLookup>();
    var directorates = ViewBag.Directorates as List<Compass.Models.DirectorateLookup> ?? new List<Compass.Models.DirectorateLookup>();
    var ragStatuses = ViewBag.RagStatuses as string[] ?? new[] { "Red", "Amber-Red", "Amber", "Amber-Green", "Green" };
    var statuses = ViewBag.Statuses as string[] ?? new[] { "Active", "Paused", "Completed", "Cancelled" };
    var currentTab = ViewBag.CurrentTab as string ?? "overview";
    var deliveryCode = $"DFE-DDT-{Model.Id}";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="CentralOps" asp-action="Dashboard" style="color: #005ea5; text-decoration: none;">Central Operations</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="CentralOps" asp-action="ManageWork" style="color: #005ea5; text-decoration: none;">Manage Work</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12 col-md-8">
                <h1 class="m-0">@Model.Title</h1>
                <p class="text-muted mb-0">
                    @deliveryCode
                    @if (Model.IsFlagship)
                    {
                        <span class="badge badge-info ml-2">Flagship project</span>
                    }
                </p>
            </div>
            <div class="col-sm-12 col-md-4 text-md-right">
                <a asp-controller="CentralOps" asp-action="ManageWork" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to Manage Work
                </a>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <div class="row">
            <!-- Left Column: Navigation -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title">Navigation</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <a href="#overview" class="list-group-item list-group-item-action @(currentTab == "overview" ? "active" : "")" data-tab="overview">Overview</a>
                            <a href="#basic" class="list-group-item list-group-item-action @(currentTab == "basic" ? "active" : "")" data-tab="basic">Basic Information</a>
                            <a href="#contacts" class="list-group-item list-group-item-action @(currentTab == "contacts" ? "active" : "")" data-tab="contacts">Contacts & Governance</a>
                            <a href="#strategic" class="list-group-item list-group-item-action @(currentTab == "strategic" ? "active" : "")" data-tab="strategic">Strategic Alignment</a>
                            <a href="#dates" class="list-group-item list-group-item-action @(currentTab == "dates" ? "active" : "")" data-tab="dates">Dates & Timeline</a>
                            <a href="#status" class="list-group-item list-group-item-action @(currentTab == "status" ? "active" : "")" data-tab="status">Status & Priority</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Content -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <!-- Overview Section -->
                <div id="overview-section" class="tab-section @(currentTab == "overview" ? "" : "d-none")">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h3 class="card-title">Overview</h3>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-borderless mb-0 project-overview-summary">
                                <tbody>
                                    <tr>
                                        <td class="summary-label"><strong>Title</strong></td>
                                        <td class="summary-value">@Model.Title</td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="title">Change</a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="summary-label"><strong>Project Code</strong></td>
                                        <td class="summary-value">@deliveryCode</td>
                                        <td class="summary-action text-right"></td>
                                    </tr>
                                    <tr>
                                        <td class="summary-label"><strong>Aim</strong></td>
                                        <td class="summary-value">
                                            @if (!string.IsNullOrEmpty(Model.Aim))
                                            {
                                                @Model.Aim
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="aim">Change</a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Basic Information Section -->
                <div id="basic-section" class="tab-section @(currentTab == "basic" ? "" : "d-none")">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h3 class="card-title">Basic Information</h3>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-borderless mb-0 project-overview-summary">
                                <tbody>
                                    <tr>
                                        <td class="summary-label"><strong>Business Area</strong></td>
                                        <td class="summary-value">
                                            @if (Model.BusinessAreaLookup != null)
                                            {
                                                @Model.BusinessAreaLookup.Name
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="businessArea">Change</a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="summary-label"><strong>Phase</strong></td>
                                        <td class="summary-value">
                                            @if (Model.PhaseLookup != null)
                                            {
                                                @Model.PhaseLookup.Name
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="phase">Change</a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="summary-label"><strong>Activity Type</strong></td>
                                        <td class="summary-value">
                                            @if (Model.ActivityTypeLookup != null)
                                            {
                                                @Model.ActivityTypeLookup.Name
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="activityType">Change</a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="summary-label"><strong>Directorate(s)</strong></td>
                                        <td class="summary-value">
                                            @if (Model.Directorates != null && Model.Directorates.Any())
                                            {
                                                @foreach (var directorate in Model.Directorates.OrderBy(d => d.DirectorateLookup != null ? d.DirectorateLookup.Name : ""))
                                                {
                                                    @if (directorate.DirectorateLookup != null)
                                                    {
                                                        <div>@directorate.DirectorateLookup.Name</div>
                                                    }
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="directorates">Change</a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="summary-label"><strong>Flagship Project</strong></td>
                                        <td class="summary-value">
                                            @if (Model.IsFlagship)
                                            {
                                                <span class="badge badge-info">Yes</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">No</span>
                                            }
                                        </td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="flagship">Change</a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Contacts & Governance Section -->
                <div id="contacts-section" class="tab-section @(currentTab == "contacts" ? "" : "d-none")">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h3 class="card-title">Contacts & Governance</h3>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-borderless mb-0 project-overview-summary">
                                <tbody>
                                    <tr>
                                        <td class="summary-label"><strong>Primary Contact</strong></td>
                                        <td class="summary-value">
                                            @if (Model.PrimaryContactUser != null)
                                            {
                                                @if (!string.IsNullOrEmpty(Model.PrimaryContactUser.Email))
                                                {
                                                    <a href="mailto:@Model.PrimaryContactUser.Email">@Model.PrimaryContactUser.Name</a>
                                                }
                                                else
                                                {
                                                    @Model.PrimaryContactUser.Name
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="primaryContact">Change</a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="summary-label"><strong>SROs</strong></td>
                                        <td class="summary-value">
                                            @if (Model.SeniorResponsibleOfficers != null && Model.SeniorResponsibleOfficers.Any())
                                            {
                                                @foreach (var sro in Model.SeniorResponsibleOfficers)
                                                {
                                                    @if (sro.User != null)
                                                    {
                                                        <div>
                                                            @if (!string.IsNullOrEmpty(sro.User.Email))
                                                            {
                                                                <a href="mailto:@sro.User.Email">@sro.User.Name</a>
                                                            }
                                                            else
                                                            {
                                                                @sro.User.Name
                                                            }
                                                        </div>
                                                    }
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="sros">Change</a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="summary-label"><strong>Service Owner(s)</strong></td>
                                        <td class="summary-value">
                                            @if (Model.ServiceOwners != null && Model.ServiceOwners.Any())
                                            {
                                                @foreach (var serviceOwner in Model.ServiceOwners)
                                                {
                                                    @if (serviceOwner.User != null)
                                                    {
                                                        <div>
                                                            @if (!string.IsNullOrEmpty(serviceOwner.User.Email))
                                                            {
                                                                <a href="mailto:@serviceOwner.User.Email">@serviceOwner.User.Name</a>
                                                            }
                                                            else
                                                            {
                                                                @serviceOwner.User.Name
                                                            }
                                                        </div>
                                                    }
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="serviceOwners">Change</a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="summary-label"><strong>PMO Contact(s)</strong></td>
                                        <td class="summary-value">
                                            @if (Model.PmoContacts != null && Model.PmoContacts.Any())
                                            {
                                                @foreach (var pmo in Model.PmoContacts)
                                                {
                                                    @if (pmo.User != null)
                                                    {
                                                        <div>
                                                            @if (!string.IsNullOrEmpty(pmo.User.Email))
                                                            {
                                                                <a href="mailto:@pmo.User.Email">@pmo.User.Name</a>
                                                            }
                                                            else
                                                            {
                                                                @pmo.User.Name
                                                            }
                                                        </div>
                                                    }
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="pmoContacts">Change</a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Strategic Alignment Section -->
                <div id="strategic-section" class="tab-section @(currentTab == "strategic" ? "" : "d-none")">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h3 class="card-title">Strategic Alignment</h3>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-borderless mb-0 project-overview-summary">
                                <tbody>
                                    <tr>
                                        <td class="summary-label"><strong>Mission Pillars</strong></td>
                                        <td class="summary-value">
                                            @if (!string.IsNullOrEmpty(Model.MissionPillars))
                                            {
                                                @Model.MissionPillars
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="missionPillars">Change</a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="summary-label"><strong>Priority Outcomes</strong></td>
                                        <td class="summary-value">
                                            @if (Model.ProjectObjectives != null && Model.ProjectObjectives.Any())
                                            {
                                                @foreach (var objective in Model.ProjectObjectives)
                                                {
                                                    @if (objective.Objective != null)
                                                    {
                                                        <div>@objective.Objective.Title</div>
                                                    }
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="priorityOutcomes">Change</a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Dates & Timeline Section -->
                <div id="dates-section" class="tab-section @(currentTab == "dates" ? "" : "d-none")">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h3 class="card-title">Dates & Timeline</h3>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-borderless mb-0 project-overview-summary">
                                <tbody>
                                    <tr>
                                        <td class="summary-label"><strong>Start Date</strong></td>
                                        <td class="summary-value">
                                            @if (Model.StartDate.HasValue && Model.StartDate.Value.Year > 1)
                                            {
                                                @Model.StartDate.Value.ToString("d MMMM yyyy")
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="startDate">Change</a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="summary-label"><strong>Target End Date</strong></td>
                                        <td class="summary-value">
                                            @if (Model.TargetDeliveryDate.HasValue && Model.TargetDeliveryDate.Value.Year > 1)
                                            {
                                                @Model.TargetDeliveryDate.Value.ToString("d MMMM yyyy")
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="targetDate">Change</a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Status & Priority Section -->
                <div id="status-section" class="tab-section @(currentTab == "status" ? "" : "d-none")">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h3 class="card-title">Status & Priority</h3>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-borderless mb-0 project-overview-summary">
                                <tbody>
                                    <tr>
                                        <td class="summary-label"><strong>Status</strong></td>
                                        <td class="summary-value">
                                            <span class="badge badge-@(Model.Status == "Active" ? "success" : Model.Status == "Paused" ? "warning" : Model.Status == "Completed" ? "info" : "secondary")">@Model.Status</span>
                                        </td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="status">Change</a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="summary-label"><strong>Priority</strong></td>
                                        <td class="summary-value">
                                            @if (Model.DeliveryPriority != null)
                                            {
                                                var priorityClass = Model.DeliveryPriority.Name.ToLower() switch {
                                                    var p when p.Contains("critical") => "badge-danger",
                                                    var p when p.Contains("high") => "badge-danger",
                                                    var p when p.Contains("medium") => "badge-warning",
                                                    var p when p.Contains("low") => "badge-secondary",
                                                    _ => "badge-secondary"
                                                };
                                                <span class="badge @priorityClass">@Model.DeliveryPriority.Name</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="priority">Change</a>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td class="summary-label"><strong>RAG Status</strong></td>
                                        <td class="summary-value">
                                            @if (!string.IsNullOrEmpty(Model.RagStatus))
                                            {
                                                // Normalize the status
                                                var normalized = Model.RagStatus.Trim()
                                                    .Replace(" / ", "-")
                                                    .Replace("/", "-")
                                                    .Replace(" /", "-")
                                                    .Replace("/ ", "-");
                                                
                                                var ragClass = normalized switch {
                                                    "Red" => "badge badge-red",
                                                    "Amber-Red" => "badge badge-amber-red",
                                                    "Amber" => "badge badge-amber",
                                                    "Amber-Green" => "badge badge-amber-green",
                                                    "Green" => "badge badge-green",
                                                    _ => "badge badge-secondary"
                                                };
                                                <span class="@ragClass">@Model.RagStatus</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Not set</span>
                                            }
                                        </td>
                                        <td class="summary-action text-right">
                                            <a href="#" class="change-link" data-field="ragStatus">Change</a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Edit Title Modal -->
<div class="modal fade" id="editTitleModal" tabindex="-1" role="dialog" aria-labelledby="editTitleModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editTitleModalLabel">Change Title</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateField" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="field" value="title" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="titleInput">Title</label>
                        <input type="text" class="form-control" id="titleInput" name="value" value="@Model.Title" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Aim Modal -->
<div class="modal fade" id="editAimModal" tabindex="-1" role="dialog" aria-labelledby="editAimModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editAimModalLabel">Change Aim</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateField" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="field" value="aim" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="aimInput">Aim</label>
                        <textarea class="form-control" id="aimInput" name="value" rows="5">@Model.Aim</textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Business Area Modal -->
<div class="modal fade" id="editBusinessAreaModal" tabindex="-1" role="dialog" aria-labelledby="editBusinessAreaModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editBusinessAreaModalLabel">Change Business Area</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateField" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="field" value="businessArea" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="businessAreaInput">Business Area</label>
                        <select class="form-control" id="businessAreaInput" name="value">
                            <option value="">None</option>
                            @foreach (var ba in businessAreas)
                            {
                                <option value="@ba.Id" selected="@(Model.BusinessAreaId == ba.Id)">@ba.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Phase Modal -->
<div class="modal fade" id="editPhaseModal" tabindex="-1" role="dialog" aria-labelledby="editPhaseModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editPhaseModalLabel">Change Phase</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateField" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="field" value="phase" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="phaseInput">Phase</label>
                        <select class="form-control" id="phaseInput" name="value">
                            <option value="">None</option>
                            @foreach (var phase in phases)
                            {
                                <option value="@phase.Id" selected="@(Model.PhaseId == phase.Id)">@phase.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

