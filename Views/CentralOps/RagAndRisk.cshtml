@{
    ViewData["Title"] = "Central Operations - RAG and Risk";
    var ragCounts = ViewBag.RagCounts as Dictionary<string, int> ?? new Dictionary<string, int>();
    var ragGroups = ViewBag.RagGroups as Dictionary<string, List<Compass.Models.Project>> ?? new Dictionary<string, List<Compass.Models.Project>>();
    var totalProjects = ViewBag.TotalProjects as int? ?? 0;
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="CentralOps" asp-action="Summary" style="color: #005ea5; text-decoration: none;">Central Operations</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">RAG and Risk</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        @await Html.PartialAsync("_CentralOpsNavigation")

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <!-- RAG Ratings -->
        <div class="dashboard-section">
            <div class="dashboard-section-header">
                <h2><i class="fas fa-chart-pie"></i> RAG Ratings</h2>
                <div>
                    <button type="button" class="btn btn-sm btn-outline-primary" id="expandAllRagPanels">
                        <i class="fas fa-chevron-down"></i> Expand All
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-secondary ml-2" id="collapseAllRagPanels">
                        <i class="fas fa-chevron-up"></i> Collapse All
                    </button>
                </div>
            </div>
            <style>
                #ragStatusAccordion .card-header {
                    background-color: #f8f9fa;
                    border-bottom: 1px solid #dee2e6;
                    transition: background-color 0.2s ease;
                }
                #ragStatusAccordion .card-header:hover {
                    background-color: #e9ecef;
                }
                #ragStatusAccordion .card-header i {
                    transition: transform 0.3s ease;
                }
                #ragStatusAccordion .card-header[aria-expanded="true"] i {
                    transform: rotate(180deg);
                }
                #ragStatusAccordion .card-header[aria-expanded="false"] i {
                    transform: rotate(0deg);
                }
            </style>
            <div class="accordion" id="ragStatusAccordion">
                @foreach (var ragStatus in new[] { "Red", "Amber-Red", "Amber", "Amber-Green", "Green", "Not set" })
                {
                    var count = ragCounts.ContainsKey(ragStatus) ? ragCounts[ragStatus] : 0;
                    var percentage = totalProjects > 0 ? (count * 100.0 / totalProjects) : 0;
                    var ragClass = ragStatus switch
                    {
                        "Red" => "badge badge-red",
                        "Amber-Red" => "badge badge-amber-red",
                        "Amber" => "badge badge-amber",
                        "Amber-Green" => "badge badge-amber-green",
                        "Green" => "badge badge-green",
                        _ => "badge badge-secondary"
                    };
                    var projects = ragGroups.ContainsKey(ragStatus) ? ragGroups[ragStatus] : new List<Compass.Models.Project>();
                    var headingId = $"ragHeading{ragStatus.Replace(" ", "").Replace("-", "")}";
                    var collapseId = $"ragCollapse{ragStatus.Replace(" ", "").Replace("-", "")}";

                    <div class="card mb-2">
                        <div class="card-header" id="@headingId" style="cursor: pointer;" data-toggle="collapse" data-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-chevron-down mr-3"></i>
                                <div>
                                    <span class="@ragClass" style="font-size: 1rem;">@ragStatus</span>
                                    <span class="ml-3"><strong>@count</strong> projects</span>
                                    <span class="ml-2 text-muted">(@percentage.ToString("F1")%)</span>
                                </div>
                            </div>
                        </div>
                        <div id="@collapseId" class="collapse" aria-labelledby="@headingId" data-parent="#ragStatusAccordion">
                            <div class="card-body p-0">
                                @if (projects.Any())
                                {
                                    <div class="table-responsive">
                                        <table class="table table-hover mb-0 sortable-table">
                                            <thead>
                                                <tr>
                                                    <th style="width: 250px;" class="sortable" data-column="Title" tabindex="0" role="button" aria-label="Sort by Title">Title</th>
                                                    <th style="width: 100px;" class="sortable" data-column="Priority" tabindex="0" role="button" aria-label="Sort by Priority">Priority</th>
                                                    <th style="width: 120px;" class="sortable" data-column="Rag" tabindex="0" role="button" aria-label="Sort by RAG">RAG</th>
                                                    <th style="width: 150px;" class="sortable" data-column="BusinessArea" tabindex="0" role="button" aria-label="Sort by Business Area">Business Area</th>
                                                    <th style="width: 150px;" class="sortable" data-column="PrimaryContact" tabindex="0" role="button" aria-label="Sort by Primary Contact">Primary Contact</th>
                                                    <th style="width: 200px;" class="sortable" data-column="ServiceOwner" tabindex="0" role="button" aria-label="Sort by Service Owner">Service Owner</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var project in projects)
                                                {
                                                    <tr>
                                                        <td>
                                                            <a asp-controller="Project" asp-action="Details" asp-route-id="@project.Id" style="font-weight: bold; color: #005ea5; text-decoration: none;">@project.Title</a>
                                                            <br />
                                                            <small class="text-muted">DFE-DDT-@project.Id</small>
                                                        </td>
                                                        <td>
                                                            @if (project.DeliveryPriority != null && !string.IsNullOrEmpty(project.DeliveryPriority.Name))
                                                            {
                                                                var priorityClass = project.DeliveryPriority.Name.ToLower() switch {
                                                                    var p when p.Contains("critical") => "badge-danger",
                                                                    var p when p.Contains("high") => "badge-danger",
                                                                    var p when p.Contains("medium") => "badge-warning",
                                                                    var p when p.Contains("low") => "badge-secondary",
                                                                    _ => "badge-secondary"
                                                                };
                                                                <span class="badge @priorityClass">@project.DeliveryPriority.Name</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">-</span>
                                                            }
                                                        </td>
                                                        <td>
                                                            @if (!string.IsNullOrEmpty(project.RagStatus))
                                                            {
                                                                var normalized = project.RagStatus.Trim()
                                                                    .Replace(" / ", "-")
                                                                    .Replace("/", "-")
                                                                    .Replace(" /", "-")
                                                                    .Replace("/ ", "-");
                                                                
                                                                // Capitalize first letter of each word for consistency
                                                                var parts = normalized.Split('-');
                                                                for (int i = 0; i < parts.Length; i++)
                                                                {
                                                                    if (parts[i].Length > 0)
                                                                    {
                                                                        parts[i] = char.ToUpperInvariant(parts[i][0]) + (parts[i].Length > 1 ? parts[i].Substring(1).ToLowerInvariant() : "");
                                                                    }
                                                                }
                                                                var displayRagStatus = string.Join("-", parts);
                                                                
                                                                var projectRagClass = displayRagStatus switch {
                                                                    "Red" => "badge badge-red",
                                                                    "Amber-Red" => "badge badge-amber-red",
                                                                    "Amber" => "badge badge-amber",
                                                                    "Amber-Green" => "badge badge-amber-green",
                                                                    "Green" => "badge badge-green",
                                                                    _ => "badge badge-secondary"
                                                                };
                                                                <span class="@projectRagClass">@displayRagStatus</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">-</span>
                                                            }
                                                        </td>
                                                        <td>@(project.BusinessAreaLookup?.Name ?? "-")</td>
                                                        <td>
                                                            @if (project.PrimaryContactUser != null)
                                                            {
                                                                @project.PrimaryContactUser.Name
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">-</span>
                                                            }
                                                        </td>
                                                        <td>
                                                            @if (project.ServiceOwners != null && project.ServiceOwners.Any())
                                                            {
                                                                var serviceOwners = project.ServiceOwners.Where(so => so.User != null).Take(2).ToList();
                                                                @foreach (var so in serviceOwners)
                                                                {
                                                                    <div>@so.User.Name</div>
                                                                }
                                                                @if (project.ServiceOwners.Count > 2)
                                                                {
                                                                    <small class="text-muted">+ @(project.ServiceOwners.Count - 2) more</small>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">-</span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="p-3 text-center text-muted">
                                        No projects found with this RAG status
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Exception Reporting -->
        @{
            var exceptions = ViewBag.Exceptions as List<Compass.Controllers.RagExceptionReport> ?? new List<Compass.Controllers.RagExceptionReport>();
            var greenWithProblems = exceptions.Count(e => e.ExceptionType.Contains("Green RAG with Problem"));
            var amberGreenWithProblems = exceptions.Count(e => e.ExceptionType.Contains("Amber-Green RAG with Problem"));
            var redWithHealthy = exceptions.Count(e => e.ExceptionType.Contains("Red RAG with Healthy"));
        }
        <div class="dashboard-section mt-4">
            <div class="dashboard-section-header">
                <h2><i class="fas fa-exclamation-triangle"></i> Exception Reporting</h2>
                <p class="dashboard-section-description">Projects where RAG status contradicts milestone indicators - helps identify under or over-reporting</p>
            </div>
            @if (exceptions.Any())
            {
                <div class="row mb-3">
                    <div class="col-md-4">
                        <div class="card border-left-info">
                            <div class="card-body">
                                <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Under-reporting</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@(greenWithProblems + amberGreenWithProblems)</div>
                                <small class="text-muted">Green/Amber-Green with problems</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-left-danger">
                            <div class="card-body">
                                <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Over-reporting</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@redWithHealthy</div>
                                <small class="text-muted">Red RAG with healthy milestones</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-left-warning">
                            <div class="card-body">
                                <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Total Exceptions</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@exceptions.Count</div>
                                <small class="text-muted">Projects requiring review</small>
                            </div>
                        </div>
                    </div>
                </div>
                <style>
                    .border-left-info { border-left: 0.25rem solid #17a2b8 !important; }
                    .border-left-danger { border-left: 0.25rem solid #e74a3b !important; }
                    .border-left-warning { border-left: 0.25rem solid #f6c23e !important; }
                    .text-xs { font-size: .7rem; }
                </style>
            }
            <div class="card">
                <div class="card-body">
                    @if (exceptions.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 sortable-table">
                                <thead>
                                    <tr>
                                        <th class="sortable" data-column="ProjectCode" tabindex="0" role="button">Project ID</th>
                                        <th class="sortable" data-column="ProjectTitle" tabindex="0" role="button">Project Title</th>
                                        <th class="sortable" data-column="BusinessArea" tabindex="0" role="button">Business Area</th>
                                        <th class="sortable" data-column="PrimaryContact" tabindex="0" role="button">Primary Contact</th>
                                        <th class="sortable" data-column="RagStatus" tabindex="0" role="button">RAG Status</th>
                                        <th class="sortable" data-column="ExceptionType" tabindex="0" role="button">Exception Type</th>
                                        <th class="sortable" data-column="ExceptionDescription" tabindex="0" role="button">Description</th>
                                        <th class="sortable text-center" data-column="Overdue" tabindex="0" role="button">Overdue</th>
                                        <th class="sortable text-center" data-column="Delayed" tabindex="0" role="button">Delayed</th>
                                        <th class="sortable text-center" data-column="AtRisk" tabindex="0" role="button">At Risk</th>
                                        <th class="sortable text-center" data-column="OnTrack" tabindex="0" role="button">On Track</th>
                                        <th class="sortable text-center" data-column="Total" tabindex="0" role="button">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var exception in exceptions)
                                    {
                                        var ragClass = exception.RagStatus switch
                                        {
                                            "Red" => "badge badge-red",
                                            "Amber-Red" => "badge badge-amber-red",
                                            "Amber" => "badge badge-amber",
                                            "Amber-Green" => "badge badge-amber-green",
                                            "Green" => "badge badge-green",
                                            _ => "badge badge-secondary"
                                        };
                                        var rowClass = exception.ExceptionType.Contains("Red") ? "table-danger" : 
                                                      exception.ExceptionType.Contains("Amber-Green") ? "table-warning" : 
                                                      "table-info";

                                        <tr class="@rowClass">
                                            <td>
                                                <a asp-controller="Project" asp-action="Details" asp-route-id="@exception.ProjectId" target="_blank">
                                                    @exception.ProjectCode
                                                </a>
                                            </td>
                                            <td>@exception.ProjectTitle</td>
                                            <td>@(exception.BusinessArea ?? "Not assigned")</td>
                                            <td>@(exception.PrimaryContact ?? "Not assigned")</td>
                                            <td><span class="@ragClass">@exception.RagStatus</span></td>
                                            <td>
                                                <span class="badge badge-warning">@exception.ExceptionType</span>
                                            </td>
                                            <td>@exception.ExceptionDescription</td>
                                            <td style="text-align: center;">
                                                @if (exception.OverdueMilestonesCount > 0)
                                                {
                                                    <span class="badge badge-danger">@exception.OverdueMilestonesCount</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">0</span>
                                                }
                                            </td>
                                            <td style="text-align: center;">
                                                @if (exception.DelayedMilestonesCount > 0)
                                                {
                                                    <span class="badge badge-warning">@exception.DelayedMilestonesCount</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">0</span>
                                                }
                                            </td>
                                            <td style="text-align: center;">
                                                @if (exception.AtRiskMilestonesCount > 0)
                                                {
                                                    <span class="badge badge-warning">@exception.AtRiskMilestonesCount</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">0</span>
                                                }
                                            </td>
                                            <td style="text-align: center;">
                                                @if (exception.OnTrackMilestonesCount > 0)
                                                {
                                                    <span class="badge badge-success">@exception.OnTrackMilestonesCount</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">0</span>
                                                }
                                            </td>
                                            <td style="text-align: center;">
                                                <strong>@exception.TotalMilestonesCount</strong>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            <i class="fas fa-info-circle"></i> No exceptions found. All projects' RAG statuses align with their milestone indicators.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Initialize sortable tables
            $('.sortable-table').each(function() {
                initializeSortableTable($(this));
            });

            // Handle accordion collapse/expand events to update chevron icons
            $('#ragStatusAccordion').on('show.bs.collapse', function(e) {
                var header = $(e.target).prev('.card-header');
                header.attr('aria-expanded', 'true');
                // Keep fa-chevron-down and let CSS rotate it
            });

            $('#ragStatusAccordion').on('hide.bs.collapse', function(e) {
                var header = $(e.target).prev('.card-header');
                header.attr('aria-expanded', 'false');
                // Keep fa-chevron-down, CSS will reset rotation
            });

            // Expand all panels
            $('#expandAllRagPanels').on('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                // Remove data-parent temporarily to allow all panels to be open
                $('#ragStatusAccordion .collapse').each(function() {
                    var $collapse = $(this);
                    var $header = $collapse.prev('.card-header');
                    if (!$collapse.hasClass('show')) {
                        $collapse.removeAttr('data-parent');
                        $collapse.addClass('show');
                        $header.attr('aria-expanded', 'true');
                        // Icon will rotate via CSS
                        // Trigger Bootstrap event
                        $collapse.trigger('shown.bs.collapse');
                    }
                });
            });

            // Collapse all panels
            $('#collapseAllRagPanels').on('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                $('#ragStatusAccordion .collapse').each(function() {
                    var $collapse = $(this);
                    var $header = $collapse.prev('.card-header');
                    if ($collapse.hasClass('show')) {
                        $collapse.removeClass('show');
                        $header.attr('aria-expanded', 'false');
                        // Icon will reset via CSS
                        // Restore data-parent and trigger Bootstrap event
                        $collapse.attr('data-parent', '#ragStatusAccordion');
                        $collapse.trigger('hidden.bs.collapse');
                    }
                });
            });
        });

        function initializeSortableTable(table) {
            var currentSort = { column: null, direction: 'asc' };

            table.find('.sortable').on('click keypress', function(e) {
                if (e.type === 'keypress' && e.which !== 13 && e.which !== 32) {
                    return;
                }
                
                var column = $(this).data('column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(table, column, direction);
                currentSort = { column: column, direction: direction };
            });

            function sortTable(table, column, direction) {
                var tbody = table.find('tbody');
                var rows = tbody.find('tr').toArray();
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var colIndex = table.find('thead th[data-column="' + column + '"]').index();
                    
                    if (column === 'Overdue' || column === 'Delayed' || column === 'AtRisk' || column === 'OnTrack' || column === 'Total') {
                        // Numeric sorting
                        aVal = parseInt($(a).find('td').eq(colIndex).text().trim()) || 0;
                        bVal = parseInt($(b).find('td').eq(colIndex).text().trim()) || 0;
                    } else {
                        // Text sorting
                        aVal = $(a).find('td').eq(colIndex).text().trim().toLowerCase();
                        bVal = $(b).find('td').eq(colIndex).text().trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.empty();
                rows.forEach(function(row) {
                    tbody.append(row);
                });
                
                updateSortIcons(table, column, direction);
            }

            function updateSortIcons(table, column, direction) {
                table.find('.sortable i').remove();
                var header = table.find('.sortable[data-column="' + column + '"]');
                var iconClass = direction === 'asc' ? 'fa-sort-up' : 'fa-sort-down';
                header.append(' <i class="fas ' + iconClass + '"></i>');
            }
        }
    </script>
}

