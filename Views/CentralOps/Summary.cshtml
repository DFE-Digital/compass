@using Compass.Controllers
@{
    ViewData["Title"] = "Central Operations - Summary";
    var activeWorkItems = ViewBag.ActiveWorkItems as int? ?? 0;
    var totalWorkItems = ViewBag.TotalWorkItems as int? ?? 0;
    var redAndAmberRedItems = ViewBag.RedAndAmberRedItems as int? ?? 0;
    var redCount = ViewBag.RedCount as int? ?? 0;
    var amberRedCount = ViewBag.AmberRedCount as int? ?? 0;
    var criticalPriorityCount = ViewBag.CriticalPriorityCount as int? ?? 0;
    var highPriorityCount = ViewBag.HighPriorityCount as int? ?? 0;
    var openMilestones = ViewBag.OpenMilestones as int? ?? 0;
    var businessAreaRiskData = ViewBag.BusinessAreaRiskData as List<BusinessAreaRiskSummary> ?? new List<BusinessAreaRiskSummary>();
    var currentReportingPeriodStats = ViewBag.CurrentReportingPeriodStats as MonthlyUpdateStats;
    var monthName = ViewBag.MonthName as string ?? "";
    var submittedCount = currentReportingPeriodStats?.Submitted ?? 0;
    var totalReportingCount = currentReportingPeriodStats?.TotalProjects ?? 0;
    var submittedPercentage = totalReportingCount > 0 ? (submittedCount * 100.0 / totalReportingCount) : 0;
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="CentralOps" asp-action="Summary" style="color: #005ea5; text-decoration: none;">Central Operations</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Summary</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        @await Html.PartialAsync("_CentralOpsNavigation")

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <!-- Summary Cards - Grouped -->
        <div class="row mb-4">
            <!-- Active Work Items Group -->
            <div class="col-md-6 col-lg-3 mb-3">
                <div class="card border-left-primary shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Active Work Items</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@activeWorkItems</div>
                                <small class="text-muted">Total Work Items: @totalWorkItems</small>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-list fa-2x text-gray-300"></i>
                            </div>
                        </div>
                        <div class="mt-3 pt-3 border-top">
                            <div class="text-xs text-muted mb-1">
                                <a href="@Url.Action("MonthlyReporting", "CentralOps")">Monthly reporting progress</a> (@monthName)
                            </div>
                            <div class="h6 mb-0 font-weight-bold text-success">@submittedCount of @totalReportingCount</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RAG and Risk Group -->
            <div class="col-md-6 col-lg-3 mb-3">
                <div class="card border-left-danger shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">RAG and Risk</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@redAndAmberRedItems</div>
                                <small class="text-muted">Red/Amber-Red Items</small>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-exclamation-triangle fa-2x text-gray-300"></i>
                            </div>
                        </div>
                        <div class="mt-3 pt-3 border-top">
                            <div class="row">
                                <div class="col-6">
                                    <div class="text-xs text-muted mb-1">Red</div>
                                    <div class="h6 mb-0 font-weight-bold text-danger">@redCount</div>
                                </div>
                                <div class="col-6">
                                    <div class="text-xs text-muted mb-1">Amber-Red</div>
                                    <div class="h6 mb-0 font-weight-bold text-danger">@amberRedCount</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Priorities Group -->
            <div class="col-md-6 col-lg-3 mb-3">
                <div class="card border-left-danger shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Priorities</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@(criticalPriorityCount + highPriorityCount)</div>
                                <small class="text-muted">Critical/High Priority</small>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-exclamation-circle fa-2x text-gray-300"></i>
                            </div>
                        </div>
                        <div class="mt-3 pt-3 border-top">
                            <div class="row">
                                <div class="col-6">
                                    <div class="text-xs text-muted mb-1">Critical</div>
                                    <div class="h6 mb-0 font-weight-bold text-danger">@criticalPriorityCount</div>
                                </div>
                                <div class="col-6">
                                    <div class="text-xs text-muted mb-1">High</div>
                                    <div class="h6 mb-0 font-weight-bold text-danger">@highPriorityCount</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Milestones Group -->
            <div class="col-md-6 col-lg-3 mb-3">
                <div class="card border-left-warning shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Milestones</div>
                                <div class="h5 mb-0 font-weight-bold text-gray-800">@openMilestones</div>
                                <small class="text-muted">Open Milestones</small>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-flag fa-2x text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <style>
            .border-left-primary {
                border-left: 0.25rem solid #4e73df !important;
            }
            .border-left-danger {
                border-left: 0.25rem solid #e74a3b !important;
            }
            .border-left-warning {
                border-left: 0.25rem solid #f6c23e !important;
            }
            .text-gray-800 {
                color: #5a5c69 !important;
            }
            .text-gray-300 {
                color: #dddfeb !important;
            }
        </style>

        <!-- Business Areas Risk Summary -->
        <div class="dashboard-section">
            <div class="dashboard-section-header">
                <h2><i class="fas fa-chart-bar"></i> Business Areas Risk Summary</h2>
                <button type="button" class="btn btn-sm btn-outline-info" data-toggle="modal" data-target="#riskScoreInfoModal" style="margin-left: auto;">
                    <i class="fas fa-info-circle"></i> How is this calculated?
                </button>
            </div>
            <div class="card">
                <div class="card-body table-responsive p-0">
                    <table class="table table-hover mb-0 sortable-table">
                        <thead>
                            <tr>
                                <th style="width: 200px;" class="sortable" data-column="BusinessArea" tabindex="0" role="button" aria-label="Sort by Business Area">Business Area</th>
                                <th style="width: 100px; text-align: center;" class="sortable" data-column="TotalProjects" tabindex="0" role="button" aria-label="Sort by Total Projects">Total Projects</th>
                                <th style="width: 100px; text-align: center;" class="sortable" data-column="Red" tabindex="0" role="button" aria-label="Sort by Red">Red</th>
                                <th style="width: 100px; text-align: center;" class="sortable" data-column="AmberRed" tabindex="0" role="button" aria-label="Sort by Amber-Red">Amber-Red</th>
                                <th style="width: 100px; text-align: center;" class="sortable" data-column="Critical" tabindex="0" role="button" aria-label="Sort by Critical Priority">Critical</th>
                                <th style="width: 100px; text-align: center;" class="sortable" data-column="High" tabindex="0" role="button" aria-label="Sort by High Priority">High</th>
                                <th style="width: 150px; text-align: center;" class="sortable" data-column="DelayedMilestones" tabindex="0" role="button" aria-label="Sort by Delayed Milestones">Delayed Milestones</th>
                                <th style="width: 120px; text-align: center;" class="sortable" data-column="RiskScore" tabindex="0" role="button" aria-label="Sort by Risk Score">Risk Score</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (businessAreaRiskData != null && businessAreaRiskData.Any())
                            {
                                @foreach (var area in businessAreaRiskData)
                                {
                                    var riskScore = area.RedCount + area.AmberRedCount + area.CriticalPriorityCount + area.HighPriorityCount + area.DelayedMilestonesCount;
                                    var riskClass = riskScore switch {
                                        var r when r >= 10 => "table-danger",
                                        var r when r >= 5 => "table-warning",
                                        var r when r >= 3 => "table-info",
                                        _ => ""
                                    };
                                    <tr class="@riskClass">
                                        <td><strong>@area.BusinessAreaName</strong></td>
                                        <td style="text-align: center;">@area.TotalProjects</td>
                                        <td style="text-align: center;">
                                            @if (area.RedCount > 0)
                                            {
                                                <span class="badge badge-danger">@area.RedCount</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">0</span>
                                            }
                                        </td>
                                        <td style="text-align: center;">
                                            @if (area.AmberRedCount > 0)
                                            {
                                                <span class="badge badge-danger">@area.AmberRedCount</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">0</span>
                                            }
                                        </td>
                                        <td style="text-align: center;">
                                            @if (area.CriticalPriorityCount > 0)
                                            {
                                                <span class="badge badge-danger">@area.CriticalPriorityCount</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">0</span>
                                            }
                                        </td>
                                        <td style="text-align: center;">
                                            @if (area.HighPriorityCount > 0)
                                            {
                                                <span class="badge badge-danger">@area.HighPriorityCount</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">0</span>
                                            }
                                        </td>
                                        <td style="text-align: center;">
                                            @if (area.DelayedMilestonesCount > 0)
                                            {
                                                <span class="badge badge-warning">@area.DelayedMilestonesCount</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">0</span>
                                            }
                                        </td>
                                        <td style="text-align: center;">
                                            @if (riskScore > 0)
                                            {
                                                var badgeClass = riskScore >= 10 ? "badge-danger" : riskScore >= 5 ? "badge-warning" : "badge-info";
                                                <span class="badge @badgeClass">@riskScore</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">0</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-center text-muted py-3">No business area data available</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Risk Score Information Modal -->
<div class="modal fade" id="riskScoreInfoModal" tabindex="-1" role="dialog" aria-labelledby="riskScoreInfoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="riskScoreInfoModalLabel">
                    <i class="fas fa-info-circle"></i> Business Areas Risk Summary - How it's calculated
                </h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <h6 class="font-weight-bold mb-3">Risk Score Calculation</h6>
                <p>The Risk Score is calculated by adding together the following indicators for each business area:</p>
                <ul class="mb-4">
                    <li><strong>Red RAG count</strong> - Number of projects with Red RAG status</li>
                    <li><strong>Amber-Red RAG count</strong> - Number of projects with Amber-Red RAG status</li>
                    <li><strong>Critical Priority count</strong> - Number of projects with Critical priority</li>
                    <li><strong>High Priority count</strong> - Number of projects with High priority</li>
                    <li><strong>Delayed Milestones count</strong> - Number of delayed milestones across all projects</li>
                </ul>
                <p class="mb-3"><strong>Formula:</strong> Risk Score = Red Count + Amber-Red Count + Critical Priority Count + High Priority Count + Delayed Milestones Count</p>
                
                <h6 class="font-weight-bold mb-3">Table Sorting</h6>
                <p>Business areas are ordered by:</p>
                <ol class="mb-4">
                    <li>Highest Risk Score (descending)</li>
                    <li>Red RAG count (descending)</li>
                    <li>Amber-Red RAG count (descending)</li>
                    <li>Critical Priority count (descending)</li>
                    <li>High Priority count (descending)</li>
                    <li>Delayed Milestones count (descending)</li>
                </ol>
                
                <h6 class="font-weight-bold mb-3">Risk Score Indicators</h6>
                <p>The Risk Score is displayed with color-coded badges:</p>
                <ul>
                    <li><span class="badge badge-danger">Red badge</span> - Risk Score ≥ 10</li>
                    <li><span class="badge badge-warning">Amber badge</span> - Risk Score ≥ 5</li>
                    <li><span class="badge badge-info">Blue badge</span> - Risk Score ≥ 3</li>
                    <li><span class="badge badge-secondary">Gray badge</span> - Risk Score < 3</li>
                </ul>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Initialize sortable tables
            $('.sortable-table').each(function() {
                initializeSortableTable($(this));
            });
        });

        function initializeSortableTable(table) {
            var currentSort = { column: null, direction: 'asc' };

            table.find('.sortable').on('click keypress', function(e) {
                if (e.type === 'keypress' && e.which !== 13 && e.which !== 32) {
                    return;
                }
                
                var column = $(this).data('column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(table, column, direction);
                currentSort = { column: column, direction: direction };
            });

            function sortTable(table, column, direction) {
                var tbody = table.find('tbody');
                var rows = tbody.find('tr').toArray();
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var colIndex = table.find('thead th[data-column="' + column + '"]').index();
                    
                    if (column === 'RiskScore' || column === 'TotalProjects' || column === 'Red' || column === 'AmberRed' || column === 'Critical' || column === 'High' || column === 'DelayedMilestones') {
                        // Numeric sorting
                        aVal = parseInt($(a).find('td').eq(colIndex).text().trim()) || 0;
                        bVal = parseInt($(b).find('td').eq(colIndex).text().trim()) || 0;
                    } else {
                        // Text sorting
                        aVal = $(a).find('td').eq(colIndex).text().trim().toLowerCase();
                        bVal = $(b).find('td').eq(colIndex).text().trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.empty();
                rows.forEach(function(row) {
                    tbody.append(row);
                });
                
                updateSortIcons(table, column, direction);
            }

            function updateSortIcons(table, column, direction) {
                table.find('.sortable i').remove();
                var header = table.find('.sortable[data-column="' + column + '"]');
                var iconClass = direction === 'asc' ? 'fa-sort-up' : 'fa-sort-down';
                header.append(' <i class="fas ' + iconClass + '"></i>');
            }
        }
    </script>
}

