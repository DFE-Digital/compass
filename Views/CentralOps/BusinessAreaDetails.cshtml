@using Compass.Models
@{
    ViewData["Title"] = "Business Area Details";
    var businessArea = ViewBag.BusinessArea as string ?? "";
    var projects = ViewBag.Projects as List<Project> ?? new List<Project>();
    var ragCounts = ViewBag.RagCounts as Dictionary<string, int> ?? new Dictionary<string, int>();
    var priorityCounts = ViewBag.PriorityCounts as Dictionary<string, int> ?? new Dictionary<string, int>();
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="CentralOps" asp-action="Dashboard" style="color: #005ea5; text-decoration: none;">Central Operations</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">@businessArea</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">@businessArea</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <!-- RAG Status Cards -->
        <div class="row mb-4">
            <div class="col-12">
                <h3 class="mb-3">RAG Status Summary</h3>
            </div>
            <div class="col-lg-2 col-md-4 col-sm-6 col-6">
                <div class="small-box" style="background-color: #dc3545; color: #ffffff;">
                    <div class="inner">
                        <h3 style="color: #ffffff;">@ragCounts.GetValueOrDefault("Red", 0)</h3>
                        <p style="color: #ffffff;">Red</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-times-circle"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-sm-6 col-6">
                <div class="small-box" style="background-color: #ff6b35; color: #ffffff;">
                    <div class="inner">
                        <h3 style="color: #ffffff;">@ragCounts.GetValueOrDefault("Amber-Red", 0)</h3>
                        <p style="color: #ffffff;">Amber-Red</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-sm-6 col-6">
                <div class="small-box" style="background-color: #ffc107; color: #0b0c0c;">
                    <div class="inner">
                        <h3 style="color: #0b0c0c;">@ragCounts.GetValueOrDefault("Amber", 0)</h3>
                        <p style="color: #0b0c0c;">Amber</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-exclamation-circle"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-sm-6 col-6">
                <div class="small-box" style="background-color: #ffc107; color: #0b0c0c;">
                    <div class="inner">
                        <h3 style="color: #0b0c0c;">@ragCounts.GetValueOrDefault("Amber-Green", 0)</h3>
                        <p style="color: #0b0c0c;">Amber-Green</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-sm-6 col-6">
                <div class="small-box" style="background-color: #28a745; color: #ffffff;">
                    <div class="inner">
                        <h3 style="color: #ffffff;">@ragCounts.GetValueOrDefault("Green", 0)</h3>
                        <p style="color: #ffffff;">Green</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Priority Cards -->
        <div class="row mb-4">
            <div class="col-12">
                <h3 class="mb-3">Priority Summary</h3>
            </div>
            <div class="col-lg-2 col-md-4 col-sm-6 col-6">
                <div class="small-box bg-danger">
                    <div class="inner">
                        <h3>@priorityCounts.GetValueOrDefault("Critical", 0)</h3>
                        <p>Critical</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-sm-6 col-6">
                <div class="small-box bg-danger">
                    <div class="inner">
                        <h3>@priorityCounts.GetValueOrDefault("High", 0)</h3>
                        <p>High</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-arrow-up"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-sm-6 col-6">
                <div class="small-box bg-warning">
                    <div class="inner">
                        <h3>@priorityCounts.GetValueOrDefault("Medium", 0)</h3>
                        <p>Medium</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-minus"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-sm-6 col-6">
                <div class="small-box bg-secondary">
                    <div class="inner">
                        <h3>@priorityCounts.GetValueOrDefault("Low", 0)</h3>
                        <p>Low</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-arrow-down"></i>
                    </div>
                </div>
            </div>
            <div class="col-lg-2 col-md-4 col-sm-6 col-6">
                <div class="small-box" style="background-color: #000000; color: #ffffff;">
                    <div class="inner">
                        <h3 style="color: #ffffff;">@priorityCounts.GetValueOrDefault("Not set", 0)</h3>
                        <p style="color: #ffffff;">Not set</p>
                    </div>
                    <div class="icon">
                        <i class="fas fa-question-circle"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Products/Projects Table -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Products in @businessArea</h3>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover mb-0 sortable-table">
                            <thead>
                                <tr>
                                    <th class="sortable" data-column="Title" tabindex="0" role="button" aria-label="Sort by Title">Title <i class="fas fa-sort sort-icon"></i></th>
                                    <th class="sortable" data-column="Priority" tabindex="0" role="button" aria-label="Sort by Priority">Priority <i class="fas fa-sort sort-icon"></i></th>
                                    <th class="sortable" data-column="Rag" tabindex="0" role="button" aria-label="Sort by RAG">RAG <i class="fas fa-sort sort-icon"></i></th>
                                    <th class="sortable" data-column="Status" tabindex="0" role="button" aria-label="Sort by Status">Status <i class="fas fa-sort sort-icon"></i></th>
                                    <th class="sortable" data-column="PrimaryContact" tabindex="0" role="button" aria-label="Sort by Primary Contact">Primary Contact <i class="fas fa-sort sort-icon"></i></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (projects != null && projects.Any())
                                {
                                    @foreach (var item in projects)
                                    {
                                        <tr>
                                            <td>
                                                <a asp-controller="CentralOps" asp-action="WorkItemDetails" asp-route-id="@item.Id" class="project-title-link"><strong>@item.Title</strong></a>
                                                <div class="project-meta text-muted small mt-1">
                                                    <span class="d-block"><span class="text-monospace">DFE-DDT-@item.Id</span></span>
                                                </div>
                                            </td>
                                            <td>
                                                @if (item.DeliveryPriority != null)
                                                {
                                                    var priorityName = item.DeliveryPriority.Name.ToLower();
                                                    var priorityClass = priorityName.Contains("critical") || priorityName.Contains("high") ? "badge-danger" :
                                                                        priorityName.Contains("medium") ? "badge-warning" :
                                                                        priorityName.Contains("low") ? "badge-secondary" : "badge-secondary";
                                                    <span class="badge @priorityClass">@item.DeliveryPriority.Name</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.RagStatus))
                                                {
                                                    // Normalize the status - handle both "Amber-Green" and "Amber/Green" formats
                                                    var normalized = item.RagStatus.Trim()
                                                        .Replace(" / ", "-")
                                                        .Replace("/", "-")
                                                        .Replace(" /", "-")
                                                        .Replace("/ ", "-");
                                                    
                                                    // Capitalize first letter of each word for consistency
                                                    var parts = normalized.Split('-');
                                                    for (int i = 0; i < parts.Length; i++)
                                                    {
                                                        if (parts[i].Length > 0)
                                                        {
                                                            parts[i] = char.ToUpperInvariant(parts[i][0]) + (parts[i].Length > 1 ? parts[i].Substring(1).ToLowerInvariant() : "");
                                                        }
                                                    }
                                                    var displayRagStatus = string.Join("-", parts);
                                                    
                                                    var ragClass = displayRagStatus switch {
                                                        "Green" => "badge badge-green",
                                                        "Amber-Green" => "badge badge-amber-green",
                                                        "Amber" => "badge badge-amber",
                                                        "Amber-Red" => "badge badge-amber-red",
                                                        "Red" => "badge badge-red",
                                                        _ => "badge badge-secondary"
                                                    };
                                                    <span class="@ragClass">@displayRagStatus</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @switch (item.Status)
                                                {
                                                    case "Active":
                                                        <span class="badge badge-success">Active</span>
                                                        break;
                                                    case "Paused":
                                                        <span class="badge badge-warning">Paused</span>
                                                        break;
                                                    case "Completed":
                                                        <span class="badge badge-success">Completed</span>
                                                        break;
                                                    case "Cancelled":
                                                        <span class="badge badge-dark">Cancelled</span>
                                                        break;
                                                    default:
                                                        <span class="badge badge-secondary">@item.Status</span>
                                                        break;
                                                }
                                            </td>
                                            <td>@(item.PrimaryContactUser?.Name ?? item.PrimaryContactUser?.Email ?? "-")</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-3">No products found in this business area</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Initialize sortable tables
            $('.sortable-table').each(function() {
                initializeSortableTable($(this));
            });
        });

        function initializeSortableTable(table) {
            var currentSort = { column: null, direction: 'asc' };

            table.find('.sortable').on('click keypress', function(e) {
                if (e.type === 'keypress' && e.which !== 13 && e.which !== 32) {
                    return;
                }
                
                var column = $(this).data('column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(table, column, direction);
                currentSort = { column: column, direction: direction };
            });

            function sortTable(table, column, direction) {
                var tbody = table.find('tbody');
                var rows = tbody.find('tr').toArray();
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var colIndex = table.find('thead th[data-column="' + column + '"]').index();
                    
                    if (column === 'Title') {
                        // For Title column, get just the title text (first link text), ignore the code below
                        aVal = $(a).find('td').eq(colIndex).find('a').first().text().trim().toLowerCase();
                        bVal = $(b).find('td').eq(colIndex).find('a').first().text().trim().toLowerCase();
                    } else {
                        // For other columns, get the full cell text
                        aVal = $(a).find('td').eq(colIndex).text().trim().toLowerCase();
                        bVal = $(b).find('td').eq(colIndex).text().trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.empty();
                rows.forEach(function(row) {
                    tbody.append(row);
                });
                
                updateSortIcons(table, column, direction);
            }

            function updateSortIcons(table, column, direction) {
                table.find('.sortable i').remove();
                var header = table.find('.sortable[data-column="' + column + '"]');
                var iconClass = direction === 'asc' ? 'fa-sort-up' : 'fa-sort-down';
                header.append(' <i class="fas ' + iconClass + '"></i>');
            }
        }
    </script>
}

