        <!-- Active Projects for Selected Business Area -->
        @if (businessAreaId.HasValue && selectedBusinessArea != null)
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-white">
                    <h3 class="card-title mb-0">Active Projects - @selectedBusinessArea.Name</h3>
                    <div class="card-tools">
                        <button type="button" class="btn btn-tool" data-card-widget="collapse">
                            <i class="fas fa-minus" aria-hidden="true"></i>
                            <span class="sr-only">Toggle active projects</span>
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (businessAreaActiveProjects.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Project</th>
                                        <th>RAG Status</th>
                                        <th>Priority</th>
                                        <th>Status</th>
                                        <th>Primary Contact</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var project in businessAreaActiveProjects)
                                    {
                                        var ragStatusRaw = project.RagStatusLookup?.Name ?? project.RagStatus ?? "";
                                        var currentRag = ragStatusRaw;
                                        // Normalize RAG status
                                        if (!string.IsNullOrWhiteSpace(ragStatusRaw))
                                        {
                                            var ragLower = ragStatusRaw.ToLower();
                                            if (ragLower.Contains("red") && ragLower.Contains("amber")) currentRag = "Amber-Red";
                                            else if (ragLower.Contains("amber") && ragLower.Contains("green")) currentRag = "Amber-Green";
                                            else if (ragLower.Contains("red")) currentRag = "Red";
                                            else if (ragLower.Contains("amber")) currentRag = "Amber";
                                            else if (ragLower.Contains("green")) currentRag = "Green";
                                        }
                                        else
                                        {
                                            currentRag = "Not Set";
                                        }
                                        var ragBadgeClass = currentRag switch {
                                            "Red" => "badge-danger",
                                            "Amber-Red" => "badge",
                                            "Amber" => "badge-warning",
                                            "Amber-Green" => "badge",
                                            "Green" => "badge-success",
                                            "Not Set" => "badge-light",
                                            "Not started" => "badge-light",
                                            "On hold" => "badge-light",
                                            _ => "badge-light"
                                        };
                                        var ragBadgeStyle = currentRag switch {
                                            "Amber-Red" => "background-color: #fd7e14;",
                                            "Amber" => "color: #000;",
                                            "Amber-Green" => "background-color: #ffeb3b; color: #000;",
                                            "Not Set" => "background-color: #e9ecef; color: #000;",
                                            "Not started" => "background-color: #e9ecef; color: #000;",
                                            "On hold" => "background-color: #e9ecef; color: #000;",
                                            _ => ""
                                        };
                                        var priorityName = project.DeliveryPriority?.Name ?? "Not Set";
                                        var priorityBadgeClass = priorityName.ToLower() switch {
                                            var p when p.Contains("critical") => "badge-danger",
                                            var p when p.Contains("high") => "badge-warning",
                                            var p when p.Contains("medium") => "badge-info",
                                            var p when p.Contains("low") => "badge-success",
                                            _ => "badge-light"
                                        };
                                        var priorityBadgeStyle = priorityName.ToLower() switch {
                                            var p when p.Contains("medium") => "background-color: #ffc107; color: #000;",
                                            _ => ""
                                        };
                                        var latestProblemStatement = project.ProblemStatements?.OrderByDescending(ps => ps.CreatedAt).FirstOrDefault();
                                        var problemStatementText = latestProblemStatement?.ProblemStatement ?? "Not provided";
                                        var aimText = project.Aim ?? "Not provided";
                                        var aimEncoded = aimText.Replace("\"", "&quot;").Replace("'", "&#39;");
                                        var problemStatementEncoded = problemStatementText.Replace("\"", "&quot;").Replace("'", "&#39;");
                                        var latestMonthlyNarrative = LatestMonthlyNarrative(project);
                                        var latestMonthlyNarrativeEncoded = EncodeForDataAttr(latestMonthlyNarrative);
                                        <tr>
                                            <td>
                                                <a href="#" class="project-detail-link" 
                                                   data-project-id="@project.Id" 
                                                   data-project-title="@project.Title" 
                                                   data-project-code="DFE-DDT-@project.Id"
                                                   data-business-area="@(project.BusinessAreaLookup?.Name ?? "-")"
                                                   data-rag-status="@currentRag"
                                                   data-priority="@priorityName"
                                                   data-status="@project.Status"
                                                   data-primary-contact="@(project.PrimaryContactUser?.Name ?? "-")"
                                                   data-aim="@aimEncoded"
                                                   data-problem-statement="@problemStatementEncoded"
                                                   data-monthly-narrative="@latestMonthlyNarrativeEncoded"
                                                   style="color: #005ea5; text-decoration: none; font-weight: 600; cursor: pointer;">
                                                    @project.Title
                                                </a>
                                                <br />
                                                <small class="text-muted">DFE-DDT-@project.Id</small>
                                            </td>
                                            <td>
                                                <span class="badge @ragBadgeClass" style="@ragBadgeStyle">@currentRag</span>
                                            </td>
                                            <td>
                                                <span class="badge @priorityBadgeClass" style="@priorityBadgeStyle">@priorityName</span>
                                            </td>
                                            <td>@project.Status</td>
                                            <td>@(project.PrimaryContactUser?.Name ?? "-")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted">No active projects found for this business area</div>
                    }
                </div>
            </div>
        }

        <!-- Business Area Summary (shown when NOT in business area view) -->
        @if (!businessAreaId.HasValue)
        {
            <div class="card mb-4 shadow-sm collapsed-card">
                <div class="card-header bg-white">
                    <h3 class="card-title mb-0">Business Area Summary</h3>
                    <div class="card-tools">
                        <button type="button" class="btn btn-tool" data-card-widget="collapse">
                            <i class="fas fa-plus" aria-hidden="true"></i>
                            <span class="sr-only">Toggle business area summary</span>
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (businessAreaSummaries.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th rowspan="2">Business Area</th>
                                        <th rowspan="2" class="text-center">Total Projects</th>
                                        <th rowspan="2" class="text-center" style="border-right: 2px solid #dee2e6;">New This Month</th>
                                        <th colspan="3" class="text-center" style="border-bottom: 2px solid #dee2e6; border-left: 2px solid #dee2e6;">Milestones</th>
                                        <th colspan="5" class="text-center" style="border-bottom: 2px solid #dee2e6; border-left: 2px solid #dee2e6;">RAG Status</th>
                                        <th colspan="5" class="text-center" style="border-bottom: 2px solid #dee2e6; border-left: 2px solid #dee2e6;">Priority</th>
                                    </tr>
                                    <tr>
                                        <th class="text-center" style="border-left: 2px solid #dee2e6;">Completed</th>
                                        <th class="text-center">Upcoming</th>
                                        <th class="text-center">Late</th>
                                        <th class="text-center" style="border-left: 2px solid #dee2e6;">Red</th>
                                        <th class="text-center">Amber-Red</th>
                                        <th class="text-center">Amber-Green</th>
                                        <th class="text-center">Green</th>
                                        <th class="text-center">Not Set</th>
                                        <th class="text-center" style="border-left: 2px solid #dee2e6;">Critical</th>
                                        <th class="text-center">High</th>
                                        <th class="text-center">Medium</th>
                                        <th class="text-center">Low</th>
                                        <th class="text-center">Not Set</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var summary in businessAreaSummaries)
                                    {
                                        <tr>
                                            <td>
                                                @if (summary.BusinessAreaId.HasValue)
                                                {
                                                    <a asp-controller="CentralOps" asp-action="MonthlySummaryV2" asp-route-year="@year" asp-route-month="@month" asp-route-businessAreaId="@summary.BusinessAreaId" style="color: #005ea5; text-decoration: none; font-weight: 600;">
                                                        @summary.BusinessArea
                                                    </a>
                                                }
                                                else
                                                {
                                                    @summary.BusinessArea
                                                }
                                            </td>
                                            <td class="text-center">@summary.TotalProjects</td>
                                            <td class="text-center" style="border-right: 2px solid #dee2e6;">@summary.NewThisMonth</td>
                                            <!-- Milestones columns -->
                                            <td class="text-center" style="border-left: 2px solid #dee2e6;">
                                                <span class="badge badge-success">@summary.MilestonesAchieved</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge" style="background-color: #fd7e14;">@summary.UpcomingMilestones</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge badge-danger">@summary.LateMilestones</span>
                                            </td>
                                            <!-- RAG Status columns -->
                                            <td class="text-center" style="border-left: 2px solid #dee2e6;"><span class="badge badge-danger">@summary.RedCount</span></td>
                                            <td class="text-center"><span class="badge" style="background-color: #fd7e14;">@summary.AmberRedCount</span></td>
                                            <td class="text-center"><span class="badge" style="background-color: #ffeb3b; color: #000;">@summary.AmberGreenCount</span></td>
                                            <td class="text-center"><span class="badge badge-success">@summary.GreenCount</span></td>
                                            <td class="text-center"><span class="badge badge-light">@(summary.TotalProjects - summary.RedCount - summary.AmberRedCount - summary.AmberGreenCount - summary.GreenCount)</span></td>
                                            <!-- Priority columns -->
                                            <td class="text-center" style="border-left: 2px solid #dee2e6;"><span class="badge badge-danger">@summary.CriticalCount</span></td>
                                            <td class="text-center"><span class="badge badge-warning">@summary.HighCount</span></td>
                                            <td class="text-center"><span class="badge badge-info" style="color: #000;">@summary.MediumCount</span></td>
                                            <td class="text-center"><span class="badge badge-success">@summary.LowCount</span></td>
                                            <td class="text-center"><span class="badge badge-light">@(summary.TotalProjects - summary.CriticalCount - summary.HighCount - summary.MediumCount - summary.LowCount)</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted">No business area data available</div>
                    }
                </div>
            </div>
        }

        <!-- Path to Green -->
        <div class="card mb-4 shadow-sm">
                <div class="card-header bg-white">
                    <h3 class="card-title mb-0">Projects with Path to Green</h3>
                    <div class="card-tools">
                        <button type="button" class="btn btn-tool" data-card-widget="collapse">
                            <i class="fas fa-minus" aria-hidden="true"></i>
                            <span class="sr-only">Toggle projects with path to green</span>
                        </button>
                    </div>
                </div>
            <div class="card-body p-0">
                @if (projectsWithPathToGreen.Any())
                {
                    <div class="p-3 border-bottom">
                        <div class="form-group mb-0">
                            <label class="mb-1 font-weight-bold">Filter by current RAG</label>
                            <div class="d-flex flex-wrap" id="pathToGreenRagFilter">
                                @{
                                    var ragOptions = new[] { "Red", "Amber-Red", "Amber-Green", "Green", "Not Set" };
                                    var defaultSelectedRags = new[] { "Red", "Amber-Red" };
                                }
                                @foreach (var rag in ragOptions)
                                {
                                    var filterId = $"pathToGreenRag_{rag.Replace(" ", "").Replace("-", "")}";
                                    var isChecked = defaultSelectedRags.Contains(rag);
                                    <div class="form-check mr-3 mb-1">
                                        <input class="form-check-input path-to-green-rag-checkbox" type="checkbox" value="@rag" id="@filterId" @(isChecked ? "checked" : "")>
                                        <label class="form-check-label" for="@filterId">@rag</label>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" style="table-layout: fixed; width: 100%;">
                            <thead>
                                <tr>
                                    <th style="width: 30%;">Project</th>
                                    <th>Business Area</th>
                                    <th>Priority</th>
                                    <th>Current RAG</th>
                                    <th style="width: 50%;">Path to Green</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var project in projectsWithPathToGreen)
                                {
                                    var ragStatusRaw = project.RagStatusLookup?.Name ?? project.RagStatus ?? "";
                                    var currentRag = ragStatusRaw;
                                    // Normalize RAG status
                                    if (!string.IsNullOrWhiteSpace(ragStatusRaw))
                                    {
                                        var ragLower = ragStatusRaw.ToLower();
                                        if (ragLower.Contains("red") && ragLower.Contains("amber")) currentRag = "Amber-Red";
                                        else if (ragLower.Contains("amber") && ragLower.Contains("green")) currentRag = "Amber-Green";
                                        else if (ragLower.Contains("red")) currentRag = "Red";
                                        else if (ragLower.Contains("amber")) currentRag = "Amber";
                                        else if (ragLower.Contains("green")) currentRag = "Green";
                                    }
                                    else
                                    {
                                        currentRag = "Not Set";
                                    }
                                    var ragBadgeClass = currentRag switch {
                                        "Red" => "badge-danger",
                                        "Amber-Red" => "badge",
                                        "Amber" => "badge-warning",
                                        "Amber-Green" => "badge",
                                        "Green" => "badge-success",
                                        "Not Set" => "badge-light",
                                        "Not started" => "badge-light",
                                        "On hold" => "badge-light",
                                        _ => "badge-light"
                                    };
                                    var ragBadgeStyle = currentRag switch {
                                        "Amber-Red" => "background-color: #fd7e14;",
                                        "Amber" => "color: #000;",
                                        "Amber-Green" => "background-color: #ffeb3b; color: #000;",
                                        "Not Set" => "background-color: #e9ecef; color: #000;",
                                        "Not started" => "background-color: #e9ecef; color: #000;",
                                        "On hold" => "background-color: #e9ecef; color: #000;",
                                        _ => ""
                                    };
                                    var priorityName = project.DeliveryPriority?.Name ?? "Not Set";
                                    var priorityBadgeClass = priorityName.ToLower() switch {
                                        var p when p.Contains("critical") => "badge-danger",
                                        var p when p.Contains("high") => "badge-warning",
                                        var p when p.Contains("medium") => "badge-info",
                                        var p when p.Contains("low") => "badge-success",
                                        _ => "badge-light"
                                    };
                                    var priorityBadgeStyle = priorityName.ToLower() switch {
                                        var p when p.Contains("medium") => "background-color: #ffc107; color: #000;",
                                        _ => ""
                                    };
                                    var latestProblemStatement = project.ProblemStatements?.OrderByDescending(ps => ps.CreatedAt).FirstOrDefault();
                                    var problemStatementText = latestProblemStatement?.ProblemStatement ?? "Not provided";
                                    var aimText = project.Aim ?? "Not provided";
                                    var aimEncoded = aimText.Replace("\"", "&quot;").Replace("'", "&#39;");
                                    var problemStatementEncoded = problemStatementText.Replace("\"", "&quot;").Replace("'", "&#39;");
                                    var pathToGreenEncoded = (project.PathToGreen ?? "").Replace("\"", "&quot;").Replace("'", "&#39;");
                                    var latestMonthlyNarrativePtg = LatestMonthlyNarrative(project);
                                    var latestMonthlyNarrativePtgEncoded = EncodeForDataAttr(latestMonthlyNarrativePtg);
                                    <tr class="path-to-green-row" data-current-rag="@currentRag">
                                        <td>
                                                <a href="#" class="project-detail-link" 
                                               data-project-id="@project.Id" 
                                               data-project-title="@project.Title" 
                                               data-project-code="DFE-DDT-@project.Id"
                                               data-business-area="@(project.BusinessAreaLookup?.Name ?? "-")"
                                               data-priority="@priorityName"
                                               data-rag-status="@currentRag"
                                               data-path-to-green="@pathToGreenEncoded"
                                               data-aim="@aimEncoded"
                                               data-problem-statement="@problemStatementEncoded"
                                               data-monthly-narrative="@latestMonthlyNarrativePtgEncoded"
                                               style="color: #005ea5; text-decoration: none; font-weight: 600; cursor: pointer;">
                                                @project.Title
                                            </a>
                                            <br />
                                            <small class="text-muted">DFE-DDT-@project.Id</small>
                                        </td>
                                        <td>@(project.BusinessAreaLookup?.Name ?? "-")</td>
                                        <td>
                                            <span class="badge @priorityBadgeClass" style="@priorityBadgeStyle">@priorityName</span>
                                        </td>
                                        <td>
                                            <span class="badge @ragBadgeClass" style="@ragBadgeStyle">@currentRag</span>
                                        </td>
                                        <td>@project.PathToGreen</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-4 text-center text-muted">No projects with path to green defined</div>
                }
            </div>
        </div>
    </div>
</section>

