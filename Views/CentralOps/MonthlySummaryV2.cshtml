                                                    <td class="@changeColor">@changeText</td>
                                                }
                                            </tr>
                                        }
                                        @if (priorityTotal > 0)
                                        {
                                            <tr style="font-weight: bold; background-color: #f4f8fb;">
                                                <td>Total</td>
                                                <td>@priorityTotal</td>
                                                <td>100.0%</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Work by RAG Status and Priority -->
        @{
            var allProjects = ViewBag.AllProjects as List<Compass.Models.Project> ?? new List<Compass.Models.Project>();
            
            // Helper function to normalize RAG status
            Func<string?, string> normalizeRagStatus = (ragStatus) => {
                if (string.IsNullOrWhiteSpace(ragStatus)) return "Not Set";
                var normalized = ragStatus.Trim();
                if (normalized.Equals("Red", StringComparison.OrdinalIgnoreCase)) return "Red";
                if (normalized.Equals("Amber-Red", StringComparison.OrdinalIgnoreCase) || normalized.Equals("AmberRed", StringComparison.OrdinalIgnoreCase)) return "Amber-Red";
                if (normalized.Equals("Amber", StringComparison.OrdinalIgnoreCase)) return "Amber";
                if (normalized.Equals("Amber-Green", StringComparison.OrdinalIgnoreCase) || normalized.Equals("AmberGreen", StringComparison.OrdinalIgnoreCase)) return "Amber-Green";
                if (normalized.Equals("Green", StringComparison.OrdinalIgnoreCase)) return "Green";
                if (normalized.Equals("Not Started", StringComparison.OrdinalIgnoreCase)) return "Not Started";
                if (normalized.Equals("On Hold", StringComparison.OrdinalIgnoreCase) || normalized.Equals("OnHold", StringComparison.OrdinalIgnoreCase)) return "On Hold";
                return normalized;
            };
            
            // Helper function to get priority name
            Func<Compass.Models.Project, string> getPriorityName = (project) => {
                if (project.DeliveryPriority == null) return "Not Set";
                var priority = project.DeliveryPriority.Name.ToLower();
                if (priority.Contains("critical")) return "Critical";
                if (priority.Contains("high")) return "High";
                if (priority.Contains("medium")) return "Medium";
                if (priority.Contains("low")) return "Low";
                return "Not Set";
            };
            
            // Prepare projects grouped by RAG and Priority (RAG primary, Priority secondary)
            var ragPriorityOrder = new[] { "Red", "Amber-Red", "Amber", "Amber-Green", "Green", "Not Started", "On Hold", "Not Set" };
            var priorityOrder = new[] { "Critical", "High", "Medium", "Low", "Not Set" };
            
            var projectsByRagPriority = allProjects
                .Select(p => new {
                    Project = p,
                    RagStatus = normalizeRagStatus(p.RagStatusLookup?.Name ?? p.RagStatus),
                    Priority = getPriorityName(p)
                })
                .GroupBy(p => new { p.RagStatus, p.Priority })
                .Select(g => new {
                    RagStatus = g.Key.RagStatus,
                    Priority = g.Key.Priority,
                    Projects = g.Select(x => x.Project).OrderBy(p => p.Title).ToList(),
                    Count = g.Count()
                })
                .OrderBy(x => {
                    var ragIndex = Array.IndexOf(ragPriorityOrder, x.RagStatus);
                    return ragIndex == -1 ? int.MaxValue : ragIndex;
                })
                .ThenBy(x => {
                    var priorityIndex = Array.IndexOf(priorityOrder, x.Priority);
                    return priorityIndex == -1 ? int.MaxValue : priorityIndex;
                })
                .ToList();
        }
        <div class="row mb-4">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-white">
                        <h3 class="card-title mb-0">Work by RAG Status and Priority</h3>
                        <div class="card-tools">
                            <a href="#" id="toggleHeatmapView" class="text-primary mr-2" style="text-decoration: underline;">
                                <i class="fas fa-th mr-1"></i><span id="viewToggleText">View heatmap</span>
                            </a>
                            <button type="button" class="btn btn-tool" data-card-widget="collapse">
                                <i class="fas fa-minus" aria-hidden="true"></i>
                                <span class="sr-only">Toggle work by RAG status and priority</span>
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <!-- Table View -->
                        <div id="ragPriorityTableView" class="table-responsive">
                            <table class="table table-hover mb-0 sortable-table" id="ragPriorityTable">
                                <thead>
                                    <tr>
                                        <th class="sortable" data-column="rag" style="cursor: pointer;">
                                            RAG Status
                                            <i class="fas fa-sort ml-1 text-muted" style="font-size: 0.75rem;"></i>
                                        </th>
                                        <th class="sortable" data-column="priority" style="cursor: pointer;">
                                            Priority
                                            <i class="fas fa-sort ml-1 text-muted" style="font-size: 0.75rem;"></i>
                                        </th>
                                        <th class="sortable text-center" data-column="count" style="cursor: pointer;">
                                            Count
                                            <i class="fas fa-sort ml-1 text-muted" style="font-size: 0.75rem;"></i>
                                        </th>
                                        <th>Projects</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int rowIndex = 0;
                                    }
                                    @foreach (var group in projectsByRagPriority)
                                    {
                                        var expandId = $"expand_rag_priority_{rowIndex}";
                                        <tr data-rag="@group.RagStatus" data-priority="@group.Priority" data-count="@group.Count">
                                            <td>
                                                @{
                                                    var ragColor = group.RagStatus == "Red" ? "#dc3545" :
                                                                  group.RagStatus == "Amber-Red" ? "#fd7e14" :
                                                                  group.RagStatus == "Amber" ? "#ffc107" :
                                                                  group.RagStatus == "Amber-Green" ? "#ffeb3b" :
                                                                  group.RagStatus == "Green" ? "#28a745" : "#e9ecef";
                                                    var ragTextColor = group.RagStatus == "Amber" || group.RagStatus == "Amber-Green" || group.RagStatus == "Not Started" || group.RagStatus == "On Hold" || group.RagStatus == "Not Set" ? "#000" : "#fff";
                                                }
                                                <span class="badge" style="background-color: @ragColor; color: @ragTextColor;">@group.RagStatus</span>
                                            </td>
                                            <td>
                                                @{
                                                    var priorityColor = group.Priority == "Critical" ? "#dc3545" :
                                                                       group.Priority == "High" ? "#fd7e14" :
                                                                       group.Priority == "Medium" ? "#ffc107" :
                                                                       group.Priority == "Low" ? "#28a745" : "#e9ecef";
                                                    var priorityTextColor = group.Priority == "Medium" || group.Priority == "Not Set" ? "#000" : "#fff";
                                                }
                                                <span class="badge" style="background-color: @priorityColor; color: @priorityTextColor;">@group.Priority</span>
                                            </td>
                                            <td class="text-center"><strong>@group.Count</strong></td>
                                            <td>
                                                @if (group.Count > 0)
                                                {
                                                    <a href="#" class="expand-projects-link" data-expand-id="@expandId" style="color: #005ea5; text-decoration: none; font-weight: 600;">
                                                        <i class="fas fa-chevron-right mr-1"></i>View @group.Count project@(group.Count == 1 ? "" : "s")
                                                    </a>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                        @if (group.Count > 0)
                                        {
                                            <tr class="project-detail-row" id="@expandId" style="display: none;">
                                                <td colspan="4" style="background-color: #f8f9fa; padding: 1rem;">
                                                    <div class="mb-2">
                                                        <strong>Projects (@group.Count):</strong>
                                                    </div>
                                                    <div class="table-responsive">
                                                        <table class="table table-hover table-sm mb-0">
                                                            <thead>
                                                                <tr>
                                                                    <th style="min-width: 200px;">Title</th>
                                                                    <th style="min-width: 100px;">Project Code</th>
                                                                    <th style="min-width: 150px;">Business Area</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var project in group.Projects)
                                                                {
                                                                    <tr>
                                                                        <td>
                                                                            <a asp-controller="Project" asp-action="Details" asp-route-id="@project.Id" style="color: #005ea5; text-decoration: none; font-weight: 600;">
                                                                                @project.Title
                                                                            </a>
                                                                        </td>
                                                                        <td>
                                                                            <small class="text-muted">DFE-DDT-@project.Id</small>
                                                                        </td>
                                                                        <td>
                                                                            @(project.BusinessAreaLookup?.Name ?? "-")
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                        rowIndex++;
                                    }
                                    @if (!projectsByRagPriority.Any())
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center text-muted p-4">No projects found</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        
                        <!-- Heatmap View -->
                        <div id="ragPriorityHeatmapView" style="display: none; padding: 1.5rem;">
                            @functions {
                                // Band: 0 neutral, 1 low (green), 2 medium (yellow), 3 high (orange), 4 very high (red)
                                private int GetRiskBand(string rag, string priority)
                                {
                                    // Normalise
                                    rag = (rag ?? "").Trim();
                                    priority = (priority ?? "").Trim();

                                    // Neutral/unknown RAGs
                                    if (rag == "Not Started" || rag == "On Hold" || rag == "Not Set")
                                        return 0;

                                    if (rag == "Red") return 4;
                                    if (rag == "Amber-Red") return 3;

                                    if (rag == "Amber")
                                    {
                                        if (priority == "Critical" || priority == "High") return 3;
                                        return 2;
                                    }

                                    if (rag == "Amber-Green")
                                    {
                                        if (priority == "Critical") return 3;
                                        if (priority == "High") return 2;
                                        return 1;
                                    }

                                    if (rag == "Green")
                                    {
                                        if (priority == "Critical" || priority == "High") return 2;
                                        return 1;
                                    }

                                    // Fallback
                                    return 0;
                                }

                                private (string bg, string fg) GetHeatTone(int band, double ratio, int count)
                                {
                                    // Base neutrals
                                    if (band == 0) return ("#f3f3f3", "#0b0c0c");
                                    if (count == 0) return ("#ffffff", "#484949");

                                    // 3-step intensity
                                    bool low = ratio <= 0.25;
                                    bool mid = ratio <= 0.60;

                                    // Band palettes (bg only)
                                    if (band == 4) // red
                                    {
                                        var bg = low ? "#fcf5f5" : mid ? "#f4d7d7" : "#ca3535";
                                        var fg = (bg == "#ca3535") ? "#ffffff" : "#0b0c0c";
                                        return (bg, fg);
                                    }
                                    if (band == 3) // orange
                                    {
                                        var bg = low ? "#fef8f5" : mid ? "#fde4d7" : "#f47738";
                                        var fg = (bg == "#f47738") ? "#ffffff" : "#0b0c0c";
                                        return (bg, fg);
                                    }
                                    if (band == 2) // yellow
                                    {
                                        var bg = low ? "#fffdf2" : mid ? "#fff8cc" : "#ffdd00";
                                        // Always dark text on yellow family
                                        return (bg, "#0b0c0c");
                                    }
                                    // band == 1 green
                                    {
                                        var bg = low ? "#f3f8f6" : mid ? "#cfe4dc" : "#0f7a52";
                                        var fg = (bg == "#0f7a52") ? "#ffffff" : "#0b0c0c";
                                        return (bg, fg);
                                    }
                                }
                            }
                            @{
                                var ragOrder = new[] { "Red", "Amber-Red", "Amber", "Amber-Green", "Green", "Not Started", "On Hold", "Not Set" };
                                var priorityOrderHeatmap = new[] { "Critical", "High", "Medium", "Low", "Not Set" };
                                var maxCount = projectsByRagPriority.Any() ? projectsByRagPriority.Max(g => g.Count) : 0;
                            }
                            <div class="table-responsive">
                                <table class="table table-bordered mb-0" style="table-layout: fixed;" role="table" aria-label="RAG status and priority heatmap">
                                    <thead>
                                        <tr>
                                            <th scope="col" style="width: 120px; background-color: #f4f8fb; font-weight: 600; border: 2px solid #cecece;" rowspan="2">
                                                <span aria-hidden="true">RAG</span>
                                                <span class="sr-only">RAG Status</span>
                                            </th>
                                            <th scope="colgroup" colspan="@priorityOrderHeatmap.Length" style="background-color: #f4f8fb; font-weight: 600; text-align: center; border: 2px solid #cecece;">
                                                <span aria-hidden="true">Priority</span>
                                                <span class="sr-only">Priority Level</span>
                                            </th>
                                        </tr>
                                        <tr>
                                            @foreach (var priority in priorityOrderHeatmap)
                                            {
                                                <th scope="col" class="text-center" style="background-color: #f4f8fb; font-weight: 600; border: 2px solid #cecece;">
                                                    @{
                                                        var priorityColor = priority == "Critical" ? "#dc3545" :
                                                                           priority == "High" ? "#fd7e14" :
                                                                           priority == "Medium" ? "#ffc107" :
                                                                           priority == "Low" ? "#28a745" : "#e9ecef";
                                                        var priorityTextColor = priority == "Medium" || priority == "Not Set" ? "#000" : "#fff";
                                                    }
                                                    <span class="badge" style="background-color: @priorityColor; color: @priorityTextColor; min-width: 80px; display: inline-block;">@priority</span>
                                                </th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var rag in ragOrder)
                                        {
                                            <tr>
                                                <th scope="row" style="background-color: #f4f8fb; font-weight: 600; vertical-align: middle; border: 2px solid #cecece; padding: 0.75rem; overflow: hidden;">
                                                    @{
                                                        var ragColor = rag == "Red" ? "#dc3545" :
                                                                      rag == "Amber-Red" ? "#fd7e14" :
                                                                      rag == "Amber" ? "#ffc107" :
                                                                      rag == "Amber-Green" ? "#ffeb3b" :
                                                                      rag == "Green" ? "#28a745" : "#e9ecef";
                                                        var ragTextColor = rag == "Amber" || rag == "Amber-Green" || rag == "Not Started" || rag == "On Hold" || rag == "Not Set" ? "#000" : "#fff";
                                                    }
                                                    <span class="badge" style="background-color: @ragColor; color: @ragTextColor; display: inline-block; max-width: 100%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@rag</span>
                                                </th>
                                                @foreach (var priority in priorityOrderHeatmap)
                                                {
                                                    var group = projectsByRagPriority.FirstOrDefault(g => g.RagStatus == rag && g.Priority == priority);
                                                    var count = group?.Count ?? 0;
                                                    
                                                    // Calculate risk band and heat tone
                                                    var band = GetRiskBand(rag, priority);
                                                    var ratio = (maxCount > 0) ? (count * 1.0 / maxCount) : 0;
                                                    var tone = GetHeatTone(band, ratio, count);
                                                    var cellColor = tone.bg;
                                                    var textColor = tone.fg;
                                                    
                                                    <td class="text-center" 
                                                        style="background-color: @cellColor; color: @textColor; min-width: 100px; height: 80px; vertical-align: middle; border: 1px solid #cecece;" 
                                                        data-rag="@rag" 
                                                        data-priority="@priority" 
                                                        data-count="@count"
                                                        role="gridcell"
                                                        tabindex="0"
                                                        aria-label="@rag RAG status and @priority priority: @count project@(count == 1 ? "" : "s")"
                                                        title="@rag RAG status and @priority priority: @count project@(count == 1 ? "" : "s")"
                                                        @if (count > 0) { <text>data-projects='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(group?.Projects.Select(p => new { Id = p.Id, Title = p.Title, ProjectCode = p.ProjectCode ?? "", BusinessArea = p.BusinessAreaLookup?.Name ?? "-" }).ToList()))'</text> }>
                                                        @if (count > 0)
                                                        {
                                                            <div style="font-size: 1.75rem; font-weight: bold; color: @textColor; line-height: 1.2;">
                                                                @count
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <span style="color: @textColor;" aria-label="No projects">–</span>
                                                        }
                                                    </td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                        
                        <!-- Modal for displaying projects in a heatmap cell -->
                        <div class="modal fade" id="heatmapProjectsModal" tabindex="-1" role="dialog" aria-labelledby="heatmapProjectsModalLabel" aria-hidden="true">
                            <div class="modal-dialog modal-lg" role="document">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="heatmapProjectsModalLabel">Projects</h5>
                                        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                                            <span aria-hidden="true">&times;</span>
                                        </button>
                                    </div>
                                    <div class="modal-body">
                                        <p id="heatmapModalDescription" class="mb-3"></p>
                                        <div class="table-responsive">
                                            <table class="table table-hover" id="heatmapProjectsTable">
                                                <thead>
                                                    <tr>
                                                        <th>Project</th>
                                                        <th>Business Area</th>
                                                        <th>Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="heatmapProjectsTableBody">
                                                    <!-- Projects will be populated here -->
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Activity This Month -->
        <div class="row mb-4">
            <div class="col-lg-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-white">
                        <h3 class="card-title mb-0">New Projects This Month</h3>
                        <div class="card-tools">
                            <button type="button" class="btn btn-tool" data-card-widget="collapse">
                                <i class="fas fa-minus" aria-hidden="true"></i>
                                <span class="sr-only">Toggle new projects this month</span>
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
