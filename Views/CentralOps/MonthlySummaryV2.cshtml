        <!-- RAG and Priority Distribution Charts -->
        <div class="row mb-4">
            <div class="col-lg-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-white">
                        <h3 class="card-title mb-0">RAG Status Distribution</h3>
                    </div>
                    <div class="card-body">
                        <div style="position: relative; height: 300px;">
                            <canvas id="ragStatusChart"></canvas>
                        </div>
                        <div class="mt-3">
                            <div class="table-responsive">
                                <table class="table table-sm table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Status</th>
                                            <th>Count</th>
                                            <th>Percentage</th>
                                            @if (!string.IsNullOrEmpty(prevMonthName))
                                            {
                                                <th>Change from @prevMonthName</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            var ragTotal = ragData.Red + ragData.AmberRed + ragData.Amber + ragData.AmberGreen + ragData.Green + ragData.NotSet;
                                            var ragItems = new[] {
                                                new { Label = "Red", Count = ragData.Red, Color = "#dc3545", Key = "Red" },
                                                new { Label = "Amber-Red", Count = ragData.AmberRed, Color = "#fd7e14", Key = "Amber-Red" },
                                                new { Label = "Amber", Count = ragData.Amber, Color = "#ffc107", Key = "Amber" },
                                                new { Label = "Amber-Green", Count = ragData.AmberGreen, Color = "#ffeb3b", Key = "Amber-Green" },
                                                new { Label = "Green", Count = ragData.Green, Color = "#28a745", Key = "Green" },
                                                new { Label = "Not Set", Count = ragData.NotSet, Color = "#6c757d", Key = "Not Set" }
                                            };
                                        }
                                        @foreach (var item in ragItems)
                                        {
                                            var percentage = ragTotal > 0 ? ((item.Count * 100.0) / ragTotal).ToString("F1") : "0.0";
                                            var prevCount = prevMonthRagDistribution.ContainsKey(item.Key) ? prevMonthRagDistribution[item.Key] : 0;
                                            var change = item.Count - prevCount;
                                            var changeText = change > 0 ? $"+{change}" : change.ToString();
                                            var changeColor = change > 0 ? "text-danger" : (change < 0 ? "text-success" : "text-muted");
                                            var ragStatusParam = item.Key == "Not Set" ? "Not Set" : item.Key;
                                            var linkUrl = Url.Action("MonthlySummaryV2ByRagStatus", "CentralOps", new { year = year, month = month, ragStatus = ragStatusParam, businessAreaId = businessAreaId });
                                            <tr>
                                                <td>
                                                    <a href="@linkUrl" style="text-decoration: none; color: inherit;">
                                                        <span class="badge" style="background-color: @item.Color; color: @(item.Label == "Amber-Green" || item.Label == "Not Set" ? "#000" : "#fff"); cursor: pointer;">@item.Label</span>
                                                    </a>
                                                </td>
                                                <td><a href="@linkUrl" style="text-decoration: none; color: inherit; font-weight: 600;">@item.Count</a></td>
                                                <td>@percentage%</td>
                                                @if (!string.IsNullOrEmpty(prevMonthName))
                                                {
                                                    <td class="@changeColor">@changeText</td>
                                                }
                                            </tr>
                                        }
                                        @if (ragTotal > 0)
                                        {
                                            <tr style="font-weight: bold; background-color: #f4f8fb;">
                                                <td>Total</td>
                                                <td>@ragTotal</td>
                                                <td>100.0%</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-white">
                        <h3 class="card-title mb-0">Priority Distribution</h3>
                    </div>
                    <div class="card-body">
                        <div style="position: relative; height: 300px;">
                            <canvas id="priorityChart"></canvas>
                        </div>
                        <div class="mt-3">
                            <div class="table-responsive">
                                <table class="table table-sm table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Priority</th>
                                            <th>Count</th>
                                            <th>Percentage</th>
                                            @if (!string.IsNullOrEmpty(prevMonthName))
                                            {
                                                <th>Change from @prevMonthName</th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @{
                                            var priorityTotal = priorityData.Critical + priorityData.High + priorityData.Medium + priorityData.Low + priorityData.NotSet;
                                            var priorityItems = new[] {
                                                new { Label = "Critical", Count = priorityData.Critical, Color = "#dc3545", Key = "Critical" },
                                                new { Label = "High", Count = priorityData.High, Color = "#fd7e14", Key = "High" },
                                                new { Label = "Medium", Count = priorityData.Medium, Color = "#ffc107", Key = "Medium" },
                                                new { Label = "Low", Count = priorityData.Low, Color = "#6c757d", Key = "Low" },
                                                new { Label = "Not Set", Count = priorityData.NotSet, Color = "#e9ecef", Key = "Not Set" }
                                            };
                                        }
                                        @foreach (var item in priorityItems)
                                        {
                                            var percentage = priorityTotal > 0 ? ((item.Count * 100.0) / priorityTotal).ToString("F1") : "0.0";
                                            var prevCount = prevMonthPriorityDistribution.ContainsKey(item.Key) ? prevMonthPriorityDistribution[item.Key] : 0;
                                            var change = item.Count - prevCount;
                                            var changeText = change > 0 ? $"+{change}" : change.ToString();
                                            var changeColor = change > 0 ? "text-danger" : (change < 0 ? "text-success" : "text-muted");
                                            var priorityParam = item.Key == "Not Set" ? "Not Set" : item.Key;
                                            var linkUrl = Url.Action("MonthlySummaryV2ByPriority", "CentralOps", new { year = year, month = month, priority = priorityParam, businessAreaId = businessAreaId });
                                            <tr>
                                                <td>
                                                    <a href="@linkUrl" style="text-decoration: none; color: inherit;">
                                                        <span class="badge" style="background-color: @item.Color; color: @(item.Label == "Not Set" ? "#000" : "#fff"); cursor: pointer;">@item.Label</span>
                                                    </a>
                                                </td>
                                                <td><a href="@linkUrl" style="text-decoration: none; color: inherit; font-weight: 600;">@item.Count</a></td>
                                                <td>@percentage%</td>
                                                @if (!string.IsNullOrEmpty(prevMonthName))
                                                {
                                                    <td class="@changeColor">@changeText</td>
                                                }
                                            </tr>
                                        }
                                        @if (priorityTotal > 0)
                                        {
                                            <tr style="font-weight: bold; background-color: #f4f8fb;">
                                                <td>Total</td>
                                                <td>@priorityTotal</td>
                                                <td>100.0%</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

