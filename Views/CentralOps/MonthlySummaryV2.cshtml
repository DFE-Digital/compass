<!-- Milestone Details Modal -->
<div class="modal fade" id="milestoneModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="milestoneModalTitle">Milestone Details</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6 class="font-weight-bold">Milestone Information</h6>
                        <table class="table table-sm table-borderless">
                            <tr>
                                <td class="text-muted" style="width: 40%;">Milestone:</td>
                                <td id="milestoneModalName" class="font-weight-bold"></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Project:</td>
                                <td id="milestoneModalProject"></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Date:</td>
                                <td id="milestoneModalDate"></td>
                            </tr>
                            <tr>
                                <td class="text-muted">Primary Contact:</td>
                                <td id="milestoneModalContact"></td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                <a id="milestoneModalLink" href="#" class="btn btn-primary">Go to Project</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" nonce="@Context.Items["Nonce"]"></script>
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Show loading modal when form is submitted
            $('#filterForm').on('submit', function() {
                $('#loadingModal').modal('show');
            });
            
            // Project link click handler (for new projects)
            $('.project-link').on('click', function(e) {
                e.preventDefault();
                var projectId = $(this).data('project-id');
                var projectTitle = $(this).data('project-title');
                var projectCode = $(this).data('project-code');
                var businessArea = $(this).data('business-area');
                var created = $(this).data('created');
                var primaryContact = $(this).data('primary-contact');
                
                $('#projectModalTitle').text(projectTitle);
                $('#projectModalName').text(projectTitle);
                $('#projectModalCode').text(projectCode);
                $('#projectModalBusinessArea').text(businessArea);
                $('#projectModalCreated').text(created);
                $('#projectModalContact').text(primaryContact);
                $('#projectModalLink').attr('href', '/Project/Details/' + projectId);
                
                $('#projectModal').modal('show');
            });
            
            // Project detail link click handler (for active projects and path to green)
            $(document).on('click', '.project-detail-link', function(e) {
                e.preventDefault();
                var $link = $(this);
                var projectId = $link.data('project-id');
                var projectTitle = $link.data('project-title');
                var projectCode = $link.data('project-code');
                var businessArea = $link.data('business-area');
                var ragStatus = $link.data('rag-status');
                var priority = $link.data('priority');
                var status = $link.data('status');
                var primaryContact = $link.data('primary-contact');
                var aim = $link.attr('data-aim') || 'Not provided';
                var problemStatement = $link.attr('data-problem-statement') || 'Not provided';
                var pathToGreen = $link.attr('data-path-to-green');
                var monthlyNarrativeRaw = $link.attr('data-monthly-narrative');
                
                // Decode HTML entities
                function decodeHtml(html) {
                    var txt = document.createElement("textarea");
                    txt.innerHTML = html;
                    return txt.value;
                }
                
                aim = decodeHtml(aim);
                problemStatement = decodeHtml(problemStatement);
                var monthlyNarrative = monthlyNarrativeRaw ? decodeHtml(monthlyNarrativeRaw) : '';
                
                // Determine RAG badge class
                var ragBadgeClass = 'badge-light';
                var ragBadgeStyle = '';
                if (ragStatus === 'Red') ragBadgeClass = 'badge-danger';
                else if (ragStatus === 'Amber-Red') { ragBadgeClass = 'badge'; ragBadgeStyle = 'background-color: #fd7e14;'; }
                else if (ragStatus === 'Amber') { ragBadgeClass = 'badge-warning'; ragBadgeStyle = 'color: #000;'; }
                else if (ragStatus === 'Amber-Green') { ragBadgeClass = 'badge'; ragBadgeStyle = 'background-color: #ffeb3b; color: #000;'; }
                else if (ragStatus === 'Green') ragBadgeClass = 'badge-success';
                else if (ragStatus === 'Not Set' || ragStatus === 'Not started' || ragStatus === 'On hold') { ragBadgeClass = 'badge-light'; ragBadgeStyle = 'background-color: #e9ecef; color: #000;'; }
                
                $('#projectModalTitle').text(projectTitle);
                $('#projectModalName').text(projectTitle);
                $('#projectModalCode').text(projectCode);
                $('#projectModalBusinessArea').text(businessArea);
                $('#projectModalRagStatus').html('<span class="badge ' + ragBadgeClass + '" style="' + ragBadgeStyle + '">' + ragStatus + '</span>');
                $('#projectModalPriority').text(priority || 'Not Set');
                $('#projectModalStatus').text(status || 'Active');
                $('#projectModalContact').text(primaryContact || '-');
                
                // Display Aim
                if (aim && aim !== 'Not provided') {
                    $('#projectModalAim').text(aim);
                } else {
                    $('#projectModalAim').html('<em class="text-muted">Not provided</em>');
                }
                
                // Display Problem Statement
                if (problemStatement && problemStatement !== 'Not provided') {
                    $('#projectModalProblemStatement').text(problemStatement);
                } else {
                    $('#projectModalProblemStatement').html('<em class="text-muted">Not provided</em>');
                }
                
                // Latest monthly narrative (Active projects / Path to green links supply data-monthly-narrative)
                if (monthlyNarrative && monthlyNarrative.trim() !== '') {
                    $('#projectModalMonthlyNarrative').text(monthlyNarrative);
                } else {
                    $('#projectModalMonthlyNarrative').html('<em class="text-muted">Not provided</em>');
                }
                
                $('#projectModalLink').attr('href', '/Project/Details/' + projectId);
                
                $('#projectModal').modal('show');
            });
            
            // Path to Green - filter by current RAG
            function applyPathToGreenRagFilter() {
                var selectedRags = [];
                $('.path-to-green-rag-checkbox:checked').each(function () {
                    selectedRags.push($(this).val());
                });
                
                // If nothing selected, show nothing (explicit filter)
                $('.path-to-green-row').each(function () {
                    var rowRag = $(this).data('current-rag');
                    if (selectedRags.length === 0) {
                        $(this).hide();
                    } else if (selectedRags.indexOf(rowRag) !== -1) {
                        $(this).show();
                    } else {
                        $(this).hide();
                    }
                });
            }
            
            $(document).on('change', '.path-to-green-rag-checkbox', function () {
                applyPathToGreenRagFilter();
            });
            
            // Apply initial filter on page load (all selected)
            applyPathToGreenRagFilter();
            
            // Toggle between table and heatmap view for RAG/Priority
            $('#toggleHeatmapView').on('click', function(e) {
                e.preventDefault();
                var $tableView = $('#ragPriorityTableView');
                var $heatmapView = $('#ragPriorityHeatmapView');
                var $toggleText = $('#viewToggleText');
                
                if ($tableView.is(':visible')) {
                    $tableView.hide();
                    $heatmapView.show();
                    $toggleText.text('View table');
                    $(this).find('i').removeClass('fa-th').addClass('fa-list');
                } else {
                    $tableView.show();
                    $heatmapView.hide();
                    $toggleText.text('View heatmap');
                    $(this).find('i').removeClass('fa-list').addClass('fa-th');
                }
            });
            
            // Make RAG/Priority table sortable
            function initializeRagPriorityTableSorting() {
                var $table = $('#ragPriorityTable');
                var currentSort = { column: null, direction: 'asc' };
                
                $table.find('.sortable').on('click', function() {
                    var column = $(this).data('column');
                    var direction = 'asc';
                    
                    if (currentSort.column === column && currentSort.direction === 'asc') {
                        direction = 'desc';
                    }
                    
                    sortRagPriorityTable($table, column, direction);
                    currentSort = { column: column, direction: direction };
                    
                    // Update sort icons
                    $table.find('.sortable i').removeClass('fa-sort-up fa-sort-down').addClass('fa-sort');
                    var $icon = $(this).find('i');
                    $icon.removeClass('fa-sort');
                    if (direction === 'asc') {
                        $icon.addClass('fa-sort-up');
                    } else {
                        $icon.addClass('fa-sort-down');
                    }
                });
            }
            
            function sortRagPriorityTable($table, column, direction) {
                var tbody = $table.find('tbody');
                var rows = tbody.find('tr').toArray();
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    
                    if (column === 'count') {
                        aVal = parseInt($(a).data('count') || 0);
                        bVal = parseInt($(b).data('count') || 0);
                    } else if (column === 'rag') {
                        var ragOrder = ['Red', 'Amber-Red', 'Amber', 'Amber-Green', 'Green', 'Not Started', 'On Hold', 'Not Set'];
                        var aRag = $(a).data('rag') || '';
                        var bRag = $(b).data('rag') || '';
                        aVal = ragOrder.indexOf(aRag);
                        bVal = ragOrder.indexOf(bRag);
                    } else if (column === 'priority') {
                        var priorityOrder = ['Critical', 'High', 'Medium', 'Low', 'Not Set'];
                        var aPriority = $(a).data('priority') || '';
                        var bPriority = $(b).data('priority') || '';
                        aVal = priorityOrder.indexOf(aPriority);
                        bVal = priorityOrder.indexOf(bPriority);
                    } else {
                        aVal = $(a).find('td').eq($table.find('th[data-column="' + column + '"]').index()).text().trim().toLowerCase();
                        bVal = $(b).find('td').eq($table.find('th[data-column="' + column + '"]').index()).text().trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.empty();
                rows.forEach(function(row) {
                    tbody.append(row);
                });
            }
            
            // Initialize sorting
            initializeRagPriorityTableSorting();
            
            // Expand/collapse projects in RAG/Priority table
            $(document).on('click', '.expand-projects-link', function(e) {
                e.preventDefault();
                var $link = $(this);
                var expandId = $link.data('expand-id');
                var $detailRow = $('#' + expandId);
                var $row = $link.closest('tr');
                var count = parseInt($row.data('count') || 0);
                
                if ($detailRow.is(':visible')) {
                    $detailRow.slideUp();
                    $link.html('<i class="fas fa-chevron-right mr-1"></i>View ' + count + ' project' + (count === 1 ? '' : 's'));
                } else {
                    $detailRow.slideDown();
                    $link.html('<i class="fas fa-chevron-down mr-1"></i>Hide projects');
                }
            });
            
            // Heatmap cell click handler - show modal with projects
            $(document).on('click', '#ragPriorityHeatmapView td[data-rag][data-priority]', function() {
                var $cell = $(this);
                var rag = $cell.data('rag');
                var priority = $cell.data('priority');
                var count = $cell.data('count');
                
                // Get projects data from data-projects attribute (jQuery .data() lowercases, so we need to use attr and parse)
                var projectsJson = $cell.attr('data-projects');
                var projectsData = [];
                
                if (projectsJson) {
                    try {
                        projectsData = JSON.parse(projectsJson);
                    } catch (e) {
                        console.error('Error parsing projects JSON:', e);
                    }
                }
                
                if (count > 0 && projectsData && projectsData.length > 0) {
                    // Update modal title and description
                    $('#heatmapProjectsModalLabel').text('Projects: ' + rag + ' RAG / ' + priority + ' Priority');
                    $('#heatmapModalDescription').text('Showing ' + count + ' project' + (count === 1 ? '' : 's') + ' with ' + rag + ' RAG status and ' + priority + ' priority.');
                    
                    // Clear and populate table
                    var $tbody = $('#heatmapProjectsTableBody');
                    $tbody.empty();
                    
                    projectsData.forEach(function(project) {
                        // Handle both camelCase (from jQuery .data()) and PascalCase (from JSON)
                        var projectId = project.Id || project.id;
                        var projectTitle = project.Title || project.title || '';
                        var projectCode = project.ProjectCode || project.projectCode || '';
                        var businessArea = project.BusinessArea || project.businessArea || '-';
                        
                        var projectUrl = '@Url.Action("Details", "Project", new { id = "__ID__" })'.replace('__ID__', projectId);
                        var displayCode = projectCode ? projectCode : ('DFE-DDT-' + projectId);
                        var row = '<tr>' +
                            '<td><a href="' + projectUrl + '" style="color: #005ea5; text-decoration: none; font-weight: 600;">' + 
                            escapeHtml(projectTitle) + '</a><br /><small class="text-muted">' + displayCode + '</small></td>' +
                            '<td>' + escapeHtml(businessArea) + '</td>' +
                            '<td><a href="' + projectUrl + '" class="btn btn-sm btn-primary">View Details</a></td>' +
                            '</tr>';
                        $tbody.append(row);
                    });
                    
                    // Show modal
                    $('#heatmapProjectsModal').modal('show');
                } else if (count === 0) {
                    // Show message for empty cells
                    $('#heatmapProjectsModalLabel').text('Projects: ' + rag + ' RAG / ' + priority + ' Priority');
                    $('#heatmapModalDescription').text('No projects found with ' + rag + ' RAG status and ' + priority + ' priority.');
                    var $tbody = $('#heatmapProjectsTableBody');
                    $tbody.empty();
                    $tbody.append('<tr><td colspan="3" class="text-center text-muted p-4">No projects in this category</td></tr>');
                    $('#heatmapProjectsModal').modal('show');
                }
            });
            
            // Handle keyboard navigation for heatmap cells
            $(document).on('keydown', '#ragPriorityHeatmapView td[data-rag][data-priority]', function(e) {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    $(this).click();
                }
            });
            
            // Helper function to escape HTML
            function escapeHtml(text) {
                var map = {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#039;'
                };
                return text ? text.replace(/[&<>"']/g, function(m) { return map[m]; }) : '';
            }
            
            function formatResourceFte(v) {
                var n = parseFloat(v);
                if (isNaN(n)) n = 0;
                return n.toFixed(1);
            }
            
            function openBusinessAreaResourceModal($link) {
                var businessAreaName = $link.data('business-area-name');
                var projectCount = $link.data('project-count');
                var totalPermFte = $link.data('total-perm-fte');
                var totalMspFte = $link.data('total-msp-fte');
                var totalFte = $link.data('total-fte');
                var businessAreaIdAttr = $link.attr('data-business-area-id');
                
                var $hiddenInput = $link.closest('tr').find('.business-area-projects-data');
                var projectsJson = $hiddenInput.length ? $hiddenInput.val() : '';
                var projects = [];
                try {
                    projects = projectsJson ? JSON.parse(projectsJson) : [];
                } catch (err) {
                    console.error('Error parsing projects JSON:', err);
                }
                
                $('#businessAreaResourceModalTitle').text(businessAreaName + ' — FTE breakdown');
                $('#businessAreaResourceModalName').text(businessAreaName);
                $('#businessAreaResourceModalProjectCount').text(projectCount);
                $('#businessAreaResourceModalPermFte').text(formatResourceFte(totalPermFte));
                $('#businessAreaResourceModalMspFte').text(formatResourceFte(totalMspFte));
                $('#businessAreaResourceModalTotalFte').text(formatResourceFte(totalFte));
                
                var $projectsList = $('#businessAreaResourceModalProjectsList');
                $projectsList.empty();
                
                var projectTemplate = '@Url.Action("Details", "Project", new { id = "__ID__" })';
                
                if (projects.length > 0) {
                    projects.forEach(function(project) {
                        var id = project.Id !== undefined ? project.Id : project.id;
                        var title = project.Title !== undefined ? project.Title : (project.title || '');
                        var code = project.ProjectCode || project.projectCode || ('DFE-DDT-' + id);
                        var perm = project.TotalPermFte !== undefined ? project.TotalPermFte : project.totalPermFte;
                        var msp = project.TotalMspFte !== undefined ? project.TotalMspFte : project.totalMspFte;
                        var tot = project.TotalFte !== undefined ? project.TotalFte : project.totalFte;
                        var projectUrl = projectTemplate.replace('__ID__', id);
                        var row = '<tr>' +
                            '<td><a href="' + projectUrl + '" style="color: #005ea5; text-decoration: none; font-weight: 600;">' +
                            escapeHtml(String(title)) + '</a><br><small class="text-muted">' + escapeHtml(String(code)) + '</small></td>' +
                            '<td class="text-center">' + formatResourceFte(perm) + '</td>' +
                            '<td class="text-center">' + formatResourceFte(msp) + '</td>' +
                            '<td class="text-center"><strong>' + formatResourceFte(tot) + '</strong></td>' +
                            '</tr>';
                        $projectsList.append(row);
                    });
                } else {
                    $projectsList.append('<tr><td colspan="4" class="text-center text-muted">No work items</td></tr>');
                }
                
                var $footerBtn = $('#businessAreaResourceModalLink');
                if (businessAreaIdAttr !== undefined && businessAreaIdAttr !== null && businessAreaIdAttr !== '') {
                    $footerBtn.attr('href', '/CentralOps/MonthlySummaryV2?year=@year&month=@month&businessAreaId=' + encodeURIComponent(businessAreaIdAttr)).show();
                } else {
                    $footerBtn.hide();
                }
                
                $('#businessAreaResourceModal').modal('show');
            }
            
            $(document).on('click', '.business-area-resource-link', function(e) {
                e.preventDefault();
                openBusinessAreaResourceModal($(this));
            });
            
            $(document).on('click', '.business-area-resource-row', function(e) {
                if ($(e.target).closest('a.business-area-resource-link').length) return;
                var $a = $(this).find('.business-area-resource-link');
                if (!$a.length) return;
                e.preventDefault();
                openBusinessAreaResourceModal($a);
            });
            
            $(document).on('keydown', '.business-area-resource-row', function(e) {
                if (e.key !== 'Enter' && e.key !== ' ') return;
                var $a = $(this).find('.business-area-resource-link');
                if (!$a.length) return;
                e.preventDefault();
                openBusinessAreaResourceModal($a);
            });
            
            // Toggle icon for resource table collapse
            $('#resourceByBusinessAreaTable').on('show.bs.collapse', function() {
                $('#resourceTableToggleIcon').removeClass('fa-chevron-down').addClass('fa-chevron-up');
                $('#resourceTableToggleLabel').text('Hide');
            });
            $('#resourceByBusinessAreaTable').on('hide.bs.collapse', function() {
                $('#resourceTableToggleIcon').removeClass('fa-chevron-up').addClass('fa-chevron-down');
                $('#resourceTableToggleLabel').text('Show');
            });
            
            // Milestone link click handler
            $('.milestone-link').on('click', function(e) {
                e.preventDefault();
                var milestoneName = $(this).data('milestone-name');
                var projectId = $(this).data('project-id');
                var projectTitle = $(this).data('project-title');
                var date = $(this).data('date');
                var primaryContact = $(this).data('primary-contact');
                
                $('#milestoneModalTitle').text(milestoneName);
                $('#milestoneModalName').text(milestoneName);
                $('#milestoneModalProject').text(projectTitle);
                $('#milestoneModalDate').text(date);
                $('#milestoneModalContact').text(primaryContact);
                $('#milestoneModalLink').attr('href', '/Project/Details/' + projectId);
                
                $('#milestoneModal').modal('show');
            });
            
            // RAG Status Donut Chart (standalone "Amber" RAG retired — not shown)
            var ragCtx = document.getElementById('ragStatusChart');
            if (ragCtx) {
                new Chart(ragCtx.getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: ['Red', 'Amber-Red', 'Amber-Green', 'Green', 'Not Started', 'On Hold', 'Not Set'],
                        datasets: [{
                            data: [@ragData.Red, @ragData.AmberRed, @ragData.AmberGreen, @ragData.Green, @ragData.NotStarted, @ragData.OnHold, @ragData.NotSet],
                            backgroundColor: [
                                '#dc3545',
                                '#fd7e14',
                                '#ffeb3b',
                                '#28a745',
                                '#e9ecef',
                                '#e9ecef',
                                '#e9ecef'
                            ],
                            borderWidth: 3,
                            borderColor: '#fff'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    padding: 15,
                                    font: {
                                        size: 12
                                    }
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        var label = context.label || '';
                                        var value = context.parsed || 0;
                                        var total = context.dataset.data.reduce((a, b) => a + b, 0);
                                        var percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                        return label + ': ' + value + ' (' + percentage + '%)';
                                    }
                                }
                            }
                        }
                    }
                });
            }

            // Priority Distribution Donut Chart
            var priorityCtx = document.getElementById('priorityChart');
            if (priorityCtx) {
                var priorityChart = new Chart(priorityCtx.getContext('2d'), {
                    type: 'doughnut',
                    data: {
                        labels: ['Critical', 'High', 'Medium', 'Low', 'Not Set'],
                        datasets: [{
                            data: [@priorityData.Critical, @priorityData.High, @priorityData.Medium, @priorityData.Low, @priorityData.NotSet],
                            backgroundColor: [
                                '#dc3545',
                                '#fd7e14',
                                '#ffc107',
                                '#6c757d',
                                '#e9ecef'
                            ],
                            borderWidth: 3,
                            borderColor: '#fff'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    padding: 15,
                                    font: {
                                        size: 12
                                    }
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        var label = context.label || '';
                                        var value = context.parsed || 0;
                                        var total = context.dataset.data.reduce((a, b) => a + b, 0);
                                        var percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                        return label + ': ' + value + ' (' + percentage + '%)';
                                    }
                                }
                            }
                        },
                        onClick: function(event, elements) {
                            if (elements.length > 0) {
                                var index = elements[0].index;
                                var labels = ['Critical', 'High', 'Medium', 'Low', 'Not Set'];
                                var priority = labels[index];
                                var priorityParam = priority === 'Not Set' ? 'Not Set' : priority;
                                var url = '@Url.Action("MonthlySummaryV2ByPriority", "CentralOps", new { year = year, month = month, priority = "__PRIORITY__", businessAreaId = businessAreaId })';
                                url = url.replace('__PRIORITY__', encodeURIComponent(priorityParam));
                                window.location.href = url;
                            }
                        }
                    }
                });
            }
        });
    </script>
}
