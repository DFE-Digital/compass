                                                                @item.BusinessAreaName
                                                            </a>
                                                            <input type="hidden" class="business-area-projects-data" 
                                                                   data-business-area-id="@item.BusinessAreaId"
                                                                   value="@System.Text.Json.JsonSerializer.Serialize(businessAreaProjects.Select(p => new { Id = p.Id, Title = p.Title, ProjectCode = $"DFE-DDT-{p.Id}", TotalPermFte = p.TotalPermFte ?? 0, TotalMspFte = p.TotalMspFte ?? 0, TotalFte = (p.TotalPermFte ?? 0) + (p.TotalMspFte ?? 0) }).ToList())" />
                                                        }
