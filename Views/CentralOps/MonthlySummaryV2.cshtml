                                                        @item.Milestone.Name
                                                    </a>
                                                </td>
                                                <td>@item.Project.Title</td>
                                                <td>@item.Milestone.ActualDate?.ToString("dd MMM yyyy")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
