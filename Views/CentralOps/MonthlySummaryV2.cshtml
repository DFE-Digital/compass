                                                        <span class="badge" style="background-color: @item.Color; color: @(item.Label == "Medium" || item.Label == "Not Set" ? "#000" : "#fff"); cursor: pointer;">@item.Label</span>
                                                    </a>
                                                </td>
                                                <td><a href="@linkUrl" style="text-decoration: none; color: inherit; font-weight: 600;">@item.Count</a></td>
