@using Compass.Controllers
@using Compass.ViewModels
@{
    ViewData["Title"] = "Monthly Summary V2";
}

<style>
    .border-left-primary {
        border-left: 0.25rem solid #4e73df !important;
    }
    .border-left-success {
        border-left: 0.25rem solid #1cc88a !important;
    }
    .border-left-info {
        border-left: 0.25rem solid #36b9cc !important;
    }
    .border-left-warning {
        border-left: 0.25rem solid #f6c23e !important;
    }
    .border-left-danger {
        border-left: 0.25rem solid #e74a3b !important;
    }
    .border-left-secondary {
        border-left: 0.25rem solid #858796 !important;
    }
    .text-xs {
        font-size: 0.7rem;
    }
    .text-gray-300 {
        color: #dddfeb !important;
    }
    .text-gray-800 {
        color: #5a5c69 !important;
    }
</style>

@{
    var year = ViewBag.Year as int? ?? DateTime.UtcNow.Year;
    var month = ViewBag.Month as int? ?? DateTime.UtcNow.Month;
    var monthName = ViewBag.MonthName as string ?? "";
    var businessAreaId = ViewBag.BusinessAreaId as int?;
    var businessAreas = ViewBag.BusinessAreas as List<Compass.Models.BusinessAreaLookup> ?? new List<Compass.Models.BusinessAreaLookup>();
    var totalActiveProjects = ViewBag.TotalActiveProjects as int? ?? 0;
    var newProjectsThisMonth = ViewBag.NewProjectsThisMonth as List<Compass.Models.Project> ?? new List<Compass.Models.Project>();
    var milestonesAchieved = ViewBag.MilestonesAchieved as List<MilestoneWithProject> ?? new List<MilestoneWithProject>();
    var monthlyUpdateStats = ViewBag.MonthlyUpdateStats as MonthlyUpdateStats;
    var ragDistribution = ViewBag.RagDistribution as Dictionary<string, int> ?? new Dictionary<string, int>();
    var priorityDistribution = ViewBag.PriorityDistribution as Dictionary<string, int> ?? new Dictionary<string, int>();
    var prevMonthRagDistribution = ViewBag.PrevMonthRagDistribution as Dictionary<string, int> ?? new Dictionary<string, int>();
    var prevMonthPriorityDistribution = ViewBag.PrevMonthPriorityDistribution as Dictionary<string, int> ?? new Dictionary<string, int>();
    var upcomingMilestones = ViewBag.UpcomingMilestones as List<MilestoneWithProject> ?? new List<MilestoneWithProject>();
    var lateMilestones = ViewBag.LateMilestones as List<MilestoneWithProject> ?? new List<MilestoneWithProject>();
    var businessAreaSummaries = ViewBag.BusinessAreaSummaries as List<BusinessAreaSummaryViewModel> ?? new List<BusinessAreaSummaryViewModel>();
    var projectsWithPathToGreen = ViewBag.ProjectsWithPathToGreen as List<Compass.Models.Project> ?? new List<Compass.Models.Project>();
    var businessAreaRisks = ViewBag.BusinessAreaRisks as List<RiskWithProject> ?? new List<RiskWithProject>();
    var businessAreaIssues = ViewBag.BusinessAreaIssues as List<IssueWithProject> ?? new List<IssueWithProject>();
    var businessAreaActiveProjects = ViewBag.BusinessAreaActiveProjects as List<Compass.Models.Project> ?? new List<Compass.Models.Project>();
    var selectedBusinessArea = businessAreaId.HasValue ? businessAreas.FirstOrDefault(ba => ba.Id == businessAreaId.Value) : null;
    
    // Month-over-month trends data
    var prevMonthTotalProjects = ViewBag.PrevMonthTotalProjects as int? ?? 0;
    var prevMonthNewProjects = ViewBag.PrevMonthNewProjects as int? ?? 0;
    var prevMonthMilestonesAchieved = ViewBag.PrevMonthMilestonesAchieved as int? ?? 0;
    var prevMonthUpdateStats = ViewBag.PrevMonthUpdateStats as MonthlyUpdateStats;
    var prevMonthName = ViewBag.PrevMonthName as string ?? "";
    var projectsWithRagChange = ViewBag.ProjectsWithRagChange as int? ?? 0;
    var projectsWithStatusChange = ViewBag.ProjectsWithStatusChange as int? ?? 0;
    var projectsWithPriorityChange = ViewBag.ProjectsWithPriorityChange as int? ?? 0;
    
    // Flagship projects
    var flagshipProjects = ViewBag.FlagshipProjects as List<Compass.Models.Project> ?? new List<Compass.Models.Project>();
    
    // Resource summary
    var totalPermFte = ViewBag.TotalPermFte as decimal? ?? 0;
    var totalMspFte = ViewBag.TotalMspFte as decimal? ?? 0;
    var totalFte = ViewBag.TotalFte as decimal? ?? 0;
    var resourceByBusinessArea = ViewBag.ResourceByBusinessArea as List<object> ?? new List<object>();
    
    // Prepare data for charts (like original)
    var ragData = new {
        Red = ragDistribution.ContainsKey("Red") ? ragDistribution["Red"] : 0,
        AmberRed = ragDistribution.ContainsKey("Amber-Red") ? ragDistribution["Amber-Red"] : 0,
        Amber = ragDistribution.ContainsKey("Amber") ? ragDistribution["Amber"] : 0,
        AmberGreen = ragDistribution.ContainsKey("Amber-Green") ? ragDistribution["Amber-Green"] : 0,
        Green = ragDistribution.ContainsKey("Green") ? ragDistribution["Green"] : 0,
        NotSet = ragDistribution.ContainsKey("Not Set") ? ragDistribution["Not Set"] : 0
    };
    
    var priorityData = new {
        Critical = priorityDistribution.ContainsKey("Critical") ? priorityDistribution["Critical"] : 0,
        High = priorityDistribution.ContainsKey("High") ? priorityDistribution["High"] : 0,
        Medium = priorityDistribution.ContainsKey("Medium") ? priorityDistribution["Medium"] : 0,
        Low = priorityDistribution.ContainsKey("Low") ? priorityDistribution["Low"] : 0,
        NotSet = priorityDistribution.ContainsKey("Not Set") ? priorityDistribution["Not Set"] : 0
    };
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="CentralOps" asp-action="Dashboard" style="color: #005ea5; text-decoration: none;">Central Operations</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Monthly Summary V2</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        @await Html.PartialAsync("_CentralOpsNavigation")
        
        <!-- Header -->
        <div class="content-header mb-4">
            <div class="container-fluid">
                <div class="row align-items-center">
                    <div class="col-sm-6">
                        <h1 class="m-0" style="font-size: 1.75rem; font-weight: 600;">
                            @if (businessAreaId.HasValue && selectedBusinessArea != null)
                            {
                                @selectedBusinessArea.Name
                            }
                            else
                            {
                                <text>Monthly report dashboard</text>
                            }
                        </h1>
                        <p class="text-muted mb-0 mt-1" style="font-size: 1.1rem;">@monthName</p>
                    </div>
                    <div class="col-sm-6 text-right mt-3 mt-sm-0">
                        <a href="@Url.Action("ExportMonthlySummaryV2", "CentralOps", new { year = year, month = month, businessAreaId = businessAreaId })" 
                           class="btn btn-success mr-2" 
                           style="font-weight: 500;">
                            <i class="fas fa-file-excel mr-2"></i>Export to Excel
                        </a>
                        <a href="@Url.Action("MonthlySummaryV2Pdf", "CentralOps", new { year = year, month = month, businessAreaId = businessAreaId })" 
                           class="btn btn-primary" 
                           style="font-weight: 500;">
                            <i class="fas fa-file-pdf mr-2"></i>Download PDF Report
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filter Block -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="card-title mb-0" style="font-weight: 600;">
                    <i class="fas fa-filter mr-2"></i>Filters
                </h5>
            </div>
            <div class="card-body">
                <form method="get" asp-controller="CentralOps" asp-action="MonthlySummaryV2">
                    <div class="row align-items-end">
                        <div class="col-md-3">
                            <div class="form-group mb-0">
                                <label for="year" class="form-label" style="font-weight: 500; font-size: 0.9rem; margin-bottom: 0.5rem;">Year</label>
                                <select name="year" id="year" class="form-control">
                                    <option value="2026" selected="@(year == 2026)">2026</option>
                                    <option value="2025" selected="@(year == 2025)">2025</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="form-group mb-0">
                                <label for="month" class="form-label" style="font-weight: 500; font-size: 0.9rem; margin-bottom: 0.5rem;">Month</label>
                                <select name="month" id="month" class="form-control">
                                    @for (int m = 1; m <= 12; m++)
                                    {
                                        <option value="@m" selected="@(m == month)">@(new DateTime(year, m, 1).ToString("MMMM"))</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group mb-0">
                                <label for="businessAreaId" class="form-label" style="font-weight: 500; font-size: 0.9rem; margin-bottom: 0.5rem;">Business Area</label>
                                <select name="businessAreaId" id="businessAreaId" class="form-control">
                                    <option value="">All Areas</option>
                                    @foreach (var ba in businessAreas)
                                    {
                                        <option value="@ba.Id" selected="@(ba.Id == businessAreaId)">@ba.Name</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="col-md-2">
                            <div class="form-group mb-0">
                                <button type="submit" class="btn btn-primary btn-block" style="font-weight: 500;">
                                    <i class="fas fa-filter mr-1"></i>Apply
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <!-- Loading Modal -->
        <div class="modal fade" id="loadingModal" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-body text-center py-4">
                        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                            <span class="sr-only">Loading...</span>
                        </div>
                        <h5 class="mt-3 mb-0">Loading report...</h5>
                        <p class="text-muted mb-0">Please wait while we fetch the data</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Loading Modal -->
        <div class="modal fade" id="loadingModal" tabindex="-1" role="dialog" data-backdrop="static" data-keyboard="false">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-body text-center py-4">
                        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                            <span class="sr-only">Loading...</span>
                        </div>
                        <h5 class="mt-3 mb-0">Loading report...</h5>
                        <p class="text-muted mb-0">Please wait while we fetch the data</p>
                    </div>
                </div>
            </div>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <!-- Summary Cards -->
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-white">
                <h3 class="card-title mb-0">Summary for @monthName</h3>
                @if (ViewBag.NarrativeSummary != null)
                {
                    var narrativeSummary = ViewBag.NarrativeSummary as string ?? "";
                    if (!string.IsNullOrEmpty(narrativeSummary))
                    {
                        <div class="card-tools">
                            <a href="#" class="card-link" data-toggle="modal" data-target="#narrativeModal">
                                View narrative
                            </a>
                        </div>
                    }
                }
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-2">
                        <div class="card border-left-primary shadow-sm h-100">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">All</div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800">@totalActiveProjects</div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="fas fa-project-diagram fa-2x text-gray-300"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="card border-left-success shadow-sm h-100">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Submitted</div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800">@(monthlyUpdateStats?.Submitted ?? 0)</div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="fas fa-check fa-2x text-gray-300"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="card border-left-warning shadow-sm h-100">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Milestones Achieved</div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800">@milestonesAchieved.Count</div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="fas fa-check-double fa-2x text-gray-300"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="card border-left-info shadow-sm h-100">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">New</div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800">@newProjectsThisMonth.Count</div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="fas fa-plus-circle fa-2x text-gray-300"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="card border-left-danger shadow-sm h-100">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Late</div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800">@(monthlyUpdateStats?.Late ?? 0)</div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="fas fa-times fa-2x text-gray-300"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="card border-left-secondary shadow-sm h-100">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-secondary text-uppercase mb-1">Not Started</div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800">@(monthlyUpdateStats?.NotStarted ?? 0)</div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="fas fa-circle fa-2x text-gray-300"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Business Area Summary (shown when in business area view) -->
        @if (businessAreaId.HasValue)
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-white">
                    <h3 class="card-title mb-0">Business Area Summary</h3>
                </div>
                <div class="card-body p-0">
                    @if (businessAreaSummaries.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th rowspan="2">Business Area</th>
                                        <th rowspan="2" class="text-center">Total Projects</th>
                                        <th rowspan="2" class="text-center" style="border-right: 2px solid #dee2e6;">New This Month</th>
                                        <th colspan="3" class="text-center" style="border-bottom: 2px solid #dee2e6; border-left: 2px solid #dee2e6;">Milestones</th>
                                        <th colspan="5" class="text-center" style="border-bottom: 2px solid #dee2e6; border-left: 2px solid #dee2e6;">RAG Status</th>
                                        <th colspan="5" class="text-center" style="border-bottom: 2px solid #dee2e6; border-left: 2px solid #dee2e6;">Priority</th>
                                    </tr>
                                    <tr>
                                        <th class="text-center" style="border-left: 2px solid #dee2e6;">Completed</th>
                                        <th class="text-center">Upcoming</th>
                                        <th class="text-center">Late</th>
                                        <th class="text-center" style="border-left: 2px solid #dee2e6;">Red</th>
                                        <th class="text-center">Amber-Red</th>
                                        <th class="text-center">Amber-Green</th>
                                        <th class="text-center">Green</th>
                                        <th class="text-center">Not Set</th>
                                        <th class="text-center" style="border-left: 2px solid #dee2e6;">Critical</th>
                                        <th class="text-center">High</th>
                                        <th class="text-center">Medium</th>
                                        <th class="text-center">Low</th>
                                        <th class="text-center">Not Set</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var summary in businessAreaSummaries)
                                    {
                                        <tr>
                                            <td>
                                                @if (summary.BusinessAreaId.HasValue)
                                                {
                                                    <a asp-controller="CentralOps" asp-action="MonthlySummaryV2" asp-route-year="@year" asp-route-month="@month" asp-route-businessAreaId="@summary.BusinessAreaId" style="color: #005ea5; text-decoration: none; font-weight: 600;">
                                                        @summary.BusinessArea
                                                    </a>
                                                }
                                                else
                                                {
                                                    @summary.BusinessArea
                                                }
                                            </td>
                                            <td class="text-center">@summary.TotalProjects</td>
                                            <td class="text-center" style="border-right: 2px solid #dee2e6;">@summary.NewThisMonth</td>
                                            <!-- Milestones columns -->
                                            <td class="text-center" style="border-left: 2px solid #dee2e6;">
                                                <span class="badge badge-success">@summary.MilestonesAchieved</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge" style="background-color: #fd7e14;">@summary.UpcomingMilestones</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge badge-danger">@summary.LateMilestones</span>
                                            </td>
                                            <!-- RAG Status columns -->
                                            <td class="text-center" style="border-left: 2px solid #dee2e6;"><span class="badge badge-danger">@summary.RedCount</span></td>
                                            <td class="text-center"><span class="badge" style="background-color: #fd7e14;">@summary.AmberRedCount</span></td>
                                            <td class="text-center"><span class="badge" style="background-color: #ffeb3b; color: #000;">@summary.AmberGreenCount</span></td>
                                            <td class="text-center"><span class="badge badge-success">@summary.GreenCount</span></td>
                                            <td class="text-center"><span class="badge badge-secondary">@(summary.TotalProjects - summary.RedCount - summary.AmberRedCount - summary.AmberGreenCount - summary.GreenCount)</span></td>
                                            <!-- Priority columns -->
                                            <td class="text-center" style="border-left: 2px solid #dee2e6;"><span class="badge badge-danger">@summary.CriticalCount</span></td>
                                            <td class="text-center"><span class="badge badge-warning">@summary.HighCount</span></td>
                                            <td class="text-center"><span class="badge badge-info">@summary.MediumCount</span></td>
                                            <td class="text-center"><span class="badge badge-secondary">@summary.LowCount</span></td>
                                            <td class="text-center"><span class="badge badge-light">@(summary.TotalProjects - summary.CriticalCount - summary.HighCount - summary.MediumCount - summary.LowCount)</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted">No business area data available</div>
                    }
                </div>
            </div>
        }

        <!-- Month-over-Month Trends -->
        @if (!string.IsNullOrEmpty(prevMonthName))
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-white">
                    <h3 class="card-title mb-0">Month-over-Month Trends</h3>
                    <div class="card-tools">
                        <small class="text-muted">Comparing @monthName to @prevMonthName</small>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <div class="text-center p-3" style="border: 1px solid #dee2e6; border-radius: 0.375rem;">
                                <div class="text-muted mb-1" style="font-size: 0.875rem;">Total Projects</div>
                                <div class="h4 mb-1">@totalActiveProjects</div>
                                @{
                                    var projectChange = totalActiveProjects - prevMonthTotalProjects;
                                    var projectChangePct = prevMonthTotalProjects > 0 ? (projectChange * 100.0 / prevMonthTotalProjects) : 0;
                                }
                                @if (projectChange != 0)
                                {
                                    <div class="@(projectChange > 0 ? "text-success" : "text-danger")" style="font-size: 0.875rem;">
                                        @if (projectChange > 0)
                                        {
                                            <span>↑ +@projectChange</span>
                                        }
                                        else
                                        {
                                            <span>↓ @projectChange</span>
                                        }
                                        (@(projectChangePct > 0 ? "+" : "")@projectChangePct.ToString("F1")%)
                                    </div>
                                }
                                else
                                {
                                    <div class="text-muted" style="font-size: 0.875rem;">No change</div>
                                }
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center p-3" style="border: 1px solid #dee2e6; border-radius: 0.375rem;">
                                <div class="text-muted mb-1" style="font-size: 0.875rem;">New Projects</div>
                                <div class="h4 mb-1">@newProjectsThisMonth.Count</div>
                                @{
                                    var newProjectsChange = newProjectsThisMonth.Count - prevMonthNewProjects;
                                }
                                @if (newProjectsChange != 0)
                                {
                                    <div class="@(newProjectsChange > 0 ? "text-success" : "text-danger")" style="font-size: 0.875rem;">
                                        @if (newProjectsChange > 0)
                                        {
                                            <span>↑ +@newProjectsChange</span>
                                        }
                                        else
                                        {
                                            <span>↓ @newProjectsChange</span>
                                        }
                                        (@(prevMonthNewProjects > 0 ? ((newProjectsChange * 100.0 / prevMonthNewProjects).ToString("F1")) : "N/A")%)
                                    </div>
                                }
                                else
                                {
                                    <div class="text-muted" style="font-size: 0.875rem;">No change</div>
                                }
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center p-3" style="border: 1px solid #dee2e6; border-radius: 0.375rem;">
                                <div class="text-muted mb-1" style="font-size: 0.875rem;">Milestones Achieved</div>
                                <div class="h4 mb-1">@milestonesAchieved.Count</div>
                                @{
                                    var milestonesChange = milestonesAchieved.Count - prevMonthMilestonesAchieved;
                                }
                                @if (milestonesChange != 0)
                                {
                                    <div class="@(milestonesChange > 0 ? "text-success" : "text-danger")" style="font-size: 0.875rem;">
                                        @if (milestonesChange > 0)
                                        {
                                            <span>↑ +@milestonesChange</span>
                                        }
                                        else
                                        {
                                            <span>↓ @milestonesChange</span>
                                        }
                                        (@(prevMonthMilestonesAchieved > 0 ? ((milestonesChange * 100.0 / prevMonthMilestonesAchieved).ToString("F1")) : "N/A")%)
                                    </div>
                                }
                                else
                                {
                                    <div class="text-muted" style="font-size: 0.875rem;">No change</div>
                                }
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="text-center p-3" style="border: 1px solid #dee2e6; border-radius: 0.375rem;">
                                <div class="text-muted mb-1" style="font-size: 0.875rem;">Reports Submitted</div>
                                <div class="h4 mb-1">@(monthlyUpdateStats?.Submitted ?? 0)</div>
                                @if (prevMonthUpdateStats != null)
                                {
                                    var submittedChange = (monthlyUpdateStats?.Submitted ?? 0) - prevMonthUpdateStats.Submitted;
                                    var submittedChangePct = prevMonthUpdateStats.Submitted > 0 ? (submittedChange * 100.0 / prevMonthUpdateStats.Submitted) : 0;
                                    @if (submittedChange != 0)
                                    {
                                        <div class="@(submittedChange > 0 ? "text-success" : "text-danger")" style="font-size: 0.875rem;">
                                            @if (submittedChange > 0)
                                            {
                                                <span>↑ +@submittedChange</span>
                                            }
                                            else
                                            {
                                                <span>↓ @submittedChange</span>
                                            }
                                            (@(submittedChangePct > 0 ? "+" : "")@submittedChangePct.ToString("F1")%)
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-muted" style="font-size: 0.875rem;">No change</div>
                                    }
                                }
                                else
                                {
                                    <div class="text-muted" style="font-size: 0.875rem;">No previous data</div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Flagship Projects Spotlight -->
        @if (flagshipProjects.Any())
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-white">
                    <h3 class="card-title mb-0">Flagship Projects</h3>
                    <div class="card-tools">
                        <span class="badge badge-primary">@flagshipProjects.Count</span>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Project</th>
                                    <th>Business Area</th>
                                    <th>RAG Status</th>
                                    <th>Priority</th>
                                    <th>Status</th>
                                    <th>Primary Contact</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var project in flagshipProjects)
                                {
                                    var ragStatusRaw = project.RagStatusLookup?.Name ?? project.RagStatus ?? "";
                                    var currentRag = ragStatusRaw;
                                    if (!string.IsNullOrWhiteSpace(ragStatusRaw))
                                    {
                                        var ragLower = ragStatusRaw.ToLower();
                                        if (ragLower.Contains("red") && ragLower.Contains("amber")) currentRag = "Amber-Red";
                                        else if (ragLower.Contains("amber") && ragLower.Contains("green")) currentRag = "Amber-Green";
                                        else if (ragLower.Contains("red")) currentRag = "Red";
                                        else if (ragLower.Contains("amber")) currentRag = "Amber";
                                        else if (ragLower.Contains("green")) currentRag = "Green";
                                    }
                                    else
                                    {
                                        currentRag = "Not Set";
                                    }
                                    var ragBadgeClass = currentRag switch {
                                        "Red" => "badge-danger",
                                        "Amber-Red" => "badge",
                                        "Amber" => "badge-warning",
                                        "Amber-Green" => "badge",
                                        "Green" => "badge-success",
                                        _ => "badge-secondary"
                                    };
                                    var ragBadgeStyle = currentRag switch {
                                        "Amber-Red" => "background-color: #fd7e14;",
                                        "Amber-Green" => "background-color: #ffeb3b; color: #000;",
                                        _ => ""
                                    };
                                    var priorityName = project.DeliveryPriority?.Name ?? "Not Set";
                                    var priorityBadgeClass = priorityName.ToLower() switch {
                                        var p when p.Contains("critical") => "badge-danger",
                                        var p when p.Contains("high") => "badge-warning",
                                        var p when p.Contains("medium") => "badge-info",
                                        var p when p.Contains("low") => "badge-secondary",
                                        _ => "badge-light"
                                    };
                                    <tr>
                                        <td>
                                            <a asp-controller="Project" asp-action="Details" asp-route-id="@project.Id" style="color: #005ea5; text-decoration: none; font-weight: 600;">
                                                @project.Title
                                            </a>
                                            <br />
                                            <small class="text-muted">DFE-DDT-@project.Id</small>
                                        </td>
                                        <td>@(project.BusinessAreaLookup?.Name ?? "-")</td>
                                        <td>
                                            <span class="badge @ragBadgeClass" style="@ragBadgeStyle">@currentRag</span>
                                        </td>
                                        <td>
                                            <span class="badge @priorityBadgeClass">@priorityName</span>
                                        </td>
                                        <td>@project.Status</td>
                                        <td>@(project.PrimaryContactUser?.Name ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- Resource Summary -->
        @if (totalFte > 0 || resourceByBusinessArea.Any())
