                                                               data-business-area-name="@item.BusinessAreaName"
                                                               data-project-count="@item.ProjectCount"
                                                               data-total-perm-fte="@item.TotalPermFte.ToString("F1")"
                                                               data-total-msp-fte="@item.TotalMspFte.ToString("F1")"
                                                               data-total-fte="@item.TotalFte.ToString("F1")"
