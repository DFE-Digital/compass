                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card shadow-sm">
                    <div class="card-header bg-white">
                        <h3 class="card-title mb-0">Late Milestones</h3>
                        <div class="card-tools">
                            <button type="button" class="btn btn-tool" data-card-widget="collapse">
                                <i class="fas fa-minus" aria-hidden="true"></i>
                                <span class="sr-only">Toggle late milestones</span>
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        @if (lateMilestones.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Milestone</th>
                                            <th>Project</th>
                                            <th>Due Date</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in lateMilestones)
                                        {
                                            <tr>
                                                <td>
                                                    <a href="#" class="milestone-link" data-milestone-id="@item.Milestone.Id" data-milestone-name="@item.Milestone.Name" data-project-id="@item.Project.Id" data-project-title="@item.Project.Title" data-date="@item.Milestone.DueDate.ToString("dd MMM yyyy")" data-primary-contact="@(item.Project.PrimaryContactUser?.Name ?? "-")" style="color: #005ea5; text-decoration: none; font-weight: 600; cursor: pointer;">
                                                        @item.Milestone.Name
                                                    </a>
                                                </td>
                                                <td>@item.Project.Title</td>
                                                <td>@item.Milestone.DueDate.ToString("dd MMM yyyy")</td>
                                            </tr>
                                        }
