@{
    ViewData["Title"] = "Central Operations - All Work";
    var allProjects = ViewBag.AllProjects as List<Compass.Models.Project> ?? new List<Compass.Models.Project>();
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="CentralOps" asp-action="Summary" style="color: #005ea5; text-decoration: none;">Central Operations</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">All Work</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        @await Html.PartialAsync("_CentralOpsNavigation")

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <!-- All Work Items -->
        <div class="dashboard-section">
            <div class="dashboard-section-header">
                <h2><i class="fas fa-tasks"></i> All Work Items</h2>
                <div>
                    <button type="button" 
                            id="exportAllWorkBtn"
                            class="btn btn-sm btn-outline-primary"
                            data-search="@ViewBag.CurrentSearch"
                            data-rag-status="@ViewBag.CurrentRagStatus"
                            data-business-area="@ViewBag.CurrentBusinessArea"
                            data-phase="@ViewBag.CurrentPhase"
                            data-flagship="@ViewBag.CurrentFlagship"
                            data-priority="@ViewBag.CurrentPriority">
                        <i class="fas fa-file-excel"></i> Export to Excel
                    </button>
                </div>
            </div>
            
            <div class="row">
                <!-- Left Column: Filters -->
                <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                    <!-- Filters -->
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Filters</h3>
                        </div>
                        <div class="card-body">
                            @{
                                var deliveryPriorities = ViewBag.DeliveryPriorities as IEnumerable<Compass.Models.DeliveryPriority> ?? Array.Empty<Compass.Models.DeliveryPriority>();
                                var currentPriorityId = ViewBag.CurrentPriority as int?;
                            }
                            <form method="get" id="filterForm">
                                <div class="form-group">
                                    <label>Search</label>
                                    <input type="text" name="search" class="form-control form-control-sm" placeholder="Search work items..." value="@ViewBag.CurrentSearch" />
                                </div>

                                <div class="form-group">
                                    <label for="ragStatus">RAG Status</label>
                                    <select name="ragStatus" id="ragStatus" class="form-control form-control-sm">
                                        <option value="">All</option>
                                        @if (ViewBag.CurrentRagStatus == "Green")
                                        {
                                            <option value="Green" selected>Green</option>
                                        }
                                        else
                                        {
                                            <option value="Green">Green</option>
                                        }
                                        @if (ViewBag.CurrentRagStatus == "Amber-Green")
                                        {
                                            <option value="Amber-Green" selected>Amber-Green</option>
                                        }
                                        else
                                        {
                                            <option value="Amber-Green">Amber-Green</option>
                                        }
                                        @if (ViewBag.CurrentRagStatus == "Amber")
                                        {
                                            <option value="Amber" selected>Amber</option>
                                        }
                                        else
                                        {
                                            <option value="Amber">Amber</option>
                                        }
                                        @if (ViewBag.CurrentRagStatus == "Amber-Red")
                                        {
                                            <option value="Amber-Red" selected>Amber-Red</option>
                                        }
                                        else
                                        {
                                            <option value="Amber-Red">Amber-Red</option>
                                        }
                                        @if (ViewBag.CurrentRagStatus == "Red")
                                        {
                                            <option value="Red" selected>Red</option>
                                        }
                                        else
                                        {
                                            <option value="Red">Red</option>
                                        }
                                        @if (ViewBag.CurrentRagStatus == "Not set" || (ViewBag.CurrentRagStatus == null && ViewBag.CurrentRagStatus == ""))
                                        {
                                            <option value="" selected>Not set</option>
                                        }
                                        else
                                        {
                                            <option value="">Not set</option>
                                        }
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label for="businessArea">Business Area</label>
                                    <select name="businessArea" id="businessArea" class="form-control form-control-sm">
                                        <option value="">All</option>
                                        @if (ViewBag.BusinessAreas != null)
                                        {
                                            @foreach (var ba in ViewBag.BusinessAreas)
                                            {
                                                @if (ViewBag.CurrentBusinessArea == ba)
                                                {
                                                    <option value="@ba" selected>@ba</option>
                                                }
                                                else
                                                {
                                                    <option value="@ba">@ba</option>
                                                }
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label for="phase">Phase</label>
                                    <select name="phase" id="phase" class="form-control form-control-sm">
                                        <option value="">All</option>
                                        @if (ViewBag.Phases != null)
                                        {
                                            @foreach (var phase in ViewBag.Phases)
                                            {
                                                @if (ViewBag.CurrentPhase == phase)
                                                {
                                                    <option value="@phase" selected>@phase</option>
                                                }
                                                else
                                                {
                                                    <option value="@phase">@phase</option>
                                                }
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label for="flagship">Flagship</label>
                                    <select name="flagship" id="flagship" class="form-control form-control-sm">
                                        <option value="">All</option>
                                        @if (ViewBag.CurrentFlagship == "true")
                                        {
                                            <option value="true" selected>Yes</option>
                                        }
                                        else
                                        {
                                            <option value="true">Yes</option>
                                        }
                                        @if (ViewBag.CurrentFlagship == "false")
                                        {
                                            <option value="false" selected>No</option>
                                        }
                                        else
                                        {
                                            <option value="false">No</option>
                                        }
                                    </select>
                                </div>

                                <div class="form-group">
                                    <label for="priority">Priority</label>
                                    <select name="priority" id="priority" class="form-control form-control-sm">
                                        <option value="">All</option>
                                        @foreach (var priorityOption in deliveryPriorities)
                                        {
                                            if (currentPriorityId == priorityOption.Id)
                                            {
                                                <option value="@priorityOption.Id" selected="selected">@priorityOption.Name</option>
                                            }
                                            else
                                            {
                                                <option value="@priorityOption.Id">@priorityOption.Name</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="form-group">
                                    <button type="submit" class="btn btn-primary btn-sm btn-block">Apply filters</button>
                                    <a asp-action="AllWork" asp-route-clearFilters="true" class="btn btn-default btn-sm btn-block">Clear all filters</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Right Column: Table -->
                <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                    <div class="card">
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0 sortable-table">
                        <thead>
                            <tr>
                                <th style="width: 250px;" class="sortable" data-column="Title" tabindex="0" role="button" aria-label="Sort by Title">Title</th>
                                <th style="width: 100px;" class="sortable" data-column="Priority" tabindex="0" role="button" aria-label="Sort by Priority">Priority</th>
                                <th style="width: 120px;" class="sortable" data-column="Rag" tabindex="0" role="button" aria-label="Sort by RAG">RAG</th>
                                <th style="width: 150px;" class="sortable" data-column="BusinessArea" tabindex="0" role="button" aria-label="Sort by Business Area">Business Area</th>
                                <th style="width: 150px;" class="sortable" data-column="PrimaryContact" tabindex="0" role="button" aria-label="Sort by Primary Contact">Primary Contact</th>
                                <th style="width: 200px;" class="sortable" data-column="ServiceOwner" tabindex="0" role="button" aria-label="Sort by Service Owner">Service Owner</th>
                                <th style="width: 100px;" class="sortable" data-column="Flagship" tabindex="0" role="button" aria-label="Sort by Flagship">Flagship</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (allProjects != null && allProjects.Any())
                            {
                                @foreach (var item in allProjects)
                                {
                                    <tr>
                                        <td>
                                            <a asp-controller="Project" asp-action="Details" asp-route-id="@item.Id" style="font-weight: bold; color: #005ea5; text-decoration: none;">@item.Title</a>
                                            <br />
                                            <small class="text-muted">DFE-DDT-@item.Id</small>
                                        </td>
                                        <td>
                                            @if (item.DeliveryPriority != null && !string.IsNullOrEmpty(item.DeliveryPriority.Name))
                                            {
                                                var priorityClass = item.DeliveryPriority.Name.ToLower() switch {
                                                    var p when p.Contains("critical") => "badge-danger",
                                                    var p when p.Contains("high") => "badge-danger",
                                                    var p when p.Contains("medium") => "badge-warning",
                                                    var p when p.Contains("low") => "badge-secondary",
                                                    _ => "badge-secondary"
                                                };
                                                <span class="badge @priorityClass">@item.DeliveryPriority.Name</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.RagStatus))
                                            {
                                                var normalized = item.RagStatus.Trim()
                                                    .Replace(" / ", "-")
                                                    .Replace("/", "-")
                                                    .Replace(" /", "-")
                                                    .Replace("/ ", "-");
                                                
                                                // Capitalize first letter of each word for consistency
                                                var parts = normalized.Split('-');
                                                for (int i = 0; i < parts.Length; i++)
                                                {
                                                    if (parts[i].Length > 0)
                                                    {
                                                        parts[i] = char.ToUpperInvariant(parts[i][0]) + (parts[i].Length > 1 ? parts[i].Substring(1).ToLowerInvariant() : "");
                                                    }
                                                }
                                                var displayRagStatus = string.Join("-", parts);
                                                
                                                var ragClass = displayRagStatus switch {
                                                    "Red" => "badge badge-red",
                                                    "Amber-Red" => "badge badge-amber-red",
                                                    "Amber" => "badge badge-amber",
                                                    "Amber-Green" => "badge badge-amber-green",
                                                    "Green" => "badge badge-green",
                                                    _ => "badge badge-secondary"
                                                };
                                                <span class="@ragClass">@displayRagStatus</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>@(item.BusinessAreaLookup?.Name ?? "-")</td>
                                        <td>
                                            @if (item.PrimaryContactUser != null)
                                            {
                                                @item.PrimaryContactUser.Name
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.ServiceOwners != null && item.ServiceOwners.Any())
                                            {
                                                var serviceOwners = item.ServiceOwners.Where(so => so.User != null).Take(2).ToList();
                                                @foreach (var so in serviceOwners)
                                                {
                                                    <div>@so.User.Name</div>
                                                }
                                                @if (item.ServiceOwners.Count > 2)
                                                {
                                                    <small class="text-muted">+ @(item.ServiceOwners.Count - 2) more</small>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.IsFlagship)
                                            {
                                                <span class="badge badge-info">Yes</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">No</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-3">No work items found</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Export Progress Modal -->
<div class="modal fade" id="exportProgressModal" tabindex="-1" role="dialog" aria-labelledby="exportProgressModalLabel" aria-hidden="true" data-backdrop="static" data-keyboard="false">
    <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exportProgressModalLabel">
                    <i class="fas fa-file-excel"></i> Exporting to Excel
                </h5>
            </div>
            <div class="modal-body">
                <div class="text-center">
                    <div class="mb-3">
                        <i class="fas fa-spinner fa-spin" style="font-size: 3rem; color: #005ea5;"></i>
                    </div>
                    <p id="exportProgressText" class="mb-2">Preparing export...</p>
                    <div class="progress mt-3" style="height: 25px;">
                        <div id="exportProgressBar" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%">
                            <span id="exportProgressPercent">0%</span>
                        </div>
                    </div>
                    <p class="text-muted mt-3 mb-0" style="font-size: 0.9rem;">
                        <i class="fas fa-info-circle"></i> The file will be saved to your Downloads folder
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Initialize sortable tables
            $('.sortable-table').each(function() {
                initializeSortableTable($(this));
            });

            // Handle export button click
            $('#exportAllWorkBtn').on('click', function() {
                var $btn = $(this);
                var search = $btn.data('search') || '';
                var ragStatus = $btn.data('rag-status') || '';
                var businessArea = $btn.data('business-area') || '';
                var phase = $btn.data('phase') || '';
                var flagship = $btn.data('flagship') || '';
                var priority = $btn.data('priority') || '';

                // Build URL
                var url = '@Url.Action("ExportAllWork", "CentralOps")';
                var params = [];
                if (search) params.push('search=' + encodeURIComponent(search));
                if (ragStatus) params.push('ragStatus=' + encodeURIComponent(ragStatus));
                if (businessArea) params.push('businessArea=' + encodeURIComponent(businessArea));
                if (phase) params.push('phase=' + encodeURIComponent(phase));
                if (flagship) params.push('flagship=' + encodeURIComponent(flagship));
                if (priority) params.push('priority=' + encodeURIComponent(priority));
                
                if (params.length > 0) {
                    url += '?' + params.join('&');
                }

                // Show modal
                $('#exportProgressModal').modal('show');
                updateExportProgress(10, 'Fetching project data...');

                // Use fetch to download the file and track progress
                fetch(url)
                    .then(function(response) {
                        if (!response.ok) {
                            throw new Error('Export failed');
                        }
                        updateExportProgress(30, 'Processing projects...');
                        return response.blob();
                    })
                    .then(function(blob) {
                        updateExportProgress(60, 'Building Excel file...');
                        
                        // Create a blob URL and download
                        var blobUrl = window.URL.createObjectURL(blob);
                        var link = document.createElement('a');
                        link.href = blobUrl;
                        link.download = 'all-work-export-' + new Date().toISOString().slice(0,10) + '.xlsx';
                        document.body.appendChild(link);
                        
                        updateExportProgress(90, 'Downloading file...');
                        
                        // Trigger download
                        link.click();
                        
                        // Clean up
                        document.body.removeChild(link);
                        window.URL.revokeObjectURL(blobUrl);
                        
                        // Wait a moment for the download to start, then close modal
                        setTimeout(function() {
                            updateExportProgress(100, 'Download complete!');
                            setTimeout(function() {
                                $('#exportProgressModal').modal('hide');
                                resetExportProgress();
                            }, 1000);
                        }, 500);
                    })
                    .catch(function(error) {
                        console.error('Export error:', error);
                        $('#exportProgressText').html('<span class="text-danger">Error: ' + error.message + '</span>');
                        setTimeout(function() {
                            $('#exportProgressModal').modal('hide');
                            resetExportProgress();
                        }, 3000);
                    });
            });

            function updateExportProgress(percent, text) {
                $('#exportProgressBar').css('width', percent + '%');
                $('#exportProgressPercent').text(percent + '%');
                $('#exportProgressText').text(text);
            }

            function resetExportProgress() {
                $('#exportProgressBar').css('width', '0%');
                $('#exportProgressPercent').text('0%');
                $('#exportProgressText').text('Preparing export...');
            }

            // Reset progress when modal is hidden
            $('#exportProgressModal').on('hidden.bs.modal', function() {
                resetExportProgress();
            });
        });

        function initializeSortableTable(table) {
            var currentSort = { column: null, direction: 'asc' };

            table.find('.sortable').on('click keypress', function(e) {
                if (e.type === 'keypress' && e.which !== 13 && e.which !== 32) {
                    return;
                }
                
                var column = $(this).data('column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(table, column, direction);
                currentSort = { column: column, direction: direction };
            });

            function sortTable(table, column, direction) {
                var tbody = table.find('tbody');
                var rows = tbody.find('tr').toArray();
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var colIndex = table.find('thead th[data-column="' + column + '"]').index();
                    
                    if (column === 'Flagship') {
                        var aText = $(a).find('td').eq(colIndex).text().trim().toLowerCase();
                        var bText = $(b).find('td').eq(colIndex).text().trim().toLowerCase();
                        aVal = aText === 'yes' ? 1 : 0;
                        bVal = bText === 'yes' ? 1 : 0;
                    } else {
                        aVal = $(a).find('td').eq(colIndex).text().trim().toLowerCase();
                        bVal = $(b).find('td').eq(colIndex).text().trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.empty();
                rows.forEach(function(row) {
                    tbody.append(row);
                });
                
                updateSortIcons(table, column, direction);
            }

            function updateSortIcons(table, column, direction) {
                table.find('.sortable i').remove();
                var header = table.find('.sortable[data-column="' + column + '"]');
                var iconClass = direction === 'asc' ? 'fa-sort-up' : 'fa-sort-down';
                header.append(' <i class="fas ' + iconClass + '"></i>');
            }
        }
    </script>
}

