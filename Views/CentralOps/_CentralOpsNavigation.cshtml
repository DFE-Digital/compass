@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    ViewBag.BrandText = "Central Operations";
    var navLinks = new List<object>
    {
        new { Text = "Summary overview", Action = "Summary", Controller = "CentralOps", Url = (string)null, IsButton = false, IsActive = currentAction == "Summary" },
        new { Text = "Monthly reporting", Action = "MonthlyReporting", Controller = "CentralOps", Url = (string)null, IsButton = false, IsActive = currentAction == "MonthlyReporting" },
        new { Text = "Performance reporting", Action = "PerformanceReporting", Controller = "CentralOps", Url = (string)null, IsButton = false, IsActive = currentAction == "PerformanceReporting" },
        new { Text = "RAG and Risk", Action = "RagAndRisk", Controller = "CentralOps", Url = (string)null, IsButton = false, IsActive = currentAction == "RagAndRisk" },
        new { Text = "All work", Action = "AllWork", Controller = "CentralOps", Url = (string)null, IsButton = false, IsActive = currentAction == "AllWork" }
    };
    
    // Add view switching options
    if (currentAction == "MonthlySummary")
    {
        // On old view, add link to new view
        var year = ViewBag.Year as int? ?? DateTime.UtcNow.Year;
        var month = ViewBag.Month as int? ?? DateTime.UtcNow.Month;
        var businessAreaId = ViewBag.BusinessAreaId as int?;
        object routeValues;
        if (businessAreaId.HasValue)
        {
            routeValues = new { year = year, month = month, businessAreaId = businessAreaId.Value };
        }
        else
        {
            routeValues = new { year = year, month = month };
        }
        navLinks.Add(new { 
            Text = "Try new view", 
            Action = "MonthlySummaryV2", 
            Controller = "CentralOps", 
            Url = (string)null, 
            RouteValues = routeValues,
            IsButton = true, 
            IsActive = false 
        });
    }
    else if (currentAction == "MonthlySummaryV2")
    {
        // On new view, add link back to old view
        var year = ViewBag.Year as int? ?? DateTime.UtcNow.Year;
        var month = ViewBag.Month as int? ?? DateTime.UtcNow.Month;
        var businessAreaId = ViewBag.BusinessAreaId as int?;
        object routeValues;
        if (businessAreaId.HasValue)
        {
            routeValues = new { year = year, month = month, businessAreaId = businessAreaId.Value };
        }
        else
        {
            routeValues = new { year = year, month = month };
        }
        navLinks.Add(new { 
            Text = "Back to old view", 
            Action = "MonthlySummary", 
            Controller = "CentralOps", 
            Url = (string)null, 
            RouteValues = routeValues,
            IsButton = true, 
            IsActive = false 
        });
    }
    
    ViewBag.NavLinks = navLinks;
}
@await Html.PartialAsync("_ModuleNavbar")

