@using Compass.Controllers
@{
    ViewData["Title"] = "Monthly Update Status";
    var filteredProjects = ViewBag.FilteredProjects as List<Compass.Models.Project> ?? new List<Compass.Models.Project>();
    var businessAreaStats = ViewBag.BusinessAreaStats as List<BusinessAreaMonthlyUpdateStats> ?? new List<BusinessAreaMonthlyUpdateStats>();
    var year = ViewBag.Year as int? ?? 0;
    var month = ViewBag.Month as int? ?? 0;
    var status = ViewBag.Status as string ?? "";
    var monthName = ViewBag.MonthName as string ?? "";
    var dueDate = ViewBag.DueDate as DateTime? ?? DateTime.UtcNow;
    var previousMonthName = ViewBag.PreviousMonthName as string ?? "";
    var currentMonthName = ViewBag.CurrentMonthName as string ?? "";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="CentralOps" asp-action="Dashboard" style="color: #005ea5; text-decoration: none;">Central Operations</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="CentralOps" asp-action="Dashboard" style="color: #005ea5; text-decoration: none;">Dashboard</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Monthly Update Status</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Monthly Update Status - @monthName</h1>
                <p class="text-muted">Status: <span class="badge badge-@(status == "Submitted" ? "success" : status == "Late" ? "danger" : status == "In Progress" ? "warning" : "secondary")">@status</span></p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <!-- Projects with this status -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Projects - @status (@filteredProjects.Count)</h3>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 250px;">Title</th>
                                    <th style="width: 100px;">Priority</th>
                                    <th style="width: 120px;">RAG</th>
                                    <th style="width: 150px;">Business Area</th>
                                    <th style="width: 150px;">Primary Contact</th>
                                    <th style="width: 200px;">Service Owner</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (filteredProjects != null && filteredProjects.Any())
                                {
                                    @foreach (var project in filteredProjects)
                                    {
                                        <tr>
                                            <td>
                                                <a asp-controller="Project" asp-action="Details" asp-route-id="@project.Id" style="font-weight: bold; color: #005ea5; text-decoration: none;">@project.Title</a>
                                                <br />
                                                <small class="text-muted">DFE-DDT-@project.Id</small>
                                            </td>
                                            <td>
                                                @if (project.DeliveryPriority != null && !string.IsNullOrEmpty(project.DeliveryPriority.Name))
                                                {
                                                    var priorityClass = project.DeliveryPriority.Name.ToLower() switch {
                                                        var p when p.Contains("critical") => "badge-danger",
                                                        var p when p.Contains("high") => "badge-danger",
                                                        var p when p.Contains("medium") => "badge-warning",
                                                        var p when p.Contains("low") => "badge-secondary",
                                                        _ => "badge-secondary"
                                                    };
                                                    <span class="badge @priorityClass">@project.DeliveryPriority.Name</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(project.RagStatus))
                                                {
                                                    var normalized = project.RagStatus.Trim()
                                                        .Replace(" / ", "-")
                                                        .Replace("/", "-")
                                                        .Replace(" /", "-")
                                                        .Replace("/ ", "-");
                                                    
                                                    var ragClass = normalized switch {
                                                        "Red" => "badge badge-red",
                                                        "Amber-Red" => "badge badge-amber-red",
                                                        "Amber" => "badge badge-amber",
                                                        "Amber-Green" => "badge badge-amber-green",
                                                        "Green" => "badge badge-green",
                                                        _ => "badge badge-secondary"
                                                    };
                                                    <span class="@ragClass">@project.RagStatus</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>@(project.BusinessAreaLookup?.Name ?? "-")</td>
                                            <td>
                                                @if (project.PrimaryContactUser != null)
                                                {
                                                    @project.PrimaryContactUser.Name
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (project.ServiceOwners != null && project.ServiceOwners.Any())
                                                {
                                                    var serviceOwners = project.ServiceOwners.Where(so => so.User != null).Take(2).ToList();
                                                    @foreach (var so in serviceOwners)
                                                    {
                                                        <div>@so.User.Name</div>
                                                    }
                                                    @if (project.ServiceOwners.Count > 2)
                                                    {
                                                        <small class="text-muted">+ @(project.ServiceOwners.Count - 2) more</small>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-3">No projects found with this status</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Business Area Completion Summary -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Summary by Business Area - Monthly Update Completion</h3>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th rowspan="2" style="border-right: 2px solid #dee2e6;">Business Area</th>
                                    <th rowspan="2" style="width: 70px; text-align: center; border-right: 2px solid #dee2e6;">Total Projects</th>
                                    <th colspan="2" style="text-align: center; background-color: #f4f8fb; font-weight: 600; border-right: 2px solid #dee2e6;">Reporting</th>
                                </tr>
                                <tr>
                                    <th style="width: 100px; text-align: center; border-right: 1px solid #dee2e6;">@previousMonthName</th>
                                    <th style="width: 100px; text-align: center;">@currentMonthName</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (businessAreaStats != null && businessAreaStats.Any())
                                {
                                    @foreach (var stat in businessAreaStats)
                                    {
                                        <tr>
                                            <td style="border-right: 2px solid #dee2e6;">
                                                <strong>@stat.BusinessArea</strong>
                                            </td>
                                            <td style="text-align: center; border-right: 2px solid #dee2e6;">@stat.TotalProjects</td>
                                            <td style="text-align: center; border-right: 1px solid #dee2e6;">
                                                @stat.PreviousMonthSubmitted / @stat.TotalProjects
                                                <br />
                                                <span class="badge @(stat.PreviousMonthSubmittedPercent >= 100 ? "badge-success" : stat.PreviousMonthSubmittedPercent >= 80 ? "badge-warning" : "badge-danger")">
                                                    @stat.PreviousMonthSubmittedPercent.ToString("F1")%
                                                </span>
                                            </td>
                                            <td style="text-align: center;">
                                                @stat.CurrentMonthSubmitted / @stat.TotalProjects
                                                <br />
                                                <span class="badge @(stat.CurrentMonthSubmittedPercent >= 100 ? "badge-success" : stat.CurrentMonthSubmittedPercent >= 80 ? "badge-warning" : "badge-danger")">
                                                    @stat.CurrentMonthSubmittedPercent.ToString("F1")%
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-3">No business area data available</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

