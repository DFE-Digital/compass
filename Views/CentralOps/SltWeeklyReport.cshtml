@model Compass.ViewModels.SltWeeklyReportViewModel

@{
    ViewData["Title"] = "SLT Weekly Report";
    
    // Helper function to create a safe ID from business area name
    Func<string, string> GetSafeId = (name) =>
    {
        if (string.IsNullOrWhiteSpace(name))
            return "not-assigned";
        
        return System.Text.RegularExpressions.Regex.Replace(
            name, 
            @"[^a-zA-Z0-9\-]", 
            "-"
        ).ToLowerInvariant();
    };
    
    // Helper function to format name for display: "Firstname LASTNAME"
    Func<string, string> FormatNameForDisplay = (name) =>
    {
        if (string.IsNullOrWhiteSpace(name))
            return "Unknown";
        
        // Handle "LASTNAME, Firstname" format
        var parts = name.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 2)
        {
            return $"{parts[1]} {parts[0].ToUpperInvariant()}";
        }
        
        // If already in "Firstname Lastname" format, uppercase the last word
        var words = name.Trim().Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
        if (words.Length >= 2)
        {
            var firstName = string.Join(" ", words.Take(words.Length - 1));
            var lastName = words.Last().ToUpperInvariant();
            return $"{firstName} {lastName}";
        }
        
        return name.Trim();
    };
}

@Html.AntiForgeryToken()

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <h1 class="m-0">SLT Weekly Report</h1>
                <p class="text-muted mb-0">
                    @Model.WeekStartDate.ToString("dd MMMM") to @Model.WeekEndDate.ToString("dd MMMM yyyy")
                    <br />
                    Week @Model.WeekNumber, @Model.Year
                </p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <!-- Week Navigation -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                @if (Model.HasPreviousWeek)
                                {
                                    <a href="@Url.Action("SltWeeklyReport", "CentralOps", new { year = Model.PreviousWeekYear, week = Model.PreviousWeekNumber })" 
                                       class="btn btn-outline-primary">
                                        <i class="fas fa-chevron-left mr-2"></i>Previous Week
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-outline-secondary" disabled>
                                        <i class="fas fa-chevron-left mr-2"></i>Previous Week
                                    </button>
                                }
                            </div>
                            <div class="text-center">
                                <h4 class="mb-0">
                                    @Model.WeekStartDate.ToString("dd MMMM") to @Model.WeekEndDate.ToString("dd MMMM yyyy")
                                </h4>
                                <small class="text-muted">
                                    Week @Model.WeekNumber, @Model.Year
                                </small>
                            </div>
                            <div>
                                @if (Model.HasNextWeek)
                                {
                                    <a href="@Url.Action("SltWeeklyReport", "CentralOps", new { year = Model.NextWeekYear, week = Model.NextWeekNumber })" 
                                       class="btn btn-outline-primary">
                                        Next Week<i class="fas fa-chevron-right ml-2"></i>
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-outline-secondary" disabled>
                                        Next Week<i class="fas fa-chevron-right ml-2"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Successes Section -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0" style="font-size: 1rem; font-weight: 600;">Successes Reported to SLT</h5>
                        @if (Model.BusinessAreaGroups != null && Model.BusinessAreaGroups.Any())
                        {
                            <div class="card-tools">
                                <a href="#" class="btn btn-sm btn-link text-primary" id="expandAllBusinessAreas" style="text-decoration: none;">
                                    <i class="fas fa-chevron-down mr-1"></i>Expand all
                                </a>
                                <a href="#" class="btn btn-sm btn-link text-primary d-none" id="collapseAllBusinessAreas" style="text-decoration: none;">
                                    <i class="fas fa-chevron-up mr-1"></i>Collapse all
                                </a>
                            </div>
                        }
                    </div>
                    <div class="card-body p-0">
                        @if (Model.BusinessAreaGroups != null && Model.BusinessAreaGroups.Any())
                        {
                            @foreach (var businessArea in Model.BusinessAreaGroups)
                            {
                                var safeAreaId = GetSafeId(businessArea.BusinessAreaName);
                                var hasUpdates = businessArea.UpdateCount > 0;
                                <div class="business-area-card" style="border-top: 1px solid #dee2e6;">
                                    <div class="card-header bg-light business-area-header" style="cursor: pointer;" 
                                         data-area-id="@safeAreaId"
                                         data-toggle="collapse" 
                                         data-target="#ba-@safeAreaId"
                                         aria-expanded="false"
                                         aria-controls="ba-@safeAreaId">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <h6 class="mb-0" style="font-size: 0.95rem; font-weight: 600;">
                                                <i class="fas fa-chevron-down toggle-icon mr-2" style="font-size: 0.85rem;"></i>
                                                @businessArea.BusinessAreaName
                                            </h6>
                                            @if (hasUpdates)
                                            {
                                                <span class="badge badge-success" style="font-size: 0.75rem; padding: 0.25rem 0.5rem;">@businessArea.UpdateCount update@(businessArea.UpdateCount != 1 ? "s" : "")</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-warning" style="font-size: 0.75rem; padding: 0.25rem 0.5rem;">No Updates</span>
                                            }
                                        </div>
                                    </div>
                                    <div id="ba-@safeAreaId" 
                                         class="collapse">
                                        <div class="card-body p-3">
                                            @if (hasUpdates)
                                            {
                                                @foreach (var projectGroup in businessArea.ProjectGroups)
                                                {
                                                <div class="project-thread mb-4" style="border-left: 3px solid #005ea5; padding-left: 1rem;">
                                                    <div class="project-header mb-3">
                                                        <h6 class="mb-1" style="font-size: 0.95rem; font-weight: 600;">
                                                            <a asp-controller="Project" 
                                                               asp-action="Details" 
                                                               asp-route-id="@projectGroup.ProjectId"
                                                               style="color: #005ea5; text-decoration: none; font-weight: 600;">
                                                                @projectGroup.ProjectTitle
                                                            </a>
                                                            @if (!string.IsNullOrEmpty(projectGroup.ProjectCode))
                                                            {
                                                                <small class="text-muted ml-2" style="font-size: 0.85rem;">(@projectGroup.ProjectCode)</small>
                                                            }
                                                        </h6>
                                                    </div>
                                                    @foreach (var success in projectGroup.Successes)
                                                    {
                                                        var displayName = !string.IsNullOrWhiteSpace(success.CreatedByName) 
                                                            ? FormatNameForDisplay(success.CreatedByName) 
                                                            : (!string.IsNullOrWhiteSpace(success.CreatedByEmail) ? success.CreatedByEmail : "Unknown");
                                                        
                                                        <div class="success-item mb-3 pb-3" style="border-bottom: 1px solid #e9ecef;">
                                                            <div class="success-content mb-2">
                                                                <div style="background-color: #f8f9fa; padding: 1rem; border-radius: 4px; margin-bottom: 0.5rem; text-align: left; max-width: 75%;">
                                                                    @success.SuccessDescription
                                                                </div>
                                                            </div>
                                                            <div class="success-meta">
                                                                <div class="text-muted small" style="text-align: left;">
                                                                    Added by @displayName on @success.CreatedAt.ToString("d MMMM yyyy")
                                                                </div>
                                                            </div>
                                                            
                                                            @if (!string.IsNullOrWhiteSpace(success.SltResponse))
                                                            {
                                                                <div class="slt-response mt-3 p-3" style="background-color: #ffffff; border-left: 4px solid #ffc107; border-radius: 4px; text-align: left; max-width: 75%;" data-success-id="@success.Id" data-success-type="@success.Type">
                                                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                                                        <strong style="color: #333;">
                                                                            <i class="fas fa-comment-dots mr-1"></i>SLT Response
                                                                        </strong>
                                                                        <div>
                                                                            <button type="button" class="btn btn-sm btn-link text-primary p-0 mr-2 edit-slt-response-btn" 
                                                                                    data-success-id="@success.Id" 
                                                                                    data-success-type="@success.Type"
                                                                                    title="Edit response">
                                                                                <i class="fas fa-edit"></i>
                                                                            </button>
                                                                            <button type="button" class="btn btn-sm btn-link text-danger p-0 delete-slt-response-btn" 
                                                                                    data-success-id="@success.Id" 
                                                                                    data-success-type="@success.Type"
                                                                                    title="Delete response">
                                                                                <i class="fas fa-trash"></i>
                                                                            </button>
                                                                        </div>
                                                                    </div>
                                                                    <div class="slt-response-content" style="color: #333; text-align: left; word-wrap: break-word; margin-bottom: 0.5rem;">
                                                                        @success.SltResponse
                                                                    </div>
                                                                    <div class="slt-response-edit-form" style="display: none;">
                                                                        <textarea class="form-control mb-2" rows="3" placeholder="Enter SLT response..."></textarea>
                                                                        <div class="d-flex justify-content-end">
                                                                            <button type="button" class="btn btn-sm btn-secondary mr-2 cancel-edit-slt-response-btn">Cancel</button>
                                                                            <button type="button" class="btn btn-sm btn-primary save-edit-slt-response-btn">Save</button>
                                                                        </div>
                                                                    </div>
                                                                    <div>
                                                                        <small class="text-muted">
                                                                            @{
                                                                                var sltRespondedAt = (DateTime?)success.SltRespondedAt;
                                                                            }
                                                                            @if (sltRespondedAt != null)
                                                                            {
                                                                                @if (!string.IsNullOrWhiteSpace(success.SltRespondedByName))
                                                                                {
                                                                                    var sltDisplayName = FormatNameForDisplay(success.SltRespondedByName);
                                                                                    <text>Added by @sltDisplayName on @sltRespondedAt.Value.ToString("d MMMM yyyy")</text>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <text>@sltRespondedAt.Value.ToString("d MMMM yyyy")</text>
                                                                                }
                                                                            }
                                                                        </small>
                                                                    </div>
                                                                </div>
                                                            }
                                                            else
                                                            {
                                                                <div class="slt-response-form mt-3" data-success-type="@success.Type" data-success-id="@success.Id">
                                                                    <button type="button" 
                                                                            class="btn btn-sm btn-primary add-slt-response-btn"
                                                                            data-success-id="@success.Id"
                                                                            data-success-type="@success.Type">
                                                                        <i class="fas fa-comment mr-1" style="font-size: 0.85rem;"></i>Add SLT Response
                                                                    </button>
                                                                    <div class="slt-response-form-container mt-2" style="display: none;">
                                                                        <textarea class="form-control mb-2" 
                                                                                  rows="3" 
                                                                                  placeholder="Enter SLT response..."
                                                                                  id="slt-response-text-@success.Type-@success.Id"></textarea>
                                                                        <div class="d-flex justify-content-start">
                                                                            <button type="button" 
                                                                                    class="btn btn-sm btn-success mr-2 save-slt-response-btn"
                                                                                    data-success-id="@success.Id"
                                                                                    data-success-type="@success.Type">
                                                                                Save Response
                                                                            </button>
                                                                            <button type="button" 
                                                                                    class="btn btn-sm btn-secondary cancel-slt-response-btn"
                                                                                    data-success-id="@success.Id"
                                                                                    data-success-type="@success.Type">
                                                                                Cancel
                                                                            </button>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                                }
                                            }
                                            else
                                            {
                                                <div class="text-center p-4">
                                                    <p class="text-muted mb-0">No weekly updates submitted for this business area.</p>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="p-4">
                                <p class="text-muted mb-0">No successes reported to SLT for this week.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Milestones Section -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title mb-0" style="font-size: 1rem; font-weight: 600;">Milestones Due This Week</h5>
                    </div>
                    <div class="card-body p-0">
                        @if (Model.Milestones.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th style="width: 25%;">Work Item</th>
                                            <th style="width: 30%;">Milestone</th>
                                            <th style="width: 15%;">Due Date</th>
                                            <th style="width: 15%;">Status</th>
                                            <th style="width: 15%;">Progress</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var milestone in Model.Milestones)
                                        {
                                            <tr>
                                                <td>
                                                    @if (milestone.Project != null)
                                                    {
                                                        <a asp-controller="Project" 
                                                           asp-action="Details" 
                                                           asp-route-id="@milestone.ProjectId">
                                                            @milestone.Project.Title
                                                        </a>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">N/A</span>
                                                    }
                                                </td>
                                                <td>
                                                    <a asp-controller="Project" 
                                                       asp-action="MilestoneDetails" 
                                                       asp-route-id="@milestone.Id">
                                                        @milestone.Name
                                                    </a>
                                                    @if (!string.IsNullOrWhiteSpace(milestone.Description))
                                                    {
                                                        <br />
                                                        <small class="text-muted">@(milestone.Description.Length > 100 ? milestone.Description.Substring(0, 100) + "..." : milestone.Description)</small>
                                                    }
                                                </td>
                                                <td>
                                                    @milestone.DueDate.ToString("dd MMM yyyy")
                                                </td>
                                                <td>
                                                    <span class="badge badge-@(milestone.Status == "complete" ? "success" : milestone.Status == "at_risk" ? "warning" : milestone.Status == "in_progress" ? "info" : "secondary")">
                                                        @milestone.Status.Replace("_", " ")
                                                    </span>
                                                </td>
                                                <td>
                                                    @if (milestone.ProgressPercent.HasValue)
                                                    {
                                                        <div class="d-flex align-items-center">
                                                            <div class="progress flex-grow-1 mr-2" style="height: 20px;">
                                                                <div class="progress-bar @(milestone.ProgressPercent >= 75 ? "bg-success" : milestone.ProgressPercent >= 50 ? "bg-info" : milestone.ProgressPercent >= 25 ? "bg-warning" : "bg-danger")"
                                                                     role="progressbar"
                                                                     style="width: @milestone.ProgressPercent%"
                                                                     aria-valuenow="@milestone.ProgressPercent"
                                                                     aria-valuemin="0"
                                                                     aria-valuemax="100">
                                                                </div>
                                                            </div>
                                                            <span class="small">@milestone.ProgressPercent%</span>
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Not set</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="p-4">
                                <p class="text-muted mb-0">No milestones due this week.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .success-content {
        text-align: left !important;
        direction: ltr;
    }
    
    .success-item {
        text-align: left !important;
        direction: ltr;
    }
    
    .project-thread {
        text-align: left !important;
        direction: ltr;
    }
    
    .business-area-card .card-header {
        transition: background-color 0.2s;
    }
    
    .business-area-card .card-header:hover {
        background-color: #e9ecef !important;
    }
    
    .business-area-card .toggle-icon {
        transition: transform 0.3s;
    }
    
    .business-area-card .card-header[aria-expanded="false"] .toggle-icon {
        transform: rotate(-90deg);
    }
    
    
    .project-thread {
        position: relative;
    }
    
    .project-thread:not(:last-child) {
        margin-bottom: 2rem !important;
    }
    
    .success-item {
        position: relative;
        padding-left: 0.5rem;
    }
    
    .slt-response {
        animation: slideIn 0.3s ease-out;
        text-align: left !important;
        direction: ltr;
    }
    
    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script nonce="@Context.Items["Nonce"]">
    document.addEventListener('DOMContentLoaded', function() {
        // Handle business area toggle
        const businessAreaHeaders = document.querySelectorAll('.business-area-header');
        businessAreaHeaders.forEach(function(header) {
            header.addEventListener('click', function() {
                // Icon rotation is handled by CSS
                updateExpandCollapseButtons();
            });
        });
        
        // Handle expand all business areas
        const expandAllBtn = document.getElementById('expandAllBusinessAreas');
        const collapseAllBtn = document.getElementById('collapseAllBusinessAreas');
        
        if (expandAllBtn && collapseAllBtn) {
            // Use jQuery if available, otherwise use vanilla JS
            if (typeof jQuery !== 'undefined') {
                $(expandAllBtn).on('click', function(e) {
                    e.preventDefault();
                    $('.business-area-card .collapse').collapse('show');
                    $(this).addClass('d-none');
                    $(collapseAllBtn).removeClass('d-none');
                });
                
                $(collapseAllBtn).on('click', function(e) {
                    e.preventDefault();
                    $('.business-area-card .collapse').collapse('hide');
                    $(this).addClass('d-none');
                    $(expandAllBtn).removeClass('d-none');
                });
                
                // Update button visibility based on current state
                function updateExpandCollapseButtons() {
                    const allCollapses = $('.business-area-card .collapse');
                    const expandedCollapses = $('.business-area-card .collapse.show');
                    
                    if (allCollapses.length === 0) {
                        $(expandAllBtn).addClass('d-none');
                        $(collapseAllBtn).addClass('d-none');
                        return;
                    }
                    
                    if (expandedCollapses.length === allCollapses.length) {
                        // All expanded
                        $(expandAllBtn).addClass('d-none');
                        $(collapseAllBtn).removeClass('d-none');
                    } else if (expandedCollapses.length === 0) {
                        // All collapsed
                        $(expandAllBtn).removeClass('d-none');
                        $(collapseAllBtn).addClass('d-none');
                    } else {
                        // Mixed state
                        $(expandAllBtn).removeClass('d-none');
                        $(collapseAllBtn).removeClass('d-none');
                    }
                }
                
                // Listen for collapse events to update button state
                $('.business-area-card .collapse').on('shown.bs.collapse hidden.bs.collapse', updateExpandCollapseButtons);
                
                // Initial button state
                updateExpandCollapseButtons();
            } else {
                // Fallback to vanilla JS
                expandAllBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    const allCollapses = document.querySelectorAll('.business-area-card .collapse');
                    allCollapses.forEach(function(collapse) {
                        if (typeof bootstrap !== 'undefined' && bootstrap.Collapse) {
                            const bsCollapse = new bootstrap.Collapse(collapse, { toggle: false });
                            bsCollapse.show();
                        } else {
                            collapse.classList.add('show');
                        }
                    });
                    expandAllBtn.classList.add('d-none');
                    collapseAllBtn.classList.remove('d-none');
                });
                
                collapseAllBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    const allCollapses = document.querySelectorAll('.business-area-card .collapse');
                    allCollapses.forEach(function(collapse) {
                        if (typeof bootstrap !== 'undefined' && bootstrap.Collapse) {
                            const bsCollapse = new bootstrap.Collapse(collapse, { toggle: false });
                            bsCollapse.hide();
                        } else {
                            collapse.classList.remove('show');
                        }
                    });
                    collapseAllBtn.classList.add('d-none');
                    expandAllBtn.classList.remove('d-none');
                });
            }
        }
        
        // Handle "Add SLT Response" button clicks
        const addSltResponseButtons = document.querySelectorAll('.add-slt-response-btn');
        addSltResponseButtons.forEach(function(button) {
            button.addEventListener('click', function() {
                const successId = this.getAttribute('data-success-id');
                const successType = this.getAttribute('data-success-type');
                const formContainer = document.querySelector(`.slt-response-form[data-success-id="${successId}"][data-success-type="${successType}"] .slt-response-form-container`);
                
                if (formContainer) {
                    formContainer.style.display = 'block';
                    this.style.display = 'none';
                    const textarea = formContainer.querySelector('textarea');
                    if (textarea) {
                        textarea.focus();
                    }
                }
            });
        });
        
        // Handle "Cancel" button clicks
        const cancelButtons = document.querySelectorAll('.cancel-slt-response-btn');
        cancelButtons.forEach(function(button) {
            button.addEventListener('click', function() {
                const successId = this.getAttribute('data-success-id');
                const successType = this.getAttribute('data-success-type');
                const formContainer = document.querySelector(`.slt-response-form[data-success-id="${successId}"][data-success-type="${successType}"] .slt-response-form-container`);
                const addButton = document.querySelector(`.add-slt-response-btn[data-success-id="${successId}"][data-success-type="${successType}"]`);
                const textarea = formContainer ? formContainer.querySelector('textarea') : null;
                
                if (formContainer) {
                    formContainer.style.display = 'none';
                    if (addButton) {
                        addButton.style.display = 'inline-block';
                    }
                    if (textarea) {
                        textarea.value = '';
                    }
                }
            });
        });
        
        // Handle "Edit SLT Response" button clicks
        const editSltResponseButtons = document.querySelectorAll('.edit-slt-response-btn');
        editSltResponseButtons.forEach(function(button) {
            button.addEventListener('click', function() {
                const successId = this.getAttribute('data-success-id');
                const successType = this.getAttribute('data-success-type');
                const sltResponse = document.querySelector(`.slt-response[data-success-id="${successId}"][data-success-type="${successType}"]`);
                const contentDiv = sltResponse.querySelector('.slt-response-content');
                const editForm = sltResponse.querySelector('.slt-response-edit-form');
                const textarea = editForm.querySelector('textarea');
                
                textarea.value = contentDiv.textContent.trim();
                contentDiv.style.display = 'none';
                editForm.style.display = 'block';
                this.style.display = 'none';
                sltResponse.querySelector('.delete-slt-response-btn').style.display = 'none';
                textarea.focus();
            });
        });
        
        // Handle "Cancel Edit" button clicks
        const cancelEditButtons = document.querySelectorAll('.cancel-edit-slt-response-btn');
        cancelEditButtons.forEach(function(button) {
            button.addEventListener('click', function() {
                const sltResponse = this.closest('.slt-response');
                const contentDiv = sltResponse.querySelector('.slt-response-content');
                const editForm = sltResponse.querySelector('.slt-response-edit-form');
                const editBtn = sltResponse.querySelector('.edit-slt-response-btn');
                const deleteBtn = sltResponse.querySelector('.delete-slt-response-btn');
                
                contentDiv.style.display = 'block';
                editForm.style.display = 'none';
                editBtn.style.display = 'inline-block';
                deleteBtn.style.display = 'inline-block';
            });
        });
        
        // Handle "Save Edit" button clicks
        const saveEditButtons = document.querySelectorAll('.save-edit-slt-response-btn');
        saveEditButtons.forEach(function(button) {
            button.addEventListener('click', async function() {
                const sltResponse = this.closest('.slt-response');
                const successId = sltResponse.getAttribute('data-success-id');
                const successType = sltResponse.getAttribute('data-success-type');
                const textarea = sltResponse.querySelector('.slt-response-edit-form textarea');
                const responseText = textarea.value.trim();
                
                if (!responseText) {
                    alert('Please enter a response before saving.');
                    return;
                }
                
                const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
                const token = tokenElement ? tokenElement.value : '';
                
                if (!token) {
                    alert('Security token not found. Please refresh the page and try again.');
                    return;
                }
                
                try {
                    const formData = new FormData();
                    formData.append('successId', successId.toString());
                    formData.append('successType', successType);
                    formData.append('responseText', responseText);
                    formData.append('__RequestVerificationToken', token);
                    
                    const response = await fetch('@Url.Action("SaveSltResponse", "CentralOps")', {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token
                        },
                        body: formData
                    });
                    
                    if (response.ok) {
                        window.location.reload();
                    } else {
                        const errorText = await response.text();
                        try {
                            const errorData = JSON.parse(errorText);
                            alert('Error saving response: ' + (errorData.message || 'Unknown error'));
                        } catch {
                            alert('Error saving response. Please try again.');
                        }
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('An error occurred while saving the response. Please try again.');
                }
            });
        });
        
        // Handle "Delete SLT Response" button clicks
        const deleteSltResponseButtons = document.querySelectorAll('.delete-slt-response-btn');
        deleteSltResponseButtons.forEach(function(button) {
            button.addEventListener('click', async function() {
                if (!confirm('Are you sure you want to delete this SLT response? This action cannot be undone.')) {
                    return;
                }
                
                const successId = this.getAttribute('data-success-id');
                const successType = this.getAttribute('data-success-type');
                
                const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
                const token = tokenElement ? tokenElement.value : '';
                
                if (!token) {
                    alert('Security token not found. Please refresh the page and try again.');
                    return;
                }
                
                try {
                    const formData = new FormData();
                    formData.append('successId', successId.toString());
                    formData.append('successType', successType);
                    formData.append('__RequestVerificationToken', token);
                    
                    const response = await fetch('@Url.Action("DeleteSltResponse", "CentralOps")', {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token
                        },
                        body: formData
                    });
                    
                    if (response.ok) {
                        window.location.reload();
                    } else {
                        const errorText = await response.text();
                        try {
                            const errorData = JSON.parse(errorText);
                            alert('Error deleting response: ' + (errorData.message || 'Unknown error'));
                        } catch {
                            alert('Error deleting response. Please try again.');
                        }
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('An error occurred while deleting the response. Please try again.');
                }
            });
        });
        
        // Handle "Save Response" button clicks
        const saveButtons = document.querySelectorAll('.save-slt-response-btn');
        saveButtons.forEach(function(button) {
            button.addEventListener('click', async function() {
                const successId = this.getAttribute('data-success-id');
                const successType = this.getAttribute('data-success-type');
                const textarea = document.querySelector(`#slt-response-text-${successType}-${successId}`);
                const responseText = textarea ? textarea.value.trim() : '';
                
                if (!responseText) {
                    alert('Please enter a response before saving.');
                    return;
                }
                
                // Get anti-forgery token
                const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
                const token = tokenElement ? tokenElement.value : '';
                
                if (!token) {
                    alert('Security token not found. Please refresh the page and try again.');
                    return;
                }
                
                try {
                    // Use form data to properly send anti-forgery token
                    const formData = new FormData();
                    formData.append('successId', successId.toString());
                    formData.append('successType', successType);
                    formData.append('responseText', responseText);
                    formData.append('__RequestVerificationToken', token);
                    
                    const response = await fetch('@Url.Action("SaveSltResponse", "CentralOps")', {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': token
                        },
                        body: formData
                    });
                    
                    if (response.ok) {
                        // Reload the page to show the new response
                        window.location.reload();
                    } else {
                        const errorText = await response.text();
                        try {
                            const errorData = JSON.parse(errorText);
                            alert('Error saving response: ' + (errorData.message || 'Unknown error'));
                        } catch {
                            alert('Error saving response. Please try again.');
                        }
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('An error occurred while saving the response. Please try again.');
                }
            });
        });
    });
</script>

