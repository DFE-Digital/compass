@model Compass.ViewModels.WorkItemSideNavViewModel
@{
    string TabClass(string tab)
    {
        if (Model.IsDangerZonePage)
        {
            return "list-group-item list-group-item-action";
        }

        return Model.CurrentTab == tab ? "list-group-item list-group-item-action active" : "list-group-item list-group-item-action";
    }
}
<div class="card mb-4">
    <div class="card-header">
        <h3 class="card-title">Navigation</h3>
    </div>
    <div class="card-body p-0">
        <nav class="list-group list-group-flush" aria-label="Work item sections">
            @if (Model.IsDangerZonePage)
            {
                <a class="@TabClass("overview")" href="@Url.Action("WorkItemDetails", "CentralOps", new { id = Model.ProjectId, tab = "overview" })">Overview</a>
                <a class="@TabClass("basic")" href="@Url.Action("WorkItemDetails", "CentralOps", new { id = Model.ProjectId, tab = "basic" })">Basic Information</a>
                <a class="@TabClass("contacts")" href="@Url.Action("WorkItemDetails", "CentralOps", new { id = Model.ProjectId, tab = "contacts" })">Contacts &amp; Governance</a>
                <a class="@TabClass("strategic")" href="@Url.Action("WorkItemDetails", "CentralOps", new { id = Model.ProjectId, tab = "strategic" })">Strategic Alignment</a>
                <a class="@TabClass("dates")" href="@Url.Action("WorkItemDetails", "CentralOps", new { id = Model.ProjectId, tab = "dates" })">Dates &amp; Timeline</a>
                <a class="@TabClass("status")" href="@Url.Action("WorkItemDetails", "CentralOps", new { id = Model.ProjectId, tab = "status" })">Status &amp; Priority</a>
                <a class="@TabClass("audit")" href="@Url.Action("WorkItemDetails", "CentralOps", new { id = Model.ProjectId, tab = "audit" })">Audit actions</a>
            }
            else
            {
                <a href="#overview" class="@TabClass("overview")" data-tab="overview">Overview</a>
                <a href="#basic" class="@TabClass("basic")" data-tab="basic">Basic Information</a>
                <a href="#contacts" class="@TabClass("contacts")" data-tab="contacts">Contacts &amp; Governance</a>
                <a href="#strategic" class="@TabClass("strategic")" data-tab="strategic">Strategic Alignment</a>
                <a href="#dates" class="@TabClass("dates")" data-tab="dates">Dates &amp; Timeline</a>
                <a href="#status" class="@TabClass("status")" data-tab="status">Status &amp; Priority</a>
                <a href="#audit" class="@TabClass("audit")" data-tab="audit">Audit actions</a>
            }
            <div class="border-top">
                <a asp-controller="CentralOps" asp-action="WorkItemDangerZone" asp-route-id="@Model.ProjectId"
                   class="list-group-item list-group-item-action @(Model.IsDangerZonePage ? "active" : "") text-danger font-weight-bold">
                    Danger zone
                </a>
            </div>
        </nav>
    </div>
</div>
