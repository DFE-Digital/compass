@model List<Compass.Models.Commission>
@{
    ViewData["Title"] = "Performance reporting";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="CentralOps" asp-action="Dashboard" style="color: #005ea5; text-decoration: none;">Central Operations</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Performance reporting</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        @await Html.PartialAsync("_CentralOpsNavigation")
        
        <div class="content-header">
            <div class="container-fluid">
                <div class="row mb-2">
                    <div class="col-sm-6">
                        <h1 class="m-0">Performance reporting</h1>
                    </div>
                </div>
            </div>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (Model == null || !Model.Any())
        {
            <div class="card">
                <div class="card-body text-center py-5">
                    <p class="text-muted mb-0">No active commissions available.</p>
                </div>
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Commissions</h3>
                </div>
                <div class="card-body table-responsive p-0">
                    <table class="table table-hover" style="table-layout: fixed; width: 100%;">
                        <thead>
                            <tr>
                                <th style="width: 20%;">Name</th>
                                <th style="width: 25%;">Description</th>
                                <th style="width: 20%;">Period</th>
                                <th style="width: 15%;">Due date</th>
                                <th style="width: 20%;">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var commission in Model)
                            {
                                var now = DateTime.UtcNow;
                                var isPastDue = now > commission.DueDate;
                                var isOpen = now >= commission.OpenDate && now <= commission.DueDate;
                                var isFuture = now < commission.OpenDate;
                                
                                <tr>
                                    <td>
                                        <a href="@Url.Action("PerformanceReporting", "CentralOps", new { commissionId = commission.Id })" 
                                           style="color: #005ea5; text-decoration: none; font-weight: 600;">
                                            <strong>@commission.Name</strong>
                                        </a>
                                        @if (!string.IsNullOrEmpty(commission.Quarter))
                                        {
                                            <span class="badge badge-info ml-2">@commission.Quarter</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(commission.Description))
                                        {
                                            <span class="text-muted">@commission.Description</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @commission.StartDate.ToString("d MMM yyyy")<br />
                                        <small class="text-muted">to</small><br />
                                        @commission.EndDate.ToString("d MMM yyyy")
                                    </td>
                                    <td>
                                        @if (isPastDue)
                                        {
                                            <span>@commission.DueDate.ToString("d MMM yyyy")</span><br />
                                            <small class="text-danger">Past due</small>
                                        }
                                        else if (isOpen)
                                        {
                                            <span>@commission.DueDate.ToString("d MMM yyyy")</span><br />
                                            <small class="text-muted">Active</small>
                                        }
                                        else
                                        {
                                            <span>@commission.DueDate.ToString("d MMM yyyy")</span><br />
                                            <small class="text-muted">Opens @commission.OpenDate.ToString("d MMM yyyy")</small>
                                        }
                                    </td>
                                    <td>
                                        @if (isPastDue)
                                        {
                                            <span class="badge badge-danger">Past due</span>
                                        }
                                        else if (isOpen)
                                        {
                                            <span class="badge badge-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-secondary">Future</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</section>
