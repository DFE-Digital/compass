@{
    ViewData["Title"] = "Central Operations - RAG Status";
    var filteredProjects = ViewBag.FilteredProjects as List<Compass.Models.Project> ?? new List<Compass.Models.Project>();
    var ragStatus = ViewBag.RagStatus as string ?? "";
    var totalCount = ViewBag.TotalCount as int? ?? 0;
    var displayStatus = string.IsNullOrEmpty(ragStatus) ? "Not set" : ragStatus;
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="CentralOps" asp-action="Summary" style="color: #005ea5; text-decoration: none;">Central Operations</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="CentralOps" asp-action="RagAndRisk" style="color: #005ea5; text-decoration: none;">RAG and Risk</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">RAG Status - @displayStatus</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">RAG Status - @displayStatus</h1>
                <p class="text-muted">Total projects: <strong>@totalCount</strong></p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <!-- Projects with this RAG status -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Projects - @displayStatus (@filteredProjects.Count)</h3>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 250px;">Title</th>
                                    <th style="width: 100px;">Priority</th>
                                    <th style="width: 120px;">RAG</th>
                                    <th style="width: 150px;">Business Area</th>
                                    <th style="width: 150px;">Primary Contact</th>
                                    <th style="width: 200px;">Service Owner</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (filteredProjects != null && filteredProjects.Any())
                                {
                                    @foreach (var project in filteredProjects)
                                    {
                                        <tr>
                                            <td>
                                                <a asp-controller="Project" asp-action="Details" asp-route-id="@project.Id" style="font-weight: bold; color: #005ea5; text-decoration: none;">@project.Title</a>
                                                <br />
                                                <small class="text-muted">DFE-DDT-@project.Id</small>
                                            </td>
                                            <td>
                                                @if (project.DeliveryPriority != null && !string.IsNullOrEmpty(project.DeliveryPriority.Name))
                                                {
                                                    var priorityClass = project.DeliveryPriority.Name.ToLower() switch {
                                                        var p when p.Contains("critical") => "badge-danger",
                                                        var p when p.Contains("high") => "badge-danger",
                                                        var p when p.Contains("medium") => "badge-warning",
                                                        var p when p.Contains("low") => "badge-secondary",
                                                        _ => "badge-secondary"
                                                    };
                                                    <span class="badge @priorityClass">@project.DeliveryPriority.Name</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(project.RagStatus))
                                                {
                                                    var normalized = project.RagStatus.Trim()
                                                        .Replace(" / ", "-")
                                                        .Replace("/", "-")
                                                        .Replace(" /", "-")
                                                        .Replace("/ ", "-");
                                                    
                                                    // Capitalize first letter of each word for consistency
                                                    var parts = normalized.Split('-');
                                                    for (int i = 0; i < parts.Length; i++)
                                                    {
                                                        if (parts[i].Length > 0)
                                                        {
                                                            parts[i] = char.ToUpperInvariant(parts[i][0]) + (parts[i].Length > 1 ? parts[i].Substring(1).ToLowerInvariant() : "");
                                                        }
                                                    }
                                                    var displayRagStatus = string.Join("-", parts);
                                                    
                                                    var ragClass = displayRagStatus switch {
                                                        "Red" => "badge badge-red",
                                                        "Amber-Red" => "badge badge-amber-red",
                                                        "Amber" => "badge badge-amber",
                                                        "Amber-Green" => "badge badge-amber-green",
                                                        "Green" => "badge badge-green",
                                                        _ => "badge badge-secondary"
                                                    };
                                                    <span class="@ragClass">@displayRagStatus</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>@(project.BusinessAreaLookup?.Name ?? "-")</td>
                                            <td>
                                                @if (project.PrimaryContactUser != null)
                                                {
                                                    @project.PrimaryContactUser.Name
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (project.ServiceOwners != null && project.ServiceOwners.Any())
                                                {
                                                    var serviceOwners = project.ServiceOwners.Where(so => so.User != null).Take(2).ToList();
                                                    @foreach (var so in serviceOwners)
                                                    {
                                                        <div>@so.User.Name</div>
                                                    }
                                                    @if (project.ServiceOwners.Count > 2)
                                                    {
                                                        <small class="text-muted">+ @(project.ServiceOwners.Count - 2) more</small>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-3">No projects found with this RAG status</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

