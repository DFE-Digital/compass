                <ul class="small">
                    <li><code>Id</code> - INTEGER, primary key</li>
                    <li><code>Year</code> - INTEGER, reporting year</li>
                    <li><code>Month</code> - INTEGER, reporting month (unique per Year/Month)</li>
                    <li><code>Reason</code> - TEXT, exclusion reason</li>
                    <li><code>IsActive</code> - BOOLEAN, active flag</li>
                </ul>

                <h3 class="h6 mt-3">NotificationTemplates, NotificationRules, NotificationLogs</h3>
