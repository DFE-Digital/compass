                    <li><code>Conditions</code> - NVARCHAR(MAX), rule conditions (JSON)</li>
                    <li><code>RecipientEmail</code> - VARCHAR(255), recipient (for logs)</li>
                    <li><code>SentAt</code> - DATETIME, sent timestamp (for logs)</li>
                    <li><code>Status</code> - VARCHAR(50), status (for logs)</li>
                    <li><code>IsActive</code> - BOOLEAN, active flag</li>
                </ul>

