@{
    ViewData["Title"] = "Government departments";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Documentation")">Documentation</a></li>
            <li class="breadcrumb-item active">Government departments</li>
        </ol>
    </nav>
}

<h1 class="doc-page-title">Government Department Management</h1>
<p class="doc-page-lead">Manage government departments for organisational structure and reporting.</p>

<p>Documentation for government department management is being developed. This will cover:</p>

<ul>
    <li>Creating and managing government departments</li>
    <li>Department hierarchy support</li>
    <li>Linking departments to other entities</li>
    <li>Department-based reporting</li>
</ul>

<div class="alert alert-info mt-4">
    <p class="mb-0">For user stories and detailed feature information, see <a href="@Url.Action("UserStories", "Documentation")">User stories</a>.</p>
</div>

