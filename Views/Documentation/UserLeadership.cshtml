@{
    ViewData["Title"] = "User leadership";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Documentation")">Documentation</a></li>
            <li class="breadcrumb-item active">User leadership</li>
        </ol>
    </nav>
}

<h1 class="doc-page-title">User Leadership Management</h1>
<p class="doc-page-lead">Assign leadership roles to users for specific business areas with role-based access control.</p>

<p>Documentation for user leadership management is being developed. This will cover:</p>

<ul>
    <li>Assigning leadership roles to users</li>
    <li>Business area assignments</li>
    <li>Role types (Portfolio Lead, Business Area Lead, etc.)</li>
    <li>Access control based on leadership assignments</li>
    <li>Managing leadership assignments</li>
</ul>

<div class="alert alert-info mt-4">
    <p class="mb-0">For user stories and detailed feature information, see <a href="@Url.Action("UserStories", "Documentation")">User stories</a>.</p>
</div>

