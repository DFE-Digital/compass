        <div class="card border-primary h-100">
            <div class="card-body">
                <h3 class="h6"><i class="fas fa-file-alt text-primary"></i> Demand requests</h3>
                <p class="small mb-0">Capture new work requests with comprehensive information across multiple sections.</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 mb-3">
        <div class="card border-info h-100">
            <div class="card-body">
                <h3 class="h6"><i class="fas fa-clipboard-list text-info"></i> Triage meetings</h3>
                <p class="small mb-0">Review and assess demand requests through structured triage meetings.</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 mb-3">
        <div class="card border-success h-100">
            <div class="card-body">
                <h3 class="h6"><i class="fas fa-sort-amount-down text-success"></i> Prioritisation</h3>
                <p class="small mb-0">Score and prioritise demand requests by tier and portfolio.</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-6 mb-3">
