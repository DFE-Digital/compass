@{
    ViewData["Title"] = "Business reporting";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Documentation")">Documentation</a></li>
            <li class="breadcrumb-item active">Business reporting</li>
        </ol>
    </nav>
}

<h1 class="doc-page-title">Business Reporting</h1>
<p class="doc-page-lead">Business reporting dashboard with metrics, analytics, and insights.</p>

<p>Documentation for business reporting is being developed. This will cover:</p>

<ul>
    <li>Business reporting dashboard</li>
    <li>Metrics aggregation</li>
    <li>Analytics and charts</li>
    <li>Filtering and date range selection</li>
    <li>Export capabilities</li>
    <li>Report scheduling</li>
</ul>

<div class="alert alert-info mt-4">
    <p class="mb-0">For user stories and detailed feature information, see <a href="@Url.Action("UserStories", "Documentation")">User stories</a>.</p>
</div>

