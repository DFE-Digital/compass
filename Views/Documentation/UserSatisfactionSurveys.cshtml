@{
    ViewData["Title"] = "User satisfaction surveys";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Documentation")">Documentation</a></li>
            <li class="breadcrumb-item active">User satisfaction surveys</li>
        </ol>
    </nav>
}

<h1 class="doc-page-title">User Satisfaction Surveys</h1>
<p class="doc-page-lead">Manage user satisfaction surveys for products with enrollment, response tracking, and analytics.</p>

<p>Documentation for user satisfaction surveys is being developed. This will cover:</p>

<ul>
    <li>Product enrollment for surveys</li>
    <li>Survey response collection</li>
    <li>USS (User Satisfaction Score) calculation</li>
    <li>Survey dashboard and analytics</li>
    <li>Score range filtering</li>
    <li>Trend analysis</li>
</ul>

<div class="alert alert-info mt-4">
    <p class="mb-0">For user stories and detailed feature information, see <a href="@Url.Action("UserStories", "Documentation")">User stories</a>.</p>
</div>

