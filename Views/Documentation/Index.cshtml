@{
    ViewData["Title"] = "Documentation";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Documentation</li>
        </ol>
    </nav>
}

<h1 class="doc-page-title">COMPASS Documentation</h1>
<p class="doc-page-lead">Welcome to the COMPASS documentation. This comprehensive guide will help you understand and use the COMPASS platform effectively.</p>

<div class="row mt-4">
    <div class="col-md-6 col-lg-4 mb-4">
        <a href="@Url.Action("Overview", "Documentation")" class="text-decoration-none">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center">
                    <h3 class="h5 mb-3">Overview</h3>
                    <p class="card-text text-muted">Learn about the COMPASS platform, its purpose, and key capabilities.</p>
                </div>
            </div>
        </a>
    </div>
    
    <div class="col-md-6 col-lg-4 mb-4">
        <a href="@Url.Action("Features", "Documentation")" class="text-decoration-none">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center">
                    <h3 class="h5 mb-3">Features</h3>
                    <p class="card-text text-muted">Explore the features and functionality available in COMPASS.</p>
                </div>
            </div>
        </a>
    </div>
    
    <div class="col-md-6 col-lg-4 mb-4">
        <a href="@Url.Action("UserGuide", "Documentation")" class="text-decoration-none">
