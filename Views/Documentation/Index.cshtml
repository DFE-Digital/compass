            <div class="card h-100 border-0 shadow-sm border-primary" style="border-width: 2px !important;">
                <div class="card-body text-center">
                    <h3 class="h5 mb-3"><i class="fas fa-rocket text-primary"></i> Getting started</h3>
                    <p class="card-text text-muted">New to COMPASS? Start here for a friendly introduction to delivery and operational reporting.</p>
                </div>
            </div>
        </a>
    </div>
    
    <div class="col-md-6 col-lg-4 mb-4">
        <a href="@Url.Action("Overview", "Documentation")" class="text-decoration-none">
