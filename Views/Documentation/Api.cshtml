<script nonce="@Context.Items["Nonce"]">
    document.addEventListener('DOMContentLoaded', function() {
        // Add click event listeners to all API endpoint headers
        const headers = document.querySelectorAll('.api-endpoint-header');
        
        headers.forEach(function(header) {
            header.addEventListener('click', function() {
                const endpoint = this.closest('.api-endpoint');
                const allEndpoints = document.querySelectorAll('.api-endpoint');
                
                // Toggle current endpoint
                if (endpoint.classList.contains('active')) {
                    endpoint.classList.remove('active');
                } else {
                    // Close all other endpoints
                    allEndpoints.forEach(function(ep) {
                        ep.classList.remove('active');
                    });
                    // Open clicked endpoint
                    endpoint.classList.add('active');
                }
                
                // Update chevron icon
                const icon = this.querySelector('.fa-chevron-down, .fa-chevron-up');
                if (icon) {
                    if (endpoint.classList.contains('active')) {
                        icon.classList.remove('fa-chevron-down');
                        icon.classList.add('fa-chevron-up');
                    } else {
                        icon.classList.remove('fa-chevron-up');
                        icon.classList.add('fa-chevron-down');
                    }
                }
            });
        });
    });
</script>
