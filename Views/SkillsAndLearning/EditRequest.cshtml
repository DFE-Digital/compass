@model Compass.Models.TrainingRequest

@{
    ViewData["Title"] = "Edit training request";
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" style="color: #005ea5; text-decoration: none;">My skills and learning</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="MyRequests" style="color: #005ea5; text-decoration: none;">My requests</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Edit request</li>
        </ol>
    </nav>
}

<div class="dashboard-header">
    <div>
        <h1>Edit training request</h1>
        <p>Update your draft training request</p>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Training request details</h3>
            </div>
            <div class="card-body">
                <form asp-action="UpdateRequest" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="form-group">
                        <label>Select a course from the library</label>
                        <select name="courseId" class="form-control">
                            <option value="">-- Select a course --</option>
                            @foreach (var course in (SelectList)ViewBag.Courses)
                            {
                                <option value="@course.Value" selected="@(course.Value == Model.CourseId.ToString())">@course.Text</option>
                            }
                        </select>
                        <small class="form-text text-muted">Or provide a custom course title below</small>
                    </div>

                    <div class="form-group">
                        <label for="customCourseTitle">Custom course title</label>
                        <input type="text" id="customCourseTitle" name="customCourseTitle" class="form-control" value="@Model.CustomCourseTitle" placeholder="Enter course title if not selecting from library..." />
                        <small class="form-text text-muted">Required if no course selected from library</small>
                        @if (ViewData.ModelState["CustomCourseTitle"]?.Errors.Count > 0)
                        {
                            <span class="text-danger d-block">@ViewData.ModelState["CustomCourseTitle"].Errors.First().ErrorMessage</span>
                        }
                    </div>

                    <div class="form-group">
                        <label for="justification">Justification <span class="text-danger">*</span></label>
                        <textarea id="justification" name="justification" class="form-control" rows="5" required>@Model.Justification</textarea>
                        <small class="form-text text-muted">Required. Explain why this training is needed and how it will benefit your role.</small>
                        @if (ViewData.ModelState["Justification"]?.Errors.Count > 0)
                        {
                            <span class="text-danger d-block">@ViewData.ModelState["Justification"].Errors.First().ErrorMessage</span>
                        }
                    </div>

                    <div class="form-group">
                        <label for="professionAlignment">Profession alignment</label>
                        <textarea id="professionAlignment" name="professionAlignment" class="form-control" rows="3" placeholder="How does this training align with your profession or address capability gaps?">@Model.ProfessionAlignment</textarea>
                        <small class="form-text text-muted">Optional. Link to capability gaps or profession requirements.</small>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-success">Update request</button>
                        <a asp-action="MyRequests" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

