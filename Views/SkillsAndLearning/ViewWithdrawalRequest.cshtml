@model Compass.Models.TrainingRequest

@{
    ViewData["Title"] = "Manage withdrawal request";
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="AdminRequests" style="color: #005ea5; text-decoration: none;">Training requests</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Manage withdrawal</li>
        </ol>
    </nav>
}

<div class="dashboard-header">
    <div>
        <h1>Manage withdrawal request</h1>
        <p>Review and process withdrawal request</p>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Training request details</h3>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-3">User:</dt>
                            <dd class="col-sm-9">
                                <strong>@(Model.User?.Name ?? "Unknown")</strong><br>
                                <small class="text-muted">@(Model.User?.Email ?? "N/A")</small>
                            </dd>

                            <dt class="col-sm-3">Course:</dt>
                            <dd class="col-sm-9">
                                <strong>@(Model.Course?.Title ?? Model.CustomCourseTitle ?? "Custom course")</strong>
                            </dd>

                            <dt class="col-sm-3">Provider:</dt>
                            <dd class="col-sm-9">
                                @(Model.Course?.Provider ?? Model.CustomCourseProvider ?? "N/A")
                            </dd>

                            <dt class="col-sm-3">Cost:</dt>
                            <dd class="col-sm-9">
                                @{
                                    var cost = Model.ActualCost ?? Model.Course?.Cost ?? Model.CustomCourseCost ?? 0;
                                }
                                @if (cost > 0)
                                {
                                    <span class="text-danger">£@cost.ToString("N0")</span>
                                }
                                else
                                {
                                    <span class="text-success">Free</span>
                                }
                            </dd>

                            <dt class="col-sm-3">Planned date:</dt>
                            <dd class="col-sm-9">
                                @if (Model.PlannedDate.HasValue)
                                {
                                    @Model.PlannedDate.Value.ToString("dd MMM yyyy")
                                }
                                else
                                {
                                    <span class="text-muted">TBC</span>
                                }
                            </dd>

                            <dt class="col-sm-3">Withdrawal reason:</dt>
                            <dd class="col-sm-9">
                                @if (!string.IsNullOrEmpty(Model.WithdrawalReason))
                                {
                                    @Model.WithdrawalReason
                                }
                                else
                                {
                                    <span class="text-muted">No reason provided</span>
                                }
                            </dd>

                            <dt class="col-sm-3">Requested:</dt>
                            <dd class="col-sm-9">
                                @if (Model.WithdrawalRequestedAt.HasValue)
                                {
                                    @Model.WithdrawalRequestedAt.Value.ToString("dd MMM yyyy HH:mm")
                                }
                            </dd>
                        </dl>
                    </div>
                </div>

                <div class="card mt-4">
                    <div class="card-header">
                        <h3 class="card-title">Actions</h3>
                    </div>
                    <div class="card-body">
                        @if (cost == 0)
                        {
                            <div class="alert alert-success">
                                <i class="fas fa-check-circle"></i> 
                                <strong>This training is free.</strong> You can cancel the withdrawal request and remove the training request.
                            </div>

                            <form asp-action="CancelWithdrawalRequest" method="post" onsubmit="return confirm('Are you sure you want to cancel this withdrawal request and remove the training request?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id" />
                                <button type="submit" class="btn btn-success">
                                    <i class="fas fa-check"></i> Cancel withdrawal (remove request)
                                </button>
                            </form>
                        }
                        else
                        {
                            <div class="alert alert-warning">
                                <i class="fas fa-exclamation-triangle"></i> 
                                <strong>This training has a cost of £@cost.ToString("N0").</strong> 
                                Please transfer it to another person instead of cancelling.
                            </div>
                        }

                        <hr />

                        <h5>Transfer to another user</h5>
                        <p class="text-muted">Transfer this training request to another person.</p>

                        <form asp-action="TransferRequest" method="post" id="transferForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />

                            <div class="form-group">
                                <label for="transferSearch">Search for user</label>
                                <input type="text" id="transferSearch" class="form-control" placeholder="Type name or email to search..." autocomplete="off" />
                                <div id="transferResults" class="list-group mt-2" style="max-height: 300px; overflow-y: auto; display: none;"></div>
                            </div>
                            <input type="hidden" id="transferToUserId" name="transferToUserId" required />
                            <div id="selectedUser" class="alert alert-info" style="display: none;">
                                <strong>Selected:</strong> <span id="selectedUserName"></span>
                            </div>

                            <div class="form-group">
                                <button type="submit" class="btn btn-success" id="transferSubmit" disabled>Transfer request</button>
                                <a asp-action="AdminRequests" class="btn btn-secondary">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            var searchTimeout;

            $('#transferSearch').on('input', function() {
                clearTimeout(searchTimeout);
                var searchTerm = $(this).val().trim();
                var resultsDiv = $('#transferResults');
                var submitBtn = $('#transferSubmit');
                var userIdInput = $('#transferToUserId');
                var selectedUserDiv = $('#selectedUser');
                var selectedUserNameSpan = $('#selectedUserName');

                if (searchTerm.length < 2) {
                    resultsDiv.hide().empty();
                    return;
                }

                searchTimeout = setTimeout(function() {
                    $.ajax({
                        url: '/api/Staff/search?q=' + encodeURIComponent(searchTerm),
                        type: 'GET',
                        success: function(response) {
                            resultsDiv.empty();
                            // Handle response format: { results: [...] }
                            var data = response.results || response || [];
                            if (data && data.length > 0) {
                                data.forEach(function(user) {
                                    // Only show users that exist in database (have valid ID)
                                    if (user.id && user.id > 0) {
                                        var item = $('<a href="#" class="list-group-item list-group-item-action">')
                                            .html('<strong>' + escapeHtml(user.displayName || user.text) + '</strong><br><small class="text-muted">' + escapeHtml(user.email || '') + '</small>')
                                            .on('click', function(e) {
                                                e.preventDefault();
                                                userIdInput.val(user.id);
                                                selectedUserNameSpan.text((user.displayName || user.text) + ' (' + (user.email || '') + ')');
                                                selectedUserDiv.show();
                                                resultsDiv.hide();
                                                submitBtn.prop('disabled', false);
                                            });
                                        resultsDiv.append(item);
                                    }
                                });
                                if (resultsDiv.children().length === 0) {
                                    resultsDiv.append('<div class="list-group-item text-muted">No users found in system. Please ensure the user exists in Compass.</div>');
                                }
                                resultsDiv.show();
                            } else {
                                resultsDiv.append('<div class="list-group-item text-muted">No users found</div>');
                                resultsDiv.show();
                            }
                        },
                        error: function(xhr, status, error) {
                            console.error('Error searching users:', error);
                            resultsDiv.html('<div class="list-group-item text-danger">Error searching users. Please try again.</div>').show();
                        }
                    });
                }, 300);
            });

            function escapeHtml(text) {
                if (!text) return '';
                var map = {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#039;'
                };
                return text.replace(/[&<>"']/g, function(m) { return map[m]; });
            }
        });
    </script>
}

