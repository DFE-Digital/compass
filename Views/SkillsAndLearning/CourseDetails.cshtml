@model Compass.Models.TrainingCourse

@{
    ViewData["Title"] = Model.Title;
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" style="color: #005ea5; text-decoration: none;">My skills and learning</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="BrowseCourses" style="color: #005ea5; text-decoration: none;">Browse courses</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Title</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-12">
                    <h1 class="m-0">@Model.Title</h1>
                    <p class="text-muted mb-0">Course details</p>
                </div>
            </div>
        </div>
    </div>
    <div class="container-fluid">
        <div class="row">
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Course information</h3>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-3">Title:</dt>
                            <dd class="col-sm-9">@Model.Title</dd>

                            @if (!string.IsNullOrEmpty(Model.Provider))
                            {
                                <dt class="col-sm-3">Provider:</dt>
                                <dd class="col-sm-9">@Model.Provider</dd>
                            }

                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                <dt class="col-sm-3">Description:</dt>
                                <dd class="col-sm-9">@Html.Raw(Model.Description.Replace("\n", "<br />"))</dd>
                            }

                            @if (!string.IsNullOrEmpty(Model.Format))
                            {
                                <dt class="col-sm-3">Format:</dt>
                                <dd class="col-sm-9">@Model.Format</dd>
                            }

                            @if (!string.IsNullOrEmpty(Model.Duration))
                            {
                                <dt class="col-sm-3">Duration:</dt>
                                <dd class="col-sm-9">@Model.Duration</dd>
                            }

                            @if (!string.IsNullOrEmpty(Model.Prerequisites))
                            {
                                <dt class="col-sm-3">Prerequisites:</dt>
                                <dd class="col-sm-9">@Html.Raw(Model.Prerequisites.Replace("\n", "<br />"))</dd>
                            }

                            @if (!string.IsNullOrEmpty(Model.Location))
                            {
                                <dt class="col-sm-3">Locations:</dt>
                                <dd class="col-sm-9">
                                    @foreach (var location in Model.Location.Split(new[] { '\n', '\r', ',' }, StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <span class="badge badge-info mr-1 mb-1">@location.Trim()</span>
                                    }
                                </dd>
                            }

                            @if (Model.Cost.HasValue)
                            {
                                <dt class="col-sm-3">Cost:</dt>
                                <dd class="col-sm-9">£@Model.Cost.Value.ToString("N0")</dd>
                            }

                            @if (!string.IsNullOrEmpty(Model.Url))
                            {
                                <dt class="col-sm-3">More information:</dt>
                                <dd class="col-sm-9">
                                    <a href="@Model.Url" target="_blank" rel="noopener noreferrer">@Model.Url</a>
                                </dd>
                            }

                            @if (!string.IsNullOrEmpty(Model.ProfessionTags))
                            {
                                <dt class="col-sm-3">Professions:</dt>
                                <dd class="col-sm-9">@Model.ProfessionTags</dd>
                            }

                            @if (!string.IsNullOrEmpty(Model.CapabilityTags))
                            {
                                <dt class="col-sm-3">Capabilities:</dt>
                                <dd class="col-sm-9">@Model.CapabilityTags</dd>
                            }
                        </dl>
                        <div class="mt-4">
                            <a asp-action="RequestTraining" asp-route-courseId="@Model.Id" class="btn btn-success">
                                <i class="fas fa-plus"></i> Request this course
                            </a>
                            <a asp-action="BrowseCourses" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Return to courses
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

