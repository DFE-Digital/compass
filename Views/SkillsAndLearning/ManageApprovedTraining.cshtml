@model Compass.Models.TrainingRequest

@{
    ViewData["Title"] = "Manage approved training";
    var trainingRecord = ViewBag.TrainingRecord as Compass.Models.TrainingRecord;
}

@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    ViewBag.BrandText = "Skills and Learning";
    ViewBag.NavLinks = new[]
    {
        new { Text = "My skills and learning", Action = "Index", Controller = "SkillsAndLearning", Url = (string)null, IsButton = false, IsActive = currentAction == "Index" },
        new { Text = "Browse courses", Action = "BrowseCourses", Controller = "SkillsAndLearning", Url = (string)null, IsButton = false, IsActive = currentAction == "BrowseCourses" },
        new { Text = "My requests", Action = "MyRequests", Controller = "SkillsAndLearning", Url = (string)null, IsButton = false, IsActive = currentAction == "MyRequests" }
    };
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" style="color: #005ea5; text-decoration: none;">My skills and learning</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="MyRequests" style="color: #005ea5; text-decoration: none;">My requests</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Manage approved training</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        @await Html.PartialAsync("_ModuleNavbar")
        
        <div class="content-header">
            <div class="container-fluid">
                <div class="row mb-2">
                    <div class="col-sm-12">
                        <h1 class="m-0">Manage approved training</h1>
                        <p class="text-muted mb-0">Set training date, provide feedback, or request cancellation</p>
                    </div>
                </div>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-lg-8">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Training Details</h3>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Course:</dt>
                            <dd class="col-sm-8">
                                <strong>@(Model.Course?.Title ?? Model.CustomCourseTitle ?? "Custom course")</strong>
                            </dd>
                            
                            @if (!string.IsNullOrEmpty(Model.Justification))
                            {
                                <dt class="col-sm-4">Justification:</dt>
                                <dd class="col-sm-8">@Model.Justification</dd>
                            }
                            
                            <dt class="col-sm-4">Status:</dt>
                            <dd class="col-sm-8">
                                <span class="badge badge-success">Approved</span>
                            </dd>
                            
                            <dt class="col-sm-4">Approved:</dt>
                            <dd class="col-sm-8">
                                @if (Model.ApprovedAt.HasValue)
                                {
                                    @Model.ApprovedAt.Value.ToString("dd MMMM yyyy")
                                    @if (!string.IsNullOrEmpty(Model.ApprovedBy))
                                    {
                                        <br /><small class="text-muted">by @Model.ApprovedBy</small>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </dd>
                            
                            @if (Model.PlannedDate.HasValue)
                            {
                                <dt class="col-sm-4">Planned Date:</dt>
                                <dd class="col-sm-8">@Model.PlannedDate.Value.ToString("dd MMMM yyyy")</dd>
                            }
                            
                            @if (Model.CompletedDate.HasValue)
                            {
                                <dt class="col-sm-4">Completed Date:</dt>
                                <dd class="col-sm-8">@Model.CompletedDate.Value.ToString("dd MMMM yyyy")</dd>
                            }
                        </dl>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Training Completion</h3>
                    </div>
                    <div class="card-body">
                        <form asp-action="SubmitTrainingCompletion" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />

                            <div class="form-group">
                                <label for="completedDate">Training Date <span class="text-danger">@(Model.TrainingCompleted == true ? "" : "*")</span></label>
                                <input type="date" 
                                       id="completedDate" 
                                       name="completedDate" 
                                       class="form-control" 
                                       value="@(Model.CompletedDate?.ToString("yyyy-MM-dd") ?? Model.PlannedDate?.ToString("yyyy-MM-dd") ?? "")"
                                       max="@DateTime.UtcNow.ToString("yyyy-MM-dd")"
                                       @(Model.TrainingCompleted == true ? "" : "required") />
                                <small class="form-text text-muted">
                                    @if (Model.TrainingCompleted == true)
                                    {
                                        <text>Update the date if it's incorrect, or leave as is to keep the current date.</text>
                                    }
                                    else
                                    {
                                        <text>Select the date when the training took place</text>
                                    }
                                </small>
                            </div>

                            <div class="form-group">
                                <label>Rating <span class="text-danger">*</span></label>
                                <small class="form-text text-muted d-block mb-2">How would you rate this course for your professional needs?</small>
                                <div class="likert-scale">
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="outcomeRating" id="rating1" value="1" @(trainingRecord?.OutcomeRating == 1 ? "checked" : "") required />
                                        <label class="form-check-label" for="rating1">
                                            Poor
                                        </label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="outcomeRating" id="rating2" value="2" @(trainingRecord?.OutcomeRating == 2 ? "checked" : "") />
                                        <label class="form-check-label" for="rating2">
                                            Fair
                                        </label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="outcomeRating" id="rating3" value="3" @(trainingRecord?.OutcomeRating == 3 ? "checked" : "") />
                                        <label class="form-check-label" for="rating3">
                                            Good
                                        </label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="outcomeRating" id="rating4" value="4" @(trainingRecord?.OutcomeRating == 4 ? "checked" : "") />
                                        <label class="form-check-label" for="rating4">
                                            Very Good
                                        </label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="outcomeRating" id="rating5" value="5" @(trainingRecord?.OutcomeRating == 5 ? "checked" : "") />
                                        <label class="form-check-label" for="rating5">
                                            Excellent
                                        </label>
                                    </div>
                                </div>
                                @if (ViewData.ModelState["OutcomeRating"]?.Errors.Count > 0)
                                {
                                    <span class="text-danger d-block">@ViewData.ModelState["OutcomeRating"].Errors.First().ErrorMessage</span>
                                }
                            </div>

                            <div class="form-group">
                                <label for="feedback">Comment</label>
                                <textarea id="feedback" 
                                          name="feedback" 
                                          class="form-control" 
                                          rows="5" 
                                          placeholder="Share your thoughts on the training, what you learned, and how it will help you in your role">@trainingRecord?.Feedback</textarea>
                                <small class="form-text text-muted">Optional. Help others understand the value of this training.</small>
                            </div>

                            <div class="form-group">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> Save Training Details
                                </button>
                                <a asp-action="MyRequests" class="btn btn-secondary">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Actions</h3>
                    </div>
                    <div class="card-body">
                        <p>Need to cancel this training?</p>
                        <a asp-action="ManageWithdrawal" asp-route-id="@Model.Id" class="btn btn-danger btn-block">
                            <i class="fas fa-times-circle"></i> Request Cancellation
                        </a>
                        <small class="text-muted d-block mt-2">This will submit a cancellation request for admin review.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <style>
        .likert-scale {
            margin-bottom: 10px;
        }
        .likert-scale .form-check-inline {
            margin-right: 1.5rem;
        }
        .likert-scale .form-check-label {
            cursor: pointer;
            font-weight: normal;
            margin-left: 0.5rem;
        }
        .likert-scale .form-check-input {
            cursor: pointer;
        }
    </style>
}

