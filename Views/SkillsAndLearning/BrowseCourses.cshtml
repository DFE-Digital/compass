@model List<Compass.Models.TrainingCourse>

@{
    ViewData["Title"] = "Browse training courses";
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" style="color: #005ea5; text-decoration: none;">My skills and learning</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Browse courses</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-12">
                    <h1 class="m-0">Browse training courses</h1>
                    <p class="text-muted mb-0">Search and filter approved training courses</p>
                </div>
            </div>
        </div>
    </div>
    <div class="container-fluid">
        <div class="row">
            <!-- Left Column: Filters -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <!-- Filters -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Filters</h3>
                    </div>
                    <div class="card-body">
                        <form method="get" asp-action="BrowseCourses">
                            <div class="form-group">
                                <label>Search</label>
                                <input type="text" name="search" class="form-control form-control-sm" value="@ViewBag.Search" placeholder="Search courses..." />
                            </div>
                            <div class="form-group">
                                <label>Provider</label>
                                <select name="providerFilter" class="form-control form-control-sm">
                                    <option value="">All providers</option>
                                    @if (ViewBag.Providers != null)
                                    {
                                        @foreach (var provider in (List<string>)ViewBag.Providers)
                                        {
                                            <option value="@provider" selected="@(ViewBag.ProviderFilter == provider)">@provider</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Format</label>
                                <select name="formatFilter" class="form-control form-control-sm">
                                    <option value="">All formats</option>
                                    <option value="Online" selected="@(ViewBag.FormatFilter == "Online")">Online</option>
                                    <option value="Blended" selected="@(ViewBag.FormatFilter == "Blended")">Blended</option>
                                    <option value="In-person" selected="@(ViewBag.FormatFilter == "In-person")">In-person</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label>Professions</label>
                                <select name="professionFilter" class="form-control form-control-sm">
                                    <option value="">All professions</option>
                                    @if (ViewBag.Professions != null)
                                    {
                                        @foreach (var profession in (List<string>)ViewBag.Professions)
                                        {
                                            <option value="@profession" selected="@(ViewBag.ProfessionFilter == profession)">@profession</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="form-group">
                                <button type="submit" class="btn btn-primary btn-sm btn-block">Apply filters</button>
                                <a asp-action="BrowseCourses" class="btn btn-default btn-sm btn-block">Clear all filters</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Column: Courses List -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Training courses</h3>
                        <div class="card-tools">
                            <a asp-action="RequestTraining" class="text-primary" style="text-decoration: underline;">
                                Request training
                            </a>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        @if (Model.Any())
                        {
                            <table class="table table-hover text-nowrap sortable-table mb-0">
                                <thead>
                                    <tr>
                                        <th class="sortable" data-column="Title">Course title</th>
                                        <th class="sortable" data-column="Provider">Provider</th>
                                        <th class="sortable" data-column="Format">Format</th>
                                        <th class="sortable" data-column="Duration">Duration</th>
                                        <th class="sortable" data-column="Cost">Cost</th>
                                        <th class="sortable" data-column="PrimaryProfessions">Primary professions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var course in Model)
                                    {
                                        <tr>
                                            <td>
                                                <a asp-action="CourseDetails" asp-route-id="@course.Id" style="color: #005ea5; text-decoration: underline;">
                                                    <strong>@course.Title</strong>
                                                </a>
                                            </td>
                                            <td>@(course.Provider ?? "N/A")</td>
                                            <td>@(course.Format ?? "N/A")</td>
                                            <td>@(course.Duration ?? "N/A")</td>
                                            <td>@(course.Cost.HasValue ? $"£{course.Cost.Value:N0}" : "N/A")</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(course.PrimaryProfessionTags))
                                                {
                                                    var professions = course.PrimaryProfessionTags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                                                    @string.Join(", ", professions)
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        else
                        {
                            <div class="p-3">
                                <p class="text-muted mb-0">No courses found matching your filters.</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            $('.sortable-table').each(function() {
                initializeSortableTable($(this));
            });
        });

        function initializeSortableTable(table) {
            var currentSort = { column: null, direction: 'asc' };

            table.find('.sortable').on('click keypress', function(e) {
                if (e.type === 'keypress' && e.which !== 13 && e.which !== 32) {
                    return;
                }
                
                var column = $(this).data('column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(table, column, direction);
                currentSort = { column: column, direction: direction };
            });

            function sortTable(table, column, direction) {
                var tbody = table.find('tbody');
                var rows = tbody.find('tr').toArray();
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var colIndex = table.find('thead th[data-column="' + column + '"]').index();
                    
                    if (column === 'Cost') {
                        aVal = parseFloat($(a).find('td').eq(colIndex).text().replace('£', '').replace(',', '')) || 0;
                        bVal = parseFloat($(b).find('td').eq(colIndex).text().replace('£', '').replace(',', '')) || 0;
                    } else {
                        aVal = $(a).find('td').eq(colIndex).text().trim().toLowerCase();
                        bVal = $(b).find('td').eq(colIndex).text().trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.empty();
                rows.forEach(function(row) {
                    tbody.append(row);
                });
                
                updateSortIcons(table, column, direction);
            }

            function updateSortIcons(table, column, direction) {
                table.find('.sortable i').remove();
                var header = table.find('.sortable[data-column="' + column + '"]');
                var iconClass = direction === 'asc' ? 'fa-sort-up' : 'fa-sort-down';
                header.append(' <i class="fas ' + iconClass + '"></i>');
            }
        }
    </script>
}

