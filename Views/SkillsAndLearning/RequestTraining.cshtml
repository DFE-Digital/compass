@{
    ViewData["Title"] = "Request training";
}

@await Html.PartialAsync("_DashboardStyles")

@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    ViewBag.BrandText = "Skills and Learning";
    ViewBag.NavLinks = new[]
    {
        new { Text = "My skills and learning", Action = "Index", Controller = "SkillsAndLearning", Url = (string)null, IsButton = false, IsActive = currentAction == "Index" },
        new { Text = "Browse courses", Action = "BrowseCourses", Controller = "SkillsAndLearning", Url = (string)null, IsButton = false, IsActive = currentAction == "BrowseCourses" },
        new { Text = "My requests", Action = "MyRequests", Controller = "SkillsAndLearning", Url = (string)null, IsButton = false, IsActive = currentAction == "MyRequests" }
    };
}
@await Html.PartialAsync("_ModuleNavbar")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" style="color: #005ea5; text-decoration: none;">My skills and learning</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Request training</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-12">
                    <h1 class="m-0">Request training</h1>
                    <p class="text-muted mb-0">Request training from approved courses or submit a custom training request</p>
                </div>
            </div>
        </div>
    </div>
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <!-- Left Column: Form -->
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Training request form</h3>
                    </div>
                    <div class="card-body">
                        <form asp-action="RequestTraining" method="post">
                            @Html.AntiForgeryToken()
                            @if (ViewBag.NudgeId != null)
                            {
                                <input type="hidden" name="nudgeId" value="@ViewBag.NudgeId" />
                            }

                            <div class="form-group">
                                <label>Course selection</label>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="radio" name="courseSelectionType" id="courseSelectionListed" value="listed" checked>
                                    <label class="form-check-label" for="courseSelectionListed">
                                        Select from listed courses
                                    </label>
                                </div>
                                <div class="form-check mb-3">
                                    <input class="form-check-input" type="radio" name="courseSelectionType" id="courseSelectionCustom" value="custom">
                                    <label class="form-check-label" for="courseSelectionCustom">
                                        Course or training not listed
                                    </label>
                                </div>
                            </div>

                            <div id="listedCourseSection">
                                <div class="form-group">
                                    <label for="courseId">Select course</label>
                                    <select id="courseId" name="courseId" class="form-control">
                                        <option value="">-- Select a course --</option>
                                        @if (ViewBag.Courses != null)
                                        {
                                            @foreach (var course in (SelectList)ViewBag.Courses)
                                            {
                                                <option value="@course.Value" selected="@(course.Selected)">@course.Text</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>

                            <div id="customCourseSection" style="display: none;">
                                <div class="form-group">
                                    <label for="customCourseTitle">Course title <span class="text-danger">*</span></label>
                                    <input type="text" id="customCourseTitle" name="customCourseTitle" class="form-control" placeholder="Enter course title" />
                                    <small class="form-text text-muted">Required for custom courses</small>
                                </div>

                                <div class="form-group">
                                    <label for="customCourseProvider">Provider</label>
                                    <input type="text" id="customCourseProvider" name="customCourseProvider" class="form-control" placeholder="Enter provider name" />
                                </div>

                                <div class="form-group">
                                    <label for="customCourseCost">Cost</label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text">£</span>
                                        </div>
                                        <input type="number" step="0.01" min="0" id="customCourseCost" name="customCourseCost" class="form-control" placeholder="0.00" />
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label for="customCourseUrl">Link to course</label>
                                    <input type="url" id="customCourseUrl" name="customCourseUrl" class="form-control" placeholder="https://example.com/course" />
                                    <small class="form-text text-muted">URL to course information or booking page</small>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="justification">Justification <span class="text-danger">*</span></label>
                                <textarea id="justification" name="justification" class="form-control" rows="5" required placeholder="Explain why this training is needed and how it aligns with your role or capability development"></textarea>
                                <small class="form-text text-muted">Required. Explain why this training is needed.</small>
                            </div>

                            <div class="form-group">
                                <label for="professionAlignment">Profession alignment</label>
                                <textarea id="professionAlignment" name="professionAlignment" class="form-control" rows="3" placeholder="How does this training align with your profession or address capability gaps?"></textarea>
                                <small class="form-text text-muted">Optional. Link to capability gaps or profession requirements.</small>
                            </div>

                            <div class="form-group">
                                <button type="submit" class="btn btn-success">Save as draft</button>
                                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Column: Course Details -->
            <div class="col-md-4">
                <div class="card" id="courseDetailsCard" style="display: none; position: sticky; top: 20px;">
                    <div class="card-header">
                        <h3 class="card-title">Course details</h3>
                    </div>
                    <div class="card-body" id="courseDetailsContent">
                        <p class="text-muted">Select a course to view details</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Initialize based on pre-selected course
            var initialCourseId = $('#courseId').val();
            if (initialCourseId) {
                $('#courseSelectionListed').prop('checked', true);
                $('#listedCourseSection').show();
                $('#customCourseSection').hide();
                $('#customCourseTitle').prop('required', false);
                loadCourseDetails(initialCourseId);
            } else {
                $('#courseDetailsCard').hide();
            }

            // Handle course selection type change
            $('input[name="courseSelectionType"]').on('change', function() {
                var selectionType = $(this).val();
                
                if (selectionType === 'listed') {
                    $('#listedCourseSection').show();
                    $('#customCourseSection').hide();
                    $('#customCourseTitle').prop('required', false);
                    $('#courseId').prop('required', false);
                    
                    // Load course details if a course is selected
                    var courseId = $('#courseId').val();
                    if (courseId) {
                        loadCourseDetails(courseId);
                    } else {
                        $('#courseDetailsCard').hide();
                    }
                } else {
                    $('#listedCourseSection').hide();
                    $('#customCourseSection').show();
                    $('#customCourseTitle').prop('required', true);
                    $('#courseId').val('').prop('required', false);
                    $('#courseDetailsCard').hide();
                }
            });

            $('#courseId').on('change', function() {
                var courseId = $(this).val();
                
                if (courseId) {
                    loadCourseDetails(courseId);
                } else {
                    $('#courseDetailsCard').hide();
                }
            });

            // Load course details if a course is pre-selected
            @if (ViewBag.SelectedCourse != null)
            {
                <text>
                var preSelectedCourseId = $('#courseId').val();
                if (preSelectedCourseId) {
                    // Ensure listed course option is selected
                    $('#courseSelectionListed').prop('checked', true);
                    $('#listedCourseSection').show();
                    $('#customCourseSection').hide();
                    loadCourseDetails(preSelectedCourseId);
                }
                </text>
            }

            function loadCourseDetails(courseId) {
                if (!courseId) {
                    $('#courseDetailsCard').hide();
                    return;
                }

                $.ajax({
                    url: '@Url.Action("GetCourseDetails", "SkillsAndLearning")',
                    type: 'GET',
                    data: { id: courseId },
                    success: function(data) {
                        if (data.error) {
                            $('#courseDetailsCard').hide();
                            return;
                        }

                        var html = '<dl class="row mb-0">';
                        html += '<dt class="col-sm-12 mb-2"><strong>Title:</strong></dt>';
                        html += '<dd class="col-sm-12 mb-3">' + escapeHtml(data.title) + '</dd>';
                        
                        html += '<dt class="col-sm-12 mb-2"><strong>Provider:</strong></dt>';
                        html += '<dd class="col-sm-12 mb-3">' + escapeHtml(data.provider) + '</dd>';
                        
                        html += '<dt class="col-sm-12 mb-2"><strong>Cost:</strong></dt>';
                        html += '<dd class="col-sm-12 mb-3">' + (data.cost ? '£' + parseFloat(data.cost).toFixed(2) : 'N/A') + '</dd>';
                        
                        html += '<dt class="col-sm-12 mb-2"><strong>Description:</strong></dt>';
                        html += '<dd class="col-sm-12 mb-3">' + escapeHtml(data.description) + '</dd>';
                        
                        html += '<dt class="col-sm-12 mb-2"><strong>Primary Professions:</strong></dt>';
                        html += '<dd class="col-sm-12 mb-3">' + escapeHtml(data.primaryProfessions) + '</dd>';
                        
                        html += '<dt class="col-sm-12 mb-2"><strong>Secondary Professions:</strong></dt>';
                        html += '<dd class="col-sm-12 mb-3">' + escapeHtml(data.secondaryProfessions) + '</dd>';
                        
                        if (data.format && data.format !== 'N/A') {
                            html += '<dt class="col-sm-12 mb-2"><strong>Format:</strong></dt>';
                            html += '<dd class="col-sm-12 mb-3">' + escapeHtml(data.format) + '</dd>';
                        }
                        
                        if (data.duration && data.duration !== 'N/A') {
                            html += '<dt class="col-sm-12 mb-2"><strong>Duration:</strong></dt>';
                            html += '<dd class="col-sm-12 mb-3">' + escapeHtml(data.duration) + '</dd>';
                        }
                        
                        if (data.url) {
                            html += '<dt class="col-sm-12 mb-2"><strong>More Information:</strong></dt>';
                            html += '<dd class="col-sm-12 mb-3"><a href="' + escapeHtml(data.url) + '" target="_blank" class="btn btn-sm btn-outline-primary">View course details</a></dd>';
                        }
                        
                        html += '</dl>';
                        
                        $('#courseDetailsContent').html(html);
                        $('#courseDetailsCard').show();
                    },
                    error: function() {
                        $('#courseDetailsCard').hide();
                    }
                });
            }

            function escapeHtml(text) {
                if (!text) return '';
                var map = {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#039;'
                };
                return String(text).replace(/[&<>"']/g, function(m) { return map[m]; });
            }

            $('form').on('submit', function(e) {
                var selectionType = $('input[name="courseSelectionType"]:checked').val();
                var courseId = $('#courseId').val();
                var customTitle = $('#customCourseTitle').val().trim();

                if (selectionType === 'listed' && !courseId) {
                    e.preventDefault();
                    alert('Please select a course from the list.');
                    return false;
                }

                if (selectionType === 'custom' && !customTitle) {
                    e.preventDefault();
                    alert('Please enter a course title for the custom course.');
                    return false;
                }
            });
        });
    </script>
}

