@model Compass.Models.UserProfessionalProfile

@{
    ViewData["Title"] = "My professional profile";
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" style="color: #005ea5; text-decoration: none;">My skills and learning</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">My profile</li>
        </ol>
    </nav>
}

<div class="dashboard-header">
    <div>
        <h1>My professional profile</h1>
        <p>Update your profession, skills, and capability gaps</p>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Profile information</h3>
            </div>
            <div class="card-body">
                <form asp-action="UpdateProfile" method="post">
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label for="profession">DDaT profession</label>
                        <input type="text" id="profession" name="profession" class="form-control" value="@Model.Profession" placeholder="e.g., Software Developer, Product Manager, User Researcher" />
                        <small class="form-text text-muted">Your primary DDaT profession or equivalent</small>
                    </div>

                    <div class="form-group">
                        <label for="skills">Skills</label>
                        <textarea id="skills" name="skills" class="form-control" rows="5" placeholder="List your skills (comma-separated or one per line)">@Model.Skills</textarea>
                        <small class="form-text text-muted">Declared skills you have. Can be comma-separated or one per line.</small>
                    </div>

                    <div class="form-group">
                        <label for="capabilityGaps">Capability gaps</label>
                        <textarea id="capabilityGaps" name="capabilityGaps" class="form-control" rows="5" placeholder="Areas where you need development (comma-separated or one per line)">@Model.CapabilityGaps</textarea>
                        <small class="form-text text-muted">Areas where you need development. This helps us recommend relevant training.</small>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-primary">Update profile</button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

