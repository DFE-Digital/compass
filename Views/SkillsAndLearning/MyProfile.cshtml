@model Compass.Models.UserProfessionalProfile
@using Compass.Models

@{
    ViewData["Title"] = "My professional profile";
    var professions = ViewBag.Professions as List<DdatProfession> ?? new List<DdatProfession>();
    var availableSkills = ViewBag.AvailableSkills as List<Skill> ?? new List<Skill>();
    var roleFamilies = ViewBag.RoleFamilies as List<string> ?? new List<string>();
    var grades = ViewBag.Grades as List<string> ?? new List<string>();
    var activeFrameworkVersion = ViewBag.ActiveFrameworkVersion as DdatFrameworkVersion;
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" style="color: #005ea5; text-decoration: none;">My skills and learning</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">My profile</li>
        </ol>
    </nav>
}

<div class="dashboard-header">
    <div>
        <h1>My professional profile</h1>
        <p>Update your profession, role, grade, and skills</p>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }

        @if (activeFrameworkVersion == null)
        {
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle"></i> No active DDAT Framework version found. Please contact an administrator.
            </div>
        }

        @if (Model.DdatFrameworkRole != null || !string.IsNullOrEmpty(Model.SubstantiveGrade))
        {
            <div class="card mb-3">
                <div class="card-header">
                    <h3 class="card-title">Current profile</h3>
                </div>
                <div class="card-body">
                    @if (Model.DdatFrameworkRole != null)
                    {
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Role Family:</strong> @Model.DdatFrameworkRole.RoleFamily</p>
                                <p><strong>Role:</strong> @Model.DdatFrameworkRole.Role</p>
                                <p><strong>Role Level:</strong> @Model.DdatFrameworkRole.RoleLevel</p>
                            </div>
                            <div class="col-md-6">
                                @if (!string.IsNullOrEmpty(Model.SubstantiveGrade))
                                {
                                    <p><strong>Substantive Grade:</strong> @Model.SubstantiveGrade</p>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No role information set. Please complete the form below.</p>
                    }
                </div>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Update profile information</h3>
            </div>
            <div class="card-body">
                <form asp-action="UpdateProfile" method="post" id="profileForm">
                    @Html.AntiForgeryToken()

                    @if (activeFrameworkVersion != null)
                    {
                        <hr />
                        <h5>DDAT Framework Role</h5>

                        <div class="form-group">
                            <label for="roleFamily">Role Family <span class="text-danger">*</span></label>
                            <select name="roleFamily" id="roleFamily" class="form-control" required>
                                <option value="">Select role family...</option>
                                @foreach (var family in roleFamilies)
                                {
                                    var isSelected = Model.DdatFrameworkRole != null && Model.DdatFrameworkRole.RoleFamily == family;
                                    if (isSelected)
                                    {
                                        <option value="@family" selected>@family</option>
                                    }
                                    else
                                    {
                                        <option value="@family">@family</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="role">Role <span class="text-danger">*</span></label>
                            <select name="role" id="role" class="form-control" required disabled>
                                <option value="">Select role family first...</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label for="roleLevel">Role Level <span class="text-danger">*</span></label>
                            <select id="roleLevel" class="form-control" required disabled>
                                <option value="">Select role first...</option>
                            </select>
                            <input type="hidden" id="selectedRoleLevelId" name="ddatFrameworkRoleId" value="@(Model.DdatFrameworkRoleId?.ToString() ?? "")" />
                        </div>

                        <div class="form-group">
                            <label for="substantiveGrade">Substantive Grade <span class="text-danger">*</span></label>
                            <select name="substantiveGrade" id="substantiveGrade" class="form-control" required>
                                <option value="">Select your grade...</option>
                                @foreach (var grade in grades)
                                {
                                    var isSelected = Model.SubstantiveGrade == grade;
                                    if (isSelected)
                                    {
                                        <option value="@grade" selected>@grade</option>
                                    }
                                    else
                                    {
                                        <option value="@grade">@grade</option>
                                    }
                                }
                            </select>
                            <small class="form-text text-muted">Your substantive Civil Service grade</small>
                        </div>

                        <div id="roleSkillsSection" class="d-none">
                            <hr />
                            <h5>Skills Required for Your Role</h5>
                            <p class="text-muted">These are the skills required for your selected role and level, with expected capability levels based on your grade.</p>
                            <div id="roleSkillsContainer" class="table-responsive">
                                <table class="table table-bordered table-sm" id="roleSkillsTable">
                                    <thead>
                                        <tr>
                                            <th>Skill</th>
                                            <th>Required Level</th>
                                            <th>Expected Capability Level</th>
                                            <th>Description</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <!-- Populated via JavaScript -->
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                    <hr />
                    <h5>Additional Skills</h5>
                    <p class="text-muted">Add skills from outside your profession skill set.</p>

                    <div class="form-group">
                        <label>Add Additional Skill</label>
                        <div class="row mb-2">
                            <div class="col-md-6">
                                <select id="additionalSkillSelect" class="form-control">
                                    <option value="">Select a skill to add...</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <button type="button" class="btn btn-sm btn-primary" id="addAdditionalSkillBtn">
                                    <i class="fas fa-plus"></i> Add skill
                                </button>
                            </div>
                        </div>
                        <div id="additionalSkillsTableWrapper" class="@(Model.AdditionalDdatFrameworkSkills.Any() ? "" : "d-none")">
                            <table class="table table-bordered table-sm" id="additionalSkillsTable">
                                <thead>
                                    <tr>
                                        <th>Skill</th>
                                        <th style="width: 100px;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var additionalSkill in Model.AdditionalDdatFrameworkSkills)
                                    {
                                        <tr data-skill-id="@additionalSkill.DdatFrameworkSkillId" data-skill-name="@(additionalSkill.DdatFrameworkSkill?.SkillName ?? "")">
                                            <td>@(additionalSkill.DdatFrameworkSkill?.SkillName ?? "Unknown")</td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-danger remove-skill-btn">
                                                    <i class="fas fa-trash"></i> Remove
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div id="noAdditionalSkillsMessage" class="@(Model.AdditionalDdatFrameworkSkills.Any() ? "d-none" : "") text-muted">
                            No additional skills added yet. Select a skill above and click "Add skill".
                        </div>
                    </div>

                    <hr />
                    <h5>Capability Gaps</h5>

                    <div class="form-group">
                        <label>Capability gaps</label>
                        <div class="row mb-2">
                            <div class="col-md-10">
                                <input type="text" id="capabilityGapInput" class="form-control" placeholder="Enter a capability gap description..." />
                            </div>
                            <div class="col-md-2">
                                <button type="button" class="btn btn-sm btn-primary" id="addCapabilityGapBtn">
                                    <i class="fas fa-plus"></i> Add gap
                                </button>
                            </div>
                        </div>
                        <div id="capabilityGapsTableWrapper" class="@(Model.CapabilityGaps.Any() ? "" : "d-none")">
                            <table class="table table-bordered table-sm" id="capabilityGapsTable">
                                <thead>
                                    <tr>
                                        <th>Description</th>
                                        <th>Linked task</th>
                                        <th style="width: 120px;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var gap in Model.CapabilityGaps)
                                    {
                                        <tr data-gap-id="@gap.Id">
                                            <td>
                                                <input type="hidden" name="capabilityGapIds" value="@gap.Id" />
                                                <input type="text" name="capabilityGapDescriptions" class="form-control form-control-sm" value="@gap.Description" />
                                            </td>
                                            <td>
                                                @if (gap.Action != null)
                                                {
                                                    <a href="@Url.Action("Details", "Action", new { id = gap.Action.Id })" class="btn btn-sm btn-outline-info" target="_blank">
                                                        <i class="fas fa-external-link-alt"></i> View task
                                                    </a>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">No task linked</span>
                                                }
                                            </td>
                                            <td>
                                                <button type="button" class="btn btn-sm btn-danger remove-gap-btn">
                                                    <i class="fas fa-trash"></i> Remove
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div id="noGapsMessage" class="@(Model.CapabilityGaps.Any() ? "d-none" : "") text-muted">
                            No capability gaps added yet. Enter a gap above and click "Add gap".
                        </div>
                        <small class="form-text text-muted">Areas where you need development. You can link tasks/actions to track progress on addressing these gaps.</small>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-success">Update profile</button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            var selectedAdditionalSkillIds = [];
            var selectedAdditionalSkillNames = [];
            var currentRoleId = null;
            var currentGrade = null;

            // Initialize selected skills from table
            $('#additionalSkillsTable tbody tr').each(function() {
                var skillId = parseInt($(this).data('skill-id'));
                var skillName = $(this).data('skill-name');
                if (skillId) {
                    selectedAdditionalSkillIds.push(skillId);
                }
                if (skillName) {
                    selectedAdditionalSkillNames.push(skillName);
                }
            });

            // Load DDAT Framework Skills for additional skills dropdown
            function loadAdditionalSkills() {
                $.ajax({
                    url: '@Url.Action("GetDdatFrameworkSkills", "SkillsAndLearning")',
                    type: 'GET',
                    success: function(data) {
                        var $select = $('#additionalSkillSelect');
                        $select.empty().append('<option value="">Select a skill to add...</option>');
                        data.forEach(function(skill) {
                            if (!selectedAdditionalSkillIds.includes(skill.id)) {
                                $select.append('<option value="' + skill.id + '" data-name="' + escapeHtml(skill.skillName) + '">' + escapeHtml(skill.skillName) + '</option>');
                            }
                        });
                    },
                    error: function() {
                        console.error('Failed to load DDAT Framework Skills');
                    }
                });
            }

            // Load role families on page load if role is already selected
            @if (Model.DdatFrameworkRoleId.HasValue && Model.DdatFrameworkRole != null)
            {
                <text>
                var selectedRoleFamily = '@Html.Raw(Model.DdatFrameworkRole.RoleFamily.Replace("'", "\\'"))';
                var selectedRole = '@Html.Raw(Model.DdatFrameworkRole.Role.Replace("'", "\\'"))';
                var selectedRoleId = @Model.DdatFrameworkRoleId.Value;
                var selectedGrade = '@Html.Raw((Model.SubstantiveGrade ?? "").Replace("'", "\\'"))';
                
                if (selectedRoleFamily) {
                    // Set role family and trigger change to load roles
                    $('#roleFamily').val(selectedRoleFamily);
                    $('#roleFamily').trigger('change');
                    
                    // Wait for roles to load, then set role
                    setTimeout(function() {
                        if (selectedRole) {
                            var $roleSelect = $('#role');
                            // Check if the role option exists, if not wait a bit more
                            if ($roleSelect.find('option[value="' + selectedRole + '"]').length > 0) {
                                $roleSelect.val(selectedRole);
                                $roleSelect.trigger('change');
                                
                                // Wait for role levels to load, then set role level
                                setTimeout(function() {
                                    var $roleLevelSelect = $('#roleLevel');
                                    if ($roleLevelSelect.find('option[value="' + selectedRoleId + '"]').length > 0) {
                                        $roleLevelSelect.val(selectedRoleId);
                                        $('#selectedRoleLevelId').val(selectedRoleId);
                                        currentRoleId = selectedRoleId;
                                        
                                        if (selectedGrade) {
                                            $('#substantiveGrade').val(selectedGrade);
                                            loadRoleSkills(selectedRoleId, selectedGrade);
                                        }
                                    }
                                }, 800);
                            } else {
                                // Retry after a bit more time
                                setTimeout(function() {
                                    if ($roleSelect.find('option[value="' + selectedRole + '"]').length > 0) {
                                        $roleSelect.val(selectedRole);
                                        $roleSelect.trigger('change');
                                        setTimeout(function() {
                                            var $roleLevelSelect = $('#roleLevel');
                                            if ($roleLevelSelect.find('option[value="' + selectedRoleId + '"]').length > 0) {
                                                $roleLevelSelect.val(selectedRoleId);
                                                $('#selectedRoleLevelId').val(selectedRoleId);
                                                currentRoleId = selectedRoleId;
                                                if (selectedGrade) {
                                                    $('#substantiveGrade').val(selectedGrade);
                                                    loadRoleSkills(selectedRoleId, selectedGrade);
                                                }
                                            }
                                        }, 800);
                                    }
                                }, 500);
                            }
                        }
                    }, 800);
                }
                </text>
            }

            // Role Family change handler
            $('#roleFamily').on('change', function() {
                var roleFamily = $(this).val();
                $('#role').empty().append('<option value="">Select role family first...</option>').prop('disabled', true);
                $('#roleLevel').empty().append('<option value="">Select role first...</option>').prop('disabled', true);
                $('#roleSkillsSection').addClass('d-none');
                currentRoleId = null;

                if (roleFamily) {
                    $.ajax({
                        url: '@Url.Action("GetDdatRolesByFamily", "SkillsAndLearning")',
                        type: 'GET',
                        data: { roleFamily: roleFamily },
                        success: function(data) {
                            var $select = $('#role');
                            $select.empty().append('<option value="">Select a role...</option>');
                            data.forEach(function(role) {
                                $select.append('<option value="' + escapeHtml(role) + '">' + escapeHtml(role) + '</option>');
                            });
                            $select.prop('disabled', false);
                        },
                        error: function() {
                            alert('Failed to load roles');
                        }
                    });
                }
            });

            // Role change handler
            $('#role').on('change', function() {
                var role = $(this).val();
                var roleFamily = $('#roleFamily').val();
                $('#roleLevel').empty().append('<option value="">Select role first...</option>').prop('disabled', true);
                $('#roleSkillsSection').addClass('d-none');
                currentRoleId = null;

                if (role && roleFamily) {
                    $.ajax({
                        url: '@Url.Action("GetDdatRoleLevelsByRole", "SkillsAndLearning")',
                        type: 'GET',
                        data: { roleFamily: roleFamily, role: role },
                        success: function(data) {
                            var $select = $('#roleLevel');
                            $select.empty().append('<option value="">Select a role level...</option>');
                            data.forEach(function(level) {
                                $select.append('<option value="' + level.id + '">' + escapeHtml(level.roleLevel) + '</option>');
                            });
                            $select.prop('disabled', false);
                        },
                        error: function() {
                            alert('Failed to load role levels');
                        }
                    });
                }
            });

            // Role Level change handler
            $('#roleLevel').on('change', function() {
                currentRoleId = $(this).val();
                $('#selectedRoleLevelId').val(currentRoleId);
                currentGrade = $('#substantiveGrade').val();
                
                if (currentRoleId && currentGrade) {
                    loadRoleSkills(currentRoleId, currentGrade);
                } else {
                    $('#roleSkillsSection').addClass('d-none');
                }
            });

            // Grade change handler
            $('#substantiveGrade').on('change', function() {
                currentGrade = $(this).val();
                
                if (currentRoleId && currentGrade) {
                    loadRoleSkills(currentRoleId, currentGrade);
                } else {
                    $('#roleSkillsSection').addClass('d-none');
                }
            });

            // Load role skills
            function loadRoleSkills(roleId, grade) {
                $.ajax({
                    url: '@Url.Action("GetDdatSkillsForRole", "SkillsAndLearning")',
                    type: 'GET',
                    data: { roleId: roleId, grade: grade },
                    success: function(data) {
                        var $tbody = $('#roleSkillsTable tbody');
                        $tbody.empty();
                        
                        if (data && data.length > 0) {
                            data.forEach(function(skill) {
                                var levelBadgeClass = 'badge-secondary';
                                if (skill.requiredLevel) {
                                    var level = skill.requiredLevel.toLowerCase();
                                    if (level === 'awareness') levelBadgeClass = 'badge-secondary';
                                    else if (level === 'working') levelBadgeClass = 'badge-info';
                                    else if (level === 'practitioner') levelBadgeClass = 'badge-success';
                                    else if (level === 'expert') levelBadgeClass = 'badge-warning';
                                }
                                
                                var row = '<tr>' +
                                    '<td><strong>' + escapeHtml(skill.skillName) + '</strong>' +
                                    (skill.skillDescription ? '<br><small class="text-muted">' + escapeHtml(skill.skillDescription) + '</small>' : '') + '</td>' +
                                    '<td><span class="badge ' + levelBadgeClass + '">' + escapeHtml(skill.requiredLevel || 'N/A') + '</span></td>' +
                                    '<td>' + (skill.expectedCapabilityLevel ? '<span class="badge badge-primary">' + escapeHtml(skill.expectedCapabilityLevel) + '</span>' : '<span class="text-muted">N/A</span>') + '</td>' +
                                    '<td><small>' + escapeHtml(skill.levelDescription || 'No description') + '</small></td>' +
                                    '</tr>';
                                $tbody.append(row);
                            });
                            $('#roleSkillsSection').removeClass('d-none');
                        } else {
                            $('#roleSkillsSection').addClass('d-none');
                        }
                    },
                    error: function() {
                        alert('Failed to load role skills');
                    }
                });
            }

            // Add additional skill
            $('#addAdditionalSkillBtn').on('click', function() {
                var select = $('#additionalSkillSelect');
                var selectedOption = select.find('option:selected');
                var skillId = parseInt(selectedOption.val());
                var skillName = selectedOption.data('name');

                if (!skillId) {
                    alert('Please select a skill to add.');
                    return;
                }

                if (selectedAdditionalSkillIds.includes(skillId)) {
                    alert('This skill has already been added.');
                    return;
                }

                selectedAdditionalSkillIds.push(skillId);
                selectedAdditionalSkillNames.push(skillName);

                var newRow = '<tr data-skill-id="' + skillId + '" data-skill-name="' + escapeHtml(skillName) + '">' +
                    '<td>' + escapeHtml(skillName) + '</td>' +
                    '<td>' +
                    '<button type="button" class="btn btn-sm btn-danger remove-skill-btn">' +
                    '<i class="fas fa-trash"></i> Remove' +
                    '</button>' +
                    '</td>' +
                    '</tr>';

                $('#additionalSkillsTable tbody').append(newRow);
                $('#additionalSkillsTableWrapper').removeClass('d-none');
                $('#noAdditionalSkillsMessage').addClass('d-none');
                select.val('').trigger('change');
                loadAdditionalSkills(); // Reload to remove selected skill
                updateHiddenSkillInputs();
            });

            // Remove additional skill
            $(document).on('click', '.remove-skill-btn', function() {
                var row = $(this).closest('tr');
                var skillId = parseInt(row.data('skill-id'));
                var skillName = row.data('skill-name');

                selectedAdditionalSkillIds = selectedAdditionalSkillIds.filter(function(id) {
                    return id !== skillId;
                });
                selectedAdditionalSkillNames = selectedAdditionalSkillNames.filter(function(name) {
                    return name !== skillName;
                });

                row.remove();

                if ($('#additionalSkillsTable tbody tr').length === 0) {
                    $('#additionalSkillsTableWrapper').addClass('d-none');
                    $('#noAdditionalSkillsMessage').removeClass('d-none');
                }

                loadAdditionalSkills(); // Reload to add skill back to dropdown
                updateHiddenSkillInputs();
            });

            // Update hidden inputs for additional skills
            function updateHiddenSkillInputs() {
                $('input[name="selectedDdatFrameworkSkillIds"]').remove();
                selectedAdditionalSkillIds.forEach(function(skillId) {
                    $('#profileForm').append('<input type="hidden" name="selectedDdatFrameworkSkillIds" value="' + skillId + '" />');
                });
            }

            // Initialize hidden inputs
            updateHiddenSkillInputs();

            // Form submission - ensure skills are included
            $('#profileForm').on('submit', function() {
                updateHiddenSkillInputs();
            });

            // Add capability gap
            $('#addCapabilityGapBtn').on('click', function() {
                var input = $('#capabilityGapInput');
                var description = input.val().trim();

                if (!description) {
                    alert('Please enter a capability gap description.');
                    return;
                }

                var newRow = '<tr data-gap-id="0">' +
                    '<td>' +
                    '<input type="hidden" name="capabilityGapIds" value="0" />' +
                    '<input type="text" name="capabilityGapDescriptions" class="form-control form-control-sm" value="' + escapeHtml(description) + '" />' +
                    '</td>' +
                    '<td><span class="text-muted">No task linked</span></td>' +
                    '<td>' +
                    '<button type="button" class="btn btn-sm btn-danger remove-gap-btn">' +
                    '<i class="fas fa-trash"></i> Remove' +
                    '</button>' +
                    '</td>' +
                    '</tr>';

                $('#capabilityGapsTable tbody').append(newRow);
                $('#capabilityGapsTableWrapper').removeClass('d-none');
                $('#noGapsMessage').addClass('d-none');
                input.val('');
            });

            // Remove capability gap
            $(document).on('click', '.remove-gap-btn', function() {
                var row = $(this).closest('tr');
                row.remove();

                if ($('#capabilityGapsTable tbody tr').length === 0) {
                    $('#capabilityGapsTableWrapper').addClass('d-none');
                    $('#noGapsMessage').removeClass('d-none');
                }
            });

            // Escape HTML helper
            function escapeHtml(text) {
                var map = {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#039;'
                };
                return text.replace(/[&<>"']/g, function(m) { return map[m]; });
            }

            // Initialize
            loadAdditionalSkills();
        });
    </script>
}
