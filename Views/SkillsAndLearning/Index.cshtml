@model Compass.Models.UserProfessionalProfile
@using Compass.Models

@{
    ViewData["Title"] = "My skills and learning";
    var professions = ViewBag.Professions as List<DdatProfession> ?? new List<DdatProfession>();
    var availableSkills = ViewBag.AvailableSkills as List<Skill> ?? new List<Skill>();
    var roleFamilies = ViewBag.RoleFamilies as List<string> ?? new List<string>();
    var grades = ViewBag.Grades as List<string> ?? new List<string>();
    var activeFrameworkVersion = ViewBag.ActiveFrameworkVersion as DdatFrameworkVersion;
}

@await Html.PartialAsync("_DashboardStyles")

@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    ViewBag.BrandText = "Skills and Learning";
    ViewBag.NavLinks = new[]
    {
        new { Text = "My skills and learning", Action = "Index", Controller = "SkillsAndLearning", Url = (string)null, IsButton = false, IsActive = currentAction == "Index" },
        new { Text = "Browse courses", Action = "BrowseCourses", Controller = "SkillsAndLearning", Url = (string)null, IsButton = false, IsActive = currentAction == "BrowseCourses" },
        new { Text = "My requests", Action = "MyRequests", Controller = "SkillsAndLearning", Url = (string)null, IsButton = false, IsActive = currentAction == "MyRequests" }
    };
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">My skills and learning</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="container-fluid">
        @await Html.PartialAsync("_ModuleNavbar")
        
        <div class="content-header">
            <div class="container-fluid">
                <div class="row mb-2">
                    <div class="col-sm-12">
                        <h1 class="m-0">My skills and learning</h1>
                        <p class="text-muted mb-0">Manage your professional profile, browse training courses, request training, and track your requests</p>
                    </div>
                </div>
            </div>
        </div>
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <!-- Quick Actions -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card border-left-primary shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Browse courses</div>
                                <div class="h6 mb-0 font-weight-bold text-gray-800">Training library</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-book fa-2x text-gray-300"></i>
                            </div>
                        </div>
                        <div class="mt-3">
                            <a asp-action="BrowseCourses" class="btn btn-primary btn-sm btn-block">Browse courses</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-left-success shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Request training</div>
                                <div class="h6 mb-0 font-weight-bold text-gray-800">New request</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-plus-circle fa-2x text-gray-300"></i>
                            </div>
                        </div>
                        <div class="mt-3">
                            <a asp-action="RequestTraining" class="btn btn-success btn-sm btn-block">Request training</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-left-info shadow h-100">
                    <div class="card-body">
                        <div class="row no-gutters align-items-center">
                            <div class="col mr-2">
                                <div class="text-xs font-weight-bold text-info text-uppercase mb-1">My requests</div>
                                <div class="h6 mb-0 font-weight-bold text-gray-800">View all</div>
                            </div>
                            <div class="col-auto">
                                <i class="fas fa-clipboard-list fa-2x text-gray-300"></i>
                            </div>
                        </div>
                        <div class="mt-3">
                            <a asp-action="MyRequests" class="btn btn-info btn-sm btn-block">View requests</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Professional Profile Summary -->
        @if (Model != null)
        {
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Professional profile</h3>
                            <div class="card-tools">
                                <a class="text-primary" style="text-decoration: underline;" asp-action="MyProfile">
                                    Update profile
                                </a>
                            </div>
                        </div>
                        <div class="card-body">
                            @{
                                var hasRoleOrGrade = Model.DdatFrameworkRole != null || !string.IsNullOrEmpty(Model.SubstantiveGrade);
                            }
                            @if (hasRoleOrGrade)
                            {
                                <div class="row">
                                    @if (Model.DdatProfession != null)
                                    {
                                        <div class="col-md-3 mb-3">
                                            <strong>Profession:</strong><br>
                                            <span>@Model.DdatProfession.Name</span>
                                        </div>
                                    }
                                    @if (Model.DdatFrameworkRole != null)
                                    {
                                        <div class="col-md-3 mb-3">
                                            <strong>Role:</strong><br>
                                            <span>@Model.DdatFrameworkRole.Role (@Model.DdatFrameworkRole.RoleLevel)</span><br>
                                            <small class="text-muted">@Model.DdatFrameworkRole.RoleFamily</small>
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(Model.SubstantiveGrade))
                                    {
                                        <div class="col-md-3 mb-3">
                                            <strong>Grade:</strong><br>
                                            <span>@Model.SubstantiveGrade</span>
                                        </div>
                                    }
                                    @if (Model.DdatFrameworkRole != null && ViewBag.HeadOfProfession != null)
                                    {
                                        <div class="col-md-3 mb-3">
                                            <strong>Head of Profession:</strong><br>
                                            <span>@(((Compass.Models.User)ViewBag.HeadOfProfession).Name)</span>
                                            @if (!string.IsNullOrEmpty(((Compass.Models.User)ViewBag.HeadOfProfession).Email))
                                            {
                                                <br><small class="text-muted">@(((Compass.Models.User)ViewBag.HeadOfProfession).Email)</small>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-info">
                                    <i class="fas fa-info-circle"></i> <strong>Set your role and skills up</strong><br>
                                    <p class="mb-0 mt-2">To get personalised training recommendations, please set your role and grade in your profile.</p>
                                    <a asp-action="MyProfile" class="btn btn-sm btn-primary mt-2">
                                        <i class="fas fa-user-cog"></i> Set up profile
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Upcoming Approved Training -->
        @if (ViewBag.UpcomingTraining != null && ((List<Compass.Models.TrainingRequest>)ViewBag.UpcomingTraining).Any())
        {
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Upcoming approved training</h3>
                        </div>
                        <div class="card-body p-0">
                            <table class="table table-hover text-nowrap sortable-table mb-0">
                                <thead>
                                    <tr>
                                        <th>Course</th>
                                        <th>Provider</th>
                                        <th>Method</th>
                                        <th>Date booked</th>
                                        <th>Planned date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var training in (List<Compass.Models.TrainingRequest>)ViewBag.UpcomingTraining)
                                    {
                                        <tr>
                                            <td>
                                                <a asp-action="MyRequests" style="color: #005ea5; text-decoration: underline;">
                                                    @if (training.Course != null)
                                                    {
                                                        @training.Course.Title
                                                    }
                                                    else if (!string.IsNullOrWhiteSpace(training.CustomCourseTitle))
                                                    {
                                                        @training.CustomCourseTitle
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Custom course</span>
                                                    }
                                                </a>
                                            </td>
                                            <td>
                                                @if (training.Course != null && !string.IsNullOrWhiteSpace(training.Course.Provider))
                                                {
                                                    @training.Course.Provider
                                                }
                                                else if (!string.IsNullOrWhiteSpace(training.CustomCourseProvider))
                                                {
                                                    @training.CustomCourseProvider
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (training.Course != null && !string.IsNullOrWhiteSpace(training.Course.Mode))
                                                {
                                                    @training.Course.Mode
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>
                                                @training.CreatedAt.ToString("dd MMM yyyy")
                                            </td>
                                            <td>
                                                @if (training.PlannedDate.HasValue)
                                                {
                                                    @training.PlannedDate.Value.ToString("dd MMM yyyy")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">TBC</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Training Recommendations (Nudges) -->
        @if (ViewBag.Nudges != null && ((List<Compass.Models.TrainingNudge>)ViewBag.Nudges).Any())
        {
            <div class="row mt-4">
                <div class="col-12">
                    <div class="card border-left-info">
                        <div class="card-header">
                            <h3 class="card-title">
                                <i class="fas fa-lightbulb"></i> Recommended training for you
                            </h3>
                        </div>
                        <div class="card-body">
                            @foreach (var nudge in (List<Compass.Models.TrainingNudge>)ViewBag.Nudges)
                            {
                                <div class="alert alert-info alert-dismissible fade show mb-3" role="alert">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="flex-grow-1">
                                            <h5 class="alert-heading">
                                                <i class="fas fa-graduation-cap"></i> @(nudge.Course?.Title ?? "Course")
                                            </h5>
                                            <p class="mb-2">
                                                <strong>Why this is recommended:</strong> @nudge.Reason
                                                @if (!string.IsNullOrEmpty(nudge.CapabilityGap))
                                                {
                                                    <br><small>Addresses capability gap: @nudge.CapabilityGap</small>
                                                }
                                            </p>
                                            <div>
                                                <form asp-action="AcceptNudge" method="post" style="display: inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@nudge.Id" />
                                                    <button type="submit" class="btn btn-sm btn-success">
                                                        <i class="fas fa-check"></i> Request this training
                                                    </button>
                                                </form>
                                                <form asp-action="DismissNudge" method="post" style="display: inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@nudge.Id" />
                                                    <button type="submit" class="btn btn-sm btn-secondary">
                                                        <i class="fas fa-times"></i> Dismiss
                                                    </button>
                                                </form>
                                                @if (nudge.Course != null)
                                                {
                                                    <a asp-action="CourseDetails" asp-route-id="@nudge.Course.Id" class="btn btn-sm btn-info">
                                                        <i class="fas fa-info-circle"></i> View details
                                                    </a>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

    </div>
</section>

<style>
    .border-left-primary {
        border-left: 0.25rem solid #4e73df !important;
    }
    .border-left-success {
        border-left: 0.25rem solid #1cc88a !important;
    }
    .border-left-info {
        border-left: 0.25rem solid #36b9cc !important;
    }
    .border-left-warning {
        border-left: 0.25rem solid #f6c23e !important;
    }
    .text-gray-800 {
        color: #5a5c69 !important;
    }
    .text-gray-300 {
        color: #dddfeb !important;
    }
</style>


