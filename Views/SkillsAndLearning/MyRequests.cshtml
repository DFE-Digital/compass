@model List<Compass.Models.TrainingRequest>

@{
    ViewData["Title"] = "My training requests";
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" style="color: #005ea5; text-decoration: none;">My skills and learning</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">My requests</li>
        </ol>
    </nav>
}

<div class="dashboard-header">
    <div>
        <h1>My training requests</h1>
        <p>View and manage your training requests</p>
    </div>
    <div>
        <a asp-action="RequestTraining" class="btn btn-success">
            <i class="fas fa-plus"></i> New request
        </a>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }

        <div class="row">
            <!-- Left Column: Filters -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <!-- Filters -->
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Filters</h3>
                    </div>
                    <div class="card-body">
                        <form method="get" asp-action="MyRequests">
                            <div class="form-group">
                                <label>Status</label>
                                <select name="statusFilter" class="form-control form-control-sm">
                                    <option value="">All</option>
                                    <option value="Draft" selected="@(ViewBag.StatusFilter == "Draft")">Draft</option>
                                    <option value="Submitted" selected="@(ViewBag.StatusFilter == "Submitted")">Submitted</option>
                                    <option value="Approved" selected="@(ViewBag.StatusFilter == "Approved")">Approved</option>
                                    <option value="Rejected" selected="@(ViewBag.StatusFilter == "Rejected")">Rejected</option>
                                    <option value="On-hold" selected="@(ViewBag.StatusFilter == "On-hold")">On-hold</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <button type="submit" class="btn btn-primary btn-sm btn-block">Apply filters</button>
                                <a asp-action="MyRequests" class="btn btn-default btn-sm btn-block">Clear all filters</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Right Column: Requests List -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <div class="card">
            <div class="card-header">
                <h3 class="card-title">Training requests (@Model.Count)</h3>
            </div>
            <div class="card-body p-0">
                @if (Model.Any())
                {
                    <table class="table table-hover mb-0 sortable-table">
                        <thead>
                            <tr>
                                <th class="sortable" data-column="Course">Course</th>
                                <th class="sortable" data-column="Status">Status</th>
                                <th class="sortable" data-column="CreatedAt">Requested</th>
                                <th class="sortable" data-column="ApprovedAt">Approved/Rejected</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@(request.Course?.Title ?? request.CustomCourseTitle ?? "Custom course")</strong>
                                        @if (!string.IsNullOrEmpty(request.Justification))
                                        {
                                            <br><small class="text-muted">@(request.Justification.Length > 100 ? request.Justification.Substring(0, 100) + "..." : request.Justification)</small>
                                        }
                                    </td>
                                    <td>
                                        @switch (request.Status)
                                        {
                                            case "Draft":
                                                <span class="badge badge-secondary">Draft</span>
                                                break;
                                            case "Submitted":
                                                <span class="badge badge-info">Submitted</span>
                                                break;
                                            case "Approved":
                                                <span class="badge badge-success">Approved</span>
                                                break;
                                            case "Rejected":
                                                <span class="badge badge-danger">Rejected</span>
                                                break;
                                            case "On-hold":
                                                <span class="badge badge-warning">On-hold</span>
                                                break;
                                            default:
                                                <span class="badge badge-secondary">@request.Status</span>
                                                break;
                                        }
                                    </td>
                                    <td>@request.CreatedAt.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if (request.ApprovedAt.HasValue)
                                        {
                                            @request.ApprovedAt.Value.ToString("dd MMM yyyy")
                                            @if (!string.IsNullOrEmpty(request.ApprovedBy))
                                            {
                                                <br><small class="text-muted">by @request.ApprovedBy</small>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (request.Status == "Draft")
                                        {
                                            <a asp-action="EditRequest" asp-route-id="@request.Id" class="btn btn-sm btn-warning">Edit</a>
                                            <form asp-action="SubmitRequest" method="post" style="display: inline;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@request.Id" />
                                                <button type="submit" class="btn btn-sm btn-primary">Submit</button>
                                            </form>
                                            <form asp-action="WithdrawRequest" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to withdraw this request?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@request.Id" />
                                                <button type="submit" class="btn btn-sm btn-danger">Withdraw</button>
                                            </form>
                                        }
                                        else if (request.Status == "Submitted")
                                        {
                                            <form asp-action="WithdrawRequest" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to withdraw this request?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@request.Id" />
                                                <button type="submit" class="btn btn-sm btn-danger">Withdraw</button>
                                            </form>
                                        }
                                        @if (!string.IsNullOrEmpty(request.ApproverComments))
                                        {
                                            <button type="button" class="btn btn-sm btn-info" data-toggle="modal" data-target="#commentsModal@(request.Id)">Comments</button>
                                        }
                                    </td>
                                </tr>
                                @if (!string.IsNullOrEmpty(request.ApproverComments))
                                {
                                    <div class="modal fade" id="commentsModal@(request.Id)" tabindex="-1" role="dialog">
                                        <div class="modal-dialog" role="document">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Approver comments</h5>
                                                    <button type="button" class="close" data-dismiss="modal">
                                                        <span>&times;</span>
                                                    </button>
                                                </div>
                                                <div class="modal-body">
                                                    <p>@request.ApproverComments</p>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-3">
                        <p class="text-muted mb-0">No training requests found.</p>
                        <a asp-action="RequestTraining" class="btn btn-primary mt-2">Create your first request</a>
                    </div>
                }
            </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            $('.sortable-table').each(function() {
                initializeSortableTable($(this));
            });
        });

        function initializeSortableTable(table) {
            var currentSort = { column: null, direction: 'asc' };

            table.find('.sortable').on('click keypress', function(e) {
                if (e.type === 'keypress' && e.which !== 13 && e.which !== 32) {
                    return;
                }
                
                var column = $(this).data('column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(table, column, direction);
                currentSort = { column: column, direction: direction };
            });

            function sortTable(table, column, direction) {
                var tbody = table.find('tbody');
                var rows = tbody.find('tr').toArray();
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var colIndex = table.find('thead th[data-column="' + column + '"]').index();
                    
                    if (column === 'CreatedAt' || column === 'ApprovedAt') {
                        var aDate = $(a).find('td').eq(colIndex).text().trim();
                        var bDate = $(b).find('td').eq(colIndex).text().trim();
                        aVal = new Date(aDate);
                        bVal = new Date(bDate);
                    } else {
                        aVal = $(a).find('td').eq(colIndex).text().trim().toLowerCase();
                        bVal = $(b).find('td').eq(colIndex).text().trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.empty();
                rows.forEach(function(row) {
                    tbody.append(row);
                });
                
                updateSortIcons(table, column, direction);
            }

            function updateSortIcons(table, column, direction) {
                table.find('.sortable i').remove();
                var header = table.find('.sortable[data-column="' + column + '"]');
                var iconClass = direction === 'asc' ? 'fa-sort-up' : 'fa-sort-down';
                header.append(' <i class="fas ' + iconClass + '"></i>');
            }
        }
    </script>
}

