@model List<Compass.Models.TrainingRequest>

@{
    ViewData["Title"] = "My training requests";
}

@await Html.PartialAsync("_DashboardStyles")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" style="color: #005ea5; text-decoration: none;">My skills and learning</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">My requests</li>
        </ol>
    </nav>
}

<section class="content">
    <div class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-12">
                    <h1 class="m-0">My training requests</h1>
                    <p class="text-muted mb-0">View and manage your training requests</p>
                </div>
            </div>
        </div>
    </div>
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }

        <div class="row">
            <!-- Left Column: Navigation -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title">Status</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <a asp-action="MyRequests" asp-route-statusFilter="Submitted" 
                               class="list-group-item list-group-item-action @(ViewBag.StatusFilter == "Submitted" ? "active" : "")">
                                Submitted
                                <span class="badge badge-light float-right">@ViewBag.SubmittedCount</span>
                            </a>
                            <a asp-action="MyRequests" asp-route-statusFilter="Approved" 
                               class="list-group-item list-group-item-action @(ViewBag.StatusFilter == "Approved" ? "active" : "")">
                                Approved
                                <span class="badge badge-light float-right">@ViewBag.ApprovedCount</span>
                            </a>
                            <a asp-action="MyRequests" asp-route-statusFilter="Rejected" 
                               class="list-group-item list-group-item-action @(ViewBag.StatusFilter == "Rejected" ? "active" : "")">
                                Rejected
                                <span class="badge badge-light float-right">@ViewBag.RejectedCount</span>
                            </a>
                            <a asp-action="MyRequests" asp-route-statusFilter="Cancelled" 
                               class="list-group-item list-group-item-action @(ViewBag.StatusFilter == "Cancelled" ? "active" : "")">
                                Cancelled
                                <span class="badge badge-light float-right">@ViewBag.CancelledCount</span>
                            </a>
                            <a asp-action="MyRequests" asp-route-statusFilter="Completed" 
                               class="list-group-item list-group-item-action @(ViewBag.StatusFilter == "Completed" ? "active" : "")">
                                Completed
                                <span class="badge badge-light float-right">@ViewBag.CompletedCount</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Requests List -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <div class="card">
            <div class="card-header">
                <h3 class="card-title">Training requests (@Model.Count)</h3>
                <div class="card-tools">
                    <a asp-action="RequestTraining" class="text-primary" style="text-decoration: underline;">
                        New request
                    </a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (Model.Any())
                {
                    <table class="table table-hover text-nowrap sortable-table mb-0">
                        <thead>
                            <tr>
                                <th class="sortable" data-column="Course">Course</th>
                                <th class="sortable" data-column="Status">Status</th>
                                <th class="sortable" data-column="CreatedAt">Requested</th>
                                <th class="sortable" data-column="ApprovedAt">Approved/Rejected</th>
                                @if (ViewBag.StatusFilter == "Approved" || ViewBag.StatusFilter == "Completed")
                                {
                                    <th class="sortable" data-column="TrainingDate">Training date</th>
                                }
                                else
                                {
                                    <th>Actions</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model)
                            {
                                var recordsByCourse = ViewBag.TrainingRecords as Dictionary<int?, Compass.Models.TrainingRecord> ?? new Dictionary<int?, Compass.Models.TrainingRecord>();
                                var trainingRecord = request.CourseId.HasValue && recordsByCourse.ContainsKey(request.CourseId.Value) 
                                    ? recordsByCourse[request.CourseId.Value] 
                                    : null;
                                <tr>
                                    <td>
                                        @if (request.Status == "Approved" && !request.WithdrawalRequested && request.TrainingCompleted != true)
                                        {
                                            <a asp-action="ManageWithdrawal" asp-route-id="@request.Id" style="color: #005ea5; text-decoration: underline;">
                                                <strong>@(request.Course?.Title ?? request.CustomCourseTitle ?? "Custom course")</strong>
                                            </a>
                                        }
                                        else
                                        {
                                            <strong>@(request.Course?.Title ?? request.CustomCourseTitle ?? "Custom course")</strong>
                                        }
                                        @if (!string.IsNullOrEmpty(request.Justification))
                                        {
                                            <br><small class="text-muted">@(request.Justification.Length > 100 ? request.Justification.Substring(0, 100) + "..." : request.Justification)</small>
                                        }
                                    </td>
                                    <td>
                                        @switch (request.Status)
                                        {
                                            case "Draft":
                                                <span class="badge badge-secondary">Draft</span>
                                                break;
                                            case "Submitted":
                                                <span class="badge badge-warning">Submitted</span>
                                                break;
                                            case "Approved":
                                                @if (request.TrainingCompleted == true)
                                                {
                                                    <span class="badge badge-success">Completed</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-success">Approved</span>
                                                }
                                                break;
                                            case "Rejected":
                                                <span class="badge badge-danger">Rejected</span>
                                                break;
                                            case "On-hold":
                                                <span class="badge badge-warning">On-hold</span>
                                                break;
                                            default:
                                                <span class="badge badge-secondary">@request.Status</span>
                                                break;
                                        }
                                    </td>
                                    <td>@request.CreatedAt.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if (request.ApprovedAt.HasValue)
                                        {
                                            @request.ApprovedAt.Value.ToString("dd MMM yyyy")
                                            @if (!string.IsNullOrEmpty(request.ApprovedBy))
                                            {
                                                <br><small class="text-muted">by @request.ApprovedBy</small>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    @if (ViewBag.StatusFilter == "Approved" || ViewBag.StatusFilter == "Completed")
                                    {
                                        <td>
                                            @if (request.TrainingCompleted == true && request.CompletedDate.HasValue)
                                            {
                                                @request.CompletedDate.Value.ToString("dd MMM yyyy")
                                            }
                                            else if (request.PlannedDate.HasValue)
                                            {
                                                <span class="text-muted">Planned: @request.PlannedDate.Value.ToString("dd MMM yyyy")</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                    }
                                    else
                                    {
                                        <td>
                                            @if (request.Status == "Draft")
                                            {
                                                <a asp-action="EditRequest" asp-route-id="@request.Id" class="btn btn-sm btn-warning">Edit</a>
                                                <form asp-action="SubmitRequest" method="post" style="display: inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@request.Id" />
                                                    <button type="submit" class="btn btn-sm btn-success">Submit</button>
                                                </form>
                                                <form asp-action="WithdrawRequest" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to withdraw this request?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@request.Id" />
                                                    <button type="submit" class="btn btn-sm btn-danger">Withdraw</button>
                                                </form>
                                            }
                                            else if (request.Status == "Submitted")
                                            {
                                                <form asp-action="WithdrawRequest" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to withdraw this request?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@request.Id" />
                                                    <button type="submit" class="btn btn-sm btn-danger">Withdraw</button>
                                                </form>
                                            }
                                            else if (request.Status == "Approved" && trainingRecord != null && trainingRecord.Status == "Completed" && !trainingRecord.OutcomeRating.HasValue)
                                            {
                                                <a asp-action="ProvideFeedback" asp-route-id="@trainingRecord.Id" class="btn btn-sm btn-primary">Provide feedback</a>
                                            }
                                            else if (request.Status == "Approved" && trainingRecord != null && trainingRecord.Status == "Completed" && trainingRecord.OutcomeRating.HasValue)
                                            {
                                                <button type="button" class="btn btn-sm btn-info" data-toggle="modal" data-target="#feedbackModal@(trainingRecord.Id)">View feedback</button>
                                            }
                                            @if (!string.IsNullOrEmpty(request.ApproverComments))
                                            {
                                                <button type="button" class="btn btn-sm btn-info" data-toggle="modal" data-target="#commentsModal@(request.Id)">Comments</button>
                                            }
                                        </td>
                                    }
                                </tr>
                                @if (trainingRecord != null && trainingRecord.Status == "Completed" && !string.IsNullOrEmpty(trainingRecord.Feedback))
                                {
                                    <div class="modal fade" id="feedbackModal@(trainingRecord.Id)" tabindex="-1" role="dialog">
                                        <div class="modal-dialog" role="document">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Training feedback</h5>
                                                    <button type="button" class="close" data-dismiss="modal">
                                                        <span>&times;</span>
                                                    </button>
                                                </div>
                                                <div class="modal-body">
                                                    <p><strong>Rating:</strong> 
                                                        @if (trainingRecord.OutcomeRating.HasValue)
                                                        {
                                                            @for (int i = 1; i <= 5; i++)
                                                            {
                                                                <i class="fas fa-star @(i <= trainingRecord.OutcomeRating.Value ? "text-warning" : "text-muted")"></i>
                                                            }
                                                        }
                                                    </p>
                                                    <p><strong>Feedback:</strong></p>
                                                    <p>@trainingRecord.Feedback</p>
                                                    @if (!string.IsNullOrEmpty(trainingRecord.EvidenceFileUrl))
                                                    {
                                                        <p><strong>Evidence:</strong> <a href="@trainingRecord.EvidenceFileUrl" target="_blank">View certificate</a></p>
                                                    }
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(request.ApproverComments))
                                {
                                    <div class="modal fade" id="commentsModal@(request.Id)" tabindex="-1" role="dialog">
                                        <div class="modal-dialog" role="document">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Approver comments</h5>
                                                    <button type="button" class="close" data-dismiss="modal">
                                                        <span>&times;</span>
                                                    </button>
                                                </div>
                                                <div class="modal-body">
                                                    <p>@request.ApproverComments</p>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-3">
                        <p class="text-muted mb-0">No training requests found.</p>
                       
                    </div>
                }
            </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            $('.sortable-table').each(function() {
                initializeSortableTable($(this));
            });
        });

        function initializeSortableTable(table) {
            var currentSort = { column: null, direction: 'asc' };

            table.find('.sortable').on('click keypress', function(e) {
                if (e.type === 'keypress' && e.which !== 13 && e.which !== 32) {
                    return;
                }
                
                var column = $(this).data('column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(table, column, direction);
                currentSort = { column: column, direction: direction };
            });

            function sortTable(table, column, direction) {
                var tbody = table.find('tbody');
                var rows = tbody.find('tr').toArray();
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var colIndex = table.find('thead th[data-column="' + column + '"]').index();
                    
                    if (column === 'CreatedAt' || column === 'ApprovedAt' || column === 'Completed' || column === 'TrainingDate') {
                        var aDate = $(a).find('td').eq(colIndex).text().trim();
                        var bDate = $(b).find('td').eq(colIndex).text().trim();
                        if (aDate === '-' || aDate.startsWith('Planned:')) aDate = '1900-01-01';
                        if (bDate === '-' || bDate.startsWith('Planned:')) bDate = '1900-01-01';
                        aVal = new Date(aDate);
                        bVal = new Date(bDate);
                    } else {
                        aVal = $(a).find('td').eq(colIndex).text().trim().toLowerCase();
                        bVal = $(b).find('td').eq(colIndex).text().trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.empty();
                rows.forEach(function(row) {
                    tbody.append(row);
                });
                
                updateSortIcons(table, column, direction);
            }

            function updateSortIcons(table, column, direction) {
                table.find('.sortable i').remove();
                var header = table.find('.sortable[data-column="' + column + '"]');
                var iconClass = direction === 'asc' ? 'fa-sort-up' : 'fa-sort-down';
                header.append(' <i class="fas ' + iconClass + '"></i>');
            }
        }
    </script>
}

