@{
    ViewData["Title"] = "Help";
    var selectedGroup = ViewBag.SelectedGroup?.ToString() ?? "work-reporting";
}

@await Html.PartialAsync("_DashboardStyles")

@{
    ViewBag.BrandText = "Help";
    ViewBag.NavLinks = new object[] { };
}
@await Html.PartialAsync("_ModuleNavbar")

@section Breadcrumbs {
    <nav aria-label="Breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0 pl-4 breadcrumb-standard">
            <li class="breadcrumb-item">
                <a href="/" class="breadcrumb-link-standard">Home</a>
            </li>
            <li class="breadcrumb-item active breadcrumb-active-standard" aria-current="page">Help</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <!-- Dashboard Header -->
        <div class="dashboard-header">
            <h1>Help and Guidance</h1>
            <p>Find step-by-step guidance for using Compass. Browse help topics by category to learn how to manage work items, submit reports, manage accessibility, and work with standards.</p>
        </div>

        <style>
            .help-faq-item {
                border-bottom: 1px solid #dee2e6;
                padding: 1rem 0;
                transition: background-color 0.2s ease;
            }
            
            .help-faq-item:hover {
                background-color: #f8f9fa;
            }
            
            .help-faq-item:last-child {
                border-bottom: none;
            }
            
            .help-faq-link {
                display: flex;
                justify-content: space-between;
                align-items: center;
                text-decoration: none;
                color: #005ea5;
                padding: 0.5rem 0;
            }
            
            .help-faq-link:hover {
                color: #003078;
                text-decoration: underline;
            }
            
            .help-faq-title {
                font-size: 1rem;
                font-weight: 600;
                margin: 0;
                flex: 1;
            }
            
            .help-faq-description {
                font-size: 0.875rem;
                color: #6b7280;
                margin: 0.25rem 0 0 0;
            }
            
            .help-faq-icon {
                color: #005ea5;
                margin-left: 1rem;
                flex-shrink: 0;
            }
            
            .help-faq-link:hover .help-faq-icon {
                transform: translateX(4px);
            }
            
            .help-content-wrapper {
                min-height: 400px;
            }
            
            .help-section-title {
                font-size: 1.25rem;
                font-weight: 600;
                margin-bottom: 1rem;
                color: #212529;
            }
            
            .help-section-description {
                color: #6b7280;
                margin-bottom: 1.5rem;
            }
        </style>

        <div class="row">
            <!-- Sidebar Navigation -->
            <div class="col-xl-2 col-lg-3 col-md-4 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Help topics</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <a href="@Url.Action("Index", "Help", new { group = "work-reporting" })" 
                               class="list-group-item list-group-item-action @(selectedGroup == "work-reporting" ? "active" : "")">
                                Work Reporting
                            </a>
                            <a href="@Url.Action("Index", "Help", new { group = "operational-reporting" })" 
                               class="list-group-item list-group-item-action @(selectedGroup == "operational-reporting" ? "active" : "")">
                                Operational Reporting
                            </a>
                            <a href="@Url.Action("Index", "Help", new { group = "accessibility-management" })" 
                               class="list-group-item list-group-item-action @(selectedGroup == "accessibility-management" ? "active" : "")">
                                Accessibility Management
                            </a>
                            <a href="@Url.Action("Index", "Help", new { group = "standards" })" 
                               class="list-group-item list-group-item-action @(selectedGroup == "standards" ? "active" : "")">
                                Standards
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-xl-10 col-lg-9 col-md-8">
                <div class="card">
                    <div class="card-body">
                        @if (selectedGroup == "work-reporting")
                        {
                            <h2 class="help-section-title">
                                Work Reporting
                            </h2>
                            <p class="help-section-description">
                                Guidance on creating, managing, tracking, and reporting on work items. Learn how to set up work items, update status, manage milestones, and view reports and analytics.
                            </p>
                            
                            <div class="help-faq-list">
                            <div class="row">
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "create-project" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Create a new work item</h3>
                                        <p class="help-faq-description">Set up a new work item with all required information and team members.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "add-team-member" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Add a team member</h3>
                                        <p class="help-faq-description">Add team members, senior responsible officers, and service owners to work items.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "complete-project-info" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Complete work item information</h3>
                                        <p class="help-faq-description">Ensure all required fields and details are completed for your work items.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "update-rag-status" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Update RAG status</h3>
                                        <p class="help-faq-description">Update the Red, Amber, Green status to reflect current work item health.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "add-milestone" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Add a milestone</h3>
                                        <p class="help-faq-description">Create and manage milestones to track key delivery checkpoints.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "add-status-update" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Monthly Update</h3>
                                        <p class="help-faq-description">Provide monthly status updates to keep stakeholders informed about project progress.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "add-weekly-note-update" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Weekly success update</h3>
                                        <p class="help-faq-description">Record weekly successes and achievements to track progress and share with stakeholders.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "manage-milestones-updates-successes" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Manage milestones</h3>
                                        <p class="help-faq-description">Create, update, and track milestones to monitor key deliverables and checkpoints in your project.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "view-delivery-projects" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">View and filter work items</h3>
                                        <p class="help-faq-description">Navigate the work items list and use filters to find specific items.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "view-project-details" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">View work item details</h3>
                                        <p class="help-faq-description">Explore the detailed view of work items and understand the different information tabs.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "manage-project-deliverables" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Manage associated work items</h3>
                                        <p class="help-faq-description">Link and manage relationships between different work items.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "track-project-dependencies" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Track work item dependencies</h3>
                                        <p class="help-faq-description">Understand and manage dependencies between work items.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            </div>
                        </div>
                    }
                    else if (selectedGroup == "operational-reporting")
                    {
                        <h2 class="help-section-title">
                            Operational Reporting
                        </h2>
                        <p class="help-section-description">
                            Learn how to submit performance metrics, view product history, understand reporting requirements, and manage operational reporting data for your products and services.
                        </p>
                        
                        <div class="help-faq-list">
                            <div class="row">
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "submit-performance-metrics" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Submit performance metrics</h3>
                                        <p class="help-faq-description">Enter performance data for your products and services.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "view-product-history" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">View product reporting history</h3>
                                        <p class="help-faq-description">Access historical performance data and reporting records for products.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "understand-reporting-requirements" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Understand reporting requirements</h3>
                                        <p class="help-faq-description">Learn what metrics are required and when they need to be submitted.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "report-other-product" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Report metrics for another product</h3>
                                        <p class="help-faq-description">Submit performance metrics on behalf of other products or services.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            </div>
                        </div>
                    }
                    else if (selectedGroup == "accessibility-management")
                    {
                        <h2 class="help-section-title">
                            Accessibility Management
                        </h2>
                        <p class="help-section-description">
                            Comprehensive guidance on managing accessibility for products, including enrolling products, tracking issues, managing statements, and conducting audits to ensure WCAG compliance.
                        </p>
                        
                        <div class="help-faq-list">
                            <div class="row">
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "enrol-product-accessibility" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Enrol a product for accessibility</h3>
                                        <p class="help-faq-description">Register your product to start managing accessibility compliance.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "create-accessibility-issue" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Create and manage accessibility issues</h3>
                                        <p class="help-faq-description">Track and manage accessibility issues found in your products.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "manage-accessibility-statement" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Manage accessibility statements</h3>
                                        <p class="help-faq-description">Create, update, and maintain accessibility statements for your products.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "track-accessibility-audits" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Track accessibility audits</h3>
                                        <p class="help-faq-description">Record and monitor accessibility audit history and outcomes.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "link-wcag-criteria" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Link issues to WCAG criteria</h3>
                                        <p class="help-faq-description">Associate accessibility issues with specific WCAG success criteria.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            </div>
                        </div>
                    }
                    else if (selectedGroup == "standards")
                    {
                        <h2 class="help-section-title">
                            Standards
                        </h2>
                        <p class="help-section-description">
                            Guidance on working with DDT standards, including managing standards, understanding standard requirements, and applying standards to your work.
                        </p>
                        
                        <div class="help-faq-list">
                            <div class="row">
                            <div class="col-md-6">
                            <div class="help-faq-item">
                                <a href="@Url.Action("HowDoI", "Help", new { topic = "manage-standards" })" class="help-faq-link">
                                    <div>
                                        <h3 class="help-faq-title">Manage standards</h3>
                                        <p class="help-faq-description">Learn how to work with DDT standards and apply them to your projects.</p>
                                    </div>
                                    <i class="fas fa-chevron-right help-faq-icon"></i>
                                </a>
                            </div>
                            </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
