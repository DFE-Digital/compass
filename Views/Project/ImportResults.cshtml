@model Compass.Services.ProjectImportResult
@{
    ViewData["Title"] = "Import Results";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Import Results</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-action="Index">Projects</a></li>
                    <li class="breadcrumb-item"><a asp-action="Import">Import</a></li>
                    <li class="breadcrumb-item active">Results</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Import Summary</h3>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <div class="info-box">
                                    <span class="info-box-icon bg-info"><i class="fas fa-list"></i></span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Total Rows</span>
                                        <span class="info-box-number">@Model.TotalRows</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="info-box">
                                    <span class="info-box-icon bg-success"><i class="fas fa-check"></i></span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Successful</span>
                                        <span class="info-box-number">@Model.SuccessCount</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="info-box">
                                    <span class="info-box-icon bg-danger"><i class="fas fa-times"></i></span>
                                    <div class="info-box-content">
                                        <span class="info-box-text">Errors</span>
                                        <span class="info-box-number">@Model.ErrorCount</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (Model.SuccessCount > 0)
                        {
                            <div class="alert alert-success">
                                <h5><i class="icon fas fa-check"></i> Import Successful</h5>
                                <p>Successfully imported <strong>@Model.SuccessCount</strong> project(s).</p>
                            </div>
                        }

                        @if (Model.Warnings.Any())
                        {
                            <div class="alert alert-warning">
                                <h5><i class="icon fas fa-exclamation-triangle"></i> Warnings</h5>
                                <ul class="mb-0">
                                    @foreach (var warning in Model.Warnings)
                                    {
                                        <li>@warning</li>
                                    }
                                </ul>
                            </div>
                        }

                        @if (Model.Errors.Any())
                        {
                            <div class="alert alert-danger">
                                <h5><i class="icon fas fa-exclamation-circle"></i> Import Errors</h5>
                                <p>The following errors occurred during import:</p>
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered">
                                        <thead>
                                            <tr>
                                                <th>Row</th>
                                                <th>Field</th>
                                                <th>Error</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var error in Model.Errors)
                                            {
                                                <tr>
                                                    <td>@error.RowNumber</td>
                                                    <td>@error.Field</td>
                                                    <td>@error.Message</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }

                        <div class="mt-4">
                            <a asp-action="Index" class="btn btn-primary">
                                <i class="fas fa-list"></i> View Projects
                            </a>
                            <a asp-action="Import" class="btn btn-secondary">
                                <i class="fas fa-upload"></i> Import Another File
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

