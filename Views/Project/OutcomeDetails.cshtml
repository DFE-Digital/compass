@model Compass.ViewModels.ProjectOutcomeDetailsViewModel

@{
    ViewData["Title"] = $"Outcome details – {Model.ProjectTitle}";
    string ConfidenceBadgeClass(string confidence) => confidence switch
    {
        "High" => "badge-success",
        "Low" => "badge-danger",
        _ => "badge-warning"
    };
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <a asp-action="Details"
                   asp-route-id="@Model.ProjectId"
                   asp-route-tab="outcomes"
                   class="btn btn-link px-0 mb-2"
                   aria-label="Back to project">
                    <i class="fas fa-arrow-left mr-2" aria-hidden="true"></i>Back to project
                </a>
                <h1 class="m-0">Outcome details</h1>
                <p class="text-muted mb-0">Project: @Model.ProjectTitle</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <aside class="col-xxl-3 col-xl-3 col-lg-4 col-md-5 mb-4">
                <partial name="_ProjectSummarySidebar" model="Model.ProjectSummary" />
            </aside>
            <div class="col-xxl-9 col-xl-9 col-lg-8 col-md-7">
                <div class="card project-summary-card mb-4" id="outcome-details">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Outcome information</h3>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush outcome-summary">
                            <li class="list-group-item">
                                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                                    <div class="flex-grow-1">
                                        <small class="text-muted d-block">Outcome</small>
                                        <span class="font-weight-medium">@Model.Outcome</span>
                                    </div>
                                    <div class="mt-2 mt-md-0 text-md-right">
                                        <a class="small"
                                           asp-action="EditOutcome"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-outcomeId="@Model.OutcomeId">Change</a>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                                    <div class="flex-grow-1">
                                        <small class="text-muted d-block">Measure of success</small>
                                        <span>@(string.IsNullOrWhiteSpace(Model.MeasureOfSuccess) ? "-" : Model.MeasureOfSuccess)</span>
                                    </div>
                                    <div class="mt-2 mt-md-0 text-md-right">
                                        <a class="small"
                                           asp-action="EditOutcome"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-outcomeId="@Model.OutcomeId">Change</a>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                                    <div class="flex-grow-1">
                                        <small class="text-muted d-block">Confidence level</small>
                                        <span class="badge @ConfidenceBadgeClass(Model.ConfidenceLevel)">@Model.ConfidenceLevel</span>
                                    </div>
                                    <div class="mt-2 mt-md-0 text-md-right">
                                        <a class="small"
                                           asp-action="EditOutcome"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-outcomeId="@Model.OutcomeId">Change</a>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                                    <div class="flex-grow-1">
                                        <small class="text-muted d-block">Confidence explanation</small>
                                        @if (!string.IsNullOrWhiteSpace(Model.ConfidenceExplanation))
                                        {
                                            <span>@Model.ConfidenceExplanation</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not provided</span>
                                        }
                                    </div>
                                    <div class="mt-2 mt-md-0 text-md-right">
                                        <a class="small"
                                           asp-action="EditOutcome"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-outcomeId="@Model.OutcomeId">Change</a>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                                    <div class="flex-grow-1">
                                        <small class="text-muted d-block">Display order</small>
                                        <span>@Model.SortOrder</span>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                                    <div class="flex-grow-1">
                                        <small class="text-muted d-block">Last updated</small>
                                        <span>@Model.UpdatedAt.ToString("dd MMM yyyy HH:mm") (UTC)</span>
                                    </div>
                                </div>
                            </li>
                            <li class="list-group-item">
                                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                                    <div class="flex-grow-1">
                                        <small class="text-muted d-block">Created</small>
                                        <span>@Model.CreatedAt.ToString("dd MMM yyyy") (UTC)</span>
                                    </div>
                                </div>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
