@model Compass.ViewModels.ProjectOutcomeDetailsViewModel

@{
    ViewData["Title"] = $"Outcome details – {Model.ProjectTitle}";
    string ConfidenceBadgeClass(string confidence) => confidence switch
    {
        "High" => "badge-success",
        "Low" => "badge-danger",
        _ => "badge-warning"
    };
    string AchievementBadgeClass(string status) => status switch
    {
        "Yes" => "badge-success",
        "No" => "badge-danger",
        _ => "badge-secondary"
    };
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <a asp-action="Details"
                   asp-route-id="@Model.ProjectId"
                   asp-route-tab="outcomes"
                   class="btn btn-link px-0 mb-2"
                   aria-label="Back to work item">
                    <i class="fas fa-arrow-left mr-2" aria-hidden="true"></i>Back to work item
                </a>
                <h1 class="m-0">Outcome details</h1>
                <p class="text-muted mb-0">Work: @Model.ProjectTitle</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <aside class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12 mb-4">
                <partial name="_ProjectSummarySidebar" model="Model.ProjectSummary" />
            </aside>
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <div class="card project-summary-card mb-4" id="outcome-details">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Outcome information</h3>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-borderless mb-0 outcome-summary-table">
                            <tbody>
                                <tr>
                                    <td class="summary-label"><strong>Outcome</strong></td>
                                    <td class="summary-value font-weight-medium">@Model.Outcome</td>
                                    <td class="text-right">
                                        <a asp-action="EditOutcome"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-outcomeId="@Model.OutcomeId">Change</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Measure of success</strong></td>
                                    <td class="summary-value">
                                        @(string.IsNullOrWhiteSpace(Model.MeasureOfSuccess) ? "-" : Model.MeasureOfSuccess)
                                    </td>
                                    <td class="text-right">
                                        <a asp-action="EditOutcome"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-outcomeId="@Model.OutcomeId">Change</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Confidence level</strong></td>
                                    <td class="summary-value">
                                        <span class="badge @ConfidenceBadgeClass(Model.ConfidenceLevel)">@Model.ConfidenceLevel</span>
                                    </td>
                                    <td class="text-right">
                                        <a asp-action="EditOutcome"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-outcomeId="@Model.OutcomeId">Change</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Confidence explanation</strong></td>
                                    <td class="summary-value">
                                        @if (!string.IsNullOrWhiteSpace(Model.ConfidenceExplanation))
                                        {
                                            <span>@Model.ConfidenceExplanation</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not provided</span>
                                        }
                                    </td>
                                    <td class="text-right">
                                        <a asp-action="EditOutcome"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-outcomeId="@Model.OutcomeId">Change</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Achievement status</strong></td>
                                    <td class="summary-value">
                                        <span class="badge @AchievementBadgeClass(Model.AchievementStatus ?? "In progress")">@(Model.AchievementStatus ?? "In progress")</span>
                                    </td>
                                    <td class="text-right">
                                        <a asp-action="EditOutcome"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-outcomeId="@Model.OutcomeId">Change</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Last updated</strong></td>
                                    <td class="summary-value">@Model.UpdatedAt.ToString("dd MMM yyyy")</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Created by</strong></td>
                                    <td class="summary-value">
                                        @if (!string.IsNullOrWhiteSpace(Model.CreatedByName))
                                        {
                                            <span>@Model.CreatedByName</span>
                                            @if (!string.IsNullOrWhiteSpace(Model.CreatedByEmail))
                                            {
                                                <span class="text-muted">(@Model.CreatedByEmail)</span>
                                            }
                                        }
                                        else if (!string.IsNullOrWhiteSpace(Model.CreatedByEmail))
                                        {
                                            <span>@Model.CreatedByEmail</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Unknown</span>
                                        }
                                    </td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Created</strong></td>
                                    <td class="summary-value">@Model.CreatedAt.ToString("dd MMM yyyy")</td>
                                    <td></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
