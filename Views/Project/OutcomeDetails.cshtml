@model Compass.ViewModels.ProjectOutcomeDetailsViewModel

@{
    ViewData["Title"] = $"Outcome details – {Model.ProjectTitle}";
    string ConfidenceBadgeClass(string confidence) => confidence switch
    {
        "High" => "badge-success",
        "Low" => "badge-danger",
        _ => "badge-warning"
    };
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <a asp-action="Details"
                   asp-route-id="@Model.ProjectId"
                   asp-route-tab="outcomes"
                   class="btn btn-link px-0 mb-2"
                   aria-label="Back to project">
                    <i class="fas fa-arrow-left mr-2" aria-hidden="true"></i>Back to project
                </a>
                <h1 class="m-0">Outcome details</h1>
                <p class="text-muted mb-0">Project: @Model.ProjectTitle</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <aside class="col-xxl-3 col-xl-2 col-lg-4 col-md-5 mb-4">
                <partial name="_ProjectSummarySidebar" model="Model.ProjectSummary" />
            </aside>
            <div class="col-xxl-9 col-xl-9 col-lg-8 col-md-7">
                <div class="card project-summary-card mb-4" id="outcome-details">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Outcome information</h3>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-borderless mb-0 outcome-summary-table">
                            <tbody>
                                <tr>
                                    <td class="summary-label"><strong>Outcome</strong></td>
                                    <td class="summary-value font-weight-medium">@Model.Outcome</td>
                                    <td class="text-right">
                                        <a class="small"
                                           asp-action="EditOutcome"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-outcomeId="@Model.OutcomeId">Change</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Measure of success</strong></td>
                                    <td class="summary-value">
                                        @(string.IsNullOrWhiteSpace(Model.MeasureOfSuccess) ? "-" : Model.MeasureOfSuccess)
                                    </td>
                                    <td class="text-right">
                                        <a class="small"
                                           asp-action="EditOutcome"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-outcomeId="@Model.OutcomeId">Change</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Confidence level</strong></td>
                                    <td class="summary-value">
                                        <span class="badge @ConfidenceBadgeClass(Model.ConfidenceLevel)">@Model.ConfidenceLevel</span>
                                    </td>
                                    <td class="text-right">
                                        <a class="small"
                                           asp-action="EditOutcome"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-outcomeId="@Model.OutcomeId">Change</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Confidence explanation</strong></td>
                                    <td class="summary-value">
                                        @if (!string.IsNullOrWhiteSpace(Model.ConfidenceExplanation))
                                        {
                                            <span>@Model.ConfidenceExplanation</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not provided</span>
                                        }
                                    </td>
                                    <td class="text-right">
                                        <a class="small"
                                           asp-action="EditOutcome"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-outcomeId="@Model.OutcomeId">Change</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Display order</strong></td>
                                    <td class="summary-value">@Model.SortOrder</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Last updated</strong></td>
                                    <td class="summary-value">@Model.UpdatedAt.ToString("dd MMM yyyy HH:mm") (UTC)</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Created</strong></td>
                                    <td class="summary-value">@Model.CreatedAt.ToString("dd MMM yyyy") (UTC)</td>
                                    <td></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title mb-0">RAID summary</h3>
                    </div>
                    <div class="card-body">
                        <div class="row text-center">
                            <div class="col-sm-6 col-lg-3 mb-3">
                                <div class="border rounded p-3 h-100">
                                    <span class="text-uppercase text-muted small d-block">Risks</span>
                                    <span class="h3 mb-0">@Model.RaidSummary.RiskCount</span>
                                </div>
                            </div>
                            <div class="col-sm-6 col-lg-3 mb-3">
                                <div class="border rounded p-3 h-100">
                                    <span class="text-uppercase text-muted small d-block">Issues</span>
                                    <span class="h3 mb-0">@Model.RaidSummary.IssueCount</span>
                                </div>
                            </div>
                            <div class="col-sm-6 col-lg-3 mb-3">
                                <div class="border rounded p-3 h-100">
                                    <span class="text-uppercase text-muted small d-block">Actions</span>
                                    <span class="h3 mb-0">@Model.RaidSummary.ActionCount</span>
                                </div>
                            </div>
                            <div class="col-sm-6 col-lg-3 mb-3">
                                <div class="border rounded p-3 h-100">
                                    <span class="text-uppercase text-muted small d-block">Decisions</span>
                                    <span class="h3 mb-0">@Model.RaidSummary.DecisionCount</span>
                                </div>
                            </div>
                        </div>
                        @if (!Model.RaidSummary.HasAny)
                        {
                            <p class="text-muted text-center mb-0">No RAID artefacts are linked to this outcome yet.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
