@model Compass.Models.ProjectOutcome

@{
    ViewData["Title"] = "Outcome Details";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Projects</a></li>
                    <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@Model.ProjectId" asp-route-tab="outcomes">@Model.Project?.Title</a></li>
                    <li class="breadcrumb-item active">Outcome</li>
                </ol>
                <h1 class="m-0">Outcome Details</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <!-- Outcome Details Card -->
            <div class="col-lg-8">
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title">Outcome Information</h3>
                        <div class="card-tools">
                            <button type="button" class="btn btn-primary btn-sm" data-toggle="modal" data-target="#editOutcomeModal">Edit Outcome</button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <h5>Outcome</h5>
                            <p>@Model.Outcome</p>
                        </div>

                        <div class="mb-3">
                            <h5>Measure of Success</h5>
                            <p>@Model.MeasureOfSuccess</p>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <h5>Confidence Level</h5>
                                <p>
                                    <span class="badge @(Model.ConfidenceLevel == "High" ? "badge-success" : Model.ConfidenceLevel == "Medium" ? "badge-warning" : "badge-danger")">
                                        @Model.ConfidenceLevel
                                    </span>
                                </p>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.ConfidenceExplanation))
                        {
                            <div class="mb-3">
                                <h5>Confidence Explanation</h5>
                                <p>@Model.ConfidenceExplanation</p>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Sidebar Info -->
            <div class="col-lg-4">
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title">Project</h3>
                    </div>
                    <div class="card-body">
                        <p><strong>@Model.Project?.Title</strong></p>
                        <a asp-action="Details" asp-route-id="@Model.ProjectId" asp-route-tab="outcomes" class="btn btn-sm btn-outline-primary">View All Outcomes</a>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Actions</h3>
                    </div>
                    <div class="card-body">
                        <button type="button" class="btn btn-danger btn-block" data-toggle="modal" data-target="#deleteOutcomeModal">Delete Outcome</button>
                        <a asp-action="Details" asp-route-id="@Model.ProjectId" asp-route-tab="outcomes" class="btn btn-secondary btn-block mt-2">Back to Project</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Edit Outcome Modal -->
<div class="modal fade" id="editOutcomeModal" tabindex="-1" role="dialog" aria-labelledby="editOutcomeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editOutcomeModalLabel">Edit Outcome</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateOutcome" method="post">
                <input type="hidden" name="projectId" value="@Model.ProjectId" />
                <input type="hidden" name="outcomeId" value="@Model.Id" />
                <input type="hidden" name="sortOrder" value="@Model.SortOrder" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="outcome">Outcome</label>
                        <textarea class="form-control" id="outcome" name="outcome" rows="3" required>@Model.Outcome</textarea>
                    </div>
                    
                    <div class="form-group">
                        <label for="measureOfSuccess">Measure of Success</label>
                        <textarea class="form-control" id="measureOfSuccess" name="measureOfSuccess" rows="2" required>@Model.MeasureOfSuccess</textarea>
                    </div>
                    
                    <div class="form-group">
                        <label for="confidenceLevel">Confidence Level</label>
                        <select class="form-control" id="confidenceLevel" name="confidenceLevel" required>
                            @if (Model.ConfidenceLevel == "Low")
                            {
                                <option value="Low" selected>Low</option>
                            }
                            else
                            {
                                <option value="Low">Low</option>
                            }
                            @if (Model.ConfidenceLevel == "Medium")
                            {
                                <option value="Medium" selected>Medium</option>
                            }
                            else
                            {
                                <option value="Medium">Medium</option>
                            }
                            @if (Model.ConfidenceLevel == "High")
                            {
                                <option value="High" selected>High</option>
                            }
                            else
                            {
                                <option value="High">High</option>
                            }
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="confidenceExplanation">Confidence Explanation (Optional)</label>
                        <textarea class="form-control" id="confidenceExplanation" name="confidenceExplanation" rows="2">@Model.ConfidenceExplanation</textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Outcome</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Outcome Modal -->
<div class="modal fade" id="deleteOutcomeModal" tabindex="-1" role="dialog" aria-labelledby="deleteOutcomeModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteOutcomeModalLabel">Confirm Deletion</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="DeleteOutcome" method="post">
                <input type="hidden" name="projectId" value="@Model.ProjectId" />
                <input type="hidden" name="outcomeId" value="@Model.Id" />
                <div class="modal-body">
                    <p>Are you sure you want to delete this outcome?</p>
                    <p><strong>@Model.Outcome</strong></p>
                    <p class="text-danger">This action cannot be undone.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Delete Outcome</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

