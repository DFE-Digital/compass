@model Compass.Models.Project

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Associated Products</h3>
                <div class="card-tools">
                    <a href="#" id="addProductBtn">Add product</a>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                @if (Model.ProjectProducts.Any())
                {
                    <table class="table table-hover text-nowrap products-table">
                        <thead>
                            <tr>
                                <th class="col-product-fips-id">FIPS ID</th>
                                <th class="col-product-title">Product Title</th>
                                <th class="col-product-linked">Linked Date</th>
                                <th class="col-product-actions">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model.ProjectProducts.OrderBy(p => p.ProductTitle))
                            {
                                <tr>
                                    <td>@product.ProductFipsId</td>
                                    <td>
                                        <a href="#" class="view-product-link" 
                                           data-product-id="@product.Id" 
                                           data-product-fips-id="@product.ProductFipsId" 
                                           data-product-title="@product.ProductTitle" 
                                           data-product-linked="@product.CreatedAt.ToString("dd MMM yyyy")">@product.ProductTitle</a>
                                    </td>
                                    <td>@product.CreatedAt.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-danger remove-product-btn" data-product-id="@product.Id" data-product-title="@product.ProductTitle">Remove</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center p-4">
                        <p class="text-muted">No products associated yet.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Add Product Modal -->
<div class="modal fade" id="addProductModal" tabindex="-1" role="dialog" aria-labelledby="addProductModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addProductModalLabel">Add Product</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="AddProduct" method="post" id="addProductForm">
                <input type="hidden" name="projectId" value="@Model.Id" />
                <input type="hidden" name="productFipsId" id="selectedProductFipsId" required />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="productSearchInput">Search for Product</label>
                        <input type="text" class="form-control product-autocomplete" id="productSearchInput" autocomplete="off" placeholder="Start typing product name or FIPS ID..." required>
                        <small class="form-text text-muted">Type to search for products from the FIPS CMS</small>
                    </div>
                    <div id="selectedProductDisplay" class="alert alert-success mt-3" style="display: none;">
                        <strong>Selected Product:</strong><br>
                        <div id="selectedProductTitle"></div>
                        <small class="text-muted" id="selectedProductDetails"></small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="addProductSubmitBtn" disabled>Add Product</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- View Product Modal -->
<div class="modal fade" id="viewProductModal" tabindex="-1" role="dialog" aria-labelledby="viewProductModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewProductModalLabel">Product Details</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <dl class="row">
                    <dt class="col-sm-4">FIPS ID</dt>
                    <dd class="col-sm-8" id="viewProductFipsId"></dd>
                    
                    <dt class="col-sm-4">Product Title</dt>
                    <dd class="col-sm-8" id="viewProductTitle"></dd>
                    
                    <dt class="col-sm-4">Linked Date</dt>
                    <dd class="col-sm-8" id="viewProductLinked"></dd>
                </dl>
            </div>
            <div class="modal-footer d-flex justify-content-between">
                <button type="button" class="btn btn-danger" id="removeProductFromViewBtn">Remove Product</button>
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Remove Product Confirmation Modal -->
<div class="modal fade" id="removeProductModal" tabindex="-1" role="dialog" aria-labelledby="removeProductModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="removeProductModalLabel">Confirm Remove</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to remove the product <strong id="removeProductTitle"></strong> from this project?</p>
                <p class="text-muted">This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <form asp-action="RemoveProduct" method="post" class="d-inline">
                    <input type="hidden" name="projectId" value="@Model.Id" />
                    <input type="hidden" name="projectProductId" id="removeProductId" />
                    <button type="submit" class="btn btn-danger">Remove Product</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
    (function() {
        var currentProductId = null;
        var searchTimeout = null;

        function initProductsPage() {
            // Handle add product button
            $('#addProductBtn').on('click', function(e) {
                e.preventDefault();
                // Reset form when opening modal
                $('#productSearchInput').val('');
                $('#selectedProductFipsId').val('');
                $('#selectedProductDisplay').hide();
                $('#addProductSubmitBtn').prop('disabled', true);
                $('.autocomplete-results').hide().empty();
                $('#addProductModal').modal('show');
            });

            // Initialize product autocomplete
            initProductAutocomplete();

            // Handle view product link clicks
            $(document).on('click', '.view-product-link', function(e) {
                e.preventDefault();
                currentProductId = $(this).attr('data-product-id');
                var fipsId = $(this).attr('data-product-fips-id');
                var title = $(this).attr('data-product-title');
                var linked = $(this).attr('data-product-linked');
                
                viewProduct(currentProductId, fipsId, title, linked);
            });

            // Handle remove product button clicks (from table)
            $(document).on('click', '.remove-product-btn', function(e) {
                e.preventDefault();
                var productId = $(this).attr('data-product-id');
                var productTitle = $(this).attr('data-product-title');
                
                removeProduct(productId, productTitle);
            });

            // Handle remove product from view modal
            $('#removeProductFromViewBtn').on('click', function() {
                var productTitle = $('#viewProductTitle').text();
                $('#viewProductModal').modal('hide');
                removeProduct(currentProductId, productTitle);
            });
        }

        function initProductAutocomplete() {
            var $input = $('#productSearchInput');
            var $resultsContainer = $('<div class="autocomplete-results"></div>');
            $input.after($resultsContainer);

            // Handle input with debounce
            $input.on('input', function() {
                clearTimeout(searchTimeout);
                var searchTerm = $(this).val();

                if (searchTerm.length < 2) {
                    $resultsContainer.hide().empty();
                    return;
                }

                searchTimeout = setTimeout(function() {
                    $.ajax({
                        url: '/api/products/search',
                        data: { q: searchTerm },
                        dataType: 'json',
                        success: function(data) {
                            displayProductResults(data.results, $resultsContainer);
                        },
                        error: function(xhr, status, error) {
                            console.error('Failed to search products:', status, error);
                            $resultsContainer.html('<div class="autocomplete-item no-results">Error searching products</div>');
                            $resultsContainer.show();
                        }
                    });
                }, 300);
            });

            // Hide results when clicking outside
            $(document).on('click', function(e) {
                if (!$(e.target).closest('.product-autocomplete').length && 
                    !$(e.target).closest('.autocomplete-results').length) {
                    $resultsContainer.hide();
                }
            });

            // Keyboard navigation
            $input.on('keydown', function(e) {
                var $items = $resultsContainer.find('.autocomplete-item:not(.no-results)');
                var $selected = $items.filter('.selected');

                if (!$resultsContainer.is(':visible') || $items.length === 0) {
                    return;
                }

                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    if ($selected.length === 0) {
                        $items.first().addClass('selected');
                    } else {
                        $selected.removeClass('selected');
                        var $next = $selected.next('.autocomplete-item');
                        if ($next.length) {
                            $next.addClass('selected');
                        } else {
                            $items.first().addClass('selected');
                        }
                    }
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    if ($selected.length === 0) {
                        $items.last().addClass('selected');
                    } else {
                        $selected.removeClass('selected');
                        var $prev = $selected.prev('.autocomplete-item');
                        if ($prev.length) {
                            $prev.addClass('selected');
                        } else {
                            $items.last().addClass('selected');
                        }
                    }
                } else if (e.key === 'Enter') {
                    if ($selected.length) {
                        e.preventDefault();
                        $selected.click();
                    }
                } else if (e.key === 'Escape') {
                    e.preventDefault();
                    $resultsContainer.hide();
                }
            });
        }

        function displayProductResults(results, $resultsContainer) {
            $resultsContainer.empty();

            if (!results || results.length === 0) {
                $resultsContainer.html('<div class="autocomplete-item no-results">No products found</div>');
                $resultsContainer.show();
                return;
            }

            results.forEach(function(product) {
                var $item = $('<div class="autocomplete-item"></div>');
                $item.html(
                    '<div class="autocomplete-name">' + product.title + '</div>' +
                    '<div class="autocomplete-details">' + product.fipsId + ' • ' + product.phase + '</div>'
                );

                $item.on('click', function() {
                    selectProduct(product);
                    $resultsContainer.hide().empty();
                });

                $resultsContainer.append($item);
            });

            $resultsContainer.show();
        }

        function selectProduct(product) {
            $('#productSearchInput').val(product.title);
            $('#selectedProductFipsId').val(product.fipsId);
            $('#selectedProductTitle').text(product.title);
            $('#selectedProductDetails').text(product.fipsId + ' • ' + product.phase);
            $('#selectedProductDisplay').show();
            $('#addProductSubmitBtn').prop('disabled', false);
        }

        function viewProduct(productId, fipsId, title, linked) {
            $('#viewProductFipsId').text(fipsId);
            $('#viewProductTitle').text(title);
            $('#viewProductLinked').text(linked);
            $('#viewProductModal').modal('show');
        }

        function removeProduct(productId, productTitle) {
            $('#removeProductId').val(productId);
            $('#removeProductTitle').text(productTitle);
            $('#removeProductModal').modal('show');
        }

        if (typeof jQuery !== 'undefined') {
            $(document).ready(initProductsPage);
        } else {
            document.addEventListener('DOMContentLoaded', function() {
                if (typeof jQuery !== 'undefined') {
                    $(document).ready(initProductsPage);
                }
            });
        }
    })();
</script>

