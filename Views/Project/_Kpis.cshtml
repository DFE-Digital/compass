@using System.Collections.Generic
@using System.Globalization
@using System.Linq
@model Compass.Models.Project

@{
    var activeKpis = Model.Kpis?
        .Where(k => k.Active)
        .OrderBy(k => k.Name)
        .ToList() ?? new List<Compass.Models.Kpi>();

    var archivedKpis = Model.Kpis?
        .Where(k => !k.Active)
        .OrderBy(k => k.Name)
        .ToList() ?? new List<Compass.Models.Kpi>();
}

<div class="card" id="kpis">
    <div class="card-header">
        <h3 class="card-title">Key performance indicators</h3>
        <div class="card-tools">
            <a href="@Url.Action("CreateKpi", "Project", new { projectId = Model.Id })">Add KPI</a>
        </div>
    </div>
    <div class="card-body table-responsive p-0">
        @if (activeKpis.Any())
        {
            <table class="table table-hover text-nowrap sortable-table">
                <thead>
                    <tr>
                        <th scope="col" class="sortable" data-column="Name" tabindex="0" role="button" aria-label="Sort by Name">
                            Name
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th scope="col" class="sortable" data-column="Category" tabindex="0" role="button" aria-label="Sort by Category">
                            Category
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th scope="col" class="sortable" data-column="Stages" tabindex="0" role="button" aria-label="Sort by Stages">
                            Stages
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th scope="col" class="sortable" data-column="Status" tabindex="0" role="button" aria-label="Sort by Status">
                            Status
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th scope="col" class="sortable" data-column="Target" tabindex="0" role="button" aria-label="Sort by Target">
                            Target
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var kpi in activeKpis)
                {
                    var latestDataPoint = kpi.PerformanceData?
                        .OrderByDescending(dp => dp.ReportingPeriodStart)
                        .FirstOrDefault();
                    var stageSummary = FormatStageSummary(kpi.ReportingStage);
                    <tr>
                        <td>
                            <a asp-controller="Project" asp-action="EditKpi" asp-route-projectId="@Model.Id" asp-route-kpiId="@kpi.Id">@kpi.Name</a>
                            @if (!string.IsNullOrWhiteSpace(kpi.Code))
                            {
                                <br />
                                <small class="text-muted d-block">Code: @kpi.Code</small>
                            }
                            @if (latestDataPoint != null)
                            {
                                <div class="mt-1 small text-muted">
                                    <span class="badge badge-info">Latest</span>
                                    @latestDataPoint.ReportingPeriodStart.ToString("MMM yyyy")
                                    @if (latestDataPoint.ReportingPeriodEnd.HasValue)
                                    {
                                        <text> - @latestDataPoint.ReportingPeriodEnd.Value.ToString("MMM yyyy")</text>
                                    }
                                    @if (latestDataPoint.Value.HasValue)
                                    {
                                        <text>: <strong>@FormatKpiValue(latestDataPoint.Value.Value, kpi.UnitOfMeasure)</strong></text>
                                    }
                                    else if (!string.IsNullOrWhiteSpace(latestDataPoint.ValueNarrative))
                                    {
                                        <text>: <strong>@latestDataPoint.ValueNarrative</strong></text>
                                    }
                                </div>
                            }
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(kpi.Category) ? "—" : kpi.Category)</td>
                        <td>@stageSummary</td>
                        <td>@FormatStatusLabel(kpi.Status)</td>
                        <td>
                            @if (kpi.TargetValue.HasValue)
                            {
                                <span>@FormatKpiValue(kpi.TargetValue.Value, kpi.UnitOfMeasure)</span>
                            }
                            else
                            {
                                <span class="text-muted">Not set</span>
                            }
                        </td>
                    </tr>
                    if (kpi.PerformanceData != null && kpi.PerformanceData.Any())
                    {
                        <tr class="bg-light">
                            <td colspan="5">
                                <div class="mb-2 font-weight-bold">Recorded data</div>
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered mb-0">
                                        <thead class="thead-light">
                                            <tr>
                                                <th scope="col">Reporting period</th>
                                                <th scope="col">Value</th>
                                                <th scope="col">Narrative</th>
                                                <th scope="col">Validated</th>
                                                <th scope="col">Submitted by</th>
                                                <th scope="col">Submitted at</th>
                                                <th scope="col">Notes</th>
                                                <th scope="col" class="text-right">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var dataPoint in kpi.PerformanceData.OrderByDescending(dp => dp.ReportingPeriodStart))
                                            {
                                                <tr>
                                                    <td>
                                                        @dataPoint.ReportingPeriodStart.ToString("dd MMM yyyy")
                                                        @if (dataPoint.ReportingPeriodEnd.HasValue)
                                                        {
                                                            <text> - @dataPoint.ReportingPeriodEnd.Value.ToString("dd MMM yyyy")</text>
                                                        }
                                                    </td>
                                                    <td>
                                                        @if (dataPoint.Value.HasValue)
                                                        {
                                                            <strong>@FormatKpiValue(dataPoint.Value.Value, kpi.UnitOfMeasure)</strong>
                                                        }
                                                        else
                                                        {
                                                            <span class="text-muted">—</span>
                                                        }
                                                    </td>
                                                    <td>@(string.IsNullOrWhiteSpace(dataPoint.ValueNarrative) ? "—" : dataPoint.ValueNarrative)</td>
                                                    <td>
                                                        @if (dataPoint.IsValidated)
                                                        {
                                                            <span class="badge badge-success">Validated</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge badge-secondary">Draft</span>
                                                        }
                                                    </td>
                                                    <td>@(dataPoint.SubmittedByUser?.Name ?? dataPoint.SubmittedByUser?.Email ?? "Not recorded")</td>
                                                    <td>@dataPoint.SubmittedAt.ToString("dd MMM yyyy HH:mm")</td>
                                                    <td>@(string.IsNullOrWhiteSpace(dataPoint.Notes) ? "—" : dataPoint.Notes)</td>
                                                    <td class="text-right">
                                                        <form asp-action="DeleteKpiDataPoint"
                                                              asp-controller="Project"
                                                              method="post"
                                                              class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="projectId" value="@Model.Id" />
                                                            <input type="hidden" name="dataPointId" value="@dataPoint.Id" />
                                                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                                                Delete
                                                            </button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        }
        else
        {
            <div class="p-3">
                <p class="text-muted mb-2">No KPIs recorded.</p>
                <a href="@Url.Action("CreateKpi", "Project", new { projectId = Model.Id })">Add the first KPI</a>
            </div>
        }
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Archived KPIs</h3>
    </div>
    <div class="card-body table-responsive p-0">
        @if (archivedKpis.Any())
        {
            <table class="table table-hover text-nowrap sortable-table">
                <thead>
                    <tr>
                        <th scope="col" class="sortable" data-column="Name" tabindex="0" role="button" aria-label="Sort by Name">
                            Name
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th scope="col" class="sortable" data-column="Category" tabindex="0" role="button" aria-label="Sort by Category">
                            Category
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th scope="col" class="sortable" data-column="Stages" tabindex="0" role="button" aria-label="Sort by Stages">
                            Stages
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th scope="col" class="sortable" data-column="Status" tabindex="0" role="button" aria-label="Sort by Status">
                            Status
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var kpi in archivedKpis)
                {
                    var stageSummary = FormatStageSummary(kpi.ReportingStage);
                    <tr>
                        <td>
                            <a asp-controller="Project" asp-action="EditKpi" asp-route-projectId="@Model.Id" asp-route-kpiId="@kpi.Id">@kpi.Name</a>
                            @if (!string.IsNullOrWhiteSpace(kpi.Code))
                            {
                                <br />
                                <small class="text-muted d-block">Code: @kpi.Code</small>
                            }
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(kpi.Category) ? "—" : kpi.Category)</td>
                        <td>@FormatStageSummary(kpi.ReportingStage)</td>
                        <td>@FormatStatusLabel(kpi.Status)</td>
                    </tr>
                }
                </tbody>
            </table>
        }
        else
        {
            <div class="p-3">
                <p class="text-muted mb-0">No archived KPIs recorded.</p>
            </div>
        }
    </div>
</div>

@functions {
    private static readonly Dictionary<string, string> StatusLabels = new(StringComparer.OrdinalIgnoreCase)
    {
        ["not_started"] = "Not started",
        ["monitoring"] = "Monitoring",
        ["on_track"] = "On track",
        ["at_risk"] = "At risk",
        ["blocked"] = "Blocked",
        ["achieved"] = "Achieved",
        ["retired"] = "Retired"
    };

    private static string FormatKpiValue(decimal value, string? unit)
    {
        var formattedNumber = value.ToString("0.##", CultureInfo.InvariantCulture);

        if (!string.IsNullOrWhiteSpace(unit) && unit.Equals("Percentage", StringComparison.OrdinalIgnoreCase))
        {
            return $"{formattedNumber}%";
        }

        return !string.IsNullOrWhiteSpace(unit)
            ? $"{formattedNumber} {unit}"
            : formattedNumber;
    }

    private static string FormatStageSummary(string? storedStages)
    {
        var stages = ParseStageList(storedStages);
        if (stages.Count == 0)
        {
            return "—";
        }

        if (stages.Count == 1)
        {
            return stages[0];
        }

        var others = stages.Count - 1;
        var otherLabel = others == 1 ? "other" : "others";
        return $"{stages[0]} (+ {others} {otherLabel})";
    }

    private static string FormatStatusLabel(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "—";
        }

        if (StatusLabels.TryGetValue(value, out var label))
        {
            return label;
        }

        var labelText = value.Replace("_", " ");
        return CultureInfo.CurrentCulture.TextInfo.ToTitleCase(labelText.ToLowerInvariant());
    }

    private static List<string> ParseStageList(string? storedStages)
    {
        if (string.IsNullOrWhiteSpace(storedStages))
        {
            return new List<string>();
        }

        return storedStages
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(stage => stage.Trim())
            .Where(stage => !string.IsNullOrWhiteSpace(stage))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }
}

<script nonce="@Context.Items["Nonce"]">
    (function() {
        function initializeSortableTable(table) {
            var currentSort = { column: null, direction: 'asc' };
            var sortableHeaders = table.querySelectorAll('.sortable');
            
            sortableHeaders.forEach(function(header) {
                header.style.cursor = 'pointer';
                
                header.addEventListener('click', function(e) {
                    handleSort(e, header);
                });
                
                header.addEventListener('keypress', function(e) {
                    if (e.which === 13 || e.which === 32) {
                        e.preventDefault();
                        handleSort(e, header);
                    }
                });
            });
            
            function handleSort(e, header) {
                var column = header.getAttribute('data-column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(column, direction);
                currentSort = { column: column, direction: direction };
            }
            
            function sortTable(column, direction) {
                var tbody = table.querySelector('tbody');
                var rows = Array.from(tbody.querySelectorAll('tr'));
                var colIndex = Array.from(table.querySelectorAll('thead th')).findIndex(function(th) {
                    return th.getAttribute('data-column') === column;
                });
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var aCell = a.querySelectorAll('td')[colIndex];
                    var bCell = b.querySelectorAll('td')[colIndex];
                    
                    if (column === 'Status') {
                        // Sort by badge text
                        var aBadge = aCell.querySelector('.badge');
                        var bBadge = bCell.querySelector('.badge');
                        aVal = aBadge ? aBadge.textContent.trim().toLowerCase() : aCell.textContent.trim().toLowerCase();
                        bVal = bBadge ? bBadge.textContent.trim().toLowerCase() : bCell.textContent.trim().toLowerCase();
                    } else if (column === 'Name') {
                        // Sort by link text
                        var aLink = aCell.querySelector('a');
                        var bLink = bCell.querySelector('a');
                        aVal = aLink ? aLink.textContent.trim().toLowerCase() : aCell.textContent.trim().toLowerCase();
                        bVal = bLink ? bLink.textContent.trim().toLowerCase() : bCell.textContent.trim().toLowerCase();
                    } else {
                        aVal = aCell.textContent.trim().toLowerCase();
                        bVal = bCell.textContent.trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.innerHTML = '';
                rows.forEach(function(row) {
                    tbody.appendChild(row);
                });
                
                updateSortIcons(column, direction);
            }
            
            function updateSortIcons(column, direction) {
                var allHeaders = table.querySelectorAll('.sortable i');
                allHeaders.forEach(function(icon) {
                    icon.className = 'fas fa-sort float-right';
                    icon.style.opacity = '0.3';
                });
                
                var activeHeader = table.querySelector('.sortable[data-column="' + column + '"]');
                if (activeHeader) {
                    var icon = activeHeader.querySelector('i');
                    if (icon) {
                        icon.className = direction === 'asc' ? 'fas fa-sort-up float-right' : 'fas fa-sort-down float-right';
                        icon.style.opacity = '1';
                    }
                }
            }
        }
        
        // Initialize both KPI tables
        var activeTable = document.querySelector('#kpis .sortable-table');
        if (activeTable) {
            initializeSortableTable(activeTable);
        }
        
        // Find archived table (second sortable-table after #kpis)
        var allCards = document.querySelectorAll('.card');
        var archivedCard = null;
        for (var i = 0; i < allCards.length; i++) {
            if (allCards[i].querySelector('.card-title') && allCards[i].querySelector('.card-title').textContent.trim() === 'Archived KPIs') {
                archivedCard = allCards[i];
                break;
            }
        }
        
        if (archivedCard) {
            var archivedTable = archivedCard.querySelector('.sortable-table');
            if (archivedTable) {
                initializeSortableTable(archivedTable);
            }
        }
    })();
</script>

