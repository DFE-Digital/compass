@using System
@model Compass.ViewModels.ProjectTeamMemberDetailsViewModel

@{
    ViewData["Title"] = $"Team member – {Model.ProjectTitle}";
    var returnUrl = Url.Action("Details", "Project", new { id = Model.ProjectId, tab = "team" });
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-3">
            <div class="col-12">
                <a class="btn btn-link px-0 mb-2" href="@returnUrl" aria-label="Back to project team">
                    <i class="fas fa-arrow-left mr-2" aria-hidden="true"></i>Back to team
                </a>
                <h1 class="mb-1">Team member</h1>
                <p class="text-muted mb-0">Project: @Model.ProjectTitle</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-8 col-md-10">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h3 class="card-title mb-0">@Model.Name</h3>
                        <div class="btn-group btn-group-sm" role="group">
                            <a class="btn btn-outline-secondary" asp-action="EditTeamMember" asp-route-projectId="@Model.ProjectId" asp-route-teamMemberId="@Model.TeamMemberId">Edit</a>
                            <button type="button" class="btn btn-outline-danger" data-toggle="modal" data-target="#removeTeamMemberModal">Remove from team</button>
                        </div>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Email</dt>
                            <dd class="col-sm-8">
                                <a href="mailto:@Model.Email">@Model.Email</a>
                            </dd>

                            <dt class="col-sm-4">Role</dt>
                            <dd class="col-sm-8">@Model.Role</dd>

                            <dt class="col-sm-4">Funding</dt>
                            <dd class="col-sm-8">@Model.FundingArrangement</dd>

                            <dt class="col-sm-4">Type</dt>
                            <dd class="col-sm-8">@Model.EmploymentType</dd>

                            <dt class="col-sm-4">Status</dt>
                            <dd class="col-sm-8">@Model.TeamStatus</dd>

                            <dt class="col-sm-4">Reason for leaving</dt>
                            <dd class="col-sm-8">
                                @if (string.Equals(Model.TeamStatus, "previous", StringComparison.OrdinalIgnoreCase))
                                {
                                    if (!string.IsNullOrWhiteSpace(Model.LeaveReason))
                                    {
                                        <span>@Model.LeaveReason</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Not recorded</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Still on team</span>
                                }
                            </dd>

                            <dt class="col-sm-4">Added to team</dt>
                            <dd class="col-sm-8">@Model.AddedAt.ToString("d MMM yyyy")</dd>

                            @if (Model.LeftAt.HasValue)
                            {
                                <dt class="col-sm-4">Removed from team</dt>
                                <dd class="col-sm-8">@Model.LeftAt.Value.ToString("d MMM yyyy")</dd>
                            }
                        </dl>
                    </div>
                    <div class="card-footer d-flex justify-content-between align-items-center">
                        <a class="btn btn-outline-secondary" href="@returnUrl">Back to team</a>
                        <button type="button" class="btn btn-danger" data-toggle="modal" data-target="#removeTeamMemberModal">Remove from team</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="modal fade" id="removeTeamMemberModal" tabindex="-1" role="dialog" aria-labelledby="removeTeamMemberModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="removeTeamMemberModalLabel">Remove from team</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="RemoveTeamMember" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ProjectId" value="@Model.ProjectId" />
                <input type="hidden" name="TeamMemberId" value="@Model.TeamMemberId" />
                <div class="modal-body">
                    <p>Tell us why <strong>@Model.Name</strong> is leaving the team.</p>
                    <div class="form-group">
                        <label for="removeReason">Reason for leaving <span class="text-danger">*</span></label>
                        <textarea id="removeReason"
                                  name="Reason"
                                  class="form-control"
                                  rows="3"
                                  required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Remove from team</button>
                </div>
            </form>
        </div>
    </div>
</div>

