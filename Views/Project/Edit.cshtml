@model Compass.Models.Project

@{
    ViewData["Title"] = "Edit Project";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Projects</a></li>
                    <li class="breadcrumb-item active">Project</li>
                </ol>
                <h1 class="m-0">Edit Project</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Edit Project</h3>
                    </div>
                    <form asp-action="Edit" method="post">
                        <div class="card-body">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                            <input type="hidden" asp-for="Id" />
                            <input type="hidden" asp-for="CreatedAt" />
                            <input type="hidden" asp-for="StartDate" />
                            <input type="hidden" asp-for="TargetDeliveryDate" />
                            <input type="hidden" asp-for="RagStatus" />
                            <input type="hidden" asp-for="RagJustification" />
                            <input type="hidden" asp-for="Status" />
                            <input type="hidden" asp-for="Phase" />
                            <input type="hidden" asp-for="TotalPermFte" />
                            <input type="hidden" asp-for="TotalMspFte" />
                            <input type="hidden" asp-for="IsFlagship" />
                            <input type="hidden" asp-for="ActualDeliveryDate" />
                            
                            <div class="form-group">
                                <label asp-for="Title" class="control-label">Project Title *</label>
                                <input asp-for="Title" class="form-control" placeholder="Enter project title" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                                <small class="form-text text-muted">The name of your project</small>
                            </div>

                            <div class="form-group">
                                <label asp-for="BusinessArea" class="control-label">Business Area</label>
                                <input asp-for="BusinessArea" class="form-control" placeholder="Enter business area" />
                                <span asp-validation-for="BusinessArea" class="text-danger"></span>
                                <small class="form-text text-muted">The business area this project belongs to</small>
                            </div>

                            <div class="form-group">
                                <label asp-for="Aim" class="control-label">Aim *</label>
                                <textarea asp-for="Aim" class="form-control" rows="4" placeholder="Enter project aim"></textarea>
                                <span asp-validation-for="Aim" class="text-danger"></span>
                                <small class="form-text text-muted">What is this project trying to achieve?</small>
                            </div>
                        </div>
                        <div class="card-footer">
                            <button type="submit" class="btn btn-primary">Update Project</button>
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
