@model Compass.Models.Project

@{
    ViewData["Title"] = "Edit Project";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Projects</a></li>
                    <li class="breadcrumb-item active">Edit</li>
                </ol>
                <h1 class="m-0">Edit Project</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Project Details</h3>
                    </div>
                    <form asp-action="Edit" method="post">
                        <div class="card-body">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                            <input type="hidden" asp-for="Id" />
                            <input type="hidden" asp-for="CreatedAt" />
                            
                            <div class="form-group">
                                <label asp-for="Title" class="control-label">Title *</label>
                                <input asp-for="Title" class="form-control" placeholder="Enter project title" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Aim" class="control-label">Aim *</label>
                                <textarea asp-for="Aim" class="form-control" rows="3" placeholder="Enter project aim"></textarea>
                                <span asp-validation-for="Aim" class="text-danger"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="control-label">Missions</label>
                                        <div class="form-check-group">
                                            @foreach (var mission in ViewBag.Missions)
                                            {
                                                <div class="form-check">
                                                    <input type="checkbox" class="form-check-input" name="missionIds" value="@mission.Id" id="mission_@mission.Id">
                                                    <label class="form-check-label" for="mission_@mission.Id">@mission.Title</label>
                                                </div>
                                            }
                                        </div>
                                        <small class="text-muted">Note: Edit functionality for missions and funding will be updated in a future release.</small>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="control-label">Funding Allocations</label>
                                        <div class="alert alert-info">
                                            <small>Funding allocation editing will be available in a future update. Current allocations are preserved.</small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="StartDate" class="control-label">Start Date *</label>
                                        <input asp-for="StartDate" type="date" class="form-control" />
                                        <span asp-validation-for="StartDate" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="TargetDeliveryDate" class="control-label">Target Delivery Date *</label>
                                        <input asp-for="TargetDeliveryDate" type="date" class="form-control" />
                                        <span asp-validation-for="TargetDeliveryDate" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="ActualDeliveryDate" class="control-label">Actual Delivery Date</label>
                                        <input asp-for="ActualDeliveryDate" type="date" class="form-control" />
                                        <span asp-validation-for="ActualDeliveryDate" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="Phase" class="control-label">Phase</label>
                                        <select asp-for="Phase" class="form-control">
                                            <option value="">Select phase</option>
                                            <option value="Discovery">Discovery</option>
                                            <option value="Alpha">Alpha</option>
                                            <option value="Private beta">Private beta</option>
                                            <option value="Public beta">Public beta</option>
                                            <option value="Live">Live</option>
                                        </select>
                                        <span asp-validation-for="Phase" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="BusinessArea" class="control-label">Business Area</label>
                                        <input asp-for="BusinessArea" class="form-control" placeholder="Enter business area" />
                                        <span asp-validation-for="BusinessArea" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="RagStatus" class="control-label">RAG Status</label>
                                        <select asp-for="RagStatus" class="form-control">
                                            <option value="Green">Green</option>
                                            <option value="Amber-Green">Amber-Green</option>
                                            <option value="Amber-Red">Amber-Red</option>
                                            <option value="Red">Red</option>
                                        </select>
                                        <span asp-validation-for="RagStatus" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="TotalPermFte" class="control-label">Total Perm FTE</label>
                                        <input asp-for="TotalPermFte" type="number" step="0.1" class="form-control" placeholder="0.0" />
                                        <span asp-validation-for="TotalPermFte" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="TotalMspFte" class="control-label">Total MSP FTE</label>
                                        <input asp-for="TotalMspFte" type="number" step="0.1" class="form-control" placeholder="0.0" />
                                        <span asp-validation-for="TotalMspFte" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label asp-for="RagJustification" class="control-label">RAG Justification</label>
                                <textarea asp-for="RagJustification" class="form-control" rows="2" placeholder="Enter RAG status justification"></textarea>
                                <span asp-validation-for="RagJustification" class="text-danger"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="Status" class="control-label">Status</label>
                                        <select asp-for="Status" class="form-control">
                                            <option value="Active">Active</option>
                                            <option value="Paused">Paused</option>
                                            <option value="Completed">Completed</option>
                                            <option value="Cancelled">Cancelled</option>
                                        </select>
                                        <span asp-validation-for="Status" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <div class="form-check">
                                            <input asp-for="IsFlagship" class="form-check-input" type="checkbox" />
                                            <label asp-for="IsFlagship" class="form-check-label">
                                                Flagship Project
                                            </label>
                                        </div>
                                        <span asp-validation-for="IsFlagship" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer">
                            <div class="form-group">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> Update Project
                                </button>
                                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-info">
                                    <i class="fas fa-eye"></i> View Details
                                </a>
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left"></i> Back to List
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
