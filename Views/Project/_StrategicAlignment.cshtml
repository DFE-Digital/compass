@model Compass.Models.Project

<div class="row">
    <div class="col-12">
        <!-- Priority Outcomes -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Priority Outcomes</h3>
                <div class="card-tools">
                    <a href="#" data-toggle="modal" data-target="#manageObjectivesModal">Manage</a>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                @if (!string.IsNullOrEmpty(Model.StrategicObjectives))
                {
                    <div class="mb-3 p-3">
                        <strong>Narrative:</strong>
                        <div class="preserve-formatting mt-2">@Model.StrategicObjectives</div>
                    </div>
                }

                @if (Model.ProjectObjectives != null && Model.ProjectObjectives.Any())
                {
                    @if (!string.IsNullOrEmpty(Model.StrategicObjectives))
                    {
                        <hr class="my-0">
                    }
                 
                        <table class="table table-hover text-nowrap milestones-table">
                            <thead>
                                <tr>
                                    <th>Objective</th>
                                    <th>Priority</th>
                                    <th>Owner</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var projectObjective in Model.ProjectObjectives.OrderBy(po => po.Objective?.Theme ?? "Other").ThenBy(po => po.Objective?.Title))
                                {
                                    <tr>
                                        <td>@(projectObjective.Objective?.Theme ?? "Other")</td>
                                        <td>
                                            <strong>@projectObjective.Objective?.Title</strong>
                                            @if (!string.IsNullOrEmpty(projectObjective.Objective?.Description))
                                            {
                                                <br>
                                                <small class="text-muted">@projectObjective.Objective.Description</small>
                                            }
                                        </td>
                                        <td>@(projectObjective.Objective?.OwnerUser?.Name ?? "Not assigned")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                
                }
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <!-- Mission Pillars -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Mission Pillars</h3>
                <div class="card-tools">
                    <a href="#" data-toggle="modal" data-target="#manageMissionsModal">Manage</a>
                </div>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.MissionPillars))
                {
                    <div class="mb-3">
                        <strong>Narrative:</strong>
                        <div class="preserve-formatting mt-2">@Model.MissionPillars</div>
                    </div>
                }
                else
                {
                    <p class="text-muted">No mission pillars description provided.</p>
                }

                @if (Model.ProjectMissions != null && Model.ProjectMissions.Any())
                {
                    <hr>
                    <strong>Linked Missions:</strong>
                    <ul class="mt-2">
                        @foreach (var projectMission in Model.ProjectMissions.OrderBy(pm => pm.Mission?.Title))
                        {
                            <li class="mb-2">
                                <strong>@projectMission.Mission?.Title</strong>
                                @if (!string.IsNullOrEmpty(projectMission.Mission?.Description))
                                {
                                    <br>
                                    <small class="text-muted">@projectMission.Mission.Description</small>
                                }
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <!-- Flagship Project -->
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Flagship Project Status</h3>
                <div class="card-tools">
                    <a href="#" data-toggle="modal" data-target="#manageFlagshipModal">Manage</a>
                </div>
            </div>
            <div class="card-body">
                @if (Model.IsFlagship)
                {
                    <div class="alert alert-info mb-0">
                        <i class="fas fa-flag"></i> <strong>This is a Flagship Project</strong>
                        <p class="mb-0 mt-2">Flagship projects are high-priority initiatives that are reported separately in DDT reports and can contain multiple deliverables.</p>
                    </div>
                }
                else
                {
                    <p class="text-muted">This is a standard project. Mark as flagship to enable deliverables management and DDT flagship reporting.</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <!-- Multi-Department Cooperation -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Multi-Department Cooperation</h3>
                <div class="card-tools">
                    <a href="#" data-toggle="modal" data-target="#manageDepartmentsModal">Manage</a>
                </div>
            </div>
            <div class="card-body">
                @if (Model.IsMultiDepartmentProject)
                {
                    <p><strong>This project is being delivered in cooperation with other government departments.</strong></p>
                    
                    @if (!string.IsNullOrEmpty(Model.OtherDepartments))
                    {
                        var departmentIds = System.Text.Json.JsonSerializer.Deserialize<List<int>>(Model.OtherDepartments);
                        var departments = ViewBag.GovernmentDepartments as List<Compass.Models.GovernmentDepartment>;
                        var selectedDepartments = departments?.Where(d => departmentIds.Contains(d.Id)).ToList();
                        
                        @if (selectedDepartments != null && selectedDepartments.Any())
                        {
                            <div class="mt-2">
                                <strong>Partnering Departments:</strong>
                                <ul class="mt-2">
                                    @foreach (var dept in selectedDepartments.OrderBy(d => d.Title))
                                    {
                                        <li>
                                            <strong>@dept.Title</strong>
                                            @if (!string.IsNullOrEmpty(dept.Abbreviation))
                                            {
                                                <span class="text-muted">(@dept.Abbreviation)</span>
                                            }
                                        </li>
                                    }
                                </ul>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted mt-2">No partnering departments specified.</p>
                    }
                }
                else
                {
                    <p class="text-muted">This is a single-department project (DfE only).</p>
                }
            </div>
        </div>
    </div>
</div>

<!-- Manage Priority Outcomes Modal -->
<div class="modal fade" id="manageObjectivesModal" tabindex="-1" role="dialog" aria-labelledby="manageObjectivesModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="manageObjectivesModalLabel">Manage Priority Outcomes</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateStrategicObjectivesAndLinks" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="strategicObjectivesText">Priority Outcomes Narrative</label>
                        <textarea class="form-control preserve-formatting" id="strategicObjectivesText" name="strategicObjectivesText" rows="6" placeholder="Describe how this project aligns with priority outcomes...">@Model.StrategicObjectives</textarea>
                        <small class="form-text text-muted">Provide a narrative description of how this project supports priority outcomes.</small>
                    </div>

                    <hr>

                    <div class="form-group">
                        <label>Link to specific priority outcomes</label>
                        <p class="small text-muted">Select the priority outcomes this project directly supports.</p>
                        
                        @{
                            var selectedObjectiveIds = Model.ProjectObjectives != null 
                                ? Model.ProjectObjectives.Select(po => po.ObjectiveId).ToList() 
                                : new List<int>();
                            var objectives = ViewBag.Objectives as IEnumerable<Compass.Models.Objective>;
                            
                            if (objectives != null && objectives.Any())
                            {
                                var objectivesByTheme = objectives.GroupBy(o => o.Theme ?? "Other");
                                
                                foreach (var themeGroup in objectivesByTheme.OrderBy(g => g.Key))
                                {
                                    <div class="mb-3">
                                        <h6 class="mb-2">@themeGroup.Key</h6>
                                        @foreach (var objective in themeGroup.OrderBy(o => o.Title))
                                        {
                                            <div class="form-check">
                                                <input type="checkbox" name="selectedObjectiveIds" value="@objective.Id" 
                                                       class="form-check-input" id="obj_@objective.Id"
                                                       @(selectedObjectiveIds.Contains(objective.Id) ? "checked" : "") />
                                                <label class="form-check-label" for="obj_@objective.Id">
                                                    @objective.Title
                                                    @if (!string.IsNullOrEmpty(objective.Description))
                                                    {
                                                        <br><small class="text-muted">@objective.Description</small>
                                                    }
                                                </label>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted">No priority outcomes available.</p>
                            }
                        }
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Manage Mission Pillars Modal -->
