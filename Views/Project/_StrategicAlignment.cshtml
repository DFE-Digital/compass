                                                       @(selectedMissionIds.Contains(mission.Id) ? "checked" : "") />
                                                <label class="form-check-label" for="mission_@mission.Id">
                                                    @mission.Title
                                                    @if (!string.IsNullOrEmpty(mission.Description))
                                                    {
                                                        <br><small class="text-muted">@mission.Description</small>
                                                    }
                                                </label>
                                            </div>
                                        }
