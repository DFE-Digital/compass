                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Manage Multi-Department Cooperation Modal -->
<div class="modal fade" id="manageDepartmentsModal" tabindex="-1" role="dialog" aria-labelledby="manageDepartmentsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="manageDepartmentsModalLabel">Manage Multi-Department Cooperation</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateMultiDepartmentCooperation" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="modal-body">
                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="isMultiDeptCheck" name="isMultiDepartmentProject" value="true" @(Model.IsMultiDepartmentProject ? "checked" : "") />
                            <label class="form-check-label" for="isMultiDeptCheck">Is this a multi-department project?</label>
                        </div>
                        <small class="form-text text-muted">Being delivered by DfE and other government departments</small>
                    </div>

                    <div id="departmentSelectionSection" style="@(Model.IsMultiDepartmentProject ? "" : "display: none;")">
                        <hr>
                        
                        <div class="form-group">
                            <label>Other Government Departments</label>
                            <p class="small text-muted">Search and select the government departments partnering on this project.</p>
                            
                            <div class="input-group">
                                <input type="text" class="form-control" id="deptSearch" placeholder="Search for government departments..." autocomplete="off" />
                            </div>
                            <div id="deptSearchResults"></div>
                            
                            <div id="selectedDepartmentsList" class="mt-3"></div>
                            <input type="hidden" name="otherDepartments" id="otherDepartmentsInput" value="@Model.OtherDepartments" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Manage Flagship Status Modal -->
<div class="modal fade" id="manageFlagshipModal" tabindex="-1" role="dialog" aria-labelledby="manageFlagshipModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="manageFlagshipModalLabel">Manage Flagship Project Status</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateFlagshipStatus" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="modal-body">
                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="isFlagshipCheck" name="isFlagship" value="true" @(Model.IsFlagship ? "checked" : "") />
                            <label class="form-check-label" for="isFlagshipCheck">Mark as Flagship Project</label>
                        </div>
                        <small class="form-text text-muted">Flagship projects are high-priority initiatives that appear in dedicated DDT reports and can manage multiple deliverables.</small>
                    </div>
                    
                    @if (Model.IsFlagship)
                    {
                        <div class="alert alert-info mt-3">
                            <strong>Note:</strong> This project currently has deliverables linked to it. Removing flagship status will not remove these relationships, but the deliverables tab will no longer be accessible.
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
(function() {
    function initStrategicAlignment() {
        // Namespace to avoid conflicts
        if (!window.StrategicAlignment) {
            window.StrategicAlignment = {};
        }
        
        // Initialize with existing departments
        window.StrategicAlignment.selectedDepartmentsData = [];
        let searchTimeout;
    
    @if (Model.IsMultiDepartmentProject && !string.IsNullOrEmpty(Model.OtherDepartments))
    {
        var deptIds = System.Text.Json.JsonSerializer.Deserialize<List<int>>(Model.OtherDepartments);
        var depts = ViewBag.GovernmentDepartments as List<Compass.Models.GovernmentDepartment>;
        var selected = depts?.Where(d => deptIds.Contains(d.Id)).ToList();
        
        if (selected != null && selected.Any())
        {
            @:window.StrategicAlignment.selectedDepartmentsData = [
            for (int i = 0; i < selected.Count; i++)
            {
                var dept = selected[i];
                @:{ id: @dept.Id, text: '@Html.Raw(dept.Title.Replace("'", "\\'"))', abbreviation: '@Html.Raw(dept.Abbreviation?.Replace("'", "\\'") ?? "")' }@(i < selected.Count - 1 ? "," : "")
            }
            @:];
        }
    }
    
        function updateSelectedDepartmentsList() {
            const $container = $('#selectedDepartmentsList');
            const $input = $('#otherDepartmentsInput');
            const selectedData = window.StrategicAlignment.selectedDepartmentsData;
            
            if (selectedData.length === 0) {
                $container.empty();
                $input.val('');
                return;
            }
            
            $container.html('<strong class="d-block mb-2">Selected Departments:</strong>');
            
            selectedData.forEach(function(dept) {
                const displayText = dept.text + (dept.abbreviation ? ' (' + dept.abbreviation + ')' : '');
                const $item = $('<div class="d-inline-block mr-2 mb-2"></div>');
                const $badge = $('<span class="badge badge-primary"></span>');
                $badge.text(displayText + ' ');
                
                const $removeBtn = $('<button type="button" class="btn btn-sm btn-link text-white p-0 ml-1" aria-label="Remove"></button>');
                $removeBtn.html('&times;');
                $removeBtn.on('click', function() {
                    removeDepartmentFromList(dept.id);
                });
                
                $badge.append($removeBtn);
                $item.append($badge);
                $container.append($item);
            });
            
            // Update hidden input with JSON array of IDs
            $input.val(JSON.stringify(selectedData.map(d => d.id)));
        }
        
        function removeDepartmentFromList(deptId) {
            window.StrategicAlignment.selectedDepartmentsData = window.StrategicAlignment.selectedDepartmentsData.filter(d => d.id !== deptId);
            updateSelectedDepartmentsList();
        }
        
        function addDepartment(dept) {
            if (!window.StrategicAlignment.selectedDepartmentsData.find(d => d.id === dept.id)) {
                window.StrategicAlignment.selectedDepartmentsData.push(dept);
                updateSelectedDepartmentsList();
                $('#deptSearch').val('');
                $('#deptSearchResults').empty();
            }
        }
        
        function displaySearchResults(results) {
            const $container = $('#deptSearchResults');
            $container.empty();
            
            if (results.length === 0) {
                $container.html('<div class="list-group-item text-muted mt-2">No departments found</div>');
                return;
            }
            
            const $listGroup = $('<div class="list-group mt-2"></div>');
            
            results.forEach(function(dept) {
                // Check if already selected
                if (window.StrategicAlignment.selectedDepartmentsData.find(d => d.id === dept.id)) {
                    return; // Skip already selected
                }
                
                const $item = $('<a href="#" class="list-group-item list-group-item-action"></a>');
                const displayText = dept.text + (dept.abbreviation ? ' (' + dept.abbreviation + ')' : '');
                $item.text(displayText);
                
                $item.on('click', function(e) {
                    e.preventDefault();
                    addDepartment(dept);
                });
                
                $listGroup.append($item);
            });
            
            $container.append($listGroup);
        }
        
        function searchDepartments(query) {
            $.ajax({
                url: '/Admin/GovernmentDepartment/Search',
                data: { q: query },
                success: function(data) {
                    displaySearchResults(data.results);
                },
                error: function() {
                    $('#deptSearchResults').html('<div class="alert alert-danger mt-2">Error searching departments</div>');
                }
            });
        }
        
        // Set up department management modal
        $('#manageDepartmentsModal').on('shown.bs.modal', function() {
            console.log('Multi-department modal opened');
            updateSelectedDepartmentsList();
            
            // Ensure the section visibility is correct based on checkbox state
            if ($('#isMultiDeptCheck').is(':checked')) {
                $('#departmentSelectionSection').show();
            } else {
                $('#departmentSelectionSection').hide();
            }
            
            // Clear any previous search results
            $('#deptSearchResults').empty();
            $('#deptSearch').val('');
        });
        
        // Show/hide department selection when checkbox changes
        $('#isMultiDeptCheck').on('change', function() {
            console.log('Multi-department checkbox changed:', $(this).is(':checked'));
            if ($(this).is(':checked')) {
                $('#departmentSelectionSection').slideDown(function() {
                    // Focus search field after animation
                    $('#deptSearch').focus();
                });
            } else {
                $('#departmentSelectionSection').slideUp();
                $('#deptSearchResults').empty();
            }
        });
        
        // Department search with debounce
        $('#deptSearch').on('input', function() {
            console.log('Department search input:', $(this).val());
            clearTimeout(searchTimeout);
            const query = $(this).val().trim();
            
            if (query.length < 2) {
                $('#deptSearchResults').empty();
                return;
            }
            
            searchTimeout = setTimeout(function() {
                searchDepartments(query);
            }, 300);
        });
        
        // Hide search results when clicking outside
        $(document).on('click', function(e) {
            if (!$(e.target).closest('#deptSearch').length && !$(e.target).closest('#deptSearchResults').length) {
                $('#deptSearchResults').empty();
            }
        });
    
        // Initialize on page load
        if ($('#isMultiDeptCheck').is(':checked')) {
            updateSelectedDepartmentsList();
        }
    }
    
    // Wait for jQuery to be available
    if (typeof jQuery !== 'undefined') {
        $(document).ready(initStrategicAlignment);
    } else {
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof jQuery !== 'undefined') {
                $(document).ready(initStrategicAlignment);
            }
        });
    }
})();
</script>

