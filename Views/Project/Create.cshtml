@model Compass.Models.Project

@{
    ViewData["Title"] = "Create Project";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Create Project</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Project" asp-action="Index">Projects</a></li>
                    <li class="breadcrumb-item active">Project</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <form asp-action="Create" method="post">
            <div class="row">
                <div class="col-md-8">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Project Details</h3>
                        </div>
                        <div class="card-body">
                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="alert alert-danger">
                                    <h5><i class="icon fas fa-ban"></i> Please correct the following errors:</h5>
                                    <div asp-validation-summary="All" class="text-danger"></div>
                                </div>
                            }
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="Title" class="control-label">Project Title *</label>
                                        <input asp-for="Title" class="form-control" />
                                        <span asp-validation-for="Title" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="Status" class="control-label">Project Status</label>
                                        <select asp-for="Status" class="form-control">
                                            <option value="Active">Active</option>
                                            <option value="On Hold">On Hold</option>
                                            <option value="Completed">Completed</option>
                                            <option value="Cancelled">Cancelled</option>
                                        </select>
                                        <span asp-validation-for="Status" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="StartDate" class="control-label">Start Date *</label>
                                        <input asp-for="StartDate" type="date" class="form-control" />
                                        <span asp-validation-for="StartDate" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="TargetDeliveryDate" class="control-label">Target Delivery Date</label>
                                        <input asp-for="TargetDeliveryDate" type="date" class="form-control" />
                                        <span asp-validation-for="TargetDeliveryDate" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label asp-for="Aim" class="control-label">Project Aim</label>
                                <textarea asp-for="Aim" class="form-control" rows="3"></textarea>
                                <span asp-validation-for="Aim" class="text-danger"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="Phase" class="control-label">Phase of Delivery</label>
                                        <select asp-for="Phase" class="form-control">
                                            <option value="">Select phase</option>
                                            @if (ViewBag.Phases != null)
                                            {
                                                @foreach (var phase in ViewBag.Phases)
                                                {
                                                    <option value="@phase">@phase</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="Phase" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="BusinessArea" class="control-label">Business Area</label>
                                        <select asp-for="BusinessArea" class="form-control">
                                            <option value="">Select business area</option>
                                            @if (ViewBag.BusinessAreas != null)
                                            {
                                                @foreach (var area in ViewBag.BusinessAreas)
                                                {
                                                    <option value="@area">@area</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="BusinessArea" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Organizational Structure -->
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="PrimaryOrganizationalGroupId" class="control-label">Primary Organizational Group</label>
                                        <select asp-for="PrimaryOrganizationalGroupId" class="form-control" id="primaryOrgGroup">
                                            <option value="">Select organizational group</option>
                                            @if (ViewBag.OrganizationalGroups != null)
                                            {
                                                @foreach (var group in ViewBag.OrganizationalGroups)
                                                {
                                                    <option value="@group.Id">@group.FullPath</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="PrimaryOrganizationalGroupId" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <div class="form-check">
                                            <input asp-for="IsMultiDepartmentProject" class="form-check-input" id="isMultiDept" />
                                            <label asp-for="IsMultiDepartmentProject" class="form-check-label">Is this a multi-department project?</label>
                                        </div>
                                        <small class="form-text text-muted">Being delivered by DfE and other government departments</small>
                                        <span asp-validation-for="IsMultiDepartmentProject" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="row" id="otherDepartmentsRow" style="display: none;">
                                <div class="col-12">
                                    <div class="form-group">
                                        <label class="control-label">Other Government Departments</label>
                                        <div class="input-group">
                                            <input type="text" class="form-control" id="departmentSearch" placeholder="Search for government departments..." />
                                            <div class="input-group-append">
                                                <button type="button" class="btn btn-outline-secondary" id="addDepartmentBtn">Add</button>
                                            </div>
                                        </div>
                                        <div id="selectedDepartments" class="mt-2"></div>
                                        <input type="hidden" asp-for="OtherDepartments" id="otherDepartmentsJson" />
                                        <span asp-validation-for="OtherDepartments" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="RagStatus" class="control-label">RAG Status</label>
                                        <select asp-for="RagStatus" class="form-control">
                                            <option value="">Select RAG status</option>
                                            <option value="Green">Green</option>
                                            <option value="Amber-Green">Amber-Green</option>
                                            <option value="Amber-Red">Amber-Red</option>
                                            <option value="Red">Red</option>
                                        </select>
                                        <span asp-validation-for="RagStatus" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="TotalPermFte" class="control-label">Total Permanent FTE</label>
                                        <input asp-for="TotalPermFte" type="number" step="0.01" class="form-control" />
                                        <span asp-validation-for="TotalPermFte" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="form-group">
                                        <label asp-for="TotalMspFte" class="control-label">Total MSP FTE</label>
                                        <input asp-for="TotalMspFte" type="number" step="0.01" class="form-control" />
                                        <span asp-validation-for="TotalMspFte" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label asp-for="RagJustification" class="control-label">RAG Justification</label>
                                <textarea asp-for="RagJustification" class="form-control" rows="2"></textarea>
                                <span asp-validation-for="RagJustification" class="text-danger"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-check">
                                        <input asp-for="IsFlagship" class="form-check-input" />
                                        <label asp-for="IsFlagship" class="form-check-label">This is a flagship project</label>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-check">
                                        <input asp-for="IsAiInitiative" class="form-check-input" />
                                        <label asp-for="IsAiInitiative" class="form-check-label">This is an AI initiative</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Strategic Objectives -->
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Strategic Objectives</h3>
                        </div>
                        <div class="card-body">
                            <div class="card">
                                <div class="card-header">
                                    <h5 class="mb-0">Mission Pillars</h5>
                                </div>
                                <div class="card-body">
                                    <p>Does this project support the delivery of any of the following missions?</p>
                                    @if (ViewBag.Missions != null)
                                    {
                                        @foreach (var mission in ViewBag.Missions)
                                        {
                                            <div class="form-check">
                                                <input type="checkbox" name="SelectedMissionIds" value="@mission.Id" class="form-check-input" />
                                                <label class="form-check-label">@mission.Title</label>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                            
                            <div class="card mt-3">
                                <div class="card-header">
                                    <h5 class="mb-0">Strategic Objectives</h5>
                                </div>
                                <div class="card-body">
                                    <p>Which strategic objectives does this project support?</p>
                                    @if (ViewBag.Objectives != null)
                                    {
                                        @foreach (var themeGroup in ViewBag.Objectives)
                                        {
                                            <div class="mb-3">
                                                <h6>@themeGroup.Key</h6>
                                                @foreach (var objective in themeGroup.Value)
                                                {
                                                    <div class="form-check">
                                                        <input type="checkbox" name="SelectedObjectiveIds" value="@objective.Id" class="form-check-input" />
                                                        <label class="form-check-label">@objective.Title</label>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Funding -->
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Funding</h3>
                        </div>
                        <div class="card-body">
                            <div id="funding-container">
                                <div class="card mb-3">
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label class="control-label">Funding Source</label>
                                                    <select name="FundingAllocations[0].FundingSourceId" class="form-control">
                                                        <option value="">Select funding source</option>
                                                        @if (ViewBag.FundingSources != null)
                                                        {
                                                            @foreach (var source in ViewBag.FundingSources)
                                                            {
                                                                <option value="@source.Id">@source.Name</option>
                                                            }
                                                        }
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-4">
                                                <div class="form-group">
                                                    <label class="control-label">Allocation %</label>
                                                    <input type="number" name="FundingAllocations[0].AllocationPercentage" class="form-control" step="0.01" min="0" max="100" placeholder="0.00" />
                                                </div>
                                            </div>
                                            <div class="col-md-2">
                                                <div class="form-group">
                                                    <label class="control-label">&nbsp;</label>
                                                    <button type="button" class="btn btn-outline-danger btn-block" onclick="removeFundingSource(this)">Remove</button>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-12">
                                                <div class="form-group">
                                                    <label class="control-label">Notes (Optional)</label>
                                                    <input type="text" name="FundingAllocations[0].Notes" class="form-control" placeholder="Additional notes about this funding allocation" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <button type="button" class="btn btn-outline-primary" onclick="addFundingSource()">Add Another Funding Source</button>
                        </div>
                    </div>

                    <!-- Expected Outcomes -->
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Expected Outcomes</h3>
                        </div>
                        <div class="card-body">
                            <div id="outcomes-container">
                                <div class="card mb-3">
                                    <div class="card-body">
                                        <div class="form-group">
                                            <label class="control-label">Expected Outcome</label>
                                            <input type="text" name="Outcomes[0].Outcome" class="form-control" placeholder="Describe the expected outcome" />
                                        </div>
                                        <div class="form-group">
                                            <label class="control-label">Measure of Success</label>
                                            <input type="text" name="Outcomes[0].MeasureOfSuccess" class="form-control" placeholder="How will you know the outcome has been achieved?" />
                                        </div>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label class="control-label">Confidence Level</label>
                                                    <select name="Outcomes[0].ConfidenceLevel" class="form-control">
                                                        <option value="Low">Low</option>
                                                        <option value="Medium" selected>Medium</option>
                                                        <option value="High">High</option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label class="control-label">&nbsp;</label>
                                                    <button type="button" class="btn btn-outline-danger btn-block" onclick="removeOutcome(this)">Remove</button>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label class="control-label">Confidence Explanation</label>
                                            <textarea name="Outcomes[0].ConfidenceExplanation" class="form-control" rows="2" placeholder="Explain your confidence level"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <button type="button" class="btn btn-outline-primary" onclick="addOutcome()">Add Another Outcome</button>
                        </div>
                    </div>

                    <!-- Roles & Contacts -->
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Roles & Contacts</h3>
                        </div>
                        <div class="card-body">
                            <div id="contacts-container">
                                <div class="card mb-3">
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label class="control-label">Role</label>
                                                    <input type="text" name="Contacts[0].Role" class="form-control" placeholder="e.g., Product Manager, Delivery Manager" />
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label class="control-label">&nbsp;</label>
                                                    <button type="button" class="btn btn-outline-danger btn-block" onclick="removeContact(this)">Remove</button>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label class="control-label">Name</label>
                                                    <input type="text" name="Contacts[0].Name" class="form-control" placeholder="Contact name" />
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="form-group">
                                                    <label class="control-label">Email</label>
                                                    <input type="email" name="Contacts[0].Email" class="form-control" placeholder="Contact email" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label class="control-label">Role Description</label>
                                            <textarea name="Contacts[0].RoleDescription" class="form-control" rows="2" placeholder="Brief description of the role"></textarea>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <button type="button" class="btn btn-outline-primary" onclick="addContact()">Add Another Contact</button>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Actions</h3>
                        </div>
                        <div class="card-body">
                            <button type="submit" class="btn btn-primary btn-block">Create Project</button>
                            <a asp-action="Index" class="btn btn-secondary btn-block">Cancel</a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        let fundingIndex = 1;
        let outcomeIndex = 1;
        let contactIndex = 1;

        function addFundingSource() {
            const container = document.getElementById('funding-container');
            const newCard = document.createElement('div');
            newCard.className = 'card mb-3';
            newCard.innerHTML = 
                '<div class="card-body">' +
                    '<div class="row">' +
                        '<div class="col-md-6">' +
                            '<div class="form-group">' +
                                '<label class="control-label">Funding Source</label>' +
                                '<select name="FundingAllocations[' + fundingIndex + '].FundingSourceId" class="form-control">' +
                                    '<option value="">Select funding source</option>' +
                                    '@if (ViewBag.FundingSources != null) { @foreach (var source in ViewBag.FundingSources) { <option value="@source.Id">@source.Name</option> } }' +
                                '</select>' +
                            '</div>' +
                        '</div>' +
                        '<div class="col-md-4">' +
                            '<div class="form-group">' +
                                '<label class="control-label">Allocation %</label>' +
                                '<input type="number" name="FundingAllocations[' + fundingIndex + '].AllocationPercentage" class="form-control" step="0.01" min="0" max="100" placeholder="0.00" />' +
                            '</div>' +
                        '</div>' +
                        '<div class="col-md-2">' +
                            '<div class="form-group">' +
                                '<label class="control-label">&nbsp;</label>' +
                                '<button type="button" class="btn btn-outline-danger btn-block" onclick="removeFundingSource(this)">Remove</button>' +
                            '</div>' +
                        '</div>' +
                    '</div>' +
                    '<div class="row">' +
                        '<div class="col-md-12">' +
                            '<div class="form-group">' +
                                '<label class="control-label">Notes (Optional)</label>' +
                                '<input type="text" name="FundingAllocations[' + fundingIndex + '].Notes" class="form-control" placeholder="Additional notes about this funding allocation" />' +
                            '</div>' +
                        '</div>' +
                    '</div>' +
                '</div>';
            container.appendChild(newCard);
            fundingIndex++;
        }

        function removeFundingSource(button) {
            button.closest('.card').remove();
        }

        function addOutcome() {
            const container = document.getElementById('outcomes-container');
            const newCard = document.createElement('div');
            newCard.className = 'card mb-3';
            newCard.innerHTML = 
                '<div class="card-body">' +
                    '<div class="form-group">' +
                        '<label class="control-label">Expected Outcome</label>' +
                        '<input type="text" name="Outcomes[' + outcomeIndex + '].Outcome" class="form-control" placeholder="Describe the expected outcome" />' +
                    '</div>' +
                    '<div class="form-group">' +
                        '<label class="control-label">Measure of Success</label>' +
                        '<input type="text" name="Outcomes[' + outcomeIndex + '].MeasureOfSuccess" class="form-control" placeholder="How will you know the outcome has been achieved?" />' +
                    '</div>' +
                    '<div class="row">' +
                        '<div class="col-md-6">' +
                            '<div class="form-group">' +
                                '<label class="control-label">Confidence Level</label>' +
                                '<select name="Outcomes[' + outcomeIndex + '].ConfidenceLevel" class="form-control">' +
                                    '<option value="Low">Low</option>' +
                                    '<option value="Medium" selected>Medium</option>' +
                                    '<option value="High">High</option>' +
                                '</select>' +
                            '</div>' +
                        '</div>' +
                        '<div class="col-md-6">' +
                            '<div class="form-group">' +
                                '<label class="control-label">&nbsp;</label>' +
                                '<button type="button" class="btn btn-outline-danger btn-block" onclick="removeOutcome(this)">Remove</button>' +
                            '</div>' +
                        '</div>' +
                    '</div>' +
                    '<div class="form-group">' +
                        '<label class="control-label">Confidence Explanation</label>' +
                        '<textarea name="Outcomes[' + outcomeIndex + '].ConfidenceExplanation" class="form-control" rows="2" placeholder="Explain your confidence level"></textarea>' +
                    '</div>' +
                '</div>';
            container.appendChild(newCard);
            outcomeIndex++;
        }

        function removeOutcome(button) {
            button.closest('.card').remove();
        }

        function addContact() {
            const container = document.getElementById('contacts-container');
            const newCard = document.createElement('div');
            newCard.className = 'card mb-3';
            newCard.innerHTML = 
                '<div class="card-body">' +
                    '<div class="row">' +
                        '<div class="col-md-6">' +
                            '<div class="form-group">' +
                                '<label class="control-label">Role</label>' +
                                '<input type="text" name="Contacts[' + contactIndex + '].Role" class="form-control" placeholder="e.g., Product Manager, Delivery Manager" />' +
                            '</div>' +
                        '</div>' +
                        '<div class="col-md-6">' +
                            '<div class="form-group">' +
                                '<label class="control-label">&nbsp;</label>' +
                                '<button type="button" class="btn btn-outline-danger btn-block" onclick="removeContact(this)">Remove</button>' +
                            '</div>' +
                        '</div>' +
                    '</div>' +
                    '<div class="row">' +
                        '<div class="col-md-6">' +
                            '<div class="form-group">' +
                                '<label class="control-label">Name</label>' +
                                '<input type="text" name="Contacts[' + contactIndex + '].Name" class="form-control" placeholder="Contact name" />' +
                            '</div>' +
                        '</div>' +
                        '<div class="col-md-6">' +
                            '<div class="form-group">' +
                                '<label class="control-label">Email</label>' +
                                '<input type="email" name="Contacts[' + contactIndex + '].Email" class="form-control" placeholder="Contact email" />' +
                            '</div>' +
                        '</div>' +
                    '</div>' +
                    '<div class="form-group">' +
                        '<label class="control-label">Role Description</label>' +
                        '<textarea name="Contacts[' + contactIndex + '].RoleDescription" class="form-control" rows="2" placeholder="Brief description of the role"></textarea>' +
                    '</div>' +
                '</div>';
            container.appendChild(newCard);
            contactIndex++;
        }

        function removeContact(button) {
            button.closest('.card').remove();
        }

        // Multi-department project functionality
        let selectedDepartments = [];
        
        document.getElementById('isMultiDept').addEventListener('change', function() {
            const otherDeptRow = document.getElementById('otherDepartmentsRow');
            if (this.checked) {
                otherDeptRow.style.display = 'block';
            } else {
                otherDeptRow.style.display = 'none';
                selectedDepartments = [];
                updateSelectedDepartments();
            }
        });

        // Department search functionality
        let searchTimeout;
        document.getElementById('departmentSearch').addEventListener('input', function() {
            clearTimeout(searchTimeout);
            const query = this.value;
            
            if (query.length < 2) {
                hideDepartmentResults();
                return;
            }
            
            searchTimeout = setTimeout(() => {
                searchDepartments(query);
            }, 300);
        });

        function searchDepartments(query) {
            fetch(`/Admin/GovernmentDepartment/Search?q=${encodeURIComponent(query)}`)
                .then(response => response.json())
                .then(data => {
                    showDepartmentResults(data.results);
                })
                .catch(error => {
                    console.error('Error searching departments:', error);
                });
        }

        function showDepartmentResults(departments) {
            const resultsContainer = document.getElementById('departmentResults');
            if (!resultsContainer) {
                const container = document.createElement('div');
                container.id = 'departmentResults';
                container.className = 'list-group mt-2';
                document.getElementById('departmentSearch').parentNode.appendChild(container);
            }
            
            const container = document.getElementById('departmentResults');
            container.innerHTML = '';
            
            if (departments.length === 0) {
                container.innerHTML = '<div class="list-group-item text-muted">No departments found</div>';
            } else {
                departments.forEach(dept => {
                    const item = document.createElement('div');
                    item.className = 'list-group-item list-group-item-action';
                    item.innerHTML = `<strong>${dept.text}</strong>${dept.abbreviation ? ` (${dept.abbreviation})` : ''}`;
                    item.addEventListener('click', () => addDepartment(dept));
                    container.appendChild(item);
                });
            }
            
            container.style.display = 'block';
        }

        function hideDepartmentResults() {
            const container = document.getElementById('departmentResults');
            if (container) {
                container.style.display = 'none';
            }
        }

        function addDepartment(department) {
            if (!selectedDepartments.find(d => d.id === department.id)) {
                selectedDepartments.push(department);
                updateSelectedDepartments();
            }
            
            document.getElementById('departmentSearch').value = '';
            hideDepartmentResults();
        }

        function removeDepartment(departmentId) {
            selectedDepartments = selectedDepartments.filter(d => d.id !== departmentId);
            updateSelectedDepartments();
        }

        function updateSelectedDepartments() {
            const container = document.getElementById('selectedDepartments');
            const jsonInput = document.getElementById('otherDepartmentsJson');
            
            if (selectedDepartments.length === 0) {
                container.innerHTML = '';
                jsonInput.value = '';
                return;
            }
            
            let html = '<div class="mt-2"><strong>Selected Departments:</strong></div>';
            selectedDepartments.forEach(dept => {
                html += `
                    <div class="badge badge-primary mr-2 mb-2">
                        ${dept.text}${dept.abbreviation ? ` (${dept.abbreviation})` : ''}
                        <button type="button" class="btn btn-sm btn-outline-light ml-2" onclick="removeDepartment(${dept.id})">×</button>
                    </div>
                `;
            });
            
            container.innerHTML = html;
            jsonInput.value = JSON.stringify(selectedDepartments.map(d => d.id));
        }

        // Hide department results when clicking outside
        document.addEventListener('click', function(e) {
            if (!e.target.closest('#departmentSearch') && !e.target.closest('#departmentResults')) {
                hideDepartmentResults();
            }
        });
    </script>
}