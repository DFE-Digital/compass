@model Compass.Models.Project

@{
    var successes = Model.Successes
        .OrderByDescending(s => s.RecordedAt)
        .ToList();
}

<div class="card" id="successes">
    <div class="card-header">
        <h3 class="card-title">Work successes</h3>
        <div class="card-tools">
            <a asp-controller="Project" asp-action="CreateSuccess" asp-route-projectId="@Model.Id">Add success</a>
        </div>
    </div>
    <div class="card-body table-responsive p-0">
        @if (successes.Any())
        {
            <table class="table table-hover text-nowrap sortable-table successes-table">
                <thead>
                    <tr>
                        <th class="col-description sortable" data-column="Description" tabindex="0" role="button" aria-label="Sort by Description">
                            Success
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="col-recorded-by sortable" data-column="RecordedBy" tabindex="0" role="button" aria-label="Sort by Recorded By">
                            Recorded by
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="col-recorded-at sortable" data-column="RecordedAt" tabindex="0" role="button" aria-label="Sort by Recorded Date">
                            Recorded date
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="col-slt-flag sortable" data-column="IsReportedToSlt" tabindex="0" role="button" aria-label="Sort by DDT Report">
                            DDT report
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var success in successes)
                    {
                        var displayName = !string.IsNullOrWhiteSpace(success.RecordedByName)
                            ? success.RecordedByName
                            : success.RecordedByEmail;
                        var truncatedDescription = success.SuccessDescription?.Length > 175
                            ? $"{success.SuccessDescription.Substring(0, 175).TrimEnd()}…"
                            : success.SuccessDescription;
                        <tr>
                            <td>
                                <a asp-controller="Project" asp-action="SuccessDetails" asp-route-projectId="@Model.Id" asp-route-successId="@success.Id" title="@success.SuccessDescription">
                                    @truncatedDescription
                                </a>
                            </td>
                            <td>
                                <span>@displayName</span>
                                <br />
                                <small class="text-muted">@success.RecordedByEmail</small>
                            </td>
                            <td>@success.RecordedAt.ToString("d MMMM yyyy")</td>
                            <td>
                                @if (success.IsReportedToSlt)
                                {
                                    <span class="badge badge-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">No</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="p-3">
                <p class="text-muted mb-2">No successes recorded yet.</p>
                <a asp-controller="Project" asp-action="CreateSuccess" asp-route-projectId="@Model.Id">Add the first success</a>
            </div>
        }
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
    (function() {
        function initSorting(table) {
            var sortableHeaders = table.querySelectorAll('.sortable');
            var currentSort = { column: null, direction: 'asc' };
            
            sortableHeaders.forEach(function(header) {
                header.style.cursor = 'pointer';
                
                header.addEventListener('click', function(e) {
                    handleSort(e, header);
                });
                
                header.addEventListener('keypress', function(e) {
                    if (e.which === 13 || e.which === 32) {
                        e.preventDefault();
                        handleSort(e, header);
                    }
                });
            });
            
            function handleSort(e, header) {
                var column = header.getAttribute('data-column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(column, direction);
                currentSort = { column: column, direction: direction };
            }
            
            function sortTable(column, direction) {
                var tbody = table.querySelector('tbody');
                var rows = Array.from(tbody.querySelectorAll('tr'));
                var colIndex = Array.from(table.querySelectorAll('thead th')).findIndex(function(th) {
                    return th.getAttribute('data-column') === column;
                });
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var aCell = a.querySelectorAll('td')[colIndex];
                    var bCell = b.querySelectorAll('td')[colIndex];
                    
                    if (column === 'IsReportedToSlt' || column === 'Status') {
                        // Sort by badge text
                        var aBadge = aCell.querySelector('.badge');
                        var bBadge = bCell.querySelector('.badge');
                        aVal = aBadge ? aBadge.textContent.trim().toLowerCase() : '';
                        bVal = bBadge ? bBadge.textContent.trim().toLowerCase() : '';
                    } else if (column === 'Description') {
                        // Sort by link text
                        var aLink = aCell.querySelector('a');
                        var bLink = bCell.querySelector('a');
                        aVal = aLink ? aLink.textContent.trim().toLowerCase() : aCell.textContent.trim().toLowerCase();
                        bVal = bLink ? bLink.textContent.trim().toLowerCase() : bCell.textContent.trim().toLowerCase();
                    } else if (column === 'RecordedAt') {
                        // Sort by date
                        var aDate = Date.parse(aCell.textContent.trim());
                        var bDate = Date.parse(bCell.textContent.trim());
                        aVal = isNaN(aDate) ? 0 : aDate;
                        bVal = isNaN(bDate) ? 0 : bDate;
                    } else {
                        aVal = aCell.textContent.trim().toLowerCase();
                        bVal = bCell.textContent.trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.innerHTML = '';
                rows.forEach(function(row) {
                    tbody.appendChild(row);
                });
                
                updateSortIcons(column, direction);
            }
            
            function updateSortIcons(column, direction) {
                var allHeaders = table.querySelectorAll('.sortable i');
                allHeaders.forEach(function(icon) {
                    icon.className = 'fas fa-sort float-right';
                    icon.style.opacity = '0.3';
                });
                
                var activeHeader = table.querySelector('.sortable[data-column="' + column + '"]');
                if (activeHeader) {
                    var icon = activeHeader.querySelector('i');
                    if (icon) {
                        icon.className = direction === 'asc' ? 'fas fa-sort-up float-right' : 'fas fa-sort-down float-right';
                        icon.style.opacity = '1';
                    }
                }
            }
        }
        
        var table = document.querySelector('.successes-table');
        if (table) {
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function() { initSorting(table); });
            } else {
                initSorting(table);
            }
        }
    })();
</script>
