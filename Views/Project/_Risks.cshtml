@using System.Globalization
@model Compass.Models.Project

@{
    var risks = Model.Risks?
        .Where(r => !r.IsDeleted)
        .OrderByDescending(r => r.NextReviewDate ?? r.IdentifiedDate ?? r.CreatedAt)
        .ToList() ?? new List<Compass.Models.Risk>();

    var textInfo = CultureInfo.InvariantCulture.TextInfo;
    var returnUrl = Url.Action("Details", "Project", new { id = Model.Id, tab = "risks" });

    string FormatText(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "Not set";
        }

        return textInfo.ToTitleCase(value.Replace("_", " "));
    }

    string ResolveStatusClass(string? status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return "badge-secondary";
        }

        status = status.ToLowerInvariant();
        return status switch
        {
            "closed" or "resolved" => "badge-success",
            "mitigated" or "monitoring" => "badge-primary",
            "escalated" or "blocked" => "badge-danger",
            "at_risk" or "watching" => "badge-warning",
            _ => "badge-secondary"
        };
    }

    string GetStatusLabel(Compass.Models.Risk risk)
    {
        if (!string.IsNullOrWhiteSpace(risk.RiskStatus?.Label))
        {
            return risk.RiskStatus.Label;
        }

        return FormatText(risk.Status);
    }

    string GetOwner(Compass.Models.Risk risk)
    {
        if (!string.IsNullOrWhiteSpace(risk.OwnerUser?.Name))
        {
            return risk.OwnerUser.Name;
        }

        if (!string.IsNullOrWhiteSpace(risk.OwnerEmail))
        {
            return risk.OwnerEmail;
        }

        return "Not assigned";
    }

    string GetScore(Compass.Models.Risk risk)
    {
        if (risk.InherentScore.HasValue)
        {
            return risk.InherentScore.Value.ToString("0.#");
        }

        if (risk.RiskScore > 0)
        {
            return risk.RiskScore.ToString();
        }

        return "Not scored";
    }
}

<div class="card" id="risks">
    <div class="card-header">
        <h3 class="card-title mb-0">Risks</h3>
        <div class="card-tools d-flex flex-wrap align-items-center">
            <a class="mr-2 mb-2"
               asp-controller="Project"
               asp-action="CreateRisk"
               asp-route-projectId="@Model.Id">
                Add risk
            </a>
            <a class="mb-2"
               asp-controller="Risk"
               asp-action="Index">
                Open risk register
            </a>
        </div>
    </div>
    @if (!risks.Any())
    {
        <div class="card-body p-0">
            <div class="p-3">
                <p class="text-muted mb-2">No risks recorded for this work item.</p>
                <p class="mb-0">
                    <a asp-controller="Project" asp-action="CreateRisk" asp-route-projectId="@Model.Id">Create a risk</a>
                    or <a asp-controller="Risk" asp-action="Index">open the risk register</a> to link existing entries.
                </p>
            </div>
        </div>
    }
    else
    {
        <div class="card-body table-responsive p-0">
            <table class="table table-hover text-nowrap sortable-table risks-table mb-0">
                <thead>
                    <tr>
                        <th class="col-title sortable" data-column="Title" tabindex="0" role="button" aria-label="Sort by Title">
                            Title
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="col-tier sortable" data-column="Tier" tabindex="0" role="button" aria-label="Sort by Tier">
                            Tier
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="col-score sortable" data-column="Score" tabindex="0" role="button" aria-label="Sort by Score">
                            Score
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="col-owner sortable" data-column="Owner" tabindex="0" role="button" aria-label="Sort by Owner">
                            Owner
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="col-status sortable" data-column="Status" tabindex="0" role="button" aria-label="Sort by Status">
                            Status
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="col-review sortable" data-column="NextReview" tabindex="0" role="button" aria-label="Sort by Next review">
                            Next review
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var risk in risks)
                    {
                        var tierLabel = risk.RiskTier?.Name ?? FormatText(risk.RiskPriority?.Label);
                        var ownerLabel = GetOwner(risk);
                        var statusLabel = GetStatusLabel(risk);
                        var statusClass = ResolveStatusClass(statusLabel);
                        var nextReview = risk.NextReviewDate?.ToString("d MMM yyyy") ?? "Not scheduled";
                        <tr>
                            <td>
                                <strong>
                                    <a asp-controller="Risk" asp-action="Details" asp-route-id="@risk.Id">@risk.Title</a>
                                </strong>
                                @if (!string.IsNullOrWhiteSpace(risk.Description))
                                {
                                    <div class="text-muted small mt-1">@risk.Description</div>
                                }
                            </td>
                            <td>@tierLabel</td>
                            <td>@GetScore(risk)</td>
                            <td>@ownerLabel</td>
                            <td>
                                <span class="badge @statusClass">@statusLabel</span>
                            </td>
                            <td data-sort-value="@(risk.NextReviewDate?.Ticks ?? 0)">
                                @nextReview
                            </td>
                            <td class="text-right">
                                <a class="btn btn-link btn-sm"
                                   asp-controller="Risk"
                                   asp-action="Details"
                                   asp-route-id="@risk.Id">
                                    View
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<script nonce="@Context.Items["Nonce"]">
    (function() {
        function initSorting(table) {
            var sortableHeaders = table.querySelectorAll('.sortable');
            var currentSort = { column: null, direction: 'asc' };
            
            sortableHeaders.forEach(function(header) {
                header.style.cursor = 'pointer';
                
                header.addEventListener('click', function(e) {
                    handleSort(e, header);
                });
                
                header.addEventListener('keypress', function(e) {
                    if (e.which === 13 || e.which === 32) {
                        e.preventDefault();
                        handleSort(e, header);
                    }
                });
            });
            
            function handleSort(e, header) {
                var column = header.getAttribute('data-column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(column, direction);
                currentSort = { column: column, direction: direction };
            }
            
            function sortTable(column, direction) {
                var tbody = table.querySelector('tbody');
                var rows = Array.from(tbody.querySelectorAll('tr'));
                var colIndex = Array.from(table.querySelectorAll('thead th')).findIndex(function(th) {
                    return th.getAttribute('data-column') === column;
                });
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var aCell = a.querySelectorAll('td')[colIndex];
                    var bCell = b.querySelectorAll('td')[colIndex];
                    
                    if (column === 'Status') {
                        // Sort by badge text
                        var aBadge = aCell.querySelector('.badge');
                        var bBadge = bCell.querySelector('.badge');
                        aVal = aBadge ? aBadge.textContent.trim().toLowerCase() : '';
                        bVal = bBadge ? bBadge.textContent.trim().toLowerCase() : '';
                    } else if (column === 'Title') {
                        // Sort by link text
                        var aLink = aCell.querySelector('a');
                        var bLink = bCell.querySelector('a');
                        aVal = aLink ? aLink.textContent.trim().toLowerCase() : aCell.textContent.trim().toLowerCase();
                        bVal = bLink ? bLink.textContent.trim().toLowerCase() : bCell.textContent.trim().toLowerCase();
                    } else if (column === 'Score') {
                        // Sort by numeric value
                        var aText = aCell.textContent.trim();
                        var bText = bCell.textContent.trim();
                        var aNum = parseFloat(aText);
                        var bNum = parseFloat(bText);
                        aVal = isNaN(aNum) ? 0 : aNum;
                        bVal = isNaN(bNum) ? 0 : bNum;
                    } else if (column === 'NextReview') {
                        // Use data-sort-value if available, otherwise parse date
                        var aSortValue = aCell.getAttribute('data-sort-value');
                        var bSortValue = bCell.getAttribute('data-sort-value');
                        if (aSortValue && bSortValue) {
                            aVal = parseInt(aSortValue);
                            bVal = parseInt(bSortValue);
                        } else {
                            var aDate = Date.parse(aCell.textContent.trim());
                            var bDate = Date.parse(bCell.textContent.trim());
                            aVal = isNaN(aDate) ? 0 : aDate;
                            bVal = isNaN(bDate) ? 0 : bDate;
                        }
                    } else {
                        aVal = aCell.textContent.trim().toLowerCase();
                        bVal = bCell.textContent.trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.innerHTML = '';
                rows.forEach(function(row) {
                    tbody.appendChild(row);
                });
                
                updateSortIcons(column, direction);
            }
            
            function updateSortIcons(column, direction) {
                var allHeaders = table.querySelectorAll('.sortable i');
                allHeaders.forEach(function(icon) {
                    icon.className = 'fas fa-sort float-right';
                    icon.style.opacity = '0.3';
                });
                
                var activeHeader = table.querySelector('.sortable[data-column="' + column + '"]');
                if (activeHeader) {
                    var icon = activeHeader.querySelector('i');
                    if (icon) {
                        icon.className = direction === 'asc' ? 'fas fa-sort-up float-right' : 'fas fa-sort-down float-right';
                        icon.style.opacity = '1';
                    }
                }
            }
        }
        
        var table = document.querySelector('.risks-table');
        if (table) {
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function() { initSorting(table); });
            } else {
                initSorting(table);
            }
        }
    })();
</script>

