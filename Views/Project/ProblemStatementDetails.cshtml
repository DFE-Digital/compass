@model Compass.ViewModels.ProjectProblemStatementDetailsViewModel

@{
    ViewData["Title"] = $"Problem statement details – {Model.ProjectTitle}";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <a asp-action="Details"
                   asp-route-id="@Model.ProjectId"
                   asp-route-tab="outcomes"
                   class="btn btn-link px-0 mb-2"
                   aria-label="Back to work item">
                    <i class="fas fa-arrow-left mr-2" aria-hidden="true"></i>Back to work item
                </a>
                <h1 class="m-0">Problem statement details</h1>
                <p class="text-muted mb-0">Work: @Model.ProjectTitle</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <aside class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12 mb-4">
                <partial name="_ProjectSummarySidebar" model="Model.ProjectSummary" />
            </aside>
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                <div class="card project-summary-card mb-4" id="problem-statement-details">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Problem statement information</h3>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-borderless mb-0 problem-statement-summary-table">
                            <tbody>
                                <tr>
                                    <td class="summary-label"><strong>Problem statement</strong></td>
                                    <td class="summary-value font-weight-medium preserve-formatting">@Model.ProblemStatement</td>
                                    <td class="text-right">
                                        <a class="small"
                                           asp-action="EditProblemStatement"
                                           asp-route-projectId="@Model.ProjectId">Change</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Created by</strong></td>
                                    <td class="summary-value">
                                        @if (!string.IsNullOrWhiteSpace(Model.CreatedByName))
                                        {
                                            <span>@Model.CreatedByName</span>
                                            @if (!string.IsNullOrWhiteSpace(Model.CreatedByEmail))
                                            {
                                                <span class="text-muted">(@Model.CreatedByEmail)</span>
                                            }
                                        }
                                        else if (!string.IsNullOrWhiteSpace(Model.CreatedByEmail))
                                        {
                                            <span>@Model.CreatedByEmail</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Unknown</span>
                                        }
                                    </td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Created</strong></td>
                                    <td class="summary-value">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm") (UTC)</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Last updated</strong></td>
                                    <td class="summary-value">@Model.UpdatedAt.ToString("dd MMM yyyy HH:mm") (UTC)</td>
                                    <td></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                @if (Model.History.Any())
                {
                    <div class="card mb-4 collapsed-card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h3 class="card-title mb-0">History <span class="badge badge-secondary">@Model.History.Count</span></h3>
                            <button type="button" class="btn btn-tool" style="color: black !important;" data-card-widget="collapse" aria-label="Collapse History section">
                                <i class="fas fa-plus" aria-hidden="true"></i>
                            </button>
                        </div>
                        <div class="card-body p-0 collapse">
                            <div class="table-responsive">
                                <table class="table table-hover text-nowrap sortable-table">
                                    <thead>
                                        <tr>
                                            <th>Problem statement</th>
                                            <th>Changed by</th>
                                            <th>Changed at</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var historyItem in Model.History)
                                        {
                                            <tr>
                                                <td class="preserve-formatting">@historyItem.ProblemStatement</td>
                                                <td>
                                                    @if (!string.IsNullOrWhiteSpace(historyItem.ChangedByName))
                                                    {
                                                        <span>@historyItem.ChangedByName</span>
                                                        @if (!string.IsNullOrWhiteSpace(historyItem.ChangedByEmail))
                                                        {
                                                            <span class="text-muted">(@historyItem.ChangedByEmail)</span>
                                                        }
                                                    }
                                                    else if (!string.IsNullOrWhiteSpace(historyItem.ChangedByEmail))
                                                    {
                                                        <span>@historyItem.ChangedByEmail</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Unknown</span>
                                                    }
                                                </td>
                                                <td>@historyItem.ChangedAt.ToString("dd MMM yyyy HH:mm")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

