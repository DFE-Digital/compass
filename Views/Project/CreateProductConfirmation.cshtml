@{
    ViewData["Title"] = "Product created successfully";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1>Product created successfully</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Project" asp-action="Index">Projects</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Project" asp-action="Details" asp-route-id="@ViewBag.ProjectId" asp-route-tab="products">@ViewBag.ProjectTitle</a></li>
                    <li class="breadcrumb-item active">Confirmation</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-8 offset-md-2">
                <div class="card card-success">
                    <div class="card-header">
                        <h3 class="card-title">
                            <i class="fas fa-check-circle"></i> Product successfully created
                        </h3>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-success">
                            <h4><i class="icon fas fa-check"></i> Success!</h4>
                            <p class="mb-0">
                                The product "<strong>@ViewBag.ProductTitle</strong>" has been successfully created in the FIPS CMS 
                                and linked to the project "<strong>@ViewBag.ProjectTitle</strong>".
                            </p>
                        </div>

                        <dl class="row">
                            <dt class="col-sm-4">Product title:</dt>
                            <dd class="col-sm-8">@ViewBag.ProductTitle</dd>

                            <dt class="col-sm-4">FIPS ID:</dt>
                            <dd class="col-sm-8">
                                <span class="badge badge-info">@ViewBag.FipsId</span>
                            </dd>

                            <dt class="col-sm-4">Project:</dt>
                            <dd class="col-sm-8">@ViewBag.ProjectTitle</dd>

                            <dt class="col-sm-4">Status:</dt>
                            <dd class="col-sm-8">
                                <span class="badge badge-success">Active</span>
                                <span class="badge badge-secondary">Draft</span>
                            </dd>
                        </dl>

                        <div class="alert alert-info mt-3">
                            <i class="icon fas fa-info-circle"></i>
                            <strong>Note:</strong> The product has been created as a draft. You may need to publish it in the FIPS CMS admin interface to make it visible in production.
                        </div>
                    </div>
                    <div class="card-footer">
                        <a asp-action="Details" 
                           asp-route-id="@ViewBag.ProjectId" 
                           asp-route-tab="products" 
                           class="btn btn-primary">
                            <i class="fas fa-arrow-left"></i> Return to products
                        </a>
                        <a asp-controller="Project" 
                           asp-action="Details" 
                           asp-route-id="@ViewBag.ProjectId" 
                           class="btn btn-secondary">
                            <i class="fas fa-project-diagram"></i> Return to project
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

