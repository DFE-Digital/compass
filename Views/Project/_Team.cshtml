@using System
@model Compass.Models.Project

@{
    var teamMembers = Model.ProjectContacts?
        .Where(member => !string.Equals(member.TeamStatus, "governance", StringComparison.OrdinalIgnoreCase))
        .OrderByDescending(member => string.Equals(member.TeamStatus, "current", StringComparison.OrdinalIgnoreCase))
        .ThenBy(member => member.SortOrder)
        .ToList() ?? new List<Compass.Models.ProjectContact>();
    var currentTeamMembers = teamMembers
        .Where(member => !string.Equals(member.TeamStatus, "previous", StringComparison.OrdinalIgnoreCase))
        .ToList();
    var previousTeamMembers = teamMembers
        .Where(member => string.Equals(member.TeamStatus, "previous", StringComparison.OrdinalIgnoreCase))
        .ToList();
}

<div class="card" id="team">
    <div class="card-header">
        <h3 class="card-title mb-0">Team</h3>
        <div class="card-tools">
            <a asp-controller="Project"
               asp-action="CreateTeamMember"
               asp-route-projectId="@Model.Id"
               class="card-link">
                Add team member
            </a>
        </div>
    </div>
    <div class="card-body p-0">
        @if (currentTeamMembers.Any())
        {
            <table class="table table-hover text-nowrap sortable-table team-table mb-0">
                <thead>
                    <tr>
                        <th class="sortable" data-column="Name" tabindex="0" role="button" aria-label="Sort by Name">
                            Name
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="Role" tabindex="0" role="button" aria-label="Sort by Role">
                            Role
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="EmploymentType" tabindex="0" role="button" aria-label="Sort by Type">
                            Type
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="TimeAllocation" tabindex="0" role="button" aria-label="Sort by Time Allocation">
                            Time allocation
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="FundingArrangement" tabindex="0" role="button" aria-label="Sort by Funding">
                            Funding
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="Status" tabindex="0" role="button" aria-label="Sort by Status">
                            Status
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var member in currentTeamMembers)
                    {
                        var directoryUser = member.User;
                        var displayName = !string.IsNullOrWhiteSpace(directoryUser?.Name)
                            ? directoryUser!.Name
                            : (!string.IsNullOrWhiteSpace(member.Name) ? member.Name : directoryUser?.Email ?? member.Email);
                        var displayEmail = !string.IsNullOrWhiteSpace(directoryUser?.Email)
                            ? directoryUser!.Email
                            : member.Email;
                        var jobTitle = directoryUser?.JobTitle;
                        var statusBadgeClass = string.Equals(member.TeamStatus, "current", StringComparison.OrdinalIgnoreCase)
                            ? "badge badge-success"
                            : "badge badge-secondary";
                        var statusLabel = string.IsNullOrWhiteSpace(member.TeamStatus)
                            ? "Unknown"
                            : char.ToUpper(member.TeamStatus[0]) + member.TeamStatus.Substring(1);
                        var employmentBadgeClass = string.Equals(member.EmploymentType, "MSP", StringComparison.OrdinalIgnoreCase)
                            ? "badge badge-info"
                            : "badge badge-primary";
                        <tr>
                            <td>
                                <div class="d-flex flex-column">
                                    <a asp-controller="Project"
                                       asp-action="EditTeamMember"
                                       asp-route-projectId="@Model.Id"
                                       asp-route-teamMemberId="@member.Id"
                                       class="font-weight-bold">
                                        @displayName
                                    </a>
                                    @if (!string.IsNullOrWhiteSpace(displayEmail))
                                    {
                                        <span class="text-muted small">@displayEmail</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">No email recorded</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(jobTitle))
                                    {
                                        <span class="text-muted small">@jobTitle</span>
                                    }
                                </div>
                            </td>
                            <td>@member.Role</td>
                            <td>
                                <span class="@employmentBadgeClass">@member.EmploymentType</span>
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(member.TimeAllocation))
                                {
                                    <span>@member.TimeAllocation</span>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                            <td>
                                <span class="badge badge-secondary">@member.FundingArrangement</span>
                            </td>
                            <td>
                                <span class="@statusBadgeClass">@statusLabel</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="p-3">
                <p class="text-muted mb-2">No current team members recorded.</p>
                <a asp-controller="Project"
                   asp-action="CreateTeamMember"
                   asp-route-projectId="@Model.Id">
                    Add the first team member
                </a>
            </div>
        }
    </div>
</div>

@if (previousTeamMembers.Any())
{
    <div class="card collapsed-card mt-3" id="previous-team">
        <div class="card-header">
            <h3 class="card-title mb-0">Previous team members (@previousTeamMembers.Count)</h3>
            <div class="card-tools">
                <button type="button" class="btn btn-tool" data-card-widget="collapse">
                    <i class="fas fa-plus" aria-hidden="true"></i>
                    <span class="sr-only">Toggle previous team members</span>
                </button>
            </div>
        </div>
        <div class="card-body table-responsive p-0" style="display: none;">
            <table class="table table-hover text-nowrap sortable-table team-table mb-0">
                <thead>
                    <tr>
                        <th class="sortable" data-column="Name" tabindex="0" role="button" aria-label="Sort by Name">
                            Name
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="Role" tabindex="0" role="button" aria-label="Sort by Role">
                            Role
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="EmploymentType" tabindex="0" role="button" aria-label="Sort by Type">
                            Type
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="TimeAllocation" tabindex="0" role="button" aria-label="Sort by Time Allocation">
                            Time allocation
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="FundingArrangement" tabindex="0" role="button" aria-label="Sort by Funding">
                            Funding
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="Status" tabindex="0" role="button" aria-label="Sort by Status">
                            Status
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="LeftAt" tabindex="0" role="button" aria-label="Sort by Left team">
                            Left team
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var member in previousTeamMembers)
                    {
                        var directoryUser = member.User;
                        var displayName = !string.IsNullOrWhiteSpace(directoryUser?.Name)
                            ? directoryUser!.Name
                            : (!string.IsNullOrWhiteSpace(member.Name) ? member.Name : directoryUser?.Email ?? member.Email);
                        var displayEmail = !string.IsNullOrWhiteSpace(directoryUser?.Email)
                            ? directoryUser!.Email
                            : member.Email;
                        var jobTitle = directoryUser?.JobTitle;
                        var leftAtLabel = member.LeftAt?.ToString("dd MMM yyyy") ?? "Not recorded";
                        <tr>
                            <td>
                                <div class="d-flex flex-column">
                                    <a asp-controller="Project"
                                       asp-action="EditTeamMember"
                                       asp-route-projectId="@Model.Id"
                                       asp-route-teamMemberId="@member.Id"
                                       class="font-weight-bold">
                                        @displayName
                                    </a>
                                    @if (!string.IsNullOrWhiteSpace(displayEmail))
                                    {
                                        <span class="text-muted small">@displayEmail</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(jobTitle))
                                    {
                                        <span class="text-muted small">@jobTitle</span>
                                    }
                                </div>
                            </td>
                            <td>@member.Role</td>
                            <td>
                                <span class="badge badge-primary">@member.EmploymentType</span>
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(member.TimeAllocation))
                                {
                                    <span>@member.TimeAllocation</span>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                            <td>
                                <span class="badge badge-secondary">@member.FundingArrangement</span>
                            </td>
                            <td>
                                <span class="badge badge-secondary">Previous</span>
                                @if (!string.IsNullOrWhiteSpace(member.LeaveReason))
                                {
                                    <div class="text-muted small mt-1">@member.LeaveReason</div>
                                }
                            </td>
                            <td>
                                <span class="text-muted small">@leftAtLabel</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (currentTeamMembers.Any() || previousTeamMembers.Any())
{
    <script nonce="@Context.Items["Nonce"]">
        (function() {
            function initSorting(table) {
                var sortableHeaders = table.querySelectorAll('.sortable');
                var currentSort = { column: null, direction: 'asc' };
                
                sortableHeaders.forEach(function(header) {
                    header.style.cursor = 'pointer';
                    
                    header.addEventListener('click', function(e) {
                        handleSort(e, header);
                    });
                    
                    header.addEventListener('keypress', function(e) {
                        if (e.which === 13 || e.which === 32) {
                            e.preventDefault();
                            handleSort(e, header);
                        }
                    });
                });
                
                function handleSort(e, header) {
                    var column = header.getAttribute('data-column');
                    var direction = 'asc';
                    
                    if (currentSort.column === column && currentSort.direction === 'asc') {
                        direction = 'desc';
                    }
                    
                    sortTable(column, direction);
                    currentSort = { column: column, direction: direction };
                }
                
                function updateSortIcons(column, direction) {
                    var allHeaders = table.querySelectorAll('.sortable i');
                    
                    allHeaders.forEach(function(icon) {
                        icon.className = 'fas fa-sort float-right';
                        icon.style.opacity = '0.3';
                    });
                    
                    var activeHeader = table.querySelector('.sortable[data-column="' + column + '"]');
                    if (activeHeader) {
                        var icon = activeHeader.querySelector('i');
                        if (icon) {
                            icon.className = direction === 'asc' ? 'fas fa-sort-up float-right' : 'fas fa-sort-down float-right';
                            icon.style.opacity = '1';
                        }
                    }
                }
                
                function sortTable(column, direction) {
                    var tbody = table.querySelector('tbody');
                    var rows = Array.from(tbody.querySelectorAll('tr'));
                    var colIndex = Array.from(table.querySelectorAll('thead th')).findIndex(function(th) {
                        return th.getAttribute('data-column') === column;
                    });
                    
                    rows.sort(function(a, b) {
                        var aVal, bVal;
                        var aCell = a.querySelectorAll('td')[colIndex];
                        var bCell = b.querySelectorAll('td')[colIndex];
                        
                        if (column === 'LeftAt') {
                            var aText = aCell.textContent.trim();
                            var bText = bCell.textContent.trim();
                            if (aText === 'Not recorded' || bText === 'Not recorded') {
                                if (aText === 'Not recorded' && bText === 'Not recorded') {
                                    aVal = bVal = 0;
                                } else if (aText === 'Not recorded') {
                                    aVal = 0;
                                    bVal = new Date(bText).getTime();
                                } else {
                                    aVal = new Date(aText).getTime();
                                    bVal = 0;
                                }
                            } else {
                                aVal = new Date(aText).getTime();
                                bVal = new Date(bText).getTime();
                            }
                        } else if (column === 'TimeAllocation') {
                            // Parse percentage values for sorting
                            var aText = aCell.textContent.trim();
                            var bText = bCell.textContent.trim();
                            
                            // Handle "Not set" as 0
                            if (aText === 'Not set') aText = '0%';
                            if (bText === 'Not set') bText = '0%';
                            
                            // Handle "Less than 25%" as 12.5%
                            if (aText.includes('Less than 25%')) aText = '12.5%';
                            if (bText.includes('Less than 25%')) bText = '12.5%';
                            
                            // Extract numeric value
                            var aMatch = aText.match(/(\d+(?:\.\d+)?)%/);
                            var bMatch = bText.match(/(\d+(?:\.\d+)?)%/);
                            aVal = aMatch ? parseFloat(aMatch[1]) : 0;
                            bVal = bMatch ? parseFloat(bMatch[1]) : 0;
                        } else {
                            var aLink = aCell.querySelector('a');
                            var bLink = bCell.querySelector('a');
                            aVal = aLink ? aLink.textContent.trim().toLowerCase() : aCell.textContent.trim().toLowerCase();
                            bVal = bLink ? bLink.textContent.trim().toLowerCase() : bCell.textContent.trim().toLowerCase();
                        }
                        
                        if (direction === 'asc') {
                            return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                        } else {
                            return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                        }
                    });
                    
                    tbody.innerHTML = '';
                    rows.forEach(function(row) {
                        tbody.appendChild(row);
                    });
                    
                    updateSortIcons(column, direction);
                }
            }
            
            var teamTables = document.querySelectorAll('.team-table');
            teamTables.forEach(function(table) {
                initSorting(table);
            });
        })();
    </script>
}
