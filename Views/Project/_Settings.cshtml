@model Compass.Models.Project

@{
    var deliveryCode = $"DEL-DDT-{Model.Id}";
}

<div class="card mb-4">
    <div class="card-header">
        <h3 class="card-title">Work Settings</h3>
    </div>
    <div class="card-body p-0">
        <table class="table table-borderless mb-0 settings-table">
            <tbody>
                <tr>
                    <td class="summary-label"><strong>Delivery code</strong></td>
                    <td class="summary-value">
                        @deliveryCode
                    </td>
                    <td class="summary-action"></td>
                </tr>
                <tr>
                    <td class="summary-label"><strong>Title</strong></td>
                    <td class="summary-value">@Model.Title</td>
                    <td class="summary-action text-right">
                        <a href="#" class="change-link" data-field="title">Change</a>
                    </td>
                </tr>
                <tr>
                    <td class="summary-label"><strong>Created</strong></td>
                    <td class="summary-value">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                    <td class="summary-action"></td>
                </tr>
                <tr>
                    <td class="summary-label"><strong>Last Modified</strong></td>
                    <td class="summary-value">@Model.UpdatedAt.ToString("dd MMM yyyy HH:mm")</td>
                    <td class="summary-action"></td>
                </tr>
                <tr>
                    <td class="summary-label"><strong>Status</strong></td>
                    <td class="summary-value">
                        <span class="badge badge-@(Model.Status == "Active" ? "success" : Model.Status == "Paused" ? "warning" : Model.Status == "Completed" ? "info" : "secondary")">@Model.Status</span>
                        @if (!string.IsNullOrEmpty(Model.StatusChangeReason))
                        {
                            <br>
                            <small class="text-muted">@Model.StatusChangeReason</small>
                        }
                    </td>
                    <td class="summary-action text-right">
                        <a href="#" class="change-link" data-field="status">Change</a>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Danger Zone -->
<div class="card border-danger">
    <div class="card-header bg-danger text-white">
        <h3 class="card-title">Danger Zone</h3>
    </div>
    <div class="card-body">
        <h5>Delete Work Item</h5>
            <p class="text-muted">
            Once you delete a work item, there is no going back. This will permanently remove the work item 
            and all associated data including milestones, successes, RAG history, funding information, and contacts.
        </p>
        <button type="button" class="btn btn-danger" id="deleteProjectBtn" data-project-id="@Model.Id" data-project-title="@Model.Title">Delete Work Item</button>
    </div>
</div>

<!-- Edit Title Modal -->
<div class="modal fade" id="editTitleModal" tabindex="-1" role="dialog" aria-labelledby="editTitleModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editTitleModalLabel">Edit Work Title</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateTitle" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="titleInput">Work Item Title</label>
                        <input type="text" class="form-control" id="titleInput" name="title" value="@Model.Title" required maxlength="200" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Status Modal -->
<div class="modal fade" id="editStatusModal" tabindex="-1" role="dialog" aria-labelledby="editStatusModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editStatusModalLabel">Edit Work Status</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateStatus" method="post" id="statusForm">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="statusInput">Work Item Status</label>
                        <select class="form-control" name="status" id="statusInput" required>
                            <option value="Active" selected="@(Model.Status == "Active")">Active</option>
                            <option value="Paused" selected="@(Model.Status == "Paused")">Paused</option>
                            <option value="Completed" selected="@(Model.Status == "Completed")">Completed</option>
                            <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Cancelled</option>
                        </select>
                    </div>
                    <div class="form-group" id="statusReasonGroup" style="display: none;">
                        <label for="statusChangeReason">Reason for Status Change <span class="text-danger">*</span></label>
                        <textarea class="form-control" name="statusChangeReason" id="statusChangeReason" rows="4" placeholder="Please provide a reason for changing the status..."></textarea>
                        <small class="form-text text-muted">Required when changing to Paused, Completed, or Cancelled</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteProjectModal" tabindex="-1" role="dialog" aria-labelledby="deleteProjectModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteProjectModalLabel">Confirm Work Item Deletion</h5>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="alert alert-danger">
                    <strong>Warning:</strong> This action cannot be undone!
                </div>
                <p>Are you sure you want to delete the work item <strong id="projectNameToDelete"></strong>?</p>
                <p>This will permanently remove:</p>
                <ul>
                    <li>All project information</li>
                    <li>All milestones and their history</li>
                    <li>All successes and achievements</li>
                    <li>All RAG status history</li>
                    <li>All funding and resource allocations</li>
                    <li>All work item contacts</li>
                </ul>
                <div class="form-group mt-3">
                    <label for="confirmProjectName">Type the work item name to confirm:</label>
                    <input type="text" class="form-control" id="confirmProjectName" placeholder="Enter work item name">
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn" disabled>Delete Work Item</button>
            </div>
        </div>
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
    (function() {
        var projectToDelete = null;
        var projectNameToDelete = null;

        function confirmDelete(projectId, projectTitle) {
            projectToDelete = projectId;
            projectNameToDelete = projectTitle;
            document.getElementById('projectNameToDelete').textContent = projectTitle;
            document.getElementById('confirmProjectName').value = '';
            document.getElementById('confirmDeleteBtn').disabled = true;
            $('#deleteProjectModal').modal('show');
        }

        function initSettingsPage() {
            // Handle change link clicks
            $(document).on('click', '.change-link', function(e) {
                e.preventDefault();
                var field = $(this).attr('data-field');
                
                if (field === 'title') {
                    $('#editTitleModal').modal('show');
                } else if (field === 'status') {
                    // Reset form when opening modal
                    $('#statusChangeReason').val('');
                    toggleStatusReasonField();
                    $('#editStatusModal').modal('show');
                }
            });

            // Handle status change to show/hide reason field
            $('#statusInput').on('change', function() {
                toggleStatusReasonField();
            });

            // Function to toggle status reason field visibility and required attribute
            function toggleStatusReasonField() {
                var status = $('#statusInput').val();
                var $reasonGroup = $('#statusReasonGroup');
                var $reasonField = $('#statusChangeReason');
                
                if (status === 'Paused' || status === 'Completed' || status === 'Cancelled') {
                    $reasonGroup.show();
                    $reasonField.prop('required', true);
                } else {
                    $reasonGroup.hide();
                    $reasonField.prop('required', false);
                    $reasonField.val('');
                }
            }

            // Validate form before submission
            $('#statusForm').on('submit', function(e) {
                var status = $('#statusInput').val();
                var reason = $('#statusChangeReason').val().trim();
                
                if ((status === 'Paused' || status === 'Completed' || status === 'Cancelled') && !reason) {
                    e.preventDefault();
                    alert('Please provide a reason for changing the status.');
                    return false;
                }
            });

            // Handle delete project button
            $('#deleteProjectBtn').on('click', function() {
                var projectId = $(this).attr('data-project-id');
                var projectTitle = $(this).attr('data-project-title');
                confirmDelete(projectId, projectTitle);
            });

            // Handle confirm project name input
            $('#confirmProjectName').on('input', function() {
                var inputValue = $(this).val().trim();
                var confirmBtn = $('#confirmDeleteBtn');
                
                if (inputValue === projectNameToDelete) {
                    confirmBtn.prop('disabled', false);
                } else {
                    confirmBtn.prop('disabled', true);
                }
            });

            // Handle confirm delete button
            $('#confirmDeleteBtn').on('click', function() {
                if (projectToDelete && !$(this).prop('disabled')) {
                    // Create a form to submit the delete request
                    var form = $('<form>', {
                        'method': 'POST',
                        'action': '@Url.Action("Delete", "Project")'
                    });
                    
                    form.append($('<input>', {
                        'type': 'hidden',
                        'name': 'id',
                        'value': projectToDelete
                    }));
                    
                    form.append($('<input>', {
                        'type': 'hidden',
                        'name': '__RequestVerificationToken',
                        'value': $('input[name="__RequestVerificationToken"]').val()
                    }));
                    
                    $('body').append(form);
                    form.submit();
                }
            });
        }

        if (typeof jQuery !== 'undefined') {
            $(document).ready(initSettingsPage);
        } else {
            document.addEventListener('DOMContentLoaded', function() {
                if (typeof jQuery !== 'undefined') {
                    $(document).ready(initSettingsPage);
                }
            });
        }
    })();
</script>
