@model Compass.Models.Project

<div class="row">
    <div class="col-12">
        <!-- Current Funding Allocation -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Resource Funding Allocation</h3>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover text-nowrap funding-table">
                    <thead>
                        <tr>
                            <th class="col-type">Type</th>
                            <th class="col-count">Count</th>
                            <th class="col-programme">Programme %</th>
                            <th class="col-admin">Admin %</th>
                            <th class="col-total">Total FTE</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var permProgramme = Model.ResourceFunding?.FirstOrDefault(rf => rf.ResourceType == "Permanent")?.ProgrammeFundedPercentage ?? 0;
                            var permAdmin = Model.ResourceFunding?.FirstOrDefault(rf => rf.ResourceType == "Permanent")?.AdminFundedPercentage ?? 0;
                            var mspProgramme = Model.ResourceFunding?.FirstOrDefault(rf => rf.ResourceType == "MSP")?.ProgrammeFundedPercentage ?? 0;
                            var mspAdmin = Model.ResourceFunding?.FirstOrDefault(rf => rf.ResourceType == "MSP")?.AdminFundedPercentage ?? 0;
                        }
                        <tr>
                            <td>
                                <a href="#" class="edit-funding-link" data-type="Permanent" data-count="@(Model.TotalPermFte ?? 0)" data-programme="@permProgramme" data-admin="@permAdmin">Permanent</a>
                            </td>
                            <td><strong>@(Model.TotalPermFte ?? 0)</strong></td>
                            <td>
                                <span class="badge badge-success">@permProgramme%</span>
                            </td>
                            <td>
                                <span class="badge badge-info">@permAdmin%</span>
                            </td>
                            <td>
                                <strong>@(Model.TotalPermFte ?? 0)</strong>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <a href="#" class="edit-funding-link" data-type="MSP" data-count="@(Model.TotalMspFte ?? 0)" data-programme="@mspProgramme" data-admin="@mspAdmin">MSP</a>
                            </td>
                            <td><strong>@(Model.TotalMspFte ?? 0)</strong></td>
                            <td>
                                <span class="badge badge-success">@mspProgramme%</span>
                            </td>
                            <td>
                                <span class="badge badge-info">@mspAdmin%</span>
                            </td>
                            <td>
                                <strong>@(Model.TotalMspFte ?? 0)</strong>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Funding Change History -->
        <div class="card collapsed-card mb-4">
            <div class="card-header">
                <h3 class="card-title">Funding Change History</h3>
                <div class="card-tools">
                  <button type="button" class="btn btn-tool" style="color: black !important;" data-card-widget="collapse"><i class="fas fa-plus"></i>
                  </button>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                @if (Model.FundingHistory?.Any() == true)
                {
                    <table class="table table-hover text-nowrap sortable-table funding-history-table">
                        <thead>
                            <tr>
                                <th class="col-date sortable" data-column="Date" tabindex="0" role="button" aria-label="Sort by Date">
                                    Date
                                    <i class="fas fa-sort sort-icon"></i>
                                </th>
                                <th class="col-type-history sortable" data-column="Type" tabindex="0" role="button" aria-label="Sort by Type">
                                    Type
                                    <i class="fas fa-sort sort-icon"></i>
                                </th>
                                <th class="col-change-summary">Change Summary</th>
                                <th class="col-count-history">Count</th>
                                <th class="col-programme-history">Programme %</th>
                                <th class="col-admin-history">Admin %</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var historyList = Model.FundingHistory.OrderByDescending(h => h.ChangedAt).ToList();
                                var historyByType = Model.FundingHistory.GroupBy(h => h.ResourceType).ToDictionary(g => g.Key, g => g.OrderByDescending(h => h.ChangedAt).ToList());
                            }
                            @for (int i = 0; i < historyList.Count; i++)
                            {
                                var history = historyList[i];
                                var typeHistory = historyByType[history.ResourceType];
                                var indexInType = typeHistory.IndexOf(history);
                                var previousHistory = indexInType < typeHistory.Count - 1 ? typeHistory[indexInType + 1] : null;
                                
                                var changeSummary = "";
                                if (previousHistory != null)
                                {
                                    var changes = new List<string>();
                                    
                                    if (history.Count != previousHistory.Count)
                                    {
                                        var diff = history.Count - previousHistory.Count;
                                        var arrow = diff > 0 ? "↑" : "↓";
                                        changes.Add($"Count {arrow} {Math.Abs(diff):0.0}");
                                    }
                                    
                                    if (history.ProgrammeFundedPercentage != previousHistory.ProgrammeFundedPercentage)
                                    {
                                        var diff = history.ProgrammeFundedPercentage - previousHistory.ProgrammeFundedPercentage;
                                        var arrow = diff > 0 ? "↑" : "↓";
                                        changes.Add($"Programme {arrow} {Math.Abs(diff):0.0}%");
                                    }
                                    
                                    if (history.AdminFundedPercentage != previousHistory.AdminFundedPercentage)
                                    {
                                        var diff = history.AdminFundedPercentage - previousHistory.AdminFundedPercentage;
                                        var arrow = diff > 0 ? "↑" : "↓";
                                        changes.Add($"Admin {arrow} {Math.Abs(diff):0.0}%");
                                    }
                                    
                                    changeSummary = changes.Any() ? string.Join(", ", changes) : "No change";
                                }
                                else
                                {
                                    changeSummary = "Initial setup";
                                }
                                <tr>
                                    <td>
                                        <a href="#" class="view-funding-history-link" 
                                           data-date="@history.ChangedAt.ToString("d MMMM yyyy")"
                                           data-time="@history.ChangedAt.ToString("HH:mm")"
                                           data-type="@history.ResourceType"
                                           data-count="@history.Count"
                                           data-programme="@history.ProgrammeFundedPercentage"
                                           data-admin="@history.AdminFundedPercentage"
                                           data-prev-count="@(previousHistory?.Count ?? 0)"
                                           data-prev-programme="@(previousHistory?.ProgrammeFundedPercentage ?? 0)"
                                           data-prev-admin="@(previousHistory?.AdminFundedPercentage ?? 0)"
                                           data-has-previous="@(previousHistory != null ? "true" : "false")"
                                           data-notes="@(history.Notes ?? "")"
                                           data-changed-by="@history.ChangedByName"
                                           data-changed-email="@history.ChangedByEmail"
                                           data-summary="@changeSummary">
                                            @history.ChangedAt.ToString("d MMMM yyyy")
                                        </a>
                                    </td>
                                    <td>
                                        <span class="badge badge-@(history.ResourceType == "Permanent" ? "primary" : "info")">
                                            @history.ResourceType
                                        </span>
                                    </td>
                                    <td>
                                        @if (previousHistory != null)
                                        {
                                            <small class="text-muted">@changeSummary</small>
                                        }
                                        else
                                        {
                                            <small class="text-success">@changeSummary</small>
                                        }
                                    </td>
                                    <td><strong>@history.Count</strong></td>
                                    <td>
                                        <span class="badge badge-success">@history.ProgrammeFundedPercentage%</span>
                                    </td>
                                    <td>
                                        <span class="badge badge-info">@history.AdminFundedPercentage%</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-4">
                        <p class="text-muted mb-1">No funding changes recorded.</p>
                        <small class="text-muted d-block">Funding history tracking will be available once the data model is updated.</small>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Update Funding Modal -->
<div class="modal fade" id="updateFundingModal" tabindex="-1" role="dialog" aria-labelledby="updateFundingModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="updateFundingModalLabel">Update Funding Allocation</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateFunding" method="post" asp-antiforgery="true">
                <input type="hidden" name="projectId" value="@Model.Id" />
                <input type="hidden" name="resourceType" id="resourceType" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="resourceCount">Resource Count</label>
                        <input type="number" class="form-control" id="resourceCount" name="count" min="0" step="0.1" required>
                    </div>
                    <div class="form-group">
                        <label for="programmePercentage">Programme Funded Percentage</label>
                        <input type="number" class="form-control" id="programmePercentage" name="programmePercentage" min="0" max="100" required>
                    </div>
                    <div class="form-group">
                        <label for="adminPercentage">Admin Funded Percentage</label>
                        <input type="number" class="form-control" id="adminPercentage" name="adminPercentage" min="0" max="100" required>
                    </div>
                    <div class="form-group">
                        <label for="fundingNotes">Notes</label>
                        <textarea class="form-control" id="fundingNotes" name="notes" rows="3" placeholder="Optional notes about this funding change..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Funding</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- View Funding History Details Modal -->
<div class="modal fade" id="viewFundingHistoryModal" tabindex="-1" role="dialog" aria-labelledby="viewFundingHistoryModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewFundingHistoryModalLabel">Funding Change Details</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row mb-3">
                    <div class="col-6">
                        <strong>Date:</strong><br>
                        <span id="historyDate"></span>
                    </div>
                    <div class="col-6">
                        <strong>Time:</strong><br>
                        <span id="historyTime"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-12">
                        <strong>Resource Type:</strong><br>
                        <span id="historyType"></span>
                    </div>
                </div>
                <hr>
                <div id="historyChangesTable"></div>
                <hr>
                <div class="row mb-3">
                    <div class="col-12">
                        <strong>Changed By:</strong><br>
                        <span id="historyChangedBy"></span>
                    </div>
                </div>
                <div class="row" id="historyNotesContainer" style="display: none;">
                    <div class="col-12">
                        <strong>Notes:</strong><br>
                        <span id="historyNotes"></span>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

