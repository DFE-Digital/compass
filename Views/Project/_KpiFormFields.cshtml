@model Compass.ViewModels.ProjectKpiFormViewModel

@{
    const string OtherOptionValue = "__other__";

    Func<string, bool> hasError = key =>
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return false;
        }

        if (ViewData.ModelState.TryGetValue(key, out var entry) && entry.Errors.Count > 0)
        {
            return true;
        }

        var inputKey = $"Input.{key}";
        if (ViewData.ModelState.TryGetValue(inputKey, out var inputEntry) && inputEntry.Errors.Count > 0)
        {
            return true;
        }

        return false;
    };

    var showUnitOther = string.Equals(Model.Input.UnitOfMeasure, OtherOptionValue, System.StringComparison.Ordinal);
    var showDataSourceOther = string.Equals(Model.Input.DataSource, OtherOptionValue, System.StringComparison.Ordinal);
}

<div class="form-group @(hasError("Name") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.Name" class="font-weight-bold">KPI name</label>
    <small class="form-text text-muted">Provide a clear name so teams know what is being measured.</small>
    <span asp-validation-for="Input.Name" class="form-error-message"></span>
    <input asp-for="Input.Name" class="form-control @(hasError("Name") ? "form-control--error" : string.Empty)" maxlength="200" required />
</div>

<div class="form-group @(hasError("ReportingStages") ? "form-group--error" : string.Empty)" id="kpiStagesGroup">
    <label class="font-weight-bold" for="kpiStagesGroup">Reporting stages</label>
    <small class="form-text text-muted">Select all stages when this KPI should be reported.</small>
    <span asp-validation-for="Input.ReportingStages" class="form-error-message"></span>
    <div class="kpi-stage-checkboxes">
        @if (Model.ReportingStageOptions == null || !Model.ReportingStageOptions.Any())
        {
            <p class="text-muted mb-0">No stages available.</p>
        }
        else
        {
            var index = 0;
            foreach (var option in Model.ReportingStageOptions)
            {
                var checkboxId = $"kpiStage_{index++}";
                <div class="form-check">
                    <input class="form-check-input"
                           type="checkbox"
                           id="@checkboxId"
                           name="Input.ReportingStages"
                           value="@option.Value"
                           @(option.Selected ? "checked" : string.Empty) />
                    <label class="form-check-label" for="@checkboxId">@option.Text</label>
                </div>
            }
        }
    </div>
</div>

<div class="form-group @(hasError("Description") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.Description">Description</label>
    <small class="form-text text-muted">Explain what this KPI measures.</small>
    <span asp-validation-for="Input.Description" class="form-error-message"></span>
    <textarea asp-for="Input.Description" class="form-control @(hasError("Description") ? "form-control--error" : string.Empty)" rows="3"></textarea>
</div>

<div class="form-group @(hasError("CategoryCode") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.CategoryCode">Category</label>
    <small class="form-text text-muted">Categories are managed in Admin settings. The KPI code is generated automatically from the category and entry ID.</small>
    <span asp-validation-for="Input.CategoryCode" class="form-error-message"></span>
    <select asp-for="Input.CategoryCode" class="form-control @(hasError("CategoryCode") ? "form-control--error" : string.Empty)" asp-items="Model.CategoryOptions" id="kpiCategory">
        <option value="">Select category</option>
    </select>
    @if (!string.IsNullOrWhiteSpace(Model.Input.Code))
    {
        <small class="form-text text-muted">Current KPI code: <strong>@Model.Input.Code</strong></small>
    }
    else
    {
        <small class="form-text text-muted">KPI code appears after you save.</small>
    }
</div>

<div class="form-group @(hasError("UnitOfMeasure") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.UnitOfMeasure">Unit of measure</label>
    <span asp-validation-for="Input.UnitOfMeasure" class="form-error-message"></span>
    <select asp-for="Input.UnitOfMeasure" class="form-control @(hasError("UnitOfMeasure") ? "form-control--error" : string.Empty)" asp-items="Model.UnitOfMeasureOptions" id="kpiUnit">
        <option value="">Select unit of measure</option>
    </select>
</div>

<div class="form-group @(hasError("UnitOfMeasureOther") ? "form-group--error" : string.Empty) @(showUnitOther ? string.Empty : "d-none")" id="kpiUnitOtherGroup">
    <label asp-for="Input.UnitOfMeasureOther">Unit of measure (other)</label>
    <span asp-validation-for="Input.UnitOfMeasureOther" class="form-error-message"></span>
    <input asp-for="Input.UnitOfMeasureOther" class="form-control @(hasError("UnitOfMeasureOther") ? "form-control--error" : string.Empty)" maxlength="100" placeholder="If other, specify" />
</div>

<div class="form-group @(hasError("Frequency") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.Frequency">Reporting frequency</label>
    <span asp-validation-for="Input.Frequency" class="form-error-message"></span>
    <select asp-for="Input.Frequency" class="form-control @(hasError("Frequency") ? "form-control--error" : string.Empty)" asp-items="Model.FrequencyOptions">
        <option value="">Select frequency</option>
    </select>
</div>

<div class="form-group @(hasError("TargetValue") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.TargetValue">Target value</label>
    <span asp-validation-for="Input.TargetValue" class="form-error-message"></span>
    <input asp-for="Input.TargetValue" class="form-control @(hasError("TargetValue") ? "form-control--error" : string.Empty)" type="number" step="0.01" />
</div>

<div class="form-group @(hasError("Thresholds") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.Thresholds">Thresholds</label>
    <small class="form-text text-muted">Optional guardrails or tolerances.</small>
    <span asp-validation-for="Input.Thresholds" class="form-error-message"></span>
    <input asp-for="Input.Thresholds" class="form-control @(hasError("Thresholds") ? "form-control--error" : string.Empty)" />
</div>

<div class="form-group @(hasError("DataSource") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.DataSource">Data source</label>
    <span asp-validation-for="Input.DataSource" class="form-error-message"></span>
    <select asp-for="Input.DataSource" class="form-control @(hasError("DataSource") ? "form-control--error" : string.Empty)" asp-items="Model.DataSourceOptions" id="kpiDataSource">
        <option value="">Select data source</option>
    </select>
</div>

<div class="form-group @(hasError("DataSourceOther") ? "form-group--error" : string.Empty) @(showDataSourceOther ? string.Empty : "d-none")" id="kpiDataSourceOtherGroup">
    <label asp-for="Input.DataSourceOther">Data source (other)</label>
    <span asp-validation-for="Input.DataSourceOther" class="form-error-message"></span>
    <input asp-for="Input.DataSourceOther" class="form-control @(hasError("DataSourceOther") ? "form-control--error" : string.Empty)" maxlength="200" placeholder="If other, specify" />
</div>

<div class="form-group @(hasError("Status") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.Status">Status</label>
    <small class="form-text text-muted">Show how this KPI is currently performing.</small>
    <span asp-validation-for="Input.Status" class="form-error-message"></span>
    <select asp-for="Input.Status" class="form-control @(hasError("Status") ? "form-control--error" : string.Empty)" asp-items="Model.StatusOptions">
        <option value="">Select status</option>
    </select>
</div>

<div class="form-group @(hasError("ObjectiveId") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.ObjectiveId">Linked objective</label>
    <span asp-validation-for="Input.ObjectiveId" class="form-error-message"></span>
    <select asp-for="Input.ObjectiveId" class="form-control @(hasError("ObjectiveId") ? "form-control--error" : string.Empty)" asp-items="Model.ObjectiveOptions">
        <option value="">Not linked</option>
    </select>
</div>

<div class="form-group @(hasError("MilestoneId") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.MilestoneId">Linked milestone</label>
    <span asp-validation-for="Input.MilestoneId" class="form-error-message"></span>
    <select asp-for="Input.MilestoneId" class="form-control @(hasError("MilestoneId") ? "form-control--error" : string.Empty)" asp-items="Model.MilestoneOptions">
        <option value="">Not linked</option>
    </select>
</div>

@if (Model.ShowActiveToggle)
{
    <div class="form-group form-check mb-0">
        <input asp-for="Input.Active" class="form-check-input" />
        <label asp-for="Input.Active" class="form-check-label">KPI is active</label>
    </div>
}

