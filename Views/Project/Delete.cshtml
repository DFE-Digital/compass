@model Compass.Models.Project
@{
    ViewData["Title"] = "Delete Project";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Project")">Projects</a></li>
                    <li class="breadcrumb-item active">Project</li>
                </ol>
                <h1 class="m-0">Delete Project</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Are you sure you want to delete this project?</h3>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-warning">
                            <h5><i class="fas fa-exclamation-triangle"></i> Warning</h5>
                            <p class="mb-0">This action will permanently delete the project and all associated data. This action cannot be undone.</p>
                        </div>

                        <dl class="row">
                            <dt class="col-sm-3">Project Code:</dt>
                            <dd class="col-sm-9">@Model.ProjectCode</dd>

                            <dt class="col-sm-3">Title:</dt>
                            <dd class="col-sm-9">@Model.Title</dd>

                            <dt class="col-sm-3">Aim:</dt>
                            <dd class="col-sm-9">@Model.Aim</dd>

                            <dt class="col-sm-3">Status:</dt>
                            <dd class="col-sm-9">@Model.Status</dd>

                            <dt class="col-sm-3">RAG Status:</dt>
                            <dd class="col-sm-9">@Model.RagStatus</dd>

                            <dt class="col-sm-3">Phase:</dt>
                            <dd class="col-sm-9">@Model.Phase</dd>

                            <dt class="col-sm-3">Flagship:</dt>
                            <dd class="col-sm-9">@(Model.IsFlagship ? "Yes" : "No")</dd>

                            <dt class="col-sm-3">AI Initiative:</dt>
                            <dd class="col-sm-9">@(Model.IsAiInitiative ? "Yes" : "No")</dd>

                            <dt class="col-sm-3">Start Date:</dt>
                            <dd class="col-sm-9">@Model.StartDate.ToString("dd MMM yyyy")</dd>

                            <dt class="col-sm-3">Target Delivery:</dt>
                            <dd class="col-sm-9">@Model.TargetDeliveryDate.ToString("dd MMM yyyy")</dd>
                        </dl>

                        <form asp-action="Delete">
                            <input type="hidden" asp-for="Id" />
                            <div class="form-group">
                                <button type="submit" class="btn btn-danger">
                                    <i class="fas fa-trash"></i> Delete Project
                                </button>
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left"></i> Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
