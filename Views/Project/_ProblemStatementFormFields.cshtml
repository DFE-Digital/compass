@model Compass.ViewModels.ProjectProblemStatementFormViewModel

@{
    Func<string, bool> hasError = key =>
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return false;
        }

        if (ViewData.ModelState.TryGetValue(key, out var entry) && entry.Errors.Count > 0)
        {
            return true;
        }

        var inputKey = $"Input.{key}";
        if (ViewData.ModelState.TryGetValue(inputKey, out var inputEntry) && inputEntry.Errors.Count > 0)
        {
            return true;
        }

        return false;
    };
}

<div class="form-group @(hasError("ProblemStatement") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.ProblemStatement" class="font-weight-bold">Problem statement</label>
    <small class="form-text text-muted">Describe the problem this project aims to solve.</small>
    <span asp-validation-for="Input.ProblemStatement" class="form-error-message"></span>
    <textarea asp-for="Input.ProblemStatement" class="form-control @(hasError("ProblemStatement") ? "form-control--error" : string.Empty)" rows="8"></textarea>
</div>

