@model Compass.ViewModels.ProjectProblemStatementFormViewModel

@{
    ViewData["Title"] = $"Edit problem statement – {Model.ProjectTitle}";
    var returnUrl = Url.Action("Details", "Project", new { id = Model.Input.ProjectId, tab = "outcomes" });

    Func<string, string> normaliseKey = key =>
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return string.Empty;
        }

        var trimmed = key;
        var bracketIndex = trimmed.IndexOf('[');
        if (bracketIndex >= 0)
        {
            trimmed = trimmed.Substring(0, bracketIndex);
        }

        var segments = trimmed.Split('.', System.StringSplitOptions.RemoveEmptyEntries);
        return segments.Length > 0 ? segments[^1] : trimmed;
    };

    var fieldIdLookup = new Dictionary<string, string>(System.StringComparer.OrdinalIgnoreCase)
    {
        ["ProblemStatement"] = Html.IdFor(m => m.Input.ProblemStatement)
    };

    var modelErrors = ViewData.ModelState
        .Where(kvp => kvp.Value?.Errors?.Any() == true)
        .Select(kvp => new
        {
            Key = normaliseKey(kvp.Key),
            Errors = kvp.Value!.Errors
                .Select(error => error.ErrorMessage)
                .Where(message => !string.IsNullOrWhiteSpace(message))
                .ToList()
        })
        .Where(entry => entry.Errors.Any())
        .ToList();

    var hasModelErrors = modelErrors.Any();
    var errorSummaryClasses = hasModelErrors ? "card error-summary mb-3" : "card error-summary d-none mb-3";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-3">
            <div class="col-12">
                <a class="btn btn-link px-0 mb-2" href="@returnUrl" aria-label="Back to project">
                    <i class="fas fa-arrow-left mr-2" aria-hidden="true"></i>Back to project
                </a>
                <h1 class="m-0">Edit problem statement</h1>
                <p class="text-muted mb-0">Project: @Model.ProjectTitle</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <form asp-action="UpdateProblemStatement" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input asp-for="Input.ProjectId" type="hidden" />
            <input asp-for="Input.ProblemStatementId" type="hidden" />

            <div class="row">
                <div class="col-lg-8 col-md-10">
                    <div id="problem-statement-edit-error-summary"
                         class="@errorSummaryClasses"
                         role="alert"
                         aria-labelledby="problem-statement-edit-error-summary-title"
                         @(hasModelErrors ? "tabindex=\"-1\" aria-hidden=\"false\"" : "aria-hidden=\"true\"")
                         data-module="error-summary">
                        <div class="card-body">
                            <h2 id="problem-statement-edit-error-summary-title" class="error-summary__title">There is a problem</h2>
                            <ul class="error-summary__list">
                                @if (hasModelErrors)
                                {
                                    foreach (var entry in modelErrors)
                                    {
                                        string fieldId = string.Empty;
                                        var hasLink = !string.IsNullOrWhiteSpace(entry.Key) && fieldIdLookup.TryGetValue(entry.Key, out fieldId);

                                        foreach (var message in entry.Errors)
                                        {
                                            if (hasLink)
                                            {
                                                <li><a href="#@fieldId">@message</a></li>
                                            }
                                            else
                                            {
                                                <li>@message</li>
                                            }
                                        }
                                    }
                                }
                            </ul>
                        </div>
                    </div>
                    <div class="card mb-4">
                        <div class="card-header">
                            <h3 class="card-title mb-0">Problem statement details</h3>
                        </div>
                        <div class="card-body">
                            <partial name="_ProblemStatementFormFields" model="Model" />
                        </div>
                        <div class="card-footer d-flex align-items-center">
                            <button type="submit" class="btn btn-primary mr-3">Save changes</button>
                            <a class="btn btn-outline-secondary" href="@returnUrl">Cancel</a>
                        </div>
                    </div>
                </div>
            </div>
        </form>

        <div class="row">
            <div class="col-lg-8 col-md-10">
                <div class="card card-outline card-danger">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Delete problem statement</h3>
                    </div>
                    <div class="card-body">
                        <p class="mb-3">Deleting this problem statement will remove it from planning and reporting views.</p>
                        <form asp-action="DeleteProblemStatement" method="post" onsubmit="return confirm('Are you sure you want to delete this problem statement?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="projectId" value="@Model.Input.ProjectId" />
                            <input type="hidden" name="problemStatementId" value="@Model.Input.ProblemStatementId" />
                            <button type="submit" class="btn btn-outline-danger">Delete problem statement</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

