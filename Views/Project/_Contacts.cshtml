@model Compass.Models.Project

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Project Contacts</h3>
                <div class="card-tools">
                    <a href="#" data-toggle="modal" data-target="#addContactModal">Add contact</a>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                @{
                    // Check if ProjectContacts property exists and has data
                    var projectContacts = Model.GetType().GetProperty("ProjectContacts")?.GetValue(Model) as IEnumerable<dynamic>;
                }
                @if (projectContacts?.Any() == true)
                {
                    <table class="table table-hover text-nowrap sortable-table contacts-table">
                        <thead>
                            <tr>
                                <th class="col-contact-name sortable" data-column="Name" tabindex="0" role="button" aria-label="Sort by Name">
                                    Name
                                    <i class="fas fa-sort sort-icon"></i>
                                </th>
                                <th class="col-contact-email sortable" data-column="Email" tabindex="0" role="button" aria-label="Sort by Email">
                                    Email Address
                                    <i class="fas fa-sort sort-icon"></i>
                                </th>
                                <th class="col-contact-role sortable" data-column="Role" tabindex="0" role="button" aria-label="Sort by Role">
                                    Role
                                    <i class="fas fa-sort sort-icon"></i>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var contact in projectContacts.OrderByDescending(c => (DateTime)c.CreatedAt))
                            {
                                <tr>
                                    <td>
                                        <a href="#" class="edit-contact-link" data-contact-id="@contact.Id" data-contact-name="@contact.Name" data-contact-email="@contact.Email" data-contact-role="@contact.Role" data-contact-description="@(contact.RoleDescription ?? "")">@contact.Name</a>
                                    </td>
                                    <td>
                                        <a href="mailto:@contact.Email" class="text-primary">@contact.Email</a>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(contact.Role))
                                        {
                                            @contact.Role
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not specified</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-4">
                        <p class="text-muted mb-2">No contacts recorded.</p>
                        <button type="button" class="btn btn-success" data-toggle="modal" data-target="#addContactModal">Add first contact</button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Add Contact Modal -->
<div class="modal fade" id="addContactModal" tabindex="-1" role="dialog" aria-labelledby="addContactModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addContactModalLabel">Add New Contact</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="AddContact" method="post">
                <input type="hidden" name="projectId" value="@Model.Id" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="contactName">Name</label>
                        <input type="text" class="form-control" id="contactName" name="name" required placeholder="Enter contact name">
                    </div>
                    <div class="form-group">
                        <label for="contactEmail">Email Address</label>
                        <input type="email" class="form-control" id="contactEmail" name="email" required placeholder="Enter email address">
                    </div>
                    <div class="form-group">
                        <label for="contactRole">Role (Optional)</label>
                        <input type="text" class="form-control" id="contactRole" name="role" placeholder="e.g., Project Manager, Stakeholder, Developer">
                        <small class="form-text text-muted">Role will be populated from Entra ID once integration is complete</small>
                    </div>
                    <div class="form-group">
                        <label for="contactDescription">Description (Optional)</label>
                        <textarea class="form-control" id="contactDescription" name="description" rows="2" placeholder="Additional information about this contact..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add Contact</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Contact Modal -->
<div class="modal fade" id="editContactModal" tabindex="-1" role="dialog" aria-labelledby="editContactModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editContactModalLabel">Edit Contact</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateContact" method="post">
                <input type="hidden" name="projectId" value="@Model.Id" />
                <input type="hidden" name="contactId" id="editContactId" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="editContactName">Name</label>
                        <input type="text" class="form-control" id="editContactName" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="editContactEmail">Email Address</label>
                        <input type="email" class="form-control" id="editContactEmail" name="email" required>
                    </div>
                    <div class="form-group">
                        <label for="editContactRole">Role (Optional)</label>
                        <input type="text" class="form-control" id="editContactRole" name="role" placeholder="e.g., Project Manager, Stakeholder, Developer">
                        <small class="form-text text-muted">Role will be populated from Entra ID once integration is complete</small>
                    </div>
                    <div class="form-group">
                        <label for="editContactDescription">Description (Optional)</label>
                        <textarea class="form-control" id="editContactDescription" name="description" rows="2" placeholder="Additional information about this contact..."></textarea>
                    </div>
                </div>
                <div class="modal-footer d-flex justify-content-between">
                    <button type="button" class="btn btn-danger" id="deleteContactFromEditBtn">Delete Contact</button>
                    <div>
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Update Contact</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Contact Confirmation Modal -->
<div class="modal fade" id="deleteContactModal" tabindex="-1" role="dialog" aria-labelledby="deleteContactModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteContactModalLabel">Confirm Delete</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete the contact <strong id="deleteContactName"></strong>?</p>
                <p class="text-muted">This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <form asp-action="DeleteContact" method="post" class="d-inline">
                    <input type="hidden" name="projectId" value="@Model.Id" />
                    <input type="hidden" name="contactId" id="deleteContactId" />
                    <button type="submit" class="btn btn-danger">Delete Contact</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
    (function() {
        function initContactsPage() {
            // Initialize sortable tables
            $('.contacts-table').each(function() {
                initializeContactsTable($(this));
            });

            // Handle edit contact link clicks
            $(document).on('click', '.edit-contact-link', function(e) {
                e.preventDefault();
                var contactId = $(this).attr('data-contact-id');
                var name = $(this).attr('data-contact-name');
                var email = $(this).attr('data-contact-email');
                var role = $(this).attr('data-contact-role');
                var description = $(this).attr('data-contact-description');
                editContact(contactId, name, email, role, description);
            });

            // Handle delete contact from edit modal
            $('#deleteContactFromEditBtn').on('click', function() {
                deleteContactFromEdit();
            });
        }

        if (typeof jQuery !== 'undefined') {
            $(document).ready(initContactsPage);
        } else {
            document.addEventListener('DOMContentLoaded', function() {
                if (typeof jQuery !== 'undefined') {
                    $(document).ready(initContactsPage);
                }
            });
        }
    })();

    function editContact(contactId, name, email, role, description) {
        $('#editContactId').val(contactId);
        $('#editContactName').val(name);
        $('#editContactEmail').val(email);
        $('#editContactRole').val(role || '');
        $('#editContactDescription').val(description || '');
        $('#editContactModal').modal('show');
    }

    function deleteContactFromEdit() {
        var contactId = $('#editContactId').val();
        var name = $('#editContactName').val();
        $('#editContactModal').modal('hide');
        deleteContact(contactId, name);
    }

    function deleteContact(contactId, name) {
        $('#deleteContactId').val(contactId);
        $('#deleteContactName').text(name);
        $('#deleteContactModal').modal('show');
    }

    function initializeContactsTable(table) {
        var currentSort = { column: null, direction: 'asc' };

        table.find('.sortable').on('click keypress', function(e) {
            if (e.type === 'keypress' && e.which !== 13 && e.which !== 32) {
                return;
            }
            
            var column = $(this).data('column');
            var direction = 'asc';
            
            if (currentSort.column === column && currentSort.direction === 'asc') {
                direction = 'desc';
            }
            
            sortTable(table, column, direction);
            currentSort = { column: column, direction: direction };
        });

        function sortTable(table, column, direction) {
            var tbody = table.find('tbody');
            var rows = tbody.find('tr').toArray();
            
            rows.sort(function(a, b) {
                var aVal, bVal;
                var colIndex = table.find('thead th[data-column="' + column + '"]').index();
                
                aVal = $(a).find('td').eq(colIndex).text().trim().toLowerCase();
                bVal = $(b).find('td').eq(colIndex).text().trim().toLowerCase();
                
                if (direction === 'asc') {
                    return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                } else {
                    return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                }
            });
            
            tbody.empty();
            rows.forEach(function(row) {
                tbody.append(row);
            });
            
            updateSortIcons(table, column, direction);
        }

        function updateSortIcons(table, column, direction) {
            table.find('.sortable i').remove();
            var header = table.find('.sortable[data-column="' + column + '"]');
            var iconClass = direction === 'asc' ? 'fa-sort-up' : 'fa-sort-down';
            header.append(' <i class="fas ' + iconClass + '"></i>');
        }
    }
</script>
