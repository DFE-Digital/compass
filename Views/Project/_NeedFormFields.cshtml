@model Compass.ViewModels.ProjectNeedFormViewModel

@{
    Func<string, bool> hasError = key =>
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return false;
        }

        if (ViewData.ModelState.TryGetValue(key, out var entry) && entry.Errors.Count > 0)
        {
            return true;
        }

        var inputKey = $"Input.{key}";
        if (ViewData.ModelState.TryGetValue(inputKey, out var inputEntry) && inputEntry.Errors.Count > 0)
        {
            return true;
        }

        return false;
    };
}

<div class="form-group @(hasError("Title") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.Title" class="font-weight-bold">Title</label>
    <small class="form-text text-muted">A short title for this need.</small>
    <span asp-validation-for="Input.Title" class="form-error-message"></span>
    <input asp-for="Input.Title" class="form-control @(hasError("Title") ? "form-control--error" : string.Empty)" maxlength="200" />
</div>

<div class="form-group @(hasError("Need") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.Need" class="font-weight-bold">Need</label>
    <small class="form-text text-muted">Describe the high level need.</small>
    <span asp-validation-for="Input.Need" class="form-error-message"></span>
    <textarea asp-for="Input.Need" class="form-control @(hasError("Need") ? "form-control--error" : string.Empty)" rows="4" maxlength="1000"></textarea>
</div>

<div class="form-group @(hasError("Source") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.Source">Source (optional)</label>
    <small class="form-text text-muted">Where this need came from (e.g., user research, stakeholder feedback).</small>
    <span asp-validation-for="Input.Source" class="form-error-message"></span>
    <input asp-for="Input.Source" class="form-control @(hasError("Source") ? "form-control--error" : string.Empty)" maxlength="500" />
</div>

<div class="form-group @(hasError("Validated") ? "form-group--error" : string.Empty)">
    <fieldset>
        <legend>Validated</legend>
        <small class="form-text text-muted">Whether this need has been validated.</small>
        <span asp-validation-for="Input.Validated" class="form-error-message"></span>
        @foreach (var option in Model.ValidatedOptions)
        {
            <div class="form-check">
                <input class="form-check-input" 
                       type="radio" 
                       name="Input.Validated" 
                       id="validated-@option.Value" 
                       value="@option.Value" 
                       @(option.Selected ? "checked" : "") />
                <label class="form-check-label" for="validated-@option.Value">
                    @option.Text
                </label>
            </div>
        }
    </fieldset>
</div>

<div class="form-group @(hasError("ValidationNotes") ? "form-group--error" : string.Empty) @(Model.Input.Validated != "Yes" ? "d-none" : "")" id="validation-notes-group">
    <label asp-for="Input.ValidationNotes" class="font-weight-bold">Validation notes</label>
    <small class="form-text text-muted">How and when this need was validated (e.g., user research conducted on 15 Jan 2025, stakeholder workshop on 20 Jan 2025).</small>
    <span asp-validation-for="Input.ValidationNotes" class="form-error-message"></span>
    <textarea asp-for="Input.ValidationNotes" class="form-control @(hasError("ValidationNotes") ? "form-control--error" : string.Empty)" rows="4" maxlength="2000"></textarea>
</div>

<input asp-for="Input.SortOrder" type="hidden" />

<script nonce="@Context.Items["Nonce"]">
    document.addEventListener('DOMContentLoaded', function() {
        const validatedRadios = document.querySelectorAll('input[name="Input.Validated"]');
        const validationNotesGroup = document.getElementById('validation-notes-group');
        let previousValidatedValue = '@Model.Input.Validated';
        
        if (validatedRadios.length > 0 && validationNotesGroup) {
            function toggleValidationNotes() {
                const selectedValue = document.querySelector('input[name="Input.Validated"]:checked')?.value;
                if (selectedValue === 'Yes') {
                    validationNotesGroup.classList.remove('d-none');
                    // If changing from "No" to "Yes", focus on the notes field
                    if (previousValidatedValue === 'No' && selectedValue === 'Yes') {
                        const notesTextarea = validationNotesGroup.querySelector('textarea');
                        if (notesTextarea) {
                            setTimeout(function() {
                                notesTextarea.focus();
                            }, 100);
                        }
                    }
                    // Update previous value
                    previousValidatedValue = selectedValue;
                } else {
                    validationNotesGroup.classList.add('d-none');
                    // Update previous value
                    previousValidatedValue = selectedValue || previousValidatedValue;
                }
            }
            
            validatedRadios.forEach(function(radio) {
                radio.addEventListener('change', toggleValidationNotes);
            });
            
            toggleValidationNotes(); // Initial state
        }
    });
</script>

