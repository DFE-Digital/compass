@using System.Globalization
@using Compass.Helpers
@model Compass.Models.Project

@{
    var issuesView = (ViewBag.IssuesView as string ?? "table").ToLowerInvariant();
    var issues = Model.Issues?
        .Where(i => !i.IsDeleted)
        .OrderByDescending(i => i.DetectedDate)
        .ToList() ?? new List<Compass.Models.Issue>();
    var severityOrder = new[] { "critical", "high", "medium", "low" };
    var priorityOrder = new[] { "not_set", "low", "medium", "high" };
    var textInfo = CultureInfo.InvariantCulture.TextInfo;

    string FormatLabel(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "Not set";
        }

        return textInfo.ToTitleCase(value.Replace("_", " "));
    }

    string ResolveSeverityClass(string? severity) => severity switch
    {
        "critical" => "badge-danger",
        "high" => "badge-warning",
        "medium" => "badge-info",
        _ => "badge-secondary"
    };

    string ResolveStatusClass(string status) => status switch
    {
        "resolved" or "closed" => "badge-success",
        "blocked" => "badge-danger",
        "in_progress" => "badge-primary",
        _ => "badge-secondary"
    };

    string ResolvePriorityBadgeClass(string? priority)
    {
        var key = PriorityStyleHelper.GetPriorityKey(priority);
        return $"priority-badge priority-badge--{key}";
    }

    string ResolveCellBackgroundClass(string? severity, string? priority)
    {
        var severityKey = severity?.ToLowerInvariant() ?? "low";
        var priorityKey = priority?.ToLowerInvariant() ?? "not_set";
        
        // Critical severity - combination determines risk level
        if (severityKey == "critical")
        {
            return priorityKey switch
            {
                "high" => "bg-danger",        // Critical risk (red)
                "medium" => "bg-danger",      // Critical risk (red)
                "low" => "bg-warning",        // High risk (yellow/orange)
                _ => "bg-warning"             // High risk (yellow/orange)
            };
        }
        
        // High severity
        if (severityKey == "high")
        {
            return priorityKey switch
            {
                "high" => "bg-danger",        // Critical risk (red)
                "medium" => "bg-warning",     // High risk (yellow/orange)
                "low" => "bg-warning",        // High risk (yellow/orange)
                _ => "bg-warning"             // High risk (yellow/orange)
            };
        }
        
        // Medium severity
        if (severityKey == "medium")
        {
            return priorityKey switch
            {
                "high" => "bg-warning",       // High risk (yellow/orange)
                "medium" => "bg-info",        // Moderate risk (blue)
                "low" => "bg-info",           // Moderate risk (blue)
                _ => "bg-info"                // Moderate risk (blue)
            };
        }
        
        // Low severity - always low risk (light green)
        return "bg-light";
    }

    var severityValues = severityOrder.ToList();
    foreach (var severity in issues.Select(i => i.Severity).Where(s => !string.IsNullOrWhiteSpace(s)))
    {
        if (!severityValues.Contains(severity, StringComparer.OrdinalIgnoreCase))
        {
            severityValues.Add(severity);
        }
    }

    var priorityValues = priorityOrder.ToList();
    foreach (var priority in issues.Select(i => i.Priority).Where(p => !string.IsNullOrWhiteSpace(p)))
    {
        if (!priorityValues.Contains(priority!, StringComparer.OrdinalIgnoreCase))
        {
            priorityValues.Add(priority!);
        }
    }
}

<div class="card" id="issues">
    <div class="card-header">
        <h3 class="card-title mb-0">Project issues</h3>
        <div class="card-tools">
            <a class="card-link mr-3 mb-2"
               asp-controller="Project"
               asp-action="CreateIssue"
               asp-route-projectId="@Model.Id">
                Add issue
            </a>
            @if (issuesView == "priority")
            {
                <a class="card-link mb-2"
                   asp-action="Details"
                   asp-route-id="@Model.Id"
                   asp-route-tab="issues"
                   asp-route-issuesView="table">
                    List view
                </a>
            }
            else
            {
                <a class="card-link mb-2"
                   asp-action="Details"
                   asp-route-id="@Model.Id"
                   asp-route-tab="issues"
                   asp-route-issuesView="priority">
                    Priority view
                </a>
            }
        </div>
    </div>
    @if (!issues.Any())
    {
        <div class="card-body">
            <p class="text-muted mb-2">No issues recorded.</p>
            <a asp-controller="Project" asp-action="CreateIssue" asp-route-projectId="@Model.Id">Add issue</a>
        </div>
    }
    else if (issuesView == "priority")
    {
        <div class="card-body priority-view">
            <p class="text-muted mb-3">
                Use the grid to see how issues are distributed across severity and priority. Select a cell to drill into the related issues.
            </p>
            <div class="table-responsive">
                <table class="table table-bordered priority-matrix mb-0">
                    <thead>
                        <tr>
                            <th scope="col" class="align-middle">Severity \ Priority</th>
                            @foreach (var priority in priorityValues)
                            {
                                <th scope="col" class="text-center align-middle">
                                    <span class="badge @ResolvePriorityBadgeClass(priority == "not_set" ? null : priority)">
                                        @FormatLabel(priority == "not_set" ? null : priority)
                                    </span>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var severity in severityValues)
                        {
                            <tr>
                                <th scope="row" class="align-middle">
                                    <span class="badge @ResolveSeverityClass(severity)">@FormatLabel(severity)</span>
                                </th>
                                @foreach (var priority in priorityValues)
                                {
                                    var cellIssues = issues
                                        .Where(i =>
                                            string.Equals(i.Severity, severity, StringComparison.OrdinalIgnoreCase) &&
                                            (priority == "not_set"
                                                ? string.IsNullOrWhiteSpace(i.Priority)
                                                : string.Equals(i.Priority, priority, StringComparison.OrdinalIgnoreCase)))
                                        .OrderByDescending(i => i.TargetResolutionDate ?? DateTime.MaxValue)
                                        .ThenByDescending(i => i.DetectedDate)
                                        .ToList();
                                    var cellBgClass = ResolveCellBackgroundClass(severity, priority == "not_set" ? null : priority);
                                    <td class="@cellBgClass">
                                        <div class="priority-matrix-cell">
                                            <div class="text-center">
                                                <span class="badge badge-light font-weight-bold" style="font-size: 1.25rem;">@cellIssues.Count</span>
                                            </div>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="card-body table-responsive p-0">
            <table class="table table-hover text-nowrap sortable-table issues-table mb-0">
                <thead>
                    <tr>
                        <th class="col-title sortable" data-column="Title" tabindex="0" role="button" aria-label="Sort by Title">
                            Title
                            <i class="fas fa-sort sort-icon" aria-hidden="true"></i>
                        </th>
                        <th class="col-severity sortable" data-column="Severity" tabindex="0" role="button" aria-label="Sort by Severity">
                            Severity
                            <i class="fas fa-sort sort-icon" aria-hidden="true"></i>
                        </th>
                        <th class="col-priority sortable" data-column="Priority" tabindex="0" role="button" aria-label="Sort by Priority">
                            Priority
                            <i class="fas fa-sort sort-icon" aria-hidden="true"></i>
                        </th>
                        <th class="col-status sortable" data-column="Status" tabindex="0" role="button" aria-label="Sort by Status">
                            Status
                            <i class="fas fa-sort sort-icon" aria-hidden="true"></i>
                        </th>
                        <th class="col-detected sortable" data-column="Detected" tabindex="0" role="button" aria-label="Sort by Detected date">
                            Detected
                            <i class="fas fa-sort sort-icon" aria-hidden="true"></i>
                        </th>
                        <th class="col-target sortable" data-column="Target" tabindex="0" role="button" aria-label="Sort by Target resolution">
                            Target resolution
                            <i class="fas fa-sort sort-icon" aria-hidden="true"></i>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var issue in issues)
                    {
                        var detectedSort = issue.DetectedDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
                        var targetSort = issue.TargetResolutionDate?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
                        var isTargetOverdue = issue.TargetResolutionDate.HasValue && issue.TargetResolutionDate.Value.Date < DateTime.Today;
                        <tr>
                            <td>
                                <a asp-controller="Issue" asp-action="Details" asp-route-id="@issue.Id">@issue.Title</a>
                            </td>
                            <td>
                                <span class="badge @ResolveSeverityClass(issue.Severity)">
                                    @FormatLabel(issue.Severity)
                                </span>
                            </td>
                            <td>
                                <span class="badge @ResolvePriorityBadgeClass(issue.Priority)">
                                    @FormatLabel(issue.Priority)
                                </span>
                            </td>
                            <td>
                                <span class="badge @ResolveStatusClass(issue.Status)">
                                    @issue.Status.Replace("_", " ")
                                </span>
                            </td>
                            <td data-sort-value="@detectedSort">@issue.DetectedDate.ToString("d MMMM yyyy")</td>
                            <td data-sort-value="@(targetSort ?? string.Empty)">
                                @if (issue.TargetResolutionDate.HasValue)
                                {
                                    <span class="@(isTargetOverdue ? "text-danger font-weight-semibold" : string.Empty)">
                                        @issue.TargetResolutionDate.Value.ToString("d MMMM yyyy")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
