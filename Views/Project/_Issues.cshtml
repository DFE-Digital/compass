@using System.Globalization
@using Compass.Helpers
@model Compass.Models.Project

@{
    var issuesView = (ViewBag.IssuesView as string ?? "table").ToLowerInvariant();
    var issues = Model.Issues?
        .Where(i => !i.IsDeleted)
        .OrderByDescending(i => i.DetectedDate)
        .ToList() ?? new List<Compass.Models.Issue>();
    var severityOrder = new[] { "critical", "high", "medium", "low" };
    var priorityOrder = new[] { "not_set", "low", "medium", "high" };
    var textInfo = CultureInfo.InvariantCulture.TextInfo;

    string FormatLabel(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "Not set";
        }

        return textInfo.ToTitleCase(value.Replace("_", " "));
    }

    string ResolveSeverityClass(string? severity)
    {
        var severityKey = severity?.ToLowerInvariant() ?? "low";
        return severityKey switch
        {
            "critical" => "badge priority-badge priority-badge--critical",
            "high" => "badge priority-badge priority-badge--high",
            "medium" => "badge priority-badge priority-badge--medium",
            _ => "badge priority-badge priority-badge--low"
        };
    }

    string ResolveStatusClass(string status) => status switch
    {
        "resolved" or "closed" => "badge-success",
        "blocked" => "badge-danger",
        "in_progress" => "badge-primary",
        _ => "badge-secondary"
    };

    string ResolvePriorityBadgeClass(string? priority)
    {
        var key = PriorityStyleHelper.GetPriorityKey(priority);
        return $"priority-badge priority-badge--{key}";
    }

    string ResolveCellBackgroundClass(string? severity, string? priority)
    {
        var severityKey = severity?.ToLowerInvariant() ?? "low";
        var priorityKey = priority?.ToLowerInvariant() ?? "not_set";
        
        // Critical severity - combination determines risk level
        if (severityKey == "critical")
        {
            return priorityKey switch
            {
                "high" => "priority-matrix-bg--critical",        // Critical risk (muted red)
                "medium" => "priority-matrix-bg--critical",      // Critical risk (muted red)
                "low" => "priority-matrix-bg--medium",           // High risk (muted orange)
                _ => "priority-matrix-bg--medium"                // High risk (muted orange)
            };
        }
        
        // High severity
        if (severityKey == "high")
        {
            return priorityKey switch
            {
                "high" => "priority-matrix-bg--critical",        // Critical risk (muted red)
                "medium" => "priority-matrix-bg--medium",        // High risk (muted orange)
                "low" => "priority-matrix-bg--medium",            // High risk (muted orange)
                _ => "priority-matrix-bg--medium"               // High risk (muted orange)
            };
        }
        
        // Medium severity
        if (severityKey == "medium")
        {
            return priorityKey switch
            {
                "high" => "priority-matrix-bg--medium",          // High risk (muted orange)
                "medium" => "priority-matrix-bg--low",            // Moderate risk (muted green)
                "low" => "priority-matrix-bg--low",              // Moderate risk (muted green)
                _ => "priority-matrix-bg--low"                   // Moderate risk (muted green)
            };
        }
        
        // Low severity - always low risk (muted grey)
        return "priority-matrix-bg--default";
    }

    var severityValues = severityOrder.ToList();
    foreach (var severity in issues.Select(i => i.Severity).Where(s => !string.IsNullOrWhiteSpace(s)))
    {
        if (!severityValues.Contains(severity, StringComparer.OrdinalIgnoreCase))
        {
            severityValues.Add(severity);
        }
    }

    var priorityValues = priorityOrder.ToList();
    foreach (var priority in issues.Select(i => i.Priority).Where(p => !string.IsNullOrWhiteSpace(p)))
    {
        if (!priorityValues.Contains(priority!, StringComparer.OrdinalIgnoreCase))
        {
            priorityValues.Add(priority!);
        }
    }
}

<div class="card" id="issues">
    <div class="card-header">
        <h3 class="card-title mb-0">Work issues</h3>
        <div class="card-tools">
            @if (issuesView == "table" && issues.Any())
            {
                <button class="card-link mr-3 issues-filter-toggle" 
                        type="button" 
                        data-toggle="collapse" 
                        data-target="#issuesFilterCollapse" 
                        aria-expanded="false" 
                        aria-controls="issuesFilterCollapse">
                    <i class="fas fa-filter mr-1"></i>
                    Filters
                    <i class="fas fa-chevron-down ml-1 filter-chevron"></i>
                </button>
            }
            <a class="card-link mr-3"
               asp-controller="Project"
               asp-action="CreateIssue"
               asp-route-projectId="@Model.Id">
                Add issue
            </a>
            @if (issuesView == "priority")
            {
                <a class="card-link"
                   asp-action="Details"
                   asp-route-id="@Model.Id"
                   asp-route-tab="issues"
                   asp-route-issuesView="table">
                    List view
                </a>
            }
            else
            {
                <a class="card-link"
                   asp-action="Details"
                   asp-route-id="@Model.Id"
                   asp-route-tab="issues"
                   asp-route-issuesView="priority">
                    Priority view
                </a>
            }
        </div>
    </div>
    @if (!issues.Any())
    {
        <div class="card-body p-0">
            <div class="p-3">
                <p class="text-muted mb-2">No issues recorded.</p>
                <a asp-controller="Project" asp-action="CreateIssue" asp-route-projectId="@Model.Id">Add issue</a>
            </div>
        </div>
    }
    else if (issuesView == "priority")
    {
        <div class="card-body priority-view">
            <p class="text-muted mb-3">
                Use the grid to see how issues are distributed across severity and priority. Select a cell to drill into the related issues.
            </p>
            <div class="table-responsive">
                <table class="table priority-matrix mb-0" style="border-collapse: separate; border-spacing: 0;">
                    <thead>
                        <tr>
                            <th scope="col" class="align-middle">Severity \ Priority</th>
                            @foreach (var priority in priorityValues)
                            {
                                <th scope="col" class="text-center align-middle">
                                    <span class="badge @ResolvePriorityBadgeClass(priority == "not_set" ? null : priority)">
                                        @FormatLabel(priority == "not_set" ? null : priority)
                                    </span>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var severity in severityValues)
                        {
                            <tr>
                                <th scope="row" class="align-middle">
                                    <span class="badge @ResolveSeverityClass(severity)">@FormatLabel(severity)</span>
                                </th>
                                @foreach (var priority in priorityValues)
                                {
                                    var cellIssues = issues
                                        .Where(i =>
                                            string.Equals(i.Severity, severity, StringComparison.OrdinalIgnoreCase) &&
                                            (priority == "not_set"
                                                ? string.IsNullOrWhiteSpace(i.Priority)
                                                : string.Equals(i.Priority, priority, StringComparison.OrdinalIgnoreCase)))
                                        .OrderByDescending(i => i.TargetResolutionDate ?? DateTime.MaxValue)
                                        .ThenByDescending(i => i.DetectedDate)
                                        .ToList();
                                    var cellBgClass = ResolveCellBackgroundClass(severity, priority == "not_set" ? null : priority);
                                    <td class="@cellBgClass">
                                        <div class="priority-matrix-cell">
                                            <div class="d-flex justify-content-center align-items-center" style="min-height: 80px;">
                                                <span class="badge badge-light font-weight-bold priority-matrix-count">@cellIssues.Count</span>
                                            </div>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        @if (issues.Any())
        {
            <div id="issuesFilterCollapse" class="collapse" aria-labelledby="issuesFilterHeading">
                <div class="card-body border-bottom">
                    <form id="issuesFilterForm" class="row">
                        <div class="col-md-12 mb-4">
                            <label for="filterSearch" class="font-weight-bold">Search keyword</label>
                            <input type="text" 
                                   id="filterSearch" 
                                   class="form-control" 
                                   placeholder="Search in title or description..." 
                                   autocomplete="off" />
                        </div>
                        
                        <div class="col-md-6 mb-4">
                            <label class="font-weight-bold d-block mb-3">Severity</label>
                            <div class="row">
                                <div class="col-6 mb-2">
                                    <div class="form-check">
                                        <input class="form-check-input severity-filter" type="checkbox" value="critical" id="severityCritical" checked>
                                        <label class="form-check-label" for="severityCritical">
                                            <span class="badge priority-badge priority-badge--critical">Critical</span>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-6 mb-2">
                                    <div class="form-check">
                                        <input class="form-check-input severity-filter" type="checkbox" value="high" id="severityHigh" checked>
                                        <label class="form-check-label" for="severityHigh">
                                            <span class="badge priority-badge priority-badge--high">High</span>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-6 mb-2">
                                    <div class="form-check">
                                        <input class="form-check-input severity-filter" type="checkbox" value="medium" id="severityMedium" checked>
                                        <label class="form-check-label" for="severityMedium">
                                            <span class="badge priority-badge priority-badge--medium">Medium</span>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-6 mb-2">
                                    <div class="form-check">
                                        <input class="form-check-input severity-filter" type="checkbox" value="low" id="severityLow" checked>
                                        <label class="form-check-label" for="severityLow">
                                            <span class="badge priority-badge priority-badge--low">Low</span>
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-3 mb-4">
                            <label for="filterPriority" class="font-weight-bold">Priority</label>
                            <select id="filterPriority" class="form-control">
                                <option value="">All priorities</option>
                                @foreach (var priority in priorityOrder.Where(p => p != "not_set"))
                                {
                                    <option value="@priority">@FormatLabel(priority)</option>
                                }
                                <option value="not_set">Not set</option>
                            </select>
                        </div>
                        
                        <div class="col-md-3 mb-4">
                            <label for="filterStatus" class="font-weight-bold">Status</label>
                            <select id="filterStatus" class="form-control">
                                <option value="">All statuses</option>
                                <option value="not_started">Not Started</option>
                                <option value="open">Open</option>
                                <option value="in_progress">In Progress</option>
                                <option value="blocked">Blocked</option>
                                <option value="resolved">Resolved</option>
                                <option value="closed">Closed</option>
                            </select>
                        </div>
                        
                        <div class="col-md-12">
                            <button type="button" id="clearFilters" class="btn btn-outline-secondary btn-sm">Clear filters</button>
                        </div>
                    </form>
                </div>
            </div>
        }
        
        <div class="card-body table-responsive p-0">
            <table class="table table-hover text-nowrap sortable-table issues-table mb-0" id="issuesTable">
                <thead>
                    <tr>
                        <th class="col-title sortable" data-column="Title" tabindex="0" role="button" aria-label="Sort by Title">
                            Title
                            <i class="fas fa-sort sort-icon" aria-hidden="true"></i>
                        </th>
                        <th class="col-severity sortable" data-column="Severity" tabindex="0" role="button" aria-label="Sort by Severity">
                            Severity
                            <i class="fas fa-sort sort-icon" aria-hidden="true"></i>
                        </th>
                        <th class="col-priority sortable" data-column="Priority" tabindex="0" role="button" aria-label="Sort by Priority">
                            Priority
                            <i class="fas fa-sort sort-icon" aria-hidden="true"></i>
                        </th>
                        <th class="col-status sortable" data-column="Status" tabindex="0" role="button" aria-label="Sort by Status">
                            Status
                            <i class="fas fa-sort sort-icon" aria-hidden="true"></i>
                        </th>
                        <th class="col-detected sortable" data-column="Detected" tabindex="0" role="button" aria-label="Sort by Detected date">
                            Detected
                            <i class="fas fa-sort sort-icon" aria-hidden="true"></i>
                        </th>
                        <th class="col-target sortable" data-column="Target" tabindex="0" role="button" aria-label="Sort by Target resolution">
                            Target resolution
                            <i class="fas fa-sort sort-icon" aria-hidden="true"></i>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var issue in issues)
                    {
                        var detectedSort = issue.DetectedDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
                        var targetSort = issue.TargetResolutionDate?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
                        var isTargetOverdue = issue.TargetResolutionDate.HasValue && issue.TargetResolutionDate.Value.Date < DateTime.Today;
                        <tr data-severity="@(issue.Severity?.ToLowerInvariant() ?? "low")" 
                            data-priority="@(string.IsNullOrWhiteSpace(issue.Priority) ? "not_set" : issue.Priority.ToLowerInvariant())" 
                            data-status="@issue.Status.ToLowerInvariant()"
                            data-title="@issue.Title"
                            data-description="@(issue.Description ?? "")">
                            <td>
                                <a asp-controller="Issue" asp-action="Details" asp-route-id="@issue.Id">@issue.Title</a>
                            </td>
                            <td>
                                <span class="badge @ResolveSeverityClass(issue.Severity)">
                                    @FormatLabel(issue.Severity)
                                </span>
                            </td>
                            <td>
                                <span class="badge @ResolvePriorityBadgeClass(issue.Priority)">
                                    @FormatLabel(issue.Priority)
                                </span>
                            </td>
                            <td>
                                <span class="badge @ResolveStatusClass(issue.Status)">
                                    @issue.Status.Replace("_", " ")
                                </span>
                            </td>
                            <td data-sort-value="@detectedSort">@issue.DetectedDate.ToString("d MMMM yyyy")</td>
                            <td data-sort-value="@(targetSort ?? string.Empty)">
                                @if (issue.TargetResolutionDate.HasValue)
                                {
                                    <span class="@(isTargetOverdue ? "text-danger font-weight-semibold" : string.Empty)">
                                        @issue.TargetResolutionDate.Value.ToString("d MMMM yyyy")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    /* Background colors for priority matrix cells - matching priority badge colors but more vibrant */
    .priority-matrix-bg--critical {
        background-color: #f4d2d2 !important; /* Red - matches priority badge #d4351c */
        border: none !important;
    }
    
    .priority-matrix-bg--medium {
        background-color: #fde4d1 !important; /* Orange - matches priority badge #f47738 */
        border: none !important;
    }
    
    .priority-matrix-bg--low {
        background-color: #d4e8dd !important; /* Green - matches priority badge #00703c */
        border: none !important;
    }
    
    .priority-matrix-bg--default {
        background-color: #e5e5e5 !important; /* Grey - matches priority badge #6f777b */
        border: none !important;
    }
    
    /* Remove ALL borders from priority matrix table */
    .priority-matrix {
        border: none !important;
    }
    
    .priority-matrix th,
    .priority-matrix td {
        border: none !important;
    }
    
    .priority-matrix thead th {
        border: none !important;
    }
    
    .priority-matrix tbody th {
        border: none !important;
    }
    
    /* Make count badges bigger and centered */
    .priority-matrix-count {
        font-size: 2rem !important;
        padding: 0.5rem 1rem !important;
        min-width: 60px;
    }
    
    .priority-matrix-cell {
        padding: 1rem !important;
    }
    
    /* Filter section styling */
    .issues-filter-toggle {
        border: none;
        background: none;
        padding: 0;
        cursor: pointer;
    }
    
    .filter-chevron {
        transition: transform 0.3s ease;
        font-size: 0.75rem;
    }
    
    .issues-filter-toggle[aria-expanded="true"] .filter-chevron {
        transform: rotate(180deg);
    }
    
    /* Ensure checkboxes use default styling */
    .severity-filter {
        accent-color: #005ea5;
    }
</style>

@if (issuesView == "table" && issues.Any())
{
    <script nonce="@Context.Items["Nonce"]">
        (function() {
            var filterSearch = document.getElementById('filterSearch');
            var severityFilters = document.querySelectorAll('.severity-filter');
            var filterPriority = document.getElementById('filterPriority');
            var filterStatus = document.getElementById('filterStatus');
            var clearFiltersBtn = document.getElementById('clearFilters');
            var issuesTable = document.getElementById('issuesTable');
            var tableRows = issuesTable ? issuesTable.querySelectorAll('tbody tr') : [];

            function applyFilters() {
                var searchTerm = (filterSearch.value || '').toLowerCase();
                var selectedSeverities = Array.from(severityFilters)
                    .filter(cb => cb.checked)
                    .map(cb => cb.value.toLowerCase());
                var priorityFilter = (filterPriority.value || '').toLowerCase();
                var statusFilter = (filterStatus.value || '').toLowerCase();

                var visibleCount = 0;

                tableRows.forEach(function(row) {
                    var severity = (row.getAttribute('data-severity') || 'low').toLowerCase();
                    var priority = (row.getAttribute('data-priority') || 'not_set').toLowerCase();
                    var status = (row.getAttribute('data-status') || '').toLowerCase();
                    var title = (row.getAttribute('data-title') || '').toLowerCase();
                    var description = (row.getAttribute('data-description') || '').toLowerCase();

                    // Check severity filter
                    var severityMatch = selectedSeverities.length === 0 || selectedSeverities.includes(severity);

                    // Check priority filter
                    var priorityMatch = !priorityFilter || priority === priorityFilter;

                    // Check status filter
                    var statusMatch = !statusFilter || status === statusFilter;

                    // Check search filter
                    var searchMatch = !searchTerm || 
                        title.includes(searchTerm) || 
                        description.includes(searchTerm);

                    if (severityMatch && priorityMatch && statusMatch && searchMatch) {
                        row.style.display = '';
                        visibleCount++;
                    } else {
                        row.style.display = 'none';
                    }
                });

                // Show/hide "no results" message if needed
                var tbody = issuesTable.querySelector('tbody');
                var noResultsRow = tbody.querySelector('tr[data-no-results]');
                if (visibleCount === 0) {
                    if (!noResultsRow) {
                        noResultsRow = document.createElement('tr');
                        noResultsRow.setAttribute('data-no-results', 'true');
                        noResultsRow.innerHTML = '<td colspan="6" class="text-center text-muted py-4">No issues match the current filters.</td>';
                        tbody.appendChild(noResultsRow);
                    }
                    noResultsRow.style.display = '';
                } else if (noResultsRow) {
                    noResultsRow.style.display = 'none';
                }
            }

            // Attach event listeners
            if (filterSearch) {
                filterSearch.addEventListener('input', applyFilters);
            }

            severityFilters.forEach(function(checkbox) {
                checkbox.addEventListener('change', applyFilters);
            });

            if (filterPriority) {
                filterPriority.addEventListener('change', applyFilters);
            }

            if (filterStatus) {
                filterStatus.addEventListener('change', applyFilters);
            }

            if (clearFiltersBtn) {
                clearFiltersBtn.addEventListener('click', function() {
                    if (filterSearch) filterSearch.value = '';
                    severityFilters.forEach(function(cb) { cb.checked = true; });
                    if (filterPriority) filterPriority.value = '';
                    if (filterStatus) filterStatus.value = '';
                    applyFilters();
                });
            }

            // Update aria-expanded attribute for chevron rotation
            var filterCollapse = document.getElementById('issuesFilterCollapse');
            var filterButton = document.querySelector('[data-target="#issuesFilterCollapse"]');
            if (filterCollapse && filterButton) {
                filterCollapse.addEventListener('show.bs.collapse', function() {
                    filterButton.setAttribute('aria-expanded', 'true');
                });
                filterCollapse.addEventListener('hide.bs.collapse', function() {
                    filterButton.setAttribute('aria-expanded', 'false');
                });
            }
        })();
    </script>
}
