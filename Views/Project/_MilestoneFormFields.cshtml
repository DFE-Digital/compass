@model Compass.ViewModels.ProjectMilestoneFormViewModel

@{
    Func<string, bool> hasError = key =>
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return false;
        }

        if (ViewData.ModelState.TryGetValue(key, out var entry) && entry.Errors.Count > 0)
        {
            return true;
        }

        var inputKey = $"Input.{key}";
        if (ViewData.ModelState.TryGetValue(inputKey, out var inputEntry) && inputEntry.Errors.Count > 0)
        {
            return true;
        }

        return false;
    };
}

<div class="form-group @(hasError("Name") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.Name" class="font-weight-bold">Milestone name</label>
    <small class="form-text text-muted">Provide a clear, descriptive name for this milestone.</small>
    <span asp-validation-for="Input.Name" class="form-error-message"></span>
    <input asp-for="Input.Name" class="form-control @(hasError("Name") ? "form-control--error" : string.Empty)" maxlength="200" required />
</div>

<div class="form-group @(hasError("Status") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.Status">Status</label>
    <span asp-validation-for="Input.Status" class="form-error-message"></span>
    <select asp-for="Input.Status" class="form-control @(hasError("Status") ? "form-control--error" : string.Empty)" asp-items="Model.StatusOptions">
        <option value="">Select status</option>
    </select>
</div>

<div class="form-group @(hasError("Description") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.Description">Description</label>
    <span asp-validation-for="Input.Description" class="form-error-message"></span>
    <textarea asp-for="Input.Description" class="form-control @(hasError("Description") ? "form-control--error" : string.Empty)" rows="3"></textarea>
</div>

<div class="form-group @(hasError("DueDate") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.DueDate" class="font-weight-bold">Due date</label>
    <span asp-validation-for="Input.DueDate" class="form-error-message"></span>
    <input asp-for="Input.DueDate" type="date" class="form-control @(hasError("DueDate") ? "form-control--error" : string.Empty)" required />
</div>

<div class="form-group @(hasError("ActualDate") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.ActualDate">Actual completion date</label>
    <span asp-validation-for="Input.ActualDate" class="form-error-message"></span>
    <input asp-for="Input.ActualDate" type="date" class="form-control @(hasError("ActualDate") ? "form-control--error" : string.Empty)" />
</div>

<div class="form-group @(hasError("ProgressPercent") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.ProgressPercent">Progress (%)</label>
    <span asp-validation-for="Input.ProgressPercent" class="form-error-message"></span>
    <input asp-for="Input.ProgressPercent" type="number" class="form-control @(hasError("ProgressPercent") ? "form-control--error" : string.Empty)" min="0" max="100" />
</div>

<div class="form-group @(hasError("ObjectiveId") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.ObjectiveId">Linked objective (optional)</label>
    <span asp-validation-for="Input.ObjectiveId" class="form-error-message"></span>
    <select asp-for="Input.ObjectiveId" class="form-control @(hasError("ObjectiveId") ? "form-control--error" : string.Empty)" asp-items="Model.ObjectiveOptions">
        <option value="">Not linked</option>
    </select>
</div>

<div class="form-group @(hasError("Notes") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.Notes">Notes</label>
    <span asp-validation-for="Input.Notes" class="form-error-message"></span>
    <textarea asp-for="Input.Notes" class="form-control @(hasError("Notes") ? "form-control--error" : string.Empty)" rows="2"></textarea>
</div>
