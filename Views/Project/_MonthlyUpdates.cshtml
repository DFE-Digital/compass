@model Compass.Models.Project
@inject Compass.Services.IMonthlyUpdateService MonthlyUpdateService

@{
    var monthlyUpdates = Model.MonthlyUpdates.OrderByDescending(u => u.Year).ThenByDescending(u => u.Month).ToList();
    
    // Generate periods starting from November 2025
    var startDate = new DateTime(2025, 11, 1);
    var currentDate = DateTime.UtcNow;
    var periods = new List<dynamic>();
    
    var periodDate = startDate;
    while (periodDate <= currentDate.AddMonths(1))
    {
        var year = periodDate.Year;
        var month = periodDate.Month;
        var dueDate = MonthlyUpdateService.GetMonthlyUpdateDueDate(year, month);
        var update = monthlyUpdates.FirstOrDefault(u => u.Year == year && u.Month == month);
        var status = MonthlyUpdateService.CalculateUpdateStatus(year, month, update?.SubmittedAt);
        
        periods.Add(new {
            Year = year,
            Month = month,
            PeriodName = periodDate.ToString("MMMM yyyy"),
            DueDate = dueDate,
            Status = status.ToString(),
            Update = update
        });
        
        periodDate = periodDate.AddMonths(1);
    }
    
    // Group periods by status and sort by date (latest first)
    var dueOrLate = periods
        .Where(p => p.Status == "Due" || p.Status == "Late")
        .OrderByDescending(p => p.Year)
        .ThenByDescending(p => p.Month)
        .ToList();
    
    var upcoming = periods
        .Where(p => p.Status == "Upcoming")
        .OrderByDescending(p => p.Year)
        .ThenByDescending(p => p.Month)
        .ToList();
    
    var completed = periods
        .Where(p => p.Status == "Submitted")
        .OrderByDescending(p => p.Year)
        .ThenByDescending(p => p.Month)
        .ToList();
}

<div class="row">
    <div class="col-12">
        <!-- Due or Late Updates Card -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Due or Late Updates</h3>
            </div>
            <div class="card-body p-0">
                @if (dueOrLate.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 35%;">Period</th>
                                    <th style="width: 20%;">Due Date</th>
                                    <th style="width: 15%;">Status</th>
                                    <th style="width: 30%;">Updates</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var period in dueOrLate)
                                {
                                    <tr>
                                        <td>
                                            @if (period.Update != null)
                                            {
                                                <a href="@Url.Action("EditUpdate", "MilestonesUpdatesSuccesses", new { projectId = Model.Id, year = period.Year, month = period.Month })">@period.PeriodName</a>
                                            }
                                            else
                                            {
                                                <a href="@Url.Action("CreateUpdate", "MilestonesUpdatesSuccesses", new { projectId = Model.Id, year = period.Year, month = period.Month })">@period.PeriodName</a>
                                            }
                                        </td>
                                        <td>@period.DueDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @if (period.Status == "Late")
                                            {
                                                <span class="badge badge-danger">Late</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-warning">Due</span>
                                            }
                                        </td>
                                        <td>
                                            @{
                                                var narrativeCount = period.Update?.MonthlyUpdateNarratives?.Count ?? 0;
                                            }
                                            @narrativeCount
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0 p-3">No due or late updates.</p>
                }
            </div>
        </div>

        <!-- Upcoming Updates Card -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Upcoming Updates</h3>
            </div>
            <div class="card-body p-0">
                @if (upcoming.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 35%;">Period</th>
                                    <th style="width: 20%;">Due Date</th>
                                    <th style="width: 15%;">Status</th>
                                    <th style="width: 30%;">Updates</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var period in upcoming)
                                {
                                    <tr>
                                        <td>
                                            @if (period.Update != null)
                                            {
                                                <a href="@Url.Action("EditUpdate", "MilestonesUpdatesSuccesses", new { projectId = Model.Id, year = period.Year, month = period.Month })">@period.PeriodName</a>
                                            }
                                            else
                                            {
                                                <a href="@Url.Action("CreateUpdate", "MilestonesUpdatesSuccesses", new { projectId = Model.Id, year = period.Year, month = period.Month })">@period.PeriodName</a>
                                            }
                                        </td>
                                        <td>@period.DueDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            <span class="badge badge-secondary">Upcoming</span>
                                        </td>
                                        <td>
                                            @{
                                                var narrativeCount = period.Update?.MonthlyUpdateNarratives?.Count ?? 0;
                                            }
                                            @narrativeCount
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0 p-3">No upcoming updates.</p>
                }
            </div>
        </div>

        <!-- Completed Updates Card -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Completed Updates</h3>
            </div>
            <div class="card-body p-0">
                @if (completed.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 25%;">Period</th>
                                    <th style="width: 15%;">Due Date</th>
                                    <th style="width: 12%;">Status</th>
                                    <th style="width: 18%;">Submitted</th>
                                    <th style="width: 30%;">Updates</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var period in completed)
                                {
                                    <tr>
                                        <td>
                                            @if (period.Update != null)
                                            {
                                                <a href="@Url.Action("EditUpdate", "MilestonesUpdatesSuccesses", new { projectId = Model.Id, year = period.Year, month = period.Month })">@period.PeriodName</a>
                                            }
                                            else
                                            {
                                                <a href="@Url.Action("CreateUpdate", "MilestonesUpdatesSuccesses", new { projectId = Model.Id, year = period.Year, month = period.Month })">@period.PeriodName</a>
                                            }
                                        </td>
                                        <td>@period.DueDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            <span class="badge badge-success">Complete</span>
                                        </td>
                                        <td>
                                            @if (period.Update != null)
                                            {
                                                var update = (Compass.Models.ProjectMonthlyUpdate)period.Update;
                                                @if (update.SubmittedAt.HasValue)
                                                {
                                                    @update.SubmittedAt.Value.ToString("dd MMM yyyy")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            @{
                                                var narrativeCount = period.Update?.MonthlyUpdateNarratives?.Count ?? 0;
                                            }
                                            @narrativeCount
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0 p-3">No completed updates.</p>
                }
            </div>
        </div>
    </div>
</div>

