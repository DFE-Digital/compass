@model Compass.Models.Project
@inject Compass.Services.IMonthlyUpdateService MonthlyUpdateService

@{
    var monthlyUpdates = Model.MonthlyUpdates.OrderByDescending(u => u.Year).ThenByDescending(u => u.Month).ToList();
    
    // Generate periods starting from November 2025
    var startDate = new DateTime(2025, 11, 1);
    var currentDate = DateTime.UtcNow;
    var periods = new List<dynamic>();
    
    var periodDate = startDate;
    while (periodDate <= currentDate.AddMonths(1))
    {
        var year = periodDate.Year;
        var month = periodDate.Month;
        var dueDate = MonthlyUpdateService.GetMonthlyUpdateDueDate(year, month);
        var update = monthlyUpdates.FirstOrDefault(u => u.Year == year && u.Month == month);
        var status = MonthlyUpdateService.CalculateUpdateStatus(year, month, update?.SubmittedAt);
        
        periods.Add(new {
            Year = year,
            Month = month,
            PeriodName = periodDate.ToString("MMMM yyyy"),
            DueDate = dueDate,
            Status = status.ToString(),
            Update = update
        });
        
        periodDate = periodDate.AddMonths(1);
    }
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Monthly Updates</h3>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover text-nowrap sortable-table mb-0">
                        <thead>
                            <tr>
                                <th class="sortable" data-column="Period" tabindex="0" role="button" aria-label="Sort by Period">
                                    Period
                                    <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                                </th>
                                <th class="sortable" data-column="DueDate" tabindex="0" role="button" aria-label="Sort by Due Date">
                                    Due Date
                                    <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                                </th>
                                <th class="sortable" data-column="Status" tabindex="0" role="button" aria-label="Sort by Status">
                                    Status
                                    <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                                </th>
                                <th class="sortable" data-column="SubmittedDate" tabindex="0" role="button" aria-label="Sort by Submitted Date">
                                    Submitted
                                    <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                                </th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var period in periods)
                            {
                                <tr>
                                    <td>@period.PeriodName</td>
                                    <td>@period.DueDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if (period.Status == "Submitted")
                                        {
                                            <span class="badge badge-success">Complete</span>
                                        }
                                        else if (period.Status == "Late")
                                        {
                                            <span class="badge badge-danger">Late</span>
                                        }
                                        else if (period.Status == "Due")
                                        {
                                            <span class="badge badge-warning">Due</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-secondary">Upcoming</span>
                                        }
                                    </td>
                                    <td>
                                        @if (period.Update?.SubmittedAt.HasValue == true)
                                        {
                                            @period.Update.SubmittedAt.Value.ToString("dd MMM yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (period.Update != null)
                                        {
                                            <a href="@Url.Action("EditUpdate", "MilestonesUpdatesSuccesses", new { projectId = Model.Id, year = period.Year, month = period.Month })" class="btn btn-sm btn-primary">Edit</a>
                                        }
                                        else
                                        {
                                            <a href="@Url.Action("CreateUpdate", "MilestonesUpdatesSuccesses", new { projectId = Model.Id, year = period.Year, month = period.Month })" class="btn btn-sm btn-success">Add Update</a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
    (function() {
        var table = document.querySelector('.sortable-table');
        if (!table) return;
        
        function initSorting(table) {
            var sortableHeaders = table.querySelectorAll('.sortable');
            var currentSort = { column: null, direction: 'asc' };
            
            sortableHeaders.forEach(function(header) {
                header.style.cursor = 'pointer';
                
                header.addEventListener('click', function(e) {
                    handleSort(e, header);
                });
                
                header.addEventListener('keypress', function(e) {
                    if (e.which === 13 || e.which === 32) {
                        e.preventDefault();
                        handleSort(e, header);
                    }
                });
            });
            
            function handleSort(e, header) {
                var column = header.getAttribute('data-column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(column, direction);
                currentSort = { column: column, direction: direction };
            }
            
            function sortTable(column, direction) {
                var tbody = table.querySelector('tbody');
                var rows = Array.from(tbody.querySelectorAll('tr'));
                var colIndex = Array.from(table.querySelectorAll('thead th')).findIndex(function(th) {
                    return th.getAttribute('data-column') === column;
                });
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var aCell = a.querySelectorAll('td')[colIndex];
                    var bCell = b.querySelectorAll('td')[colIndex];
                    
                    if (column === 'DueDate' || column === 'SubmittedDate') {
                        var aDate = Date.parse(aCell.textContent.trim());
                        var bDate = Date.parse(bCell.textContent.trim());
                        aVal = isNaN(aDate) ? 0 : aDate;
                        bVal = isNaN(bDate) ? 0 : bDate;
                    } else {
                        aVal = aCell.textContent.trim().toLowerCase();
                        bVal = bCell.textContent.trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.innerHTML = '';
                rows.forEach(function(row) {
                    tbody.appendChild(row);
                });
                
                updateSortIcons(column, direction);
            }
            
            function updateSortIcons(column, direction) {
                var allHeaders = table.querySelectorAll('.sortable i');
                allHeaders.forEach(function(icon) {
                    icon.className = 'fas fa-sort float-right';
                    icon.style.opacity = '0.3';
                });
                
                var activeHeader = table.querySelector('.sortable[data-column="' + column + '"]');
                if (activeHeader) {
                    var icon = activeHeader.querySelector('i');
                    if (icon) {
                        icon.className = direction === 'asc' ? 'fas fa-sort-up float-right' : 'fas fa-sort-down float-right';
                        icon.style.opacity = '1';
                    }
                }
            }
        }
        
        initSorting(table);
    })();
</script>

