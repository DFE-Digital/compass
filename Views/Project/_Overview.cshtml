@functions {
    string GetRagBadgeClass(string ragStatus)
    {
        if (string.IsNullOrWhiteSpace(ragStatus))
        {
            return "badge badge-secondary";
        }
        
        // Normalize the status - handle both "Amber-Green" and "Amber/Green" formats
        var normalized = ragStatus.Trim()
            .Replace(" / ", "-")
            .Replace("/", "-")
            .Replace(" /", "-")
            .Replace("/ ", "-");
        
        return normalized switch
        {
            "Green" => "badge badge-green",
            "Amber-Green" => "badge badge-amber-green",
            "Amber" => "badge badge-amber",
            "Amber-Red" => "badge badge-amber-red",
            "Red" => "badge badge-red",
            _ => "badge badge-secondary"
        };
    }

    string GetRagCardClass(string ragStatus)
    {
        if (string.IsNullOrWhiteSpace(ragStatus))
        {
            return "rag-card-default";
        }
        
        // Normalize the status - handle both "Amber-Green" and "Amber/Green" formats
        var normalized = ragStatus.Trim()
            .Replace(" / ", "-")
            .Replace("/", "-")
            .Replace(" /", "-")
            .Replace("/ ", "-");
        
        return normalized switch
        {
            "Green" => "rag-card-green",
            "Amber-Green" => "rag-card-amber-green",
            "Amber" => "rag-card-amber",
            "Amber-Red" => "rag-card-amber-red",
            "Red" => "rag-card-red",
            _ => "rag-card-default"
        };
    }

    string FormatRagStatusText(string ragStatus)
    {
        if (string.IsNullOrWhiteSpace(ragStatus))
        {
            return ragStatus;
        }

        return ragStatus switch
        {
            "Amber-Green" => "Amber / Green",
            "Amber-Red" => "Amber / Red",
            _ => ragStatus
        };
    }

    string GetRiskAppetiteBadgeClass(string riskAppetite)
    {
        if (string.IsNullOrEmpty(riskAppetite))
            return "badge-secondary";
            
        var normalized = riskAppetite.Trim().ToLowerInvariant();
        
        return normalized switch
        {
            "averse" => "badge-danger",
            "minimal" => "badge-danger",
            "cautious" => "badge-warning",
            "open" => "badge-success",
            "eager" => "badge-success",
            _ => "badge-secondary"
        };
    }
}

<script nonce="@Context.Items["Nonce"]">
    (function() {
        function initOverviewPage() {
            // Set progress bar width from data attribute
            $('.milestone-progress').each(function() {
                var progress = $(this).attr('data-progress');
                if (progress) {
                    $(this).css('width', progress + '%');
                }
            });

            // Handle delete milestone button from view modal
            $('#deleteMilestoneFromViewBtn').on('click', function() {
                var milestoneId = $('#editMilestoneId').val();
                $('#viewMilestoneModal').modal('hide');
                $('#deleteMilestoneId').val(milestoneId);
                $('#deleteMilestoneModal').modal('show');
            });

            // Handle status change to show/hide reason field
            $('#statusInputOverview').on('change', function() {
                toggleStatusReasonField();
            });

            // Function to toggle status reason field visibility and required attribute
            function toggleStatusReasonField() {
                var status = $('#statusInputOverview').val();
                var $reasonGroup = $('#statusReasonGroupOverview');
                var $reasonField = $('#statusChangeReasonOverview');
                
                if (status === 'Paused' || status === 'Completed' || status === 'Cancelled') {
                    $reasonGroup.show();
                    $reasonField.prop('required', true);
                } else {
                    $reasonGroup.hide();
                    $reasonField.prop('required', false);
                    $reasonField.val('');
                }
            }

            // Initialize status reason field when modal opens
            $('#editStatusModal').on('show.bs.modal', function() {
                $('#statusChangeReasonOverview').val('');
                toggleStatusReasonField();
            });

            // Validate form before submission
            $('#statusFormOverview').on('submit', function(e) {
                var status = $('#statusInputOverview').val();
                var reason = $('#statusChangeReasonOverview').val().trim();
                
                if ((status === 'Paused' || status === 'Completed' || status === 'Cancelled') && !reason) {
                    e.preventDefault();
                    alert('Please provide a reason for changing the status.');
                    return false;
                }
            });

            // Service type form - ensure unchecked checkboxes send empty value
            $('#serviceTypeForm').on('submit', function(e) {
                // For unchecked checkboxes, add a hidden input with empty value so the controller knows it was unchecked
                if (!$('#isInternalOverview').is(':checked')) {
                    $(this).append('<input type="hidden" name="isInternal" value="" />');
                }
                if (!$('#isExternalOverview').is(':checked')) {
                    $(this).append('<input type="hidden" name="isExternal" value="" />');
                }
            });
            
            // Initialize sorting for Active milestones table
            function initMilestonesTableSorting() {
                var table = document.querySelector('.milestones-table');
                if (!table) return;
                
                var currentSort = { column: null, direction: 'asc' };
                var sortableHeaders = table.querySelectorAll('.sortable');
                
                sortableHeaders.forEach(function(header) {
                    header.style.cursor = 'pointer';
                    
                    header.addEventListener('click', function(e) {
                        handleSort(e, header);
                    });
                    
                    header.addEventListener('keypress', function(e) {
                        if (e.which === 13 || e.which === 32) {
                            e.preventDefault();
                            handleSort(e, header);
                        }
                    });
                });
                
                function handleSort(e, header) {
                    var column = header.getAttribute('data-column');
                    var direction = 'asc';
                    
                    if (currentSort.column === column && currentSort.direction === 'asc') {
                        direction = 'desc';
                    }
                    
                    sortTable(column, direction);
                    currentSort = { column: column, direction: direction };
                }
                
                function sortTable(column, direction) {
                    var tbody = table.querySelector('tbody');
                    var rows = Array.from(tbody.querySelectorAll('tr'));
                    var colIndex = Array.from(table.querySelectorAll('thead th')).findIndex(function(th) {
                        return th.getAttribute('data-column') === column;
                    });
                    
                    rows.sort(function(a, b) {
                        var aVal, bVal;
                        var aCell = a.querySelectorAll('td')[colIndex];
                        var bCell = b.querySelectorAll('td')[colIndex];
                        
                        if (column === 'Status') {
                            var aBadge = aCell.querySelector('.badge');
                            var bBadge = bCell.querySelector('.badge');
                            aVal = aBadge ? aBadge.textContent.trim().toLowerCase() : '';
                            bVal = bBadge ? bBadge.textContent.trim().toLowerCase() : '';
                        } else if (column === 'Name') {
                            var aLink = aCell.querySelector('a');
                            var bLink = bCell.querySelector('a');
                            aVal = aLink ? aLink.textContent.trim().toLowerCase() : aCell.textContent.trim().toLowerCase();
                            bVal = bLink ? bLink.textContent.trim().toLowerCase() : bCell.textContent.trim().toLowerCase();
                        } else if (column === 'DueDate' || column === 'ActualDate') {
                            var aDate = Date.parse(aCell.textContent.trim());
                            var bDate = Date.parse(bCell.textContent.trim());
                            aVal = isNaN(aDate) ? 0 : aDate;
                            bVal = isNaN(bDate) ? 0 : bDate;
                        } else if (column === 'Progress') {
                            var aText = aCell.textContent.trim();
                            var bText = bCell.textContent.trim();
                            var aMatch = aText.match(/(\d+)%/);
                            var bMatch = bText.match(/(\d+)%/);
                            aVal = aMatch ? parseInt(aMatch[1]) : 0;
                            bVal = bMatch ? parseInt(bMatch[1]) : 0;
                        } else {
                            aVal = aCell.textContent.trim().toLowerCase();
                            bVal = bCell.textContent.trim().toLowerCase();
                        }
                        
                        if (direction === 'asc') {
                            return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                        } else {
                            return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                        }
                    });
                    
                    tbody.innerHTML = '';
                    rows.forEach(function(row) {
                        tbody.appendChild(row);
                    });
                    
                    updateSortIcons(column, direction);
                }
                
                function updateSortIcons(column, direction) {
                    var allHeaders = table.querySelectorAll('.sortable i');
                    allHeaders.forEach(function(icon) {
                        icon.className = 'fas fa-sort float-right';
                        icon.style.opacity = '0.3';
                    });
                    
                    var activeHeader = table.querySelector('.sortable[data-column="' + column + '"]');
                    if (activeHeader) {
                        var icon = activeHeader.querySelector('i');
                        if (icon) {
                            icon.className = direction === 'asc' ? 'fas fa-sort-up float-right' : 'fas fa-sort-down float-right';
                            icon.style.opacity = '1';
                        }
                    }
                }
            }
            
