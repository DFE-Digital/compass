                <h5 class="modal-title" id="editSpendControlModalLabel">Edit subject to spend control</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateSubjectToSpendControl" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="modal-body">
                    <div class="form-group">
                        <label>Subject to spend control</label>
                        <div>
                            <div class="form-check">
                                <input type="radio" class="form-check-input" id="spendControlYes" name="isSubjectToSpendControl" value="true" @(Model.IsSubjectToSpendControl == true ? "checked" : "") />
                                <label class="form-check-label" for="spendControlYes">Yes</label>
                            </div>
                            <div class="form-check">
                                <input type="radio" class="form-check-input" id="spendControlNo" name="isSubjectToSpendControl" value="false" @(Model.IsSubjectToSpendControl == false ? "checked" : "") />
                                <label class="form-check-label" for="spendControlNo">No</label>
                            </div>
                            <div class="form-check">
                                <input type="radio" class="form-check-input" id="spendControlNotSet" name="isSubjectToSpendControl" value="" @(!Model.IsSubjectToSpendControl.HasValue ? "checked" : "") />
                                <label class="form-check-label" for="spendControlNotSet">Not set</label>
                            </div>
                        </div>
                        <small class="form-text text-muted">Indicate whether this project is subject to spend control</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@functions {
    string GetRagBadgeClass(string ragStatus)
    {
        return ragStatus switch
        {
            "Green" => "badge badge-green",
            "Amber-Green" => "badge badge-amber-green",
            "Amber" => "badge badge-amber",
            "Amber-Red" => "badge badge-amber-red",
            "Red" => "badge badge-red",
            _ => "badge badge-secondary"
        };
    }

    string GetRagCardClass(string ragStatus)
    {
        return ragStatus switch
        {
            "Green" => "rag-card-green",
            "Amber-Green" => "rag-card-amber-green",
            "Amber" => "rag-card-amber",
            "Amber-Red" => "rag-card-amber-red",
            "Red" => "rag-card-red",
            _ => "rag-card-default"
        };
    }

    string GetRiskAppetiteBadgeClass(string riskAppetite)
    {
        if (string.IsNullOrEmpty(riskAppetite))
            return "badge-secondary";
            
        var normalized = riskAppetite.Trim().ToLowerInvariant();
        
        return normalized switch
        {
            "averse" => "badge-danger",
            "minimal" => "badge-danger",
            "cautious" => "badge-warning",
            "open" => "badge-success",
            "eager" => "badge-success",
            _ => "badge-secondary"
        };
    }
}

<script nonce="@Context.Items["Nonce"]">
    (function() {
        function initOverviewPage() {
            // Handle delete milestone button from view modal
            $('#deleteMilestoneFromViewBtn').on('click', function() {
                var milestoneId = $('#editMilestoneId').val();
                $('#viewMilestoneModal').modal('hide');
                $('#deleteMilestoneId').val(milestoneId);
                $('#deleteMilestoneModal').modal('show');
            });

            // Handle status change to show/hide reason field
            $('#statusInputOverview').on('change', function() {
                toggleStatusReasonField();
            });

            // Function to toggle status reason field visibility and required attribute
            function toggleStatusReasonField() {
                var status = $('#statusInputOverview').val();
                var $reasonGroup = $('#statusReasonGroupOverview');
                var $reasonField = $('#statusChangeReasonOverview');
                
                if (status === 'Paused' || status === 'Completed' || status === 'Cancelled') {
                    $reasonGroup.show();
                    $reasonField.prop('required', true);
                } else {
                    $reasonGroup.hide();
                    $reasonField.prop('required', false);
                    $reasonField.val('');
                }
            }

            // Initialize status reason field when modal opens
            $('#editStatusModal').on('show.bs.modal', function() {
                $('#statusChangeReasonOverview').val('');
                toggleStatusReasonField();
            });

            const prioritySelect = document.getElementById('deliveryPrioritySelection');
            const priorityReasonGroup = document.getElementById('priorityReasonGroup');
            const priorityReasonField = document.getElementById('priorityChangeReason');
            const initialPriority = prioritySelect?.dataset.currentPriority ?? '';

            const togglePriorityReasonField = () => {
                if (!prioritySelect || !priorityReasonGroup || !priorityReasonField) {
                    return;
                }
                const hasChanged = (prioritySelect.value || '') !== (initialPriority || '');
                if (hasChanged) {
                    priorityReasonGroup.style.display = 'block';
                    priorityReasonField.required = true;
                } else {
                    priorityReasonGroup.style.display = 'none';
                    priorityReasonField.required = false;
                    priorityReasonField.value = '';
                }
            };

            prioritySelect?.addEventListener('change', togglePriorityReasonField);

            $('#editDeliveryPriorityModal').on('show.bs.modal', function () {
                if (priorityReasonField) {
                    priorityReasonField.value = '';
                }
                togglePriorityReasonField();
            });

            // Validate form before submission
            $('#statusFormOverview').on('submit', function(e) {
                var status = $('#statusInputOverview').val();
                var reason = $('#statusChangeReasonOverview').val().trim();
                
                if ((status === 'Paused' || status === 'Completed' || status === 'Cancelled') && !reason) {
                    e.preventDefault();
                    alert('Please provide a reason for changing the status.');
                    return false;
                }
            });

            // Service type form - ensure unchecked checkboxes send empty value
            $('#serviceTypeForm').on('submit', function(e) {
                // For unchecked checkboxes, add a hidden input with empty value so the controller knows it was unchecked
                if (!$('#isInternalOverview').is(':checked')) {
                    $(this).append('<input type="hidden" name="isInternal" value="" />');
                }
                if (!$('#isExternalOverview').is(':checked')) {
                    $(this).append('<input type="hidden" name="isExternal" value="" />');
                }
            });
        }

        if (typeof jQuery !== 'undefined') {
            $(document).ready(initOverviewPage);
        } else {
            document.addEventListener('DOMContentLoaded', function() {
                if (typeof jQuery !== 'undefined') {
                    $(document).ready(initOverviewPage);
                }
            });
        }
    })();
</script>
