@model Compass.Models.Project
@using System.Linq

@{
    var totalOutcomes = Model.Outcomes.Count;
    var totalMilestones = Model.Milestones.Count;
    var completedMilestones = Model.Milestones.Count(m => m.Status == "complete");
    
    // Flagship project deliverables
    var deliverableProjects = ViewBag.DeliverableProjects as List<Compass.Models.Project> ?? new List<Compass.Models.Project>();
    var totalPermFte = (Model.TotalPermFte ?? 0) + deliverableProjects.Sum(p => p.TotalPermFte ?? 0);
    var totalMspFte = (Model.TotalMspFte ?? 0) + deliverableProjects.Sum(p => p.TotalMspFte ?? 0);
    var totalFte = totalPermFte + totalMspFte;
    var deliveryCode = $"DEL-DDT-{Model.Id}";
    var deliveryPriorityOptions = ViewBag.DeliveryPriorities as IEnumerable<Compass.Models.DeliveryPriority> ?? Enumerable.Empty<Compass.Models.DeliveryPriority>();
}

<div class="row">
    <!-- Left Column -->
    <div class="col-lg-8">
        <!-- Project Aim -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Project Aim</h3>
                <div class="card-tools">
                    <a href="#" data-toggle="modal" data-target="#editAimModal">Change</a>
                </div>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.Aim))
                {
                    <p class="mb-0">@Model.Aim</p>
                }
                else
                {
                    <p class="text-muted mb-0">No aim specified</p>
                }
            </div>
        </div>

        <!-- Project Summary -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Project Summary</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-borderless mb-0 project-overview-summary">
                    <tbody>
                        <tr>
                            <td class="summary-label"><strong>Delivery code</strong></td>
                            <td class="summary-value">
                                @deliveryCode
                                @if (!string.IsNullOrEmpty(Model.HistoricBuRTId))
                                {
                                    <div class="text-muted small">BuRT: @Model.HistoricBuRTId</div>
                                }
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editBuRTIdModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Business Area</strong></td>
                            <td class="summary-value">
                                @if (!string.IsNullOrEmpty(Model.BusinessArea))
                                {
                                    @Model.BusinessArea
                                }
                                else
                                {
                                    <span class="text-muted">Not specified</span>
                                }
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editBusinessAreaModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Phase</strong></td>
                            <td class="summary-value">
                                @if (!string.IsNullOrEmpty(Model.Phase))
                                {
                                    @Model.Phase
                                }
                                else
                                {
                                    <span class="text-muted">Not specified</span>
                                }
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editPhaseModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Status</strong></td>
                            <td class="summary-value">
                                <span class="badge badge-@(Model.Status == "Active" ? "success" : Model.Status == "Paused" ? "warning" : Model.Status == "Completed" ? "info" : "secondary")">@Model.Status</span>
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editStatusModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Primary contact</strong></td>
                            <td class="summary-value">
                                @if (Model.PrimaryContactUser != null)
                                {
                                    <div>
                                        <strong>@Model.PrimaryContactUser.Name</strong><br />
                                        <span class="text-muted">@Model.PrimaryContactUser.Email</span>
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editPrimaryContactModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Priority</strong></td>
                            <td class="summary-value">
                                @if (Model.DeliveryPriority != null)
                                {
                                    <span class="badge badge-secondary">@Model.DeliveryPriority.Name</span>
                                    if (!string.IsNullOrWhiteSpace(Model.DeliveryPriority.Summary))
                                    {
                                        <div class="text-muted small mt-1">@Model.DeliveryPriority.Summary</div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editDeliveryPriorityModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>RAG Status</strong></td>
                            <td class="summary-value">
                                @if (!string.IsNullOrEmpty(Model.RagStatus))
                                {
                                <span class="@GetRagBadgeClass(Model.RagStatus)">@Model.RagStatus</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Not set</span>
                                }
                            </td>
                            <td class="text-right">
                                <a asp-action="Details" asp-route-id="@Model.Id" asp-route-tab="rag">View</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Flagship</strong></td>
                            <td class="summary-value">
                                @if (Model.IsFlagship)
                                {
                                    <span class="badge badge-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">No</span>
                                }
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editFlagshipModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Start Date</strong></td>
                            <td class="summary-value">
                                @if (Model.StartDate.HasValue && Model.StartDate.Value.Year > 1)
                                {
                                    @Model.StartDate.Value.ToString("d MMMM yyyy")
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editStartDateModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Target End Date</strong></td>
                            <td class="summary-value">
                                @if (Model.TargetDeliveryDate.HasValue && Model.TargetDeliveryDate.Value.Year > 1)
                                {
                                    @Model.TargetDeliveryDate.Value.ToString("d MMMM yyyy")
                                }
                                else
                                {
                                    <span class="text-muted">No end date</span>
                                }
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editTargetDateModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Outcomes</strong></td>
                            <td class="summary-value">@totalOutcomes defined</td>
                            <td class="text-right">
                                <a asp-action="Details" asp-route-id="@Model.Id" asp-route-tab="outcomes">View</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Milestones</strong></td>
                            <td class="summary-value">@completedMilestones of @totalMilestones completed</td>
                            <td class="text-right">
                                <a asp-action="Details" asp-route-id="@Model.Id" asp-route-tab="milestones">View</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.IsFlagship)
        {
            <!-- Flagship Project Deliverables -->
            <div class="card mb-4">
                <div class="card-header">
                    <h3 class="card-title">Flagship Project Deliverables</h3>
                    <div class="card-tools">
                        <a href="@Url.Action("Details", new { id = Model.Id, tab = "deliverables" })">Manage deliverables</a>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (deliverableProjects.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>RAG Status</th>
                                        <th>Phase</th>
                                        <th>Business Area</th>
                                        <th>Milestones</th>
                                        <th>FTE</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var project in deliverableProjects.OrderBy(p => p.Title))
                                    {
                                        var projectMilestoneCount = project.Milestones?.Count(m => !m.IsDeleted) ?? 0;
                                        var projectCompletedMilestones = project.Milestones?.Count(m => !m.IsDeleted && m.Status == "complete") ?? 0;
                                        var projectFte = (project.TotalPermFte ?? 0) + (project.TotalMspFte ?? 0);
                                        
                                        <tr>
                                            <td>
                                                <a href="@Url.Action("Details", "Project", new { id = project.Id })">
                                                    <strong>@project.Title</strong>
                                                </a><br>
                                                <small class="text-muted">DEL-DDT-@project.Id</small>
                                                @if (!string.IsNullOrWhiteSpace(project.ProjectCode))
                                                {
                                                    <div class="text-muted small">Legacy code: @project.ProjectCode</div>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(project.RagStatus))
                                                {
                                                    <span class="@GetRagBadgeClass(project.RagStatus)">@project.RagStatus</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-secondary">Not set</span>
                                                }
                                            </td>
                                            <td>@(project.Phase ?? "Not set")</td>
                                            <td>@(project.BusinessArea ?? "Not set")</td>
                                            <td>
                                                @if (projectMilestoneCount > 0)
                                                {
                                                    <span>@projectCompletedMilestones / @projectMilestoneCount</span>
                                                    <div class="progress" style="height: 4px;">
                                                        <div class="progress-bar bg-success" role="progressbar" 
                                                             style="width: @((projectCompletedMilestones * 100.0 / projectMilestoneCount).ToString("F0"))%" 
                                                             aria-valuenow="@projectCompletedMilestones" 
                                                             aria-valuemin="0" 
                                                             aria-valuemax="@projectMilestoneCount"></div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">0</span>
                                                }
                                            </td>
                                            <td>@projectFte.ToString("F1")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center p-3">
                            <p class="text-muted mb-2">No deliverables have been added yet.</p>
                            <a href="@Url.Action("Details", new { id = Model.Id, tab = "deliverables" })" class="btn btn-sm btn-primary">
                                <i class="fas fa-plus"></i> Add Deliverables
                            </a>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Project Milestones -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Recent Milestones</h3>
                <div class="card-tools">
                    <a asp-controller="Project" asp-action="CreateMilestone" asp-route-projectId="@Model.Id">Add milestone</a>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                @if (Model.Milestones.Any())
                {
                    <table class="table table-hover text-nowrap milestones-table">
                        <thead>
                            <tr>
                                <th class="col-name">Name</th>
                                <th class="col-status">Status</th>
                                <th class="col-due">Due Date</th>
                                <th class="col-actual">Actual Date</th>
                                <th class="col-progress">Progress</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var milestone in Model.Milestones.OrderBy(m => m.DueDate).Take(5))
                            {
                                <tr>
                                    <td>
                                        <a href="#" 
                                           class="view-milestone-link"
                                           data-milestone-id="@milestone.Id"
                                           data-milestone-name="@milestone.Name"
                                           data-milestone-status="@milestone.Status"
                                           data-milestone-progress="@(milestone.ProgressPercent ?? 0)"
                                           data-milestone-due="@milestone.DueDate.ToString("yyyy-MM-dd")"
                                           data-milestone-actual="@(milestone.ActualDate?.ToString("yyyy-MM-dd") ?? "")"
                                           data-milestone-description="@milestone.Description">
                                            @milestone.Name
                                        </a>
                                    </td>
                                    <td>
                                        <span class="badge badge-@(milestone.Status == "complete" ? "success" : milestone.Status == "at_risk" ? "warning" : milestone.Status == "in_progress" ? "info" : "secondary")">
                                            @milestone.Status.Replace("_", " ")
                                        </span>
                                    </td>
                                    <td>@milestone.DueDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if (milestone.ActualDate.HasValue)
                                        {
                                            @milestone.ActualDate.Value.ToString("dd MMM yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not completed</span>
                                        }
                                    </td>
                                    <td>
                                        @if (milestone.ProgressPercent.HasValue && milestone.ProgressPercent.Value > 0)
                                        {
                                            @milestone.ProgressPercent.Value<text>%</text>
                                        }
                                        else
                                        {
                                            <span class="text-muted">0%</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-4">
                        <p class="text-muted mb-2">No milestones recorded.</p>
                        <a class="btn btn-success btn-sm" asp-controller="Project" asp-action="CreateMilestone" asp-route-projectId="@Model.Id">Add milestone</a>
                    </div>
                }
            </div>
            @if (Model.Milestones.Count > 5)
            {
                <div class="card-footer">
                    <a asp-action="Details" asp-route-id="@Model.Id" asp-route-tab="milestones">View all @Model.Milestones.Count milestones</a>
                </div>
            }
        </div>

        <!-- Strategic Alignment -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Strategic Alignment</h3>
                <div class="card-tools">
                    <a asp-action="Details" asp-route-id="@Model.Id" asp-route-tab="strategicalignment">Manage alignment</a>
                </div>
            </div>
            <div class="card-body p-0">
                <table class="table table-borderless mb-0 project-overview-summary">
                    <tbody>
                        <tr>
                            <td class="summary-label"><strong>Priority Outcomes</strong></td>
                            <td class="summary-value">
                                @if (Model.ProjectObjectives != null && Model.ProjectObjectives.Any())
                                {
                                    <ul class="mb-0 pl-3">
                                        @foreach (var projectObjective in Model.ProjectObjectives.OrderBy(po => po.Objective?.Title))
                                        {
                                            <li>@projectObjective.Objective?.Title</li>
                                        }
                                    </ul>
                                }
                                else if (!string.IsNullOrEmpty(Model.StrategicObjectives))
                                {
                                    @Model.StrategicObjectives
                                }
                                else
                                {
                                    <span class="text-muted">No priority outcomes defined</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Mission Pillars</strong></td>
                            <td class="summary-value">
                                @if (Model.ProjectMissions != null && Model.ProjectMissions.Any())
                                {
                                    <ul class="mb-0 pl-3">
                                        @foreach (var projectMission in Model.ProjectMissions.OrderBy(pm => pm.Mission?.Title))
                                        {
                                            <li>@projectMission.Mission?.Title</li>
                                        }
                                    </ul>
                                }
                                else if (!string.IsNullOrEmpty(Model.MissionPillars))
                                {
                                    @Model.MissionPillars
                                }
                                else
                                {
                                    <span class="text-muted">No mission pillars defined</span>
                                }
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Project Milestones -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Recent Milestones</h3>
                <div class="card-tools">
                    <a asp-action="Details" asp-route-id="@Model.Id" asp-route-tab="milestones">View all milestones</a>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                @if (Model.Milestones.Any())
                {
                    <table class="table table-hover text-nowrap milestones-table">
                        <thead>
                            <tr>
                                <th class="col-name">Name</th>
                                <th class="col-status">Status</th>
                                <th class="col-due">Due Date</th>
                                <th class="col-actual">Actual Date</th>
                                <th class="col-progress">Progress</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var milestone in Model.Milestones.OrderBy(m => m.DueDate).Take(5))
                            {
                                <tr>
                                    <td>
                                        <a href="#" 
                                           class="view-milestone-link"
                                           data-milestone-id="@milestone.Id"
                                           data-milestone-name="@milestone.Name"
                                           data-milestone-status="@milestone.Status"
                                           data-milestone-progress="@(milestone.ProgressPercent ?? 0)"
                                           data-milestone-due="@milestone.DueDate.ToString("yyyy-MM-dd")"
                                           data-milestone-actual="@(milestone.ActualDate?.ToString("yyyy-MM-dd") ?? "")"
                                           data-milestone-description="@milestone.Description">
                                            @milestone.Name
                                        </a>
                                    </td>
                                    <td>
                                        <span class="badge badge-@(milestone.Status == "complete" ? "success" : milestone.Status == "at_risk" ? "warning" : milestone.Status == "in_progress" ? "info" : "secondary")">
                                            @milestone.Status.Replace("_", " ")
                                        </span>
                                    </td>
                                    <td>@milestone.DueDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if (milestone.ActualDate.HasValue)
                                        {
                                            @milestone.ActualDate.Value.ToString("dd MMM yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not completed</span>
                                        }
                                    </td>
                                    <td>
                                        @if (milestone.ProgressPercent.HasValue && milestone.ProgressPercent.Value > 0)
                                        {
                                            @milestone.ProgressPercent.Value<text>%</text>
                                        }
                                        else
                                        {
                                            <span class="text-muted">0%</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="p-4">
                        <p class="text-muted mb-2">No milestones recorded.</p>
                        <a class="btn btn-success btn-sm" asp-controller="Project" asp-action="CreateMilestone" asp-route-projectId="@Model.Id">Add milestone</a>
                    </div>
                }
            </div>
            @if (Model.Milestones.Count > 5)
            {
                <div class="card-footer">
                    <a asp-action="Details" asp-route-id="@Model.Id" asp-route-tab="milestones">View all @Model.Milestones.Count milestones</a>
                </div>
            }
        </div>
    </div>
    
    <!-- Right Column -->
    <div class="col-lg-4">
        <!-- Staff & Funding Overview -->
        <div class="card mb-4 staff-funding-card">
            <div class="card-header">
                <h3 class="card-title">Staff & Funding Overview</h3>
                <div class="card-tools">
                    <a asp-action="Details" asp-route-id="@Model.Id" asp-route-tab="funding">Manage</a>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                @{
                    var permFte = Model.TotalPermFte ?? 0;
                    var mspFte = Model.TotalMspFte ?? 0;
                    var projectTotalFte = permFte + mspFte;
                    
                    // Calculate percentages for Permanent vs MSP
                    var permPercentage = projectTotalFte > 0 ? Math.Round((permFte / projectTotalFte) * 100, 1) : 0;
                    var mspPercentage = projectTotalFte > 0 ? Math.Round((mspFte / projectTotalFte) * 100, 1) : 0;
                    
                    // Funding calculations
                    var permFunding = Model.ResourceFunding?.FirstOrDefault(rf => rf.ResourceType == "Permanent");
                    var mspFunding = Model.ResourceFunding?.FirstOrDefault(rf => rf.ResourceType == "MSP");
                    
                    var permProgrammeFunded = permFunding != null ? (permFunding.ProgrammeFundedPercentage / 100m) * permFte : 0;
                    var permAdminFunded = permFunding != null ? (permFunding.AdminFundedPercentage / 100m) * permFte : 0;
                    var mspProgrammeFunded = mspFunding != null ? (mspFunding.ProgrammeFundedPercentage / 100m) * mspFte : 0;
                    var mspAdminFunded = mspFunding != null ? (mspFunding.AdminFundedPercentage / 100m) * mspFte : 0;
                    
                    var programmeFunded = permProgrammeFunded + mspProgrammeFunded;
                    var adminFunded = permAdminFunded + mspAdminFunded;
                }
                
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Type</th>
                            <th class="text-right">FTE</th>
                            <th class="text-right">%</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Permanent</td>
                            <td class="text-right"><strong>@permFte</strong></td>
                            <td class="text-right">@permPercentage%</td>
                        </tr>
                        <tr>
                            <td>MSP</td>
                            <td class="text-right"><strong>@mspFte</strong></td>
                            <td class="text-right">@mspPercentage%</td>
                        </tr>
                        <tr>
                            <td><strong>Total FTE</strong></td>
                            <td class="text-right"><strong>@projectTotalFte</strong></td>
                            <td class="text-right"><strong>100%</strong></td>
                        </tr>
                        <tr class="border-top">
                            <td>Programme</td>
                            <td class="text-right" colspan="2">@programmeFunded.ToString("0.0") FTE</td>
                        </tr>
                        <tr>
                            <td>Admin</td>
                            <td class="text-right" colspan="2">@adminFunded.ToString("0.0") FTE</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Contacts -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Contacts</h3>
                <div class="card-tools">
                    <a asp-action="Details" asp-route-id="@Model.Id" asp-route-tab="contacts">View contacts</a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (Model.ProjectContacts.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Role</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var contact in Model.ProjectContacts.OrderBy(c => c.SortOrder).Take(5))
                                {
                                    <tr>
                                        <td>
                                            @if (!string.IsNullOrEmpty(contact.Email))
                                            {
                                                <a href="mailto:@contact.Email">@contact.Name</a>
                                            }
                                            else
                                            {
                                                @contact.Name
                                            }
                                        </td>
                                        <td>@contact.Role</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (Model.ProjectContacts.Count > 5)
                    {
                        <div class="text-center mt-3 p-3 border-top">
                            <a asp-action="Details" asp-route-id="@Model.Id" asp-route-tab="contacts" class="btn btn-sm btn-outline-secondary">
                                View all @Model.ProjectContacts.Count contacts
                            </a>
                        </div>
                    }
                }
                else
                {
