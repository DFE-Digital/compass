@model Compass.Models.Project
@using System
@using System.Linq
@using Compass.Helpers

@{
    var activeMilestones = Model.Milestones
        .Where(m => m.Status != "complete")
        .OrderBy(m => m.DueDate)
        .ToList();
    
    // Flagship project deliverables
    var deliverableProjects = ViewBag.DeliverableProjects as List<Compass.Models.Project> ?? new List<Compass.Models.Project>();
    var totalPermFte = (Model.TotalPermFte ?? 0) + deliverableProjects.Sum(p => p.TotalPermFte ?? 0);
    var totalMspFte = (Model.TotalMspFte ?? 0) + deliverableProjects.Sum(p => p.TotalMspFte ?? 0);
    var totalFte = totalPermFte + totalMspFte;
    var deliveryCode = $"DEL-DDT-{Model.Id}";
    var deliveryPriorityOptions = ViewBag.DeliveryPriorities as IEnumerable<Compass.Models.DeliveryPriority> ?? Enumerable.Empty<Compass.Models.DeliveryPriority>();
    var priorityKey = PriorityStyleHelper.GetPriorityKey(Model.DeliveryPriority?.Name);
}

<div class="row">
    <!-- Left Column -->
    <div class="col-lg-8">
        <div class="row">
            <div class="col-md-6">
                <div class="card priority-card priority-card--@priorityKey h-100 mb-4" role="group" aria-labelledby="priorityCardHeading" aria-describedby="priorityCardSummary">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <p class="card-label text-uppercase mb-1" id="priorityCardHeading">Priority</p>
                                <h3 class="card-value mb-0">@((Model.DeliveryPriority?.Name) ?? "Not set")</h3>
                            </div>
                            <a href="#"
                               class="btn btn-sm priority-card__cta"
                               data-toggle="modal"
                               data-target="#editDeliveryPriorityModal">
                                Change priority
                                <span class="sr-only">for @Model.Title</span>
                                <i class="fas fa-arrow-right ml-1" aria-hidden="true"></i>
                            </a>
                        </div>
                        @if (Model.DeliveryPriority != null && !string.IsNullOrWhiteSpace(Model.DeliveryPriority.Summary))
                        {
                            <p class="mb-0 priority-card__support" id="priorityCardSummary">@Model.DeliveryPriority.Summary</p>
                        }
                        else
                        {
                            <p class="mb-0 priority-card__support" id="priorityCardSummary">No summary provided.</p>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                @{
                    var ragCardClass = GetRagCardClass(Model.RagStatus);
                    var ragStatusDisplay = !string.IsNullOrEmpty(Model.RagStatus) ? Model.RagStatus : "Not set";
                    var ragSupportingTextClass = !string.IsNullOrEmpty(ragCardClass) && ragCardClass.Contains("amber", StringComparison.OrdinalIgnoreCase)
                        ? "rag-card__support--dark"
                        : "rag-card__support--light";
                }
                <div class="card rag-card @ragCardClass h-100 mb-4" role="group" aria-labelledby="ragStatusHeading">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <p class="card-label text-uppercase mb-1" id="ragStatusHeading">RAG status</p>
                                <h3 class="card-value mb-0">@ragStatusDisplay</h3>
                            </div>
                            <a asp-action="Details"
                               asp-route-id="@Model.Id"
                               asp-route-tab="rag"
                               class="btn btn-sm rag-card__cta">
                                View RAG history
                                <span class="sr-only">for @Model.Title</span>
                                <i class="fas fa-arrow-right ml-1" aria-hidden="true"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Aim -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Aim</h3>
                <div class="card-tools">
                    <a href="#" data-toggle="modal" data-target="#editAimModal">Change</a>
                </div>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.Aim))
                {
                    <p class="mb-0">@Model.Aim</p>
                }
                else
                {
                    <p class="text-muted mb-0">No aim specified</p>
                }
            </div>
        </div>

        <!-- Status Updates -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Status updates</h3>
                <div class="card-tools">
                    <a asp-action="Details" asp-route-id="@Model.Id" asp-route-tab="statusupdates">View all</a>
                </div>
            </div>
            <div class="card-body p-0">
                @if (Model.StatusUpdates?.Any() == true)
                {
                    var recentUpdates = Model.StatusUpdates.OrderByDescending(su => su.CreatedAt).Take(2).ToList();
                    @foreach (var update in recentUpdates)
                    {
                        <div class="p-3 @(update != recentUpdates.Last() ? "border-bottom" : "")">
                            <div class="mb-2">
                                <small class="text-muted">@update.CreatedAt.ToString("d MMMM yyyy 'at' HH:mm")</small>
                                @if (update.CreatedByUser != null)
                                {
                                    <small class="text-muted"> by @update.CreatedByUser.Name</small>
                                }
                            </div>
                            <p class="mb-0">
                                @if (update.Narrative.Length > 200)
                                {
                                    @update.Narrative.Substring(0, 200)<text>…</text>
                                }
                                else
                                {
                                    @update.Narrative
                                }
                            </p>
                        </div>
                    }
                    @if (Model.StatusUpdates.Count > 2)
                    {
                        <div class="p-3 border-top">
                            <a asp-action="Details" asp-route-id="@Model.Id" asp-route-tab="statusupdates" class="btn btn-sm btn-outline-secondary">
                                View all @Model.StatusUpdates.Count status updates
                            </a>
                        </div>
                    }
                }
                else
                {
                    <div class="p-3">
                        <p class="text-muted mb-0">No status updates recorded yet.</p>
                        <a asp-action="Details" asp-route-id="@Model.Id" asp-route-tab="statusupdates" class="btn btn-sm btn-primary mt-2">
                            Add status update
                        </a>
                    </div>
                }
            </div>
        </div>

        @if (Model.IsFlagship)
        {
            <!-- Flagship Project Deliverables -->
            <div class="card mb-4">
                <div class="card-header">
                    <h3 class="card-title">
                        @{
                            var deliverableCount = deliverableProjects.Count;
                            if (deliverableCount > 0)
                            {
                                <text>1 to @deliverableCount of @deliverableCount @(deliverableCount == 1 ? "deliverable" : "deliverables")</text>
                            }
                            else
                            {
                                <text>Flagship Project Deliverables</text>
                            }
                        }
                    </h3>
                    <div class="card-tools">
                        <a href="@Url.Action("Details", new { id = Model.Id, tab = "deliverables" })">Manage deliverables</a>
                    </div>
                </div>
                <div class="card-body">
                    @if (deliverableProjects.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>RAG Status</th>
                                        <th>Phase</th>
                                        <th>Business Area</th>
                                        <th>Milestones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var project in deliverableProjects.OrderBy(p => p.Title))
                                    {
                                        var projectMilestoneCount = project.Milestones?.Count(m => !m.IsDeleted) ?? 0;
                                        var projectCompletedMilestones = project.Milestones?.Count(m => !m.IsDeleted && m.Status == "complete") ?? 0;
                                
                                        
                                        <tr>
                                            <td>
                                                <a href="@Url.Action("Details", "Project", new { id = project.Id })">
                                                    <strong>@project.Title</strong>
                                                </a><br>
                                                <small class="text-muted">DEL-DDT-@project.Id</small>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(project.RagStatus))
                                                {
                                                    <span class="@GetRagBadgeClass(project.RagStatus)">@project.RagStatus</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-secondary">Not set</span>
                                                }
                                            </td>
                                            <td>@(project.Phase ?? "Not set")</td>
                                            <td>@(project.BusinessArea ?? "Not set")</td>
                                            <td>
                                                @if (projectMilestoneCount > 0)
                                                {
                                                    <span>@projectCompletedMilestones / @projectMilestoneCount</span>
                                                    <div class="progress" style="height: 4px;">
                                                        <div class="progress-bar bg-success" role="progressbar" 
                                                             style="width: @((projectCompletedMilestones * 100.0 / projectMilestoneCount).ToString("F0"))%" 
                                                             aria-valuenow="@projectCompletedMilestones" 
                                                             aria-valuemin="0" 
                                                             aria-valuemax="@projectMilestoneCount"
                                                             aria-label="Milestone completion for @project.Title: @projectCompletedMilestones of @projectMilestoneCount completed"></div>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">0</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center p-3">
                            <p class="text-muted mb-2">No deliverables have been added yet.</p>
                            <a href="@Url.Action("Details", new { id = Model.Id, tab = "deliverables" })" class="btn btn-sm btn-primary">
                                <i class="fas fa-plus"></i> Add Deliverables
                            </a>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Active Milestones -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Active milestones</h3>
                <div class="card-tools">
                    <a asp-controller="Project" asp-action="CreateMilestone" asp-route-projectId="@Model.Id">Add milestone</a>
                </div>
            </div>
            <div class="card-body ">
                @if (activeMilestones.Any())
                {
                    <table class="table table-hover text-nowrap milestones-table table-responsive p-0">
                        <thead>
                            <tr>
                                <th class="col-name">Name</th>
                                <th class="col-status">Status</th>
                                <th class="col-due">Due Date</th>
                                <th class="col-actual">Actual Date</th>
                                <th class="col-progress">Progress</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var milestone in activeMilestones.Take(5))
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Project" asp-action="MilestoneDetails" asp-route-id="@milestone.Id">
                                            @milestone.Name
                                        </a>
                                    </td>
                                    <td>
                                        <span class="badge badge-@(milestone.Status == "complete" ? "success" : milestone.Status == "at_risk" ? "warning" : milestone.Status == "in_progress" ? "info" : "secondary")">
                                            @milestone.Status.Replace("_", " ")
                                        </span>
                                    </td>
                                    <td>@milestone.DueDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        @if (milestone.ActualDate.HasValue)
                                        {
                                            @milestone.ActualDate.Value.ToString("dd MMM yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not completed</span>
                                        }
                                    </td>
                                    <td>
                                        @if (milestone.ProgressPercent.HasValue && milestone.ProgressPercent.Value > 0)
                                        {
                                            @milestone.ProgressPercent.Value<text>%</text>
                                        }
                                        else
                                        {
                                            <span class="text-muted">0%</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
               
                        <p class="text-muted mb-2">No active milestones.</p>
                        <a class="btn btn-success btn-sm" asp-controller="Project" asp-action="CreateMilestone" asp-route-projectId="@Model.Id">Add milestone</a>
            
                }
            </div>
            @if (activeMilestones.Count > 5)
            {
                <div class="card-footer">
                    <a asp-action="Details" asp-route-id="@Model.Id" asp-route-tab="milestones">View all @Model.Milestones.Count milestones</a>
                </div>
            }
        </div>



    </div>
    
    <!-- Right Column -->
    <div class="col-lg-4">
        <!-- Project Summary (Key Fields) -->
        <div class="card mb-4 project-summary-card">
            <div class="card-header">
                <h3 class="card-title">Project summary</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-borderless mb-0 project-overview-summary">
                    <tbody>
                        <tr>
                            <td class="summary-label"><strong>Title</strong></td>
                            <td class="summary-value">
                                @Model.Title
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editTitleModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Status</strong></td>
                            <td class="summary-value">
                                <span class="badge badge-@(Model.Status == "Active" ? "success" : Model.Status == "Paused" ? "warning" : Model.Status == "Completed" ? "info" : "secondary")">@Model.Status</span>
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editStatusModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Phase</strong></td>
                            <td class="summary-value">
                                @if (!string.IsNullOrEmpty(Model.Phase))
                                {
                                    @Model.Phase
                                }
                                else
                                {
                                    <span class="text-muted">Not specified</span>
                                }
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editPhaseModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Business area</strong></td>
                            <td class="summary-value">
                                @if (!string.IsNullOrEmpty(Model.BusinessArea))
                                {
                                    @Model.BusinessArea
                                }
                                else
                                {
                                    <span class="text-muted">Not specified</span>
                                }
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editBusinessAreaModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Primary contact</strong></td>
                            <td class="summary-value">
                                @if (Model.PrimaryContactUser != null)
                                {
                                    <div>
                                @if (!string.IsNullOrWhiteSpace(Model.PrimaryContactUser.Email))
                                {
                                    <a href="mailto:@Model.PrimaryContactUser.Email" class="font-weight-bold">
                                        @Model.PrimaryContactUser.Name
                                    </a>
                                }
                                else
                                {
                                    <strong>@Model.PrimaryContactUser.Name</strong>
                                }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editPrimaryContactModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>SROs</strong></td>
                            <td class="summary-value">
                                @if (Model.SeniorResponsibleOfficers?.Any() == true)
                                {
                                    @foreach (var sro in Model.SeniorResponsibleOfficers.Take(2))
                                    {
                                        @if (sro.User != null)
                                        {
                                            <div>
                                                @if (!string.IsNullOrEmpty(sro.User.Email))
                                                {
                                                    <a href="mailto:@sro.User.Email">@sro.User.Name</a>
                                                }
                                                else
                                                {
                                                    @sro.User.Name
                                                }
                                            </div>
                                        }
                                    }
                                    @if (Model.SeniorResponsibleOfficers.Count > 2)
                                    {
                                        <small class="text-muted">+ @(Model.SeniorResponsibleOfficers.Count - 2) more</small>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                            <td class="text-right">
                                <a asp-action="Details" asp-route-id="@Model.Id" asp-route-tab="contactsandgovernance">View all</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Start date</strong></td>
                            <td class="summary-value">
                                @if (Model.StartDate.HasValue && Model.StartDate.Value.Year > 1)
                                {
                                    @Model.StartDate.Value.ToString("d MMMM yyyy")
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editStartDateModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Target end date</strong></td>
                            <td class="summary-value">
                                @if (Model.TargetDeliveryDate.HasValue && Model.TargetDeliveryDate.Value.Year > 1)
                                {
                                    @Model.TargetDeliveryDate.Value.ToString("d MMMM yyyy")
                                }
                                else
                                {
                                    <span class="text-muted">No end date</span>
                                }
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editTargetDateModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Activity type</strong></td>
                            <td class="summary-value">
                                @if (Model.ActivityTypeLookup != null)
                                {
                                    @Model.ActivityTypeLookup.Name
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editActivityTypeModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Risk appetite</strong></td>
                            <td class="summary-value">
                                @if (Model.RiskAppetiteLookup != null)
                                {
                                    <span class="badge @GetRiskAppetiteBadgeClass(Model.RiskAppetiteLookup.Name)">
                                        @Model.RiskAppetiteLookup.Name
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editRiskAppetiteModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Service type</strong></td>
                            <td class="summary-value">
                                @{
                                    var serviceTypes = new List<string>();
                                    if (Model.IsInternal) serviceTypes.Add("Internal");
                                    if (Model.IsExternal) serviceTypes.Add("External");
                                    if (!serviceTypes.Any())
                                    {
                                        serviceTypes.Add("Not set");
                                    }
                                }
                                @string.Join(", ", serviceTypes)
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editServiceTypeModal">Change</a>
                            </td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Subject to spend control</strong></td>
                            <td class="summary-value">
                                @if (Model.IsSubjectToSpendControl.HasValue)
                                {
                                    @(Model.IsSubjectToSpendControl.Value ? "Yes" : "No")
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                            <td class="text-right">
                                <a href="#" data-toggle="modal" data-target="#editSpendControlModal">Change</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Team snapshot -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Team</h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-tool" style="color: black !important;" data-card-widget="collapse" aria-label="Collapse Team section">
                        <i class="fas fa-minus" aria-hidden="true"></i>
                    </button>
                </div>
            </div>
            <div class="card-body p-0">
                @if (Model.ProjectContacts.Any())
                {
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Role</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var contact in Model.ProjectContacts.OrderBy(c => c.SortOrder).Take(5))
                                {
                                    <tr>
                                        <td>
                                            @if (!string.IsNullOrEmpty(contact.Email))
                                            {
                                                <a href="mailto:@contact.Email">@contact.Name</a>
                                            }
                                            else
                                            {
                                                @contact.Name
                                            }
                                        </td>
                                        <td>@contact.Role</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                 
                  
                }
                else
                {
                    <div class="p-3">
                        <p class="text-muted mb-0">No contacts recorded.</p>
                    </div>
                }
            </div>
            <div class="card-footer">
                <a asp-action="Details" asp-route-id="@Model.Id" asp-route-tab="team" class="btn btn-sm btn-outline-secondary">
                    View full team
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Edit Aim Modal -->
<div class="modal fade" id="editAimModal" tabindex="-1" role="dialog" aria-labelledby="editAimModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editAimModalLabel">Edit aim</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateAim" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="aim">Aim</label>
                        <textarea class="form-control" id="aim" name="aim" rows="6" placeholder="Describe the aim...">@Model.Aim</textarea>
                        <small class="form-text text-muted">Clearly state the primary objective and purpose of this project.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- View/Edit Milestone Modal -->
<div class="modal fade" id="viewMilestoneModal" tabindex="-1" role="dialog" aria-labelledby="viewMilestoneModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewMilestoneModalLabel">Milestone Details</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="editMilestoneForm" asp-action="UpdateMilestone" method="post">
                <input type="hidden" name="projectId" value="@Model.Id" />
                <input type="hidden" name="milestoneId" id="editMilestoneId" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="editMilestoneName">Milestone Name</label>
                        <input type="text" class="form-control" id="editMilestoneName" name="name" required>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="editMilestoneStatus">Status</label>
                                <select class="form-control" id="editMilestoneStatus" name="status" required>
                                    <option value="not_started">Not Started</option>
                                    <option value="in_progress">In Progress</option>
                                    <option value="at_risk">At Risk</option>
                                    <option value="complete">Complete</option>
                                </select>
                            </div>
                        </div>
