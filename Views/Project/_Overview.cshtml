                    var activeHeader = table.querySelector('.sortable[data-column="' + column + '"]');
                    if (activeHeader) {
                        var icon = activeHeader.querySelector('i');
                        if (icon) {
                            icon.className = direction === 'asc' ? 'fas fa-sort-up float-right' : 'fas fa-sort-down float-right';
                            icon.style.opacity = '1';
                        }
                    }
                }
            }
            
            // Initialize all table sorting
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function() {
                    initMilestonesTableSorting();
                    initTeamTableSorting();
                    initDeliverablesTableSorting();
                });
            } else {
                initMilestonesTableSorting();
                initTeamTableSorting();
                initDeliverablesTableSorting();
            }
        }

        if (typeof jQuery !== 'undefined') {
            $(document).ready(initOverviewPage);
        } else {
            document.addEventListener('DOMContentLoaded', function() {
                if (typeof jQuery !== 'undefined') {
                    $(document).ready(initOverviewPage);
                }
            });
        }
    })();
</script>
