@model Compass.ViewModels.ProjectNeedDetailsViewModel

@{
    ViewData["Title"] = $"Need details – {Model.ProjectTitle}";
    string ValidatedBadgeClass(string validated) => validated switch
    {
        "Yes" => "badge-success",
        "Partially" => "badge-warning",
        _ => "badge-secondary"
    };
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <a asp-action="Details"
                   asp-route-id="@Model.ProjectId"
                   asp-route-tab="outcomes"
                   class="btn btn-link px-0 mb-2"
                   aria-label="Back to project">
                    <i class="fas fa-arrow-left mr-2" aria-hidden="true"></i>Back to project
                </a>
                <h1 class="m-0">Need details</h1>
                <p class="text-muted mb-0">Project: @Model.ProjectTitle</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <aside class="col-xxl-3 col-xl-2 col-lg-4 col-md-5 mb-4">
                <partial name="_ProjectSummarySidebar" model="Model.ProjectSummary" />
            </aside>
            <div class="col-xxl-9 col-xl-9 col-lg-8 col-md-7">
                <div class="card project-summary-card mb-4" id="need-details">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Need information</h3>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-borderless mb-0 need-summary-table">
                            <tbody>
                                <tr>
                                    <td class="summary-label"><strong>Title</strong></td>
                                    <td class="summary-value font-weight-medium">@Model.Title</td>
                                    <td class="text-right">
                                        <a class="small"
                                           asp-action="EditNeed"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-needId="@Model.NeedId">Change</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Need</strong></td>
                                    <td class="summary-value">@Model.Need</td>
                                    <td class="text-right">
                                        <a class="small"
                                           asp-action="EditNeed"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-needId="@Model.NeedId">Change</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Source</strong></td>
                                    <td class="summary-value">
                                        @(string.IsNullOrWhiteSpace(Model.Source) ? "-" : Model.Source)
                                    </td>
                                    <td class="text-right">
                                        <a class="small"
                                           asp-action="EditNeed"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-needId="@Model.NeedId">Change</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Validated</strong></td>
                                    <td class="summary-value">
                                        <span class="badge @ValidatedBadgeClass(Model.Validated)">@Model.Validated</span>
                                    </td>
                                    <td class="text-right">
                                        <a class="small"
                                           asp-action="EditNeed"
                                           asp-route-projectId="@Model.ProjectId"
                                           asp-route-needId="@Model.NeedId">Change</a>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Display order</strong></td>
                                    <td class="summary-value">@Model.SortOrder</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Created by</strong></td>
                                    <td class="summary-value">
                                        @if (!string.IsNullOrWhiteSpace(Model.CreatedByName))
                                        {
                                            <span>@Model.CreatedByName</span>
                                            @if (!string.IsNullOrWhiteSpace(Model.CreatedByEmail))
                                            {
                                                <span class="text-muted">(@Model.CreatedByEmail)</span>
                                            }
                                        }
                                        else if (!string.IsNullOrWhiteSpace(Model.CreatedByEmail))
                                        {
                                            <span>@Model.CreatedByEmail</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Unknown</span>
                                        }
                                    </td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Created</strong></td>
                                    <td class="summary-value">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm") (UTC)</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="summary-label"><strong>Last updated</strong></td>
                                    <td class="summary-value">@Model.UpdatedAt.ToString("dd MMM yyyy HH:mm") (UTC)</td>
                                    <td></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

