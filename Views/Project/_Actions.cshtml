@model Compass.Models.Project
@{
    var actions = Model.Actions.Where(a => !a.IsDeleted).OrderByDescending(a => a.CreatedAt).ToList();
    var openCount = actions.Count(a => a.Status != "done" && a.Status != "cancelled");
    var closedCount = actions.Count(a => a.Status == "done" || a.Status == "cancelled");
    var blockedCount = actions.Count(a => a.Status == "blocked");
    var overdueCount = actions.Count(a =>
        a.DueDate.HasValue &&
        a.DueDate.Value.Date < DateTime.UtcNow.Date &&
        a.Status != "done" &&
        a.Status != "cancelled");
}

<div class="card" id="actions">
    <div class="card-header">
        <h3 class="card-title">Work actions</h3>
        <div class="card-tools">
            <a asp-controller="Project" asp-action="CreateAction" asp-route-projectId="@Model.Id">Add action</a>
        </div>
    </div>
    <div class="card-body table-responsive p-0">
        @if (actions.Any())
        {
            <table class="table table-hover text-nowrap sortable-table">
                <thead>
                    <tr>
                        <th class="sortable" data-column="Title" tabindex="0" role="button" aria-label="Sort by Title">
                            Title
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="Status" tabindex="0" role="button" aria-label="Sort by Status" style="width: 140px;">
                            Status
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="Priority" tabindex="0" role="button" aria-label="Sort by Priority" style="width: 110px;">
                            Priority
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="DueDate" tabindex="0" role="button" aria-label="Sort by Due date" style="width: 160px;">
                            Due date
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="AssignedTo" tabindex="0" role="button" aria-label="Sort by Assigned to" style="width: 180px;">
                            Assigned to
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th style="width: 220px;">Linked items</th>
                        <th style="width: 160px;">Decision</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var action in actions)
                    {
                        var isOverdue = action.DueDate.HasValue && action.DueDate.Value.Date < DateTime.UtcNow.Date && action.Status != "done" && action.Status != "cancelled";
                        var riskLinks = action.RiskActions.Select(ra => ra.Risk).Where(r => r != null && !r.IsDeleted).OrderBy(r => r!.Title).ToList();
                        var issueLinks = action.IssueActions.Select(ia => ia.Issue).Where(i => i != null && !i.IsDeleted).OrderBy(i => i!.Title).ToList();
                        var decision = action.Decision != null && !action.Decision.IsDeleted ? action.Decision : null;

                        <tr>
                            <td>
                                <a asp-controller="Action" asp-action="Details" asp-route-id="@action.Id">@action.Title</a>
                            </td>
                            <td>
                                @switch (action.Status)
                                {
                                    case "not_started":
                                        <span class="badge badge-secondary">Not started</span>
                                        break;
                                    case "in_progress":
                                        <span class="badge badge-primary">In progress</span>
                                        break;
                                    case "blocked":
                                        <span class="badge badge-danger">Blocked</span>
                                        break;
                                    case "done":
                                        <span class="badge badge-success">Done</span>
                                        break;
                                    case "cancelled":
                                        <span class="badge badge-secondary">Cancelled</span>
                                        break;
                                    default:
                                        <span class="badge badge-secondary">@action.Status.Replace("_", " ")</span>
                                        break;
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(action.Priority))
                                {
                                    var priorityClass = action.Priority switch
                                    {
                                        "high" => "badge-danger",
                                        "medium" => "badge-warning",
                                        "low" => "badge-secondary",
                                        _ => "badge-light"
                                    };
                                    <span class="badge @priorityClass">@action.Priority</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (action.CompletedDate.HasValue)
                                {
                                    <span class="text-success">@action.CompletedDate.Value.ToString("d MMMM yyyy")</span>
                                }
                                else if (action.DueDate.HasValue)
                                {
                                    <span class="@(isOverdue ? "text-danger font-weight-bold" : string.Empty)">@action.DueDate.Value.ToString("d MMMM yyyy")</span>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(action.AssignedToEmail))
                                {
                                    <span>@action.AssignedToEmail</span>
                                }
                                else
                                {
                                    <span class="text-muted">Unassigned</span>
                                }
                            </td>
                            <td>
                                @if (riskLinks.Any())
                                {
                                    foreach (var risk in riskLinks)
                                    {
                                        <span class="badge badge-warning mr-1 mb-1"><i class="fas fa-exclamation-triangle mr-1"></i>@risk!.Title</span>
                                    }
                                }
                                @if (issueLinks.Any())
                                {
                                    foreach (var issue in issueLinks)
                                    {
                                        <span class="badge badge-info mr-1 mb-1"><i class="fas fa-bug mr-1"></i>@issue!.Title</span>
                                    }
                                }
                                @if (!riskLinks.Any() && !issueLinks.Any())
                                {
                                    <span class="text-muted">No linked items</span>
                                }
                            </td>
                            <td>
                                @if (decision != null)
                                {
                                    <span class="badge badge-primary"><i class="fas fa-gavel mr-1"></i>@decision.Title</span>
                                }
                                else
                                {
                                    <span class="text-muted">Not linked</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="p-3">
                <p class="text-muted mb-2">No actions recorded for this work item yet.</p>
                <a asp-controller="Project" asp-action="CreateAction" asp-route-projectId="@Model.Id">Add the first action</a>
            </div>
        }
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
    (function() {
        function initSorting(table) {
            var sortableHeaders = table.querySelectorAll('.sortable');
            var currentSort = { column: null, direction: 'asc' };
            
            sortableHeaders.forEach(function(header) {
                header.style.cursor = 'pointer';
                
                header.addEventListener('click', function(e) {
                    handleSort(e, header);
                });
                
                header.addEventListener('keypress', function(e) {
                    if (e.which === 13 || e.which === 32) {
                        e.preventDefault();
                        handleSort(e, header);
                    }
                });
            });
            
            function handleSort(e, header) {
                var column = header.getAttribute('data-column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(column, direction);
                currentSort = { column: column, direction: direction };
            }
            
            function sortTable(column, direction) {
                var tbody = table.querySelector('tbody');
                var rows = Array.from(tbody.querySelectorAll('tr'));
                var colIndex = Array.from(table.querySelectorAll('thead th')).findIndex(function(th) {
                    return th.getAttribute('data-column') === column;
                });
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var aCell = a.querySelectorAll('td')[colIndex];
                    var bCell = b.querySelectorAll('td')[colIndex];
                    
                    if (column === 'Status' || column === 'Priority') {
                        // Sort by badge text
                        var aBadge = aCell.querySelector('.badge');
                        var bBadge = bCell.querySelector('.badge');
                        aVal = aBadge ? aBadge.textContent.trim().toLowerCase() : aCell.textContent.trim().toLowerCase();
                        bVal = bBadge ? bBadge.textContent.trim().toLowerCase() : bCell.textContent.trim().toLowerCase();
                    } else if (column === 'Title') {
                        // Sort by link text
                        var aLink = aCell.querySelector('a');
                        var bLink = bCell.querySelector('a');
                        aVal = aLink ? aLink.textContent.trim().toLowerCase() : aCell.textContent.trim().toLowerCase();
                        bVal = bLink ? bLink.textContent.trim().toLowerCase() : bCell.textContent.trim().toLowerCase();
                    } else if (column === 'DueDate') {
                        // Sort by date
                        var aDate = Date.parse(aCell.textContent.trim());
                        var bDate = Date.parse(bCell.textContent.trim());
                        aVal = isNaN(aDate) ? 0 : aDate;
                        bVal = isNaN(bDate) ? 0 : bDate;
                    } else {
                        aVal = aCell.textContent.trim().toLowerCase();
                        bVal = bCell.textContent.trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.innerHTML = '';
                rows.forEach(function(row) {
                    tbody.appendChild(row);
                });
                
                updateSortIcons(column, direction);
            }
            
            function updateSortIcons(column, direction) {
                var allHeaders = table.querySelectorAll('.sortable i');
                allHeaders.forEach(function(icon) {
                    icon.className = 'fas fa-sort float-right';
                    icon.style.opacity = '0.3';
                });
                
                var activeHeader = table.querySelector('.sortable[data-column="' + column + '"]');
                if (activeHeader) {
                    var icon = activeHeader.querySelector('i');
                    if (icon) {
                        icon.className = direction === 'asc' ? 'fas fa-sort-up float-right' : 'fas fa-sort-down float-right';
                        icon.style.opacity = '1';
                    }
                }
            }
        }
        
        var table = document.querySelector('#actions .sortable-table');
        if (table) {
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function() { initSorting(table); });
            } else {
                initSorting(table);
            }
        }
    })();
</script>
