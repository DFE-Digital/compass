@model Compass.ViewModels.ProjectMilestoneFormViewModel

@{
    ViewData["Title"] = $"Edit milestone – {Model.Input.Name}";
    var projectDetailsUrl = Url.Action("Details", "Project", new { id = Model.Input.ProjectId, tab = "milestones" });

    Func<string, string> normaliseKey = key =>
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return string.Empty;
        }

        var trimmed = key;
        var bracketIndex = trimmed.IndexOf('[');
        if (bracketIndex >= 0)
        {
            trimmed = trimmed.Substring(0, bracketIndex);
        }

        var segments = trimmed.Split('.', System.StringSplitOptions.RemoveEmptyEntries);
        return segments.Length > 0 ? segments[^1] : trimmed;
    };

    var fieldIdLookup = new Dictionary<string, string>(System.StringComparer.OrdinalIgnoreCase)
    {
        ["Name"] = Html.IdFor(m => m.Input.Name),
        ["Status"] = Html.IdFor(m => m.Input.Status),
        ["DueDate"] = Html.IdFor(m => m.Input.DueDate)
    };

    var modelErrors = ViewData.ModelState
        .Where(kvp => kvp.Value?.Errors?.Any() == true)
        .Select(kvp => new
        {
            Key = normaliseKey(kvp.Key),
            Errors = kvp.Value!.Errors
                .Select(error => error.ErrorMessage)
                .Where(message => !string.IsNullOrWhiteSpace(message))
                .ToList()
        })
        .Where(entry => entry.Errors.Any())
        .ToList();

    var hasModelErrors = modelErrors.Any();
    var errorSummaryClasses = hasModelErrors ? "card error-summary mb-3" : "card error-summary d-none mb-3";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-3">
            <div class="col-12">
                <a class="btn btn-link px-0 mb-2" href="@projectDetailsUrl" aria-label="Back to project">
                    <i class="fas fa-arrow-left mr-2" aria-hidden="true"></i>Back to project
                </a>
                <h1 class="mb-0">Edit milestone</h1>
                <p class="text-muted mb-0">@Model.Input.Name</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <form asp-action="UpdateMilestone" asp-controller="Project" method="post" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Input.ProjectId" />
            <input type="hidden" asp-for="Input.MilestoneId" />

            <div class="row">
                <div class="col-xl-8 col-lg-9 col-md-10">
                    <div id="milestone-edit-error-summary"
                         class="@errorSummaryClasses"
                         role="alert"
                         aria-labelledby="milestone-edit-error-summary-title"
                         @(hasModelErrors ? "tabindex=\"-1\" aria-hidden=\"false\"" : "aria-hidden=\"true\"")
                         data-module="error-summary">
                        <div class="card-body">
                            <h2 id="milestone-edit-error-summary-title" class="error-summary__title">There is a problem</h2>
                            <ul class="error-summary__list">
                                @if (hasModelErrors)
                                {
                                    foreach (var entry in modelErrors)
                                    {
                                        string fieldId = string.Empty;
                                        var hasLink = !string.IsNullOrWhiteSpace(entry.Key) && fieldIdLookup.TryGetValue(entry.Key, out fieldId);

                                        foreach (var message in entry.Errors)
                                        {
                                            if (hasLink)
                                            {
                                                <li><a href="#@fieldId">@message</a></li>
                                            }
                                            else
                                            {
                                                <li>@message</li>
                                            }
                                        }
                                    }
                                }
                            </ul>
                        </div>
                    </div>
                    <div class="card mb-4">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h3 class="card-title mb-0">Milestone details</h3>
                            @if (Model.ShowDeleteButton)
                            {
                                <button type="submit"
                                        class="btn btn-outline-danger btn-sm"
                                        formaction="@Url.Action("DeleteMilestone", "Project", new { projectId = Model.Input.ProjectId, milestoneId = Model.Input.MilestoneId })"
                                        formmethod="post"
                                        formnovalidate
                                        onclick="return confirm('Are you sure you want to delete this milestone?');">
                                    Delete
                                </button>
                            }
                        </div>
                        <div class="card-body">
                            <partial name="_MilestoneFormFields" model="Model" />
                        </div>
                        <div class="card-footer d-flex align-items-center">
                            <button type="submit" class="btn btn-primary mr-3">Save changes</button>
                            <a class="btn btn-outline-secondary" href="@projectDetailsUrl">Cancel</a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>
