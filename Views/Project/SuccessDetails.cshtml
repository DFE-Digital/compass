@model Compass.ViewModels.ProjectSuccessDetailsViewModel

@{
    ViewData["Title"] = $"Success details – {Model.ProjectTitle}";
    var returnUrl = Url.Action("Details", "Project", new { id = Model.ProjectId, tab = "successes" });
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2 align-items-center">
            <div class="col-sm-6">
                <h1 class="mb-0">Success details</h1>
                <p class="text-muted mb-0">Project: @Model.ProjectTitle</p>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Project" asp-action="Index">Projects</a></li>
                    <li class="breadcrumb-item"><a href="@returnUrl">Successes</a></li>
                    <li class="breadcrumb-item active">Success details</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-8 col-md-10">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h3 class="card-title mb-0">Recorded success</h3>
                        <div class="btn-group btn-group-sm" role="group">
                            <a class="btn btn-outline-secondary" asp-controller="Project" asp-action="EditSuccess" asp-route-projectId="@Model.ProjectId" asp-route-successId="@Model.SuccessId">Edit</a>
                            <form asp-controller="Project" asp-action="DeleteSuccess" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this success?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="projectId" value="@Model.ProjectId" />
                                <input type="hidden" name="successId" value="@Model.SuccessId" />
                                <button type="submit" class="btn btn-outline-danger">Delete</button>
                            </form>
                        </div>
                    </div>
                    <div class="card-body">
                        <dl class="row">
                            <dt class="col-sm-4">Description</dt>
                            <dd class="col-sm-8">@Model.SuccessDescription</dd>

                            <dt class="col-sm-4">Recorded by</dt>
                            <dd class="col-sm-8">
                                @if (!string.IsNullOrWhiteSpace(Model.RecordedByName))
                                {
                                    <span>@Model.RecordedByName</span>
                                    <br />
                                }
                                <span class="text-muted">@Model.RecordedByEmail</span>
                            </dd>

                            <dt class="col-sm-4">Recorded at</dt>
                            <dd class="col-sm-8">@Model.RecordedAt.ToString("dd MMM yyyy HH:mm") (UTC)</dd>

                            <dt class="col-sm-4">Reported to DDT</dt>
                            <dd class="col-sm-8">
                                @if (Model.IsReportedToSlt)
                                {
                                    <span class="badge badge-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">No</span>
                                }
                            </dd>
                        </dl>
                    </div>
                    <div class="card-footer">
                        <a class="btn btn-secondary" href="@returnUrl">Back to successes</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
