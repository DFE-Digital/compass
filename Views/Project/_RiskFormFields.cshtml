@model Compass.ViewModels.ProjectRiskFormViewModel

@{
    Func<string, bool> hasError = key =>
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return false;
        }

        if (ViewData.ModelState.TryGetValue(key, out var entry) && entry.Errors.Count > 0)
        {
            return true;
        }

        var inputKey = $"Input.{key}";
        if (ViewData.ModelState.TryGetValue(inputKey, out var inputEntry) && inputEntry.Errors.Count > 0)
        {
            return true;
        }

        return false;
    };
}

<div class="form-group @(hasError("Title") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.Title" class="font-weight-bold">Title</label>
    <small class="form-text text-muted">Give the risk a clear, searchable name.</small>
    <span asp-validation-for="Input.Title" class="form-error-message"></span>
    <input asp-for="Input.Title" class="form-control @(hasError("Title") ? "form-control--error" : string.Empty)" maxlength="200" required />
</div>

<div class="form-group @(hasError("Description") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.Description">Description</label>
    <small class="form-text text-muted">Describe the risk, its potential impact, and context.</small>
    <span asp-validation-for="Input.Description" class="form-error-message"></span>
    <textarea asp-for="Input.Description" class="form-control @(hasError("Description") ? "form-control--error" : string.Empty)" rows="4"></textarea>
</div>

<div class="form-group @(hasError("RiskStatusId") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.RiskStatusId">Status</label>
    <small class="form-text text-muted">Select the current status of this risk.</small>
    <span asp-validation-for="Input.RiskStatusId" class="form-error-message"></span>
    <select asp-for="Input.RiskStatusId" class="form-control @(hasError("RiskStatusId") ? "form-control--error" : string.Empty)" asp-items="Model.RiskStatusOptions">
        <option value="">Not set</option>
    </select>
</div>

<div class="form-group @(hasError("RiskPriorityId") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.RiskPriorityId">Priority</label>
    <small class="form-text text-muted">Select the priority level for this risk.</small>
    <span asp-validation-for="Input.RiskPriorityId" class="form-error-message"></span>
    <select asp-for="Input.RiskPriorityId" class="form-control @(hasError("RiskPriorityId") ? "form-control--error" : string.Empty)" asp-items="Model.RiskPriorityOptions">
        <option value="">Not set</option>
    </select>
</div>

<div class="form-group @(hasError("RiskCategoryId") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.RiskCategoryId">Category</label>
    <small class="form-text text-muted">Select the category classification for this risk.</small>
    <span asp-validation-for="Input.RiskCategoryId" class="form-error-message"></span>
    <select asp-for="Input.RiskCategoryId" class="form-control @(hasError("RiskCategoryId") ? "form-control--error" : string.Empty)" asp-items="Model.RiskCategoryOptions">
        <option value="">Not set</option>
    </select>
</div>

<div class="form-group @(hasError("RiskTierId") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.RiskTierId">Risk tier</label>
    <small class="form-text text-muted">Defines the tier of risk management (project/programme/portfolio/department/cross-government).</small>
    <span asp-validation-for="Input.RiskTierId" class="form-error-message"></span>
    <select asp-for="Input.RiskTierId" class="form-control @(hasError("RiskTierId") ? "form-control--error" : string.Empty)" asp-items="Model.RiskTierOptions">
        <option value="">Not set</option>
    </select>
</div>

<div class="form-group @(hasError("RiskImpactLevelId") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.RiskImpactLevelId">Impact level</label>
    <small class="form-text text-muted">Select the impact level classification.</small>
    <span asp-validation-for="Input.RiskImpactLevelId" class="form-error-message"></span>
    <select asp-for="Input.RiskImpactLevelId" class="form-control @(hasError("RiskImpactLevelId") ? "form-control--error" : string.Empty)" asp-items="Model.RiskImpactLevelOptions">
        <option value="">Not set</option>
    </select>
</div>

<div class="form-group @(hasError("RiskLikelihoodId") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.RiskLikelihoodId">Likelihood</label>
    <small class="form-text text-muted">Select the likelihood classification.</small>
    <span asp-validation-for="Input.RiskLikelihoodId" class="form-error-message"></span>
    <select asp-for="Input.RiskLikelihoodId" class="form-control @(hasError("RiskLikelihoodId") ? "form-control--error" : string.Empty)" asp-items="Model.RiskLikelihoodOptions">
        <option value="">Not set</option>
    </select>
</div>

<div class="form-group @(hasError("RiskProximityId") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.RiskProximityId">Proximity</label>
    <small class="form-text text-muted">Select the proximity classification.</small>
    <span asp-validation-for="Input.RiskProximityId" class="form-error-message"></span>
    <select asp-for="Input.RiskProximityId" class="form-control @(hasError("RiskProximityId") ? "form-control--error" : string.Empty)" asp-items="Model.RiskProximityOptions">
        <option value="">Not set</option>
    </select>
</div>

<div class="form-group @(hasError("GovernanceBoardId") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.GovernanceBoardId">Governance board</label>
    <small class="form-text text-muted">Select the governance board responsible for this risk.</small>
    <span asp-validation-for="Input.GovernanceBoardId" class="form-error-message"></span>
    <select asp-for="Input.GovernanceBoardId" class="form-control @(hasError("GovernanceBoardId") ? "form-control--error" : string.Empty)" asp-items="Model.GovernanceBoardOptions">
        <option value="">Not set</option>
    </select>
</div>

<div class="form-group @(hasError("IdentifiedDate") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.IdentifiedDate">Identified date</label>
    <small class="form-text text-muted">Date when this risk was first identified.</small>
    <span asp-validation-for="Input.IdentifiedDate" class="form-error-message"></span>
    <input asp-for="Input.IdentifiedDate" class="form-control @(hasError("IdentifiedDate") ? "form-control--error" : string.Empty)" type="date" />
</div>

<div class="form-group">
    <label asp-for="Input.HowIdentified">How identified</label>
    <small class="form-text text-muted">Describe how this risk was identified (e.g. risk workshop, project review, lessons learned).</small>
    <span asp-validation-for="Input.HowIdentified" class="form-error-message"></span>
    <textarea asp-for="Input.HowIdentified" class="form-control" rows="2"></textarea>
</div>

<div class="form-group @(hasError("NextReviewDate") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.NextReviewDate">Next review date</label>
    <small class="form-text text-muted">Date when this risk should next be reviewed.</small>
    <span asp-validation-for="Input.NextReviewDate" class="form-error-message"></span>
    <input asp-for="Input.NextReviewDate" class="form-control @(hasError("NextReviewDate") ? "form-control--error" : string.Empty)" type="date" />
</div>

<div class="form-group @(hasError("ProximityDate") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.ProximityDate">Proximity date</label>
    <small class="form-text text-muted">When the risk is likely to materialise.</small>
    <span asp-validation-for="Input.ProximityDate" class="form-error-message"></span>
    <input asp-for="Input.ProximityDate" class="form-control @(hasError("ProximityDate") ? "form-control--error" : string.Empty)" type="date" />
</div>

<div class="form-group">
    <label>Risk types</label>
    <small class="form-text text-muted">Select one or more risk type classifications to categorise this risk.</small>
    <span asp-validation-for="Input.SelectedRiskTypeIds" class="form-error-message"></span>
    <div class="form-check-group">
        @foreach (var option in Model.RiskTypeOptions)
        {
            <div class="form-check">
                <input class="form-check-input" 
                       type="checkbox" 
                       name="Input.SelectedRiskTypeIds" 
                       value="@option.Value" 
                       id="riskType_@option.Value"
                       @(option.Selected ? "checked" : "") />
                <label class="form-check-label" for="riskType_@option.Value">
                    @option.Text
                </label>
            </div>
        }
    </div>
</div>

<div class="form-group @(hasError("Response") ? "form-group--error" : string.Empty)">
    <label asp-for="Input.Response">Response strategy</label>
    <small class="form-text text-muted">Select the strategy for responding to this risk (e.g. avoid, mitigate, transfer, accept).</small>
    <span asp-validation-for="Input.Response" class="form-error-message"></span>
    <select asp-for="Input.Response" class="form-control @(hasError("Response") ? "form-control--error" : string.Empty)">
        <option value="">Not set</option>
        <option value="avoid">Avoid</option>
        <option value="mitigate">Mitigate</option>
        <option value="transfer">Transfer</option>
        <option value="accept">Accept</option>
    </select>
</div>

<div class="form-group">
    <label asp-for="Input.ResponseStrategy">Response strategy details</label>
    <small class="form-text text-muted">Describe the strategy for responding to this risk (e.g. Mitigate via service redesign).</small>
    <span asp-validation-for="Input.ResponseStrategy" class="form-error-message"></span>
    <textarea asp-for="Input.ResponseStrategy" class="form-control" rows="2" placeholder="e.g. Mitigate via service redesign"></textarea>
</div>

<div class="form-group @(hasError("OwnerEmail") ? "form-group--error" : string.Empty)">
    <label for="riskOwnerSearch">Risk owner</label>
    <small class="form-text text-muted">Search the Entra directory. Leave blank if unassigned.</small>
    <span asp-validation-for="Input.OwnerEmail" class="form-error-message"></span>
    <div class="user-picker"
         data-user-picker
         data-search-url="/api/users/search"
         data-select-url="/api/users/select">
        <div class="position-relative">
            <input type="text"
                   class="form-control js-user-picker-input @(hasError("OwnerEmail") ? "form-control--error" : string.Empty)"
                   id="riskOwnerSearch"
                   autocomplete="off"
                   placeholder="e.g. Alex Smith or alex.smith@education.gov.uk"
                   value="@(Model.Input.OwnerName ?? string.Empty)" />
            <span class="user-picker__spinner js-user-picker-spinner" aria-hidden="true">Searching…</span>
            <div class="user-picker__results js-user-picker-results" role="listbox" aria-live="polite"></div>
        </div>
        <p class="form-text text-muted js-user-picker-message"></p>
        <input asp-for="Input.OwnerUserId" type="hidden" class="js-user-picker-value" />
        <input asp-for="Input.OwnerName" type="hidden" class="js-user-picker-name" />
        <input asp-for="Input.OwnerEmail" type="hidden" class="js-user-picker-email" />
        <div class="user-picker__selected js-user-picker-summary" data-default-text="No owner selected.">
            @if (!string.IsNullOrWhiteSpace(Model.Input.OwnerName))
            {
                <div class="user-picker__selected-card">
                    <div class="user-picker__selected-name">@Model.Input.OwnerName</div>
                    @if (!string.IsNullOrWhiteSpace(Model.Input.OwnerEmail))
                    {
                        <div class="user-picker__selected-meta">@Model.Input.OwnerEmail</div>
                    }
                    <button type="button" class="btn btn-link btn-sm js-user-picker-clear">Remove</button>
                </div>
            }
            else
            {
                <span class="text-muted">No owner selected.</span>
            }
        </div>
    </div>
</div>

<div class="form-group">
    <label asp-for="Input.BusinessArea">Business area</label>
    <small class="form-text text-muted">Select the business area this risk relates to (optional).</small>
    <select asp-for="Input.BusinessArea" class="form-control" asp-items="Model.BusinessAreaOptions">
        <option value="">Not set</option>
    </select>
</div>

<div class="form-group">
    <label asp-for="Input.Notes">Notes</label>
    <small class="form-text text-muted">Additional notes or context about this risk.</small>
    <span asp-validation-for="Input.Notes" class="form-error-message"></span>
    <textarea asp-for="Input.Notes" class="form-control" rows="3"></textarea>
</div>

<div class="form-group">
    <label>Linked issues</label>
    <small class="form-text text-muted">Start typing to find issues from this project and others.</small>
    <select asp-for="Input.LinkedIssueIds"
            class="form-control js-linked-entity-select"
            data-search-url="@Url.Action("SearchIssuesForRisk", "Project", new { projectId = Model.Input.ProjectId })"
            data-project-id="@Model.Input.ProjectId"
            data-placeholder="Search issues"
            multiple>
        @foreach (var option in Model.IssueOptions ?? new List<SelectListItem>())
        {
            <option value="@option.Value" selected="@option.Selected">@option.Text</option>
        }
    </select>
    <span asp-validation-for="Input.LinkedIssueIds" class="form-error-message"></span>
</div>

<div class="form-group">
    <label>Linked actions</label>
    <small class="form-text text-muted">Start typing to find actions from this project and others.</small>
    <select asp-for="Input.LinkedActionIds"
            class="form-control js-linked-entity-select"
            data-search-url="@Url.Action("SearchActionsForRisk", "Project", new { projectId = Model.Input.ProjectId })"
            data-project-id="@Model.Input.ProjectId"
            data-placeholder="Search actions"
            multiple>
        @foreach (var option in Model.ActionOptions ?? new List<SelectListItem>())
        {
            <option value="@option.Value" selected="@option.Selected">@option.Text</option>
        }
    </select>
    <span asp-validation-for="Input.LinkedActionIds" class="form-error-message"></span>
</div>

<div class="form-group">
    <label>Linked decisions</label>
    <small class="form-text text-muted">Start typing to find decisions from this project and others.</small>
    <select asp-for="Input.LinkedDecisionIds"
            class="form-control js-linked-entity-select"
            data-search-url="@Url.Action("SearchDecisionsForRisk", "Project", new { projectId = Model.Input.ProjectId })"
            data-project-id="@Model.Input.ProjectId"
            data-placeholder="Search decisions"
            multiple>
        @foreach (var option in Model.DecisionOptions ?? new List<SelectListItem>())
        {
            <option value="@option.Value" selected="@option.Selected">@option.Text</option>
        }
    </select>
    <span asp-validation-for="Input.LinkedDecisionIds" class="form-error-message"></span>
</div>

<input asp-for="Input.ProjectId" type="hidden" />
<input asp-for="Input.RiskId" type="hidden" />

