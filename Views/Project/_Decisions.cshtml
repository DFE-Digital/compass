@model Compass.Models.Project
@{
    var decisions = Model.Decisions.Where(d => !d.IsDeleted).OrderByDescending(d => d.DecisionDate ?? d.CreatedAt).ToList();
    var pendingCount = decisions.Count(d => d.Status == "pending");
    var approvedCount = decisions.Count(d => d.Status == "approved");
    var rejectedCount = decisions.Count(d => d.Status == "rejected");
    var supersededCount = decisions.Count(d => d.Status == "superseded");
}

<div class="card" id="decisions">
    <div class="card-header">
        <h3 class="card-title">Work decisions</h3>
        <div class="card-tools">
            <a asp-controller="Project" asp-action="CreateDecision" asp-route-projectId="@Model.Id">Add decision</a>
        </div>
    </div>
    <div class="card-body table-responsive p-0">
        @if (decisions.Any())
        {
            <table class="table table-hover text-nowrap sortable-table">
                <thead>
                    <tr>
                        <th class="sortable" data-column="Title" tabindex="0" role="button" aria-label="Sort by Title">
                            Title
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="Status" tabindex="0" role="button" aria-label="Sort by Status" style="width: 140px;">
                            Status
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="DecisionDate" tabindex="0" role="button" aria-label="Sort by Decision date" style="width: 150px;">
                            Decision date
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="sortable" data-column="Owner" tabindex="0" role="button" aria-label="Sort by Owner" style="width: 200px;">
                            Owner
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th style="width: 220px;">Linked risks &amp; issues</th>
                        <th style="width: 220px;">Linked actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var decision in decisions)
                    {
                        var riskLinks = decision.RiskDecisions.Select(rd => rd.Risk).Where(r => r != null && !r.IsDeleted).OrderBy(r => r!.Title).ToList();
                        var issueLinks = decision.IssueDecisions.Select(idl => idl.Issue).Where(i => i != null && !i.IsDeleted).OrderBy(i => i!.Title).ToList();
                        var actionLinks = decision.Actions.Where(a => !a.IsDeleted).OrderBy(a => a.Title).ToList();
                        var decisionReferenceDate = decision.DecisionDate ?? decision.CreatedAt;
                        <tr>
                            <td>
                                <a asp-controller="Decision" asp-action="Details" asp-route-id="@decision.Id">@decision.Title</a>
                                @if (!string.IsNullOrWhiteSpace(decision.Summary))
                                {
                                    <small class="text-muted d-block">@decision.Summary</small>
                                }
                                @if (!string.IsNullOrWhiteSpace(decision.Outcome))
                                {
                                    <small class="text-muted d-block"><i class="fas fa-flag-checkered mr-1"></i>@decision.Outcome</small>
                                }
                                @if (!string.IsNullOrWhiteSpace(decision.BusinessArea))
                                {
                                    <small class="text-muted d-block"><i class="fas fa-sitemap mr-1"></i>@decision.BusinessArea</small>
                                }
                            </td>
                            <td>
                                @switch (decision.Status)
                                {
                                    case "pending":
                                        <span class="badge badge-warning">Pending</span>
                                        break;
                                    case "approved":
                                        <span class="badge badge-success">Approved</span>
                                        break;
                                    case "rejected":
                                        <span class="badge badge-danger">Rejected</span>
                                        break;
                                    case "superseded":
                                        <span class="badge badge-secondary">Superseded</span>
                                        break;
                                    default:
                                        <span class="badge badge-secondary">@decision.Status</span>
                                        break;
                                }
                            </td>
                            <td>
                                @if (decision.DecisionDate.HasValue)
                                {
                                    @decision.DecisionDate.Value.ToString("d MMMM yyyy")
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                            <td>
                                @if (decision.OwnerUser != null)
                                {
                                    <span>@decision.OwnerUser.Name</span>
                                    <br /><small class="text-muted">@decision.OwnerUser.Email</small>
                                }
                                else
                                {
                                    <span class="text-muted">Not assigned</span>
                                }
                            </td>
                            <td>
                                @if (riskLinks.Any())
                                {
                                    foreach (var risk in riskLinks)
                                    {
                                        <span class="badge badge-warning mr-1 mb-1"><i class="fas fa-exclamation-triangle mr-1"></i>@risk!.Title</span>
                                    }
                                }
                                @if (issueLinks.Any())
                                {
                                    foreach (var issue in issueLinks)
                                    {
                                        <span class="badge badge-info mr-1 mb-1"><i class="fas fa-bug mr-1"></i>@issue!.Title</span>
                                    }
                                }
                                @if (!riskLinks.Any() && !issueLinks.Any())
                                {
                                    <span class="text-muted">No linked risks or issues</span>
                                }
                            </td>
                            <td>
                                @if (actionLinks.Any())
                                {
                                    foreach (var action in actionLinks)
                                    {
                                        <span class="badge badge-primary mr-1 mb-1"><i class="fas fa-tasks mr-1"></i>@action.Title</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">No linked actions</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="p-3">
                <p class="text-muted mb-2">No decisions recorded for this work item yet.</p>
                <a asp-controller="Project" asp-action="CreateDecision" asp-route-projectId="@Model.Id">Add the first decision</a>
            </div>
        }
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
    (function() {
        function initSorting(table) {
            var sortableHeaders = table.querySelectorAll('.sortable');
            var currentSort = { column: null, direction: 'asc' };
            
            sortableHeaders.forEach(function(header) {
                header.style.cursor = 'pointer';
                
                header.addEventListener('click', function(e) {
                    handleSort(e, header);
                });
                
                header.addEventListener('keypress', function(e) {
                    if (e.which === 13 || e.which === 32) {
                        e.preventDefault();
                        handleSort(e, header);
                    }
                });
            });
            
            function handleSort(e, header) {
                var column = header.getAttribute('data-column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(column, direction);
                currentSort = { column: column, direction: direction };
            }
            
            function sortTable(column, direction) {
                var tbody = table.querySelector('tbody');
                var rows = Array.from(tbody.querySelectorAll('tr'));
                var colIndex = Array.from(table.querySelectorAll('thead th')).findIndex(function(th) {
                    return th.getAttribute('data-column') === column;
                });
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var aCell = a.querySelectorAll('td')[colIndex];
                    var bCell = b.querySelectorAll('td')[colIndex];
                    
                    if (column === 'Status') {
                        // Sort by badge text
                        var aBadge = aCell.querySelector('.badge');
                        var bBadge = bCell.querySelector('.badge');
                        aVal = aBadge ? aBadge.textContent.trim().toLowerCase() : '';
                        bVal = bBadge ? bBadge.textContent.trim().toLowerCase() : '';
                    } else if (column === 'Title') {
                        // Sort by link text
                        var aLink = aCell.querySelector('a');
                        var bLink = bCell.querySelector('a');
                        aVal = aLink ? aLink.textContent.trim().toLowerCase() : aCell.textContent.trim().toLowerCase();
                        bVal = bLink ? bLink.textContent.trim().toLowerCase() : bCell.textContent.trim().toLowerCase();
                    } else if (column === 'DecisionDate') {
                        // Sort by date
                        var aDate = Date.parse(aCell.textContent.trim());
                        var bDate = Date.parse(bCell.textContent.trim());
                        aVal = isNaN(aDate) ? 0 : aDate;
                        bVal = isNaN(bDate) ? 0 : bDate;
                    } else {
                        aVal = aCell.textContent.trim().toLowerCase();
                        bVal = bCell.textContent.trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.innerHTML = '';
                rows.forEach(function(row) {
                    tbody.appendChild(row);
                });
                
                updateSortIcons(column, direction);
            }
            
            function updateSortIcons(column, direction) {
                var allHeaders = table.querySelectorAll('.sortable i');
                allHeaders.forEach(function(icon) {
                    icon.className = 'fas fa-sort float-right';
                    icon.style.opacity = '0.3';
                });
                
                var activeHeader = table.querySelector('.sortable[data-column="' + column + '"]');
                if (activeHeader) {
                    var icon = activeHeader.querySelector('i');
                    if (icon) {
                        icon.className = direction === 'asc' ? 'fas fa-sort-up float-right' : 'fas fa-sort-down float-right';
                        icon.style.opacity = '1';
                    }
                }
            }
        }
        
        var table = document.querySelector('#decisions .sortable-table');
        if (table) {
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function() { initSorting(table); });
            } else {
                initSorting(table);
            }
        }
    })();
</script>
