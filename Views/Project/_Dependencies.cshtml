@model Compass.Models.Project

@{
    // Get dependencies where this project is the source
    var outgoingDependencies = Model.DependenciesAsSource.OrderByDescending(d => d.CreatedAt).ToList();
    
    // Get dependencies where this project is the target
    var incomingDependencies = Model.DependenciesAsTarget.OrderByDescending(d => d.CreatedAt).ToList();
}

<div class="card mb-4" id="outgoing-dependencies">
    <div class="card-header">
        <div>
            <h3 class="card-title mb-0">Things this project depends on</h3>
        </div>
        <div class="card-tools">
            <a asp-controller="Project" asp-action="CreateDependency" asp-route-projectId="@Model.Id">Add dependency</a>
        </div>
    </div>
    <div class="card-body table-responsive p-0">
        @if (outgoingDependencies.Any())
        {
            <table class="table table-hover text-nowrap sortable-table dependencies-table">
                <thead>
                    <tr>
                        <th class="col-title sortable" data-column="Title" tabindex="0" role="button" aria-label="Sort by title">
                            Dependency
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="col-type sortable" data-column="Type" tabindex="0" role="button" aria-label="Sort by type">
                            Type
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="col-created sortable" data-column="Created" tabindex="0" role="button" aria-label="Sort by created">
                            Created
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dependency in outgoingDependencies)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Project" asp-action="DependencyDetails" asp-route-projectId="@Model.Id" asp-route-dependencyId="@dependency.Id">
                                    @(string.IsNullOrWhiteSpace(dependency.TargetEntityTitle) ? "View details" : dependency.TargetEntityTitle)
                                </a>
                            </td>
                            <td>@(dependency.DependencyType ?? "Related")</td>
                            <td>@dependency.CreatedAt.ToString("d MMMM yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="p-3">
                <p class="text-muted mb-2">No outgoing dependencies recorded.</p>
                <a asp-controller="Project" asp-action="CreateDependency" asp-route-projectId="@Model.Id" class="text-block-link">Add the first dependency</a>
            </div>
        }
    </div>
</div>

<div class="card" id="incoming-dependencies">
    <div class="card-header">
        <div>
            <h3 class="card-title mb-0">Dependencies on this project</h3>
        </div>
    </div>
    <div class="card-body table-responsive p-0">
        @if (incomingDependencies.Any())
        {
            <table class="table table-hover text-nowrap sortable-table dependencies-table">
                <thead>
                    <tr>
                        <th class="col-title sortable" data-column="Title" tabindex="0" role="button" aria-label="Sort by title">
                            Dependency
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="col-type sortable" data-column="Type" tabindex="0" role="button" aria-label="Sort by type">
                            Type
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                        <th class="col-created sortable" data-column="Created" tabindex="0" role="button" aria-label="Sort by created">
                            Created
                            <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dependency in incomingDependencies)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Project" asp-action="DependencyDetails" asp-route-projectId="@Model.Id" asp-route-dependencyId="@dependency.Id">
                                    @(string.IsNullOrWhiteSpace(dependency.SourceEntityTitle) ? "View details" : dependency.SourceEntityTitle)
                                </a>
                            </td>
                            <td>@(dependency.DependencyType ?? "Related")</td>
                            <td>@dependency.CreatedAt.ToString("d MMMM yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="p-3">
                <p class="text-muted mb-0">No incoming dependencies recorded.</p>
            </div>
        }
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
    (function() {
        function initSorting(table) {
            var sortableHeaders = table.querySelectorAll('.sortable');
            var currentSort = { column: null, direction: 'asc' };
            
            sortableHeaders.forEach(function(header) {
                header.style.cursor = 'pointer';
                
                header.addEventListener('click', function(e) {
                    handleSort(e, header);
                });
                
                header.addEventListener('keypress', function(e) {
                    if (e.which === 13 || e.which === 32) {
                        e.preventDefault();
                        handleSort(e, header);
                    }
                });
            });
            
            function handleSort(e, header) {
                var column = header.getAttribute('data-column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(column, direction);
                currentSort = { column: column, direction: direction };
            }
            
            function sortTable(column, direction) {
                var tbody = table.querySelector('tbody');
                var rows = Array.from(tbody.querySelectorAll('tr'));
                var colIndex = Array.from(table.querySelectorAll('thead th')).findIndex(function(th) {
                    return th.getAttribute('data-column') === column;
                });
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var aCell = a.querySelectorAll('td')[colIndex];
                    var bCell = b.querySelectorAll('td')[colIndex];
                    
                    if (column === 'Title') {
                        // Sort by link text
                        var aLink = aCell.querySelector('a');
                        var bLink = bCell.querySelector('a');
                        aVal = aLink ? aLink.textContent.trim().toLowerCase() : aCell.textContent.trim().toLowerCase();
                        bVal = bLink ? bLink.textContent.trim().toLowerCase() : bCell.textContent.trim().toLowerCase();
                    } else if (column === 'Created') {
                        // Sort by date
                        var aDate = Date.parse(aCell.textContent.trim());
                        var bDate = Date.parse(bCell.textContent.trim());
                        aVal = isNaN(aDate) ? 0 : aDate;
                        bVal = isNaN(bDate) ? 0 : bDate;
                    } else {
                        aVal = aCell.textContent.trim().toLowerCase();
                        bVal = bCell.textContent.trim().toLowerCase();
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.innerHTML = '';
                rows.forEach(function(row) {
                    tbody.appendChild(row);
                });
                
                updateSortIcons(column, direction);
            }
            
            function updateSortIcons(column, direction) {
                var allHeaders = table.querySelectorAll('.sortable i');
                allHeaders.forEach(function(icon) {
                    icon.className = 'fas fa-sort float-right';
                    icon.style.opacity = '0.3';
                });
                
                var activeHeader = table.querySelector('.sortable[data-column="' + column + '"]');
                if (activeHeader) {
                    var icon = activeHeader.querySelector('i');
                    if (icon) {
                        icon.className = direction === 'asc' ? 'fas fa-sort-up float-right' : 'fas fa-sort-down float-right';
                        icon.style.opacity = '1';
                    }
                }
            }
        }
        
        // Initialize both dependency tables
        var outgoingTable = document.querySelector('#outgoing-dependencies .sortable-table');
        if (outgoingTable) {
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function() { initSorting(outgoingTable); });
            } else {
                initSorting(outgoingTable);
            }
        }
        
        var incomingTable = document.querySelector('#incoming-dependencies .sortable-table');
        if (incomingTable) {
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function() { initSorting(incomingTable); });
            } else {
                initSorting(incomingTable);
            }
        }
    })();
</script>
