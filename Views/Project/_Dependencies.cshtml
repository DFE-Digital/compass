@model Compass.Models.Project

@{
    // Get dependencies where this project is the source
    var outgoingDependencies = Model.DependenciesAsSource.OrderByDescending(d => d.CreatedAt).ToList();
    
    // Get dependencies where this project is the target
    var incomingDependencies = Model.DependenciesAsTarget.OrderByDescending(d => d.CreatedAt).ToList();
}

<div class="card mb-4" id="outgoing-dependencies">
    <div class="card-header">
        <div>
            <h3 class="card-title mb-0">Things this project depends on</h3>
            <p class="text-muted small mb-0">Other programmes, services or interventions this project requires.</p>
        </div>
        <div class="card-tools">
            <a asp-controller="Project" asp-action="CreateDependency" asp-route-projectId="@Model.Id">Add dependency</a>
        </div>
    </div>
    <div class="card-body table-responsive p-0">
        @if (outgoingDependencies.Any())
        {
            <table class="table table-hover text-nowrap sortable-table dependencies-table">
                <thead>
                    <tr>
                        <th class="col-title sortable" data-column="Title" tabindex="0" role="button" aria-label="Sort by title">Dependency</th>
                        <th class="col-type sortable" data-column="Type" tabindex="0" role="button" aria-label="Sort by type">Type</th>
                        <th class="col-created sortable" data-column="Created" tabindex="0" role="button" aria-label="Sort by created">Created</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dependency in outgoingDependencies)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Project" asp-action="DependencyDetails" asp-route-projectId="@Model.Id" asp-route-dependencyId="@dependency.Id">
                                    @(string.IsNullOrWhiteSpace(dependency.TargetEntityTitle) ? "View details" : dependency.TargetEntityTitle)
                                </a>
                            </td>
                            <td>@(dependency.DependencyType ?? "Related")</td>
                            <td>@dependency.CreatedAt.ToString("d MMMM yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="p-4">
                <p class="text-muted mb-2">No outgoing dependencies recorded.</p>
                <a asp-controller="Project" asp-action="CreateDependency" asp-route-projectId="@Model.Id" class="text-block-link">Add the first dependency</a>
            </div>
        }
    </div>
</div>

<div class="card" id="incoming-dependencies">
    <div class="card-header">
        <div>
            <h3 class="card-title mb-0">Dependencies on this project</h3>
            <p class="text-muted small mb-0">Projects and services that rely on this work to progress.</p>
        </div>
    </div>
    <div class="card-body table-responsive p-0">
        @if (incomingDependencies.Any())
        {
            <table class="table table-hover text-nowrap sortable-table dependencies-table">
                <thead>
                    <tr>
                        <th class="col-title sortable" data-column="Title" tabindex="0" role="button" aria-label="Sort by title">Dependency</th>
                        <th class="col-type sortable" data-column="Type" tabindex="0" role="button" aria-label="Sort by type">Type</th>
                        <th class="col-created sortable" data-column="Created" tabindex="0" role="button" aria-label="Sort by created">Created</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dependency in incomingDependencies)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Project" asp-action="DependencyDetails" asp-route-projectId="@Model.Id" asp-route-dependencyId="@dependency.Id">
                                    @(string.IsNullOrWhiteSpace(dependency.SourceEntityTitle) ? "View details" : dependency.SourceEntityTitle)
                                </a>
                            </td>
                            <td>@(dependency.DependencyType ?? "Related")</td>
                            <td>@dependency.CreatedAt.ToString("d MMMM yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="p-4">
                <p class="text-muted mb-0">No incoming dependencies recorded.</p>
            </div>
        }
    </div>
</div>
