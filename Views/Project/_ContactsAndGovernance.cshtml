                        </div>
                    `;
                });
                html += '</div>';
                
                container.innerHTML = html;
                hiddenInput.value = selectedSrosModal.map(s => s.id).join(',');
                
                // Attach event listeners to remove buttons using event delegation
                $(container).off('click', '.remove-sro-btn').on('click', '.remove-sro-btn', function(e) {
                    e.preventDefault();
                    const sroId = $(this).data('sro-id');
                    if (sroId) {
                        removeSroModal(sroId);
                    }
                });
            }

            // Make removeSroModal available globally for backward compatibility
            window.removeSroModal = removeSroModal;
            
            // Ensure hidden input is set before form submission
            $('#editSrosModal form').on('submit', function(e) {
                const hiddenInput = document.getElementById('selectedSroUserIdsModal');
                if (hiddenInput) {
                    hiddenInput.value = selectedSrosModal.map(s => s.id).join(',');
                }
            });

            // ========================================
            // PMO Contacts Modal
