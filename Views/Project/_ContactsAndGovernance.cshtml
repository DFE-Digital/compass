                        <div class="badge badge-primary mr-2 mb-2 d-flex align-items-center">
                            ${escapedName}${escapedEmail ? ` (${escapedEmail})` : ''}
                            <button type="button" class="btn btn-sm btn-outline-light ml-2 remove-serviceowner-btn" data-serviceowner-id="${escapedId}" aria-label="Remove ${escapedName}">×</button>
                        </div>
                    `;
                });
                html += '</div>';
                
                container.innerHTML = html;
                hiddenInput.value = selectedServiceOwnersModal.map(so => so.id).join(',');
                
                // Attach event listeners to remove buttons using event delegation
                $(container).off('click', '.remove-serviceowner-btn').on('click', '.remove-serviceowner-btn', function(e) {
                    e.preventDefault();
                    const serviceOwnerId = $(this).data('serviceowner-id');
                    if (serviceOwnerId) {
                        removeServiceOwnerModal(serviceOwnerId);
                    }
                });
            }

            // Make removeServiceOwnerModal available globally
            window.removeServiceOwnerModal = removeServiceOwnerModal;
            
            // Ensure hidden input is set before form submission
            $('#editServiceOwnersModal form').on('submit', function(e) {
                const hiddenInput = document.getElementById('selectedServiceOwnerUserIdsModal');
                if (hiddenInput) {
                    hiddenInput.value = selectedServiceOwnersModal.map(so => so.id).join(',');
                }
            });
            
            // Initialize governance table sorting
            function initGovernanceTableSorting() {
                var table = document.querySelector('.sortable-table.mb-0');
                if (!table) {
                    return;
                }
                
                var currentSort = { column: null, direction: 'asc' };
                var sortableHeaders = table.querySelectorAll('.sortable');
                
                sortableHeaders.forEach(function(header) {
                    header.style.cursor = 'pointer';
                    
                    header.addEventListener('click', function(e) {
                        handleSort(e, header);
                    });
                    
                    header.addEventListener('keypress', function(e) {
                        if (e.which === 13 || e.which === 32) {
                            e.preventDefault();
                            handleSort(e, header);
                        }
                    });
                });
                
                function handleSort(e, header) {
                    var column = header.getAttribute('data-column');
                    var direction = 'asc';
                    
                    if (currentSort.column === column && currentSort.direction === 'asc') {
                        direction = 'desc';
                    }
                    
                    sortTable(column, direction);
                    currentSort = { column: column, direction: direction };
                }
                
                function sortTable(column, direction) {
                    var tbody = table.querySelector('tbody');
                    var rows = Array.from(tbody.querySelectorAll('tr'));
                    var colIndex = Array.from(table.querySelectorAll('thead th')).findIndex(function(th) {
                        return th.getAttribute('data-column') === column;
                    });
                    
                    rows.sort(function(a, b) {
                        var aVal, bVal;
                        var aCell = a.querySelectorAll('td')[colIndex];
                        var bCell = b.querySelectorAll('td')[colIndex];
                        
                        aVal = aCell.textContent.trim().toLowerCase();
                        bVal = bCell.textContent.trim().toLowerCase();
                        
                        if (direction === 'asc') {
                            return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                        } else {
                            return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                        }
                    });
                    
                    tbody.innerHTML = '';
                    rows.forEach(function(row) {
                        tbody.appendChild(row);
                    });
                    
                    updateSortIcons(column, direction);
                }
                
                function updateSortIcons(column, direction) {
                    var allHeaders = table.querySelectorAll('.sortable i');
                    allHeaders.forEach(function(icon) {
                        icon.className = 'fas fa-sort float-right';
                        icon.style.opacity = '0.3';
                    });
                    
                    var activeHeader = table.querySelector('.sortable[data-column="' + column + '"]');
                    if (activeHeader) {
                        var icon = activeHeader.querySelector('i');
                        if (icon) {
                            icon.className = direction === 'asc' ? 'fas fa-sort-up float-right' : 'fas fa-sort-down float-right';
                            icon.style.opacity = '1';
                        }
                    }
                }
                
                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', initGovernanceTableSorting);
                } else {
                    initGovernanceTableSorting();
                }
            }
        }
        
        // Initialize when jQuery is ready
        if (typeof jQuery !== 'undefined') {
            jQuery(document).ready(initContactsAndGovernance);
        } else {
            document.addEventListener('DOMContentLoaded', function() {
                if (typeof jQuery !== 'undefined') {
                    jQuery(document).ready(initContactsAndGovernance);
                }
            });
        }
        
        // Handle clear primary contact button
        $('#clearPrimaryContactBtnContacts').on('click', function() {
            $('#editPrimaryContactModal .js-user-picker-value').val('');
            $('#editPrimaryContactModal .js-user-picker-input').val('');
            $('#editPrimaryContactModal .js-user-picker-summary').html('<span class="text-muted">No primary contact selected.</span>');
        });
    })();
</script>
