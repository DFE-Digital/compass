<script src="~/js/user-picker.js" asp-append-version="true"></script>
<script nonce="@Context.Items["Nonce"]">
    (function() {
        // Wait for jQuery to be available
        function initContactsAndGovernance() {
            if (typeof jQuery === 'undefined') {
                setTimeout(initContactsAndGovernance, 100);
                return;
            }
            
            const $ = jQuery;
            
            // ========================================
            // Senior Responsible Officers (SROs) Modal
            // ========================================
            let selectedSrosModal = [];

            // Handle user selection for SROs
            function handleSroUserSelected(e, user) {
                console.log('SRO userSelected event received:', e, user);
                
                // Extract user data - jQuery passes as second param, native event has detail
                let userData = null;
                if (user) {
                    // jQuery event with user as second parameter
                    userData = user;
                } else if (e && e.detail) {
                    // Native CustomEvent
                    userData = e.detail;
                } else if (e && e.originalEvent && e.originalEvent.detail) {
                    // jQuery wrapped native event
                    userData = e.originalEvent.detail;
                }
                
                console.log('Extracted user data:', userData);
                
                if (userData && (userData.objectId || userData.id)) {
                    const userId = userData.objectId || userData.id;
                    console.log('Adding SRO with ID:', userId);
                    addSroModal({
                        id: userId,
                        name: userData.name || '',
                        email: userData.email || ''
                    });
                    clearSroPicker();
                } else {
                    console.error('No valid user data found in event:', e, user);
                }
            }
        
            // Initialize with existing SROs and attach event listeners when modal opens
            $('#editSrosModal').on('shown.bs.modal', function() {
                selectedSrosModal = [];
                @if (Model.SeniorResponsibleOfficers != null && Model.SeniorResponsibleOfficers.Any())
                {
                    @foreach (var sro in Model.SeniorResponsibleOfficers)
                    {
                        @if (sro.User != null && !string.IsNullOrEmpty(sro.User.AzureObjectId))
                        {
                            <text>
                            selectedSrosModal.push({
                                id: '@sro.User.AzureObjectId',
                                name: '@Html.Raw(sro.User.Name?.Replace("'", "\\'") ?? "")',
                                email: '@Html.Raw(sro.User.Email?.Replace("'", "\\'") ?? "")'
                            });
                            </text>
                        }
                    }
                }
                updateSelectedSrosModal();
                clearSroPicker();
                
                // Ensure user picker is initialized (it should auto-initialize on DOMContentLoaded)
                // But we'll manually trigger initialization if needed for modals
                const sroPicker = document.getElementById('sroUserPicker');
                if (sroPicker && sroPicker.hasAttribute('data-user-picker') && !window.userPickerInstances) {
                    window.userPickerInstances = window.userPickerInstances || {};
                }
                
                // Attach event listeners - use both jQuery and native for maximum compatibility
                const sroInput = document.getElementById('sroSearchModal');
                if (sroInput) {
                    // Remove existing listeners to avoid duplicates
                    $(sroInput).off('userSelected');
                    sroInput.removeEventListener('userSelected', handleSroUserSelected);
                    
                    // Attach new listeners - use capture phase for native events
                    $(sroInput).on('userSelected', handleSroUserSelected);
                    sroInput.addEventListener('userSelected', handleSroUserSelected, true);
                    
                    // Also listen on the picker container as fallback
                    if (sroPicker) {
                        $(sroPicker).off('userSelected');
                        $(sroPicker).on('userSelected', handleSroUserSelected);
                    }
                }
            });
        
            // Document-level delegation as fallback (capture phase to catch early)
            document.addEventListener('userSelected', function(e) {
                if (e.target && e.target.id === 'sroSearchModal') {
                    handleSroUserSelected(e);
                }
            }, true);
            
            $(document).on('userSelected', '#sroSearchModal', handleSroUserSelected);

            function clearSroPicker() {
                const picker = document.getElementById('sroUserPicker');
                if (picker) {
                    const input = picker.querySelector('.js-user-picker-input');
                    const objectIdInput = picker.querySelector('.js-user-picker-objectid');
                    const nameInput = picker.querySelector('.js-user-picker-name');
                    const emailInput = picker.querySelector('.js-user-picker-email');
                    const summary = picker.querySelector('.js-user-picker-summary');
                    const message = picker.querySelector('.js-user-picker-message');
                    
                    if (input) input.value = '';
                    if (objectIdInput) objectIdInput.value = '';
                    if (nameInput) nameInput.value = '';
                    if (emailInput) emailInput.value = '';
                    if (summary) summary.innerHTML = '<span class="text-muted">No user selected.</span>';
                    if (message) message.textContent = '';
                }
            }

            function addSroModal(user) {
                console.log('addSroModal called with:', user);
                // Normalize the ID - use objectId if available, otherwise id
                const userId = user.objectId || user.id;
                if (!userId) {
                    console.error('No user ID found:', user);
                    return;
                }
                if (!selectedSrosModal.find(s => s.id === userId)) {
                    selectedSrosModal.push({
                        id: userId,
                        name: user.name || '',
                        email: user.email || ''
                    });
                    updateSelectedSrosModal();
                } else {
                    console.log('User already in list:', userId);
                }
            }

            function removeSroModal(userId) {
                // Remove any HTML entity encoding that jQuery might apply
                const decodedUserId = userId.replace(/&quot;/g, '"').replace(/&#39;/g, "'");
                selectedSrosModal = selectedSrosModal.filter(s => s.id !== decodedUserId && s.id !== userId);
                updateSelectedSrosModal();
            }

            function updateSelectedSrosModal() {
                const container = document.getElementById('selectedSrosModal');
                const hiddenInput = document.getElementById('selectedSroUserIdsModal');
                
                if (!container || !hiddenInput) return;
                
                if (selectedSrosModal.length === 0) {
                    container.innerHTML = '<div class="mt-2 text-muted">No SROs selected. Click "Save changes" to remove all SROs.</div>';
                    hiddenInput.value = '';
                    return;
                }
                
                let html = '<div class="mt-2"><strong>Selected SROs:</strong></div><div class="d-flex flex-wrap mt-2">';
                selectedSrosModal.forEach(sro => {
                    // Escape the ID properly for use in onclick attribute
                    const escapedId = sro.id.replace(/'/g, "\\'").replace(/"/g, '&quot;');
                    const escapedName = (sro.name || '').replace(/'/g, "\\'").replace(/"/g, '&quot;');
                    const escapedEmail = (sro.email || '').replace(/'/g, "\\'").replace(/"/g, '&quot;');
                    // Use data attribute instead of inline onclick for better reliability
                    html += `
                        <div class="badge badge-primary mr-2 mb-2 d-flex align-items-center">
                            ${escapedName}${escapedEmail ? ` (${escapedEmail})` : ''}
