@model Compass.Models.Project
@using System
@using System.Linq
@{
    var governanceContacts = Model.ProjectContacts?
        .Where(pc => string.Equals(pc.TeamStatus, "governance", StringComparison.OrdinalIgnoreCase))
        .OrderBy(pc => pc.SortOrder)
        .ToList() ?? new List<Compass.Models.ProjectContact>();
}

<div class="row">
    <div class="col-lg-12">
        <!-- Governance Structure -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Governance Structure</h3>
                <div class="card-tools">
                    <a href="#" class="card-link" data-toggle="modal" data-target="#addGovernanceContactModal">Add contact</a>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover text-nowrap sortable-table mb-0">
                        <thead>
                            <tr>
                                <th style="width: 25%;" class="sortable" data-column="Type" tabindex="0" role="button" aria-label="Sort by Type">
                                    Type
                                    <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                                </th>
                                <th style="width: 65%;" class="sortable" data-column="Information" tabindex="0" role="button" aria-label="Sort by Information">
                                    Information
                                    <i class="fas fa-sort float-right" style="opacity: 0.3;"></i>
                                </th>
                                <th style="width: 10%;" class="text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Senior Responsible Officers -->
                            <tr>
                                <td class="font-weight-bold">Senior Responsible Officer(s)</td>
                                <td>
                                    @if (Model.SeniorResponsibleOfficers?.Any() == true)
                                    {
                                        <div>
                                            @foreach (var sro in Model.SeniorResponsibleOfficers)
                                            {
                                                @if (sro.User != null)
                                                {
                                                    <div class="mb-1">
                                                        @if (!string.IsNullOrEmpty(sro.User.Email))
                                                        {
                                                            <a href="mailto:@sro.User.Email" class="font-weight-bold">@sro.User.Name</a>
                                                            <br />
                                                            <small class="text-muted">@sro.User.Email</small>
                                                        }
                                                        else
                                                        {
                                                            <span class="font-weight-bold">@sro.User.Name</span>
                                                        }
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No Senior Responsible Officers assigned.</span>
                                    }
                                </td>
                                <td class="text-right">
                                    <a href="#" data-toggle="modal" data-target="#editSrosModal">Change</a>
                                </td>
                            </tr>
                            
                            <!-- Service Owners -->
                            <tr>
                                <td class="font-weight-bold">Service Owner(s)</td>
                                <td>
                                    @if (Model.ServiceOwners?.Any() == true)
                                    {
                                        <div>
                                            @foreach (var serviceOwner in Model.ServiceOwners)
                                            {
                                                @if (serviceOwner.User != null)
                                                {
                                                    <div class="mb-1">
                                                        @if (!string.IsNullOrEmpty(serviceOwner.User.Email))
                                                        {
                                                            <a href="mailto:@serviceOwner.User.Email" class="font-weight-bold">@serviceOwner.User.Name</a>
                                                            <br />
                                                            <small class="text-muted">@serviceOwner.User.Email</small>
                                                        }
                                                        else
                                                        {
                                                            <span class="font-weight-bold">@serviceOwner.User.Name</span>
                                                        }
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No Service Owners assigned.</span>
                                    }
                                </td>
                                <td class="text-right">
                                    <a href="#" data-toggle="modal" data-target="#editServiceOwnersModal">Change</a>
                                </td>
                            </tr>
                            
                            <!-- Primary Contact -->
                            <tr>
                                <td class="font-weight-bold">Primary Contact</td>
                                <td>
                                    @if (Model.PrimaryContactUser != null)
                                    {
                                        <div class="mb-1">
                                            @if (!string.IsNullOrEmpty(Model.PrimaryContactUser.Email))
                                            {
                                                <a href="mailto:@Model.PrimaryContactUser.Email" class="font-weight-bold">@Model.PrimaryContactUser.Name</a>
                                                <br />
                                                <small class="text-muted">@Model.PrimaryContactUser.Email</small>
                                            }
                                            else
                                            {
                                                <span class="font-weight-bold">@Model.PrimaryContactUser.Name</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No primary contact assigned.</span>
                                    }
                                </td>
                                <td class="text-right">
                                    <a href="#" data-toggle="modal" data-target="#editPrimaryContactModal">Change</a>
                                </td>
                            </tr>
                            
                            <!-- PMO Contacts -->
                            <tr>
                                <td class="font-weight-bold">PMO Contacts</td>
                                <td>
                                    @if (Model.PmoContacts?.Any() == true)
                                    {
                                        <div>
                                            @foreach (var pmo in Model.PmoContacts)
                                            {
                                                @if (pmo.User != null)
                                                {
                                                    <div class="mb-1">
                                                        @if (!string.IsNullOrEmpty(pmo.User.Email))
                                                        {
                                                            <a href="mailto:@pmo.User.Email" class="font-weight-bold">@pmo.User.Name</a>
                                                            <br />
                                                            <small class="text-muted">@pmo.User.Email</small>
                                                        }
                                                        else
                                                        {
                                                            <span class="font-weight-bold">@pmo.User.Name</span>
                                                        }
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No PMO contacts assigned.</span>
                                    }
                                </td>
                                <td class="text-right">
                                    <a href="#" data-toggle="modal" data-target="#editPmoContactsModal">Change</a>
                                </td>
                            </tr>
                            
                            <!-- Directorates -->
                            <tr>
                                <td class="font-weight-bold">Directorate(s)</td>
                                <td>
                            @if (Model.Directorates?.Any() == true)
                            {
                                <div>
                                    @foreach (var directorate in Model.Directorates.OrderBy(d => d.Division != null ? d.Division.Name : ""))
                                    {
                                        @if (directorate.Division != null)
                                        {
                                            <div class="mb-1">
                                                <span class="font-weight-bold">@directorate.Division.Name</span>
                                                @if (!string.IsNullOrEmpty(directorate.Division.Description))
                                                {
                                                    <br />
                                                    <small class="text-muted">@directorate.Division.Description</small>
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                            }
                                    else
                                    {
                                        <span class="text-muted">No directorates assigned.</span>
                                    }
                                </td>
                                <td class="text-right">
                                    <a href="#" data-toggle="modal" data-target="#editDirectoratesModal">Change</a>
                                </td>
                            </tr>
                            
                            <!-- Budget Owners -->
                            <tr>
                                <td class="font-weight-bold">Budget Owner(s)</td>
                                <td>
                                    @if (Model.BudgetOwners?.Any() == true)
                                    {
                                        <div>
                                            @foreach (var budgetOwner in Model.BudgetOwners.OrderBy(bo => bo.BusinessAreaLookup != null ? bo.BusinessAreaLookup.Name : ""))
                                            {
                                                @if (budgetOwner.BusinessAreaLookup != null)
                                                {
                                                    <div class="mb-1">
                                                        <span class="font-weight-bold">@budgetOwner.BusinessAreaLookup.Name</span>
                                                        @if (!string.IsNullOrEmpty(budgetOwner.BusinessAreaLookup.Description))
                                                        {
                                                            <br />
                                                            <small class="text-muted">@budgetOwner.BusinessAreaLookup.Description</small>
                                                        }
                                                    </div>
                                                }
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No budget owners assigned.</span>
                                    }
                                </td>
                                <td class="text-right">
                                    <a href="#" data-toggle="modal" data-target="#editBudgetOwnersModal">Change</a>
                                </td>
                            </tr>
                            @foreach (var gc in governanceContacts)
                            {
                                <tr>
                                    <td class="font-weight-bold">@gc.Role</td>
                                    <td>
                                        @{
                                            var gcUser = gc.User;
                                            var displayName = gcUser?.Name ?? gc.Name;
                                            var displayEmail = gcUser?.Email ?? gc.Email;
                                        }
                                        @if (!string.IsNullOrEmpty(displayEmail))
                                        {
                                            <div class="mb-1">
                                                <a href="mailto:@displayEmail" class="font-weight-bold">@displayName</a>
                                                <br />
                                                <small class="text-muted">@displayEmail</small>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="font-weight-bold">@displayName</span>
                                        }
                                    </td>
                                    <td class="text-right">
                                        <form asp-action="RemoveGovernanceContact" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@Model.Id" />
                                            <input type="hidden" name="contactId" value="@gc.Id" />
                                            <button type="submit" class="btn btn-link btn-sm p-0">Remove</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Business Case Approval -->
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="card-title">Business Case Approval</h3>
            </div>
            <div class="card-body p-0">
                <table class="table table-borderless mb-0">
                    <tbody>
                        <tr>
                            <td class="summary-label" style="width: 25%;"><strong>Business case approval</strong></td>
                            <td class="summary-value" style="width: 65%;">
                                @if (!string.IsNullOrWhiteSpace(Model.BusinessCaseApproval))
                                {
                                    <span>@Model.BusinessCaseApproval</span>
                                }
                                else
                                {
                                    <span class="text-muted">Not set</span>
                                }
                            </td>
                            <td class="text-right" style="width: 10%;">
                                <a href="#" data-toggle="modal" data-target="#editBusinessCaseApprovalModal">Change</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Add governance contact -->
<div class="modal fade" id="addGovernanceContactModal" tabindex="-1" role="dialog" aria-labelledby="addGovernanceContactModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addGovernanceContactModalLabel">Add contact</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="AddGovernanceContact" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="modal-body">
                    <div class="form-group">
                        <label class="control-label" for="governanceContactSearch">Person</label>
                        <small class="form-text text-muted">Start typing a name or email address to look up someone in Entra ID.</small>
                        <div class="user-picker" data-user-picker data-search-url="/api/users/search" data-select-url="/api/users/select">
                            <div class="position-relative">
                                <input type="text"
                                       class="form-control js-user-picker-input"
                                       id="governanceContactSearch"
                                       autocomplete="off"
                                       placeholder="e.g. Alex Smith or alex.smith@education.gov.uk" />
                                <span class="user-picker__spinner js-user-picker-spinner" aria-hidden="true">Searching…</span>
                                <div class="user-picker__results js-user-picker-results" role="listbox" aria-live="polite"></div>
                            </div>
                            <p class="form-text text-muted js-user-picker-message"></p>
                            <input type="hidden" name="governanceContactUserId" class="js-user-picker-value" value="" />
                            <div class="user-picker__selected js-user-picker-summary" data-default-text="No one selected.">
                                <span class="text-muted">No one selected.</span>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="governanceContactRole">Role</label>
                        <input type="text" class="form-control" id="governanceContactRole" name="role" maxlength="100" placeholder="e.g. Design assurance, G6 sponsor" />
                        <small class="form-text text-muted">Describe this person’s relationship to governance (free text).</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Add contact</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Business Case Approval Modal -->
<div class="modal fade" id="editBusinessCaseApprovalModal" tabindex="-1" role="dialog" aria-labelledby="editBusinessCaseApprovalModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editBusinessCaseApprovalModalLabel">Edit Business Case Approval</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateBusinessCaseApproval" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="businessCaseApprovalInput">Business case approval</label>
                        <select class="form-control" id="businessCaseApprovalInput" name="businessCaseApproval">
                            <option value="">Select an option</option>
                            <option value="Yes" selected="@(Model.BusinessCaseApproval == "Yes")">Yes</option>
                            <option value="No" selected="@(Model.BusinessCaseApproval == "No")">No</option>
                            <option value="Not applicable" selected="@(Model.BusinessCaseApproval == "Not applicable")">Not applicable</option>
                        </select>
                        <small class="form-text text-muted">Has the business case been approved?</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

