@model Compass.ViewModels.ProjectDependencyFormViewModel
@{
    ViewData["Title"] = $"Edit dependency · {Model.ProjectTitle}";
    var projectDetailsUrl = Url.Action("Details", "Project", new { id = Model.Input.ProjectId, tab = "dependencies" });

    Func<string, string> normaliseKey = key =>
    {
        if (string.IsNullOrWhiteSpace(key))
        {
            return string.Empty;
        }

        var trimmed = key;
        var bracketIndex = trimmed.IndexOf('[');
        if (bracketIndex >= 0)
        {
            trimmed = trimmed.Substring(0, bracketIndex);
        }

        var segments = trimmed.Split('.', System.StringSplitOptions.RemoveEmptyEntries);
        return segments.Length > 0 ? segments[^1] : trimmed;
    };

    var fieldIdLookup = new Dictionary<string, string>(System.StringComparer.OrdinalIgnoreCase)
    {
        ["TargetEntityType"] = Html.IdFor(m => m.Input.TargetEntityType),
        ["TargetEntityId"] = Html.IdFor(m => m.Input.TargetEntityId),
        ["DependencyType"] = Html.IdFor(m => m.Input.DependencyType),
        ["Status"] = Html.IdFor(m => m.Input.Status)
    };

    var modelErrors = ViewData.ModelState
        .Where(kvp => kvp.Value?.Errors?.Any() == true)
        .Select(kvp => new
        {
            Key = normaliseKey(kvp.Key),
            Errors = kvp.Value!.Errors
                .Select(error => error.ErrorMessage)
                .Where(message => !string.IsNullOrWhiteSpace(message))
                .ToList()
        })
        .Where(entry => entry.Errors.Any())
        .ToList();

    var hasModelErrors = modelErrors.Any();
    var errorSummaryClasses = hasModelErrors ? "card error-summary mb-3" : "card error-summary d-none mb-3";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-3">
            <div class="col-12">
                <a class="btn btn-link px-0 mb-2" href="@projectDetailsUrl" aria-label="Back to project">
                    <i class="fas fa-arrow-left mr-2" aria-hidden="true"></i>Back to project
                </a>
                <h1 class="m-0">Edit dependency</h1>
                <p class="text-muted mb-0">Update an existing dependency for @Model.ProjectTitle.</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xxl-7 col-xl-8 col-lg-9 col-md-12">
                <form asp-action="UpdateDependency" asp-controller="Project" method="post" novalidate>
                    @Html.AntiForgeryToken()
                    <div id="dependency-edit-error-summary"
                         class="@errorSummaryClasses"
                         role="alert"
                         aria-labelledby="dependency-edit-error-summary-title"
                         @(hasModelErrors ? "tabindex=\"-1\" aria-hidden=\"false\"" : "aria-hidden=\"true\"")
                         data-module="error-summary">
                        <div class="card-body">
                            <h2 id="dependency-edit-error-summary-title" class="error-summary__title">There is a problem</h2>
                            <ul class="error-summary__list">
                                @if (hasModelErrors)
                                {
                                    foreach (var entry in modelErrors)
                                    {
                                        string fieldId = string.Empty;
                                        var hasLink = !string.IsNullOrWhiteSpace(entry.Key) && fieldIdLookup.TryGetValue(entry.Key, out fieldId);

                                        foreach (var message in entry.Errors)
                                        {
                                            if (hasLink)
                                            {
                                                <li><a href="#@fieldId">@message</a></li>
                                            }
                                            else
                                            {
                                                <li>@message</li>
                                            }
                                        }
                                    }
                                }
                            </ul>
                        </div>
                    </div>
                    <div class="card">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <h3 class="card-title mb-0">Dependency details</h3>
                            @if (Model.ShowDeleteButton)
                            {
                                <button type="submit"
                                        class="btn btn-outline-danger btn-sm"
                                        formaction="@Url.Action("DeleteDependency", "Project", new { projectId = Model.Input.ProjectId, dependencyId = Model.Input.DependencyId })"
                                        formmethod="post"
                                        formnovalidate
                                        onclick="return confirm('Are you sure you want to delete this dependency?');">
                                    Delete
                                </button>
                            }
                        </div>
                        <div class="card-body">
                            <partial name="_DependencyFormFields" model="Model" />
                        </div>
                        <div class="card-footer d-flex align-items-center">
                            <button type="submit" class="btn btn-primary mr-3">Save changes</button>
                            <a asp-action="Details" asp-controller="Project" asp-route-id="@Model.Input.ProjectId" asp-route-tab="dependencies" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        (function () {
            const typeSelect = document.getElementById('dependencyTargetType');
            const targetGroups = Array.from(document.querySelectorAll('.dependency-target-group'));
            const hiddenIdInput = document.getElementById('dependencyTargetId');
            const summaryContainer = document.getElementById('dependencyTargetSummary');
            const summaryText = document.getElementById('dependencyTargetSummaryText');
            const container = document.getElementById('dependencyTargetSelectContainer');

            if (!typeSelect || !hiddenIdInput || !container) {
                return;
            }

            function setSummary(text) {
                if (!summaryContainer || !summaryText) {
                    return;
                }

                if (text) {
                    summaryText.textContent = text;
                    summaryContainer.classList.remove('d-none');
                } else {
                    summaryText.textContent = '';
                    summaryContainer.classList.add('d-none');
                }
            }

            function updateHiddenFromSelect(select) {
                if (!select) {
                    hiddenIdInput.value = '';
                    setSummary('');
                    return;
                }

                hiddenIdInput.value = select.value;
                const selectedOption = select.options[select.selectedIndex];
                const text = select.value ? selectedOption?.text ?? '' : '';
                setSummary(text);
            }

            function showGroupForType(type) {
                let activeSelect = null;

                targetGroups.forEach(group => {
                    const matches = group.dataset.targetSelect === type;
                    group.classList.toggle('d-none', !matches);

                    const select = group.querySelector('select');
                    if (!matches && select) {
                        select.selectedIndex = 0;
                    }

                    if (matches) {
                        activeSelect = select;
                    }
                });

                if (!activeSelect) {
                    hiddenIdInput.value = '';
                    setSummary('');
                    return;
                }

                if (!activeSelect.value && hiddenIdInput.value) {
                    hiddenIdInput.value = '';
                }

                updateHiddenFromSelect(activeSelect);
            }

            targetGroups.forEach(group => {
                const select = group.querySelector('select');
                if (!select) {
                    return;
                }

                select.addEventListener('change', () => {
                    if (group.classList.contains('d-none')) {
                        return;
                    }

                    updateHiddenFromSelect(select);
                });
            });

            typeSelect.addEventListener('change', () => {
                const value = typeSelect.value;
                hiddenIdInput.value = '';
                setSummary('');
                showGroupForType(value);
            });

            const initialSummary = container.dataset.selectedSummary;
            if (initialSummary) {
                setSummary(initialSummary);
            }

            showGroupForType(typeSelect.value);
        })();
    </script>
}
