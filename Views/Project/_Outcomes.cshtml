@model Compass.Models.Project

@{
    var outcomes = Model.Outcomes
        .OrderBy(o => o.SortOrder)
        .ToList();
}

<div class="card mb-4" id="outcomes">
    <div class="card-header">
        <h3 class="card-title">Priority outcomes</h3>
        <div class="card-tools">
            <a asp-controller="Project" asp-action="CreateOutcome" asp-route-projectId="@Model.Id">Add outcome</a>
        </div>
    </div>
    <div class="card-body table-responsive p-0">
        @if (outcomes.Any())
        {
            <table class="table table-hover sortable-table outcomes-table">
                <thead>
                    <tr>
                        <th style="width: 35%;" class="sortable" data-column="Outcome" tabindex="0" role="button" aria-label="Sort by Outcome">Outcome</th>
                        <th style="width: 35%;" class="sortable" data-column="Measure" tabindex="0" role="button" aria-label="Sort by Measure of Success">Measure of success</th>
                        <th style="width: 15%;" class="sortable" data-column="ConfidenceLevel" tabindex="0" role="button" aria-label="Sort by Confidence">Confidence</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var outcome in outcomes)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Project" asp-action="OutcomeDetails" asp-route-projectId="@Model.Id" asp-route-outcomeId="@outcome.Id">
                                    @outcome.Outcome
                                </a>
                                @if (!string.IsNullOrWhiteSpace(outcome.ConfidenceExplanation))
                                {
                                    <br />
                                    <small class="text-muted">@outcome.ConfidenceExplanation</small>
                                }
                            </td>
                            <td>@outcome.MeasureOfSuccess</td>
                            <td>
                                <span class="badge badge-@(outcome.ConfidenceLevel switch { "High" => "success", "Low" => "danger", _ => "warning" })">
                                    @outcome.ConfidenceLevel
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="p-4">
                <p class="text-muted mb-2">No priority outcomes recorded yet.</p>
                <a asp-controller="Project" asp-action="CreateOutcome" asp-route-projectId="@Model.Id">Add the first priority outcome</a>
            </div>
        }
    </div>
</div>
