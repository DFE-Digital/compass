@model Compass.Models.Project

@{
    var totalOutcomes = Model.Outcomes.Count;
    var totalMilestones = Model.Milestones.Count;
    var completedMilestones = Model.Milestones.Count(m => m.Status == "complete");
}


<!-- Outcomes Overview -->
<div class="card mb-4" id="outcomes">
    <div class="card-header">
        <h3 class="card-title">Expected Outcomes</h3>
        <div class="card-tools">
            <a href="#" data-toggle="modal" data-target="#addOutcomeModal">Add outcome</a>
        </div>
    </div>
    <div class="card-body table-responsive p-0">
        @if (Model.Outcomes.Any())
        {
                <table class="table table-hover sortable-table outcomes-table">
                    <thead>
                        <tr>
                            <th class="col-outcome sortable" data-column="Outcome" tabindex="0" role="button" aria-label="Sort by Outcome">
                                Outcome
                                <i class="fas fa-sort sort-icon"></i>
                            </th>
                            <th class="col-confidence-explanation">Confidence Explanation</th>
                            <th class="col-confidence-level sortable" data-column="ConfidenceLevel" tabindex="0" role="button" aria-label="Sort by Confidence Level">
                                Confidence Level
                                <i class="fas fa-sort sort-icon"></i>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var outcome in Model.Outcomes.OrderBy(o => o.SortOrder))
                        {
                            <tr>
                                <td>
                                    <a href="#" class="edit-outcome-link" 
                                       data-outcome-id="@outcome.Id" 
                                       data-outcome-text="@outcome.Outcome" 
                                       data-outcome-measure="@outcome.MeasureOfSuccess" 
                                       data-outcome-confidence="@outcome.ConfidenceLevel" 
                                       data-outcome-explanation="@(outcome.ConfidenceExplanation ?? "")" 
                                       data-outcome-sort="@outcome.SortOrder">@outcome.Outcome</a>
                                </td>
                                <td>@(string.IsNullOrEmpty(outcome.ConfidenceExplanation) ? "-" : outcome.ConfidenceExplanation)</td>
                                <td>
                                    <span class="badge @(outcome.ConfidenceLevel == "High" ? "badge-success" : outcome.ConfidenceLevel == "Medium" ? "badge-warning" : "badge-danger")">
                                        @outcome.ConfidenceLevel
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
        }
        else
        {
            <div class="text-center p-4">
                <p class="text-muted">No outcomes have been defined for this project yet.</p>
            </div>
        }
    </div>
</div>




<!-- Add Outcome Modal -->
<div class="modal fade" id="addOutcomeModal" tabindex="-1" role="dialog" aria-labelledby="addOutcomeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addOutcomeModalLabel">Add Expected Outcome</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="AddOutcome" asp-controller="Project" method="post">
                <input type="hidden" name="projectId" value="@Model.Id" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="outcome">Outcome</label>
                        <textarea class="form-control" id="outcome" name="outcome" rows="3" required placeholder="Describe the expected outcome..."></textarea>
                    </div>
                    
                    <div class="form-group">
                        <label for="measureOfSuccess">Measure of Success</label>
                        <textarea class="form-control" id="measureOfSuccess" name="measureOfSuccess" rows="2" required placeholder="How will this outcome be measured?"></textarea>
                    </div>
                    
                    <div class="form-group">
                        <label for="confidenceLevel">Confidence Level</label>
                        <select class="form-control" id="confidenceLevel" name="confidenceLevel" required>
                            <option value="Low">Low</option>
                            <option value="Medium" selected>Medium</option>
                            <option value="High">High</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="confidenceExplanation">Confidence Explanation (Optional)</label>
                        <textarea class="form-control" id="confidenceExplanation" name="confidenceExplanation" rows="2" placeholder="Explain why you have this level of confidence..."></textarea>
                    </div>
                    
                    <div class="alert alert-info">
                        <strong>Example:</strong>
                        <ul class="mb-0">
                            <li><strong>Outcome:</strong> Reduce processing time for user applications</li>
                            <li><strong>Measure:</strong> 30% reduction in average processing time within 6 months</li>
                            <li><strong>Confidence:</strong> High - Based on similar projects and available resources</li>
                        </ul>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add Outcome</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Outcome Modal -->
<div class="modal fade" id="editOutcomeModal" tabindex="-1" role="dialog" aria-labelledby="editOutcomeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editOutcomeModalLabel">View/Edit Expected Outcome</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateOutcome" asp-controller="Project" method="post">
                <input type="hidden" name="projectId" value="@Model.Id" />
                <input type="hidden" id="edit_outcomeId" name="outcomeId" />
                <input type="hidden" id="edit_sortOrder" name="sortOrder" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="edit_outcome">Outcome</label>
                        <textarea class="form-control" id="edit_outcome" name="outcome" rows="3" required></textarea>
                    </div>
                    
                    <div class="form-group">
                        <label for="edit_measureOfSuccess">Measure of Success</label>
                        <textarea class="form-control" id="edit_measureOfSuccess" name="measureOfSuccess" rows="2" required></textarea>
                    </div>
                    
                    <div class="form-group">
                        <label for="edit_confidenceLevel">Confidence Level</label>
                        <select class="form-control" id="edit_confidenceLevel" name="confidenceLevel" required>
                            <option value="Low">Low</option>
                            <option value="Medium">Medium</option>
                            <option value="High">High</option>
                        </select>
                    </div>
                    
                    <div class="form-group">
                        <label for="edit_confidenceExplanation">Confidence Explanation (Optional)</label>
                        <textarea class="form-control" id="edit_confidenceExplanation" name="confidenceExplanation" rows="2"></textarea>
                    </div>
                </div>
                <div class="modal-footer d-flex justify-content-between">
                    <button type="button" class="btn btn-danger" id="deleteOutcomeBtn">Delete Outcome</button>
                    <div>
                        <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Update Outcome</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Delete Outcome Confirmation Modal -->
<div class="modal fade" id="deleteOutcomeModal" tabindex="-1" role="dialog" aria-labelledby="deleteOutcomeModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteOutcomeModalLabel">Confirm Delete</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this outcome?</p>
                <p class="text-muted">This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <form asp-action="DeleteOutcome" asp-controller="Project" method="post" class="d-inline">
                    <input type="hidden" name="projectId" value="@Model.Id" />
                    <input type="hidden" id="delete_outcomeId" name="outcomeId" />
                    <button type="submit" class="btn btn-danger">Delete Outcome</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
    (function() {
        function initOutcomesPage() {
            // Initialize sortable tables
            $('.outcomes-table').each(function() {
                initializeOutcomesTable($(this));
            });

            // Handle edit outcome link clicks
            $(document).on('click', '.edit-outcome-link', function(e) {
                e.preventDefault();
                var id = $(this).attr('data-outcome-id');
                var outcome = $(this).attr('data-outcome-text');
                var measure = $(this).attr('data-outcome-measure');
                var confidence = $(this).attr('data-outcome-confidence');
                var explanation = $(this).attr('data-outcome-explanation');
                var sortOrder = $(this).attr('data-outcome-sort');
                
                editOutcome(id, outcome, measure, confidence, explanation, sortOrder);
            });

            // Handle delete outcome button
            $('#deleteOutcomeBtn').on('click', function() {
                var outcomeId = $('#edit_outcomeId').val();
                $('#delete_outcomeId').val(outcomeId);
                $('#editOutcomeModal').modal('hide');
                $('#deleteOutcomeModal').modal('show');
            });
        }

        function editOutcome(id, outcome, measure, confidence, explanation, sortOrder) {
            $('#edit_outcomeId').val(id);
            $('#edit_outcome').val(outcome);
            $('#edit_measureOfSuccess').val(measure);
            $('#edit_confidenceLevel').val(confidence);
            $('#edit_confidenceExplanation').val(explanation);
            $('#edit_sortOrder').val(sortOrder);
            $('#editOutcomeModal').modal('show');
        }

        function initializeOutcomesTable(table) {
            var currentSort = { column: null, direction: 'asc' };

            table.find('.sortable').on('click keypress', function(e) {
                if (e.type === 'keypress' && e.which !== 13 && e.which !== 32) {
                    return;
                }
                
                var column = $(this).data('column');
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(table, column, direction);
                currentSort = { column: column, direction: direction };
            });

            function sortTable(table, column, direction) {
                var tbody = table.find('tbody');
                var rows = tbody.find('tr').toArray();
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var colIndex = table.find('thead th[data-column="' + column + '"]').index();
                    
                    aVal = $(a).find('td').eq(colIndex).text().trim().toLowerCase();
                    bVal = $(b).find('td').eq(colIndex).text().trim().toLowerCase();
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.empty();
                rows.forEach(function(row) {
                    tbody.append(row);
                });
                
                updateSortIcons(table, column, direction);
            }

            function updateSortIcons(table, column, direction) {
                table.find('.sortable i').remove();
                var header = table.find('.sortable[data-column="' + column + '"]');
                var iconClass = direction === 'asc' ? 'fa-sort-up' : 'fa-sort-down';
                header.append(' <i class="fas ' + iconClass + '"></i>');
            }
        }

        if (typeof jQuery !== 'undefined') {
            $(document).ready(initOutcomesPage);
        } else {
            document.addEventListener('DOMContentLoaded', function() {
                if (typeof jQuery !== 'undefined') {
                    $(document).ready(initOutcomesPage);
                }
            });
        }
    })();
</script>
