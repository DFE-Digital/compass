@model Compass.ViewModels.Admin.UserLeadershipAssignmentPageViewModel

@{
    ViewData["Title"] = "Leadership scope assignments";
}


@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4 breadcrumb-standard">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" class="breadcrumb-link-standard">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Admin")" class="breadcrumb-link-standard">Administration</a>
            </li>
            <li class="breadcrumb-item active breadcrumb-active-standard" aria-current="page">Leadership scope</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Leadership scope</h1>
                <p class="text-muted mb-0">Assign business areas and reporting roles to senior colleagues.</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @successMessage
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @errorMessage
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (TempData["InfoMessage"] is string infoMessage)
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                @infoMessage
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h2 class="h5 mb-3">Choose a user</h2>
                <form asp-action="SelectUser" method="post" class="mb-0">
                    @Html.AntiForgeryToken()
                    <div class="user-picker"
                         data-user-picker
                         data-search-url="/api/users/search"
                         data-select-url="/api/users/select">
                        <div class="position-relative">
                            <label class="sr-only" for="userLeadershipSearch">Search for a user</label>
                            <input type="text"
                                   class="form-control js-user-picker-input"
                                   id="userLeadershipSearch"
                                   autocomplete="off"
                                   placeholder="e.g. Alex Smith or alex.smith@education.gov.uk" />
                            <span class="user-picker__spinner js-user-picker-spinner" aria-hidden="true">Searching…</span>
                            <div class="user-picker__results js-user-picker-results" role="listbox" aria-live="polite"></div>
                        </div>
                        <p class="form-text text-muted js-user-picker-message"></p>
                        <input type="hidden" name="selectedUserId" class="js-user-picker-value" value="@(Model.SelectedUser?.Id ?? 0)" />
                        <div class="user-picker__selected js-user-picker-summary" data-default-text="No user selected.">
                            @if (Model.SelectedUser != null)
                            {
                                <div class="user-picker__selected-card">
                                    <div class="user-picker__selected-name">@Model.SelectedUser.Name</div>
                                    <div class="user-picker__selected-meta">@Model.SelectedUser.Email</div>
                                    <button type="button" class="btn btn-link btn-sm js-user-picker-clear">Remove</button>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">No user selected.</span>
                            }
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary mt-3">Load leadership view</button>
                </form>
            </div>
        </div>

        @if (Model.Assignees.Any())
        {
            var roleLabelMap = Model.RoleOptions.ToDictionary(r => r.Value, r => r.Label);
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
                        <h2 class="h5 mb-0">People with leadership scope</h2>
                        <span class="badge badge-secondary">@Model.Assignees.Count</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th scope="col">User</th>
                                    <th scope="col">Business areas</th>
                                    <th scope="col">Roles</th>
                                    <th scope="col" class="text-right">Assignments</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var assignee in Model.Assignees)
                                {
                                    var businessAreas = assignee.BusinessAreas.ToList();
                                    var visibleAreas = businessAreas.Take(3).ToList();
                                    var hiddenAreas = businessAreas.Skip(3).ToList();
                                    var hasMoreAreas = hiddenAreas.Any();
                                    var uniqueId = $"business-areas-{assignee.UserId}";
                                    
                                    <tr>
                                        <td>
                                            <form asp-action="SelectUser" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="selectedUserId" value="@assignee.UserId" />
                                                <button type="submit" class="btn btn-link p-0 text-left font-weight-bold btn-link-text">
                                                    @assignee.Name
                                                </button>
                                            </form>
                                            <br />
                                            <span class="text-muted user-email">@assignee.Email</span>
                                        </td>
                                        <td>
                                            @if (businessAreas.Any())
                                            {
                                                @foreach (var area in visibleAreas)
                                                {
                                                    <span class="badge badge-light mr-1 mb-1">@area</span>
                                                }
                                                @if (hasMoreAreas)
                                                {
                                                    <span class="badge badge-secondary business-area-more mr-1 mb-1" 
                                                          data-target="@uniqueId" 
                                                          onclick="toggleBusinessAreas('@uniqueId', this)">
                                                        + @hiddenAreas.Count more
                                                    </span>
                                                    <span id="@uniqueId" class="business-area-hidden">
                                                        @foreach (var area in hiddenAreas)
                                                        {
                                                            <span class="badge badge-light mr-1 mb-1">@area</span>
                                                        }
                                                    </span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">None recorded</span>
                                            }
                                        </td>
                                        <td>
                                            @if (assignee.Roles.Any())
                                            {
                                                foreach (var role in assignee.Roles)
                                                {
                                                    var roleLabel = roleLabelMap.ContainsKey(role) ? roleLabelMap[role] : role.ToString();
                                                    <span class="badge badge-primary mr-1 mb-1">@roleLabel</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">No roles</span>
                                            }
                                        </td>
                                        <td class="text-right">@assignee.AssignmentCount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    
                    <!-- Hierarchical Tree View -->
                    <div class="leadership-tree mt-4">
                        <h3 class="h6 mb-3">Organisational structure by business area</h3>
                        @{
                            var roleOrder = new[] {
                                LeadershipRoleTier.PermanentSecretary,
                                LeadershipRoleTier.DirectorGeneral,
                                LeadershipRoleTier.CLevel,
                                LeadershipRoleTier.DeputyDirectorOrSro,
                                LeadershipRoleTier.HeadOfProfession,
                                LeadershipRoleTier.PortfolioLead
                            };
                            
                            // Group assignees by business area
                            var assigneesByBusinessArea = Model.Assignees
                                .SelectMany(a => a.BusinessAreas.Select(ba => new { BusinessArea = ba, Assignee = a }))
                                .GroupBy(x => x.BusinessArea)
                                .OrderBy(g => g.Key)
                                .ToList();
                        }
                        
                        @if (assigneesByBusinessArea.Any())
                        {
                            @foreach (var businessAreaGroup in assigneesByBusinessArea)
                            {
                                <div class="leadership-tree__business-area">
                                    <div class="leadership-tree__business-area-title">@businessAreaGroup.Key</div>
                                    
                                    @foreach (var roleTier in roleOrder)
                                    {
                                        var peopleInRole = businessAreaGroup
                                            .Where(x => x.Assignee.Roles.Contains(roleTier))
                                            .Select(x => x.Assignee)
                                            .GroupBy(a => a.UserId)
                                            .Select(g => g.First())
                                            .OrderBy(a => a.Name)
                                            .ToList();
                                        
                                        if (peopleInRole.Any())
                                        {
                                            var level = Array.IndexOf(roleOrder, roleTier);
                                            var roleLabel = roleLabelMap.ContainsKey(roleTier) ? roleLabelMap[roleTier] : roleTier.ToString();
                                            
                                            <div class="leadership-tree__role-tier leadership-tree__role-tier--level-@level">
                                                <div class="leadership-tree__role-label">@roleLabel</div>
                                                @foreach (var person in peopleInRole)
                                                {
                                                    <div class="leadership-tree__person">
                                                        <form asp-action="SelectUser" method="post" class="d-inline">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="selectedUserId" value="@person.UserId" />
                                                            <button type="submit" class="btn btn-link p-0 text-left btn-link-person-name leadership-tree__person-name">
                                                                @person.Name
                                                            </button>
                                                        </form>
                                                        <div class="leadership-tree__person-email">@person.Email</div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted">No leadership assignments to display in tree structure.</p>
                        }
                    </div>
                </div>
            </div>
        }

        @if (Model.HasSelectedUser)
        {
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between flex-wrap align-items-start">
                        <div>
                            <h2 class="h5 mb-1">Leadership remit for @Model.SelectedUser!.Name</h2>
                            <p class="text-muted mb-3 user-email">@Model.SelectedUser.Email</p>
                        </div>
                        <div class="text-right">
                            <span class="badge badge-info">
                                @Model.Assignments.Count assignment@(Model.Assignments.Count == 1 ? string.Empty : "s")
                            </span>
                        </div>
                    </div>

                    <form asp-action="Assign" method="post" class="leadership-assignment-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Input.UserId" value="@Model.SelectedUser.Id" />

                        <div class="form-group">
                            <label class="font-weight-semibold">Leadership roles</label>
                            <div class="row">
                                @foreach (var role in Model.RoleOptions)
                                {
                                    <div class="col-md-4">
                                        <div class="custom-control custom-checkbox mb-2">
                                            <input class="custom-control-input" type="checkbox" name="Input.Roles" id="role-@role.Value" value="@role.Value"
                                                   @(Model.Input.Roles?.Contains(role.Value) == true ? "checked" : string.Empty) />
                                            <label class="custom-control-label" for="role-@role.Value">
                                                <strong>@role.Label</strong><br />
                                                <small class="text-muted">@role.Description</small>
                                            </label>
                                        </div>
                                    </div>
                                }
                            </div>
                            <span asp-validation-for="Input.Roles" class="text-danger small"></span>
                        </div>

                        <div class="form-group">
                            <label class="font-weight-semibold">Business areas</label>
                            <div class="leadership-business-area-grid">
                                @foreach (var area in Model.BusinessAreas)
                                {
                                    var isChecked = Model.Input.BusinessAreas?.Any(value =>
                                        string.Equals(value, area.Value, StringComparison.OrdinalIgnoreCase)) == true;
                                    <div class="custom-control custom-checkbox mb-2">
                                        <input class="custom-control-input"
                                               type="checkbox"
                                               name="Input.BusinessAreas"
                                               id="ba-@area.Value"
                                               value="@area.Value"
                                               @(isChecked ? "checked" : string.Empty) />
                                        <label class="custom-control-label" for="ba-@area.Value">
                                            @area.Name
                                             @if (!string.IsNullOrWhiteSpace(area.Description))
                                            {
                                                <small class="text-muted d-block">@area.Description</small>
                                            }
                                        </label>
                                    </div>
                                }
                            </div>
                            <span asp-validation-for="Input.BusinessAreas" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-success">Save assignments</button>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="h5 mb-3">Current leadership scope</h3>
                    @if (!Model.Assignments.Any())
                    {
                        <p class="text-muted mb-0">No leadership scope recorded yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th scope="col">Business area</th>
                                        <th scope="col">Role</th>
                                        <th scope="col">Assigned</th>
                                        <th scope="col" class="text-right">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var assignment in Model.Assignments)
                                    {
                                        <tr>
                                            <td>@assignment.BusinessAreaName</td>
                                            <td>@assignment.Role</td>
                                            <td>@assignment.CreatedAt.ToString("dd MMM yyyy")</td>
                                            <td class="text-right">
                                                <form asp-action="Delete" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@assignment.Id" />
                                                    <input type="hidden" name="userId" value="@Model.SelectedUser.Id" />
                                                    <button type="submit" class="btn btn-link btn-sm text-danger">Remove</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script src="~/js/user-picker.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
    <script>
        function toggleBusinessAreas(targetId, element) {
            const target = document.getElementById(targetId);
            if (target) {
                const isCurrentlyExpanded = target.classList.contains('expanded');
                target.classList.toggle('expanded');
                const isExpanded = target.classList.contains('expanded');
                const count = target.querySelectorAll('.badge').length;
                element.textContent = isExpanded ? '- show less' : '+ ' + count + ' more';
            }
        }
    </script>
}

