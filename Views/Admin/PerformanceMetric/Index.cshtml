@model IEnumerable<Compass.Models.PerformanceMetric>
@{
    ViewData["Title"] = "Operational reports";
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item active">Operational reports</li>
                </ol>
                <h1 class="m-0">Operational reports</h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <div class="btn-group">
                        <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            Actions
                        </button>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" href="#" data-toggle="modal" data-target="#performanceMetricModal" onclick="openCreatePerformanceMetricModal()">
                                Add new metric
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-xxl-2 col-xl-2 col-lg-2 col-md-2 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Administration</h3>
                    </div>
                    <div class="card-body p-2">
                        <div class="nav flex-column nav-pills">
                            <a href="@Url.Action("Index", "PerformanceMetric")" class="nav-link @(currentController == "PerformanceMetric" ? "active" : "")">
                                Operational reports
                            </a>
                            <a href="@Url.Action("Index", "EnterpriseMetric")" class="nav-link @(currentController == "EnterpriseMetric" ? "active" : "")">
                                Enterprise metrics
                            </a>
                            <a href="@Url.Action("Index", "FunctionalStandard")" class="nav-link @(currentController == "FunctionalStandard" ? "active" : "")">
                                Functional standards
                            </a>
                            <a href="@Url.Action("Objectives", "Admin")" class="nav-link @(currentAction.StartsWith("Objective") ? "active" : "")">
                                Strategic objectives
                            </a>
                            <a href="@Url.Action("Missions", "Admin")" class="nav-link @(currentAction.StartsWith("Mission") ? "active" : "")">
                                Missions
                            </a>
                            <a href="@Url.Action("FundingSources", "Admin")" class="nav-link @(currentAction.Contains("FundingSource") ? "active" : "")">
                                Funding sources
                            </a>
                            <a href="@Url.Action("Index", "GovernmentDepartment")" class="nav-link @(currentController == "GovernmentDepartment" ? "active" : "")">
                                Government departments
                            </a>
                            <a href="@Url.Action("Index", "Organizational")" class="nav-link @(currentController == "Organizational" ? "active" : "")">
                                Organizational
                            </a>
                            <a href="@Url.Action("RiskTypes", "Admin")" class="nav-link @(currentAction.Contains("RiskType") ? "active" : "")">
                                Risk types
                            </a>
                            <a href="@Url.Action("RiskTiers", "Admin")" class="nav-link @(currentAction.Contains("RiskTier") ? "active" : "")">
                                Risk tiers
                            </a>
                            <a href="@Url.Action("ActionSources", "Admin")" class="nav-link @(currentAction.Contains("ActionSource") ? "active" : "")">
                                Action sources
                            </a>
                            <a href="@Url.Action("WcagCriteria", "Admin")" class="nav-link @(currentAction.Contains("WcagCriterion") || currentAction.Contains("WcagCriteria") ? "active" : "")">
                                WCAG Criteria
                            </a>
                            <a href="@Url.Action("GddRoles", "Admin")" class="nav-link @(currentAction.Contains("GddRole") ? "active" : "")">
                                GDD Roles
                            </a>
                            <a href="@Url.Action("Skills", "Admin")" class="nav-link @(currentAction.Contains("Skill") ? "active" : "")">
                                Skills
                            </a>
                            <a href="@Url.Action("ApiTokens", "Admin")" class="nav-link @(currentAction.Contains("ApiToken") ? "active" : "")">
                                API tokens
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xxl-10 col-xl-10 col-lg-10 col-md-10 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Operational reports</h3>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover text-nowrap">
                            <thead>
                                <tr>
                                    <th style="width: 10%;">ID</th>
                                    <th style="width: 30%;">Title</th>
                                    <th style="width: 20%;">Identifier</th>
                                    <th style="width: 20%;">Value type</th>
                                    <th style="width: 20%;">Valid from</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var metric in Model)
                                    {
                                        <tr class="@(metric.IsDisabled ? "text-muted" : "")">
                                            <td>@metric.Id</td>
                                            <td>
                                                <a href="#" class="edit-performance-metric font-weight-bold" 
                                                   data-id="@metric.Id" 
                                                   data-identifier="@metric.Identifier" 
                                                   data-title="@metric.Title" 
                                                   data-description="@(metric.Description ?? "")" 
                                                   data-hinttext="@(metric.HintText ?? "")" 
                                                   data-valuetype="@((int)metric.ValueType)" 
                                                   data-validfrommonth="@metric.ValidFromMonth" 
                                                   data-validfromyear="@metric.ValidFromYear" 
                                                   data-applicablephases="@(metric.ApplicablePhases ?? "")"
                                                   data-validationrules="@(metric.ValidationRules ?? "{\"required\": true, \"allowNull\": false}")"
                                                   data-isdisabled="@metric.IsDisabled.ToString().ToLower()">
                                                    @metric.Title
                                                </a>
                                            </td>
                                            <td>@metric.Identifier</td>
                                            <td>
                                                @switch (metric.ValueType)
                                                {
                                                    case Compass.Models.ValueType.Text:
                                                        <span>Text</span>
                                                        break;
                                                    case Compass.Models.ValueType.Number:
                                                        <span>Number</span>
                                                        break;
                                                    case Compass.Models.ValueType.Decimal:
                                                        <span>Decimal</span>
                                                        break;
                                                    case Compass.Models.ValueType.Percentage:
                                                        <span>Percentage</span>
                                                        break;
                                                }
                                            </td>
                                            <td>
                                                @(new DateTime(metric.ValidFromYear, metric.ValidFromMonth, 1).ToString("MMMM yyyy"))
                                                @if (metric.IsDisabled)
                                                {
                                                    <span class="badge badge-secondary ml-2">Disabled</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center">No operational reports found</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Create/Edit Modal -->
<div class="modal fade" id="performanceMetricModal" tabindex="-1" role="dialog" aria-labelledby="performanceMetricModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="performanceMetricModalLabel">Create performance metric</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="performanceMetricForm" method="post">
                <input type="hidden" id="performanceMetricId" name="Id" />
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <div class="form-group">
                        <label for="performanceMetricIdentifier" class="control-label">Identifier</label>
                        <input type="text" id="performanceMetricIdentifier" name="Identifier" class="form-control" placeholder="e.g. perf-1" />
                        <small class="form-text text-muted">Format: perf-x where x is a unique incremental ID</small>
                        <span class="text-danger field-validation-valid" data-valmsg-for="Identifier" data-valmsg-replace="true"></span>
                    </div>

                    <div class="form-group">
                        <label for="performanceMetricTitle" class="control-label">Title</label>
                        <input type="text" id="performanceMetricTitle" name="Title" class="form-control" placeholder="Enter title" required />
                        <span class="text-danger field-validation-valid" data-valmsg-for="Title" data-valmsg-replace="true"></span>
                    </div>

                    <div class="form-group">
                        <label for="performanceMetricDescription" class="control-label">Description</label>
                        <textarea id="performanceMetricDescription" name="Description" class="form-control" rows="4"></textarea>
                        <span class="text-danger field-validation-valid" data-valmsg-for="Description" data-valmsg-replace="true"></span>
                    </div>

                    <div class="form-group">
                        <label for="performanceMetricHintText" class="control-label">Hint text</label>
                        <input type="text" id="performanceMetricHintText" name="HintText" class="form-control" placeholder="e.g. Enter the total number of active users" />
                        <small class="form-text text-muted">Optional hint text to guide users when entering data</small>
                        <span class="text-danger field-validation-valid" data-valmsg-for="HintText" data-valmsg-replace="true"></span>
                    </div>

                    <div class="form-group">
                        <label for="performanceMetricValueType" class="control-label">Value type</label>
                        <select id="performanceMetricValueType" name="ValueType" class="form-control custom-select">
                            <option value="@((int)Compass.Models.ValueType.Text)">Text</option>
                            <option value="@((int)Compass.Models.ValueType.Number)">Number</option>
                            <option value="@((int)Compass.Models.ValueType.Decimal)">Decimal</option>
                            <option value="@((int)Compass.Models.ValueType.Percentage)">Percentage</option>
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="performanceMetricValidFromMonth" class="control-label">Valid for reporting from (Month)</label>
                                <select id="performanceMetricValidFromMonth" name="ValidFromMonth" class="form-control custom-select">
                                    <option value="1">January</option>
                                    <option value="2">February</option>
                                    <option value="3">March</option>
                                    <option value="4">April</option>
                                    <option value="5">May</option>
                                    <option value="6">June</option>
                                    <option value="7">July</option>
                                    <option value="8">August</option>
                                    <option value="9" selected>September</option>
                                    <option value="10">October</option>
                                    <option value="11">November</option>
                                    <option value="12">December</option>
                                </select>
                                <span class="text-danger field-validation-valid" data-valmsg-for="ValidFromMonth" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="performanceMetricValidFromYear" class="control-label">Valid for reporting from (Year)</label>
                                <input type="number" id="performanceMetricValidFromYear" name="ValidFromYear" class="form-control" min="2025" max="2099" />
                                <span class="text-danger field-validation-valid" data-valmsg-for="ValidFromYear" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                    </div>
                    <div class="alert alert-info">
                        This metric will only appear in returns from the specified month onwards
                    </div>

                    <div class="form-group">
                        <label>Applicable phases</label>
                        <div id="performanceMetricPhasesContainer">
                            @if (ViewBag.Phases != null && ((List<string>)ViewBag.Phases).Any())
                            {
                                @foreach (var phase in (List<string>)ViewBag.Phases)
                                {
                                    <div class="custom-control custom-checkbox">
                                        <input type="checkbox" name="selectedPhases" value="@phase" class="custom-control-input" id="perfPhase_@phase.Replace(" ", "_")" />
                                        <label class="custom-control-label" for="perfPhase_@phase.Replace(" ", "_")">@phase</label>
                                    </div>
                                }
                                <small class="form-text text-muted">Select the phases this metric applies to. Leave unchecked to apply to all phases.</small>
                            }
                            else
                            {
                                <p class="text-muted">No phases available</p>
                            }
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="performanceMetricValidationRules" class="control-label">Validation rules</label>
                        <textarea id="performanceMetricValidationRules" name="validationRulesJson" class="form-control" rows="6">{"required": true, "allowNull": false}</textarea>
                        <small class="form-text text-muted">JSON format for validation rules</small>
                    </div>

                    <div class="form-group">
                        <div class="custom-control custom-switch">
                            <input type="checkbox" id="performanceMetricIsDisabled" name="IsDisabled" class="custom-control-input" />
                            <label class="custom-control-label" for="performanceMetricIsDisabled">Disable this metric</label>
                        </div>
                        <small class="form-text text-muted">Disabled metrics will not appear in new returns but remain available for historical data</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script nonce="@Context.Items["Nonce"]">
        var phases = @Html.Raw(ViewBag.Phases != null ? Json.Serialize(ViewBag.Phases) : "[]");

        function openCreatePerformanceMetricModal() {
            $('#performanceMetricModalLabel').text('Create performance metric');
            $('#performanceMetricForm').attr('action', '@Url.Action("Create", "PerformanceMetric")');
            $('#performanceMetricId').val('');
            $('#performanceMetricIdentifier').val('').prop('readonly', false);
            $('#performanceMetricTitle').val('');
            $('#performanceMetricDescription').val('');
            $('#performanceMetricHintText').val('');
            $('#performanceMetricValueType').val('@((int)Compass.Models.ValueType.Text)');
            $('#performanceMetricValidFromMonth').val('9');
            $('#performanceMetricValidFromYear').val('');
            $('#performanceMetricValidationRules').val('{"required": true, "allowNull": false}');
            $('#performanceMetricIsDisabled').prop('checked', false);
            
            // Reset checkboxes
            $('#performanceMetricPhasesContainer input[type="checkbox"]').prop('checked', false);
            
            $('#performanceMetricModal').modal('show');
        }

        function openEditPerformanceMetricModal(id, identifier, title, description, hintText, valueType, validFromMonth, validFromYear, applicablePhases, validationRules, isDisabled) {
            $('#performanceMetricModalLabel').text('Edit performance metric');
            $('#performanceMetricForm').attr('action', '@Url.Action("Edit", "PerformanceMetric")');
            $('#performanceMetricId').val(id);
            $('#performanceMetricIdentifier').val(identifier).prop('readonly', true);
            $('#performanceMetricTitle').val(title);
            $('#performanceMetricDescription').val(description || '');
            $('#performanceMetricHintText').val(hintText || '');
            $('#performanceMetricValueType').val(valueType);
            $('#performanceMetricValidFromMonth').val(validFromMonth);
            $('#performanceMetricValidFromYear').val(validFromYear);
            $('#performanceMetricValidationRules').val(validationRules || '{"required": true, "allowNull": false}');
            $('#performanceMetricIsDisabled').prop('checked', isDisabled === 'true' || isDisabled === true);
            
            // Set phase checkboxes
            var selectedPhases = applicablePhases ? applicablePhases.split(',').map(p => p.trim()) : [];
            $('#performanceMetricPhasesContainer input[type="checkbox"]').each(function() {
                $(this).prop('checked', selectedPhases.includes($(this).val()));
            });
            
            $('#performanceMetricModal').modal('show');
        }

        $(document).on('click', '.edit-performance-metric', function(e) {
            e.preventDefault();
            var $item = $(this);
            openEditPerformanceMetricModal(
                $item.data('id'),
                $item.data('identifier'),
                $item.data('title'),
                $item.data('description'),
                $item.data('hinttext'),
                $item.data('valuetype'),
                $item.data('validfrommonth'),
                $item.data('validfromyear'),
                $item.data('applicablephases'),
                $item.data('validationrules'),
                $item.data('isdisabled')
            );
        });

        $('#performanceMetricValueType').on('change', function() {
            var valueType = $(this).val();
            var rulesTextarea = $('#performanceMetricValidationRules');
            var currentRules = {};
            
            try {
                currentRules = JSON.parse(rulesTextarea.val());
            } catch (e) {
                currentRules = {"required": true, "allowNull": false};
            }
            
            if (valueType == '@((int)Compass.Models.ValueType.Number)') {
                currentRules.minimumValue = 0;
                currentRules.maximumValue = 100000000;
                delete currentRules.decimalPlaces;
            } else if (valueType == '@((int)Compass.Models.ValueType.Decimal)') {
                currentRules.minimumValue = 0;
                currentRules.maximumValue = 100000000;
            } else if (valueType == '@((int)Compass.Models.ValueType.Percentage)') {
                currentRules.minimumValue = 0;
                currentRules.maximumValue = 100;
            } else {
                delete currentRules.minimumValue;
                delete currentRules.maximumValue;
                delete currentRules.decimalPlaces;
            }
            
            rulesTextarea.val(JSON.stringify(currentRules, null, 2));
        });

        $('#performanceMetricModal').on('hidden.bs.modal', function () {
            $('#performanceMetricForm')[0].reset();
            $('.field-validation-valid').text('');
        });
    </script>
}
