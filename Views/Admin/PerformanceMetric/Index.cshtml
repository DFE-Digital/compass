@model IEnumerable<Compass.Models.PerformanceMetric>
@{
    ViewData["Title"] = "Performance metrics";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item active">Performance metrics</li>
                </ol>
                <h1 class="m-0">Performance metrics</h1>
            </div>
            <div class="col-sm-6 text-right">
                <a href="@Url.Action("Index", "Documentation")#performance-metrics" class="btn btn-outline-info btn-sm">
                    View documentation
                </a>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Performance metrics</h3>
                <div class="card-tools">
                    <a asp-action="Create" class="btn btn-primary btn-sm">
                        Add new metric
                    </a>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover text-nowrap">
                    <thead>
                        <tr>
                            <th>Identifier</th>
                            <th>Title</th>
                            <th>Value type</th>
                            <th>Valid from</th>
                            <th class="col-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var metric in Model)
                            {
                                <tr>
                                    <td>@metric.Identifier</td>
                                    <td>@metric.Title</td>
                                    <td>
                                        @switch (metric.ValueType)
                                        {
                                            case Compass.Models.ValueType.Text:
                                                <span class="badge badge-info">Text</span>
                                                break;
                                            case Compass.Models.ValueType.Number:
                                                <span class="badge badge-success">Number</span>
                                                break;
                                            case Compass.Models.ValueType.Decimal:
                                                <span class="badge badge-warning">Decimal</span>
                                                break;
                                        }
                                    </td>
                                    <td>@(new DateTime(metric.ValidFromYear, metric.ValidFromMonth, 1).ToString("MMMM yyyy"))</td>
                                    <td class="col-actions">
                                        <a asp-action="Edit" asp-route-id="@metric.Id" class="btn btn-sm btn-primary">
                                            Edit
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@metric.Id" class="btn btn-sm btn-danger">
                                            Delete
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center">No performance metrics found</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>
