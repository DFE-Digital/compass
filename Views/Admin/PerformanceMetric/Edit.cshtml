@model Compass.Models.PerformanceMetric
@{
    ViewData["Title"] = "Edit performance metric";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Edit performance metric</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xxl-8 col-xl-8 col-lg-8 col-md-8 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Metric details</h3>
                    </div>
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CreatedAt" />
                        
                        <div class="card-body">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                            
                            <div class="form-group">
                                <label asp-for="Identifier">Identifier</label>
                                <input asp-for="Identifier" class="form-control" />
                            </div>

                            <div class="form-group">
                                <label asp-for="Title">Title</label>
                                <input asp-for="Title" class="form-control" />
                            </div>

                            <div class="form-group">
                                <label asp-for="Description">Description</label>
                                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                            </div>

                            <div class="form-group">
                                <label asp-for="HintText">Hint text</label>
                                <input asp-for="HintText" class="form-control" placeholder="e.g. Enter the total number of active users" />
                                <small class="form-text text-muted">Optional hint text to guide users when entering data</small>
                                <span asp-validation-for="HintText" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="ValueType">Value type</label>
                                <select asp-for="ValueType" class="form-control custom-select" id="valueTypeSelect">
                                    <option value="@((int)Compass.Models.ValueType.Text)">Text</option>
                                    <option value="@((int)Compass.Models.ValueType.Number)">Number</option>
                                    <option value="@((int)Compass.Models.ValueType.Decimal)">Decimal</option>
                                    <option value="@((int)Compass.Models.ValueType.Percentage)">Percentage</option>
                                </select>
                            </div>

                            <div class="row">
                                <div class="col-xxl-6 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12">
                                    <div class="form-group">
                                        <label asp-for="ValidFromMonth">Valid for reporting from (Month)</label>
                                        <select asp-for="ValidFromMonth" class="form-control custom-select">
                                            <option value="1">January</option>
                                            <option value="2">February</option>
                                            <option value="3">March</option>
                                            <option value="4">April</option>
                                            <option value="5">May</option>
                                            <option value="6">June</option>
                                            <option value="7">July</option>
                                            <option value="8">August</option>
                                            <option value="9">September</option>
                                            <option value="10">October</option>
                                            <option value="11">November</option>
                                            <option value="12">December</option>
                                        </select>
                                        <span asp-validation-for="ValidFromMonth" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-xxl-6 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12">
                                    <div class="form-group">
                                        <label asp-for="ValidFromYear">Valid for reporting from (Year)</label>
                                        <input asp-for="ValidFromYear" type="number" class="form-control" min="2025" max="2099" />
                                        <span asp-validation-for="ValidFromYear" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="alert alert-info">
                                This metric will only appear in returns from the specified month onwards
                            </div>

                            <div class="form-group">
                                <label>Applicable phases</label>
                                @if (ViewBag.Phases != null && ((List<string>)ViewBag.Phases).Any())
                                {
                                    var selectedPhasesList = !string.IsNullOrEmpty(Model.ApplicablePhases) 
                                        ? Model.ApplicablePhases.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(p => p.Trim()).ToList()
                                        : new List<string>();
                                    
                                    <div class="row">
                                        @foreach (var phase in (List<string>)ViewBag.Phases)
                                        {
                                            <div class="col-xxl-12 col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12">
                                                <div class="custom-control custom-checkbox">
                                                    <input type="checkbox" name="selectedPhases" value="@phase" 
                                                           class="custom-control-input" id="phase_@phase.Replace(" ", "_")"
                                                           @(selectedPhasesList.Contains(phase) ? "checked" : "") />
                                                    <label class="custom-control-label" for="phase_@phase.Replace(" ", "_")">@phase</label>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <small class="form-text text-muted">Select the phases this metric applies to. Leave unchecked to apply to all phases.</small>
                                }
                                else
                                {
                                    <p class="text-muted">No phases available</p>
                                }
                            </div>

                            <div class="form-group">
                                <label>Applicable types</label>
                                @if (ViewBag.Types != null && ((List<string>)ViewBag.Types).Any())
                                {
                                    var selectedTypesList = !string.IsNullOrEmpty(Model.ApplicableTypes) 
                                        ? Model.ApplicableTypes.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(t => t.Trim()).ToList()
                                        : new List<string>();
                                    
                                    <div class="row">
                                        @foreach (var type in (List<string>)ViewBag.Types)
                                        {
                                            <div class="col-xxl-12 col-xl-12 col-lg-12 col-md-12 col-sm-12 col-12">
                                                <div class="custom-control custom-checkbox">
                                                    <input type="checkbox" name="selectedTypes" value="@type" 
                                                           class="custom-control-input" id="type_@type.Replace(" ", "_")"
                                                           @(selectedTypesList.Contains(type) ? "checked" : "") />
                                                    <label class="custom-control-label" for="type_@type.Replace(" ", "_")">@type</label>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    <small class="form-text text-muted">Select the product types this metric applies to. Leave unchecked to apply to all types.</small>
                                }
                                else
                                {
                                    <p class="text-muted">No types available</p>
                                }
                            </div>

                            <div class="form-group">
                                <label>Validation rules</label>
                                <textarea name="validationRulesJson" id="validationRulesJson" class="form-control" rows="6">@Model.ValidationRules</textarea>
                                <small class="form-text text-muted">JSON format for validation rules</small>
                            </div>

                            <details class="mt-3 mb-3">
                                <summary class="mb-2" style="cursor: pointer;">
                                    <strong>What rules you can add</strong>
                                </summary>
                                <div class="card">
                                    <div class="card-body">
                                        <p class="small mb-2">Available validation rules (all optional except where noted):</p>
                                        <dl class="row small mb-0">
                                            <dt class="col-sm-4"><code>required</code></dt>
                                            <dd class="col-sm-8">Boolean. If true, the field must be filled in. Default: <code>true</code></dd>
                                            
                                            <dt class="col-sm-4"><code>allowNull</code></dt>
                                            <dd class="col-sm-8">Boolean. If true, allows "not captured" option. Default: <code>false</code></dd>
                                            
                                            <dt class="col-sm-4"><code>minimumValue</code></dt>
                                            <dd class="col-sm-8">Number. Minimum allowed value (for Number, Decimal, Percentage types)</dd>
                                            
                                            <dt class="col-sm-4"><code>maximumValue</code></dt>
                                            <dd class="col-sm-8">Number. Maximum allowed value (for Number, Decimal, Percentage types)</dd>
                                            
                                            <dt class="col-sm-4"><code>decimalPlaces</code></dt>
                                            <dd class="col-sm-8">Number. Maximum decimal places allowed (for Decimal and Percentage types)</dd>
                                        </dl>
                                        
                                        <hr class="my-2" />
                                        
                                        <p class="small mb-2"><strong>Examples:</strong></p>
                                        <dl class="row small mb-0">
                                            <dt class="col-sm-4">Number (0-100M)</dt>
                                            <dd class="col-sm-8"><code>{"required": true, "allowNull": false, "minimumValue": 0, "maximumValue": 100000000}</code></dd>
                                            
                                            <dt class="col-sm-4">Percentage (0-100)</dt>
                                            <dd class="col-sm-8"><code>{"required": true, "allowNull": false, "minimumValue": 0, "maximumValue": 100}</code></dd>
                                            
                                            <dt class="col-sm-4">Decimal (0-100, 2dp)</dt>
                                            <dd class="col-sm-8"><code>{"required": true, "allowNull": false, "minimumValue": 0, "maximumValue": 100, "decimalPlaces": 2}</code></dd>
                                            
                                            <dt class="col-sm-4">Optional text</dt>
                                            <dd class="col-sm-8"><code>{"required": false, "allowNull": true}</code></dd>
                                        </dl>
                                    </div>
                                </div>
                            </details>

                            <div class="form-group">
                                <label asp-for="ConditionalOnMetricId">Conditional display</label>
                                <select asp-for="ConditionalOnMetricId" class="form-control custom-select">
                                    <option value="">Always show this metric</option>
                                    @if (ViewBag.AvailableMetrics != null)
                                    {
                                        @foreach (var metric in (List<Compass.Models.PerformanceMetric>)ViewBag.AvailableMetrics)
                                        {
                                            <option value="@metric.Id">Show only when "@metric.Title" has a value</option>
                                        }
                                    }
                                </select>
                                <small class="form-text text-muted">Optionally show this metric only when another metric has been filled in</small>
                                <span asp-validation-for="ConditionalOnMetricId" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <div class="custom-control custom-checkbox">
                                    <input asp-for="IsDisabled" class="custom-control-input" type="checkbox" value="true" />
                                    <label asp-for="IsDisabled" class="custom-control-label">Disable this metric</label>
                                </div>
                                <small class="form-text text-muted">Disabled metrics will not appear in new returns but remain available for historical data</small>
                            </div>
                        </div>

                        <div class="card-footer">
                            <button type="submit" class="btn btn-primary">
                                Save changes
                            </button>
                            <a asp-action="Index" class="btn btn-default">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            $('#valueTypeSelect').on('change', function() {
                var valueType = $(this).val();
                var rulesTextarea = $('#validationRulesJson');
                var currentRules = {};
                
                try {
                    currentRules = JSON.parse(rulesTextarea.val());
                } catch (e) {
                    currentRules = {"required": true, "allowNull": false};
                }
                
                // Set default min/max based on type
                if (valueType == '@((int)Compass.Models.ValueType.Number)') {
                    currentRules.minimumValue = 0;
                    currentRules.maximumValue = 100000000;
                    delete currentRules.decimalPlaces;
                } else if (valueType == '@((int)Compass.Models.ValueType.Decimal)') {
                    currentRules.minimumValue = 0;
                    currentRules.maximumValue = 100000000;
                } else if (valueType == '@((int)Compass.Models.ValueType.Percentage)') {
                    currentRules.minimumValue = 0;
                    currentRules.maximumValue = 100;
                } else {
                    delete currentRules.minimumValue;
                    delete currentRules.maximumValue;
                    delete currentRules.decimalPlaces;
                }
                
                rulesTextarea.val(JSON.stringify(currentRules, null, 2));
            });
        });
    </script>
}
