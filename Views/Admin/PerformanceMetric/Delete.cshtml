@model Compass.Models.PerformanceMetric
@{
    ViewData["Title"] = "Delete performance metric";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Delete performance metric</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xxl-8 col-xl-8 col-lg-8 col-md-8 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Confirm deletion</h3>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-warning">
                            <h5>Warning</h5>
                            Are you sure you want to delete this performance metric? This action cannot be undone.
                        </div>
                        
                        <dl class="row">
                            <dt class="col-sm-3">Identifier</dt>
                            <dd class="col-sm-9"><code>@Model.Identifier</code></dd>

                            <dt class="col-sm-3">Title</dt>
                            <dd class="col-sm-9">@Model.Title</dd>

                            <dt class="col-sm-3">Description</dt>
                            <dd class="col-sm-9">@Model.Description</dd>
                        </dl>
                    </div>

                    <div class="card-footer">
                        <form asp-action="Delete" method="post">
                            <input type="hidden" asp-for="Id" />
                            <button type="submit" class="btn btn-danger">
                                Delete metric
                            </button>
                            <a asp-action="Index" class="btn btn-default">
                                Cancel
                            </a>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
