@model IEnumerable<Compass.Models.DdatProfession>

@{
    ViewData["Title"] = "Professions";
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Admin" asp-action="Index" style="color: #005ea5; text-decoration: none;">Admin</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Professions</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Professions</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">DDaT Professions</h3>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Role Group</th>
                                    <th>Skills</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Any())
                                {
                                    @foreach (var profession in Model)
                                    {
                                        <tr class="@(!profession.IsActive ? "text-muted" : "")">
                                            <td>
                                                <strong>@profession.Name</strong>
                                                @if (!string.IsNullOrEmpty(profession.Description))
                                                {
                                                    <br><small class="text-muted">@(profession.Description.Length > 100 ? profession.Description.Substring(0, 100) + "..." : profession.Description)</small>
                                                }
                                            </td>
                                            <td>@(profession.RoleGroup ?? "—")</td>
                                            <td>
                                                @{
                                                    var skillCount = await ViewContext.HttpContext.RequestServices
                                                        .GetRequiredService<Compass.Data.CompassDbContext>()
                                                        .ProfessionSkills.CountAsync(ps => ps.DdatProfessionId == profession.Id);
                                                }
                                                <span class="badge badge-info">@skillCount skill(s)</span>
                                            </td>
                                            <td>
                                                @if (profession.IsActive)
                                                {
                                                    <span class="badge badge-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-secondary">Inactive</span>
                                                }
                                            </td>
                                            <td>
                                                <a asp-action="ProfessionDetails" asp-route-id="@profession.Id" class="btn btn-sm btn-primary">
                                                    <i class="fas fa-eye"></i> View
                                                </a>
                                                <a asp-action="EditProfession" asp-route-id="@profession.Id" class="btn btn-sm btn-secondary">
                                                    <i class="fas fa-edit"></i> Edit
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted">No professions found.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

