@model List<Compass.Models.StandardProduct>
@{
    ViewData["Title"] = "Standard Products";
    var filterStatus = ViewBag.FilterStatus as string;
    var editId = ViewBag.EditId as int?;
    var editProduct = ViewBag.EditProduct as Compass.Models.StandardProduct;
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Admin" asp-action="Index" style="color: #005ea5; text-decoration: none;">Admin</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Standard Products</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <h1 class="m-0">Standard Products</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        }

        <div class="row">
            <div class="col-lg-3 col-md-4 mb-4">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Filters</h3>
                    </div>
                    <div class="list-group list-group-flush">
                        <a href="@Url.Action("Index", "StandardProducts", new { area = "Admin" })" class="list-group-item list-group-item-action @(string.IsNullOrEmpty(filterStatus) ? "active" : "")">
                            All Products
                        </a>
                        <a href="@Url.Action("Index", "StandardProducts", new { area = "Admin", filterStatus = "Pending" })" class="list-group-item list-group-item-action @(filterStatus == "Pending" ? "active" : "")">
                            Pending Approval
                        </a>
                        <a href="@Url.Action("Index", "StandardProducts", new { area = "Admin", filterStatus = "Approved" })" class="list-group-item list-group-item-action @(filterStatus == "Approved" ? "active" : "")">
                            Approved
                        </a>
                        <a href="@Url.Action("Index", "StandardProducts", new { area = "Admin", filterStatus = "Rejected" })" class="list-group-item list-group-item-action @(filterStatus == "Rejected" ? "active" : "")">
                            Rejected
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-lg-9 col-md-8">
                <div class="card">
                    <div class="card-header d-flex flex-wrap align-items-center" style="gap: 0.5rem;">
                        <h3 class="card-title mb-0">Products</h3>
                        <div class="ml-auto d-flex flex-wrap" style="gap: 0.5rem;">
                            <button type="button" class="btn btn-primary btn-sm" data-toggle="modal" data-target="#createModal">
                                <i class="fas fa-plus-circle mr-1"></i> Add New Product
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Provider</th>
                                        <th>Version</th>
                                        <th>DfE Product</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Any())
                                    {
                                        @foreach (var product in Model)
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@product.Name</strong>
                                                    @if (!string.IsNullOrEmpty(product.Description))
                                                    {
                                                        <br><small class="text-muted">@(product.Description.Length > 100 ? product.Description.Substring(0, 100) + "..." : product.Description)</small>
                                                    }
                                                </td>
                                                <td>@(product.Provider ?? "-")</td>
                                                <td>@(product.Version ?? "-")</td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(product.DfeProductName))
                                                    {
                                                        <span class="badge badge-info">@product.DfeProductName</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (product.ApprovalStatus == "Approved")
                                                    {
                                                        <span class="badge badge-success">Approved</span>
                                                    }
                                                    else if (product.ApprovalStatus == "Rejected")
                                                    {
                                                        <span class="badge badge-danger">Rejected</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-warning">Pending</span>
                                                    }
                                                </td>
                                                <td>
                                                    <button type="button" class="btn btn-info btn-sm" data-toggle="modal" data-target="#editModal" 
                                                            onclick="editProduct(@product.Id, '@product.Name.Replace("'", "\\'")', '@(product.Description?.Replace("'", "\\'") ?? "")', '@(product.Provider?.Replace("'", "\\'") ?? "")', '@(product.Version?.Replace("'", "\\'") ?? "")', '@(product.DfeFipsProductId?.Replace("'", "\\'") ?? "")', '@(product.DfeProductName?.Replace("'", "\\'") ?? "")')">
                                                        Edit
                                                    </button>
                                                    @if (product.ApprovalStatus == "Pending")
                                                    {
                                                        <button type="button" class="btn btn-success btn-sm" data-toggle="modal" data-target="#approveModal" 
                                                                onclick="approveProduct(@product.Id, '@product.Name.Replace("'", "\\'")')">
                                                            Approve
                                                        </button>
                                                        <button type="button" class="btn btn-danger btn-sm" data-toggle="modal" data-target="#rejectModal" 
                                                                onclick="rejectProduct(@product.Id, '@product.Name.Replace("'", "\\'")')">
                                                            Reject
                                                        </button>
                                                    }
                                                    <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this product?');">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@product.Id" />
                                                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted">No products found.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Create Modal -->
<div class="modal fade" id="createModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Add New Product</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="form-group">
                        <label for="newName">Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="newName" name="name" required maxlength="200" />
                    </div>
                    <div class="form-group">
                        <label for="newDescription">Description</label>
                        <textarea class="form-control" id="newDescription" name="description" rows="3" maxlength="2000"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="newProvider">Provider</label>
                                <input type="text" class="form-control" id="newProvider" name="provider" maxlength="200" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="newVersion">Version</label>
                                <input type="text" class="form-control" id="newVersion" name="version" maxlength="100" />
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="newDfeFipsProductId">DfE FIPS Product ID (optional)</label>
                        <input type="text" class="form-control" id="newDfeFipsProductId" name="dfeFipsProductId" maxlength="50" />
                        <small class="form-text text-muted">Link to a DfE product from FIPS (e.g., DfE Sign-in)</small>
                    </div>
                    <div class="form-group">
                        <label for="newDfeProductName">DfE Product Name (optional)</label>
                        <input type="text" class="form-control" id="newDfeProductName" name="dfeProductName" maxlength="200" />
                        <small class="form-text text-muted">Display name for the linked DfE product</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Product</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Product</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <form asp-action="Update" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editId" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="editName">Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="editName" name="name" required maxlength="200" />
                    </div>
                    <div class="form-group">
                        <label for="editDescription">Description</label>
                        <textarea class="form-control" id="editDescription" name="description" rows="3" maxlength="2000"></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="editProvider">Provider</label>
                                <input type="text" class="form-control" id="editProvider" name="provider" maxlength="200" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="editVersion">Version</label>
                                <input type="text" class="form-control" id="editVersion" name="version" maxlength="100" />
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="editDfeFipsProductId">DfE FIPS Product ID (optional)</label>
                        <input type="text" class="form-control" id="editDfeFipsProductId" name="dfeFipsProductId" maxlength="50" />
                    </div>
                    <div class="form-group">
                        <label for="editDfeProductName">DfE Product Name (optional)</label>
                        <input type="text" class="form-control" id="editDfeProductName" name="dfeProductName" maxlength="200" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Approve Modal -->
<div class="modal fade" id="approveModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Approve Product</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <form asp-action="Approve" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="approveId" />
                <div class="modal-body">
                    <p>Approve product: <strong id="approveName"></strong></p>
                    <div class="form-group">
                        <label for="approveNotes">Review Notes (optional)</label>
                        <textarea class="form-control" id="approveNotes" name="reviewNotes" rows="3" maxlength="1000"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Approve</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Reject Product</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <form asp-action="Reject" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="rejectId" />
                <div class="modal-body">
                    <p>Reject product: <strong id="rejectName"></strong></p>
                    <div class="form-group">
                        <label for="rejectNotes">Review Notes <span class="text-danger">*</span></label>
                        <textarea class="form-control" id="rejectNotes" name="reviewNotes" rows="3" required maxlength="1000"></textarea>
                        <small class="form-text text-muted">Please provide a reason for rejection.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Reject</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        function editProduct(id, name, description, provider, version, dfeFipsProductId, dfeProductName) {
            $('#editId').val(id);
            $('#editName').val(name);
            $('#editDescription').val(description);
            $('#editProvider').val(provider);
            $('#editVersion').val(version);
            $('#editDfeFipsProductId').val(dfeFipsProductId);
            $('#editDfeProductName').val(dfeProductName);
        }

        function approveProduct(id, name) {
            $('#approveId').val(id);
            $('#approveName').text(name);
            $('#approveNotes').val('');
        }

        function rejectProduct(id, name) {
            $('#rejectId').val(id);
            $('#rejectName').text(name);
            $('#rejectNotes').val('');
        }
    </script>
}

