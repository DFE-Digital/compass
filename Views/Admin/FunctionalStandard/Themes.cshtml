@model IEnumerable<Compass.Models.FunctionalStandardTheme>
@{
    ViewData["Title"] = "Themes";
    var standard = ViewBag.Standard as Compass.Models.FunctionalStandard;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Functional standards</a></li>
                    <li class="breadcrumb-item active">Themes</li>
                </ol>
                <h1 class="m-0">Themes for standard @standard.Id</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }

        <div class="callout callout-info">
            <h5>@standard.Title</h5>
            <p>@standard.Description</p>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Themes</h3>
                <div class="card-tools">
                    <a asp-action="CreateTheme" asp-route-standardId="@standard.Id" class="btn btn-primary btn-sm">
                        Add theme
                    </a>
                    <a asp-action="Index" class="btn btn-default btn-sm">
                        Back
                    </a>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover text-nowrap">
                    <thead>
                        <tr>
                            <th>Theme ID</th>
                            <th>Title</th>
                            <th class="col-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var theme in Model)
                            {
                                <tr>
                                    <td><strong>@theme.ThemeId</strong></td>
                                    <td>@theme.Title</td>
                                    <td class="col-actions">
                                        <a asp-action="PracticeAreas" asp-route-standardId="@theme.FunctionalStandardId" asp-route-themeId="@theme.ThemeId" class="btn btn-sm btn-info">
                                            Practice areas
                                        </a>
                                        <a asp-action="EditTheme" asp-route-id="@theme.Id" class="btn btn-sm btn-primary">
                                            Edit
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center">No themes found</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

