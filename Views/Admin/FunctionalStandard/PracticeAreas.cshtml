@model IEnumerable<Compass.Models.PracticeArea>
@{
    ViewData["Title"] = "Practice areas";
    var theme = ViewBag.Theme as Compass.Models.FunctionalStandardTheme;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Functional standards</a></li>
                    <li class="breadcrumb-item"><a asp-action="Themes" asp-route-id="@theme.FunctionalStandardId">Themes</a></li>
                    <li class="breadcrumb-item active">Practice areas</li>
                </ol>
                <h1 class="m-0">Practice areas</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }

        <div class="callout callout-info">
            <h5>@theme.FunctionalStandard?.Title - Theme @theme.ThemeId: @theme.Title</h5>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Practice areas</h3>
                <div class="card-tools">
                    <a asp-action="CreatePracticeArea" asp-route-standardId="@theme.FunctionalStandardId" asp-route-themeId="@theme.ThemeId" class="btn btn-primary btn-sm">
                        Add practice area
                    </a>
                    <a asp-action="Themes" asp-route-id="@theme.FunctionalStandardId" class="btn btn-default btn-sm">
                        Back
                    </a>
                </div>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover text-nowrap">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Title</th>
                            <th class="col-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var area in Model)
                            {
                                <tr>
                                    <td><strong>@area.PracticeAreaId</strong></td>
                                    <td>@area.Title</td>
                                    <td class="col-actions">
                                        <a asp-action="Criteria" asp-route-standardId="@area.FunctionalStandardId" asp-route-themeId="@area.ThemeId" asp-route-practiceAreaId="@area.PracticeAreaId" class="btn btn-sm btn-info">
                                            Criteria
                                        </a>
                                        <a asp-action="EditPracticeArea" asp-route-id="@area.Id" class="btn btn-sm btn-primary">
                                            Edit
                                        </a>
                                        
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center">No practice areas found</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

