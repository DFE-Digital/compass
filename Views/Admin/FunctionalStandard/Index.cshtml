@model IEnumerable<Compass.Models.FunctionalStandard>
@{
    ViewData["Title"] = "Functional standards";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item active">Functional standards</li>
                </ol>
                <h1 class="m-0">Functional standards</h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <div class="btn-group">
                        <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            Actions
                        </button>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" asp-action="Create">
                                Add new standard
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Functional standards</h3>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover text-nowrap">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Title</th>
                            <th>Published date</th>
                            <th class="col-actions">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var standard in Model)
                            {
                                <tr>
                                    <td>@standard.Id</td>
                                    <td>@standard.Title</td>
                                    <td>
                                        @if (standard.PublishedDate.HasValue)
                                        {
                                            @standard.PublishedDate.Value.ToString("dd/MM/yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-muted">Not published</span>
                                        }
                                    </td>
                                    <td class="col-actions">
                                        <a asp-action="Themes" asp-route-id="@standard.Id" class="btn btn-sm btn-info">
                                            Themes
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@standard.Id" class="btn btn-sm btn-primary">
                                            Edit
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@standard.Id" class="btn btn-sm btn-danger">
                                            Delete
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center">No functional standards found</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>