@model Compass.Models.PerformanceReportingDueDateOverride
@{
    ViewData["Title"] = "Edit due date override";
    var periodDate = new DateTime(Model.ReportingYear, Model.ReportingMonth, 1);
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Edit due date override</h1>
                <p class="text-muted mb-0">@periodDate.ToString("MMMM yyyy")</p>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Admin</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Performance reporting management</a></li>
                    <li class="breadcrumb-item"><a asp-action="DueDateOverrides">Due date overrides</a></li>
                    <li class="breadcrumb-item active">Edit</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <form asp-action="EditDueDateOverride" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ReportingYear" />
                <input type="hidden" asp-for="ReportingMonth" />
                
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="form-group">
                        <label>Reporting period</label>
                        <input type="text" class="form-control" value="@periodDate.ToString("MMMM yyyy")" readonly />
                        <small class="form-text text-muted">The reporting period cannot be changed</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="DueDate">Due date <span class="text-danger">*</span></label>
                        <input asp-for="DueDate" class="form-control" type="date" />
                        <span asp-validation-for="DueDate" class="text-danger"></span>
                        <small class="form-text text-muted">The specific date when reports for this period are due</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="Reason">Reason</label>
                        <textarea asp-for="Reason" class="form-control" rows="3" maxlength="500"></textarea>
                        <span asp-validation-for="Reason" class="text-danger"></span>
                        <small class="form-text text-muted">Optional explanation for this override</small>
                    </div>

                    <div class="form-group">
                        <div class="custom-control custom-checkbox">
                            <input asp-for="IsActive" class="custom-control-input" />
                            <label asp-for="IsActive" class="custom-control-label">Active</label>
                        </div>
                        <small class="form-text text-muted">Only active overrides will be used</small>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.CreatedBy))
                    {
                        <div class="alert alert-light">
                            <small class="text-muted">
                                Created by <strong>@Model.CreatedBy</strong> on @Model.CreatedAt.ToString("dd MMMM yyyy HH:mm")
                            </small>
                        </div>
                    }
                </div>

                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save mr-2"></i>Update override
                    </button>
                    <a asp-action="DueDateOverrides" class="btn btn-default">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

