@model Compass.Models.PerformanceReportingPeriodExclusion
@{
    ViewData["Title"] = "Create period exclusion";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Create period exclusion</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Admin</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Performance reporting management</a></li>
                    <li class="breadcrumb-item"><a asp-action="PeriodExclusions">Period exclusions</a></li>
                    <li class="breadcrumb-item active">Create</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="alert alert-info">
            <i class="fas fa-info-circle mr-2"></i>
            <strong>Note:</strong> Period exclusions mark entire months as not requiring reporting at the base level. If a business area is configured to report for this period, it will override this exclusion.
        </div>

        <div class="card">
            <form asp-action="CreatePeriodExclusion" method="post">
                @Html.AntiForgeryToken()
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Year">Year <span class="text-danger">*</span></label>
                                <input asp-for="Year" class="form-control" type="number" min="2025" max="2030" />
                                <span asp-validation-for="Year" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Month">Month <span class="text-danger">*</span></label>
                                <select asp-for="Month" class="form-control">
                                    <option value="">-- Select month --</option>
                                    <option value="1">January</option>
                                    <option value="2">February</option>
                                    <option value="3">March</option>
                                    <option value="4">April</option>
                                    <option value="5">May</option>
                                    <option value="6">June</option>
                                    <option value="7">July</option>
                                    <option value="8">August</option>
                                    <option value="9">September</option>
                                    <option value="10">October</option>
                                    <option value="11">November</option>
                                    <option value="12">December</option>
                                </select>
                                <span asp-validation-for="Month" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Reason">Reason <span class="text-danger">*</span></label>
                        <textarea asp-for="Reason" class="form-control" rows="3" maxlength="1000"></textarea>
                        <span asp-validation-for="Reason" class="text-danger"></span>
                        <small class="form-text text-muted">Explain why reporting is not required for this period (e.g., "System migration", "Holiday period")</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="Notes">Additional notes</label>
                        <textarea asp-for="Notes" class="form-control" rows="3" maxlength="2000"></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                        <small class="form-text text-muted">Optional additional information</small>
                    </div>
                </div>

                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save mr-2"></i>Create exclusion
                    </button>
                    <a asp-action="PeriodExclusions" class="btn btn-default">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

