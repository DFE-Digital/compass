@model Compass.Models.PerformanceReportingBusinessAreaConfig
@{
    ViewData["Title"] = "Edit business area configuration";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Edit business area configuration</h1>
                <p class="text-muted mb-0">@Model.BusinessAreaName</p>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Admin</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Performance reporting management</a></li>
                    <li class="breadcrumb-item"><a asp-action="BusinessAreaConfig">Business area config</a></li>
                    <li class="breadcrumb-item active">Edit</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <form asp-action="EditBusinessAreaConfig" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="form-group">
                        <label asp-for="BusinessAreaName">Business area / portfolio name <span class="text-danger">*</span></label>
                        <input asp-for="BusinessAreaName" class="form-control" maxlength="255" />
                        <span asp-validation-for="BusinessAreaName" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ApplicableFromYear">Applicable from year <span class="text-danger">*</span></label>
                                <input asp-for="ApplicableFromYear" class="form-control" type="number" min="2025" max="2030" />
                                <span asp-validation-for="ApplicableFromYear" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ApplicableFromMonth">Applicable from month <span class="text-danger">*</span></label>
                                <select asp-for="ApplicableFromMonth" class="form-control">
                                    <option value="1">January</option>
                                    <option value="2">February</option>
                                    <option value="3">March</option>
                                    <option value="4">April</option>
                                    <option value="5">May</option>
                                    <option value="6">June</option>
                                    <option value="7">July</option>
                                    <option value="8">August</option>
                                    <option value="9">September</option>
                                    <option value="10">October</option>
                                    <option value="11">November</option>
                                    <option value="12">December</option>
                                </select>
                                <span asp-validation-for="ApplicableFromMonth" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ApplicableUntilYear">Applicable until year</label>
                                <input asp-for="ApplicableUntilYear" class="form-control" type="number" min="2025" max="2035" />
                                <span asp-validation-for="ApplicableUntilYear" class="text-danger"></span>
                                <small class="form-text text-muted">Leave blank for indefinite applicability</small>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ApplicableUntilMonth">Applicable until month</label>
                                <select asp-for="ApplicableUntilMonth" class="form-control">
                                    <option value="">-- Select month --</option>
                                    <option value="1">January</option>
                                    <option value="2">February</option>
                                    <option value="3">March</option>
                                    <option value="4">April</option>
                                    <option value="5">May</option>
                                    <option value="6">June</option>
                                    <option value="7">July</option>
                                    <option value="8">August</option>
                                    <option value="9">September</option>
                                    <option value="10">October</option>
                                    <option value="11">November</option>
                                    <option value="12">December</option>
                                </select>
                                <span asp-validation-for="ApplicableUntilMonth" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Notes">Notes</label>
                        <textarea asp-for="Notes" class="form-control" rows="3" maxlength="1000"></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <div class="custom-control custom-checkbox">
                            <input asp-for="IsActive" class="custom-control-input" />
                            <label asp-for="IsActive" class="custom-control-label">Active</label>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.CreatedBy))
                    {
                        <div class="alert alert-light">
                            <small class="text-muted">
                                Created by <strong>@Model.CreatedBy</strong> on @Model.CreatedAt.ToString("dd MMMM yyyy HH:mm")
                            </small>
                        </div>
                    }
                </div>

                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save mr-2"></i>Update configuration
                    </button>
                    <a asp-action="BusinessAreaConfig" class="btn btn-default">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

