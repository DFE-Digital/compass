@model List<Compass.Models.PerformanceReportingPeriodExclusion>
@{
    ViewData["Title"] = "Period exclusions";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Period exclusions</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Admin</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Performance reporting management</a></li>
                    <li class="breadcrumb-item active">Period exclusions</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="alert alert-info">
            <i class="fas fa-info-circle mr-2"></i>
            <strong>Note:</strong> Period exclusions ignore reporting for entire months at the base level. However, if a business area is configured to report for that period, it will override the exclusion for products in that business area.
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Active exclusions</h3>
                <div class="card-tools">
                    <a asp-action="CreatePeriodExclusion" class="btn btn-primary btn-sm">
                        <i class="fas fa-plus mr-2"></i>Create exclusion
                    </a>
                </div>
            </div>
            <div class="card-body">
                @if (Model.Any())
                {
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Period</th>
                                <th>Reason</th>
                                <th>Notes</th>
                                <th>Created by</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var exclusion in Model)
                            {
                                var periodDate = new DateTime(exclusion.Year, exclusion.Month, 1);
                                var isPast = periodDate < new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
                                <tr>
                                    <td>
                                        <strong>@periodDate.ToString("MMMM yyyy")</strong>
                                        @if (isPast)
                                        {
                                            <span class="badge badge-secondary ml-2">Past</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning ml-2">Upcoming</span>
                                        }
                                    </td>
                                    <td>@exclusion.Reason</td>
                                    <td><small>@(exclusion.Notes ?? "-")</small></td>
                                    <td>
                                        <small class="text-muted">@exclusion.CreatedBy</small><br/>
                                        <small class="text-muted">@exclusion.CreatedAt.ToString("dd MMM yyyy HH:mm")</small>
                                    </td>
                                    <td>
                                        <a asp-action="EditPeriodExclusion" asp-route-id="@exclusion.Id" class="btn btn-sm btn-primary">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-danger" 
                                                data-toggle="modal" 
                                                data-target="#confirmDeleteModal"
                                                data-id="@exclusion.Id"
                                                data-period="@periodDate.ToString("MMMM yyyy")">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted mb-0">No active period exclusions.</p>
                }
            </div>
            <div class="card-footer">
                <a asp-action="Index" class="btn btn-default">
                    <i class="fas fa-arrow-left mr-2"></i>Back to management
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="confirmDeleteModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header bg-danger">
                <h5 class="modal-title">Confirm deletion</h5>
                <button type="button" class="close" data-dismiss="modal">
                    <span>&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p class="mb-0">Are you sure you want to delete the period exclusion for <strong><span id="modalPeriod"></span></strong>?</p>
                <p class="mt-2 mb-0 text-muted"><small>Reporting will be required for this period again (unless overridden by other configurations).</small></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-default" data-dismiss="modal">Cancel</button>
                <form asp-action="DeletePeriodExclusion" method="post" id="deleteForm" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteId" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash-alt mr-2"></i>Delete exclusion
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            $('#confirmDeleteModal').on('show.bs.modal', function (event) {
                var button = $(event.relatedTarget);
                var id = button.data('id');
                var period = button.data('period');
                
                var modal = $(this);
                modal.find('#modalPeriod').text(period);
                modal.find('#deleteId').val(id);
            });
        });
    </script>
}

