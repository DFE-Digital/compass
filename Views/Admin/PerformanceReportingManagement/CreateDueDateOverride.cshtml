@model Compass.Models.PerformanceReportingDueDateOverride
@{
    ViewData["Title"] = "Create due date override";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Create due date override</h1>
            </div>
            <div class="col-sm-6">
                <ol class="breadcrumb float-sm-right">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index">Admin</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Performance reporting management</a></li>
                    <li class="breadcrumb-item"><a asp-action="DueDateOverrides">Due date overrides</a></li>
                    <li class="breadcrumb-item active">Create</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <form asp-action="CreateDueDateOverride" method="post">
                @Html.AntiForgeryToken()
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="form-group">
                        <label asp-for="ReportingYear">Reporting year <span class="text-danger">*</span></label>
                        <input asp-for="ReportingYear" class="form-control" type="number" min="2025" max="2030" value="@DateTime.UtcNow.Year" />
                        <span asp-validation-for="ReportingYear" class="text-danger"></span>
                        <small class="form-text text-muted">The year of the reporting period (e.g., 2025 for October 2025)</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="ReportingMonth">Reporting month <span class="text-danger">*</span></label>
                        <select asp-for="ReportingMonth" class="form-control">
                            <option value="">-- Select month --</option>
                            <option value="1">January</option>
                            <option value="2">February</option>
                            <option value="3">March</option>
                            <option value="4">April</option>
                            <option value="5">May</option>
                            <option value="6">June</option>
                            <option value="7">July</option>
                            <option value="8">August</option>
                            <option value="9">September</option>
                            <option value="10">October</option>
                            <option value="11">November</option>
                            <option value="12">December</option>
                        </select>
                        <span asp-validation-for="ReportingMonth" class="text-danger"></span>
                        <small class="form-text text-muted">The month of the reporting period</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="DueDate">Due date <span class="text-danger">*</span></label>
                        <input asp-for="DueDate" class="form-control" type="date" />
                        <span asp-validation-for="DueDate" class="text-danger"></span>
                        <small class="form-text text-muted">The specific date when reports for this period are due</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="Reason">Reason</label>
                        <textarea asp-for="Reason" class="form-control" rows="3" maxlength="500"></textarea>
                        <span asp-validation-for="Reason" class="text-danger"></span>
                        <small class="form-text text-muted">Optional explanation for this override (e.g., "Bank holiday adjustment")</small>
                    </div>

                    <div class="form-group">
                        <div class="custom-control custom-checkbox">
                            <input asp-for="IsActive" class="custom-control-input" checked />
                            <label asp-for="IsActive" class="custom-control-label">Active</label>
                        </div>
                        <small class="form-text text-muted">Only active overrides will be used</small>
                    </div>
                </div>

                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save mr-2"></i>Create override
                    </button>
                    <a asp-action="DueDateOverrides" class="btn btn-default">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

