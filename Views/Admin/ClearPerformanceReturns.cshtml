@{
    ViewData["Title"] = "Clear performance returns";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Clear performance returns</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xxl-8 col-xl-8 col-lg-8 col-md-10 col-sm-12 col-12">
                <div class="card card-danger">
                    <div class="card-header">
                        <h3 class="card-title"><i class="fas fa-exclamation-triangle"></i> Warning: Data deletion</h3>
                    </div>
                    <div class="card-body">
                        <p class="lead"><strong>This action will permanently delete all operational reporting returns.</strong></p>
                        
                        <div class="alert alert-warning">
                            <h5><i class="icon fas fa-exclamation-triangle"></i> What will be deleted:</h5>
                            <ul class="mb-0">
                                <li>All <code>ProductReturns</code> records</li>
                                <li>All <code>ProductMetricValues</code> records</li>
                                <li>All submitted and draft performance metric data</li>
                            </ul>
                        </div>

                        <div class="alert alert-info">
                            <h5><i class="icon fas fa-info-circle"></i> What will happen after:</h5>
                            <ul class="mb-0">
                                <li>The system will start generating returns from <strong>October 2025</strong> onwards</li>
                                <li>All performance metrics will remain (only the return data is deleted)</li>
                                <li>Products will need to resubmit all their data</li>
                            </ul>
                        </div>

                        <p class="mb-0"><strong>This action cannot be undone.</strong> Please confirm you want to proceed.</p>
                    </div>
                    <div class="card-footer">
                        <form asp-action="ClearPerformanceReturnsConfirmed" method="post" onsubmit="return confirm('Are you absolutely sure you want to delete ALL performance returns? This cannot be undone!');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash"></i> Yes, clear all performance returns
                            </button>
                            <a asp-action="Index" asp-controller="PerformanceMetric" class="btn btn-default">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

