@model Compass.Models.TrainingCourse
@using Compass.Models

@{
    ViewData["Title"] = "Create training course";
}

@await Html.PartialAsync("_DashboardStyles")

@await Html.PartialAsync("_AdminPageHeader", new { Title = "Create training course", Description = "Add a new course to the training library" })

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group">
                        <label asp-for="Title">Course title <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" required />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Provider">Provider</label>
                        <input asp-for="Provider" class="form-control" />
                        <span asp-validation-for="Provider" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Description">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Format">Format</label>
                                <select asp-for="Format" class="form-control" id="formatSelect">
                                    <option value="">Select format</option>
                                    <option value="Online">Online</option>
                                    <option value="Blended">Blended</option>
                                    <option value="In-person">In-person</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Duration">Duration</label>
                                <input asp-for="Duration" class="form-control" placeholder="e.g., 2 days, 16 hours" />
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Prerequisites">Prerequisites</label>
                        <textarea asp-for="Prerequisites" class="form-control" rows="3" placeholder="List any prerequisites for this course"></textarea>
                        <small class="form-text text-muted">Describe any prerequisites, required knowledge, or skills needed for this course</small>
                    </div>

                    <div class="form-group" id="locationGroup" style="display: none;">
                        <label asp-for="Location">Locations</label>
                        <textarea asp-for="Location" class="form-control" rows="3" placeholder="Enter locations, one per line (e.g., London, Manchester, Birmingham)"></textarea>
                        <small class="form-text text-muted">List locations where this in-person course is available (one per line)</small>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Cost">Cost (£)</label>
                                <input asp-for="Cost" type="number" step="0.01" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Url">Course URL</label>
                                <input asp-for="Url" type="url" class="form-control" placeholder="https://..." />
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Primary professions <span class="text-danger">*</span></label>
                        <div style="max-height: 250px; overflow-y: auto; border: 1px solid #ddd; padding: 15px; border-radius: 4px; background-color: #f9f9f9;">
                            @{
                                var professions = ViewBag.Professions as List<DdatProfession> ?? new List<DdatProfession>();
                                var selectedPrimaryIds = ViewBag.SelectedPrimaryProfessionIds as List<int> ?? new List<int>();
                            }
                            @if (professions.Any())
                            {
                                @foreach (var profession in professions)
                                {
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="selectedPrimaryProfessionIds" value="@profession.Id" 
                                               id="primary_profession_@profession.Id" @(selectedPrimaryIds.Contains(profession.Id) ? "checked" : "")>
                                        <label class="form-check-label" for="primary_profession_@profession.Id">
                                            <strong>@profession.Name</strong>
                                            @if (!string.IsNullOrEmpty(profession.RoleGroup))
                                            {
                                                <span class="badge badge-secondary ml-2">@profession.RoleGroup</span>
                                            }
                                        </label>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted">No professions available. Please add professions in the Admin area first.</p>
                            }
                        </div>
                        <small class="form-text text-muted">Select professions where this skill is specifically required</small>
                    </div>

                    <div class="form-group">
                        <label>Secondary professions</label>
                        <div style="max-height: 250px; overflow-y: auto; border: 1px solid #ddd; padding: 15px; border-radius: 4px; background-color: #f0f8ff;">
                            @{
                                var selectedSecondaryIds = ViewBag.SelectedSecondaryProfessionIds as List<int> ?? new List<int>();
                            }
                            @if (professions.Any())
                            {
                                @foreach (var profession in professions)
                                {
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="selectedSecondaryProfessionIds" value="@profession.Id" 
                                               id="secondary_profession_@profession.Id" @(selectedSecondaryIds.Contains(profession.Id) ? "checked" : "")>
                                        <label class="form-check-label" for="secondary_profession_@profession.Id">
                                            <strong>@profession.Name</strong>
                                            @if (!string.IsNullOrEmpty(profession.RoleGroup))
                                            {
                                                <span class="badge badge-secondary ml-2">@profession.RoleGroup</span>
                                            }
                                        </label>
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="text-muted">No professions available. Please add professions in the Admin area first.</p>
                            }
                        </div>
                        <small class="form-text text-muted">Select professions where this would be useful for additional awareness training or career progression</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="CapabilityTags">Capability tags</label>
                        <input asp-for="CapabilityTags" class="form-control" placeholder="Comma-separated capabilities" />
                        <small class="form-text text-muted">Comma-separated list of relevant capabilities</small>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-success">Create course</button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Show/hide location field based on format selection
            $('#formatSelect').on('change', function() {
                if ($(this).val() === 'In-person') {
                    $('#locationGroup').show();
                } else {
                    $('#locationGroup').hide();
                }
            });
            
            // Check initial value
            if ($('#formatSelect').val() === 'In-person') {
                $('#locationGroup').show();
            }
        });
    </script>
}

