@model Compass.Models.TrainingCourse

@{
    ViewData["Title"] = "Create training course";
}

@await Html.PartialAsync("_DashboardStyles")

@await Html.PartialAsync("_AdminPageHeader", new { Title = "Create training course", Description = "Add a new course to the training library" })

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group">
                        <label asp-for="Title">Course title <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" required />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Provider">Provider</label>
                        <input asp-for="Provider" class="form-control" />
                        <span asp-validation-for="Provider" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Description">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Format">Format</label>
                                <select asp-for="Format" class="form-control">
                                    <option value="">Select format</option>
                                    <option value="Online">Online</option>
                                    <option value="Blended">Blended</option>
                                    <option value="In-person">In-person</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Mode">Mode</label>
                                <select asp-for="Mode" class="form-control">
                                    <option value="">Select mode</option>
                                    <option value="Live">Live</option>
                                    <option value="Async">Async</option>
                                    <option value="Cohort">Cohort</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Duration">Duration</label>
                                <input asp-for="Duration" class="form-control" placeholder="e.g., 2 days, 16 hours" />
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Cost">Cost (£)</label>
                                <input asp-for="Cost" type="number" step="0.01" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Url">Course URL</label>
                                <input asp-for="Url" type="url" class="form-control" placeholder="https://..." />
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="ProfessionTags">Profession tags</label>
                        <input asp-for="ProfessionTags" class="form-control" placeholder="Comma-separated professions" />
                        <small class="form-text text-muted">Comma-separated list of relevant professions</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="CapabilityTags">Capability tags</label>
                        <input asp-for="CapabilityTags" class="form-control" placeholder="Comma-separated capabilities" />
                        <small class="form-text text-muted">Comma-separated list of relevant capabilities</small>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-primary">Create course</button>
                        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

