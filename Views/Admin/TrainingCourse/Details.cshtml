@model Compass.Models.TrainingCourse

@{
    ViewData["Title"] = Model.Title;
}

@await Html.PartialAsync("_DashboardStyles")

@await Html.PartialAsync("_AdminPageHeader", new { Title = "Course details", Description = Model.Title })

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Course information</h3>
                <div class="card-tools">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-sm">Edit</a>
                </div>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Title:</dt>
                    <dd class="col-sm-9">@Model.Title</dd>

                    <dt class="col-sm-3">Provider:</dt>
                    <dd class="col-sm-9">@(Model.Provider ?? "N/A")</dd>

                    <dt class="col-sm-3">Description:</dt>
                    <dd class="col-sm-9">@(Model.Description ?? "N/A")</dd>

                    <dt class="col-sm-3">Format:</dt>
                    <dd class="col-sm-9">@(Model.Format ?? "N/A")</dd>

                    <dt class="col-sm-3">Duration:</dt>
                    <dd class="col-sm-9">@(Model.Duration ?? "N/A")</dd>

                    @if (!string.IsNullOrEmpty(Model.Prerequisites))
                    {
                        <dt class="col-sm-3">Prerequisites:</dt>
                        <dd class="col-sm-9">@Html.Raw(Model.Prerequisites.Replace("\n", "<br />"))</dd>
                    }

                    @if (!string.IsNullOrEmpty(Model.Location))
                    {
                        <dt class="col-sm-3">Locations:</dt>
                        <dd class="col-sm-9">
                            @foreach (var location in Model.Location.Split(new[] { '\n', '\r', ',' }, StringSplitOptions.RemoveEmptyEntries))
                            {
                                <span class="badge badge-info mr-1 mb-1">@location.Trim()</span>
                            }
                        </dd>
                    }

                    <dt class="col-sm-3">Cost:</dt>
                    <dd class="col-sm-9">@(Model.Cost.HasValue ? $"£{Model.Cost.Value:N0}" : "N/A")</dd>

                    <dt class="col-sm-3">URL:</dt>
                    <dd class="col-sm-9">
                        @if (!string.IsNullOrEmpty(Model.Url))
                        {
                            <a href="@Model.Url" target="_blank" rel="noopener noreferrer">@Model.Url</a>
                        }
                        else
                        {
                            <span>N/A</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Primary professions:</dt>
                    <dd class="col-sm-9">
                        @if (!string.IsNullOrEmpty(Model.PrimaryProfessionTags))
                        {
                            <span class="badge badge-primary mr-1">@Model.PrimaryProfessionTags</span>
                        }
                        else if (!string.IsNullOrEmpty(Model.ProfessionTags))
                        {
                            <span class="badge badge-primary mr-1">@Model.ProfessionTags</span>
                            <small class="text-muted">(Legacy field)</small>
                        }
                        else
                        {
                            <span>N/A</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Secondary professions:</dt>
                    <dd class="col-sm-9">
                        @if (!string.IsNullOrEmpty(Model.SecondaryProfessionTags))
                        {
                            <span class="badge badge-info mr-1">@Model.SecondaryProfessionTags</span>
                        }
                        else
                        {
                            <span class="text-muted">None</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Capability tags:</dt>
                    <dd class="col-sm-9">@(Model.CapabilityTags ?? "N/A")</dd>

                    <dt class="col-sm-3">Status:</dt>
                    <dd class="col-sm-9">
                        @if (Model.Active)
                        {
                            <span class="badge badge-success">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-secondary">Archived</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Created:</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm") by @(Model.CreatedBy ?? "System")</dd>

                    <dt class="col-sm-3">Updated:</dt>
                    <dd class="col-sm-9">@Model.UpdatedAt.ToString("dd MMM yyyy HH:mm") by @(Model.UpdatedBy ?? "System")</dd>
                </dl>

                <div class="mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
                    <a asp-action="Index" class="btn btn-secondary">Back to list</a>
                </div>
            </div>
        </div>
    </div>
</section>

