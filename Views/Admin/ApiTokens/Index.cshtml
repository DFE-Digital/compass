@model List<Compass.Models.ApiToken>
@{
    ViewData["Title"] = "API tokens";
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Settings">Settings</a></li>
                    <li class="breadcrumb-item active">API tokens</li>
                </ol>
                <h1 class="m-0">API tokens</h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <div class="btn-group">
                        <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            Actions
                        </button>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" href="@Url.Action("ApiLogs", "Admin")">
                                View logs
                            </a>
                            <a class="dropdown-item" href="#" data-toggle="modal" data-target="#apiTokenModal" onclick="openCreateApiTokenModal()">
                                Create token
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-xxl-2 col-xl-2 col-lg-2 col-md-2 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Administration</h3>
                    </div>
                    <div class="card-body p-2">
                        <div class="nav flex-column nav-pills">
                            <a href="@Url.Action("Index", "PerformanceMetric")" class="nav-link @(currentController == "PerformanceMetric" ? "active" : "")">
                                Operational reports
                            </a>
                            <a href="@Url.Action("Index", "EnterpriseMetric")" class="nav-link @(currentController == "EnterpriseMetric" ? "active" : "")">
                                Enterprise metrics
                            </a>
                            <a href="@Url.Action("Index", "FunctionalStandard")" class="nav-link @(currentController == "FunctionalStandard" ? "active" : "")">
                                Functional standards
                            </a>
                            <a href="@Url.Action("Objectives", "Admin")" class="nav-link @(currentAction.StartsWith("Objective") ? "active" : "")">
                                Priority outcomes
                            </a>
                            <a href="@Url.Action("Missions", "Admin")" class="nav-link @(currentAction.StartsWith("Mission") ? "active" : "")">
                                Missions
                            </a>
                            <a href="@Url.Action("FundingSources", "Admin")" class="nav-link @(currentAction.Contains("FundingSource") ? "active" : "")">
                                Funding sources
                            </a>
                            <a href="@Url.Action("Index", "GovernmentDepartment")" class="nav-link @(currentController == "GovernmentDepartment" ? "active" : "")">
                                Government departments
                            </a>
                            <a href="@Url.Action("Index", "Organizational")" class="nav-link @(currentController == "Organizational" ? "active" : "")">
                                Organizational
                            </a>
                            <a href="@Url.Action("RiskTypes", "Admin")" class="nav-link @(currentAction.Contains("RiskType") ? "active" : "")">
                                Risk types
                            </a>
                            <a href="@Url.Action("RiskTiers", "Admin")" class="nav-link @(currentAction.Contains("RiskTier") ? "active" : "")">
                                Risk tiers
                            </a>
                            <a href="@Url.Action("ActionSources", "Admin")" class="nav-link @(currentAction.Contains("ActionSource") ? "active" : "")">
                                Action sources
                            </a>
                            <a href="@Url.Action("WcagCriteria", "Admin")" class="nav-link @(currentAction.Contains("WcagCriterion") || currentAction.Contains("WcagCriteria") ? "active" : "")">
                                WCAG Criteria
                            </a>
                            <a href="@Url.Action("GddRoles", "Admin")" class="nav-link @(currentAction.Contains("GddRole") ? "active" : "")">
                                GDD Roles
                            </a>
                            <a href="@Url.Action("Skills", "Admin")" class="nav-link @(currentAction.Contains("Skill") ? "active" : "")">
                                Skills
                            </a>
                            <a href="@Url.Action("ApiTokens", "Admin")" class="nav-link @(currentAction.Contains("ApiToken") ? "active" : "")">
                                API tokens
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xxl-10 col-xl-10 col-lg-10 col-md-10 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">API tokens</h3>
                    </div>
                    <div class="card-body">

                        @if (!Model.Any())
                        {
                            <div class="alert alert-info">
                                No API tokens have been created yet.
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive p-0">
                                <table class="table table-hover text-nowrap">
                                    <thead>
                                        <tr>
                                            <th style="width: 10%;">ID</th>
                                            <th style="width: 20%;">Name</th>
                                            <th style="width: 25%;">Description</th>
                                            <th style="width: 15%;">Status</th>
                                            <th style="width: 10%;">Created</th>
                                            <th style="width: 10%;">Last used</th>
                                            <th style="width: 10%;">Expires</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var token in Model)
                                        {
                                            <tr>
                                                <td>@token.Id</td>
                                                <td>
                                                    <a href="@Url.Action("ConfigurePermissions", "Admin", new { id = token.Id })" class="font-weight-bold">
                                                        @token.Name
                                                    </a>
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(token.Description))
                                                    {
                                                        <span>@token.Description</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">—</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (token.IsActive)
                                                    {
                                                        <span class="badge badge-success">Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-secondary">Inactive</span>
                                                    }
                                                    @if (token.ExpiresAt.HasValue && token.ExpiresAt.Value < DateTime.UtcNow)
                                                    {
                                                        <br /><span class="badge badge-danger mt-1">Expired</span>
                                                    }
                                                </td>
                                                <td>@token.CreatedAt.ToString("dd MMM yyyy")</td>
                                                <td>
                                                    @if (token.LastUsedAt.HasValue)
                                                    {
                                                        <span title="@token.LastUsedAt.Value.ToString("dd MMM yyyy HH:mm")">
                                                            @((DateTime.UtcNow - token.LastUsedAt.Value).TotalDays < 1 ? "Today" : $"{(int)(DateTime.UtcNow - token.LastUsedAt.Value).TotalDays}d ago")
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Never</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (token.ExpiresAt.HasValue)
                                                    {
                                                        <span>@token.ExpiresAt.Value.ToString("dd MMM yyyy")</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">Never</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Create/Edit Modal -->
<div class="modal fade" id="apiTokenModal" tabindex="-1" role="dialog" aria-labelledby="apiTokenModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="apiTokenModalLabel">Create API token</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="apiTokenForm" method="post" action="@Url.Action("CreateApiToken", "Admin")">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <div class="form-group">
                        <label for="apiTokenName" class="control-label">Token name <span class="text-danger">*</span></label>
                        <input type="text" id="apiTokenName" name="name" class="form-control" required maxlength="200" placeholder="e.g. SAS-ReadOnly, PowerBI-Integration" />
                        <small class="form-text text-muted">Give this token a descriptive name to identify its purpose</small>
                        <span class="text-danger field-validation-valid" data-valmsg-for="name" data-valmsg-replace="true"></span>
                    </div>

                    <div class="form-group">
                        <label for="apiTokenDescription" class="control-label">Description</label>
                        <textarea id="apiTokenDescription" name="description" class="form-control" rows="3" maxlength="1000" placeholder="Optional description of what this token will be used for"></textarea>
                        <span class="text-danger field-validation-valid" data-valmsg-for="description" data-valmsg-replace="true"></span>
                    </div>

                    <div class="form-group">
                        <label for="apiTokenExpiresAt" class="control-label">Expiry date</label>
                        <input type="date" id="apiTokenExpiresAt" name="expiresAt" class="form-control" min="@DateTime.UtcNow.AddDays(1).ToString("yyyy-MM-dd")" />
                        <small class="form-text text-muted">Optional. Leave blank for a token that never expires</small>
                        <span class="text-danger field-validation-valid" data-valmsg-for="expiresAt" data-valmsg-replace="true"></span>
                    </div>

                    <div class="alert alert-warning">
                        <strong>Important:</strong> After creating the token, you'll need to copy it immediately. 
                        For security reasons, you won't be able to view it again.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create token</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script nonce="@Context.Items["Nonce"]">
        function openCreateApiTokenModal() {
            $('#apiTokenModalLabel').text('Create API token');
            $('#apiTokenForm').attr('action', '@Url.Action("CreateApiToken", "Admin")');
            $('#apiTokenName').val('');
            $('#apiTokenDescription').val('');
            $('#apiTokenExpiresAt').val('');
            $('#apiTokenModal').modal('show');
        }

        $('#apiTokenModal').on('hidden.bs.modal', function () {
            $('#apiTokenForm')[0].reset();
            $('.field-validation-valid').text('');
        });
    </script>
}


