@model List<Compass.Models.ApiRequestLog>
@using Compass.Models
@{
    ViewData["Title"] = "API request logs";
    var tokens = ViewBag.Tokens as List<ApiToken>;
    var selectedTokenId = ViewBag.SelectedTokenId as int?;
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Settings", "Admin")">Settings</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("ApiTokens", "Admin")">API tokens</a></li>
            <li class="breadcrumb-item active" aria-current="page">Request logs</li>
        </ol>
    </nav>
}

<div class="row">
    <div class="col-12">
        <h1 class="mb-4">API request logs</h1>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h6 class="text-muted mb-1">Total requests</h6>
                <h3 class="mb-0">@Model.Count</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h6 class="text-muted mb-1">Successful</h6>
                <h3 class="mb-0 text-success">@Model.Count(l => l.IsSuccess)</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card">
            <div class="card-body">
                <h6 class="text-muted mb-1">Failed</h6>
                <h3 class="mb-0 text-danger">@Model.Count(l => !l.IsSuccess)</h3>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-xxl-3 col-xl-3 col-lg-3 col-md-3 col-sm-12 col-12">
        <div class="card">
            <div class="card-header">
                <h2 class="card-title mb-0 h6">Filters</h2>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label for="tokenFilter" class="form-label">Filter by token</label>
                    <select class="form-select" id="tokenFilter" onchange="filterByToken()">
                        <option value="">All tokens</option>
                        @foreach (var token in tokens ?? new List<ApiToken>())
                        {
                            var isSelected = token.Id == selectedTokenId;
                            <option value="@token.Id" selected="@isSelected">
                                @token.Name
                            </option>
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xxl-9 col-xl-9 col-lg-9 col-md-9 col-sm-12 col-12">
        <div class="card">
            <div class="card-header">
                <h2 class="card-title mb-0 h5">Recent requests</h2>
            </div>
            <div class="card-body">

                @if (!Model.Any())
                {
                    <div class="alert alert-info">
                        No API requests have been logged yet.
                    </div>
                }
                else
                {
                    <div class="table-responsive mt-3">
                        <table class="table table-sm table-hover">
                            <thead>
                                <tr>
                                    <th>Timestamp</th>
                                    <th>Token</th>
                                    <th>Method</th>
                                    <th>Path</th>
                                    <th>Status</th>
                                    <th>Response time</th>
                                    <th>IP address</th>
                                    <th>Details</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var log in Model)
                                {
                                    <tr class="@(log.IsSuccess ? "" : "table-danger")">
                                        <td>
                                            <small>@log.RequestTimestamp.ToString("dd MMM HH:mm:ss")</small>
                                        </td>
                                        <td>
                                            <small>@log.ApiToken.Name</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-@(log.HttpMethod switch {
                                                "GET" => "info",
                                                "POST" => "success",
                                                "PUT" => "warning",
                                                "DELETE" => "danger",
                                                _ => "secondary"
                                            })">
                                                @log.HttpMethod
                                            </span>
                                        </td>
                                        <td>
                                            <small class="font-monospace">@log.RequestPath</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-@(log.ResponseStatusCode < 300 ? "success" : 
                                                                    log.ResponseStatusCode < 400 ? "info" :
                                                                    log.ResponseStatusCode < 500 ? "warning" : "danger")">
                                                @log.ResponseStatusCode
                                            </span>
                                        </td>
                                        <td>
                                            <small>@log.ResponseTimeMs ms</small>
                                        </td>
                                        <td>
                                            <small>@log.IpAddress</small>
                                        </td>
                                        <td>
                                            <button type="button" 
                                                    class="btn btn-sm btn-outline-secondary" 
                                                    data-bs-toggle="modal" 
                                                    data-bs-target="#logModal@(log.Id)">
                                                View
                                            </button>
                                        </td>
                                    </tr>

                                    <!-- Modal for log details -->
                                    <div class="modal fade" id="logModal@(log.Id)" tabindex="-1">
                                        <div class="modal-dialog modal-lg">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title">Request details</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <h6>Request</h6>
                                                    <dl class="row small">
                                                        <dt class="col-sm-3">Timestamp</dt>
                                                        <dd class="col-sm-9">@log.RequestTimestamp.ToString("dd MMM yyyy HH:mm:ss")</dd>

                                                        <dt class="col-sm-3">Method</dt>
                                                        <dd class="col-sm-9">@log.HttpMethod</dd>

                                                        <dt class="col-sm-3">Path</dt>
                                                        <dd class="col-sm-9"><code>@log.RequestPath@log.QueryString</code></dd>

                                                        <dt class="col-sm-3">IP address</dt>
                                                        <dd class="col-sm-9">@log.IpAddress</dd>

                                                        <dt class="col-sm-3">User agent</dt>
                                                        <dd class="col-sm-9">@log.UserAgent</dd>
                                                    </dl>

                                                    @if (!string.IsNullOrEmpty(log.RequestBody))
                                                    {
                                                        <h6>Request body</h6>
                                                        <pre class="bg-light p-2 small">@log.RequestBody</pre>
                                                    }

                                                    <h6 class="mt-3">Response</h6>
                                                    <dl class="row small">
                                                        <dt class="col-sm-3">Status code</dt>
                                                        <dd class="col-sm-9">@log.ResponseStatusCode</dd>

                                                        <dt class="col-sm-3">Response time</dt>
                                                        <dd class="col-sm-9">@log.ResponseTimeMs ms</dd>

                                                        <dt class="col-sm-3">Success</dt>
                                                        <dd class="col-sm-9">
                                                            @if (log.IsSuccess)
                                                            {
                                                                <span class="badge bg-success">Yes</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-danger">No</span>
                                                            }
                                                        </dd>
                                                    </dl>

                                                    @if (!string.IsNullOrEmpty(log.ErrorMessage))
                                                    {
                                                        <div class="alert alert-danger">
                                                            <strong>Error:</strong> @log.ErrorMessage
                                                        </div>
                                                    }

                                                    @if (!string.IsNullOrEmpty(log.ResponseBody))
                                                    {
                                                        <h6>Response body</h6>
                                                        <pre class="bg-light p-2 small" style="max-height: 300px; overflow-y: auto;">@log.ResponseBody</pre>
                                                    }
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (Model.Count >= 1000)
                    {
                        <div class="alert alert-warning mt-3">
                            Showing the most recent 1,000 requests. Older requests are still stored in the database.
                        </div>
                    }
                }
            </div>
            <div class="card-footer">
                <a href="@Url.Action("ApiTokens")" class="btn btn-secondary">
                    Back to tokens
                </a>
            </div>
        </div>
    </div>
</div>

<script>
function filterByToken() {
    const select = document.getElementById('tokenFilter');
    const tokenId = select.value;
    if (tokenId) {
        window.location.href = '@Url.Action("ApiLogs")?tokenId=' + tokenId;
    } else {
        window.location.href = '@Url.Action("ApiLogs")';
    }
}
</script>

