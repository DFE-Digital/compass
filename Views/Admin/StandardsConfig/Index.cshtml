@model dynamic
@{
    ViewData["Title"] = "Standards Config";
    var categories = ViewBag.Categories as List<Compass.Models.StandardCategory> ?? new List<Compass.Models.StandardCategory>();
    var selectedCategoryId = ViewBag.SelectedCategoryId as int?;
    var selectedCategory = ViewBag.SelectedCategory as Compass.Models.StandardCategory;
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Admin" asp-action="Index" style="color: #005ea5; text-decoration: none;">Admin</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Standards Config</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <div class="d-flex justify-content-between align-items-center">
                    <h1 class="m-0">Standards Configuration</h1>
                    <form asp-action="SeedCategories" method="post" class="m-0">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary" onclick="return confirm('This will import all categories and sub-categories from the DfE Standards Manual. Continue?');">
                            <i class="fas fa-download mr-2"></i>Import from DfE Standards Manual
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        }

        <div class="row">
            <!-- Categories List -->
            <div class="col-lg-4">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Categories</h3>
                        <div class="card-tools">
                            <button type="button" class="btn btn-sm btn-primary" data-toggle="modal" data-target="#createCategoryModal">
                                <i class="fas fa-plus"></i> Add Category
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            @foreach (var category in categories)
                            {
                                <a href="@Url.Action("Index", new { categoryId = category.Id })" 
                                   class="list-group-item list-group-item-action @(selectedCategoryId == category.Id ? "active" : "")">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong>@category.Name</strong>
                                            @if (!string.IsNullOrWhiteSpace(category.Description))
                                            {
                                                <br />
                                                <small class="text-muted">@(category.Description.Length > 60 ? category.Description.Substring(0, 60) + "..." : category.Description)</small>
                                            }
                                            <br />
                                            <small class="text-muted">
                                                @category.SubCategories.Count sub-category(ies)
                                                @if (!category.IsActive)
                                                {
                                                    <span class="badge badge-secondary ml-2">Inactive</span>
                                                }
                                            </small>
                                        </div>
                                        <div class="btn-group btn-group-sm">
                                            <button type="button" class="btn btn-link p-0" 
                                                    data-toggle="modal" data-target="#editCategoryModal"
                                                    data-id="@category.Id"
                                                    data-name="@category.Name"
                                                    data-description="@(category.Description ?? "")"
                                                    data-sort="@category.SortOrder"
                                                    data-active="@category.IsActive">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                        </div>
                                    </div>
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sub-Categories List -->
            <div class="col-lg-8">
                @if (selectedCategory != null)
                {
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">Sub-Categories: @selectedCategory.Name</h3>
                            <div class="card-tools">
                                <button type="button" class="btn btn-sm btn-primary" data-toggle="modal" data-target="#createSubCategoryModal">
                                    <i class="fas fa-plus"></i> Add Sub-Category
                                </button>
                            </div>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead>
                                        <tr>
                                            <th>Name</th>
                                            <th>Description</th>
                                            <th>Sort Order</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var subCategory in selectedCategory.SubCategories)
                                        {
                                            <tr class="@(!subCategory.IsActive ? "text-muted" : "")">
                                                <td><strong>@subCategory.Name</strong></td>
                                                <td>@(subCategory.Description ?? "-")</td>
                                                <td>@subCategory.SortOrder</td>
                                                <td>
                                                    @if (subCategory.IsActive)
                                                    {
                                                        <span class="badge badge-success">Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-secondary">Inactive</span>
                                                    }
                                                </td>
                                                <td>
                                                    <button type="button" class="btn btn-sm btn-link" 
                                                            data-toggle="modal" data-target="#editSubCategoryModal"
                                                            data-id="@subCategory.Id"
                                                            data-name="@subCategory.Name"
                                                            data-description="@(subCategory.Description ?? "")"
                                                            data-sort="@subCategory.SortOrder"
                                                            data-active="@subCategory.IsActive">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    <form asp-action="DeleteSubCategory" method="post" class="d-inline" 
                                                          onsubmit="return confirm('Are you sure you want to delete this sub-category?');">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@subCategory.Id" />
                                                        <button type="submit" class="btn btn-sm btn-link text-danger">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card">
                        <div class="card-body text-center text-muted">
                            <p>Select a category to view and manage sub-categories</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- Create Category Modal -->
<div class="modal fade" id="createCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CreateCategory" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-header">
                    <h5 class="modal-title">Create Category</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="categoryName">Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="categoryName" name="name" required maxlength="200" />
                    </div>
                    <div class="form-group">
                        <label for="categoryDescription">Description</label>
                        <textarea class="form-control" id="categoryDescription" name="description" rows="3" maxlength="1000"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="categorySortOrder">Sort Order</label>
                        <input type="number" class="form-control" id="categorySortOrder" name="sortOrder" value="0" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Category Modal -->
<div class="modal fade" id="editCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="UpdateCategory" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editCategoryId" />
                <div class="modal-header">
                    <h5 class="modal-title">Edit Category</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="editCategoryName">Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="editCategoryName" name="name" required maxlength="200" />
                    </div>
                    <div class="form-group">
                        <label for="editCategoryDescription">Description</label>
                        <textarea class="form-control" id="editCategoryDescription" name="description" rows="3" maxlength="1000"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="editCategorySortOrder">Sort Order</label>
                        <input type="number" class="form-control" id="editCategorySortOrder" name="sortOrder" />
                    </div>
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="editCategoryIsActive" name="isActive" checked />
                        <label class="form-check-label" for="editCategoryIsActive">Active</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Create Sub-Category Modal -->
<div class="modal fade" id="createSubCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="CreateSubCategory" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="categoryId" value="@selectedCategoryId" />
                <div class="modal-header">
                    <h5 class="modal-title">Create Sub-Category</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="subCategoryName">Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="subCategoryName" name="name" required maxlength="200" />
                    </div>
                    <div class="form-group">
                        <label for="subCategoryDescription">Description</label>
                        <textarea class="form-control" id="subCategoryDescription" name="description" rows="3" maxlength="1000"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="subCategorySortOrder">Sort Order</label>
                        <input type="number" class="form-control" id="subCategorySortOrder" name="sortOrder" value="0" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Sub-Category Modal -->
<div class="modal fade" id="editSubCategoryModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="UpdateSubCategory" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="editSubCategoryId" />
                <div class="modal-header">
                    <h5 class="modal-title">Edit Sub-Category</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="editSubCategoryName">Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="editSubCategoryName" name="name" required maxlength="200" />
                    </div>
                    <div class="form-group">
                        <label for="editSubCategoryDescription">Description</label>
                        <textarea class="form-control" id="editSubCategoryDescription" name="description" rows="3" maxlength="1000"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="editSubCategorySortOrder">Sort Order</label>
                        <input type="number" class="form-control" id="editSubCategorySortOrder" name="sortOrder" />
                    </div>
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="editSubCategoryIsActive" name="isActive" checked />
                        <label class="form-check-label" for="editSubCategoryIsActive">Active</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Handle edit category modal
        $('#editCategoryModal').on('show.bs.modal', function (event) {
            var button = $(event.relatedTarget);
            $('#editCategoryId').val(button.data('id'));
            $('#editCategoryName').val(button.data('name'));
            $('#editCategoryDescription').val(button.data('description'));
            $('#editCategorySortOrder').val(button.data('sort'));
            $('#editCategoryIsActive').prop('checked', button.data('active') === true || button.data('active') === 'true');
        });

        // Handle edit sub-category modal
        $('#editSubCategoryModal').on('show.bs.modal', function (event) {
            var button = $(event.relatedTarget);
            $('#editSubCategoryId').val(button.data('id'));
            $('#editSubCategoryName').val(button.data('name'));
            $('#editSubCategoryDescription').val(button.data('description'));
            $('#editSubCategorySortOrder').val(button.data('sort'));
            $('#editSubCategoryIsActive').prop('checked', button.data('active') === true || button.data('active') === 'true');
        });
    </script>
}

