@model Compass.Models.DdatFrameworkSkill

@{
    ViewData["Title"] = "DDAT Framework Skill Details";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item"><a href="/" style="color: #005ea5;">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index" style="color: #005ea5;">Admin</a></li>
            <li class="breadcrumb-item"><a asp-action="DdatFrameworkSkills" style="color: #005ea5;">DDAT Framework Skills</a></li>
            <li class="breadcrumb-item active">Skill Details</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">@Model.SkillName</h1>
            </div>
            <div class="col-sm-6 text-right">
                <a href="@Url.Action("EditDdatFrameworkSkill", "Admin", new { id = Model.Id })" class="btn btn-primary">
                    <i class="fas fa-edit"></i> Edit
                </a>
                <a href="@Url.Action("DdatFrameworkSkills", "Admin", new { versionId = Model.FrameworkVersionId })" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Back to Skills
                </a>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Skill Information</h3>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Skill Name:</dt>
                    <dd class="col-sm-9">@Model.SkillName</dd>

                    <dt class="col-sm-3">Description:</dt>
                    <dd class="col-sm-9">@(Model.SkillDescription ?? "No description")</dd>

                    <dt class="col-sm-3">Framework Version:</dt>
                    <dd class="col-sm-9">@Model.FrameworkVersion.VersionIdentifier</dd>

                    <dt class="col-sm-3">Roles that require this skill:</dt>
                    <dd class="col-sm-9">
                        @if (!string.IsNullOrEmpty(Model.RolesThatRequireSkill))
                        {
                            @Model.RolesThatRequireSkill
                        }
                        else
                        {
                            <span class="text-muted">None specified</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Capability Level Descriptions</h3>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <h5>Awareness</h5>
                        <div class="border p-3 rounded" style="background-color: #f8f9fa;">
                            @if (!string.IsNullOrEmpty(Model.AwarenessDescription))
                            {
                                <p class="mb-0">@Model.AwarenessDescription</p>
                            }
                            else
                            {
                                <p class="text-muted mb-0">No description available</p>
                            }
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <h5>Working</h5>
                        <div class="border p-3 rounded" style="background-color: #e9f2fa;">
                            @if (!string.IsNullOrEmpty(Model.WorkingDescription))
                            {
                                <p class="mb-0">@Model.WorkingDescription</p>
                            }
                            else
                            {
                                <p class="text-muted mb-0">No description available</p>
                            }
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <h5>Practitioner</h5>
                        <div class="border p-3 rounded" style="background-color: #d4edda;">
                            @if (!string.IsNullOrEmpty(Model.PractitionerDescription))
                            {
                                <p class="mb-0">@Model.PractitionerDescription</p>
                            }
                            else
                            {
                                <p class="text-muted mb-0">No description available</p>
                            }
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <h5>Expert</h5>
                        <div class="border p-3 rounded" style="background-color: #fff3cd;">
                            @if (!string.IsNullOrEmpty(Model.ExpertDescription))
                            {
                                <p class="mb-0">@Model.ExpertDescription</p>
                            }
                            else
                            {
                                <p class="text-muted mb-0">No description available</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Grade Mappings</h3>
            </div>
            <div class="card-body">
                @if (Model.GradeMappings.Any())
                {
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Capability Level</th>
                                <th>Grade</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var mapping in Model.GradeMappings.OrderBy(m => m.CapabilityLevel).ThenBy(m => m.Grade))
                            {
                                <tr>
                                    <td>@mapping.CapabilityLevel</td>
                                    <td>@mapping.Grade</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No grade mappings configured. <a href="@Url.Action("EditDdatFrameworkSkill", "Admin", new { id = Model.Id })">Add grade mappings</a></p>
                }
            </div>
        </div>
    </div>
</section>

