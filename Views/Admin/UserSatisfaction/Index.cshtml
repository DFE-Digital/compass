@{
    ViewData["Title"] = "User satisfaction service";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Settings", "Admin")">Settings</a></li>
            <li class="breadcrumb-item active" aria-current="page">User satisfaction service</li>
        </ol>
    </nav>
}

<div class="row">
    <div class="col-12">
        <h1 class="mb-4">User satisfaction service</h1>
    </div>
</div>

<div class="row">
    <div class="col-lg-4 col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Manage survey questions</h2>
                <p>Create and edit the USS question set, weights and bands.</p>
                <a href="@Url.Action("UserSatisfactionQuestions", "Admin")" class="btn btn-primary btn-sm">Open</a>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Manage response scales</h2>
                <p>Create and manage response scales (Yes/No, Likert types, etc.).</p>
                <a href="@Url.Action("ResponseScales", "Admin")" class="btn btn-primary btn-sm">Open</a>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-md-6 mb-3">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">View satisfaction data</h2>
                <p>Explore scores and comments across products.</p>
                <a href="@Url.Action("UserSatisfactionResponses", "Admin")" class="btn btn-primary btn-sm">Open</a>
            </div>
        </div>
    </div>
</div>


