@model IEnumerable<Compass.Models.SurveyResponse>
@{
    ViewData["Title"] = "Responses & scores";
    var services = ViewBag.Services as IEnumerable<Compass.Models.FipsService>;
    var summary = ViewBag.Summary;
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("UserSatisfaction", "Admin")">User satisfaction service</a></li>
            <li class="breadcrumb-item active" aria-current="page">Responses</li>
        </ol>
    </nav>
}

<div class="row mb-3">
    <div class="col-12">
        <form class="form-inline" method="get" action="@Url.Action("UserSatisfactionResponses", "Admin")">
            <div class="form-group mr-2">
                <label class="mr-2">Service</label>
                <select name="fipsId" class="form-control">
                    <option value="">All</option>
                    @foreach (var s in services ?? Enumerable.Empty<Compass.Models.FipsService>())
                    {
                        <option value="@s.FipsId">@s.FipsId - @s.DisplayName</option>
                    }
                </select>
            </div>
            <div class="form-group mr-2">
                <label class="mr-2">From</label>
                <input type="date" name="from" class="form-control" />
            </div>
            <div class="form-group mr-2">
                <label class="mr-2">To</label>
                <input type="date" name="to" class="form-control" />
            </div>
            <button type="submit" class="btn btn-primary">Filter</button>
        </form>
    </div>
    <div class="col-12 mt-3">
        <div class="alert alert-info">
            <strong>Summary:</strong>
            @summary
        </div>
    </div>
    <div class="col-12">
        <div class="table-responsive">
            <table class="table table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Submitted</th>
                        <th>Service</th>
                        <th>Channel</th>
                        <th>Region</th>
                        <th>USS</th>
                        <th>Band</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>@r.SubmittedUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@r.SurveyInstance?.Service?.FipsId</td>
                            <td>@r.Channel</td>
                            <td>@r.GeoRegion</td>
                            <td>@r.UssComputed</td>
                            <td>@r.Band</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


