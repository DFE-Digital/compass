@model Compass.Models.RiskTier

@{
    ViewData["Title"] = "Create risk tier";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Users", "Admin")">Administration</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Settings", "Admin")">Settings</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("RiskTiers", "Admin")">Risk tiers</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Create</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xxl-2 col-xl-2 col-lg-2 col-md-2 col-sm-12 col-12">
                <partial name="~/Views/Admin/Settings/_SettingsSidebar.cshtml" />
            </div>

            <div class="col-xxl-10 col-xl-10 col-lg-10 col-md-10 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Create risk tier</h3>
                    </div>
                    <div class="card-body">
                <form asp-action="CreateRiskTier" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <div class="form-group">
                        <label asp-for="Code" class="control-label">Code <span class="text-danger">*</span></label>
                        <input asp-for="Code" class="form-control" placeholder="e.g. PROJECT" maxlength="50" style="font-family: monospace;" />
                        <span asp-validation-for="Code" class="text-danger"></span>
                        <small class="form-text text-muted">Unique identifier (uppercase, underscores allowed).</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="Name" class="control-label">Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Project-level risk" maxlength="100" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Summary" class="control-label">Summary</label>
                        <input asp-for="Summary" class="form-control" placeholder="Short description (max 200 characters)" maxlength="200" />
                        <span asp-validation-for="Summary" class="text-danger"></span>
                        <small class="form-text text-muted">Concise description of the scope (e.g., "Within a discrete project or service").</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="Description" class="control-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4" placeholder="Full definition, governance details, and examples"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                        <small class="form-text text-muted">Detailed explanation with examples.</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="SortOrder" class="control-label">Sort order <span class="text-danger">*</span></label>
                        <input asp-for="SortOrder" type="number" class="form-control" value="0" min="0" />
                        <span asp-validation-for="SortOrder" class="text-danger"></span>
                        <small class="form-text text-muted">Display order (lower numbers appear first). Typically: 1=Project, 2=Programme, 3=Portfolio, 4=Department, 5=Cross-government.</small>
                    </div>

                    <div class="form-group">
                        <div class="custom-control custom-switch">
                            <input asp-for="IsActive" type="checkbox" class="custom-control-input" id="IsActive" checked />
                            <label class="custom-control-label" for="IsActive">Active</label>
                        </div>
                        <small class="form-text text-muted">Inactive risk tiers will not appear in dropdowns.</small>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-primary">
                            Create
                        </button>
                        <a asp-action="RiskTiers" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

