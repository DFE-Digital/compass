@model IEnumerable<Compass.Models.RiskType>

@{
    ViewData["Title"] = "Risk types";
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Settings">Settings</a></li>
                    <li class="breadcrumb-item active">Risk types</li>
                </ol>
                <h1 class="m-0">Risk types</h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <div class="btn-group">
                        <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            Actions
                        </button>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" href="#" data-toggle="modal" data-target="#riskTypeModal" onclick="openCreateModal()">
                                Create new risk type
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-xxl-2 col-xl-2 col-lg-2 col-md-2 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Administration</h3>
                    </div>
                    <div class="card-body p-2">
                        <div class="nav flex-column nav-pills">
                            <a href="@Url.Action("Index", "PerformanceMetric")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "PerformanceMetric" ? "active" : "")">
                                Operational reports
                            </a>
                            <a href="@Url.Action("Index", "EnterpriseMetric")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "EnterpriseMetric" ? "active" : "")">
                                Enterprise metrics
                            </a>
                            <a href="@Url.Action("Index", "FunctionalStandard")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "FunctionalStandard" ? "active" : "")">
                                Functional standards
                            </a>
                            <a href="@Url.Action("Objectives", "Admin")" class="nav-link @(currentAction.StartsWith("Objective") ? "active" : "")">
                                Strategic objectives
                            </a>
                            <a href="@Url.Action("Missions", "Admin")" class="nav-link @(currentAction.StartsWith("Mission") ? "active" : "")">
                                Missions
                            </a>
                            <a href="@Url.Action("FundingSources", "Admin")" class="nav-link @(currentAction.Contains("FundingSource") ? "active" : "")">
                                Funding sources
                            </a>
                            <a href="@Url.Action("Index", "GovernmentDepartment")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "GovernmentDepartment" ? "active" : "")">
                                Government departments
                            </a>
                            <a href="@Url.Action("Index", "Organizational")" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Organizational" ? "active" : "")">
                                Organizational
                            </a>
                            <a href="@Url.Action("RiskTypes", "Admin")" class="nav-link @(currentAction.Contains("RiskType") ? "active" : "")">
                                Risk types
                            </a>
                            <a href="@Url.Action("RiskTiers", "Admin")" class="nav-link @(currentAction.Contains("RiskTier") ? "active" : "")">
                                Risk tiers
                            </a>
                            <a href="@Url.Action("ActionSources", "Admin")" class="nav-link @(currentAction.Contains("ActionSource") ? "active" : "")">
                                Action sources
                            </a>
                            <a href="@Url.Action("WcagCriteria", "Admin")" class="nav-link @(currentAction.Contains("WcagCriterion") || currentAction.Contains("WcagCriteria") ? "active" : "")">
                                WCAG Criteria
                            </a>
                            <a href="@Url.Action("BusinessAreas", "Admin")" class="nav-link @(currentAction.Contains("BusinessArea") ? "active" : "")">
                                Business areas
                            </a>
                            <a href="@Url.Action("Phases", "Admin")" class="nav-link @(currentAction.Contains("Phase") ? "active" : "")">
                                Phases
                            </a>
                            <a href="@Url.Action("GddRoles", "Admin")" class="nav-link @(currentAction.Contains("GddRole") ? "active" : "")">
                                GDD Roles
                            </a>
                            <a href="@Url.Action("Skills", "Admin")" class="nav-link @(currentAction.Contains("Skill") ? "active" : "")">
                                Skills
                            </a>
                            <a href="@Url.Action("ApiTokens", "Admin")" class="nav-link @(currentAction.Contains("ApiToken") ? "active" : "")">
                                API tokens
                            </a>
                            <a href="@Url.Action("Index", "Admin", new { area = "" })" class="nav-link @(currentAction == "Settings" ? "active" : "")">
                                User management
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xxl-10 col-xl-10 col-lg-10 col-md-10 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Risk types</h3>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover text-nowrap">
                            <thead>
                                <tr>
                                    <th style="width: 10%;">ID</th>
                                    <th style="width: 25%;">Name</th>
                                    <th style="width: 15%;">Code</th>
                                    <th style="width: 40%;">Summary</th>
                                    <th style="width: 10%;">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Any())
                                {
                                    @foreach (var item in Model)
                                    {
                                        <tr class="@(!item.IsActive ? "text-muted" : "")">
                                            <td>@item.Id</td>
                                            <td>
                                                <a href="#" class="font-weight-bold edit-risk-type" 
                                                   data-id="@item.Id" 
                                                   data-code="@item.Code" 
                                                   data-name="@item.Name" 
                                                   data-summary="@(item.Summary ?? "")" 
                                                   data-description="@(item.Description ?? "")" 
                                                   data-isactive="@item.IsActive.ToString().ToLower()">
                                                    @item.Name
                                                </a>
                                            </td>
                                            <td>@item.Code</td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.Summary))
                                                {
                                                    <small class="text-muted">@item.Summary</small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.IsActive)
                                                {
                                                    <span class="badge badge-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-secondary">Inactive</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted">No risk types found.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Create/Edit Modal -->
<div class="modal fade" id="riskTypeModal" tabindex="-1" role="dialog" aria-labelledby="riskTypeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="riskTypeModalLabel">Create risk type</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="riskTypeForm" method="post">
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <input type="hidden" id="riskTypeId" name="Id" />
                    
                    <div class="form-group">
                        <label for="riskTypeCode" class="control-label">Code <span class="text-danger">*</span></label>
                        <input type="text" id="riskTypeCode" name="Code" class="form-control" maxlength="50" style="font-family: monospace;" required />
                        <span class="text-danger field-validation-valid" data-valmsg-for="Code" data-valmsg-replace="true"></span>
                        <small class="form-text text-muted">Unique identifier (uppercase, no spaces).</small>
                    </div>

                    <div class="form-group">
                        <label for="riskTypeName" class="control-label">Name <span class="text-danger">*</span></label>
                        <input type="text" id="riskTypeName" name="Name" class="form-control" maxlength="100" required />
                        <span class="text-danger field-validation-valid" data-valmsg-for="Name" data-valmsg-replace="true"></span>
                    </div>

                    <div class="form-group">
                        <label for="riskTypeSummary" class="control-label">Summary</label>
                        <input type="text" id="riskTypeSummary" name="Summary" class="form-control" maxlength="200" />
                        <span class="text-danger field-validation-valid" data-valmsg-for="Summary" data-valmsg-replace="true"></span>
                        <small class="form-text text-muted">Concise one-line summary.</small>
                    </div>

                    <div class="form-group">
                        <label for="riskTypeDescription" class="control-label">Description</label>
                        <textarea id="riskTypeDescription" name="Description" class="form-control" rows="4"></textarea>
                        <span class="text-danger field-validation-valid" data-valmsg-for="Description" data-valmsg-replace="true"></span>
                        <small class="form-text text-muted">Detailed explanation and examples.</small>
                    </div>

                    <div class="form-group">
                        <div class="custom-control custom-switch">
                            <input type="checkbox" id="riskTypeIsActive" name="IsActive" class="custom-control-input" checked />
                            <label class="custom-control-label" for="riskTypeIsActive">Active</label>
                        </div>
                        <small class="form-text text-muted">Inactive risk types will not appear in dropdowns.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script nonce="@Context.Items["Nonce"]">
        var isEditMode = false;

        function openCreateModal() {
            isEditMode = false;
            $('#riskTypeModalLabel').text('Create risk type');
            $('#riskTypeForm').attr('action', '@Url.Action("CreateRiskType", "Admin")');
            $('#riskTypeId').val('');
            $('#riskTypeCode').val('').prop('readonly', false);
            $('#riskTypeName').val('');
            $('#riskTypeSummary').val('');
            $('#riskTypeDescription').val('');
            $('#riskTypeIsActive').prop('checked', true);
            $('#riskTypeModal').modal('show');
        }

        function openEditModal(id, code, name, summary, description, isActive) {
            isEditMode = true;
            $('#riskTypeModalLabel').text('Edit risk type');
            $('#riskTypeForm').attr('action', '@Url.Action("EditRiskType", "Admin")');
            $('#riskTypeId').val(id);
            $('#riskTypeCode').val(code).prop('readonly', true);
            $('#riskTypeName').val(name);
            $('#riskTypeSummary').val(summary || '');
            $('#riskTypeDescription').val(description || '');
            $('#riskTypeIsActive').prop('checked', isActive === 'true' || isActive === true);
            $('#riskTypeModal').modal('show');
        }

        $(document).on('click', '.edit-risk-type', function(e) {
            e.preventDefault();
            var $item = $(this);
            openEditModal(
                $item.data('id'),
                $item.data('code'),
                $item.data('name'),
                $item.data('summary'),
                $item.data('description'),
                $item.data('isactive')
            );
        });

        $('#riskTypeModal').on('hidden.bs.modal', function () {
            $('#riskTypeForm')[0].reset();
            $('.field-validation-valid').text('');
        });
    </script>
}

