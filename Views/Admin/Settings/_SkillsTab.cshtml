@model List<Compass.Models.Skill>

<div class="card">
    <div class="card-header">
        <div class="d-flex justify-content-between align-items-center">
            <h3 class="card-title mb-0">Skills</h3>
            <a asp-action="CreateSkill">
                Create new
            </a>
        </div>
    </div>
    <div class="card-body">
        <p class="text-muted">Manage Skills from the Government Digital and Data Capability Framework Skills A-Z.</p>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Skill Name</th>
                        <th>Category</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th class="col-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.SkillName</strong></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Category))
                                    {
                                        @item.Category
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Description))
                                    {
                                        <small class="text-muted">@(item.Description.Length > 100 ? item.Description.Substring(0, 100) + "..." : item.Description)</small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="EditSkill" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Edit">
                                            Edit
                                        </a>
                                        <form asp-action="DeleteSkill" asp-route-id="@item.Id" method="post" style="display: inline;" class="delete-form">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger" title="Delete" onclick="return confirm('Are you sure you want to delete this Skill?');">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">No skills found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

