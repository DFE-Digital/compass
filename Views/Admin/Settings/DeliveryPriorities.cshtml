@model IEnumerable<Compass.Models.DeliveryPriority>
@{
    ViewData["Title"] = "Delivery priorities";
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4 breadcrumb-standard">
            <li class="breadcrumb-item">
                <a href="/" class="breadcrumb-link-standard">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Admin" asp-action="Settings" class="breadcrumb-link-standard">Settings</a>
            </li>
            <li class="breadcrumb-item active breadcrumb-active-standard" aria-current="page">Delivery priorities</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Delivery priorities</h1>
            </div>
            <div class="col-sm-6">
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-xxl-2 col-xl-2 col-lg-2 col-md-2 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Administration</h3>
                    </div>
                    <div class="card-body p-2">
                        <div class="nav flex-column nav-pills">
                            <a href="@Url.Action("Index", "PerformanceMetric")" class="nav-link @(currentController == "PerformanceMetric" ? "active" : "")">
                                Operational reports
                            </a>
                            <a href="@Url.Action("Index", "EnterpriseMetric")" class="nav-link @(currentController == "EnterpriseMetric" ? "active" : "")">
                                Enterprise metrics
                            </a>
                            <a href="@Url.Action("Index", "FunctionalStandard")" class="nav-link @(currentController == "FunctionalStandard" ? "active" : "")">
                                Functional standards
                            </a>
                            <a href="@Url.Action("Objectives", "Admin")" class="nav-link @(currentAction.StartsWith("Objective") ? "active" : "")">
                                Priority outcomes
                            </a>
                            <a href="@Url.Action("Missions", "Admin")" class="nav-link @(currentAction.StartsWith("Mission") ? "active" : "")">
                                Missions
                            </a>
                            <a href="@Url.Action("FundingSources", "Admin")" class="nav-link @(currentAction.Contains("FundingSource") ? "active" : "")">
                                Funding sources
                            </a>
                            <a href="@Url.Action("Index", "GovernmentDepartment")" class="nav-link @(currentController == "GovernmentDepartment" ? "active" : "")">
                                Government departments
                            </a>
                            <a href="@Url.Action("Index", "Organizational")" class="nav-link @(currentController == "Organizational" ? "active" : "")">
                                Organizational
                            </a>
                            <a href="@Url.Action("RiskTypes", "Admin")" class="nav-link @(currentAction.Contains("RiskType") ? "active" : "")">
                                Risk types
                            </a>
                            <a href="@Url.Action("RiskTiers", "Admin")" class="nav-link @(currentAction.Contains("RiskTier") ? "active" : "")">
                                Risk tiers
                            </a>
                            <a href="@Url.Action("ActionSources", "Admin")" class="nav-link @(currentAction.Contains("ActionSource") ? "active" : "")">
                                Action sources
                            </a>
                            <a href="@Url.Action("DeliveryPriorities", "Admin")" class="nav-link @(currentAction.Contains("DeliveryPriorit") ? "active" : "")">
                                Delivery priorities
                            </a>
                            <a href="@Url.Action("WcagCriteria", "Admin")" class="nav-link @(currentAction.Contains("WcagCriterion") || currentAction.Contains("WcagCriteria") ? "active" : "")">
                                WCAG Criteria
                            </a>
                            <a href="@Url.Action("BusinessAreas", "Admin")" class="nav-link @(currentAction.Contains("BusinessArea") ? "active" : "")">
                                Business areas
                            </a>
                            <a href="@Url.Action("Phases", "Admin")" class="nav-link @(currentAction.Contains("Phase") ? "active" : "")">
                                Phases
                            </a>
                            <a href="@Url.Action("RagStatuses", "Admin")" class="nav-link @(currentAction.Contains("RagStatus") ? "active" : "")">
                                RAG Statuses
                            </a>
                            <a href="@Url.Action("GddRoles", "Admin")" class="nav-link @(currentAction.Contains("GddRole") ? "active" : "")">
                                GDD Roles
                            </a>
                            <a href="@Url.Action("Skills", "Admin")" class="nav-link @(currentAction.Contains("Skill") ? "active" : "")">
                                Skills
                            </a>
                            <a href="@Url.Action("KpiCategories", "Admin")" class="nav-link @(currentAction.Contains("KpiCategor") ? "active" : "")">
                                KPI categories
                            </a>
                            <a href="@Url.Action("ApiTokens", "Admin")" class="nav-link @(currentAction.Contains("ApiToken") ? "active" : "")">
                                API tokens
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xxl-10 col-xl-10 col-lg-10 col-md-10 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Delivery priorities</h3>
                        <div class="card-tools">
                            <a href="#" class="btn btn-primary btn-sm" data-toggle="modal" data-target="#deliveryPriorityModal" onclick="openCreateDeliveryPriorityModal()">
                                Create new
                            </a>
                        </div>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover text-nowrap">
                            <thead>
                                <tr>
                                    <th class="col-width-8">ID</th>
                                    <th class="col-width-24">Name</th>
                                    <th class="col-width-28">Summary</th>
                                    <th class="col-width-20">Description</th>
                                    <th class="col-width-15">CSS Class</th>
                                    <th class="col-width-10">Sort order</th>
                                    <th class="col-width-10">Status</th>
                                    <th class="col-actions">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Any())
                                {
                                    foreach (var priority in Model)
                                    {
                                        <tr class="@(!priority.IsActive ? "text-muted" : string.Empty)">
                                            <td>@priority.Id</td>
                                            <td><strong>@priority.Name</strong></td>
                                            <td>@(string.IsNullOrWhiteSpace(priority.Summary) ? Html.Raw("<span class=\"text-muted\">—</span>") : priority.Summary)</td>
                                            <td>
                                                @if (!string.IsNullOrWhiteSpace(priority.Description))
                                                {
                                                    <small class="text-muted">@priority.Description</small>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(priority.CssClass))
                                                {
                                                    <code>@priority.CssClass</code>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                            <td>@priority.SortOrder</td>
                                            <td>
                                                @if (priority.IsActive)
                                                {
                                                    <span class="badge badge-success">Active</span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-secondary">Inactive</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <button type="button" class="btn btn-outline-primary edit-delivery-priority" 
                                                            data-id="@priority.Id"
                                                            data-name="@Html.Raw(priority.Name.Replace("'", "\\'"))"
                                                            data-summary="@Html.Raw(priority.Summary?.Replace("'", "\\'") ?? "")"
                                                            data-description="@Html.Raw(priority.Description?.Replace("'", "\\'") ?? "")"
                                                            data-cssclass="@Html.Raw(priority.CssClass?.Replace("'", "\\'") ?? "")"
                                                            data-sortorder="@priority.SortOrder"
                                                            data-isactive="@(priority.IsActive ? "true" : "false")"
                                                            title="Edit">
                                                        Edit
                                                    </button>
                                                    <form asp-action="DeleteDeliveryPriority" asp-route-id="@priority.Id" method="post" class="d-inline delete-delivery-priority-form">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" class="btn btn-outline-danger" title="Delete">
                                                            Delete
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="8" class="text-center text-muted">No delivery priorities defined.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Create/Edit Modal -->
<div class="modal fade" id="deliveryPriorityModal" tabindex="-1" role="dialog" aria-labelledby="deliveryPriorityModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deliveryPriorityModalLabel">Create delivery priority</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="deliveryPriorityForm" method="post">
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <input type="hidden" id="deliveryPriorityId" name="Id" />

                    <div class="form-group">
                        <label for="deliveryPriorityName" class="control-label">Name <span class="text-danger">*</span></label>
                        <input type="text" id="deliveryPriorityName" name="Name" class="form-control" maxlength="100" required />
                        <small class="form-text text-muted">Displayed label (for example: High, Medium, Low).</small>
                    </div>

                    <div class="form-group">
                        <label for="deliveryPrioritySummary" class="control-label">Summary</label>
                        <input type="text" id="deliveryPrioritySummary" name="Summary" class="form-control" maxlength="200" />
                        <small class="form-text text-muted">Optional short description.</small>
                    </div>

                    <div class="form-group">
                        <label for="deliveryPriorityDescription" class="control-label">Description</label>
                        <textarea id="deliveryPriorityDescription" name="Description" class="form-control" rows="3"></textarea>
                        <small class="form-text text-muted">Optional longer description.</small>
                    </div>

                    <div class="form-group">
                        <label for="deliveryPriorityCssClass" class="control-label">CSS Class</label>
                        <input type="text" id="deliveryPriorityCssClass" name="CssClass" class="form-control" maxlength="100" />
                        <small class="form-text text-muted">CSS class for styling the badge (e.g., badge badge-high)</small>
                    </div>

                    <div class="form-group">
                        <label for="deliveryPrioritySortOrder" class="control-label">Sort order</label>
                        <input type="number" id="deliveryPrioritySortOrder" name="SortOrder" class="form-control" min="0" />
                        <small class="form-text text-muted">Lower numbers appear first in lists.</small>
                    </div>

                    <div class="form-group">
                        <div class="custom-control custom-switch">
                            <input type="checkbox" id="deliveryPriorityIsActive" name="IsActive" class="custom-control-input" checked />
                            <label class="custom-control-label" for="deliveryPriorityIsActive">Active</label>
                        </div>
                        <small class="form-text text-muted">Inactive priorities will not be available to projects.</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script nonce="@Context.Items["Nonce"]">
        function openCreateDeliveryPriorityModal() {
            $('#deliveryPriorityModalLabel').text('Create delivery priority');
            $('#deliveryPriorityForm').attr('action', '@Url.Action("CreateDeliveryPriority", "Admin")');
            $('#deliveryPriorityId').val('');
            $('#deliveryPriorityName').val('');
            $('#deliveryPrioritySummary').val('');
            $('#deliveryPriorityDescription').val('');
            $('#deliveryPriorityCssClass').val('');
            $('#deliveryPrioritySortOrder').val('0');
            $('#deliveryPriorityIsActive').prop('checked', true);
            $('#deliveryPriorityModal').modal('show');
        }

        function openEditDeliveryPriorityModal(id, name, summary, description, cssClass, sortOrder, isActive) {
            $('#deliveryPriorityModalLabel').text('Edit delivery priority');
            $('#deliveryPriorityForm').attr('action', '@Url.Action("EditDeliveryPriority", "Admin")');
            $('#deliveryPriorityId').val(id);
            $('#deliveryPriorityName').val(name);
            $('#deliveryPrioritySummary').val(summary || '');
            $('#deliveryPriorityDescription').val(description || '');
            $('#deliveryPriorityCssClass').val(cssClass || '');
            $('#deliveryPrioritySortOrder').val(sortOrder || '0');
            $('#deliveryPriorityIsActive').prop('checked', isActive === 'true' || isActive === true);
            $('#deliveryPriorityModal').modal('show');
        }

        $(document).on('click', '.edit-delivery-priority', function (e) {
            e.preventDefault();
            var $item = $(this);
            openEditDeliveryPriorityModal(
                $item.data('id'),
                $item.data('name'),
                $item.data('summary'),
                $item.data('description'),
                $item.data('cssclass'),
                $item.data('sortorder'),
                $item.data('isactive')
            );
        });

        // Handle delete confirmation
        $(document).on('submit', '.delete-delivery-priority-form', function (e) {
            if (!confirm('Are you sure you want to delete this delivery priority? This action cannot be undone.')) {
                e.preventDefault();
                return false;
            }
        });

        $('#deliveryPriorityModal').on('hidden.bs.modal', function () {
            $('#deliveryPriorityForm')[0].reset();
            $('.field-validation-valid').text('');
        });
    </script>
}


