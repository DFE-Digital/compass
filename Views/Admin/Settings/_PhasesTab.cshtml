@model List<Compass.Models.PhaseLookup>

<div class="card">
    <div class="card-header">
        <div class="d-flex justify-content-between align-items-center">
            <h3 class="card-title mb-0">Phases</h3>
            <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#createPhaseModal">
                Create new
            </button>
        </div>
    </div>
    <div class="card-body">
        <p class="text-muted">Manage phase options for projects. These are separate from the CMS phases and specific to Compass delivery tracking.</p>

        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th style="width: 60px;">Order</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th class="col-actions">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center"><span class="badge badge-secondary">@item.SortOrder</span></td>
                                <td><strong>@item.Name</strong></td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Description))
                                    {
                                        <small class="text-muted">@item.Description</small>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-secondary">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button type="button" class="btn btn-outline-primary edit-phase-btn" 
                                                data-phase-id="@item.Id"
                                                data-phase-name="@Html.Raw(item.Name.Replace("'", "\\'"))"
                                                data-phase-description="@Html.Raw(item.Description?.Replace("'", "\\'") ?? "")"
                                                data-phase-sortorder="@item.SortOrder"
                                                data-phase-isactive="@(item.IsActive ? "true" : "false")"
                                                title="Edit">
                                            Edit
                                        </button>
                                        <form asp-action="DeletePhase" asp-route-id="@item.Id" method="post" style="display: inline;" class="delete-phase-form">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger" title="Delete">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">No phases found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Create Phase Modal -->
<div class="modal fade" id="createPhaseModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create Phase</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="CreatePhase" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="form-group">
                        <label for="phaseName">Name</label>
                        <input type="text" class="form-control" id="phaseName" name="name" required maxlength="100">
                    </div>
                    <div class="form-group">
                        <label for="phaseDescription">Description</label>
                        <textarea class="form-control" id="phaseDescription" name="description" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="phaseSortOrder">Sort Order</label>
                        <input type="number" class="form-control" id="phaseSortOrder" name="sortOrder" value="0" min="0">
                        <small class="form-text text-muted">Lower numbers appear first</small>
                    </div>
                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="phaseIsActive" name="isActive" value="true" checked>
                            <label class="form-check-label" for="phaseIsActive">Active</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Phase Modal -->
<div class="modal fade" id="editPhaseModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Phase</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="EditPhase" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editPhaseId" name="id">
                <div class="modal-body">
                    <div class="form-group">
                        <label for="editPhaseName">Name</label>
                        <input type="text" class="form-control" id="editPhaseName" name="name" required maxlength="100">
                    </div>
                    <div class="form-group">
                        <label for="editPhaseDescription">Description</label>
                        <textarea class="form-control" id="editPhaseDescription" name="description" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="editPhaseSortOrder">Sort Order</label>
                        <input type="number" class="form-control" id="editPhaseSortOrder" name="sortOrder" min="0">
                    </div>
                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="editPhaseIsActive" name="isActive" value="true">
                            <label class="form-check-label" for="editPhaseIsActive">Active</label>
                            <input type="hidden" name="isActive" value="false">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
(function() {
    function initPhasesTab() {
        // Handle edit phase button clicks
        $(document).on('click', '.edit-phase-btn', function() {
            const id = $(this).data('phase-id');
            const name = $(this).data('phase-name');
            const description = $(this).data('phase-description') || '';
            const sortOrder = $(this).data('phase-sortorder');
            const isActive = $(this).data('phase-isactive');
            
            console.log('editPhase called with:', { id, name, description, sortOrder, isActive });
            
            $('#editPhaseId').val(id);
            $('#editPhaseName').val(name);
            $('#editPhaseDescription').val(description);
            $('#editPhaseSortOrder').val(sortOrder);
            
            // Handle checkbox - convert string "true"/"false" to boolean
            const isActiveBool = isActive === true || isActive === 'true' || String(isActive).toLowerCase() === 'true';
            $('#editPhaseIsActive').prop('checked', isActiveBool);
            
            // Update hidden field based on checkbox state
            $('#editPhaseModal input[type="hidden"][name="isActive"]').val(isActiveBool ? 'true' : 'false');
            
            // Listen for checkbox changes
            $('#editPhaseIsActive').off('change').on('change', function() {
                $('#editPhaseModal input[type="hidden"][name="isActive"]').val($(this).is(':checked') ? 'true' : 'false');
            });
            
            $('#editPhaseModal').modal('show');
        });
        
        // Handle delete phase form submissions
        $(document).on('submit', '.delete-phase-form', function(e) {
            if (!confirm('Are you sure you want to delete this phase?')) {
                e.preventDefault();
                return false;
            }
            return true;
        });
    }

    // Wait for jQuery to be available
    if (typeof jQuery !== 'undefined') {
        $(document).ready(initPhasesTab);
    } else {
        document.addEventListener('DOMContentLoaded', function() {
            // Try again after a short delay to ensure jQuery is loaded
            var checkJQuery = setInterval(function() {
                if (typeof jQuery !== 'undefined') {
                    clearInterval(checkJQuery);
                    $(document).ready(initPhasesTab);
                }
            }, 50);
            
            // Stop trying after 5 seconds
            setTimeout(function() {
                clearInterval(checkJQuery);
            }, 5000);
        });
    }
})();
</script>

