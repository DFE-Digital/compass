@{
    ViewData["Title"] = "Settings";
    var riskTypes = ViewBag.RiskTypes as List<Compass.Models.RiskType> ?? new List<Compass.Models.RiskType>();
    var riskTiers = ViewBag.RiskTiers as List<Compass.Models.RiskTier> ?? new List<Compass.Models.RiskTier>();
    var actionSources = ViewBag.ActionSources as List<Compass.Models.ActionSource> ?? new List<Compass.Models.ActionSource>();
    var wcagCriteria = ViewBag.WcagCriteria as List<Compass.Models.WcagCriterion> ?? new List<Compass.Models.WcagCriterion>();
    var businessAreas = ViewBag.BusinessAreas as List<Compass.Models.BusinessAreaLookup> ?? new List<Compass.Models.BusinessAreaLookup>();
    var phases = ViewBag.Phases as List<Compass.Models.PhaseLookup> ?? new List<Compass.Models.PhaseLookup>();
    var gddRoles = ViewBag.GddRoles as List<Compass.Models.GddRole> ?? new List<Compass.Models.GddRole>();
    var skills = ViewBag.Skills as List<Compass.Models.Skill> ?? new List<Compass.Models.Skill>();
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Users", "Admin")">Administration</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Settings</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <!-- Navigation Pills in 2-column grid -->
        <div class="row mb-3">
            <div class="col-12">
                <ul class="nav nav-pills settings-nav d-flex flex-wrap" id="settings-nav" role="tablist">
                    <li class="nav-item flex-fill col-md-6 px-1 mb-2">
                        <a class="nav-link active text-center" id="risk-types-tab" data-toggle="pill" href="#risk-types" role="tab" aria-controls="risk-types" aria-selected="true">
                            Risk types <span class="badge badge-light ml-2">@riskTypes.Count</span>
                        </a>
                    </li>
                    <li class="nav-item flex-fill col-md-6 px-1 mb-2">
                        <a class="nav-link text-center" id="risk-tiers-tab" data-toggle="pill" href="#risk-tiers" role="tab" aria-controls="risk-tiers" aria-selected="false">
                            Risk tiers <span class="badge badge-light ml-2">@riskTiers.Count</span>
                        </a>
                    </li>
                    <li class="nav-item flex-fill col-md-6 px-1 mb-2">
                        <a class="nav-link text-center" id="action-sources-tab" data-toggle="pill" href="#action-sources" role="tab" aria-controls="action-sources" aria-selected="false">
                            Action sources <span class="badge badge-light ml-2">@actionSources.Count</span>
                        </a>
                    </li>
                    <li class="nav-item flex-fill col-md-6 px-1 mb-2">
                        <a class="nav-link text-center" id="wcag-criteria-tab" data-toggle="pill" href="#wcag-criteria" role="tab" aria-controls="wcag-criteria" aria-selected="false">
                            WCAG Criteria <span class="badge badge-light ml-2">@wcagCriteria.Count</span>
                        </a>
                    </li>
                    <li class="nav-item flex-fill col-md-6 px-1 mb-2">
                        <a class="nav-link text-center" id="business-areas-tab" data-toggle="pill" href="#business-areas" role="tab" aria-controls="business-areas" aria-selected="false">
                            Business areas <span class="badge badge-light ml-2">@businessAreas.Count</span>
                        </a>
                    </li>
                    <li class="nav-item flex-fill col-md-6 px-1 mb-2">
                        <a class="nav-link text-center" id="phases-tab" data-toggle="pill" href="#phases" role="tab" aria-controls="phases" aria-selected="false">
                            Phases <span class="badge badge-light ml-2">@phases.Count</span>
                        </a>
                    </li>
                    <li class="nav-item flex-fill col-md-6 px-1 mb-2">
                        <a class="nav-link text-center" id="gdd-roles-tab" data-toggle="pill" href="#gdd-roles" role="tab" aria-controls="gdd-roles" aria-selected="false">
                            GDD Roles <span class="badge badge-light ml-2">@gddRoles.Count</span>
                        </a>
                    </li>
                    <li class="nav-item flex-fill col-md-6 px-1 mb-2">
                        <a class="nav-link text-center" id="skills-tab" data-toggle="pill" href="#skills" role="tab" aria-controls="skills" aria-selected="false">
                            Skills <span class="badge badge-light ml-2">@skills.Count</span>
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Tab Content -->
        <div class="row">
            <div class="col-12">
                <div class="tab-content" id="settings-tabContent">
                    <!-- Risk Types Tab -->
                    <div class="tab-pane fade show active" id="risk-types" role="tabpanel" aria-labelledby="risk-types-tab">
                        <div class="card">
                            <div class="card-header">
                                <div class="d-flex justify-content-between align-items-center">
                                    <h3 class="card-title mb-0">Risk types</h3>
                                    <a asp-action="CreateRiskType">
                                        Create new
                                    </a>
                                </div>
                            </div>
                            <div class="card-body">
                                <p class="text-muted">Manage the risk type taxonomy for classifying risks by category. Risks can be assigned multiple types.</p>
                        
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Code</th>
                                        <th>Name</th>
                                        <th>Summary</th>
                                        <th>Status</th>
                                        <th class="col-actions">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (riskTypes.Any())
                                    {
                                        @foreach (var item in riskTypes)
                                        {
                                            <tr>
                                                <td><code>@item.Code</code></td>
                                                <td><strong>@item.Name</strong></td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(item.Summary))
                                                    {
                                                        <small class="text-muted">@item.Summary</small>
                                                    }
                                                    else
                                                    {
                                                        <span>-</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (item.IsActive)
                                                    {
                                                        <span class="badge badge-success">Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-secondary">Inactive</span>
                                                    }
                                                </td>
                                                <td>
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <a asp-action="EditRiskType" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Edit">
                                                            Edit
                                                        </a>
                                                        <a asp-action="DeleteRiskType" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Delete">
                                                            Delete
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="5" class="text-center text-muted">No risk types found.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                            </div>
                        </div>
                    </div>

                    <!-- Risk Tiers Tab -->
                    <div class="tab-pane fade" id="risk-tiers" role="tabpanel" aria-labelledby="risk-tiers-tab">
                        <div class="card">
                            <div class="card-header">
                                <div class="d-flex justify-content-between align-items-center">
                                    <h3 class="card-title mb-0">Risk tiers</h3>
                                    <a asp-action="CreateRiskTier">
                                        Create new
                                    </a>
                                </div>
                            </div>
                            <div class="card-body">
                                <p class="text-muted">Manage the risk tier levels for classifying risks by governance scope. Risks are assigned one tier level.</p>
                        
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th style="width: 60px;">Order</th>
                                        <th>Code</th>
                                        <th>Name</th>
                                        <th>Summary</th>
                                        <th>Status</th>
                                        <th class="col-actions">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (riskTiers.Any())
                                    {
                                        @foreach (var item in riskTiers)
                                        {
                                            <tr>
                                                <td class="text-center"><span class="badge badge-secondary">@item.SortOrder</span></td>
                                                <td><code>@item.Code</code></td>
                                                <td><strong>@item.Name</strong></td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(item.Summary))
                                                    {
                                                        <small class="text-muted">@item.Summary</small>
                                                    }
                                                    else
                                                    {
                                                        <span>-</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (item.IsActive)
                                                    {
                                                        <span class="badge badge-success">Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-secondary">Inactive</span>
                                                    }
                                                </td>
                                                <td>
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <a asp-action="EditRiskTier" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Edit">
                                                            Edit
                                                        </a>
                                                        <a asp-action="DeleteRiskTier" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Delete">
                                                            Delete
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted">No risk tiers found.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                            </div>
                        </div>
                    </div>

                    <!-- Action Sources Tab -->
                    <div class="tab-pane fade" id="action-sources" role="tabpanel" aria-labelledby="action-sources-tab">
                        <div class="card">
                            <div class="card-header">
                                <div class="d-flex justify-content-between align-items-center">
                                    <h3 class="card-title mb-0">Action sources</h3>
                                    <a asp-action="CreateActionSource">
                                        Create new
                                    </a>
                                </div>
                            </div>
                            <div class="card-body">
                                <p class="text-muted">Manage the action source types for tracking where actions originated. Actions are assigned one source type.</p>
                        
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th style="width: 60px;">Order</th>
                                        <th>Code</th>
                                        <th>Name</th>
                                        <th>Summary</th>
                                        <th>Status</th>
                                        <th class="col-actions">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (actionSources.Any())
                                    {
                                        @foreach (var item in actionSources)
                                        {
                                            <tr>
                                                <td class="text-center"><span class="badge badge-secondary">@item.SortOrder</span></td>
                                                <td><code>@item.Code</code></td>
                                                <td><strong>@item.Name</strong></td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(item.Summary))
                                                    {
                                                        <small class="text-muted">@item.Summary</small>
                                                    }
                                                    else
                                                    {
                                                        <span>-</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (item.IsActive)
                                                    {
                                                        <span class="badge badge-success">Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-secondary">Inactive</span>
                                                    }
                                                </td>
                                                <td>
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <a asp-action="EditActionSource" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Edit">
                                                            Edit
                                                        </a>
                                                        <a asp-action="DeleteActionSource" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Delete">
                                                            Delete
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted">No action sources found.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                            </div>
                        </div>
                    </div>

                    <!-- WCAG Criteria Tab -->
                    <div class="tab-pane fade" id="wcag-criteria" role="tabpanel" aria-labelledby="wcag-criteria-tab">
                        <div class="card">
                            <div class="card-header">
                                <div class="d-flex justify-content-between align-items-center">
                                    <h3 class="card-title mb-0">WCAG Criteria</h3>
                                    <a asp-action="CreateWcagCriterion">
                                        Create new
                                    </a>
                                </div>
                            </div>
                            <div class="card-body">
                                <p class="text-muted">Manage WCAG (Web Content Accessibility Guidelines) criteria for tracking accessibility issues.</p>
                        
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Criterion</th>
                                        <th>Title</th>
                                        <th>Level</th>
                                        <th>Version</th>
                                        <th>Status</th>
                                        <th class="col-actions">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (wcagCriteria.Any())
                                    {
                                        @foreach (var item in wcagCriteria.OrderBy(w => w.Criterion))
                                        {
                                            <tr>
                                                <td><code>@item.Criterion</code></td>
                                                <td><strong>@item.Title</strong></td>
                                                <td><span class="badge badge-@(item.Level == "AAA" ? "primary" : item.Level == "AA" ? "info" : "secondary")">@item.Level</span></td>
                                                <td>WCAG @item.Version</td>
                                                <td>
                                                    @if (item.IsActive)
                                                    {
                                                        <span class="badge badge-success">Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-secondary">Inactive</span>
                                                    }
                                                </td>
                                                <td>
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <a asp-action="EditWcagCriterion" asp-route-id="@item.Id" class="btn btn-outline-primary" title="Edit">
                                                            Edit
                                                        </a>
                                                        <a asp-action="DeleteWcagCriterion" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Delete">
                                                            Delete
                                                        </a>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted">No WCAG criteria found.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                            </div>
                        </div>
                    </div>

                    <!-- Business Areas Tab -->
                    <div class="tab-pane fade" id="business-areas" role="tabpanel" aria-labelledby="business-areas-tab">
                        @await Html.PartialAsync("~/Views/Admin/Settings/_BusinessAreasTab.cshtml", businessAreas)
                    </div>

                    <!-- Phases Tab -->
                    <div class="tab-pane fade" id="phases" role="tabpanel" aria-labelledby="phases-tab">
                        @await Html.PartialAsync("~/Views/Admin/Settings/_PhasesTab.cshtml", phases)
                    </div>

                    <!-- GDD Roles Tab -->
                    <div class="tab-pane fade" id="gdd-roles" role="tabpanel" aria-labelledby="gdd-roles-tab">
                        @await Html.PartialAsync("~/Views/Admin/Settings/_GddRolesTab.cshtml", gddRoles)
                    </div>

                    <!-- Skills Tab -->
                    <div class="tab-pane fade" id="skills" role="tabpanel" aria-labelledby="skills-tab">
                        @await Html.PartialAsync("~/Views/Admin/Settings/_SkillsTab.cshtml", skills)
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


@section Scripts {
    <script>
        // Initialize Bootstrap tabs
        $('#settings-nav a').on('click', function (e) {
            e.preventDefault();
            $(this).tab('show');
        });
    </script>
}

