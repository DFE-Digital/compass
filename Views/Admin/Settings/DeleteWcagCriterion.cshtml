@model Compass.Models.WcagCriterion

@{
    ViewData["Title"] = "Delete WCAG criterion";
    var issueCount = ViewBag.IssueCount as int? ?? 0;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Users", "Admin")">Administration</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Settings", "Admin")">Settings</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("WcagCriteria", "Admin")">WCAG Criteria</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Delete</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xxl-2 col-xl-2 col-lg-2 col-md-2 col-sm-12 col-12">
                <partial name="~/Views/Admin/Settings/_SettingsSidebar.cshtml" />
            </div>

            <div class="col-xxl-10 col-xl-10 col-lg-10 col-md-10 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Delete WCAG criterion</h3>
                    </div>
                    <div class="card-body">
                <h5>Are you sure you want to delete this WCAG criterion?</h5>
                
                @if (issueCount > 0)
                {
                    <div class="alert alert-warning" role="alert">
                        <strong>Warning:</strong> This WCAG criterion is currently being used by <strong>@issueCount accessibility issue(s)</strong>. 
                        You must reassign those issues to a different criterion before you can delete this WCAG criterion.
                    </div>
                }
                
                <dl class="row mt-4">
                    <dt class="col-sm-3">Criterion</dt>
                    <dd class="col-sm-9"><code>@Model.Criterion</code></dd>

                    <dt class="col-sm-3">Title</dt>
                    <dd class="col-sm-9">@Model.Title</dd>

                    <dt class="col-sm-3">Level</dt>
                    <dd class="col-sm-9"><span class="badge badge-@(Model.Level == "AAA" ? "primary" : Model.Level == "AA" ? "info" : "secondary")">Level @Model.Level</span></dd>

                    <dt class="col-sm-3">Version</dt>
                    <dd class="col-sm-9">WCAG @Model.Version</dd>

                    <dt class="col-sm-3">Description</dt>
                    <dd class="col-sm-9">
                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <div class="border p-2">@Model.Description</div>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </dd>

                    <dt class="col-sm-3">URL</dt>
                    <dd class="col-sm-9">
                        @if (!string.IsNullOrEmpty(Model.Url))
                        {
                            <a href="@Model.Url" target="_blank" rel="noopener noreferrer">@Model.Url</a>
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">
                        @if (Model.IsActive)
                        {
                            <span class="badge badge-success">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-secondary">Inactive</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Created</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-3">Last updated</dt>
                    <dd class="col-sm-9">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
                
                <form asp-action="DeleteWcagCriterion" method="post" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    @if (issueCount > 0)
                    {
                        <a asp-action="WcagCriteria" class="btn btn-secondary">
                            Back to list
                        </a>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-danger">
                            Delete
                        </button>
                        <a asp-action="WcagCriteria" class="btn btn-secondary">
                            Cancel
                        </a>
                    }
                </form>
            </div>
        </div>
            </div>
        </div>
    </div>
</section>


