@model Compass.Models.Grade

@{
    ViewData["Title"] = "Create Grade";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item"><a href="/" style="color: #005ea5;">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index" style="color: #005ea5;">Admin</a></li>
            <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Grades" style="color: #005ea5;">Grades</a></li>
            <li class="breadcrumb-item active">Create Grade</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Create Grade</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-body">
                <form asp-action="CreateGrade" method="post">
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label asp-for="Code">Code <span class="text-danger">*</span></label>
                        <input asp-for="Code" class="form-control" required maxlength="50" />
                        <span asp-validation-for="Code" class="text-danger"></span>
                        <small class="form-text text-muted">Grade code (e.g., "AA", "AO", "G6 HOP")</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="DisplayName">Display Name</label>
                        <input asp-for="DisplayName" class="form-control" maxlength="200" />
                        <small class="form-text text-muted">Optional display name (e.g., "Administrative Assistant", "Grade 6 Head of Profession")</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="DisplayOrder">Display Order</label>
                        <input asp-for="DisplayOrder" class="form-control" type="number" value="0" />
                        <small class="form-text text-muted">Order for sorting (lower numbers appear first)</small>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" checked />
                            <label class="form-check-label" asp-for="IsActive">Active</label>
                        </div>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-primary">Create Grade</button>
                        <a asp-action="Grades" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

