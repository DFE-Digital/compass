@model List<Compass.Models.BusinessAreaLookup>
@{
    ViewData["Title"] = "Business areas";
}

@section Breadcrumbs {
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Settings", "Admin")">Settings</a></li>
            <li class="breadcrumb-item active" aria-current="page">Business areas</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Business areas</h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#createBusinessAreaModal">
                        Create new
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-body">
                <p class="text-muted">Manage business area options for projects. These are separate from the CMS business areas and specific to Compass.</p>

                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th style="width: 60px;">Order</th>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Status</th>
                                <th class="col-actions">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="text-center"><span class="badge badge-secondary">@item.SortOrder</span></td>
                                        <td><strong>@item.Name</strong></td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.Description))
                                            {
                                                <small class="text-muted">@item.Description</small>
                                            }
                                            else
                                            {
                                                <span>-</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.IsActive)
                                            {
                                                <span class="badge badge-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-secondary">Inactive</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <button type="button" class="btn btn-outline-primary" 
                                                        onclick="editBusinessArea(@item.Id, '@Html.Raw(item.Name.Replace("'", "\\'"))', '@Html.Raw(item.Description?.Replace("'", "\\'") ?? "")', @item.SortOrder, @(item.IsActive ? "true" : "false"))" 
                                                        title="Edit">
                                                    Edit
                                                </button>
                                                <form asp-action="DeleteBusinessArea" asp-route-id="@item.Id" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this business area?');">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-outline-danger" title="Delete">
                                                        Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted">No business areas found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Create Business Area Modal -->
<div class="modal fade" id="createBusinessAreaModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create Business Area</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="CreateBusinessArea" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="form-group">
                        <label for="baName">Name</label>
                        <input type="text" class="form-control" id="baName" name="name" required maxlength="100">
                    </div>
                    <div class="form-group">
                        <label for="baDescription">Description</label>
                        <textarea class="form-control" id="baDescription" name="description" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="baSortOrder">Sort Order</label>
                        <input type="number" class="form-control" id="baSortOrder" name="sortOrder" value="0" min="0">
                        <small class="form-text text-muted">Lower numbers appear first</small>
                    </div>
                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="baIsActive" name="isActive" value="true" checked>
                            <label class="form-check-label" for="baIsActive">Active</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Business Area Modal -->
<div class="modal fade" id="editBusinessAreaModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Business Area</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="EditBusinessArea" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editBaId" name="id">
                <div class="modal-body">
                    <div class="form-group">
                        <label for="editBaName">Name</label>
                        <input type="text" class="form-control" id="editBaName" name="name" required maxlength="100">
                    </div>
                    <div class="form-group">
                        <label for="editBaDescription">Description</label>
                        <textarea class="form-control" id="editBaDescription" name="description" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="editBaSortOrder">Sort Order</label>
                        <input type="number" class="form-control" id="editBaSortOrder" name="sortOrder" min="0">
                    </div>
                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="editBaIsActive" name="isActive" value="true">
                            <label class="form-check-label" for="editBaIsActive">Active</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script nonce="@Context.Items["Nonce"]">
function editBusinessArea(id, name, description, sortOrder, isActive) {
    $('#editBaId').val(id);
    $('#editBaName').val(name);
    $('#editBaDescription').val(description);
    $('#editBaSortOrder').val(sortOrder);
    $('#editBaIsActive').prop('checked', isActive);
    $('#editBusinessAreaModal').modal('show');
}
</script>
}

