@model Compass.Models.Grade

@{
    ViewData["Title"] = "Edit Grade";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4 breadcrumb-standard">
            <li class="breadcrumb-item"><a href="/" class="breadcrumb-link-standard">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index" class="breadcrumb-link-standard">Admin</a></li>
            <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Grades" class="breadcrumb-link-standard">Grades</a></li>
            <li class="breadcrumb-item active breadcrumb-active-standard">Edit Grade</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Edit Grade</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-body">
                <form asp-action="EditGrade" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="form-group">
                        <label asp-for="Code">Code <span class="text-danger">*</span></label>
                        <input asp-for="Code" class="form-control" required maxlength="50" />
                        <span asp-validation-for="Code" class="text-danger"></span>
                        <small class="form-text text-muted">Grade code (e.g., "AA", "AO", "G6 HOP")</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="DisplayName">Display Name</label>
                        <input asp-for="DisplayName" class="form-control" maxlength="200" />
                        <small class="form-text text-muted">Optional display name (e.g., "Administrative Assistant", "Grade 6 Head of Profession")</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="DisplayOrder">Display Order</label>
                        <input asp-for="DisplayOrder" class="form-control" type="number" />
                        <small class="form-text text-muted">Order for sorting (lower numbers appear first)</small>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label class="form-check-label" asp-for="IsActive">Active</label>
                        </div>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-success">Update Grade</button>
                        <a asp-action="Grades" class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

