@model List<Compass.Models.KpiCategory>
@{
    ViewData["Title"] = "KPI categories";
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Settings", "Admin")">Settings</a></li>
                    <li class="breadcrumb-item active" aria-current="page">KPI categories</li>
                </ol>
                <h1 class="m-0">KPI categories</h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#createKpiCategoryModal">
                        Create new
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-xxl-2 col-xl-2 col-lg-2 col-md-2 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Administration</h3>
                    </div>
                    <div class="card-body p-2">
                        <div class="nav flex-column nav-pills">
                            <a href="@Url.Action("Index", "PerformanceMetric")" class="nav-link @(currentController == "PerformanceMetric" ? "active" : "")">
                                Operational reports
                            </a>
                            <a href="@Url.Action("Index", "EnterpriseMetric")" class="nav-link @(currentController == "EnterpriseMetric" ? "active" : "")">
                                Enterprise metrics
                            </a>
                            <a href="@Url.Action("Index", "FunctionalStandard")" class="nav-link @(currentController == "FunctionalStandard" ? "active" : "")">
                                Functional standards
                            </a>
                            <a href="@Url.Action("Objectives", "Admin")" class="nav-link @(currentAction.StartsWith("Objective") ? "active" : "")">
                                Priority outcomes
                            </a>
                            <a href="@Url.Action("Missions", "Admin")" class="nav-link @(currentAction.StartsWith("Mission") ? "active" : "")">
                                Missions
                            </a>
                            <a href="@Url.Action("FundingSources", "Admin")" class="nav-link @(currentAction.Contains("FundingSource") ? "active" : "")">
                                Funding sources
                            </a>
                            <a href="@Url.Action("Index", "GovernmentDepartment")" class="nav-link @(currentController == "GovernmentDepartment" ? "active" : "")">
                                Government departments
                            </a>
                            <a href="@Url.Action("Index", "Organizational")" class="nav-link @(currentController == "Organizational" ? "active" : "")">
                                Organizational
                            </a>
                            <a href="@Url.Action("RiskTypes", "Admin")" class="nav-link @(currentAction.Contains("RiskType") ? "active" : "")">
                                Risk types
                            </a>
                            <a href="@Url.Action("RiskTiers", "Admin")" class="nav-link @(currentAction.Contains("RiskTier") ? "active" : "")">
                                Risk tiers
                            </a>
                            <a href="@Url.Action("ActionSources", "Admin")" class="nav-link @(currentAction.Contains("ActionSource") ? "active" : "")">
                                Action sources
                            </a>
                            <a href="@Url.Action("DeliveryPriorities", "Admin")" class="nav-link @(currentAction.Contains("DeliveryPriorit") ? "active" : "")">
                                Delivery priorities
                            </a>
                            <a href="@Url.Action("WcagCriteria", "Admin")" class="nav-link @(currentAction.Contains("WcagCriterion") || currentAction.Contains("WcagCriteria") ? "active" : "")">
                                WCAG Criteria
                            </a>
                            <a href="@Url.Action("BusinessAreas", "Admin")" class="nav-link @(currentAction.Contains("BusinessArea") ? "active" : "")">
                                Business areas
                            </a>
                            <a href="@Url.Action("Phases", "Admin")" class="nav-link @(currentAction.Contains("Phase") ? "active" : "")">
                                Phases
                            </a>
                            <a href="@Url.Action("GddRoles", "Admin")" class="nav-link @(currentAction.Contains("GddRole") ? "active" : "")">
                                GDD Roles
                            </a>
                            <a href="@Url.Action("Skills", "Admin")" class="nav-link @(currentAction.Contains("Skill") ? "active" : "")">
                                Skills
                            </a>
                            <a href="@Url.Action("KpiCategories", "Admin")" class="nav-link @(currentAction.Contains("KpiCategor") ? "active" : "")">
                                KPI categories
                            </a>
                            <a href="@Url.Action("ApiTokens", "Admin")" class="nav-link @(currentAction.Contains("ApiToken") ? "active" : "")">
                                API tokens
                            </a>
                            <a href="@Url.Action("Index", "Admin", new { area = "" })" class="nav-link @(currentAction == "Settings" ? "active" : "")">
                                User management
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xxl-10 col-xl-10 col-lg-10 col-md-10 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">KPI categories</h3>
                    </div>
                    <div class="card-body">
                        <p class="text-muted">Manage KPI categories available in Compass. These replace the older CMS-managed categories and drive KPI code generation.</p>

                        <div class="table-responsive">
                            <table class="table table-hover table-striped">
                                <thead>
                                    <tr>
                                        <th style="width: 80px;">Order</th>
                                        <th style="width: 20%;">Name</th>
                                        <th style="width: 15%;">Code</th>
                                        <th>Description</th>
                                        <th style="width: 110px;">Status</th>
                                        <th class="col-actions text-right">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.Any())
                                    {
                                        foreach (var category in Model)
                                        {
                                            <tr class="@(category.IsActive ? string.Empty : "text-muted")">
                                                <td class="text-center">
                                                    <span class="badge badge-secondary">@category.SortOrder</span>
                                                </td>
                                                <td><strong>@category.Name</strong></td>
                                                <td><code>@category.Code</code></td>
                                                <td>
                                                    @if (!string.IsNullOrWhiteSpace(category.Description))
                                                    {
                                                        <small class="text-muted">@category.Description</small>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">-</span>
                                                    }
                                                </td>
                                                <td>
                                                    @if (category.IsActive)
                                                    {
                                                        <span class="badge badge-success">Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-secondary">Inactive</span>
                                                    }
                                                </td>
                                                <td class="text-right">
                                                    <div class="btn-group btn-group-sm" role="group">
                                                        <button type="button"
                                                                class="btn btn-outline-primary"
                                                                data-toggle="modal"
                                                                data-target="#editKpiCategoryModal"
                                                                data-id="@category.Id"
                                                                data-name="@category.Name"
                                                                data-code="@category.Code"
                                                                data-description="@category.Description"
                                                                data-sortorder="@category.SortOrder"
                                                                data-active="@category.IsActive.ToString().ToLower()">
                                                            Edit
                                                        </button>
                                                        <form asp-action="DeleteKpiCategory"
                                                              asp-controller="Admin"
                                                              method="post"
                                                              class="d-inline"
                                                              onsubmit="return confirm('Delete @category.Name? This cannot be undone.');">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@category.Id" />
                                                            <button type="submit" class="btn btn-outline-danger">Delete</button>
                                                        </form>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted">No KPI categories have been configured.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Create KPI Category Modal -->
<div class="modal fade" id="createKpiCategoryModal" tabindex="-1" role="dialog" aria-labelledby="createKpiCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createKpiCategoryModalLabel">Create KPI category</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="CreateKpiCategory" asp-controller="Admin" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="form-group">
                        <label for="createCategoryName">Name</label>
                        <input type="text" class="form-control" id="createCategoryName" name="Name" required />
                        <small class="form-text text-muted">This label is shown in KPI forms.</small>
                    </div>
                    <div class="form-group">
                        <label for="createCategoryCode">Code</label>
                        <input type="text" class="form-control" id="createCategoryCode" name="Code" />
                        <small class="form-text text-muted">Leave blank to generate from the name. Letters and numbers only.</small>
                    </div>
                    <div class="form-group">
                        <label for="createCategoryDescription">Description</label>
                        <textarea class="form-control" id="createCategoryDescription" name="Description" rows="2"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="createCategorySortOrder">Sort order</label>
                        <input type="number" class="form-control" id="createCategorySortOrder" name="SortOrder" min="1" />
                        <small class="form-text text-muted">Lower numbers appear first.</small>
                    </div>
                    <div class="form-group form-check">
                        <input type="checkbox" class="form-check-input" id="createCategoryIsActive" name="IsActive" checked />
                        <label class="form-check-label" for="createCategoryIsActive">Active</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create category</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit KPI Category Modal -->
<div class="modal fade" id="editKpiCategoryModal" tabindex="-1" role="dialog" aria-labelledby="editKpiCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editKpiCategoryModalLabel">Edit KPI category</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateKpiCategory" asp-controller="Admin" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editCategoryId" name="id" />
                <div class="modal-body">
                    <div class="form-group">
                        <label for="editCategoryName">Name</label>
                        <input type="text" class="form-control" id="editCategoryName" name="name" required />
                    </div>
                    <div class="form-group">
                        <label for="editCategoryCode">Code</label>
                        <input type="text" class="form-control" id="editCategoryCode" name="code" />
                        <small class="form-text text-muted">Used when generating KPI IDs.</small>
                    </div>
                    <div class="form-group">
                        <label for="editCategoryDescription">Description</label>
                        <textarea class="form-control" id="editCategoryDescription" name="description" rows="2"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="editCategorySortOrder">Sort order</label>
                        <input type="number" class="form-control" id="editCategorySortOrder" name="sortOrder" min="1" />
                    </div>
                    <div class="form-group form-check">
                        <input type="checkbox" class="form-check-input" id="editCategoryIsActive" name="isActive" />
                        <label class="form-check-label" for="editCategoryIsActive">Active</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script nonce="@Context.Items["Nonce"]">
    $('#editKpiCategoryModal').on('show.bs.modal', function (event) {
        var button = $(event.relatedTarget);
        $('#editCategoryId').val(button.data('id'));
        $('#editCategoryName').val(button.data('name'));
        $('#editCategoryCode').val(button.data('code'));
        $('#editCategoryDescription').val(button.data('description'));
        $('#editCategorySortOrder').val(button.data('sortorder'));
        $('#editCategoryIsActive').prop('checked', button.data('active') === true || button.data('active') === 'true');
    });

    $('#editKpiCategoryModal').on('hidden.bs.modal', function () {
        $('#editCategoryId').val('');
        $('#editCategoryName').val('');
        $('#editCategoryCode').val('');
        $('#editCategoryDescription').val('');
        $('#editCategorySortOrder').val('');
        $('#editCategoryIsActive').prop('checked', true);
    });
</script>

