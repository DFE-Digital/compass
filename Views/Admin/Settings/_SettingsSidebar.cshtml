@{
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
    var isRiskTypes = currentAction.Contains("RiskType");
    var isRiskTiers = currentAction.Contains("RiskTier");
    var isActionSources = currentAction.Contains("ActionSource");
    var isWcagCriteria = currentAction.Contains("WcagCriterion") || currentAction.Contains("WcagCriteria");
    var isGddRoles = currentAction.Contains("GddRole");
    var isSkills = currentAction.Contains("Skill");
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Lookup types</h3>
    </div>
    <div class="card-body p-2">
        <div class="nav flex-column nav-pills">
            <a href="@Url.Action("RiskTypes", "Admin")" class="nav-link @(isRiskTypes ? "active" : "")">
                Risk types
            </a>
            <a href="@Url.Action("RiskTiers", "Admin")" class="nav-link @(isRiskTiers ? "active" : "")">
                Risk tiers
            </a>
            <a href="@Url.Action("ActionSources", "Admin")" class="nav-link @(isActionSources ? "active" : "")">
                Action sources
            </a>
            <a href="@Url.Action("WcagCriteria", "Admin")" class="nav-link @(isWcagCriteria ? "active" : "")">
                WCAG Criteria
            </a>
            <a href="@Url.Action("GddRoles", "Admin")" class="nav-link @(isGddRoles ? "active" : "")">
                GDD Roles
            </a>
            <a href="@Url.Action("Skills", "Admin")" class="nav-link @(isSkills ? "active" : "")">
                Skills
            </a>
        </div>
    </div>
</div>

