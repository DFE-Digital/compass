@model Compass.Models.WcagCriterion

@{
    ViewData["Title"] = "Edit WCAG criterion";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Users", "Admin")">Administration</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Settings", "Admin")">Settings</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("WcagCriteria", "Admin")">WCAG Criteria</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Edit</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xxl-2 col-xl-2 col-lg-2 col-md-2 col-sm-12 col-12">
                <partial name="~/Views/Admin/Settings/_SettingsSidebar.cshtml" />
            </div>

            <div class="col-xxl-10 col-xl-10 col-lg-10 col-md-10 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Edit WCAG criterion</h3>
                    </div>
                    <div class="card-body">
                <form asp-action="EditWcagCriterion" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="form-group">
                        <label asp-for="Criterion" class="control-label">Criterion Reference <span class="text-danger">*</span></label>
                        <input asp-for="Criterion" class="form-control" maxlength="20" style="font-family: monospace;" />
                        <span asp-validation-for="Criterion" class="text-danger"></span>
                        <small class="form-text text-muted">The WCAG criterion reference number (e.g., 1.1.1, 2.4.3)</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="Title" class="control-label">Title <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control" maxlength="200" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                        <small class="form-text text-muted">Display name of the criterion</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="Description" class="control-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                        <small class="form-text text-muted">Detailed explanation of what this criterion requires</small>
                    </div>

                    <div class="form-group">
                        <label asp-for="Url" class="control-label">URL</label>
                        <input asp-for="Url" type="url" class="form-control" />
                        <span asp-validation-for="Url" class="text-danger"></span>
                        <small class="form-text text-muted">Link to the official WCAG documentation page</small>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Level" class="control-label">Level <span class="text-danger">*</span></label>
                                <select asp-for="Level" class="form-control">
                                    <option value="">Select level...</option>
                                    <option value="A">Level A</option>
                                    <option value="AA">Level AA</option>
                                    <option value="AAA">Level AAA</option>
                                </select>
                                <span asp-validation-for="Level" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Version" class="control-label">WCAG Version <span class="text-danger">*</span></label>
                                <select asp-for="Version" class="form-control">
                                    <option value="">Select version...</option>
                                    <option value="2.1">WCAG 2.1</option>
                                    <option value="2.2">WCAG 2.2</option>
                                    <option value="3.0">WCAG 3.0</option>
                                </select>
                                <span asp-validation-for="Version" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="SortOrder" class="control-label">Sort order</label>
                        <input asp-for="SortOrder" type="number" class="form-control" min="0" />
                        <span asp-validation-for="SortOrder" class="text-danger"></span>
                        <small class="form-text text-muted">Display order in autocomplete (lower numbers appear first)</small>
                    </div>

                    <div class="form-group">
                        <div class="custom-control custom-switch">
                            <input asp-for="IsActive" type="checkbox" class="custom-control-input" id="IsActive" />
                            <label class="custom-control-label" for="IsActive">Active</label>
                        </div>
                        <small class="form-text text-muted">Inactive criteria will not appear in autocomplete when adding issues</small>
                    </div>

                    <div class="form-group">
                        <button type="submit" class="btn btn-primary">
                            Update
                        </button>
                        <a asp-action="WcagCriteria" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


