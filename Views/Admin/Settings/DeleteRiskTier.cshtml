@model Compass.Models.RiskTier

@{
    ViewData["Title"] = "Delete risk tier";
    var riskCount = ViewBag.RiskCount as int? ?? 0;
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Users", "Admin")">Administration</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Settings", "Admin")">Settings</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("RiskTiers", "Admin")">Risk tiers</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Delete</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xxl-2 col-xl-2 col-lg-2 col-md-2 col-sm-12 col-12">
                <partial name="~/Views/Admin/Settings/_SettingsSidebar.cshtml" />
            </div>

            <div class="col-xxl-10 col-xl-10 col-lg-10 col-md-10 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Delete risk tier</h3>
                    </div>
                    <div class="card-body">
                <h5>Are you sure you want to delete this risk tier?</h5>
                
                @if (riskCount > 0)
                {
                    <div class="alert alert-warning" role="alert">
                        <strong>Warning:</strong> This risk tier is currently being used by <strong>@riskCount risk(s)</strong>. 
                        You must reassign those risks to a different tier before you can delete this risk tier.
                    </div>
                }
                
                <dl class="row mt-4">
                    <dt class="col-sm-3">Code</dt>
                    <dd class="col-sm-9"><code>@Model.Code</code></dd>

                    <dt class="col-sm-3">Name</dt>
                    <dd class="col-sm-9">@Model.Name</dd>

                    <dt class="col-sm-3">Sort order</dt>
                    <dd class="col-sm-9">@Model.SortOrder</dd>

                    <dt class="col-sm-3">Summary</dt>
                    <dd class="col-sm-9">@(Model.Summary ?? "-")</dd>

                    <dt class="col-sm-3">Description</dt>
                    <dd class="col-sm-9">
                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <div class="border p-2">@Model.Description</div>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">
                        @if (Model.IsActive)
                        {
                            <span class="badge badge-success">Active</span>
                        }
                        else
                        {
                            <span class="badge badge-secondary">Inactive</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Created</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-3">Last updated</dt>
                    <dd class="col-sm-9">@Model.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
                
                <form asp-action="DeleteRiskTier" method="post" class="mt-4">
                    <input type="hidden" asp-for="Id" />
                    @if (riskCount > 0)
                    {
                        <a asp-action="RiskTiers" class="btn btn-secondary">
                            Back to list
                        </a>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-danger">
                            Delete
                        </button>
                        <a asp-action="RiskTiers" class="btn btn-secondary">
                            Cancel
                        </a>
                    }
                </form>
            </div>
        </div>
            </div>
        </div>
    </div>
</section>

