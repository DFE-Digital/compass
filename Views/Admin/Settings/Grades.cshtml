@model IEnumerable<Compass.Models.Grade>

@{
    ViewData["Title"] = "Grades";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f4f8fb; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item"><a href="/" style="color: #005ea5;">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Index" style="color: #005ea5;">Admin</a></li>
            <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Settings" style="color: #005ea5;">Settings</a></li>
            <li class="breadcrumb-item active">Grades</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Grades</h1>
            </div>
            <div class="col-sm-6 text-right">
                <button type="button" class="btn btn-primary" onclick="openCreateGradeModal()">
                    <i class="fas fa-plus"></i> Create Grade
                </button>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Civil Service Grades</h3>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover table-striped">
                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Display Name</th>
                            <th>Display Order</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var grade in Model)
                            {
                                <tr class="@(!grade.IsActive ? "text-muted" : "")">
                                    <td><strong>@grade.Code</strong></td>
                                    <td>@(grade.DisplayName ?? "-")</td>
                                    <td>@grade.DisplayOrder</td>
                                    <td>
                                        @if (grade.IsActive)
                                        {
                                            <span class="badge badge-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-primary edit-grade" 
                                                data-id="@grade.Id"
                                                data-code="@grade.Code"
                                                data-displayname="@grade.DisplayName"
                                                data-displayorder="@grade.DisplayOrder"
                                                data-isactive="@grade.IsActive">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <form asp-action="DeleteGrade" method="post" style="display: inline;" 
                                              onsubmit="return confirm('Are you sure you want to delete this grade?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@grade.Id" />
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                <i class="fas fa-trash"></i> Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">No grades found. Create your first grade above.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Create/Edit Grade Modal -->
<div class="modal fade" id="gradeModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="gradeModalLabel">Create Grade</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="gradeForm" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <input type="hidden" id="gradeId" name="Id" />
                    
                    <div class="form-group">
                        <label for="gradeCode">Code <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="gradeCode" name="Code" required maxlength="50" />
                        <small class="form-text text-muted">Grade code (e.g., "AA", "AO", "G6 HOP")</small>
                    </div>

                    <div class="form-group">
                        <label for="gradeDisplayName">Display Name</label>
                        <input type="text" class="form-control" id="gradeDisplayName" name="DisplayName" maxlength="200" />
                        <small class="form-text text-muted">Optional display name (e.g., "Administrative Assistant", "Grade 6 Head of Profession")</small>
                    </div>

                    <div class="form-group">
                        <label for="gradeDisplayOrder">Display Order</label>
                        <input type="number" class="form-control" id="gradeDisplayOrder" name="DisplayOrder" value="0" />
                        <small class="form-text text-muted">Order for sorting (lower numbers appear first)</small>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="gradeIsActive" name="IsActive" checked />
                            <label class="form-check-label" for="gradeIsActive">Active</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        function openCreateGradeModal() {
            $('#gradeModalLabel').text('Create Grade');
            $('#gradeForm').attr('action', '@Url.Action("CreateGrade", "Admin")');
            $('#gradeId').val('');
            $('#gradeCode').val('');
            $('#gradeDisplayName').val('');
            $('#gradeDisplayOrder').val('0');
            $('#gradeIsActive').prop('checked', true);
            $('#gradeModal').modal('show');
        }

        function openEditGradeModal(id, code, displayName, displayOrder, isActive) {
            $('#gradeModalLabel').text('Edit Grade');
            $('#gradeForm').attr('action', '@Url.Action("EditGrade", "Admin")');
            $('#gradeId').val(id);
            $('#gradeCode').val(code);
            $('#gradeDisplayName').val(displayName || '');
            $('#gradeDisplayOrder').val(displayOrder || '0');
            $('#gradeIsActive').prop('checked', isActive === 'true' || isActive === true);
            $('#gradeModal').modal('show');
        }

        $(document).on('click', '.edit-grade', function(e) {
            e.preventDefault();
            var $item = $(this);
            openEditGradeModal(
                $item.data('id'),
                $item.data('code'),
                $item.data('displayname'),
                $item.data('displayorder'),
                $item.data('isactive')
            );
        });

        $('#gradeModal').on('hidden.bs.modal', function () {
            $('#gradeForm')[0].reset();
            $('.field-validation-valid').text('');
        });
    </script>
}

