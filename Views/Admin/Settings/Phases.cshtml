@model List<Compass.Models.PhaseLookup>
@{
    ViewData["Title"] = "Phases";
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4 breadcrumb-standard">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" class="breadcrumb-link-standard">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Settings", "Admin")" class="breadcrumb-link-standard">Settings</a>
            </li>
            <li class="breadcrumb-item active breadcrumb-active-standard" aria-current="page">Phases</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Phases</h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#createPhaseModal">
                        Create new
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-xxl-2 col-xl-2 col-lg-2 col-md-2 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Administration</h3>
                    </div>
                    <div class="card-body p-2">
                        <div class="nav flex-column nav-pills">
                            <a href="@Url.Action("Index", "PerformanceMetric")" class="nav-link @(currentController == "PerformanceMetric" ? "active" : "")">
                                Operational reports
                            </a>
                            <a href="@Url.Action("Index", "EnterpriseMetric")" class="nav-link @(currentController == "EnterpriseMetric" ? "active" : "")">
                                Enterprise metrics
                            </a>
                            <a href="@Url.Action("Index", "FunctionalStandard")" class="nav-link @(currentController == "FunctionalStandard" ? "active" : "")">
                                Functional standards
                            </a>
                            <a href="@Url.Action("Objectives", "Admin")" class="nav-link @(currentAction.StartsWith("Objective") ? "active" : "")">
                                Priority outcomes
                            </a>
                            <a href="@Url.Action("Missions", "Admin")" class="nav-link @(currentAction.StartsWith("Mission") ? "active" : "")">
                                Missions
                            </a>
                            <a href="@Url.Action("FundingSources", "Admin")" class="nav-link @(currentAction.Contains("FundingSource") ? "active" : "")">
                                Funding sources
                            </a>
                            <a href="@Url.Action("Index", "GovernmentDepartment")" class="nav-link @(currentController == "GovernmentDepartment" ? "active" : "")">
                                Government departments
                            </a>
                            <a href="@Url.Action("Index", "Organizational")" class="nav-link @(currentController == "Organizational" ? "active" : "")">
                                Organizational
                            </a>
                            <a href="@Url.Action("RiskTypes", "Admin")" class="nav-link @(currentAction.Contains("RiskType") ? "active" : "")">
                                Risk types
                            </a>
                            <a href="@Url.Action("RiskTiers", "Admin")" class="nav-link @(currentAction.Contains("RiskTier") ? "active" : "")">
                                Risk tiers
                            </a>
                            <a href="@Url.Action("ActionSources", "Admin")" class="nav-link @(currentAction.Contains("ActionSource") ? "active" : "")">
                                Action sources
                            </a>
                            <a href="@Url.Action("DeliveryPriorities", "Admin")" class="nav-link @(currentAction.Contains("DeliveryPriorit") ? "active" : "")">
                                Delivery priorities
                            </a>
                            <a href="@Url.Action("WcagCriteria", "Admin")" class="nav-link @(currentAction.Contains("WcagCriterion") || currentAction.Contains("WcagCriteria") ? "active" : "")">
                                WCAG Criteria
                            </a>
                            <a href="@Url.Action("BusinessAreas", "Admin")" class="nav-link @(currentAction.Contains("BusinessArea") ? "active" : "")">
                                Business areas
                            </a>
                            <a href="@Url.Action("Phases", "Admin")" class="nav-link @(currentAction.Contains("Phase") ? "active" : "")">
                                Phases
                            </a>
                            <a href="@Url.Action("GddRoles", "Admin")" class="nav-link @(currentAction.Contains("GddRole") ? "active" : "")">
                                GDD Roles
                            </a>
                            <a href="@Url.Action("Skills", "Admin")" class="nav-link @(currentAction.Contains("Skill") ? "active" : "")">
                                Skills
                            </a>
                            <a href="@Url.Action("KpiCategories", "Admin")" class="nav-link @(currentAction.Contains("KpiCategor") ? "active" : "")">
                                KPI categories
                            </a>
                            <a href="@Url.Action("ApiTokens", "Admin")" class="nav-link @(currentAction.Contains("ApiToken") ? "active" : "")">
                                API tokens
                            </a>
                            <a href="@Url.Action("Index", "Admin", new { area = "" })" class="nav-link @(currentAction == "Settings" ? "active" : "")">
                                User management
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xxl-10 col-xl-10 col-lg-10 col-md-10 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Phases</h3>
                    </div>
                    <div class="card-body">
                <p class="text-muted">Manage phase options for projects. These are separate from the CMS phases and specific to Compass delivery tracking.</p>

                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th class="col-width-60px">Order</th>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Status</th>
                                <th class="col-actions">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="text-center"><span class="badge badge-secondary">@item.SortOrder</span></td>
                                        <td><strong>@item.Name</strong></td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.Description))
                                            {
                                                <small class="text-muted">@item.Description</small>
                                            }
                                            else
                                            {
                                                <span>-</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.IsActive)
                                            {
                                                <span class="badge badge-success">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-secondary">Inactive</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <button type="button" class="btn btn-outline-primary edit-phase-btn" 
                                                        data-phase-id="@item.Id"
                                                        data-phase-name="@Html.Raw(item.Name.Replace("'", "\\'"))"
                                                        data-phase-description="@Html.Raw(item.Description?.Replace("'", "\\'") ?? "")"
                                                        data-phase-sortorder="@item.SortOrder"
                                                        data-phase-isactive="@(item.IsActive ? "true" : "false")"
                                                        title="Edit">
                                                    Edit
                                                </button>
                                                <form asp-action="DeletePhase" asp-route-id="@item.Id" method="post" class="d-inline delete-phase-form">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-outline-danger" title="Delete">
                                                        Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted">No phases found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Create Phase Modal -->
<div class="modal fade" id="createPhaseModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create Phase</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="CreatePhase" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="form-group">
                        <label for="phaseName">Name</label>
                        <input type="text" class="form-control" id="phaseName" name="name" required maxlength="100">
                    </div>
                    <div class="form-group">
                        <label for="phaseDescription">Description</label>
                        <textarea class="form-control" id="phaseDescription" name="description" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="phaseSortOrder">Sort Order</label>
                        <input type="number" class="form-control" id="phaseSortOrder" name="sortOrder" value="0" min="0">
                        <small class="form-text text-muted">Lower numbers appear first</small>
                    </div>
                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="phaseIsActive" name="isActive" value="true" checked>
                            <label class="form-check-label" for="phaseIsActive">Active</label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Phase Modal -->
<div class="modal fade" id="editPhaseModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Phase</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="EditPhase" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editPhaseId" name="id">
                <div class="modal-body">
                    <div class="form-group">
                        <label for="editPhaseName">Name</label>
                        <input type="text" class="form-control" id="editPhaseName" name="name" required maxlength="100">
                    </div>
                    <div class="form-group">
                        <label for="editPhaseDescription">Description</label>
                        <textarea class="form-control" id="editPhaseDescription" name="description" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="editPhaseSortOrder">Sort Order</label>
                        <input type="number" class="form-control" id="editPhaseSortOrder" name="sortOrder" min="0">
                    </div>
                    <div class="form-group">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="editPhaseIsActive" name="isActive" value="true">
                            <label class="form-check-label" for="editPhaseIsActive">Active</label>
                            <input type="hidden" name="isActive" value="false">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script nonce="@Context.Items["Nonce"]">
(function() {
    function initPhasesPage() {
        // Handle edit phase button clicks
        $(document).on('click', '.edit-phase-btn', function() {
            const id = $(this).data('phase-id');
            const name = $(this).data('phase-name');
            const description = $(this).data('phase-description') || '';
            const sortOrder = $(this).data('phase-sortorder');
            const isActive = $(this).data('phase-isactive');
            
            $('#editPhaseId').val(id);
            $('#editPhaseName').val(name);
            $('#editPhaseDescription').val(description);
            $('#editPhaseSortOrder').val(sortOrder);
            
            // Handle checkbox - convert string "true"/"false" to boolean
            const isActiveBool = isActive === true || isActive === 'true' || String(isActive).toLowerCase() === 'true';
            $('#editPhaseIsActive').prop('checked', isActiveBool);
            
            // Update hidden field based on checkbox state
            $('#editPhaseModal input[type="hidden"][name="isActive"]').val(isActiveBool ? 'true' : 'false');
            
            // Listen for checkbox changes
            $('#editPhaseIsActive').off('change').on('change', function() {
                $('#editPhaseModal input[type="hidden"][name="isActive"]').val($(this).is(':checked') ? 'true' : 'false');
            });
            
            $('#editPhaseModal').modal('show');
        });
        
        // Handle delete phase form submissions
        $(document).on('submit', '.delete-phase-form', function(e) {
            if (!confirm('Are you sure you want to delete this phase?')) {
                e.preventDefault();
                return false;
            }
            return true;
        });
    }

    // Wait for jQuery to be available
    if (typeof jQuery !== 'undefined') {
        $(document).ready(initPhasesPage);
    } else {
        document.addEventListener('DOMContentLoaded', function() {
            // Try again after a short delay to ensure jQuery is loaded
            var checkJQuery = setInterval(function() {
                if (typeof jQuery !== 'undefined') {
                    clearInterval(checkJQuery);
                    $(document).ready(initPhasesPage);
                }
            }, 50);
            
            // Stop trying after 5 seconds
            setTimeout(function() {
                clearInterval(checkJQuery);
            }, 5000);
        });
    }
})();
</script>
}

