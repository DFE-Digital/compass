@model IEnumerable<Compass.Models.AccessibilityRetestRequest>
@{
    ViewData["Title"] = "Retest Requests";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Settings", "Admin")">Settings</a></li>
                        <li class="breadcrumb-item"><a href="@Url.Action("Index")">Accessibility Issues Service</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Retest Requests</li>
                    </ol>
                </nav>
                <h1 class="m-0">Retest Requests</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <!-- Left Column: Navigation Pills -->
            <div class="col-lg-3 col-md-4 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Navigation</h3>
                    </div>
                    <div class="card-body p-0">
                        <ul class="nav nav-pills flex-column">
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index")">
                                    Products
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link active" href="@Url.Action("RetestRequests")">
                                    Retest Requests
                                    @if (ViewBag.PendingRetestCount != null && (int)ViewBag.PendingRetestCount > 0)
                                    {
                                        <span class="badge bg-danger float-right ml-2">@ViewBag.PendingRetestCount</span>
                                    }
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("EmailConfigurations")">
                                    Email Configuration
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Filters -->
                <div class="card mt-3">
                    <div class="card-header">
                        <h3 class="card-title">Filters</h3>
                    </div>
                    <div class="card-body p-0">
                        <ul class="nav nav-pills flex-column">
                            <li class="nav-item">
                                <a class="nav-link @(ViewBag.CurrentStatus == null ? "active" : "")" 
                                   href="@Url.Action("RetestRequests", new { status = (string?)null })">
                                    All
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewBag.CurrentStatus == "pending" ? "active" : "")" 
                                   href="@Url.Action("RetestRequests", new { status = "pending" })">
                                    Pending
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewBag.CurrentStatus == "completed" ? "active" : "")" 
                                   href="@Url.Action("RetestRequests", new { status = "completed" })">
                                    Completed
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(ViewBag.CurrentStatus == "cancelled" ? "active" : "")" 
                                   href="@Url.Action("RetestRequests", new { status = "cancelled" })">
                                    Cancelled
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

    <!-- Right Column: Content -->
    <div class="col-lg-9 col-md-8 col-12">

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Requests</h3>
            </div>
            <div class="card-body table-responsive p-0">
                @if (Model.Any())
                {
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Product</th>
                                    <th>Issue</th>
                                    <th>Requested By</th>
                                    <th>Requested At</th>
                                    <th>Status</th>
                                    <th>Outcome</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var request in Model)
                                {
                                    <tr>
                                        <td>
                                            <strong>@request.AccessibilityIssue.ProductAccessibility.ProductName</strong><br>
                                            <small class="text-muted">@request.AccessibilityIssue.ProductAccessibility.FipsId</small>
                                        </td>
                                        <td>
                                            @if (request.AccessibilityIssue.IssueType == "WCAG" && request.AccessibilityIssue.WcagCriteriaLinks != null && request.AccessibilityIssue.WcagCriteriaLinks.Any())
                                            {
                                                var firstLink = request.AccessibilityIssue.WcagCriteriaLinks.First();
                                                <strong>@firstLink.WcagCriterion.Criterion</strong>
                                                @if (request.AccessibilityIssue.WcagCriteriaLinks.Count > 1)
                                                {
                                                    <text> +@(request.AccessibilityIssue.WcagCriteriaLinks.Count - 1) more</text>
                                                }
                                            }
                                            else if (!string.IsNullOrEmpty(request.AccessibilityIssue.IssueTitle))
                                            {
                                                <strong>@request.AccessibilityIssue.IssueTitle</strong>
                                            }
                                            else if (!string.IsNullOrEmpty(request.AccessibilityIssue.WcagCriteria))
                                            {
                                                <strong>@request.AccessibilityIssue.WcagCriteria</strong>
                                            }
                                            else
                                            {
                                                <strong>@request.AccessibilityIssue.IssueType Issue</strong>
                                            }
                                            <br>
                                            <small class="text-muted">@request.AccessibilityIssue.IssueType</small>
                                        </td>
                                        <td>
                                            @request.RequestedBy
                                            @if (!string.IsNullOrEmpty(request.RequestorEmail))
                                            {
                                                <br><small class="text-muted">@request.RequestorEmail</small>
                                            }
                                        </td>
                                        <td>
                                            @request.RequestedAt.ToString("dd MMM yyyy HH:mm")
                                        </td>
                                        <td>
                                            @if (request.IsCompleted == null)
                                            {
                                                <span class="badge bg-warning">Pending</span>
                                            }
                                            else if (request.IsCompleted == true)
                                            {
                                                <span class="badge bg-success">Completed</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">Cancelled</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(request.Outcome))
                                            {
                                                <span class="badge bg-@(request.Outcome == "Resolved" ? "success" : "danger")">
                                                    @request.Outcome
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="@Url.Action("RetestRequestDetails", new { id = request.Id })" 
                                               class="btn btn-sm btn-outline-primary">
                                                View Details
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                }
                else
                {
                    <p class="text-muted text-center p-3 mb-0">No retest requests found.</p>
                }
            </div>
        </div>
    </div>
    </div>
</section>

