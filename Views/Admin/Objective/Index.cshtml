@model IEnumerable<Compass.Models.Objective>
@{
    ViewData["Title"] = "Strategic objectives";
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString() ?? "";
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString() ?? "";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item">Administration</li>
                    <li class="breadcrumb-item active">Strategic objectives</li>
                </ol>
                <h1 class="m-0">Strategic objectives</h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <div class="btn-group">
                        <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            Actions
                        </button>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" href="#" data-toggle="modal" data-target="#objectiveModal" onclick="openCreateObjectiveModal()">
                                Add new strategic objective
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-xxl-2 col-xl-2 col-lg-2 col-md-2 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Administration</h3>
                    </div>
                    <div class="card-body p-2">
                        <div class="nav flex-column nav-pills">
                            <a href="@Url.Action("Index", "PerformanceMetric")" class="nav-link @(currentController == "PerformanceMetric" ? "active" : "")">
                                Operational reports
                            </a>
                            <a href="@Url.Action("Index", "EnterpriseMetric")" class="nav-link @(currentController == "EnterpriseMetric" ? "active" : "")">
                                Enterprise metrics
                            </a>
                            <a href="@Url.Action("Index", "FunctionalStandard")" class="nav-link @(currentController == "FunctionalStandard" ? "active" : "")">
                                Functional standards
                            </a>
                            <a href="@Url.Action("Objectives", "Admin")" class="nav-link @(currentAction.StartsWith("Objective") ? "active" : "")">
                                Strategic objectives
                            </a>
                            <a href="@Url.Action("Missions", "Admin")" class="nav-link @(currentAction.StartsWith("Mission") ? "active" : "")">
                                Missions
                            </a>
                            <a href="@Url.Action("FundingSources", "Admin")" class="nav-link @(currentAction.Contains("FundingSource") ? "active" : "")">
                                Funding sources
                            </a>
                            <a href="@Url.Action("Index", "GovernmentDepartment")" class="nav-link @(currentController == "GovernmentDepartment" ? "active" : "")">
                                Government departments
                            </a>
                            <a href="@Url.Action("Index", "Organizational")" class="nav-link @(currentController == "Organizational" ? "active" : "")">
                                Organizational
                            </a>
                            <a href="@Url.Action("RiskTypes", "Admin")" class="nav-link @(currentAction.Contains("RiskType") ? "active" : "")">
                                Risk types
                            </a>
                            <a href="@Url.Action("RiskTiers", "Admin")" class="nav-link @(currentAction.Contains("RiskTier") ? "active" : "")">
                                Risk tiers
                            </a>
                            <a href="@Url.Action("ActionSources", "Admin")" class="nav-link @(currentAction.Contains("ActionSource") ? "active" : "")">
                                Action sources
                            </a>
                            <a href="@Url.Action("WcagCriteria", "Admin")" class="nav-link @(currentAction.Contains("WcagCriterion") || currentAction.Contains("WcagCriteria") ? "active" : "")">
                                WCAG Criteria
                            </a>
                            <a href="@Url.Action("GddRoles", "Admin")" class="nav-link @(currentAction.Contains("GddRole") ? "active" : "")">
                                GDD Roles
                            </a>
                            <a href="@Url.Action("Skills", "Admin")" class="nav-link @(currentAction.Contains("Skill") ? "active" : "")">
                                Skills
                            </a>
                            <a href="@Url.Action("ApiTokens", "Admin")" class="nav-link @(currentAction.Contains("ApiToken") ? "active" : "")">
                                API tokens
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xxl-10 col-xl-10 col-lg-10 col-md-10 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">All strategic objectives</h3>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover text-nowrap">
                            <thead>
                                <tr>
                                    <th style="width: 10%;">ID</th>
                                    <th style="width: 30%;">Title</th>
                                    <th style="width: 20%;">Theme</th>
                                    <th style="width: 20%;">Owner</th>
                                    <th style="width: 20%;">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var objective in Model)
                                    {
                                        <tr>
                                            <td>@objective.Id</td>
                                            <td>
                                                <a href="#" class="edit-objective font-weight-bold" 
                                                   data-id="@objective.Id" 
                                                   data-title="@objective.Title" 
                                                   data-theme="@(objective.Theme ?? "")" 
                                                   data-description="@(objective.Description ?? "")" 
                                                   data-owneruserid="@(objective.OwnerUserId?.ToString() ?? "")" 
                                                   data-status="@(objective.Status ?? "")">
                                                    @objective.Title
                                                </a>
                                            </td>
                                            <td>@(objective.Theme ?? "—")</td>
                                            <td>@(objective.OwnerUser?.Name ?? "—")</td>
                                            <td>
                                                @switch (objective.Status)
                                                {
                                                    case "active":
                                                        <span class="badge badge-success">Active</span>
                                                        break;
                                                    case "proposed":
                                                        <span class="badge badge-info">Proposed</span>
                                                        break;
                                                    case "paused":
                                                        <span class="badge badge-warning">Paused</span>
                                                        break;
                                                    case "completed":
                                                        <span class="badge badge-primary">Completed</span>
                                                        break;
                                                    case "cancelled":
                                                        <span class="badge badge-secondary">Cancelled</span>
                                                        break;
                                                    default:
                                                        <span class="badge badge-secondary">@objective.Status</span>
                                                        break;
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center">No strategic objectives found</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Create/Edit Modal -->
<div class="modal fade" id="objectiveModal" tabindex="-1" role="dialog" aria-labelledby="objectiveModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="objectiveModalLabel">Create strategic objective</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form id="objectiveForm" method="post" asp-controller="Admin">
                <input type="hidden" id="objectiveId" name="Id" />
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <div class="form-group">
                        <label for="objectiveTitle" class="control-label">Title</label>
                        <input type="text" id="objectiveTitle" name="Title" class="form-control" required />
                        <span class="text-danger field-validation-valid" data-valmsg-for="Title" data-valmsg-replace="true"></span>
                    </div>

                    <div class="form-group">
                        <label for="objectiveTheme" class="control-label">Theme</label>
                        <input type="text" id="objectiveTheme" name="Theme" class="form-control" />
                        <span class="text-danger field-validation-valid" data-valmsg-for="Theme" data-valmsg-replace="true"></span>
                    </div>

                    <div class="form-group">
                        <label for="objectiveDescription" class="control-label">Description</label>
                        <textarea id="objectiveDescription" name="Description" class="form-control" rows="4"></textarea>
                        <span class="text-danger field-validation-valid" data-valmsg-for="Description" data-valmsg-replace="true"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="objectiveOwnerUserId" class="control-label">Owner</label>
                                <select id="objectiveOwnerUserId" name="OwnerUserId" class="form-control" asp-items="ViewBag.Users">
                                    <option value="">-- Select owner --</option>
                                </select>
                                <span class="text-danger field-validation-valid" data-valmsg-for="OwnerUserId" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label for="objectiveStatus" class="control-label">Status</label>
                                <select id="objectiveStatus" name="Status" class="form-control">
                                    <option value="">-- Select status --</option>
                                    <option value="proposed">Proposed</option>
                                    <option value="active">Active</option>
                                    <option value="paused">Paused</option>
                                    <option value="completed">Completed</option>
                                    <option value="cancelled">Cancelled</option>
                                </select>
                                <span class="text-danger field-validation-valid" data-valmsg-for="Status" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script nonce="@Context.Items["Nonce"]">
        function openCreateObjectiveModal() {
            $('#objectiveModalLabel').text('Create strategic objective');
            $('#objectiveForm').attr('action', '@Url.Action("CreateObjective", "Admin")');
            $('#objectiveId').val('');
            $('#objectiveTitle').val('');
            $('#objectiveTheme').val('');
            $('#objectiveDescription').val('');
            $('#objectiveOwnerUserId').val('');
            $('#objectiveStatus').val('');
            $('#objectiveModal').modal('show');
        }

        function openEditObjectiveModal(id, title, theme, description, ownerUserId, status) {
            $('#objectiveModalLabel').text('Edit strategic objective');
            $('#objectiveForm').attr('action', '@Url.Action("EditObjective", "Admin")');
            $('#objectiveId').val(id);
            $('#objectiveTitle').val(title);
            $('#objectiveTheme').val(theme || '');
            $('#objectiveDescription').val(description || '');
            $('#objectiveOwnerUserId').val(ownerUserId || '');
            $('#objectiveStatus').val(status || '');
            $('#objectiveModal').modal('show');
        }

        $(document).on('click', '.edit-objective', function(e) {
            e.preventDefault();
            var $item = $(this);
            openEditObjectiveModal(
                $item.data('id'),
                $item.data('title'),
                $item.data('theme'),
                $item.data('description'),
                $item.data('owneruserid'),
                $item.data('status')
            );
        });

        $('#objectiveModal').on('hidden.bs.modal', function () {
            $('#objectiveForm')[0].reset();
            $('.field-validation-valid').text('');
        });
    </script>
}

