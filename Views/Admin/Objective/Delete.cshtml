@model Compass.Models.Objective
@{
    ViewData["Title"] = "Delete strategic objective";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item">Administration</li>
                    <li class="breadcrumb-item"><a asp-controller="Admin" asp-action="Objectives">Strategic objectives</a></li>
                    <li class="breadcrumb-item active">Delete</li>
                </ol>
                <h1 class="m-0">Delete strategic objective</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card card-danger">
            <div class="card-header">
                <h3 class="card-title">Confirm deletion</h3>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <h5><i class="icon fas fa-exclamation-triangle"></i> Warning</h5>
                    Are you sure you want to delete this strategic objective? This action cannot be undone.
                </div>

                <dl class="row">
                    <dt class="col-sm-3">Title</dt>
                    <dd class="col-sm-9">@Model.Title</dd>

                    <dt class="col-sm-3">Description</dt>
                    <dd class="col-sm-9">@(Model.Description ?? "-")</dd>

                    <dt class="col-sm-3">Owner</dt>
                    <dd class="col-sm-9">@(Model.OwnerUser?.Name ?? "-")</dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">@(Model.Status ?? "-")</dd>

                    <dt class="col-sm-3">Created</dt>
                    <dd class="col-sm-9">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>
                </dl>
            </div>
            <div class="card-footer">
                <form asp-controller="Admin" asp-action="DeleteObjective" method="post">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">
                        Yes, delete this strategic objective
                    </button>
                    <a asp-controller="Admin" asp-action="Objectives" class="btn btn-secondary">
                        Cancel
                    </a>
                </form>
            </div>
        </div>
    </div>
</section>

