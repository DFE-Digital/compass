@*
 * ROUTE: /Admin/Index
 * CONTROLLER: Compass.Controllers.AdminController
 * MODEL: N/A
 * 
 * DESCRIPTION:
 * Admin landing page providing access to all administrative functions.
 * 
 * AUTHOR: Andy Jones
 * CREATED: 2025-01-15
 * LAST MODIFIED: 2025-01-15
 *@

@{
    ViewData["Title"] = "Administration";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Administration</li>
                </ol>
                <h1 class="m-0">Administration</h1>
                <p class="text-muted mb-0">Manage users, settings, and system configuration</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <!-- Administration Section -->
      

        <div class="row">
            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-users text-primary mr-2"></i>
                            Users
                        </h5>
                        <p class="card-text text-muted">Manage user accounts and permissions</p>
                        <a href="@Url.Action("Users", "Admin")" class="btn btn-primary btn-sm">Manage users</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-chart-line text-primary mr-2"></i>
                            Operational metrics
                        </h5>
                        <p class="card-text text-muted">Manage operational metrics</p>
                        <a href="@Url.Action("Index", "PerformanceMetric")" class="btn btn-primary btn-sm">View metrics</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-chart-bar text-primary mr-2"></i>
                            Enterprise metrics
                        </h5>
                        <p class="card-text text-muted">Manage enterprise-level metrics</p>
                        <a href="@Url.Action("Index", "EnterpriseMetric")" class="btn btn-primary btn-sm">View metrics</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-book text-primary mr-2"></i>
                            Functional standards
                        </h5>
                        <p class="card-text text-muted">Manage functional standards and criteria</p>
                        <a href="@Url.Action("Index", "FunctionalStandard")" class="btn btn-primary btn-sm">Manage standards</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-bullseye text-primary mr-2"></i>
                            Strategic objectives
                        </h5>
                        <p class="card-text text-muted">Manage strategic objectives</p>
                        <a href="@Url.Action("Objectives", "Admin")" class="btn btn-primary btn-sm">Manage objectives</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-rocket text-primary mr-2"></i>
                            Missions
                        </h5>
                        <p class="card-text text-muted">Manage missions and objectives</p>
                        <a href="@Url.Action("Missions", "Admin")" class="btn btn-primary btn-sm">Manage missions</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-pound-sign text-primary mr-2"></i>
                            Funding sources
                        </h5>
                        <p class="card-text text-muted">Manage funding sources</p>
                        <a href="@Url.Action("FundingSources", "Admin")" class="btn btn-primary btn-sm">Manage funding</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-sliders-h text-primary mr-2"></i>
                            Settings
                        </h5>
                        <p class="card-text text-muted">Configure system settings and lookups</p>
                        <a href="@Url.Action("Settings", "Admin")" class="btn btn-primary btn-sm">Manage settings</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-building text-primary mr-2"></i>
                            Government departments
                        </h5>
                        <p class="card-text text-muted">Manage government department hierarchy</p>
                        <a href="@Url.Action("Index", "GovernmentDepartment")" class="btn btn-primary btn-sm">Manage departments</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- System Section -->
        <div class="row mt-5 mb-4">
            <div class="col-12">
                <h3 class="mb-3">System</h3>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-shield-alt text-success mr-2"></i>
                            User Management
                        </h5>
                        <p class="card-text text-muted">Advanced user management and permissions</p>
                        <a href="/Admin/UserManagement" class="btn btn-success btn-sm">Manage users</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-key text-success mr-2"></i>
                            API Manager
                        </h5>
                        <p class="card-text text-muted">Manage API tokens and permissions</p>
                        <a href="@Url.Action("ApiTokens", "Admin")" class="btn btn-success btn-sm">Manage API tokens</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-universal-access text-success mr-2"></i>
                            Accessibility Service
                        </h5>
                        <p class="card-text text-muted">Manage accessibility service configuration</p>
                        <a href="/Admin/AccessibilityService" class="btn btn-success btn-sm">Configure service</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-poll text-success mr-2"></i>
                            User Satisfaction
                        </h5>
                        <p class="card-text text-muted">Manage user satisfaction surveys and responses</p>
                        <a href="@Url.Action("UserSatisfaction", "Admin")" class="btn btn-success btn-sm">Manage surveys</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
