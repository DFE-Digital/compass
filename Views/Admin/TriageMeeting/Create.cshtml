@model Compass.Models.TriageMeeting

@{
    ViewData["Title"] = "Create triage meeting";
    string FormatDateTime(DateTime value) => value.ToLocalTime().ToString("yyyy-MM-ddTHH:mm");
}

@section Breadcrumbs {
    <style>
        .breadcrumb a:hover {
            color: #003078 !important;
            text-decoration: underline !important;
        }
    </style>
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4 breadcrumb-standard">
            <li class="breadcrumb-item">
                <a href="/" class="breadcrumb-link-standard">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Admin" asp-action="Index" class="breadcrumb-link-standard">Administration</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-controller="Admin" asp-action="TriageMeetings" class="breadcrumb-link-standard">Triage meetings</a>
            </li>
            <li class="breadcrumb-item active breadcrumb-active-standard" aria-current="page">Create</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Create triage meeting</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-lg-8 col-md-10 col-sm-12">
                <div class="card">
                    <div class="card-body">
                        <form asp-action="CreateTriageMeeting" method="post">
                            @Html.AntiForgeryToken()

                            <div class="form-group">
                                <label asp-for="Title" class="font-weight-semibold">Meeting name</label>
                                <input asp-for="Title" class="form-control" maxlength="150" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>

                            <div class="form-row">
                                <div class="form-group col-md-6">
                                    <label asp-for="StartAt" class="font-weight-semibold">Start</label>
                                    <input asp-for="StartAt" class="form-control" type="datetime-local" value="@FormatDateTime(Model.StartAt == default ? DateTime.UtcNow : Model.StartAt)" />
                                    <span asp-validation-for="StartAt" class="text-danger"></span>
                                </div>
                                <div class="form-group col-md-6">
                                    <label asp-for="EndAt" class="font-weight-semibold">End</label>
                                    <input asp-for="EndAt" class="form-control" type="datetime-local" value="@FormatDateTime(Model.EndAt == default ? DateTime.UtcNow.AddHours(1) : Model.EndAt)" />
                                    <span asp-validation-for="EndAt" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="form-group">
                                <label asp-for="Location" class="font-weight-semibold">Location</label>
                                <input asp-for="Location" class="form-control" maxlength="255" placeholder="Microsoft Teams / Sanctuary Buildings" />
                                <span asp-validation-for="Location" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Description" class="font-weight-semibold">Agenda or notes</label>
                                <textarea asp-for="Description" class="form-control" rows="3" maxlength="500"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>

                            <div class="form-group form-check">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                                <label asp-for="IsActive" class="form-check-label">Meeting is active</label>
                            </div>

                            <div class="d-flex justify-content-between">
                                <a asp-action="TriageMeetings" class="btn btn-secondary">Cancel</a>
                                <button type="submit" class="btn btn-success">Create meeting</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
