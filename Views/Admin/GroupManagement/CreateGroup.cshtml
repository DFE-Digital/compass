@model Compass.Models.Group
@{
    ViewData["Title"] = "Create Group";
    var features = ViewBag.Features as List<Compass.Models.Feature> ?? new List<Compass.Models.Feature>();
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a href="/Admin">Admin</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">User Management</a></li>
                    <li class="breadcrumb-item"><a asp-action="Groups">Groups</a></li>
                    <li class="breadcrumb-item active">Create Group</li>
                </ol>
                <h1 class="m-0">Create Group</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Group Details</h3>
            </div>
            <form asp-action="CreateGroup" method="post" id="createGroupForm">
                @Html.AntiForgeryToken()
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="form-group">
                        <label asp-for="Name"></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g., Delivery reporting viewer" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Description"></label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Optional description for this group"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" checked />
                            <label asp-for="IsActive" class="form-check-label">Active</label>
                        </div>
                    </div>

                    <hr />

                    <h4>Feature Permissions</h4>
                    <p class="text-muted">Select permissions for each feature by checking the boxes below.</p>
                    
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover">
                            <thead class="thead-light">
                                <tr>
                                    <th>Feature</th>
                                    <th class="text-center">
                                        <span data-toggle="tooltip" title="View">
                                            <i class="fas fa-eye"></i> View
                                        </span>
                                    </th>
                                    <th class="text-center">
                                        <span data-toggle="tooltip" title="Create">
                                            <i class="fas fa-plus"></i> Create
                                        </span>
                                    </th>
                                    <th class="text-center">
                                        <span data-toggle="tooltip" title="Update">
                                            <i class="fas fa-edit"></i> Update
                                        </span>
                                    </th>
                                    <th class="text-center">
                                        <span data-toggle="tooltip" title="Delete">
                                            <i class="fas fa-trash"></i> Delete
                                        </span>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var feature in features.OrderBy(f => f.Name))
                                {
                                    <tr>
                                        <td>
                                            <strong>@feature.Name</strong>
                                            @if (!string.IsNullOrEmpty(feature.Description))
                                            {
                                                <br />
                                                <small class="text-muted">@feature.Description</small>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <div class="form-check d-flex justify-content-center">
                                                <input type="checkbox" 
                                                       class="form-check-input permission-checkbox" 
                                                       value="@feature.Id:@((int)Compass.Models.PermissionType.View)"
                                                       data-feature-id="@feature.Id"
                                                       data-permission="@((int)Compass.Models.PermissionType.View)" />
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <div class="form-check d-flex justify-content-center">
                                                <input type="checkbox" 
                                                       class="form-check-input permission-checkbox" 
                                                       value="@feature.Id:@((int)Compass.Models.PermissionType.Create)"
                                                       data-feature-id="@feature.Id"
                                                       data-permission="@((int)Compass.Models.PermissionType.Create)" />
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <div class="form-check d-flex justify-content-center">
                                                <input type="checkbox" 
                                                       class="form-check-input permission-checkbox" 
                                                       value="@feature.Id:@((int)Compass.Models.PermissionType.Update)"
                                                       data-feature-id="@feature.Id"
                                                       data-permission="@((int)Compass.Models.PermissionType.Update)" />
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <div class="form-check d-flex justify-content-center">
                                                <input type="checkbox" 
                                                       class="form-check-input permission-checkbox" 
                                                       value="@feature.Id:@((int)Compass.Models.PermissionType.Delete)"
                                                       data-feature-id="@feature.Id"
                                                       data-permission="@((int)Compass.Models.PermissionType.Delete)" />
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    
                    @if (!features.Any())
                    {
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i> No features available. Please create features first.
                            <a asp-action="CreateFeature" class="alert-link">Create a feature</a>
                        </div>
                    }
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Create Group
                    </button>
                    <a asp-action="Groups" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Initialize tooltips
            $('[data-toggle="tooltip"]').tooltip();
            
            // Handle form submission - collect checked permissions
            $('#createGroupForm').on('submit', function(e) {
                // Remove any existing hidden inputs
                $('input[name="featureIds"]').remove();
                $('input[type="hidden"][name="permissions"]').remove();
                
                // Extract feature IDs and permissions from checked boxes
                var featureIds = [];
                var permissions = [];
                
                $('.permission-checkbox:checked').each(function() {
                    var value = $(this).attr('value').split(':');
                    featureIds.push(parseInt(value[0]));
                    permissions.push(parseInt(value[1]));
                });
                
                // Create hidden inputs with proper names for array binding
                featureIds.forEach(function(id) {
                    $('<input>').attr({
                        type: 'hidden',
                        name: 'featureIds',
                        value: id
                    }).appendTo('#createGroupForm');
                });
                
                permissions.forEach(function(perm) {
                    $('<input>').attr({
                        type: 'hidden',
                        name: 'permissions',
                        value: perm
                    }).appendTo('#createGroupForm');
                });
            });
        });
    </script>
}
