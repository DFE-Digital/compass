@using Compass.Models
@{
    ViewData["Title"] = "User Management";
    var users = ViewBag.Users as List<User> ?? new List<User>();
    var groups = ViewBag.Groups as List<Group> ?? new List<Group>();
    var totalUsers = users.Count;
    var totalGroups = groups.Count;
    var activeUsers = users.Count(u => u.Role != UserRole.Visitor);
    var activeGroups = groups.Count(g => g.IsActive);
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a href="/Admin">Admin</a></li>
                    <li class="breadcrumb-item active">User Management</li>
                </ol>
                <h1 class="m-0">User Management</h1>
                <p class="text-muted mb-0">Manage users, groups, and permissions</p>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <a href="/Admin/User/CreateUser" class="btn btn-primary">
                        <i class="fas fa-user-plus"></i> Add user
                    </a>
                    <a asp-action="CreateGroup" class="btn btn-primary">
                        <i class="fas fa-users"></i> Create group
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <!-- Administration Section -->
        <div class="row mb-3">
            <div class="col-12">
                <h3 class="mb-3">User Management</h3>
            </div>
        </div>

        <!-- Summary Cards -->
        <div class="row mb-4">
            <div class="col-lg-3 col-md-6">
                <div class="card card-primary card-outline">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-0">Total Users</h5>
                                <h2 class="mb-0">@totalUsers</h2>
                            </div>
                            <div class="text-primary" style="font-size: 3rem; opacity: 0.3;">
                                <i class="fas fa-users"></i>
                            </div>
                        </div>
                        <small class="text-muted">@activeUsers active</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card card-success card-outline">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-0">Total Groups</h5>
                                <h2 class="mb-0">@totalGroups</h2>
                            </div>
                            <div class="text-success" style="font-size: 3rem; opacity: 0.3;">
                                <i class="fas fa-users-cog"></i>
                            </div>
                        </div>
                        <small class="text-muted">@activeGroups active</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card card-info card-outline">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-0">Admin Users</h5>
                                <h2 class="mb-0">@users.Count(u => u.Role == UserRole.Admin || u.Role == UserRole.SuperAdmin)</h2>
                            </div>
                            <div class="text-info" style="font-size: 3rem; opacity: 0.3;">
                                <i class="fas fa-user-shield"></i>
                            </div>
                        </div>
                        <small class="text-muted">Administrators</small>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6">
                <div class="card card-warning card-outline">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-0">System Groups</h5>
                                <h2 class="mb-0">@groups.Count(g => g.IsSystemGroup)</h2>
                            </div>
                            <div class="text-warning" style="font-size: 3rem; opacity: 0.3;">
                                <i class="fas fa-lock"></i>
                            </div>
                        </div>
                        <small class="text-muted">Protected groups</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabbed Interface -->
        <div class="card card-primary card-outline card-tabs">
            <div class="card-header p-0 pt-1 border-bottom-0">
                <ul class="nav nav-tabs" id="userManagementTabs" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" id="users-tab" data-toggle="tab" href="#users" role="tab" aria-controls="users" aria-selected="true">
                            <i class="fas fa-users mr-2"></i>Users
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" id="groups-tab" data-toggle="tab" href="#groups" role="tab" aria-controls="groups" aria-selected="false">
                            <i class="fas fa-users-cog mr-2"></i>Groups
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" id="permissions-tab" data-toggle="tab" href="#permissions" role="tab" aria-controls="permissions" aria-selected="false">
                            <i class="fas fa-shield-alt mr-2"></i>Permissions
                        </a>
                    </li>
                </ul>
            </div>
            <div class="card-body">
                <div class="tab-content" id="userManagementTabContent">
                    <!-- Users Tab -->
                    <div class="tab-pane fade show active" id="users" role="tabpanel" aria-labelledby="users-tab">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="input-group">
                                    <input type="text" class="form-control" id="userSearch" placeholder="Search users by name or email...">
                                    <div class="input-group-append">
                                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6 text-right">
                                <a href="/Admin/User/CreateUser" class="btn btn-primary">
                                    <i class="fas fa-user-plus"></i> Add user
                                </a>
                            </div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover" id="usersTable">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Role</th>
                                        <th>Groups</th>
                                        <th>Status</th>
                                        <th class="text-right">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (users.Any())
                                    {
                                        @foreach (var user in users.OrderBy(u => u.Name))
                                        {
                                            var userGroups = user.UserGroups?.Where(ug => ug.Group.IsActive).Select(ug => ug.Group).ToList() ?? new List<Group>();
                                            <tr>
                                                <td>
                                                    <strong>@user.Name</strong>
                                                    @if (user.Role == UserRole.SuperAdmin)
                                                    {
                                                        <span class="badge badge-danger ml-2">Super Admin</span>
                                                    }
                                                </td>
                                                <td>@user.Email</td>
                                                <td>
                                                    @switch (user.Role)
                                                    {
                                                        case UserRole.SuperAdmin:
                                                            <span class="badge badge-danger">Super admin</span>
                                                            break;
                                                        case UserRole.Admin:
                                                            <span class="badge badge-warning">Admin</span>
                                                            break;
                                                        case UserRole.Reporter:
                                                            <span class="badge badge-info">Reporter</span>
                                                            break;
                                                        default:
                                                            <span class="badge badge-secondary">Visitor</span>
                                                            break;
                                                    }
                                                </td>
                                                <td>
                                                    @if (userGroups.Any())
                                                    {
                                                        @foreach (var group in userGroups.Take(3))
                                                        {
                                                            <span class="badge badge-primary mr-1">@group.Name</span>
                                                        }
                                                        @if (userGroups.Count > 3)
                                                        {
                                                            <span class="badge badge-secondary">+@(userGroups.Count - 3)</span>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted">No groups</span>
                                                    }
                                                </td>
                                                <td>
                                                    <span class="badge badge-success">Active</span>
                                                </td>
                                                <td class="text-right">
                                                    <a href="/Admin/User/EditUser/@user.Id" class="btn btn-sm btn-primary" title="Edit user">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a asp-action="UserPermissions" class="btn btn-sm btn-info" title="View permissions">
                                                        <i class="fas fa-shield-alt"></i>
                                                    </a>
                                                    @if (user.Role != UserRole.SuperAdmin)
                                                    {
                                                        <a href="/Admin/User/DeleteUser/@user.Id" class="btn btn-sm btn-danger" title="Delete user">
                                                            <i class="fas fa-trash"></i>
                                                        </a>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted py-4">
                                                <i class="fas fa-users fa-2x mb-2 d-block"></i>
                                                No users found. <a href="/Admin/User/CreateUser">Add a user</a> to get started.
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Groups Tab -->
                    <div class="tab-pane fade" id="groups" role="tabpanel" aria-labelledby="groups-tab">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="input-group">
                                    <input type="text" class="form-control" id="groupSearch" placeholder="Search groups by name...">
                                    <div class="input-group-append">
                                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6 text-right">
                                <a asp-action="CreateGroup" class="btn btn-primary">
                                    <i class="fas fa-plus"></i> Create group
                                </a>
                            </div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover" id="groupsTable">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th>Description</th>
                                        <th>Members</th>
                                        <th>Permissions</th>
                                        <th>Status</th>
                                        <th class="text-right">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (groups.Any())
                                    {
                                        @foreach (var group in groups.OrderBy(g => g.Name))
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@group.Name</strong>
                                                    @if (group.IsSystemGroup)
                                                    {
                                                        <span class="badge badge-info ml-2">System</span>
                                                    }
                                                </td>
                                                <td>@(group.Description ?? "-")</td>
                                                <td>
                                                    <span class="badge badge-secondary">@(group.UserGroups?.Count() ?? 0)</span>
                                                </td>
                                                <td>
                                                    <span class="badge badge-primary">@(group.GroupFeaturePermissions?.Count() ?? 0)</span>
                                                </td>
                                                <td>
                                                    @if (group.IsActive)
                                                    {
                                                        <span class="badge badge-success">Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge badge-danger">Inactive</span>
                                                    }
                                                </td>
                                                <td class="text-right">
                                                    <a asp-action="EditGroup" asp-route-id="@group.Id" class="btn btn-sm btn-primary" title="Edit group">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a asp-action="ManageUsers" asp-route-id="@group.Id" class="btn btn-sm btn-info" title="Manage members">
                                                        <i class="fas fa-users"></i>
                                                    </a>
                                                    @if (!group.IsSystemGroup)
                                                    {
                                                        <a asp-action="DeleteGroup" asp-route-id="@group.Id" class="btn btn-sm btn-danger" title="Delete group">
                                                            <i class="fas fa-trash"></i>
                                                        </a>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted py-4">
                                                <i class="fas fa-users-cog fa-2x mb-2 d-block"></i>
                                                No groups found. <a asp-action="CreateGroup">Create a group</a> to get started.
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Permissions Tab -->
                    <div class="tab-pane fade" id="permissions" role="tabpanel" aria-labelledby="permissions-tab">
                        <div class="row mb-3">
                            <div class="col-md-12">
                                <p class="text-muted">View and manage user permissions across all groups. Click on a user to see detailed permissions.</p>
                            </div>
                        </div>
                        <div class="text-center">
                            <a asp-action="UserPermissions" class="btn btn-primary btn-lg">
                                <i class="fas fa-shield-alt mr-2"></i>View detailed permissions
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // User search
            $('#userSearch').on('keyup', function() {
                var value = $(this).val().toLowerCase();
                $('#usersTable tbody tr').filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });

            // Group search
            $('#groupSearch').on('keyup', function() {
                var value = $(this).val().toLowerCase();
                $('#groupsTable tbody tr').filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });
        });
    </script>
}
