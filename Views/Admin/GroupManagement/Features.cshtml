@model IEnumerable<Compass.Models.Feature>
@{
    ViewData["Title"] = "Features";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a href="/Admin">Admin</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">User Management</a></li>
                    <li class="breadcrumb-item active">Features</li>
                </ol>
                <h1 class="m-0">Features</h1>
            </div>
            <div class="col-sm-6">
                <a asp-action="CreateFeature" class="btn btn-primary float-right">
                    <i class="fas fa-plus"></i> Create Feature
                </a>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">All Features</h3>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover text-nowrap">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Code</th>
                            <th>Description</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var feature in Model)
                            {
                                <tr>
                                    <td>@feature.Name</td>
                                    <td><code>@feature.Code</code></td>
                                    <td>@(feature.Description ?? "-")</td>
                                    <td>
                                        @if (feature.IsActive)
                                        {
                                            <span class="badge badge-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger">Inactive</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center">No features found</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

