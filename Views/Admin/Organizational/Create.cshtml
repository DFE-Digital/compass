@model Compass.Models.OrganizationalGroup
@{
    ViewData["Title"] = "Create Organizational Group";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Settings", "Admin")">Settings</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index")">Organizational Structure</a></li>
            <li class="breadcrumb-item active" aria-current="page">Create Group</li>
        </ol>
    </nav>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Create Organizational Group</h3>
            </div>
            <form asp-action="Create" asp-controller="Organizational" method="post">
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    
                    <div class="form-group">
                        <label asp-for="Name" class="control-label">Group Name *</label>
                        <input asp-for="Name" class="form-control" placeholder="e.g., Schools, Standards Testing and Regulation" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Description" class="control-label">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Optional description of this organizational group"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="ParentGroupId" class="control-label">Parent Group</label>
                                <select asp-for="ParentGroupId" class="form-control">
                                    <option value="">-- No parent (root level) --</option>
                                    @foreach (var parent in ViewBag.ParentGroups)
                                    {
                                        <option value="@parent.Id">@parent.FullPath</option>
                                    }
                                </select>
                                <span asp-validation-for="ParentGroupId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="SortOrder" class="control-label">Sort Order</label>
                                <input asp-for="SortOrder" type="number" class="form-control" value="0" />
                                <small class="form-text text-muted">Lower numbers appear first</small>
                                <span asp-validation-for="SortOrder" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" checked />
                            <label asp-for="IsActive" class="form-check-label">
                                Active
                            </label>
                        </div>
                        <span asp-validation-for="IsActive" class="text-danger"></span>
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-primary">
                        Create Group
                    </button>
                    <a href="@Url.Action("Index", "Organizational")" class="btn btn-secondary">
                        Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Guidance</h3>
            </div>
            <div class="card-body">
                <h6>Organizational Structure</h6>
                <p class="small">Create a hierarchical structure for your organization:</p>
                <ul class="small">
                    <li><strong>Root Groups:</strong> Top-level departments (e.g., Schools)</li>
                    <li><strong>Sub Groups:</strong> Divisions within departments (e.g., Standards, Testing and Regulation)</li>
                    <li><strong>Teams:</strong> Specific teams or units (e.g., Assessment Operations)</li>
                </ul>

                <h6 class="mt-3">Role Types</h6>
                <p class="small">After creating groups, you can add roles:</p>
                <ul class="small">
                    <li><strong>Director General:</strong> Senior leadership</li>
                    <li><strong>Director:</strong> Department/division heads</li>
                    <li><strong>Deputy Director:</strong> Team leaders</li>
                </ul>

                <div class="alert alert-info mt-3">
                    <small><strong>Tip:</strong> Start with root groups and build the hierarchy progressively.</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
