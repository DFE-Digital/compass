@model Compass.Models.OrganizationalGroup
@{
    ViewData["Title"] = "Organizational Group Details";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Settings", "Admin")">Settings</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Organizational")">Organizational Structure</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Group Details</h3>
                <div class="card-tools">
                    <a href="@Url.Action("Edit", "Organizational", new { id = Model.Id })" class="btn btn-primary btn-sm">Edit Group</a>
                </div>
            </div>
            <div class="card-body p-0">
                <table class="table table-borderless mb-0">
                    <tbody>
                        <tr>
                            <td class="summary-label"><strong>Name</strong></td>
                            <td class="summary-value">@Model.Name</td>
                        </tr>
                        @if (!string.IsNullOrEmpty(Model.Description))
                        {
                            <tr>
                                <td class="summary-label"><strong>Description</strong></td>
                                <td class="summary-value">@Model.Description</td>
                            </tr>
                        }
                        <tr>
                            <td class="summary-label"><strong>Full Path</strong></td>
                            <td class="summary-value">@Model.FullPath</td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Level</strong></td>
                            <td class="summary-value"><span class="badge badge-secondary">Level @Model.Level</span></td>
                        </tr>
                        @if (Model.ParentGroup != null)
                        {
                            <tr>
                                <td class="summary-label"><strong>Parent Group</strong></td>
                                <td class="summary-value">
                                    <a href="@Url.Action("Details", "Organizational", new { id = Model.ParentGroup.Id })">@Model.ParentGroup.Name</a>
                                </td>
                            </tr>
                        }
                        <tr>
                            <td class="summary-label"><strong>Child Groups</strong></td>
                            <td class="summary-value">@Model.ChildGroups.Count</td>
                        </tr>
                        <tr>
                            <td class="summary-label"><strong>Roles</strong></td>
                            <td class="summary-value">@Model.Roles.Count</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.Roles.Any())
        {
            <div class="card mt-4">
                <div class="card-header">
                    <h3 class="card-title">Roles</h3>
                    <div class="card-tools">
                        <a href="@Url.Action("CreateRole", "Organizational", new { groupId = Model.Id })" class="btn btn-success btn-sm">Add Role</a>
                    </div>
                </div>
                <div class="card-body table-responsive p-0">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Role Type</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var role in Model.Roles.OrderBy(r => r.RoleType))
                            {
                                <tr>
                                    <td><span class="badge badge-info">@role.RoleType</span></td>
                                    <td>@role.Name</td>
                                    <td>@role.Email</td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <a href="@Url.Action("EditRole", "Organizational", new { id = role.Id })" class="btn btn-outline-primary btn-sm">Edit</a>
                                            <form asp-action="DeleteRole" asp-controller="Organizational" method="post" style="display: inline;">
                                                <input type="hidden" name="id" value="@role.Id" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Are you sure you want to delete this role?')">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="card mt-4">
                <div class="card-body text-center">
                    <p class="text-muted">No roles defined for this group.</p>
                    <a href="@Url.Action("CreateRole", "Organizational", new { groupId = Model.Id })" class="btn btn-success">Add First Role</a>
                </div>
            </div>
        }

        @if (Model.ChildGroups.Any())
        {
            <div class="card mt-4">
                <div class="card-header">
                    <h3 class="card-title">Child Groups</h3>
                </div>
                <div class="card-body table-responsive p-0">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Roles</th>
                                <th>Children</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var child in Model.ChildGroups.OrderBy(c => c.SortOrder).ThenBy(c => c.Name))
                            {
                                <tr>
                                    <td>
                                        <strong>@child.Name</strong>
                                        @if (!string.IsNullOrEmpty(child.Description))
                                        {
                                            <br><small class="text-muted">@child.Description</small>
                                        }
                                    </td>
                                    <td>@child.Roles.Count</td>
                                    <td>@child.ChildGroups.Count</td>
                                    <td>
                                        <a href="@Url.Action("Details", "Organizational", new { id = child.Id })" class="btn btn-outline-info btn-sm">View</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Actions</h3>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="@Url.Action("Edit", "Organizational", new { id = Model.Id })" class="btn btn-primary btn-block">Edit Group</a>
                    <a href="@Url.Action("CreateRole", "Organizational", new { groupId = Model.Id })" class="btn btn-success btn-block">Add Role</a>
                    <a href="@Url.Action("Create", "Organizational", new { parentId = Model.Id })" class="btn btn-info btn-block">Add Child Group</a>
                    <a href="@Url.Action("Index", "Organizational")" class="btn btn-secondary btn-block">Back to List</a>
                    <a href="@Url.Action("Delete", "Organizational", new { id = Model.Id })" class="btn btn-danger btn-block">Delete Group</a>
                </div>
            </div>
        </div>
    </div>
</div>
