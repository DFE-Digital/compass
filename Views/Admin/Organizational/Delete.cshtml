@model Compass.Models.OrganizationalGroup
@{
    ViewData["Title"] = "Delete Organizational Group";
}

@section Breadcrumbs {
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Settings", "Admin")">Settings</a></li>
            <li class="breadcrumb-item"><a href="@Url.Action("Index")">Organizational Structure</a></li>
            <li class="breadcrumb-item active" aria-current="page">Delete @Model.Name</li>
        </ol>
    </nav>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Delete Organizational Group</h3>
            </div>
            <div class="card-body">
                <div class="alert alert-warning">
                    <h5>Warning</h5>
                    Are you sure you want to delete this organizational group? This will also delete all child groups and roles.
                </div>
                
                <dl class="row">
                    <dt class="col-sm-3">Name</dt>
                    <dd class="col-sm-9"><strong>@Model.Name</strong></dd>

                    <dt class="col-sm-3">Full Path</dt>
                    <dd class="col-sm-9">@Model.FullPath</dd>

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <dt class="col-sm-3">Description</dt>
                        <dd class="col-sm-9">@Model.Description</dd>
                    }

                    <dt class="col-sm-3">Child Groups</dt>
                    <dd class="col-sm-9">@Model.ChildGroups.Count</dd>

                    <dt class="col-sm-3">Roles</dt>
                    <dd class="col-sm-9">@Model.Roles.Count</dd>
                </dl>

                @if (Model.ChildGroups.Any() || Model.Roles.Any())
                {
                    <div class="alert alert-danger">
                        <strong>This will delete:</strong>
                        <ul class="mb-0">
                            @if (Model.ChildGroups.Any())
                            {
                                <li>@Model.ChildGroups.Count child group(s)</li>
                            }
                            @if (Model.Roles.Any())
                            {
                                <li>@Model.Roles.Count role(s)</li>
                            }
                        </ul>
                    </div>
                }
            </div>

            <div class="card-footer">
                <form asp-action="Delete" asp-controller="Organizational" method="post">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">
                        Delete Group
                    </button>
                    <a href="@Url.Action("Details", "Organizational", new { id = Model.Id })" class="btn btn-secondary">
                        Cancel
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>
