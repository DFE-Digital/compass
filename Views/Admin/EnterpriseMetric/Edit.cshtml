@model Compass.Models.EnterpriseMetric
@{
    ViewData["Title"] = "Edit enterprise metric";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Edit enterprise metric</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-xxl-8 col-xl-8 col-lg-8 col-md-8 col-sm-12 col-12">
                <div class="card card-primary">
                    <div class="card-header">
                        <h3 class="card-title">Metric details</h3>
                    </div>
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CreatedAt" />
                        
                        <div class="card-body">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                            
                            <div class="form-group">
                                <label asp-for="Identifier">Identifier</label>
                                <input asp-for="Identifier" class="form-control" />
                                <span asp-validation-for="Identifier" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Title">Title</label>
                                <input asp-for="Title" class="form-control" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="Description">Description</label>
                                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="HintText">Hint text</label>
                                <input asp-for="HintText" class="form-control" placeholder="e.g. Enter the total across all departments" />
                                <small class="form-text text-muted">Optional hint text to guide users when entering data</small>
                                <span asp-validation-for="HintText" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <label asp-for="ValueType">Value type</label>
                                <select asp-for="ValueType" class="form-control custom-select">
                                    <option value="@((int)Compass.Models.ValueType.Text)">Text</option>
                                    <option value="@((int)Compass.Models.ValueType.Number)">Number</option>
                                    <option value="@((int)Compass.Models.ValueType.Decimal)">Decimal</option>
                                </select>
                            </div>

                            <div class="row">
                                <div class="col-xxl-6 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12">
                                    <div class="form-group">
                                        <label asp-for="ValidFromMonth">Valid for reporting from (Month)</label>
                                        <select asp-for="ValidFromMonth" class="form-control custom-select">
                                            <option value="1">January</option>
                                            <option value="2">February</option>
                                            <option value="3">March</option>
                                            <option value="4">April</option>
                                            <option value="5">May</option>
                                            <option value="6">June</option>
                                            <option value="7">July</option>
                                            <option value="8">August</option>
                                            <option value="9">September</option>
                                            <option value="10">October</option>
                                            <option value="11">November</option>
                                            <option value="12">December</option>
                                        </select>
                                        <span asp-validation-for="ValidFromMonth" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-xxl-6 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12">
                                    <div class="form-group">
                                        <label asp-for="ValidFromYear">Valid for reporting from (Year)</label>
                                        <input asp-for="ValidFromYear" type="number" class="form-control" min="2025" max="2099" />
                                        <span asp-validation-for="ValidFromYear" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle"></i> This metric will only appear in returns from the specified month onwards
                            </div>

                            <div class="form-group">
                                <label>Validation rules</label>
                                <textarea name="validationRulesJson" class="form-control" rows="6">@Model.ValidationRules</textarea>
                                <small class="form-text text-muted">JSON format for validation rules</small>
                            </div>
                        </div>

                        <div class="card-footer">
                            <button type="submit" class="btn btn-primary">
                                Save changes
                            </button>
                            <a asp-action="Index" class="btn btn-default">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

