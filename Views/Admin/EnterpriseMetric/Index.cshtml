@model IEnumerable<Compass.Models.EnterpriseMetric>
@{
    ViewData["Title"] = "Enterprise metrics";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item active">Enterprise metrics</li>
                </ol>
                <h1 class="m-0">Enterprise metrics</h1>
            </div>
            <div class="col-sm-6">
                <div class="float-right">
                    <div class="btn-group">
                        <button type="button" class="btn btn-primary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                            Actions
                        </button>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" asp-action="Create">
                                Add new metric
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Enterprise metrics</h3>
            </div>
            <div class="card-body table-responsive p-0">
                <table class="table table-hover text-nowrap">
                    <thead>
                        <tr>
                            <th>Identifier</th>
                            <th>Title</th>
                            <th>Value type</th>
                            <th>Valid from</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var metric in Model)
                            {
                                <tr>
                                    <td>@metric.Identifier</td>
                                    <td>
                                        <a asp-action="Edit" asp-route-id="@metric.Id">@metric.Title</a>
                                    </td>
                                    <td>
                                        @switch (metric.ValueType)
                                        {
                                            case Compass.Models.ValueType.Text:
                                                <span class="badge badge-info">Text</span>
                                                break;
                                            case Compass.Models.ValueType.Number:
                                                <span class="badge badge-success">Number</span>
                                                break;
                                            case Compass.Models.ValueType.Decimal:
                                                <span class="badge badge-warning">Decimal</span>
                                                break;
                                        }
                                    </td>
                                    <td>@(new DateTime(metric.ValidFromYear, metric.ValidFromMonth, 1).ToString("MMMM yyyy"))</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-3">No enterprise metrics found</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

