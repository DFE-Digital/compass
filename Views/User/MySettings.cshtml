@{
    ViewData["Title"] = "My settings";
    var user = ViewBag.User as Compass.Models.User;
    var selectedBusinessAreas = ViewBag.SelectedBusinessAreas as List<string> ?? new List<string>();
    var businessAreas = ViewBag.BusinessAreas as List<string> ?? new List<string>();
    var currentSection = ViewBag.CurrentSection as string ?? "profile";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">My settings</li>
                    </ol>
                </nav>
            </div>
        </div>
        <div class="row mb-2">
            <div class="col-sm-12">
                <h1 class="m-0">My Settings</h1>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <div class="row">
            <!-- Left Column: Navigation -->
            <div class="col-xxl-2 col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">Settings</h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <a href="@Url.Action("MySettings", new { section = "profile" })" 
                               class="list-group-item list-group-item-action @(currentSection == "profile" ? "active" : "")">
                                Profile
                            </a>
                            <a href="@Url.Action("MySettings", new { section = "preferences" })" 
                               class="list-group-item list-group-item-action @(currentSection == "preferences" ? "active" : "")">
                                Preferences
                            </a>
                            <a href="#" 
                               class="list-group-item list-group-item-action disabled" 
                               aria-disabled="true">
                                Notifications <span class="badge badge-secondary ml-1">Coming soon</span>
                            </a>
                            <a href="#" 
                               class="list-group-item list-group-item-action disabled" 
                               aria-disabled="true">
                                Display <span class="badge badge-secondary ml-1">Coming soon</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Content -->
            <div class="col-xxl-10 col-xl-10 col-lg-9 col-md-8 col-sm-12 col-12">
                @switch (currentSection)
                {
                    case "profile":
                        <!-- Profile Section -->
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Account Information</h3>
                            </div>
                            <div class="card-body">
                                <p class="text-muted">Your profile information is managed through your organisation's authentication system.</p>
                                
                                <dl class="row mt-4">
                                    <dt class="col-sm-3">Name</dt>
                                    <dd class="col-sm-9">@user?.Name</dd>

                                    <dt class="col-sm-3">Email</dt>
                                    <dd class="col-sm-9">@user?.Email</dd>

                                    <dt class="col-sm-3">User ID</dt>
                                    <dd class="col-sm-9"><code>@user?.Id</code></dd>
                                </dl>

                                <div class="alert alert-info mt-4" role="alert">
                                    <strong>Note:</strong> To update your name or email address, please contact your system administrator.
                                </div>
                            </div>
                        </div>
                        break;

                    case "preferences":
                        <!-- Preferences Section -->
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Business Area Preferences</h3>
                            </div>
                            <div class="card-body">
                                <form asp-action="MySettings" method="post">
                                    <input type="hidden" name="section" value="preferences" />
                                    
                                    <p class="text-muted">
                                        Select your primary business areas. When viewing risks, issues, actions, and milestones, 
                                        you'll see items from these areas by default. This helps you focus on what's most relevant to your work.
                                    </p>

                                    <div class="form-group mt-4">
                                        @if (businessAreas.Any())
                                        {
                                            <div class="row">
                                                @foreach (var area in businessAreas)
                                                {
                                                    var isChecked = selectedBusinessAreas.Contains(area);
                                                    <div class="col-xxl-6 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12">
                                                        <div class="custom-control custom-checkbox mb-2">
                                                            <input type="checkbox" 
                                                                   class="custom-control-input" 
                                                                   id="area_@area.Replace(" ", "_")" 
                                                                   name="selectedBusinessAreas" 
                                                                   value="@area" 
                                                                   @(isChecked ? "checked" : "") />
                                                            <label class="custom-control-label" for="area_@area.Replace(" ", "_")">
                                                                @area
                                                            </label>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="alert alert-warning" role="alert">
                                                <strong>Warning:</strong> No business areas available. Please contact your administrator.
                                            </div>
                                        }
                                    </div>

                                    @if (!selectedBusinessAreas.Any())
                                    {
                                        <div class="alert alert-info" role="alert">
                                            <strong>No preferences set:</strong> You'll see all items across all business areas in list views.
                                        </div>
                                    }

                                    <div class="card bg-light mt-4">
                                        <div class="card-body">
                                            <h6 class="card-title">How preferences work</h6>
                                            <ul class="mb-0 pl-3">
                                                <li><strong>Default filtering:</strong> List views will show items from your selected business areas by default</li>
                                                <li><strong>Override filters:</strong> You can still filter by other business areas or view all items</li>
                                                <li><strong>"Assigned to me":</strong> Items assigned to you always appear regardless of business area</li>
                                                <li><strong>No preferences:</strong> If you don't select any areas, you'll see everything</li>
                                            </ul>
                                        </div>
                                    </div>

                                    <div class="form-group mt-4">
                                        <button type="submit" class="btn btn-primary">
                                            Save Preferences
                                        </button>
                                        <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">
                                            Cancel
                                        </a>
                                    </div>
                                </form>
                            </div>
                        </div>
                        break;

                    case "notifications":
                        <!-- Notifications Section (Placeholder) -->
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Notification Preferences</h3>
                            </div>
                            <div class="card-body">
                                <p class="text-muted">Notification settings will be available in a future update.</p>
                                
                                <div class="alert alert-secondary" role="alert">
                                    <strong>Coming soon:</strong> Email and in-app notification preferences for risks, issues, actions, and milestones.
                                </div>
                            </div>
                        </div>
                        break;

                    case "display":
                        <!-- Display Section (Placeholder) -->
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Display Settings</h3>
                            </div>
                            <div class="card-body">
                                <p class="text-muted">Display and interface customisation options will be available in a future update.</p>
                                
                                <div class="alert alert-secondary" role="alert">
                                    <strong>Coming soon:</strong> Theme preferences, dashboard layout options, and table column customisation.
                                </div>
                            </div>
                        </div>
                        break;

                    default:
                        <!-- Default to Profile -->
                        <div class="card">
                            <div class="card-header">
                                <h3 class="card-title">Account Information</h3>
                            </div>
                            <div class="card-body">
                                <p class="text-muted">Your profile information is managed through your organisation's authentication system.</p>
                                
                                <dl class="row mt-4">
                                    <dt class="col-sm-3">Name</dt>
                                    <dd class="col-sm-9">@user?.Name</dd>

                                    <dt class="col-sm-3">Email</dt>
                                    <dd class="col-sm-9">@user?.Email</dd>

                                    <dt class="col-sm-3">User ID</dt>
                                    <dd class="col-sm-9"><code>@user?.Id</code></dd>
                                </dl>

                                <div class="alert alert-info mt-4" role="alert">
                                    <strong>Note:</strong> To update your name or email address, please contact your system administrator.
                                </div>
                            </div>
                        </div>
                        break;
                }
            </div>
        </div>
    </div>
</section>
