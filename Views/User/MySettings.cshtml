@{
    ViewData["Title"] = "My settings";
    var user = ViewBag.User as Compass.Models.User;
    var selectedBusinessAreas = ViewBag.SelectedBusinessAreas as List<string> ?? new List<string>();
    var businessAreas = ViewBag.BusinessAreas as List<string> ?? new List<string>();
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">My settings</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <h3 class="card-title">My settings</h3>
            </div>
            <div class="card-body">
                <!-- Nav tabs -->
                <ul class="nav nav-tabs" id="settingsTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <a class="nav-link active" id="profile-tab" data-toggle="tab" href="#profile" role="tab" 
                           aria-controls="profile" aria-selected="true">
                            <i class="fas fa-user" aria-hidden="true"></i> Profile
                        </a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" id="preferences-tab" data-toggle="tab" href="#preferences" role="tab" 
                           aria-controls="preferences" aria-selected="false">
                            <i class="fas fa-sliders-h" aria-hidden="true"></i> Preferences
                        </a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link disabled" id="notifications-tab" data-toggle="tab" href="#notifications" role="tab" 
                           aria-controls="notifications" aria-selected="false" aria-disabled="true">
                            <i class="fas fa-bell" aria-hidden="true"></i> Notifications <span class="badge badge-secondary ml-1">Coming soon</span>
                        </a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link disabled" id="display-tab" data-toggle="tab" href="#display" role="tab" 
                           aria-controls="display" aria-selected="false" aria-disabled="true">
                            <i class="fas fa-palette" aria-hidden="true"></i> Display <span class="badge badge-secondary ml-1">Coming soon</span>
                        </a>
                    </li>
                </ul>

                <!-- Tab panes -->
                <div class="tab-content mt-3" id="settingsTabContent">
                    <!-- Profile Tab -->
                    <div class="tab-pane fade show active" id="profile" role="tabpanel" aria-labelledby="profile-tab">
                        <div class="row">
                            <div class="col-lg-8">
                                <h5 class="mb-3">Account information</h5>
                                <p class="text-muted">Your profile information is managed through your organisation's authentication system.</p>
                                
                                <dl class="row mt-4">
                                    <dt class="col-sm-3">Name</dt>
                                    <dd class="col-sm-9">@user?.Name</dd>

                                    <dt class="col-sm-3">Email</dt>
                                    <dd class="col-sm-9">@user?.Email</dd>

                                    <dt class="col-sm-3">User ID</dt>
                                    <dd class="col-sm-9"><code>@user?.Id</code></dd>
                                </dl>

                                <div class="alert alert-info mt-4" role="alert">
                                    <i class="fas fa-info-circle" aria-hidden="true"></i>
                                    <strong>Note:</strong> To update your name or email address, please contact your system administrator.
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Preferences Tab -->
                    <div class="tab-pane fade" id="preferences" role="tabpanel" aria-labelledby="preferences-tab">
                        <form asp-action="MySettings" method="post">
                            <div class="row">
                                <div class="col-lg-8">
                                    <h5 class="mb-3">Business area preferences</h5>
                                    <p class="text-muted">
                                        Select your primary business areas. When viewing risks, issues, actions, and milestones, 
                                        you'll see items from these areas by default. This helps you focus on what's most relevant to your work.
                                    </p>

                                    <div class="form-group mt-4">
                                        @if (businessAreas.Any())
                                        {
                                            <div class="row">
                                                @foreach (var area in businessAreas)
                                                {
                                                    var isChecked = selectedBusinessAreas.Contains(area);
                                                    <div class="col-xxl-6 col-xl-6 col-lg-6 col-md-6 col-sm-12 col-12">
                                                        <div class="custom-control custom-checkbox mb-2">
                                                            <input type="checkbox" 
                                                                   class="custom-control-input" 
                                                                   id="area_@area.Replace(" ", "_")" 
                                                                   name="selectedBusinessAreas" 
                                                                   value="@area" 
                                                                   @(isChecked ? "checked" : "") />
                                                            <label class="custom-control-label" for="area_@area.Replace(" ", "_")">
                                                                @area
                                                            </label>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="alert alert-warning" role="alert">
                                                <i class="fas fa-exclamation-triangle" aria-hidden="true"></i>
                                                No business areas available. Please contact your administrator.
                                            </div>
                                        }
                                    </div>

                                    @if (!selectedBusinessAreas.Any())
                                    {
                                        <div class="alert alert-info" role="alert">
                                            <i class="fas fa-info-circle" aria-hidden="true"></i>
                                            <strong>No preferences set:</strong> You'll see all items across all business areas in list views.
                                        </div>
                                    }

                                    <div class="card bg-light mt-4">
                                        <div class="card-body">
                                            <h6 class="card-title"><i class="fas fa-question-circle" aria-hidden="true"></i> How preferences work</h6>
                                            <ul class="mb-0 pl-3">
                                                <li><strong>Default filtering:</strong> List views will show items from your selected business areas by default</li>
                                                <li><strong>Override filters:</strong> You can still filter by other business areas or view all items</li>
                                                <li><strong>"Assigned to me":</strong> Items assigned to you always appear regardless of business area</li>
                                                <li><strong>No preferences:</strong> If you don't select any areas, you'll see everything</li>
                                            </ul>
                                        </div>
                                    </div>

                                    <div class="form-group mt-4">
                                        <button type="submit" class="btn btn-primary">
                                            <i class="fas fa-save" aria-hidden="true"></i> Save preferences
                                        </button>
                                        <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">
                                            <i class="fas fa-times" aria-hidden="true"></i> Cancel
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>

                    <!-- Notifications Tab (Placeholder) -->
                    <div class="tab-pane fade" id="notifications" role="tabpanel" aria-labelledby="notifications-tab">
                        <div class="row">
                            <div class="col-lg-8">
                                <h5 class="mb-3">Notification preferences</h5>
                                <p class="text-muted">Notification settings will be available in a future update.</p>
                                
                                <div class="alert alert-secondary" role="alert">
                                    <i class="fas fa-clock" aria-hidden="true"></i>
                                    <strong>Coming soon:</strong> Email and in-app notification preferences for risks, issues, actions, and milestones.
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Display Tab (Placeholder) -->
                    <div class="tab-pane fade" id="display" role="tabpanel" aria-labelledby="display-tab">
                        <div class="row">
                            <div class="col-lg-8">
                                <h5 class="mb-3">Display settings</h5>
                                <p class="text-muted">Display and interface customisation options will be available in a future update.</p>
                                
                                <div class="alert alert-secondary" role="alert">
                                    <i class="fas fa-clock" aria-hidden="true"></i>
                                    <strong>Coming soon:</strong> Theme preferences, dashboard layout options, and table column customisation.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

