@{
    ViewData["Title"] = "Accessibility report - DDT Reports";
    
    // Get data from ViewBag
    var totalProducts = ViewBag.TotalProducts ?? 0;
    var enrolledProductsCount = ViewBag.EnrolledProductsCount ?? 0;
    var issuesByLevel = ViewBag.IssuesByLevel as Dictionary<string, int> ?? new Dictionary<string, int>();
    var topProductsWithIssues = ViewBag.TopProductsWithIssues as List<ProductAccessibility> ?? new List<ProductAccessibility>();
    var overdueIssues = ViewBag.OverdueIssues as List<AccessibilityIssue> ?? new List<AccessibilityIssue>();
    var wontFixIssues = ViewBag.WontFixIssues ?? 0;
    var totalOpenIssues = ViewBag.TotalOpenIssues ?? 0;
    
    // Calculate percentages
    var enrollmentRate = totalProducts > 0 ? (enrolledProductsCount * 100.0 / totalProducts) : 0;
    var levelACount = issuesByLevel.ContainsKey("A") ? issuesByLevel["A"] : 0;
    var levelAACount = issuesByLevel.ContainsKey("AA") ? issuesByLevel["AA"] : 0;
    var levelAAACount = issuesByLevel.ContainsKey("AAA") ? issuesByLevel["AAA"] : 0;
    var bestPracticeCount = issuesByLevel.ContainsKey("Best Practice") ? issuesByLevel["Best Practice"] : 0;
}

<style>
    .metric-card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .metric-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1) !important;
    }
    .progress-bar-custom {
        height: 8px;
        border-radius: 4px;
    }
    .wcag-badge {
        font-weight: 600;
        padding: 0.35rem 0.65rem;
    }
    .wcag-level-a { background-color: #dc3545; color: white; }
    .wcag-level-aa { background-color: #ffc107; color: #212529; }
    .wcag-level-aaa { background-color: #17a2b8; color: white; }
    .wcag-level-bp { background-color: #6c757d; color: white; }
</style>

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">DDT Reports</a></li>
                    <li class="breadcrumb-item active">Accessibility report</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <!-- Header Banner with Key Metrics -->
        <div class="row mb-4" style="display: flex;">
            <div class="col-lg-8" style="display: flex;">
                <div class="card border-0 w-100" style="background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%); border-radius: 12px;">
                    <div class="card-body p-4">
                        <div class="row align-items-center" style="height: 100%;">
                            <div class="col-md-6">
                                <p class="text-muted mb-1" style="font-size: 0.9rem;">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
                                <h2 class="mb-2" style="font-weight: 600; color: #2E7D32;">Accessibility report</h2>
                                <p class="text-muted mb-0" style="font-size: 0.95rem;">Summary of product accessibility enrollment and open issues</p>
                            </div>
                            <div class="col-md-6">
                                <div class="d-flex justify-content-start">
                                    <!-- Enrollment Card -->
                                    <div style="flex: 0 0 50%; padding-right: 8px;">
                                        <div class="card border-0 shadow-sm metric-card" style="border-radius: 8px; transition: transform 0.2s, box-shadow 0.2s;">
                                            <div class="card-body p-3">
                                                <h3 class="mb-1 text-left" style="font-weight: 700; font-size: 1.8rem;">@enrolledProductsCount</h3>
                                                <p class="text-muted mb-0 text-left" style="font-size: 0.85rem;">Enrolled products</p>
                                                <small class="text-muted">of @totalProducts total</small>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Issues Card -->
                                    <div style="flex: 0 0 50%;">
                                        <div class="card border-0 shadow-sm metric-card" style="border-radius: 8px; transition: transform 0.2s, box-shadow 0.2s;">
                                            <div class="card-body p-3">
                                                <h3 class="mb-1 text-left" style="font-weight: 700; font-size: 1.8rem; color: #dc3545;">@totalOpenIssues</h3>
                                                <p class="text-muted mb-0 text-left" style="font-size: 0.85rem;">Open issues</p>
                                                <small class="text-muted">across all products</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Right side: Enrollment Progress -->
            <div class="col-lg-4" style="display: flex;">
                <div class="card border-0 shadow-sm w-100 metric-card" style="border-radius: 12px; background: white; transition: transform 0.2s, box-shadow 0.2s;">
                    <div class="card-body p-4">
                        <h5 class="mb-3" style="font-weight: 600;">Enrollment progress</h5>
                        <div class="mb-2">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted" style="font-size: 0.9rem;">Coverage</span>
                                <span class="font-weight-bold">@enrollmentRate.ToString("F1")%</span>
                            </div>
                            <div class="progress progress-bar-custom">
                                <div class="progress-bar @(enrollmentRate >= 75 ? "bg-success" : enrollmentRate >= 50 ? "bg-warning" : "bg-danger")" 
                                     role="progressbar" 
                                     style="width: @enrollmentRate%"
                                     aria-valuenow="@enrollmentRate" 
                                     aria-valuemin="0" 
                                     aria-valuemax="100"></div>
                            </div>
                        </div>
                        <div class="mt-3 pt-3 border-top">
                            <p class="mb-0 text-muted" style="font-size: 0.85rem;">
                                @(totalProducts - enrolledProductsCount) products not yet enrolled
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- WCAG Level Summary -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0"><i class="fas fa-layer-group mr-2"></i> Issues by WCAG level</h3>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-lg-3 col-md-6 mb-3">
                                <div class="card metric-card border-left-danger shadow-sm">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center">
                                            <div class="flex-grow-1">
                                                <div class="text-muted text-uppercase mb-1" style="font-size: 0.75rem; font-weight: 600;">Level A</div>
                                                <h2 class="mb-0" style="font-weight: 700; color: #dc3545;">@levelACount</h2>
                                                @if (totalOpenIssues > 0)
                                                {
                                                    <small class="text-muted">@((levelACount * 100.0 / totalOpenIssues).ToString("F1"))% of total</small>
                                                }
                                            </div>
                                            <div class="ml-3">
                                                <span class="wcag-badge wcag-level-a">A</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 mb-3">
                                <div class="card metric-card border-left-warning shadow-sm">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center">
                                            <div class="flex-grow-1">
                                                <div class="text-muted text-uppercase mb-1" style="font-size: 0.75rem; font-weight: 600;">Level AA</div>
                                                <h2 class="mb-0" style="font-weight: 700; color: #ffc107;">@levelAACount</h2>
                                                @if (totalOpenIssues > 0)
                                                {
                                                    <small class="text-muted">@((levelAACount * 100.0 / totalOpenIssues).ToString("F1"))% of total</small>
                                                }
                                            </div>
                                            <div class="ml-3">
                                                <span class="wcag-badge wcag-level-aa">AA</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 mb-3">
                                <div class="card metric-card border-left-info shadow-sm">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center">
                                            <div class="flex-grow-1">
                                                <div class="text-muted text-uppercase mb-1" style="font-size: 0.75rem; font-weight: 600;">Level AAA</div>
                                                <h2 class="mb-0" style="font-weight: 700; color: #17a2b8;">@levelAAACount</h2>
                                                @if (totalOpenIssues > 0)
                                                {
                                                    <small class="text-muted">@((levelAAACount * 100.0 / totalOpenIssues).ToString("F1"))% of total</small>
                                                }
                                            </div>
                                            <div class="ml-3">
                                                <span class="wcag-badge wcag-level-aaa">AAA</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 mb-3">
                                <div class="card metric-card border-left-secondary shadow-sm">
                                    <div class="card-body">
                                        <div class="d-flex align-items-center">
                                            <div class="flex-grow-1">
                                                <div class="text-muted text-uppercase mb-1" style="font-size: 0.75rem; font-weight: 600;">Best practice</div>
                                                <h2 class="mb-0" style="font-weight: 700; color: #6c757d;">@bestPracticeCount</h2>
                                                @if (totalOpenIssues > 0)
                                                {
                                                    <small class="text-muted">@((bestPracticeCount * 100.0 / totalOpenIssues).ToString("F1"))% of total</small>
                                                }
                                            </div>
                                            <div class="ml-3">
                                                <span class="wcag-badge wcag-level-bp">BP</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Additional Metrics -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card metric-card border-left-warning shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-grow-1">
                                <div class="text-muted text-uppercase mb-1" style="font-size: 0.75rem; font-weight: 600;">Overdue issues</div>
                                <h2 class="mb-0" style="font-weight: 700; color: #ffc107;">@overdueIssues.Count</h2>
                                <small class="text-muted">Past planned resolution date</small>
                            </div>
                            <div class="ml-3">
                                <i class="fas fa-clock fa-2x text-warning"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card metric-card border-left-secondary shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-grow-1">
                                <div class="text-muted text-uppercase mb-1" style="font-size: 0.75rem; font-weight: 600;">Won't fix issues</div>
                                <h2 class="mb-0" style="font-weight: 700; color: #6c757d;">@wontFixIssues</h2>
                                <small class="text-muted">Not intended to be closed</small>
                            </div>
                            <div class="ml-3">
                                <i class="fas fa-ban fa-2x text-secondary"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <!-- Left Column: Top Products with Issues -->
            <div class="col-lg-8">
                @if (topProductsWithIssues.Any())
                {
                    <div class="card mb-4">
                        <div class="card-header bg-danger text-white">
                            <h3 class="card-title mb-0"><i class="fas fa-list-ol mr-2"></i> Top 10 products with most open issues</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th style="width: 40%;">Product</th>
                                        <th style="width: 15%;">FIPS ID</th>
                                        <th style="width: 15%;">Phase</th>
                                        <th style="width: 15%;">Open issues</th>
                                        <th style="width: 15%;">WCAG levels</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var product in topProductsWithIssues)
                                    {
                                        var openIssues = product.Issues.Where(i => !i.IsDeleted && (i.Status == "open" || i.Status == "in_progress")).ToList();
                                        var issueCount = openIssues.Count;
                                        
                                        // Get WCAG levels for this product
                                        var levels = new HashSet<string>();
                                        foreach (var issue in openIssues)
                                        {
                                            if (issue.IssueType == "WCAG" && issue.WcagCriteriaLinks != null && issue.WcagCriteriaLinks.Any())
                                            {
                                                foreach (var link in issue.WcagCriteriaLinks)
                                                {
                                                    if (!string.IsNullOrEmpty(link.WcagCriterion?.Level))
                                                    {
                                                        levels.Add(link.WcagCriterion.Level);
                                                    }
                                                }
                                            }
                                            else if (issue.IssueType == "Best Practice")
                                            {
                                                levels.Add("BP");
                                            }
                                        }
                                        
                                        <tr>
                                            <td>
                                                <a href="/Apps/AccessibilityService/Product/@product.FipsId" class="text-decoration-none">
                                                    <strong>@(product.ProductName ?? "Unknown")</strong>
                                                </a>
                                            </td>
                                            <td>
                                                <small class="text-muted">@product.FipsId</small>
                                            </td>
                                            <td>
                                                <span class="badge badge-secondary">@(product.ProductPhase ?? "Not set")</span>
                                            </td>
                                            <td>
                                                <span class="badge badge-danger badge-pill" style="font-size: 1rem;">@issueCount</span>
                                            </td>
                                            <td>
                                                @if (levels.Any())
                                                {
                                                    @foreach (var level in levels.OrderBy(l => l == "A" ? 1 : l == "AA" ? 2 : l == "AAA" ? 3 : 4))
                                                    {
                                                        var badgeClass = level == "A" ? "wcag-level-a" : level == "AA" ? "wcag-level-aa" : level == "AAA" ? "wcag-level-aaa" : "wcag-level-bp";
                                                        <span class="wcag-badge @badgeClass" style="font-size: 0.75rem; margin-right: 0.25rem;">@level</span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card mb-4">
                        <div class="card-body text-center py-5">
                            <i class="fas fa-check-circle fa-3x text-success mb-3"></i>
                            <h4>No products with open issues</h4>
                            <p class="text-muted">All enrolled products have no open accessibility issues.</p>
                        </div>
                    </div>
                }

                <!-- Overdue Issues -->
                @if (overdueIssues.Any())
                {
                    <div class="card">
                        <div class="card-header bg-warning text-white">
                            <h3 class="card-title mb-0"><i class="fas fa-clock mr-2"></i> Overdue issues (@overdueIssues.Count)</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th style="width: 30%;">Issue</th>
                                        <th style="width: 25%;">Product</th>
                                        <th style="width: 15%;">Planned resolution</th>
                                        <th style="width: 15%;">Days overdue</th>
                                        <th style="width: 15%;">Level</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var issue in overdueIssues.OrderBy(i => i.PlannedResolutionDate))
                                    {
                                        var daysOverdue = (DateTime.Today - issue.PlannedResolutionDate.Value).Days;
                                        var product = issue.ProductAccessibility;
                                        
                                        // Determine level
                                        string level = "—";
                                        string levelClass = "";
                                        if (issue.IssueType == "WCAG" && issue.WcagCriteriaLinks != null && issue.WcagCriteriaLinks.Any())
                                        {
                                            var levels = issue.WcagCriteriaLinks.Select(w => w.WcagCriterion.Level).Distinct().ToList();
                                            if (levels.Contains("AAA"))
                                            {
                                                level = "AAA";
                                                levelClass = "wcag-level-aaa";
                                            }
                                            else if (levels.Contains("AA"))
                                            {
                                                level = "AA";
                                                levelClass = "wcag-level-aa";
                                            }
                                            else if (levels.Contains("A"))
                                            {
                                                level = "A";
                                                levelClass = "wcag-level-a";
                                            }
                                        }
                                        else if (issue.IssueType == "Best Practice")
                                        {
                                            level = "BP";
                                            levelClass = "wcag-level-bp";
                                        }
                                        
                                        <tr class="@(daysOverdue > 30 ? "table-danger" : daysOverdue > 14 ? "table-warning" : "")">
                                            <td>
                                                <a href="/Apps/AccessibilityService/Product/@(product?.FipsId ?? "")" class="text-decoration-none">
                                                    <strong>@(issue.IssueTitle ?? issue.WcagCriteria ?? "Issue")</strong>
                                                </a>
                                            </td>
                                            <td>
                                                <a href="/Apps/AccessibilityService/Product/@(product?.FipsId ?? "")" class="text-decoration-none">
                                                    @(product?.ProductName ?? "Unknown")
                                                </a>
                                                <br>
                                                <small class="text-muted">@(product?.FipsId ?? "")</small>
                                            </td>
                                            <td>
                                                <span class="text-danger">
                                                    @issue.PlannedResolutionDate.Value.ToString("dd MMM yyyy")
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge badge-@(daysOverdue > 30 ? "danger" : daysOverdue > 14 ? "warning" : "secondary") badge-pill">
                                                    @daysOverdue day@(daysOverdue != 1 ? "s" : "")
                                                </span>
                                            </td>
                                            <td>
                                                @if (level != "—")
                                                {
                                                    <span class="wcag-badge @levelClass">@level</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">—</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <i class="fas fa-check-circle fa-3x text-success mb-3"></i>
                            <h4>No overdue issues</h4>
                            <p class="text-muted">All issues are on track for resolution.</p>
                        </div>
                    </div>
                }
            </div>

            <!-- Right Column: Summary Stats -->
            <div class="col-lg-4">
                <div class="card mb-4">
                    <div class="card-header bg-info text-white">
                        <h3 class="card-title mb-0"><i class="fas fa-chart-pie mr-2"></i> Issue distribution</h3>
                    </div>
                    <div class="card-body">
                        @if (totalOpenIssues > 0)
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="text-muted">Level A</span>
                                    <span class="font-weight-bold">@levelACount (@((levelACount * 100.0 / totalOpenIssues).ToString("F1"))%)</span>
                                </div>
                                <div class="progress progress-bar-custom mb-3">
                                    <div class="progress-bar bg-danger" role="progressbar" style="width: @((levelACount * 100.0 / totalOpenIssues))%" aria-valuenow="@levelACount" aria-valuemin="0" aria-valuemax="@totalOpenIssues"></div>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="text-muted">Level AA</span>
                                    <span class="font-weight-bold">@levelAACount (@((levelAACount * 100.0 / totalOpenIssues).ToString("F1"))%)</span>
                                </div>
                                <div class="progress progress-bar-custom mb-3">
                                    <div class="progress-bar bg-warning" role="progressbar" style="width: @((levelAACount * 100.0 / totalOpenIssues))%" aria-valuenow="@levelAACount" aria-valuemin="0" aria-valuemax="@totalOpenIssues"></div>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="text-muted">Level AAA</span>
                                    <span class="font-weight-bold">@levelAAACount (@((levelAAACount * 100.0 / totalOpenIssues).ToString("F1"))%)</span>
                                </div>
                                <div class="progress progress-bar-custom mb-3">
                                    <div class="progress-bar bg-info" role="progressbar" style="width: @((levelAAACount * 100.0 / totalOpenIssues))%" aria-valuenow="@levelAAACount" aria-valuemin="0" aria-valuemax="@totalOpenIssues"></div>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="text-muted">Best practice</span>
                                    <span class="font-weight-bold">@bestPracticeCount (@((bestPracticeCount * 100.0 / totalOpenIssues).ToString("F1"))%)</span>
                                </div>
                                <div class="progress progress-bar-custom">
                                    <div class="progress-bar bg-secondary" role="progressbar" style="width: @((bestPracticeCount * 100.0 / totalOpenIssues))%" aria-valuenow="@bestPracticeCount" aria-valuemin="0" aria-valuemax="@totalOpenIssues"></div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted text-center mb-0">No open issues</p>
                        }
                    </div>
                </div>

                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h3 class="card-title mb-0"><i class="fas fa-info-circle mr-2"></i> Quick summary</h3>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <p class="mb-1"><strong>Total products:</strong></p>
                            <p class="mb-0 text-muted">@totalProducts products in the system</p>
                        </div>
                        <hr>
                        <div class="mb-3">
                            <p class="mb-1"><strong>Enrollment coverage:</strong></p>
                            <p class="mb-0 text-muted">@enrolledProductsCount of @totalProducts products enrolled (@enrollmentRate.ToString("F1")%)</p>
                        </div>
                        <hr>
                        <div class="mb-0">
                            <p class="mb-1"><strong>Total open issues:</strong></p>
                            <p class="mb-0 text-muted">@totalOpenIssues accessibility issues requiring attention</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
