                            </div>
                            <p class="form-text text-muted js-user-picker-message"></p>
                            <input type="hidden" name="entraUserObjectId" class="js-user-picker-objectid" id="primaryContactObjectId" />
                            <input type="hidden" name="entraUserEmail" class="js-user-picker-email" id="primaryContactEmail" />
                            <input type="hidden" name="entraUserName" class="js-user-picker-name" id="primaryContactName" />
                            <div class="user-picker__selected js-user-picker-summary" data-default-text="No primary contact selected.">
                                <span class="text-muted">No primary contact selected.</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-warning" id="clearPrimaryContactBtn">Clear Contact</button>
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary">Save Primary Contact</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Update Activity Type Modal -->
<div class="modal fade" id="updateActivityTypeModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Update Activity Type</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateProjectActivityType" method="post">
                <input type="hidden" name="projectId" id="activityTypeProjectId" />
                <div class="modal-body">
                    <p class="mb-3">Select the Activity Type for this deliverable.</p>
                    <div class="form-group">
                        <label for="activityTypeLookupId" class="form-label">Activity Type</label>
                        <select class="form-control" id="activityTypeLookupId" name="activityTypeLookupId">
