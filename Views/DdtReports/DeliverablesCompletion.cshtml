                                                <i class="fas fa-check-square text-success completion-icon" title="@project.ActivityTypeName"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-times-square text-danger completion-icon" title="Activity Type missing"></i>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (project.HasSpendControl)
                                            {
                                                <span class="badge badge-@(project.IsSubjectToSpendControl == true ? "warning" : "secondary")">@(project.IsSubjectToSpendControl == true ? "Yes" : "No")</span>
                                            }
                                            else
                                            {
                                                <i class="fas fa-times-square text-danger completion-icon" title="Spend Control missing"></i>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group">
                                                <button type="button" class="btn btn-sm btn-outline-secondary view-details-btn" data-project-id="@project.ProjectId" title="View details">
                                                    <i class="fas fa-chevron-down"></i>
                                                </button>
                                                <button type="button" class="btn btn-sm btn-secondary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                    <i class="fas fa-cog"></i>
                                                </button>
                                                <div class="dropdown-menu dropdown-menu-right">
                                                    <a class="dropdown-item" href="#" data-action="change-title" data-project-id="@project.ProjectId" data-project-title="@project.ProjectTitle">
                                                        <i class="fas fa-edit mr-2"></i> Change Title
                                                    </a>
                                                    <div class="dropdown-divider"></div>
                                                    <a class="dropdown-item" href="#" data-action="set-sro" data-project-id="@project.ProjectId">
                                                        <i class="fas fa-user-tie mr-2"></i> Set SRO
                                                    </a>
                                                    <a class="dropdown-item" href="#" data-action="set-pmo-contact" data-project-id="@project.ProjectId">
                                                        <i class="fas fa-user-friends mr-2"></i> Set PMO Contact
                                                    </a>
                                                    <a class="dropdown-item" href="#" data-action="set-directorate" data-project-id="@project.ProjectId">
                                                        <i class="fas fa-sitemap mr-2"></i> Set Directorate
                                                    </a>
                                                    <div class="dropdown-divider"></div>
                                                    <a class="dropdown-item" href="#" data-action="set-rag-status" data-project-id="@project.ProjectId">
                                                        <i class="fas fa-flag mr-2"></i> Set RAG Status
                                                    </a>
                                                    <a class="dropdown-item" href="#" data-action="set-priority" data-project-id="@project.ProjectId">
                                                        <i class="fas fa-star mr-2"></i> Set Priority
                                                    </a>
                                                    <a class="dropdown-item" href="#" data-action="set-business-area" data-project-id="@project.ProjectId">
                                                        <i class="fas fa-building mr-2"></i> Set Business Area
                                                    </a>
                                                    <a class="dropdown-item" href="#" data-action="set-primary-contact" data-project-id="@project.ProjectId">
                                                        <i class="fas fa-user mr-2"></i> Set Primary Contact
                                                    </a>
