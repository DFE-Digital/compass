@model Compass.Models.ProjectCompletionViewModel
@{
    ViewData["Title"] = "Deliverables Completion %";
}

@section Breadcrumbs {
    <style>
        .breadcrumb a:hover {
            color: #003078 !important;
            text-decoration: underline !important;
        }
    </style>
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home")" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" style="color: #005ea5; text-decoration: none;">DDT Reports</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Deliverables Completion %</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <h1 class="m-0">Deliverables Completion %</h1>
                <p class="text-muted mb-0">
                    <small>
                        Showing Active deliverables only. Track completion of key fields: SRO, Primary contact, Service Owner, Directorate, Budget owner, RAG, Priority, Business area, Activity type, Spend control.
                    </small>
                </p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @Html.Raw(TempData["SuccessMessage"])
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div id="inlineAlertContainer"></div>

        <!-- Summary Cards -->
        <div class="row mb-3">
            <!-- Full Completion Count -->
            <div class="col-lg-2 col-md-4 col-6">
                <div class="card @(Model.FullCompletionCount == Model.Projects.Count ? "card-success" : "card-info") mb-4 h-100" id="fullCompletionCard">
                    <div class="card-header">
                        <h3 class="card-title">
                            100% completion target
                        </h3>
                    </div>
                    <div class="card-body text-center">
                        @{
                            var fullPercentage = Model.Projects.Any() ? (Model.FullCompletionCount / (double)Model.Projects.Count) * 100 : 0;
                            var fullColorClass = fullPercentage >= 80 ? "success" : fullPercentage >= 50 ? "warning" : "info";
                        }
                        <h2 class="mb-0 stat-value-large" id="fullCompletionValue">@fullPercentage.ToString("F1")%</h2>
                        <p class="text-muted mb-0 mt-2" id="fullCompletionText">@Model.FullCompletionCount of @Model.Projects.Count</p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar bg-@fullColorClass" 
                                 style="width: @fullPercentage%" id="fullCompletionProgress"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Field Completion Stats -->
            <div class="col-lg-2 col-md-4 col-6">
                @{
                    var sroPercentage = Model.Projects.Any() ? (Model.CompletedSroCount / (double)Model.Projects.Count) * 100 : 0;
                    var sroColorClass = sroPercentage >= 80 ? "success" : sroPercentage >= 50 ? "warning" : "danger";
                }
                <div class="card card-@sroColorClass mb-4 h-100" id="completedSroCard">
                    <div class="card-header">
                        <h3 class="card-title">SRO</h3>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0 stat-value-medium" id="completedSroValue">@sroPercentage.ToString("F1")%</h2>
                        <p class="text-muted mb-0 mt-2" id="completedSroText">@Model.CompletedSroCount of @Model.Projects.Count</p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar bg-@sroColorClass" style="width: @sroPercentage%" id="completedSroProgress"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-2 col-md-4 col-6">
                @{
                    var pmoPercentage = Model.Projects.Any() ? (Model.CompletedPmoContactCount / (double)Model.Projects.Count) * 100 : 0;
                    var pmoColorClass = pmoPercentage >= 80 ? "success" : pmoPercentage >= 50 ? "warning" : "danger";
                }
                <div class="card card-@pmoColorClass mb-4 h-100" id="completedPmoCard">
                    <div class="card-header">
                        <h3 class="card-title">PMO Contact</h3>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0 stat-value-medium" id="completedPmoValue">@pmoPercentage.ToString("F1")%</h2>
                        <p class="text-muted mb-0 mt-2" id="completedPmoText">@Model.CompletedPmoContactCount of @Model.Projects.Count</p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar bg-@pmoColorClass" style="width: @pmoPercentage%" id="completedPmoProgress"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-2 col-md-4 col-6">
                @{
                    var directoratePercentage = Model.Projects.Any() ? (Model.CompletedDirectorateCount / (double)Model.Projects.Count) * 100 : 0;
                    var directorateColorClass = directoratePercentage >= 80 ? "success" : directoratePercentage >= 50 ? "warning" : "danger";
                }
                <div class="card card-@directorateColorClass mb-4 h-100" id="completedDirectorateCard">
                    <div class="card-header">
                        <h3 class="card-title">Directorate</h3>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0 stat-value-medium" id="completedDirectorateValue">@directoratePercentage.ToString("F1")%</h2>
                        <p class="text-muted mb-0 mt-2" id="completedDirectorateText">@Model.CompletedDirectorateCount of @Model.Projects.Count</p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar bg-@directorateColorClass" style="width: @directoratePercentage%" id="completedDirectorateProgress"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-2 col-md-4 col-6">
                @{
                    var budgetOwnerPercentage = Model.Projects.Any() ? (Model.CompletedBudgetOwnerCount / (double)Model.Projects.Count) * 100 : 0;
                    var budgetOwnerColorClass = budgetOwnerPercentage >= 80 ? "success" : budgetOwnerPercentage >= 50 ? "warning" : "danger";
                }
                <div class="card card-@budgetOwnerColorClass mb-4 h-100" id="completedBudgetOwnerCard">
                    <div class="card-header">
                        <h3 class="card-title">Budget Owner</h3>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0 stat-value-medium" id="completedBudgetOwnerValue">@budgetOwnerPercentage.ToString("F1")%</h2>
                        <p class="text-muted mb-0 mt-2" id="completedBudgetOwnerText">@Model.CompletedBudgetOwnerCount of @Model.Projects.Count</p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar bg-@budgetOwnerColorClass" style="width: @budgetOwnerPercentage%" id="completedBudgetOwnerProgress"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-2 col-md-4 col-6">
                @{
                    var ragPercentage = Model.Projects.Any() ? (Model.CompletedRagStatusCount / (double)Model.Projects.Count) * 100 : 0;
                    var ragColorClass = ragPercentage >= 80 ? "success" : ragPercentage >= 50 ? "warning" : "danger";
                }
                <div class="card card-@ragColorClass mb-4 h-100" id="completedRagCard">
                    <div class="card-header">
                        <h3 class="card-title">RAG Status</h3>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0 stat-value-medium" id="completedRagValue">@ragPercentage.ToString("F1")%</h2>
                        <p class="text-muted mb-0 mt-2" id="completedRagText">@Model.CompletedRagStatusCount of @Model.Projects.Count</p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar bg-@ragColorClass" style="width: @ragPercentage%" id="completedRagProgress"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-2 col-md-4 col-6">
                @{
                    var priorityPercentage = Model.Projects.Any() ? (Model.CompletedPriorityCount / (double)Model.Projects.Count) * 100 : 0;
                    var priorityColorClass = priorityPercentage >= 80 ? "success" : priorityPercentage >= 50 ? "warning" : "danger";
                }
                <div class="card card-@priorityColorClass mb-4 h-100" id="completedPriorityCard">
                    <div class="card-header">
                        <h3 class="card-title">Priority</h3>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0 stat-value-medium" id="completedPriorityValue">@priorityPercentage.ToString("F1")%</h2>
                        <p class="text-muted mb-0 mt-2" id="completedPriorityText">@Model.CompletedPriorityCount of @Model.Projects.Count</p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar bg-@priorityColorClass" style="width: @priorityPercentage%" id="completedPriorityProgress"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-2 col-md-4 col-6">
                @{
                    var businessAreaPercentage = Model.Projects.Any() ? (Model.CompletedBusinessAreaCount / (double)Model.Projects.Count) * 100 : 0;
                    var businessAreaColorClass = businessAreaPercentage >= 80 ? "success" : businessAreaPercentage >= 50 ? "warning" : "danger";
                }
                <div class="card card-@businessAreaColorClass mb-4 h-100" id="completedBusinessAreaCard">
                    <div class="card-header">
                        <h3 class="card-title">Business Area</h3>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0 stat-value-medium" id="completedBusinessAreaValue">@businessAreaPercentage.ToString("F1")%</h2>
                        <p class="text-muted mb-0 mt-2" id="completedBusinessAreaText">@Model.CompletedBusinessAreaCount of @Model.Projects.Count</p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar bg-@businessAreaColorClass" style="width: @businessAreaPercentage%" id="completedBusinessAreaProgress"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-2 col-md-4 col-6">
                @{
                    var primaryContactPercentage = Model.Projects.Any() ? (Model.CompletedPrimaryContactCount / (double)Model.Projects.Count) * 100 : 0;
                    var primaryContactColorClass = primaryContactPercentage >= 80 ? "success" : primaryContactPercentage >= 50 ? "warning" : "danger";
                }
                <div class="card card-@primaryContactColorClass mb-4 h-100" id="completedPrimaryContactCard">
                    <div class="card-header">
                        <h3 class="card-title">Primary Contact</h3>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0 stat-value-medium" id="completedPrimaryContactValue">@primaryContactPercentage.ToString("F1")%</h2>
                        <p class="text-muted mb-0 mt-2" id="completedPrimaryContactText">@Model.CompletedPrimaryContactCount of @Model.Projects.Count</p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar bg-@primaryContactColorClass" style="width: @primaryContactPercentage%" id="completedPrimaryContactProgress"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-2 col-md-4 col-6">
                @{
                    var serviceOwnerPercentage = Model.Projects.Any() ? (Model.CompletedServiceOwnerCount / (double)Model.Projects.Count) * 100 : 0;
                    var serviceOwnerColorClass = serviceOwnerPercentage >= 80 ? "success" : serviceOwnerPercentage >= 50 ? "warning" : "danger";
                }
                <div class="card card-@serviceOwnerColorClass mb-4 h-100" id="completedServiceOwnerCard">
                    <div class="card-header">
                        <h3 class="card-title">Service Owner</h3>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0 stat-value-medium" id="completedServiceOwnerValue">@serviceOwnerPercentage.ToString("F1")%</h2>
                        <p class="text-muted mb-0 mt-2" id="completedServiceOwnerText">@Model.CompletedServiceOwnerCount of @Model.Projects.Count</p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar bg-@serviceOwnerColorClass" style="width: @serviceOwnerPercentage%" id="completedServiceOwnerProgress"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-2 col-md-4 col-6">
                @{
                    var activityTypePercentage = Model.Projects.Any() ? (Model.CompletedActivityTypeCount / (double)Model.Projects.Count) * 100 : 0;
                    var activityTypeColorClass = activityTypePercentage >= 80 ? "success" : activityTypePercentage >= 50 ? "warning" : "danger";
                }
                <div class="card card-@activityTypeColorClass mb-4 h-100" id="completedActivityTypeCard">
                    <div class="card-header">
                        <h3 class="card-title">Activity Type</h3>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0 stat-value-medium" id="completedActivityTypeValue">@activityTypePercentage.ToString("F1")%</h2>
                        <p class="text-muted mb-0 mt-2" id="completedActivityTypeText">@Model.CompletedActivityTypeCount of @Model.Projects.Count</p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar bg-@activityTypeColorClass" style="width: @activityTypePercentage%" id="completedActivityTypeProgress"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-2 col-md-4 col-6">
                @{
                    var spendControlPercentage = Model.Projects.Any() ? (Model.CompletedSpendControlCount / (double)Model.Projects.Count) * 100 : 0;
                    var spendControlColorClass = spendControlPercentage >= 80 ? "success" : spendControlPercentage >= 50 ? "warning" : "danger";
                }
                <div class="card card-@spendControlColorClass mb-4 h-100" id="completedSpendControlCard">
                    <div class="card-header">
                        <h3 class="card-title">Spend Control</h3>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0 stat-value-medium" id="completedSpendControlValue">@spendControlPercentage.ToString("F1")%</h2>
                        <p class="text-muted mb-0 mt-2" id="completedSpendControlText">@Model.CompletedSpendControlCount of @Model.Projects.Count</p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar bg-@spendControlColorClass" style="width: @spendControlPercentage%" id="completedSpendControlProgress"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Business Area Completion -->
        <div class="row mb-3">
            <div class="col-lg-12">
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title">
                            Completion by business area
                        </h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Business area</th>
                                        <th class="text-center">Deliverables</th>
                                        <th class="text-center">Average completion</th>
                                        <th class="text-center width-200px">Progress</th>
                                    </tr>
                                </thead>
                                <tbody id="businessAreaTableBody">
                                    @foreach (var area in Model.BusinessAreaCompletions)
                                    {
                                        var completionClass = area.AverageCompletionPercentage >= 80 ? "success" : 
                                                            area.AverageCompletionPercentage >= 60 ? "warning" : "danger";
                                        <tr>
                                            <td>
                                                <strong>@area.BusinessArea</strong>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge badge-info">@area.ProductCount</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge badge-@completionClass badge-lg">
                                                    @area.AverageCompletionPercentage.ToString("F1")%
                                                </span>
                                            </td>
                                            <td>
                                                <div class="progress progress-sm">
                                                    <div class="progress-bar bg-@completionClass" 
                                                         style="width: @area.AverageCompletionPercentage%"></div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters -->
        <div class="row mb-3">
            <div class="col-lg-12">
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title">Filter deliverables</h3>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-lg-4 col-md-6 col-12">
                                <div class="form-group">
                                    <label for="searchInput">Search by deliverable name or code</label>
                                    <input type="text" class="form-control" id="searchInput" placeholder="Search deliverables...">
                                </div>
                            </div>
                            <div class="col-lg-2 col-md-6 col-12">
                                <div class="form-group">
                                    <label for="businessAreaFilter">Business area</label>
                                    <select class="form-control" id="businessAreaFilter">
                                        <option value="">All business areas</option>
                                        @foreach (var area in Model.BusinessAreaCompletions.OrderBy(a => a.BusinessArea))
                                        {
                                            <option value="@area.BusinessArea">@area.BusinessArea</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 col-12">
                                <div class="form-group">
                                    <label for="completionFilter">Filter by completion %</label>
                                    <select class="form-control" id="completionFilter">
                                        <option value="">All deliverables</option>
                                        <option value="100">100% Complete</option>
                                        <option value="80-99">80-99%</option>
                                        <option value="60-79">60-79%</option>
                                        <option value="40-59">40-59%</option>
                                        <option value="0-39">0-39%</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 col-12">
                                <div class="form-group">
                                    <label for="statusFilter">Filter by status</label>
                                    <select class="form-control" id="statusFilter">
                                        <option value="">All deliverables</option>
                                        <option value="complete">Complete (100%)</option>
                                        <option value="incomplete">Incomplete (&lt;100%)</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Completion Table - All Projects -->
        <div class="row">
            <div class="col-lg-12">
                @if (!Model.Projects.Any())
                {
                    <div class="card">
                        <div class="card-body text-center text-muted p-5">
                            <i class="fas fa-info-circle fa-3x mb-3"></i>
                            <p class="mb-0">No deliverables found</p>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card mb-4">
                        <div class="card-header">
                            <h3 class="card-title">Deliverables Completion Status</h3>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-hover sortable-table mb-0" id="completionTable">
                                    <thead>
                                        <tr>
                                            <th class="sortable" data-column="ProjectTitle" style="cursor: pointer;">
                                                Project <i class="fas fa-sort"></i>
                                            </th>
                                            <th class="text-center sortable" data-column="Phase" style="cursor: pointer;">
                                                Phase <i class="fas fa-sort"></i>
                                            </th>
                                            <th class="text-center sortable" data-column="Sro" style="cursor: pointer;">
                                                SRO <i class="fas fa-sort"></i>
                                            </th>
                                            <th class="text-center sortable" data-column="PrimaryContact" style="cursor: pointer;">
                                                Primary Contact <i class="fas fa-sort"></i>
                                            </th>
                                            <th class="text-center sortable" data-column="ServiceOwner" style="cursor: pointer;">
                                                Service Owner <i class="fas fa-sort"></i>
                                            </th>
                                            <th class="text-center sortable" data-column="PmoContact" style="cursor: pointer;">
                                                PMO Contact <i class="fas fa-sort"></i>
                                            </th>
                                            <th class="text-center sortable" data-column="Directorate" style="cursor: pointer;">
                                                Directorate <i class="fas fa-sort"></i>
                                            </th>
                                            <th class="text-center sortable" data-column="BudgetOwner" style="cursor: pointer;">
                                                Budget Owner <i class="fas fa-sort"></i>
                                            </th>
                                            <th class="text-center sortable" data-column="RagStatus" style="cursor: pointer;">
                                                RAG Status <i class="fas fa-sort"></i>
                                            </th>
                                            <th class="text-center sortable" data-column="Priority" style="cursor: pointer;">
                                                Priority <i class="fas fa-sort"></i>
                                            </th>
                                            <th class="text-center sortable" data-column="BusinessArea" style="cursor: pointer;">
                                                Business Area <i class="fas fa-sort"></i>
                                            </th>
                                            <th class="text-center sortable" data-column="ActivityType" style="cursor: pointer;">
                                                Activity Type <i class="fas fa-sort"></i>
                                            </th>
                                            <th class="text-center sortable" data-column="SpendControl" style="cursor: pointer;">
                                                Spend Control <i class="fas fa-sort"></i>
                                            </th>
                                            <th class="text-center sortable" data-column="CompletionPercentage" style="cursor: pointer; width: 180px;">
                                                Completion % <i class="fas fa-sort"></i>
                                            </th>
                                            <th class="text-center" style="width: 100px;">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var project in Model.Projects)
                                        {
                                            var completionBadgeClass = project.CompletionPercentage >= 100 ? "success" :
                                                                       project.CompletionPercentage >= 75 ? "warning" :
                                                                       project.CompletionPercentage >= 50 ? "orange" : "danger";
                                            <tr data-completion="@project.CompletionPercentage"
                                                data-project-title="@project.ProjectTitle.ToLowerInvariant()"
                                                data-project-code="@($"DFE-DDT-{project.ProjectId}")"
                                                data-phase="@(project.Phase ?? "")"
                                                data-has-phase="@(project.HasPhase ? "true" : "false")"
                                                data-has-sro="@(project.HasSro ? "true" : "false")"
                                                data-sro-names="@string.Join(", ", project.SeniorResponsibleOfficerNames ?? new List<string>())"
                                                data-has-primary-contact="@(project.HasPrimaryContact ? "true" : "false")"
                                                data-primary-contact-name="@(project.PrimaryContactName ?? "")"
                                                data-has-service-owner="@(project.HasServiceOwner ? "true" : "false")"
                                                data-service-owner-names="@string.Join(", ", project.ServiceOwnerNames ?? new List<string>())"
                                                data-has-pmo="@(project.HasPmoContact ? "true" : "false")"
                                                data-pmo-names="@string.Join(", ", project.PmoContactNames ?? new List<string>())"
                                                data-has-directorate="@(project.HasDirectorate ? "true" : "false")"
                                                data-directorate-names="@string.Join(", ", project.DirectorateNames ?? new List<string>())"
                                                data-has-budget-owner="@(project.HasBudgetOwner ? "true" : "false")"
                                                data-budget-owner-names="@string.Join(", ", project.BudgetOwnerNames ?? new List<string>())"
                                                data-rag-status="@(project.RagStatus ?? "")"
                                                data-has-rag="@(project.HasRagStatus ? "true" : "false")"
                                                data-priority-name="@(project.PriorityName ?? "")"
                                                data-has-priority="@(project.HasPriority ? "true" : "false")"
                                                data-business-area="@(project.BusinessArea ?? "")"
                                                data-has-business-area="@(project.HasBusinessArea ? "true" : "false")"
                                                data-activity-type-name="@(project.ActivityTypeName ?? "")"
                                                data-has-activity-type="@(project.HasActivityType ? "true" : "false")"
                                                data-spend-control="@(project.HasSpendControl ? (project.IsSubjectToSpendControl == true ? "true" : "false") : "")"
                                                data-has-spend-control="@(project.HasSpendControl ? "true" : "false")">
                                                <td>
                                                    <a asp-controller="Project" asp-action="Details" asp-route-id="@project.ProjectId" class="text-decoration-none">
                                                        <strong>@project.ProjectTitle</strong>
                                                    </a>
                                                    <br>
                                                    <small class="text-muted">DFE-DDT-@project.ProjectId</small>
                                                </td>
                                                                <a class="dropdown-item" href="#" data-action="change-title" data-project-id="@project.ProjectId" data-project-title="@project.ProjectTitle">
                                                                    <i class="fas fa-edit mr-2"></i> Change Title
                                                                </a>
                                                <td class="text-center">
                                                    @if (!string.IsNullOrWhiteSpace(project.Phase))
                                                    {
