                    <button type="submit" class="btn btn-primary">Save Activity Type</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Update Spend Control Modal -->
<div class="modal fade" id="updateSpendControlModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Update Spend Control</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateProjectSpendControl" method="post">
                <input type="hidden" name="projectId" id="spendControlProjectId" />
                <div class="modal-body">
                    <p class="mb-3">Select whether this deliverable is subject to spend control.</p>
                    <div class="form-group">
                        <label for="isSubjectToSpendControl" class="form-label">Subject to Spend Control</label>
                        <select class="form-control" id="isSubjectToSpendControl" name="isSubjectToSpendControl">
                            <option value="">-- Not Set --</option>
                            <option value="true">Yes</option>
                            <option value="false">No</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary">Save Spend Control</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Update Title Modal -->
<div class="modal fade" id="updateTitleModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Change Deliverable Title</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateProjectTitle" method="post">
                <input type="hidden" name="projectId" id="titleProjectId" />
                <div class="modal-body">
                    <p class="mb-3">Enter the new title for this deliverable.</p>
                    <div class="form-group">
                        <label for="projectTitle" class="form-label">Title</label>
                        <input type="text" class="form-control" id="projectTitle" name="title" required maxlength="500" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary">Save Title</button>
                </div>
            </form>
        </div>
