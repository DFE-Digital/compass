<!-- Update RAG Status Modal -->
<div class="modal fade" id="updateRagStatusModal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Update RAG Status</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form asp-action="UpdateProjectRagStatus" method="post">
                <input type="hidden" name="projectId" id="ragStatusProjectId" />
