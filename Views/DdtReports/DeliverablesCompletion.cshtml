</div>

<style>
.sortable {
    cursor: pointer;
    user-select: none;
}

.sortable:hover {
    background-color: #f8f9fa;
}

.badge-lg {
    font-size: 1rem;
    padding: 0.5rem 0.75rem;
}

.completion-icon {
    font-size: 2rem;
    vertical-align: middle;
}

.badge-orange {
    background-color: #fd7e14;
    color: white;
}
</style>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            initializeSortableTable($('#completionTable'));

            $('#searchInput, #completionFilter, #statusFilter, #businessAreaFilter')
                .on('input change', filterTable);

            // Modal handlers
            $(document).on('click', '[data-action="change-title"]', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var projectId = $(this).data('project-id');
                var projectTitle = $(this).data('project-title') || '';
                $('#titleProjectId').val(projectId);
                $('#projectTitle').val(projectTitle);
                $('#updateTitleModal').modal('show');
                return false;
            });

            $(document).on('click', '[data-action="set-rag-status"]', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var projectId = $(this).data('project-id');
                $('#ragStatusProjectId').val(projectId);
                var $row = $(this).closest('tr');
                var currentRag = $row.attr('data-rag-status') || '';
                $('#ragStatus').val(currentRag);
                $('#updateRagStatusModal').modal('show');
                return false;
            });

            $(document).on('click', '[data-action="set-priority"]', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var projectId = $(this).data('project-id');
                $('#priorityProjectId').val(projectId);
                $('#deliveryPriorityId').val('');
                $('#updatePriorityModal').modal('show');
                return false;
            });

            $(document).on('click', '[data-action="set-business-area"]', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var projectId = $(this).data('project-id');
                $('#businessAreaProjectId').val(projectId);
                $('#businessAreaLookupId').val('');
                $('#updateBusinessAreaModal').modal('show');
                return false;
            });

            $(document).on('click', '[data-action="set-primary-contact"]', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var projectId = $(this).data('project-id');
                $('#primaryContactProjectId').val(projectId);
                $('#clearPrimaryContact').val('false');
                var $picker = $('#updatePrimaryContactModal [data-user-picker]');
                $picker.find('.js-user-picker-input').val('');
                $picker.find('.js-user-picker-objectid').val('');
                $picker.find('.js-user-picker-email').val('');
                $picker.find('.js-user-picker-name').val('');
                $picker.find('.js-user-picker-summary').html('<span class="text-muted">No primary contact selected.</span>');
                $('#updatePrimaryContactModal').modal('show');
                setTimeout(function() {
                    $('#primaryContactSearch').focus();
                }, 300);
                return false;
            });

            $('#clearPrimaryContactBtn').on('click', function() {
                $('#clearPrimaryContact').val('true');
                $('#updatePrimaryContactModal form').submit();
            });

            $(document).on('click', '[data-action="set-activity-type"]', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var projectId = $(this).data('project-id');
                $('#activityTypeProjectId').val(projectId);
                $('#activityTypeLookupId').val('');
                $('#updateActivityTypeModal').modal('show');
                return false;
            });

            $(document).on('click', '[data-action="set-spend-control"]', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var projectId = $(this).data('project-id');
                $('#spendControlProjectId').val(projectId);
                var $row = $(this).closest('tr');
                var currentSpendControl = $row.attr('data-spend-control') || '';
                $('#isSubjectToSpendControl').val(currentSpendControl);
                $('#updateSpendControlModal').modal('show');
                return false;
            });

            $(document).on('click', '[data-action="set-sro"]', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var projectId = $(this).data('project-id');
                $('#sroProjectId').val(projectId);
                $('#clearSro').val('false');
                var $picker = $('#updateSroModal [data-user-picker]');
                $picker.find('.js-user-picker-input').val('');
                $picker.find('.js-user-picker-objectid').val('');
                $picker.find('.js-user-picker-email').val('');
                $picker.find('.js-user-picker-name').val('');
                $picker.find('.js-user-picker-summary').html('<span class="text-muted">No SRO selected.</span>');
                $('#updateSroModal').modal('show');
                setTimeout(function() {
                    $('#sroSearch').focus();
                }, 300);
                return false;
            });

            $('#clearSroBtn').on('click', function() {
                $('#clearSro').val('true');
                $('#updateSroModal form').submit();
            });

            $(document).on('click', '[data-action="set-pmo-contact"]', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var projectId = $(this).data('project-id');
                $('#pmoContactProjectId').val(projectId);
                $('#clearPmoContact').val('false');
                var $picker = $('#updatePmoContactModal [data-user-picker]');
                $picker.find('.js-user-picker-input').val('');
                $picker.find('.js-user-picker-objectid').val('');
                $picker.find('.js-user-picker-email').val('');
                $picker.find('.js-user-picker-name').val('');
                $picker.find('.js-user-picker-summary').html('<span class="text-muted">No PMO contact selected.</span>');
                $('#updatePmoContactModal').modal('show');
                setTimeout(function() {
                    $('#pmoContactSearch').focus();
                }, 300);
                return false;
            });

            $('#clearPmoContactBtn').on('click', function() {
                $('#clearPmoContact').val('true');
                $('#updatePmoContactModal form').submit();
            });

            $(document).on('click', '[data-action="set-directorate"]', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var projectId = $(this).data('project-id');
                $('#directorateProjectId').val(projectId);
                $('#directorateLookupId').val('');
                $('#updateDirectorateModal').modal('show');
                return false;
            });

            // Setup AJAX forms
            setupAjaxForm('#updateTitleModal form', handleProjectUpdate);
            setupAjaxForm('#updateSroModal form', handleProjectUpdate);
            setupAjaxForm('#updatePmoContactModal form', handleProjectUpdate);
            setupAjaxForm('#updateDirectorateModal form', handleProjectUpdate);
            setupAjaxForm('#updateRagStatusModal form', handleProjectUpdate);
            setupAjaxForm('#updatePriorityModal form', handleProjectUpdate);
            setupAjaxForm('#updateBusinessAreaModal form', handleProjectUpdate);
            setupAjaxForm('#updatePrimaryContactModal form', handleProjectUpdate);
            setupAjaxForm('#updateActivityTypeModal form', handleProjectUpdate);
            setupAjaxForm('#updateSpendControlModal form', handleProjectUpdate);

            // View details button handler
            $(document).on('click', '.view-details-btn', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var projectId = $(this).data('project-id');
                var $detailContent = $('#detail-content-' + projectId);
                var $icon = $(this).find('i');
                
                $detailContent.collapse('toggle');
                return false;
            });
            
            // Handle Bootstrap collapse events to update chevron
            $(document).on('shown.bs.collapse', '.detail-row .collapse', function() {
                var projectId = $(this).attr('id').replace('detail-content-', '');
                $('.view-details-btn[data-project-id="' + projectId + '"] i')
                    .removeClass('fa-chevron-down').addClass('fa-chevron-up');
            });
            
            $(document).on('hidden.bs.collapse', '.detail-row .collapse', function() {
                var projectId = $(this).attr('id').replace('detail-content-', '');
                $('.view-details-btn[data-project-id="' + projectId + '"] i')
                    .removeClass('fa-chevron-up').addClass('fa-chevron-down');
            });

            filterTable();
            recalculateSummary();

            function setupAjaxForm(selector, onSuccess) {
                var $form = $(selector);
                $form.on('submit', function(e) {
                    e.preventDefault();
                    var formData = new FormData(this);
                    var $submitButton = $form.find('button[type="submit"]');
                    $submitButton.prop('disabled', true);
                    fetch($form.attr('action'), {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        body: formData,
                        credentials: 'same-origin'
                    })
                    .then(function(response) {
                        return response.json();
                    })
                    .then(function(data) {
                        if (data && data.success) {
                            if (typeof onSuccess === 'function') {
                                onSuccess(data);
                            }
                            $form.closest('.modal').modal('hide');
                        } else {
                            showInlineAlert('danger', (data && data.message) || 'Unable to complete the update. Please try again.');
                        }
                    })
                    .catch(function() {
                        showInlineAlert('danger', 'An unexpected error occurred. Please try again.');
                    })
                    .finally(function() {
                        $submitButton.prop('disabled', false);
                    });
                });
            }

            function handleProjectUpdate(response) {
                if (!response) {
                    return;
                }

                if (response.message) {
                    showInlineAlert(response.success ? 'success' : 'danger', response.message);
                }

                if (response.project) {
                    updateRowWithProject(response.project);
                    recalculateSummary();
                    filterTable();
                }
            }

            function showInlineAlert(type, message) {
                var $container = $('#inlineAlertContainer');
                if (!message) {
                    $container.empty();
                    return;
                }

                var alertHtml = '<div class="alert alert-' + type + ' alert-dismissible fade show" role="alert">' +
                    message +
                    '<button type="button" class="close" data-dismiss="alert" aria-label="Close">' +
                    '<span aria-hidden="true">&times;</span>' +
                    '</button>' +
                    '</div>';

                $container.html(alertHtml);
            }

            function updateRowWithProject(project) {
                if (!project || !project.projectId) {
                    return;
                }

                var projectId = project.projectId;
                var $row = $('#completionTable tbody tr').filter(function() {
                    var href = $(this).find('a').attr('href');
                    return href && href.includes('/' + projectId);
                });

                if (!$row.length) {
                    return;
                }

                // Update data attributes and display based on project data
                // This is a simplified version - you may need to expand based on what fields are returned
                if (project.projectTitle !== undefined) {
                    $row.attr('data-project-title', project.projectTitle.toLowerCase());
                    var titleCell = $row.find('td').first();
                    var titleLink = titleCell.find('a');
                    if (titleLink.length) {
                        titleLink.text(project.projectTitle);
                        // Update the summary if it exists
                        var summaryText = titleCell.find('small.text-muted');
                        if (summaryText.length && project.summary) {
                            var truncatedSummary = project.summary.length > 100 ? project.summary.substring(0, 100) + '...' : project.summary;
                            summaryText.text(truncatedSummary);
                        }
                    }
                    // Update the data attribute in the dropdown button
                    $row.find('[data-action="change-title"]').attr('data-project-title', project.projectTitle);
                }

                // Update completion percentage badge (2nd column)
                if (project.completionPercentage !== undefined) {
                    $row.attr('data-completion', project.completionPercentage);
                    var completionBadgeClass = project.completionPercentage >= 100 ? 'success' :
                                               project.completionPercentage >= 75 ? 'warning' :
                                               project.completionPercentage >= 50 ? 'orange' : 'danger';
                    var badgeClass = completionBadgeClass === 'orange' ? 'badge-orange' : 'badge-' + completionBadgeClass;
                    var completionCell = $row.find('td').eq(1); // 2nd column (0-indexed)
                    completionCell.html('<span class="badge ' + badgeClass + '">' + project.completionPercentage.toFixed(1) + '%</span>');
                }

                // Update phase badge (3rd column)
                if (project.phase !== undefined) {
                    $row.attr('data-phase', project.phase || '');
                    var phaseCell = $row.find('td').eq(2); // 3rd column (0-indexed)
                    if (project.phase) {
                        phaseCell.html('<span class="badge badge-info">' + escapeHtml(project.phase) + '</span>');
                    } else {
                        phaseCell.html('<span class="text-muted">-</span>');
                    }
                }

                // Update SRO (4th column)
                if (project.seniorResponsibleOfficerNames !== undefined) {
                    var hasSro = project.seniorResponsibleOfficerNames && project.seniorResponsibleOfficerNames.length > 0;
                    $row.attr('data-has-sro', hasSro ? 'true' : 'false');
                    var sroNames = hasSro ? project.seniorResponsibleOfficerNames.join(', ') : '';
                    $row.attr('data-sro-names', sroNames);
                    var sroHtml = hasSro
                        ? '<i class="fas fa-check-square text-success completion-icon" title="' + escapeHtml(sroNames) + '"></i>'
                        : '<i class="fas fa-times-square text-danger completion-icon" title="SRO missing"></i>';
                    $row.find('td').eq(3).html(sroHtml); // 4th column (0-indexed)
                }

                // Update PMO Contact (5th column)
                if (project.pmoContactNames !== undefined) {
                    var hasPmo = project.pmoContactNames && project.pmoContactNames.length > 0;
                    $row.attr('data-has-pmo', hasPmo ? 'true' : 'false');
                    var pmoNames = hasPmo ? project.pmoContactNames.join(', ') : '';
                    $row.attr('data-pmo-names', pmoNames);
                    var pmoHtml = hasPmo
                        ? '<i class="fas fa-check-square text-success completion-icon" title="' + escapeHtml(pmoNames) + '"></i>'
                        : '<i class="fas fa-times-square text-danger completion-icon" title="PMO Contact missing"></i>';
                    $row.find('td').eq(4).html(pmoHtml); // 5th column (0-indexed)
                }

                // Update Directorate (6th column)
                if (project.directorateNames !== undefined) {
                    var hasDirectorate = project.directorateNames && project.directorateNames.length > 0;
                    $row.attr('data-has-directorate', hasDirectorate ? 'true' : 'false');
                    var directorateNames = hasDirectorate ? project.directorateNames.join(', ') : '';
                    $row.attr('data-directorate-names', directorateNames);
                    var directorateHtml = hasDirectorate
                        ? '<i class="fas fa-check-square text-success completion-icon" title="' + escapeHtml(directorateNames) + '"></i>'
                        : '<i class="fas fa-times-square text-danger completion-icon" title="Directorate missing"></i>';
                    $row.find('td').eq(5).html(directorateHtml); // 6th column (0-indexed)
                }

                if (project.ragStatus !== undefined) {
                    $row.attr('data-rag-status', project.ragStatus || '');
                    $row.attr('data-has-rag', project.ragStatus ? 'true' : 'false');
                    var ragHtml = project.ragStatus 
                        ? '<span class="badge badge-' + getRagBadgeClass(project.ragStatus) + '">' + project.ragStatus + '</span>'
                        : '<i class="fas fa-times-square text-danger completion-icon" title="RAG Status missing"></i>';
                    $row.find('td').eq(7).html(ragHtml); // Updated column index
                }

                if (project.priorityName !== undefined) {
                    $row.attr('data-priority-name', project.priorityName || '');
                    $row.attr('data-has-priority', project.priorityName ? 'true' : 'false');
                    var priorityHtml = project.priorityName
                        ? '<span class="badge badge-info">' + project.priorityName + '</span>'
                        : '<i class="fas fa-times-square text-danger completion-icon" title="Priority missing"></i>';
                    $row.find('td').eq(8).html(priorityHtml); // Updated column index
                }

                if (project.businessArea !== undefined) {
                    $row.attr('data-business-area', project.businessArea || '');
                    $row.attr('data-has-business-area', project.businessArea ? 'true' : 'false');
                    var businessAreaHtml = project.businessArea
                        ? '<i class="fas fa-check-square text-success completion-icon" title="' + escapeHtml(project.businessArea) + '"></i>'
                        : '<i class="fas fa-times-square text-danger completion-icon" title="Business Area missing"></i>';
                    $row.find('td').eq(9).html(businessAreaHtml); // Updated column index
                }

                if (project.primaryContactName !== undefined) {
                    $row.attr('data-primary-contact-name', project.primaryContactName || '');
                    $row.attr('data-has-primary-contact', project.primaryContactName ? 'true' : 'false');
                    var primaryContactHtml = project.primaryContactName
                        ? '<i class="fas fa-check-square text-success completion-icon" title="' + escapeHtml(project.primaryContactName) + '"></i>'
                        : '<i class="fas fa-times-square text-danger completion-icon" title="Primary Contact missing"></i>';
                    $row.find('td').eq(10).html(primaryContactHtml); // Updated column index
                }

                if (project.activityTypeName !== undefined) {
                    $row.attr('data-activity-type-name', project.activityTypeName || '');
                    $row.attr('data-has-activity-type', project.activityTypeName ? 'true' : 'false');
                    var activityTypeHtml = project.activityTypeName
                        ? '<i class="fas fa-check-square text-success completion-icon" title="' + escapeHtml(project.activityTypeName) + '"></i>'
                        : '<i class="fas fa-times-square text-danger completion-icon" title="Activity Type missing"></i>';
                    $row.find('td').eq(11).html(activityTypeHtml); // Updated column index
                }

                if (project.isSubjectToSpendControl !== undefined) {
                    var spendControlValue = project.isSubjectToSpendControl === true ? 'true' : project.isSubjectToSpendControl === false ? 'false' : '';
                    $row.attr('data-spend-control', spendControlValue);
                    $row.attr('data-has-spend-control', spendControlValue !== '' ? 'true' : 'false');
                    var spendControlHtml = spendControlValue !== ''
                        ? '<span class="badge badge-' + (spendControlValue === 'true' ? 'warning' : 'secondary') + '">' + (spendControlValue === 'true' ? 'Yes' : 'No') + '</span>'
                        : '<i class="fas fa-times-square text-danger completion-icon" title="Spend Control missing"></i>';
                    $row.find('td').eq(12).html(spendControlHtml); // Updated column index
                }

                // Recalculate completion percentage
                var completedFields = 0;
                if ($row.attr('data-has-sro') === 'true') completedFields++;
                if ($row.attr('data-has-pmo') === 'true') completedFields++;
                if ($row.attr('data-has-directorate') === 'true') completedFields++;
                if ($row.attr('data-has-budget-owner') === 'true') completedFields++;
                if ($row.attr('data-has-rag') === 'true') completedFields++;
                if ($row.attr('data-has-priority') === 'true') completedFields++;
                if ($row.attr('data-has-business-area') === 'true') completedFields++;
                if ($row.attr('data-has-primary-contact') === 'true') completedFields++;
                if ($row.attr('data-has-activity-type') === 'true') completedFields++;
                if ($row.attr('data-has-spend-control') === 'true') completedFields++;

                var completionPercentage = (completedFields / 10.0) * 100;
                $row.attr('data-completion', completionPercentage);
                // Update completion badge in 2nd column
                var completionBadgeClass = completionPercentage >= 100 ? 'success' :
                                          completionPercentage >= 75 ? 'warning' :
                                          completionPercentage >= 50 ? 'orange' : 'danger';
                var badgeClass = completionBadgeClass === 'orange' ? 'badge-orange' : 'badge-' + completionBadgeClass;
                $row.find('td').eq(1).html('<span class="badge ' + badgeClass + '">' + completionPercentage.toFixed(1) + '%</span>');
            }

            function getRagBadgeClass(ragStatus) {
                if (ragStatus === 'Green') return 'success';
                if (ragStatus === 'Amber-Green' || ragStatus === 'Amber' || ragStatus === 'Amber-Red') return 'warning';
                if (ragStatus === 'Red') return 'danger';
                return 'secondary';
            }

            function escapeHtml(text) {
                return $('<div>').text(text || '').html();
            }

            function filterTable() {
                var searchTerm = ($('#searchInput').val() || '').toString().toLowerCase();
                var completionFilter = ($('#completionFilter').val() || '').toString();
                var statusFilter = ($('#statusFilter').val() || '').toString();
                var businessAreaFilter = ($('#businessAreaFilter').val() || '').toString();

                var visibleCount = 0;

                $('#completionTable tbody tr').each(function() {
                    var $row = $(this);
                    var projectTitle = ($row.attr('data-project-title') || '').toString();
                    var projectCode = ($row.attr('data-project-code') || '').toString();
                    var completion = parseFloat($row.attr('data-completion')) || 0;
                    var businessArea = ($row.attr('data-business-area') || '').toString();

                    var matchesSearch = !searchTerm || projectTitle.includes(searchTerm) || projectCode.includes(searchTerm);
                    var matchesBusinessArea = !businessAreaFilter || businessArea === businessAreaFilter;

                    var matchesCompletion = true;
                    if (completionFilter) {
                        if (completionFilter === '100') {
                            matchesCompletion = completion === 100;
                        } else if (completionFilter === '80-99') {
                            matchesCompletion = completion >= 80 && completion < 100;
                        } else if (completionFilter === '60-79') {
                            matchesCompletion = completion >= 60 && completion < 80;
                        } else if (completionFilter === '40-59') {
                            matchesCompletion = completion >= 40 && completion < 60;
                        } else if (completionFilter === '0-39') {
                            matchesCompletion = completion >= 0 && completion < 40;
                        }
                    }

                    var matchesStatus = true;
                    if (statusFilter === 'complete') {
                        matchesStatus = completion === 100;
                    } else if (statusFilter === 'incomplete') {
                        matchesStatus = completion < 100;
                    }

                    if (matchesSearch && matchesCompletion && matchesStatus && matchesBusinessArea) {
                        $row.show();
                        visibleCount++;
                    } else {
                        $row.hide();
                    }
                });

                $('#projectCount').text(visibleCount + ' ' + formatDeliverableLabel(visibleCount));
            }

            function formatDeliverableLabel(count) {
                return 'deliverable' + (count === 1 ? '' : 's');
            }

            function recalculateSummary() {
                var $rows = $('#completionTable tbody tr');
                var total = $rows.length;
                var completionSum = 0;
                var zeroCount = 0;
                var fullCount = 0;
                var businessAreaMap = {};

                var fieldCounts = {
                    sro: 0,
                    pmo: 0,
                    directorate: 0,
                    budgetOwner: 0,
                    rag: 0,
                    priority: 0,
                    businessArea: 0,
                    primaryContact: 0,
                    activityType: 0,
                    spendControl: 0
                };

                $rows.each(function() {
                    var $row = $(this);
                    var completion = parseFloat($row.attr('data-completion')) || 0;
                    completionSum += completion;
                    if (Math.abs(completion) < 0.0001) zeroCount++;
                    if (Math.abs(completion - 100) < 0.0001) fullCount++;

                    if ($row.attr('data-has-sro') === 'true') fieldCounts.sro++;
                    if ($row.attr('data-has-pmo') === 'true') fieldCounts.pmo++;
                    if ($row.attr('data-has-directorate') === 'true') fieldCounts.directorate++;
                    if ($row.attr('data-has-budget-owner') === 'true') fieldCounts.budgetOwner++;
                    if ($row.attr('data-has-rag') === 'true') fieldCounts.rag++;
                    if ($row.attr('data-has-priority') === 'true') fieldCounts.priority++;
                    if ($row.attr('data-has-business-area') === 'true') fieldCounts.businessArea++;
                    if ($row.attr('data-has-primary-contact') === 'true') fieldCounts.primaryContact++;
                    if ($row.attr('data-has-activity-type') === 'true') fieldCounts.activityType++;
                    if ($row.attr('data-has-spend-control') === 'true') fieldCounts.spendControl++;

                    var areaName = ($row.attr('data-business-area') || 'Unassigned').toString();
                    if (!businessAreaMap[areaName]) {
                        businessAreaMap[areaName] = { count: 0, sum: 0 };
                    }
                    businessAreaMap[areaName].count++;
                    businessAreaMap[areaName].sum += completion;
                });

                var average = total ? completionSum / total : 0;
                updateAverageCard(total, average);
                updateFullCard(total, fullCount);
                updateFieldCards(total, fieldCounts);
                rebuildBusinessAreaTable(businessAreaMap);
            }

            function updateAverageCard(total, average) {
                var cardClass = getCompletionBracket(average);
                $('#averageCompletionCard').removeClass('card-success card-warning card-danger').addClass('card-' + cardClass);
                $('#averageCompletionValue').text(average.toFixed(1) + '%');
                $('#averageCompletionSubtitle').text('Based on ' + total + ' ' + formatDeliverableLabel(total));
                $('#averageCompletionProgress').removeClass('bg-success bg-warning bg-danger').addClass('bg-' + cardClass).css('width', average + '%');
            }


            function updateFullCard(total, fullCount) {
                var fullPercentage = total ? (fullCount / total) * 100 : 0;
                var cardClass = (fullCount === total && total > 0) ? 'card-success' : 'card-info';
                var fullColorClass = fullPercentage >= 80 ? 'success' : fullPercentage >= 50 ? 'warning' : 'info';
                var text = fullCount === 0
                    ? 'No deliverables fully complete yet'
                    : fullCount === 1
                        ? 'deliverable is fully complete'
                        : 'deliverables are fully complete';

                $('#fullCompletionCard').removeClass('card-success card-info').addClass(cardClass);
                $('#fullCompletionValue').text(fullCount);
                $('#fullCompletionText').text(text + ' (' + fullPercentage.toFixed(1) + '%)');
                $('#fullCompletionProgress').removeClass('bg-success bg-warning bg-info').addClass('bg-' + fullColorClass).css('width', fullPercentage + '%');
            }

            function updateFieldCards(total, fieldCounts) {
                updateFieldCard('#completedSroCard', '#completedSroValue', '#completedSroText', '#completedSroProgress', fieldCounts.sro, total);
                updateFieldCard('#completedPmoCard', '#completedPmoValue', '#completedPmoText', '#completedPmoProgress', fieldCounts.pmo, total);
                updateFieldCard('#completedDirectorateCard', '#completedDirectorateValue', '#completedDirectorateText', '#completedDirectorateProgress', fieldCounts.directorate, total);
                updateFieldCard('#completedBudgetOwnerCard', '#completedBudgetOwnerValue', '#completedBudgetOwnerText', '#completedBudgetOwnerProgress', fieldCounts.budgetOwner, total);
                updateFieldCard('#completedRagCard', '#completedRagValue', '#completedRagText', '#completedRagProgress', fieldCounts.rag, total);
                updateFieldCard('#completedPriorityCard', '#completedPriorityValue', '#completedPriorityText', '#completedPriorityProgress', fieldCounts.priority, total);
                updateFieldCard('#completedBusinessAreaCard', '#completedBusinessAreaValue', '#completedBusinessAreaText', '#completedBusinessAreaProgress', fieldCounts.businessArea, total);
                updateFieldCard('#completedPrimaryContactCard', '#completedPrimaryContactValue', '#completedPrimaryContactText', '#completedPrimaryContactProgress', fieldCounts.primaryContact, total);
                updateFieldCard('#completedActivityTypeCard', '#completedActivityTypeValue', '#completedActivityTypeText', '#completedActivityTypeProgress', fieldCounts.activityType, total);
                updateFieldCard('#completedSpendControlCard', '#completedSpendControlValue', '#completedSpendControlText', '#completedSpendControlProgress', fieldCounts.spendControl, total);
            }

            function updateFieldCard(cardSelector, valueSelector, textSelector, progressSelector, completedCount, total) {
                var percentage = total ? (completedCount / total) * 100 : 0;
                var cardClass = getCompletionBracket(percentage);
                $(cardSelector).removeClass('card-success card-warning card-danger').addClass('card-' + cardClass);
                $(valueSelector).text(completedCount);
                $(textSelector).text('of ' + total + ' (' + percentage.toFixed(1) + '%)');
                $(progressSelector).removeClass('bg-success bg-warning bg-danger').addClass('bg-' + cardClass).css('width', percentage + '%');
            }

            function rebuildBusinessAreaTable(businessAreaMap) {
                var $tbody = $('#businessAreaTableBody');
                $tbody.empty();

                var areas = Object.keys(businessAreaMap).map(function(name) {
                    var entry = businessAreaMap[name];
                    var average = entry.count ? entry.sum / entry.count : 0;
                    return {
                        name: name,
                        count: entry.count,
                        average: average
                    };
                }).sort(function(a, b) {
                    return b.average - a.average;
                });

                areas.forEach(function(area) {
                    var completionClass = getCompletionBracket(area.average);
                    var $tr = $('<tr>');
                    $tr.append($('<td>').html('<strong>' + escapeHtml(area.name) + '</strong>'));
                    $tr.append($('<td class="text-center">').html('<span class="badge badge-info">' + area.count + '</span>'));
                    $tr.append($('<td class="text-center">').html('<span class="badge badge-' + completionClass + ' badge-lg">' + area.average.toFixed(1) + '%</span>'));
                    var $progressCell = $('<td>');
                    var $progress = $('<div class="progress progress-sm">');
                    var $bar = $('<div class="progress-bar">').addClass('bg-' + completionClass).css('width', area.average + '%');
                    $progress.append($bar);
                    $progressCell.append($progress);
                    $tr.append($progressCell);
                    $tbody.append($tr);
                });
            }

            function getCompletionBracket(value) {
                if (value >= 80) return 'success';
                if (value >= 60) return 'warning';
                return 'danger';
            }

            function initializeSortableTable(table) {
                var currentSort = { column: null, direction: 'asc' };
                
                table.find('.sortable').on('click keypress', function(e) {
                    if (e.type === 'keypress' && e.which !== 13 && e.which !== 32) {
                        return;
                    }
                    
                    var column = $(this).data('column');
                    var direction = 'asc';
                    
                    if (currentSort.column === column && currentSort.direction === 'asc') {
                        direction = 'desc';
                    }
                    
                    sortTable(table, column, direction);
                    currentSort = { column: column, direction: direction };
                });
                
                function sortTable(table, column, direction) {
                    var tbody = table.find('tbody');
                    var rows = tbody.find('tr:visible').toArray();
                    
                    rows.sort(function(a, b) {
                        var aVal, bVal;
                        var colIndex = table.find('thead th[data-column="' + column + '"]').index();
                        
                        if (column === 'ProjectTitle') {
                            aVal = $(a).find('td').eq(0).find('a').text().trim().toLowerCase();
                            bVal = $(b).find('td').eq(0).find('a').text().trim().toLowerCase();
                        } else if (column === 'CompletionPercentage') {
                            aVal = parseFloat($(a).attr('data-completion')) || 0;
                            bVal = parseFloat($(b).attr('data-completion')) || 0;
                        } else {
                            // For boolean/icon columns, check data attributes
                            var dataAttr = 'data-has-' + column.toLowerCase().replace(/\s+/g, '-');
                            aVal = $(a).attr(dataAttr) === 'true' ? 1 : 0;
                            bVal = $(b).attr(dataAttr) === 'true' ? 1 : 0;
                        }
                        
                        if (typeof aVal === 'string') {
                            if (direction === 'asc') {
                                return aVal.localeCompare(bVal);
                            } else {
                                return bVal.localeCompare(aVal);
                            }
                        } else {
                            if (direction === 'asc') {
                                return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                            } else {
                                return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                            }
                        }
                    });
                    
                    var hiddenRows = tbody.find('tr:hidden').detach();
                    tbody.empty();
                    rows.forEach(function(row) {
                        tbody.append(row);
                    });
                    tbody.append(hiddenRows);
                    
                    updateSortIcons(table, column, direction);
                }
                
                function updateSortIcons(table, column, direction) {
                    table.find('.sortable i').remove();
                    var header = table.find('.sortable[data-column="' + column + '"]');
                    var iconClass = direction === 'asc' ? 'fa-sort-up' : 'fa-sort-down';
                    header.append(' <i class="fas ' + iconClass + '"></i>');
                }
            }
        });
    </script>
    <script src="~/js/user-picker.js" asp-append-version="true"></script>
}

