                                                    </a>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                    <!-- Expandable Details Row -->
                                    <tr class="detail-row" id="detail-row-@project.ProjectId">
                                        <td colspan="14" class="bg-light p-0">
                                            <div class="collapse p-3" id="detail-content-@project.ProjectId">
                                                <div class="row">
                                                    <div class="col-md-6">
                                                        <h6 class="font-weight-bold mb-3">Deliverable Information</h6>
                                                        <table class="table table-sm table-borderless mb-0">
                                                            <tr>
                                                                <td class="font-weight-bold" style="width: 150px;">Title:</td>
                                                                <td>@project.ProjectTitle</td>
                                                            </tr>
                                                            <tr>
                                                                <td class="font-weight-bold">Phase:</td>
                                                                <td>@(project.Phase ?? "Not set")</td>
                                                            </tr>
                                                            <tr>
                                                                <td class="font-weight-bold">Business Area:</td>
                                                                <td>@(project.BusinessArea ?? "Not set")</td>
                                                            </tr>
                                                            <tr>
                                                                <td class="font-weight-bold">Completion:</td>
                                                                <td>
                                                                    @{
                                                                        var detailCompletionBadgeClass = project.CompletionPercentage >= 100 ? "success" :
                                                                                                         project.CompletionPercentage >= 75 ? "warning" :
                                                                                                         project.CompletionPercentage >= 50 ? "orange" : "danger";
                                                                    }
                                                                    <span class="badge @(detailCompletionBadgeClass == "orange" ? "badge-orange" : $"badge-{detailCompletionBadgeClass}")">@project.CompletionPercentage.ToString("F1")%</span>
                                                                </td>
                                                            </tr>
                                                        </table>
                                                    </div>
                                                    <div class="col-md-6">
                                                        <h6 class="font-weight-bold mb-3">Field Details</h6>
                                                        <table class="table table-sm table-borderless mb-0">
                                                            <tr>
                                                                <td class="font-weight-bold" style="width: 150px;">SRO:</td>
                                                                <td>@(project.HasSro ? string.Join(", ", project.SeniorResponsibleOfficerNames) : "Not set")</td>
                                                            </tr>
                                                            <tr>
                                                                <td class="font-weight-bold">PMO Contact:</td>
                                                                <td>@(project.HasPmoContact ? string.Join(", ", project.PmoContactNames) : "Not set")</td>
                                                            </tr>
                                                            <tr>
                                                                <td class="font-weight-bold">Directorate:</td>
                                                                <td>@(project.HasDirectorate ? string.Join(", ", project.DirectorateNames) : "Not set")</td>
                                                            </tr>
                                                            <tr>
                                                                <td class="font-weight-bold">Budget Owner:</td>
                                                                <td>@(project.HasBudgetOwner ? string.Join(", ", project.BudgetOwnerNames) : "Not set")</td>
                                                            </tr>
                                                            <tr>
                                                                <td class="font-weight-bold">RAG Status:</td>
                                                                <td>@(project.HasRagStatus ? project.RagStatus : "Not set")</td>
                                                            </tr>
                                                            <tr>
                                                                <td class="font-weight-bold">Priority:</td>
                                                                <td>@(project.HasPriority ? project.PriorityName : "Not set")</td>
                                                            </tr>
                                                            <tr>
                                                                <td class="font-weight-bold">Primary Contact:</td>
                                                                <td>@(project.HasPrimaryContact ? project.PrimaryContactName : "Not set")</td>
                                                            </tr>
                                                            <tr>
                                                                <td class="font-weight-bold">Activity Type:</td>
                                                                <td>@(project.HasActivityType ? project.ActivityTypeName : "Not set")</td>
                                                            </tr>
                                                            <tr>
                                                                <td class="font-weight-bold">Spend Control:</td>
                                                                <td>@(project.HasSpendControl ? (project.IsSubjectToSpendControl == true ? "Yes" : "No") : "Not set")</td>
                                                            </tr>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if (!Model.Projects.Any())
                        {
                            <div class="text-center text-muted p-5">
                                <i class="fas fa-info-circle fa-3x mb-3"></i>
                                <p class="mb-0">No deliverables found</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@{
    var deliveryPriorities = ViewBag.DeliveryPriorities as List<Compass.Models.DeliveryPriority> ?? new List<Compass.Models.DeliveryPriority>();
    var businessAreaLookups = ViewBag.BusinessAreaLookups as List<Compass.Models.BusinessAreaLookup> ?? new List<Compass.Models.BusinessAreaLookup>();
    var activityTypeLookups = ViewBag.ActivityTypeLookups as List<Compass.Models.ActivityTypeLookup> ?? new List<Compass.Models.ActivityTypeLookup>();
