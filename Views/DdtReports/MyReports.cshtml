@{
    ViewData["Title"] = "My Reports - DDT Reports";
    
    var myProjects = ViewBag.MyProjects as List<Compass.Models.Project> ?? new List<Compass.Models.Project>();
    var myProducts = ViewBag.MyProducts as List<Compass.Models.ProductDto> ?? new List<Compass.Models.ProductDto>();
    var currentUser = ViewBag.CurrentUser as Compass.Models.User;
    
    var allActiveMilestones = ViewBag.AllActiveMilestones as List<Compass.Models.Milestone> ?? new List<Compass.Models.Milestone>();
    var overdueMilestones = ViewBag.OverdueMilestones as List<Compass.Models.Milestone> ?? new List<Compass.Models.Milestone>();
    
    var allActiveIssues = ViewBag.AllActiveIssues as List<Compass.Models.Issue> ?? new List<Compass.Models.Issue>();
    var highPriorityIssues = ViewBag.HighPriorityIssues as List<Compass.Models.Issue> ?? new List<Compass.Models.Issue>();
    
    var redProjects = ViewBag.RedProjects as List<Compass.Models.Project> ?? new List<Compass.Models.Project>();
    var amberRedProjects = ViewBag.AmberRedProjects as List<Compass.Models.Project> ?? new List<Compass.Models.Project>();
    var amberProjects = ViewBag.AmberProjects as List<Compass.Models.Project> ?? new List<Compass.Models.Project>();
    var greenProjects = ViewBag.GreenProjects as List<Compass.Models.Project> ?? new List<Compass.Models.Project>();
    
    var productsNeedingReturns = ViewBag.ProductsNeedingReturns as List<(Compass.Models.ProductDto Product, Compass.Models.ReturnStatus Status, System.DateTime DueDate)> ?? new List<(Compass.Models.ProductDto, Compass.Models.ReturnStatus, System.DateTime)>();
    
    // Calculate delivery metrics
    var totalProjects = myProjects.Count;
    var atRiskProjects = redProjects.Concat(amberRedProjects).ToList();
    var atRiskCount = atRiskProjects.Count;
    var overdueMilestoneCount = overdueMilestones.Count;
    var highPriorityIssueCount = highPriorityIssues.Count;
    
    // Calculate products and services metrics
    var totalProducts = myProducts.Count;
    var productsWithReturnsDue = productsNeedingReturns.Count;
    var productsNeedingAttention = productsNeedingReturns.Where(p => p.Status == Compass.Models.ReturnStatus.Late).Count();
    
    // Extract first name from full name
    var firstName = "User";
    if (currentUser?.Name != null)
    {
        var nameParts = currentUser.Name.Split(' ');
        firstName = nameParts.Length > 0 ? nameParts[0] : currentUser.Name;
    }
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">DDT Reports</a></li>
                    <li class="breadcrumb-item active" aria-current="page">My Reports</li>
                </ol>
                <h1 class="m-0">My Reports</h1>
                <p class="text-muted mb-0">@DateTime.Now.ToString("dd MMMM yyyy")</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <!-- Delivery Summary -->
        <div class="row mb-4">
            <div class="col-lg-3 col-md-6 mb-3">
                <div class="small-box bg-info h-100">
                    <div class="inner">
                        <h3>@totalProjects</h3>
                        <p>Total projects</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-3">
                @{
                    var atRiskBg = atRiskCount == 0 ? "success" : 
                                  atRiskCount <= 2 ? "warning" : "danger";
                }
                <div class="small-box bg-@atRiskBg h-100">
                    <div class="inner">
                        <h3>@atRiskCount</h3>
                        <p>At risk projects</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-3">
                @{
                    var overdueBg = overdueMilestoneCount == 0 ? "success" : 
                                   overdueMilestoneCount <= 3 ? "warning" : "danger";
                }
                <div class="small-box bg-@overdueBg h-100">
                    <div class="inner">
                        <h3>@overdueMilestoneCount</h3>
                        <p>Overdue milestones</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-3">
                @{
                    var issuesBg = highPriorityIssueCount == 0 ? "success" : 
                                  highPriorityIssueCount <= 5 ? "warning" : "danger";
                }
                <div class="small-box bg-@issuesBg h-100">
                    <div class="inner">
                        <h3>@highPriorityIssueCount</h3>
                        <p>High priority issues</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Products Summary -->
        <div class="row mb-4">
            <div class="col-lg-3 col-md-6 mb-3">
                <div class="small-box bg-primary h-100">
                    <div class="inner">
                        <h3>@totalProducts</h3>
                        <p>Total products</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-3">
                @{
                    var returnsDueBg = productsWithReturnsDue == 0 ? "success" : 
                                      productsWithReturnsDue <= 3 ? "warning" : "danger";
                }
                <div class="small-box bg-@returnsDueBg h-100">
                    <div class="inner">
                        <h3>@productsWithReturnsDue</h3>
                        <p>Returns due</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-3">
                @{
                    var lateBg = productsNeedingAttention == 0 ? "success" : "danger";
                }
                <div class="small-box bg-@lateBg h-100">
                    <div class="inner">
                        <h3>@productsNeedingAttention</h3>
                        <p>Returns late</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-3">
                <div class="small-box bg-success h-100">
                    <div class="inner">
                        <h3>@(totalProducts - productsWithReturnsDue)</h3>
                        <p>Up to date</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Products Needing Returns -->
        @if (productsNeedingReturns.Any())
        {
            <div class="card mb-4">
                <div class="card-header bg-danger text-white">
                    <h3 class="card-title">Products requiring returns</h3>
                </div>
                <div class="card-body table-responsive p-0">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Status</th>
                                <th>Due date</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var (product, status, dueDate) in productsNeedingReturns.OrderBy(p => p.Status == Compass.Models.ReturnStatus.Late ? 0 : 1))
                            {
                                <tr>
                                    <td>
                                        <strong>@product.Title</strong><br>
                                        <small class="text-muted">@product.FipsId</small>
                                    </td>
                                    <td>
                                        @if (status == Compass.Models.ReturnStatus.Late)
                                        {
                                            <span class="badge badge-danger">Late</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning">Due</span>
                                        }
                                    </td>
                                    <td>@dueDate.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <a href="@Url.Action("PerformanceMetrics", "ProductReporting", new { fipsId = product.FipsId })" class="btn btn-primary btn-sm">
                                            Submit return
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <!-- At Risk Projects -->
        @if (atRiskProjects.Any())
        {
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h3 class="card-title">Projects requiring attention</h3>
                </div>
                <div class="card-body table-responsive p-0">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Project</th>
                                <th>RAG</th>
                                <th>Justification</th>
                                <th>Path to green</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var project in atRiskProjects.OrderBy(p => p.RagStatus == "Red" ? 0 : 1).ThenBy(p => p.Title))
                            {
                                <tr>
                                    <td>
                                        <a href="@Url.Action("Details", "Project", new { id = project.Id })">
                                            <strong>@project.Title</strong>
                                        </a><br>
                                        <small class="text-muted">@project.ProjectCode</small>
                                    </td>
                                    <td>
                                        <span class="@GetRagBadgeClass(project.RagStatus)">@project.RagStatus</span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(project.RagJustification))
                                        {
                                            @project.RagJustification.Substring(0, Math.Min(150, project.RagJustification.Length))@(project.RagJustification.Length > 150 ? "..." : "")
                                        }
                                        else
                                        {
                                            <span class="text-muted">No justification provided</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(project.PathToGreen))
                                        {
                                            @project.PathToGreen.Substring(0, Math.Min(100, project.PathToGreen.Length))@(project.PathToGreen.Length > 100 ? "..." : "")
                                        }
                                        else
                                        {
                                            <span class="text-warning">
                                                <i class="fas fa-exclamation-circle mr-1"></i>
                                                Not documented
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</section>

<style>
.small-box {
    border-radius: .25rem;
    box-shadow: 0 0 1px rgba(0,0,0,.125), 0 1px 3px rgba(0,0,0,.2);
    display: block;
    margin-bottom: 0;
    position: relative;
    min-height: 100px;
}

.small-box > .inner {
    padding: 15px;
}

.small-box h3 {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0 0 5px;
    padding: 0;
    color: #fff;
}

.small-box p {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 0;
}

@@media (max-width: 767px) {
    .small-box h3 {
        font-size: 2rem;
    }
    
    .small-box > .inner {
        padding: 10px;
    }
}
</style>

@functions {
    string GetRagBadgeClass(string ragStatus)
    {
        return ragStatus switch
        {
            "Green" => "badge badge-green",
            "Amber-Green" => "badge badge-amber-green",
            "Amber" => "badge badge-amber",
            "Amber-Red" => "badge badge-amber-red",
            "Red" => "badge badge-red",
            _ => "badge badge-secondary"
        };
    }
}
