@{
    ViewData["Title"] = "DDT Reports Overview";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item active">DDT Reports</li>
                </ol>
                <h1 class="m-0"><i class="fas fa-chart-line mr-2"></i> DDT Reports Overview</h1>
                <p class="text-muted">Access all available reports and dashboards for project delivery and operational metrics</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <!-- Personal Reports Section -->
        <div class="row mb-3">
            <div class="col-12">
                <h3 class="mb-3"><i class="fas fa-user-circle mr-2 text-success"></i> Personal Reports</h3>
            </div>
        </div>

        <div class="row mb-4">
            <!-- My Reports -->
            <div class="col-md-6">
                <div class="card border-success mb-3 h-100">
                    <div class="card-header bg-success text-white">
                        <h4 class="card-title mb-0"><i class="fas fa-user-circle mr-2"></i> My Reports</h4>
                    </div>
                    <div class="card-body">
                        <p class="card-text">Your personalized dashboard showing projects, products, milestones, and issues assigned to you.</p>
                        <ul class="list-unstyled mb-3">
                            <li><i class="fas fa-check text-success mr-2"></i> Your tasks and overdue items</li>
                            <li><i class="fas fa-check text-success mr-2"></i> Projects and products you're involved in</li>
                            <li><i class="fas fa-check text-success mr-2"></i> High priority issues requiring attention</li>
                            <li><i class="fas fa-check text-success mr-2"></i> Milestones due this week</li>
                        </ul>
                        <a asp-action="MyReports" class="btn btn-success btn-block">
                            <i class="fas fa-arrow-right mr-2"></i> View My Reports
                        </a>
                    </div>
                </div>
            </div>

            <!-- Placeholder for future personal reports -->
            <div class="col-md-6">
                <div class="card border-secondary mb-3 h-100">
                    <div class="card-header bg-secondary text-white">
                        <h4 class="card-title mb-0"><i class="fas fa-clock mr-2"></i> More Reports Coming Soon</h4>
                    </div>
                    <div class="card-body">
                        <p class="card-text text-muted">Additional personal reporting capabilities will be added here.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Organization Reports Section -->
        <div class="row mb-3">
            <div class="col-12">
                <h3 class="mb-3"><i class="fas fa-building mr-2 text-primary"></i> Organization Reports</h3>
            </div>
        </div>

        <div class="row mb-4">
            <!-- DDT Dashboard -->
            <div class="col-md-6">
                <div class="card border-primary mb-3 h-100">
                    <div class="card-header bg-primary text-white">
                        <h4 class="card-title mb-0"><i class="fas fa-chart-bar mr-2"></i> DDT Dashboard</h4>
                    </div>
                    <div class="card-body">
                        <p class="card-text">Organization-wide snapshot of all projects, products, and health metrics across DDT.</p>
                        <ul class="list-unstyled mb-3">
                            <li><i class="fas fa-check text-primary mr-2"></i> All active projects and RAG status</li>
                            <li><i class="fas fa-check text-primary mr-2"></i> High priority issues organization-wide</li>
                            <li><i class="fas fa-check text-primary mr-2"></i> Milestone and issue summaries</li>
                            <li><i class="fas fa-check text-primary mr-2"></i> Products overview</li>
                        </ul>
                        <a asp-action="ViewReport" class="btn btn-primary btn-block">
                            <i class="fas fa-arrow-right mr-2"></i> View DDT Dashboard
                        </a>
                    </div>
                </div>
            </div>

            <!-- Accessibility Report -->
            <div class="col-md-6">
                <div class="card border-info mb-3 h-100">
                    <div class="card-header bg-info text-white">
                        <h4 class="card-title mb-0"><i class="fas fa-universal-access mr-2"></i> Accessibility Report</h4>
                    </div>
                    <div class="card-body">
                        <p class="card-text">Comprehensive overview of product accessibility enrollment and WCAG compliance.</p>
                        <ul class="list-unstyled mb-3">
                            <li><i class="fas fa-check text-info mr-2"></i> Product enrollment coverage</li>
                            <li><i class="fas fa-check text-info mr-2"></i> Issues by WCAG level (A, AA, AAA)</li>
                            <li><i class="fas fa-check text-info mr-2"></i> Top products with most issues</li>
                            <li><i class="fas fa-check text-info mr-2"></i> Overdue and won't fix issues</li>
                        </ul>
                        <a asp-action="AccessibilityReport" class="btn btn-info btn-block">
                            <i class="fas fa-arrow-right mr-2"></i> View Accessibility Report
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Business Area Reports Section -->
        <div class="row mb-3">
            <div class="col-12">
                <h3 class="mb-3"><i class="fas fa-sitemap mr-2 text-warning"></i> Business Area Reports</h3>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-12">
                <div class="card border-warning mb-3">
                    <div class="card-header bg-warning">
                        <h4 class="card-title mb-0"><i class="fas fa-flag mr-2"></i> Flagship Projects</h4>
                    </div>
                    <div class="card-body">
                        <p class="card-text">Detailed view of flagship projects and their associated deliverables.</p>
                        <a asp-action="FlagshipProjects" class="btn btn-warning">
                            <i class="fas fa-arrow-right mr-2"></i> View Flagship Projects
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Additional Reports Section -->
        <div class="row mb-3">
            <div class="col-12">
                <h3 class="mb-3"><i class="fas fa-plus-circle mr-2 text-secondary"></i> Additional Reports</h3>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="card border-secondary mb-3">
                    <div class="card-header bg-secondary text-white">
                        <h4 class="card-title mb-0"><i class="fas fa-lightbulb mr-2"></i> More Reports Coming Soon</h4>
                    </div>
                    <div class="card-body">
                        <p class="card-text mb-0">Additional reporting capabilities will be added based on organizational needs.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

