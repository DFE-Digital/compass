@{
    ViewData["Title"] = "DDT Reports Overview";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                    <li class="breadcrumb-item active" aria-current="page">DDT Reports</li>
                </ol>
                <h1 class="m-0">DDT Reports Overview</h1>
                <p class="text-muted mb-0">Access all available reports and dashboards for project delivery and operational metrics</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <!-- Personal Reports Section -->
        <div class="row mb-4">
            <div class="col-12">
                <h3 class="mb-3">Personal Reports</h3>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-user text-primary mr-2"></i>
                            My Reports
                        </h5>
                        <p class="card-text text-muted">Your personalized dashboard showing projects, products, milestones, and issues assigned to you.</p>
                        <a asp-action="MyReports" class="btn btn-primary btn-sm">View My Reports</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Organization Reports Section -->
        <div class="row mt-5 mb-4">
            <div class="col-12">
                <h3 class="mb-3">Organization Reports</h3>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-tachometer-alt text-primary mr-2"></i>
                            DDT Dashboard
                        </h5>
                        <p class="card-text text-muted">Organization-wide snapshot of all projects, products, and health metrics across DDT.</p>
                        <a asp-action="ViewReport" class="btn btn-primary btn-sm">View DDT Dashboard</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-universal-access text-primary mr-2"></i>
                            Accessibility Report
                        </h5>
                        <p class="card-text text-muted">Comprehensive overview of product accessibility enrollment and WCAG compliance.</p>
                        <a asp-action="AccessibilityReport" class="btn btn-primary btn-sm">View Accessibility Report</a>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-percentage text-primary mr-2"></i>
                            FIPS Completion %
                        </h5>
                        <p class="card-text text-muted">Track completion status across all products for Phase, Business area, Contacts, Product URL, and User groups.</p>
                        <a asp-action="FipsCompletion" class="btn btn-primary btn-sm">View FIPS Completion %</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Business Area Reports Section -->
        <div class="row mt-5 mb-4">
            <div class="col-12">
                <h3 class="mb-3">Business Area Reports</h3>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-3 col-md-4 col-sm-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-flag text-primary mr-2"></i>
                            Flagship Projects
                        </h5>
                        <p class="card-text text-muted">Detailed view of flagship projects and their associated deliverables.</p>
                        <a asp-action="FlagshipProjects" class="btn btn-primary btn-sm">View Flagship Projects</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

