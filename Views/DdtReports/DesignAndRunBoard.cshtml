@model Compass.Models.DesignAndRunBoardViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Design and Run Board report";
    var fipsBaseUrl = Configuration["fipsProduct:baseUrl"] ?? "https://find-products-services-test.azurewebsites.net/";
    
    // Calculate key metrics
    var overallStatus = Model.ExecutiveSummary.OverallStatus ?? "On Track";
    var statusClass = overallStatus == "On Track" ? "success" : overallStatus == "At Risk" ? "warning" : "danger";
    var objectivesOnTrack = Model.ExecutiveSummary.ObjectivesOnTrack > 0 ? Model.ExecutiveSummary.ObjectivesOnTrack : Model.Products.Count(p => p.CompletionPercentage >= 80);
    var objectivesAtRisk = Model.ExecutiveSummary.ObjectivesAtRisk > 0 ? Model.ExecutiveSummary.ObjectivesAtRisk : Model.Products.Count(p => p.CompletionPercentage >= 60 && p.CompletionPercentage < 80);
    var objectivesAchieved = Model.ExecutiveSummary.ObjectivesAchieved > 0 ? Model.ExecutiveSummary.ObjectivesAchieved : Model.Products.Count(p => p.CompletionPercentage == 100);
    var totalObjectives = Model.ExecutiveSummary.TotalObjectives > 0 ? Model.ExecutiveSummary.TotalObjectives : Model.Products.Count;
    var onTrackPct = totalObjectives > 0 ? (objectivesOnTrack / (double)totalObjectives) * 100 : 0;
    var achievedPct = totalObjectives > 0 ? (objectivesAchieved / (double)totalObjectives) * 100 : 0;
    
    // Target values
    var targetCompletion = 80.0;
    var targetEnrollment = Model.TotalProducts * 0.8;
    var targetIssues = 0;
}

@section Breadcrumbs {
    <style>
        .breadcrumb a:hover {
            color: #003078 !important;
            text-decoration: underline !important;
        }
    </style>
    <nav aria-label="Breadcrumb">
        <ol class="breadcrumb mb-0 pl-4" style="background-color: #f8f9fa; padding: 0.75rem 1rem; border-radius: 0.375rem;">
            <li class="breadcrumb-item">
                <a href="/" style="color: #005ea5; text-decoration: none;">Home</a>
            </li>
            <li class="breadcrumb-item">
                <a asp-action="Index" style="color: #005ea5; text-decoration: none;">DDT Reports</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Design and Run Board report</li>
        </ol>
    </nav>
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <h1 class="m-0">Design and Run Board</h1>
                <p class="text-muted mb-0">Progress on targets and risk areas - @DateTime.Now.ToString("MMMM yyyy")</p>
            </div>
            <div class="col-sm-6 text-right">
                <span class="badge badge-info">@DateTime.Now.ToString("dd MMM yyyy")</span>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <!-- Summary Cards - Targets vs Actuals -->
        <div class="row mb-4">
            <div class="col-lg-3 col-md-6 col-12 mb-3">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Overall Status</h3>
                    </div>
                    <div class="card-body text-center">
                        <div class="mb-3">
                            <span class="badge badge-@statusClass badge-lg" style="font-size: 1.1rem; padding: 0.5rem 1rem;">
                                @overallStatus
                            </span>
                        </div>
                        <div class="progress" style="height: 25px;">
                            <div class="progress-bar bg-@statusClass" 
                                 style="width: @onTrackPct%" 
                                 role="progressbar">
                                @onTrackPct.ToString("F0")%
                            </div>
                        </div>
                        <small class="text-muted mt-2 d-block">@objectivesOnTrack of @totalObjectives objectives on track</small>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-md-6 col-12 mb-3">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">FIPS Completion</h3>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="h4 mb-0">@Model.AverageCompletionPercentage.ToString("F1")%</span>
                            <span class="badge badge-@(Model.AverageCompletionPercentage >= targetCompletion ? "success" : Model.AverageCompletionPercentage >= 60 ? "warning" : "danger")">
                                Target: @targetCompletion%
                            </span>
                        </div>
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar bg-@(Model.AverageCompletionPercentage >= targetCompletion ? "success" : Model.AverageCompletionPercentage >= 60 ? "warning" : "danger")" 
                                 style="width: @Model.AverageCompletionPercentage%"
                                 role="progressbar">
                            </div>
                        </div>
                        <small class="text-muted">
                            @Model.Products.Count(p => p.CompletionPercentage >= targetCompletion) of @Model.TotalProducts products meet target
                        </small>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-md-6 col-12 mb-3">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Accessibility Enrollment</h3>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="h4 mb-0">@Model.EnrolledInAccessibilityCount</span>
                            <span class="badge badge-@(Model.EnrolledInAccessibilityCount >= targetEnrollment ? "success" : Model.EnrolledInAccessibilityCount >= targetEnrollment * 0.5 ? "warning" : "danger")">
                                Target: @((int)targetEnrollment)
                            </span>
                        </div>
                        @{
                            var enrollmentPct = Model.TotalProducts > 0 ? (Model.EnrolledInAccessibilityCount / (double)Model.TotalProducts) * 100 : 0;
                        }
                        <div class="progress" style="height: 20px;">
                            <div class="progress-bar bg-@(Model.EnrolledInAccessibilityCount >= targetEnrollment ? "success" : Model.EnrolledInAccessibilityCount >= targetEnrollment * 0.5 ? "warning" : "danger")" 
                                 style="width: @enrollmentPct%"
                                 role="progressbar">
                            </div>
                        </div>
                        <small class="text-muted">
                            @enrollmentPct.ToString("F0")% of products enrolled
                        </small>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3 col-md-6 col-12 mb-3">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">Open Issues</h3>
                    </div>
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="h4 mb-0">@Model.TotalOpenAccessibilityIssues</span>
                            <span class="badge badge-@(Model.TotalOpenAccessibilityIssues == targetIssues ? "success" : Model.TotalOpenAccessibilityIssues <= 10 ? "warning" : "danger")">
                                Target: @targetIssues
                            </span>
                        </div>
                        <div class="progress" style="height: 20px;">
                            @{
                                var issuesStatusClass = Model.TotalOpenAccessibilityIssues == targetIssues ? "success" : Model.TotalOpenAccessibilityIssues <= 10 ? "warning" : "danger";
                                var issuesProgress = Model.TotalOpenAccessibilityIssues == 0 ? 100 : Math.Max(0, 100 - (Model.TotalOpenAccessibilityIssues * 5));
                            }
                            <div class="progress-bar bg-@issuesStatusClass" 
                                 style="width: @issuesProgress%"
                                 role="progressbar">
                            </div>
                        </div>
                        <small class="text-muted">
                            @Model.Products.Count(p => p.OpenAccessibilityIssuesCount == 0) products with no issues
                        </small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Progress on Targets Section -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">
                            <i class="fas fa-bullseye mr-2"></i>
                            Progress on Targets
                        </h3>
                    </div>
                    <div class="card-body p-0">
                        @{
                            var keyMeasures = Model.KeyMeasures.Any() ? Model.KeyMeasures : new List<Compass.Models.KeyMeasure>
                            {
                                new Compass.Models.KeyMeasure 
                                { 
                                    Title = "Average FIPS Completion", 
                                    CurrentValue = Model.AverageCompletionPercentage.ToString("F1") + "%",
                                    ExpectedValue = targetCompletion.ToString("F0") + "%",
                                    TargetValue = "100%",
                                    TargetDate = "Ongoing",
                                    Status = Model.AverageCompletionPercentage >= targetCompletion ? "On Track" : Model.AverageCompletionPercentage >= 60 ? "At Risk" : "Behind"
                                },
                                new Compass.Models.KeyMeasure 
                                { 
                                    Title = "Accessibility Enrollment", 
                                    CurrentValue = Model.EnrolledInAccessibilityCount.ToString(),
                                    ExpectedValue = ((int)targetEnrollment).ToString(),
                                    TargetValue = Model.TotalProducts.ToString(),
                                    TargetDate = "Ongoing",
                                    Status = (Model.EnrolledInAccessibilityCount / (double)Model.TotalProducts) >= 0.8 ? "On Track" : "At Risk"
                                },
                                new Compass.Models.KeyMeasure 
                                { 
                                    Title = "Open Accessibility Issues", 
                                    CurrentValue = Model.TotalOpenAccessibilityIssues.ToString(),
                                    ExpectedValue = targetIssues.ToString(),
                                    TargetValue = targetIssues.ToString(),
                                    TargetDate = "Ongoing",
                                    Status = Model.TotalOpenAccessibilityIssues == targetIssues ? "On Track" : Model.TotalOpenAccessibilityIssues <= 10 ? "At Risk" : "Behind"
                                }
                            };
                        }
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th style="width: 30%;">Measure</th>
                                        <th style="width: 15%;" class="text-center">Current</th>
                                        <th style="width: 15%;" class="text-center">Expected</th>
                                        <th style="width: 15%;" class="text-center">Target</th>
                                        <th style="width: 15%;" class="text-center">Progress</th>
                                        <th style="width: 10%;" class="text-center">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var measure in keyMeasures)
                                    {
                                        var measureStatusClass = measure.Status == "On Track" ? "success" : 
                                                                measure.Status == "At Risk" ? "warning" : "danger";
                                        var measureStatusIcon = measure.Status == "On Track" ? "fa-check-circle" : 
                                                              measure.Status == "At Risk" ? "fa-exclamation-triangle" : "fa-times-circle";
                                        
                                        // Calculate progress percentage
                                        double progressPct = 0;
                                        if (double.TryParse(measure.CurrentValue.Replace("%", ""), out var current) && 
                                            double.TryParse(measure.ExpectedValue.Replace("%", ""), out var expected))
                                        {
                                            if (expected > 0)
                                            {
                                                progressPct = Math.Min(100, (current / expected) * 100);
                                            }
                                        }
                                        else if (int.TryParse(measure.CurrentValue, out var currentInt) && 
                                                 int.TryParse(measure.ExpectedValue, out var expectedInt))
                                        {
                                            if (expectedInt > 0)
                                            {
                                                progressPct = Math.Min(100, (currentInt / (double)expectedInt) * 100);
                                            }
                                        }
                                        
                                        <tr>
                                            <td><strong>@measure.Title</strong></td>
                                            <td class="text-center">
                                                <span class="font-weight-bold">@measure.CurrentValue</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="text-muted">@measure.ExpectedValue</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="text-muted">@measure.TargetValue</span>
                                            </td>
                                            <td class="text-center">
                                                <div class="progress" style="height: 20px; min-width: 80px;">
                                                    <div class="progress-bar bg-@measureStatusClass" 
                                                         style="width: @progressPct%"
                                                         role="progressbar">
                                                        @progressPct.ToString("F0")%
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge badge-@measureStatusClass">
                                                    <i class="fas @measureStatusIcon"></i> @measure.Status
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Risk Areas Section -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">
                            <i class="fas fa-exclamation-triangle mr-2"></i>
                            Risk Areas
                        </h3>
                        <div class="card-tools">
                            <button type="button" class="btn btn-sm btn-outline-primary" id="expandAllRiskGroups">
                                <i class="fas fa-chevron-down"></i> Expand All
                            </button>
                            <button type="button" class="btn btn-sm btn-outline-secondary ml-2" id="collapseAllRiskGroups">
                                <i class="fas fa-chevron-up"></i> Collapse All
                            </button>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        @{
                            if (Model.TopAtRiskProducts.Any())
                            {
                                // Group products by risk score ranges
                                var criticalRisk = Model.TopAtRiskProducts.Where(p => p.RiskScore >= 80).OrderByDescending(p => p.RiskScore).ToList();
                                var highRisk = Model.TopAtRiskProducts.Where(p => p.RiskScore >= 60 && p.RiskScore < 80).OrderByDescending(p => p.RiskScore).ToList();
                                var mediumRisk = Model.TopAtRiskProducts.Where(p => p.RiskScore >= 40 && p.RiskScore < 60).OrderByDescending(p => p.RiskScore).ToList();
                                var lowRisk = Model.TopAtRiskProducts.Where(p => p.RiskScore >= 20 && p.RiskScore < 40).OrderByDescending(p => p.RiskScore).ToList();
                                var minimalRisk = Model.TopAtRiskProducts.Where(p => p.RiskScore > 0 && p.RiskScore < 20).OrderByDescending(p => p.RiskScore).ToList();
                                
                                var riskGroups = new List<(string Level, string BadgeClass, string CardClass, List<Compass.Models.DesignAndRunBoardItem> Products, string Description)>
                                {
                                    ("Critical Risk (80+)", "badge-danger", "danger", criticalRisk, "Immediate attention required"),
                                    ("High Risk (60-79)", "badge-danger", "warning", highRisk, "Urgent action needed"),
                                    ("Medium Risk (40-59)", "badge-warning", "warning", mediumRisk, "Monitor closely"),
                                    ("Low Risk (20-39)", "badge-info", "info", lowRisk, "Minor concerns"),
                                    ("Minimal Risk (<20)", "badge-success", "success", minimalRisk, "Low priority")
                                };
                                
                                var groupIndex = 0;
                            
                        <style>
                            #riskGroupsAccordion .card-header {
                                background-color: #f8f9fa;
                                border-bottom: 1px solid #dee2e6;
                                transition: background-color 0.2s ease;
                            }
                            #riskGroupsAccordion .card-header:hover {
                                background-color: #e9ecef;
                            }
                            #riskGroupsAccordion .card-header i {
                                transition: transform 0.3s ease;
                            }
                            #riskGroupsAccordion .card-header[aria-expanded="true"] i {
                                transform: rotate(180deg);
                            }
                            #riskGroupsAccordion .card-header[aria-expanded="false"] i {
                                transform: rotate(0deg);
                            }
                        </style>
                        <div class="accordion" id="riskGroupsAccordion">
                            @foreach (var group in riskGroups.Where(g => g.Products.Any()))
                            {
                                var collapseId = $"riskGroup{groupIndex}";
                                var headingId = $"riskHeading{groupIndex}";
                                
                                // Get unique risk factors for this group
                                var groupRiskFactors = group.Products
                                    .SelectMany(p => p.RiskFactors)
                                    .GroupBy(f => f)
                                    .OrderByDescending(g => g.Count())
                                    .Select(g => new { Factor = g.Key, Count = g.Count() })
                                    .ToList();
                                
                                <div class="card mb-2">
                                    <div class="card-header" id="@headingId" style="cursor: pointer;" data-toggle="collapse" data-target="#@collapseId" aria-expanded="false" aria-controls="@collapseId">
                                        <div class="d-flex align-items-center">
                                            <i class="fas fa-chevron-down mr-3"></i>
                                            <div class="flex-grow-1">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <span class="@group.BadgeClass" style="font-size: 1rem;">@group.Level</span>
                                                    </div>
                                                    <div class="d-flex align-items-center">
                                                        <span class="badge badge-primary mr-2">@group.Products.Count product@(group.Products.Count != 1 ? "s" : "")</span>
                                                        <span class="text-muted">@group.Description</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div id="@collapseId" class="collapse" aria-labelledby="@headingId" data-parent="#riskGroupsAccordion">
                                        <div class="card-body p-3">
                                            <!-- Common Risk Factors for this group -->
                                            @if (groupRiskFactors.Any())
                                            {
                                                <div class="alert alert-@group.CardClass mb-3">
                                                    <h6 class="mb-2">
                                                        <i class="fas fa-exclamation-circle mr-2"></i>
                                                        Common risk factors in this group:
                                                    </h6>
                                                    <div class="d-flex flex-wrap">
                                                        @foreach (var factor in groupRiskFactors.Take(5))
                                                        {
                                                            <span class="badge @group.BadgeClass mr-2 mb-1">
                                                                @factor.Factor <span class="badge badge-light ml-1">@factor.Count</span>
                                                            </span>
                                                        }
                                                    </div>
                                                </div>
                                            }
                                            
                                            <!-- Products in this risk group -->
                                            <div class="table-responsive">
                                                <table class="table table-sm table-hover mb-0 sortable-table">
                                                    <thead>
                                                        <tr>
                                                            <th>Product</th>
                                                            <th class="text-center">Risk Score</th>
                                                            <th class="text-center">Completion</th>
                                                            <th class="text-center">Accessibility</th>
                                                            <th class="text-center">Open Issues</th>
                                                            <th>Risk Factors</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var product in group.Products)
                                                        {
                                                            var productCompletionClass = product.CompletionPercentage >= 80 ? "success" : 
                                                                                         product.CompletionPercentage >= 60 ? "warning" : "danger";
                                                            var productRiskClass = product.RiskScore >= 80 ? "danger" : 
                                                                                  product.RiskScore >= 60 ? "warning" : 
                                                                                  product.RiskScore >= 40 ? "info" : "success";
                                                            var issuesClass = product.OpenAccessibilityIssuesCount == 0 ? "success" : 
                                                                              product.OpenAccessibilityIssuesCount <= 5 ? "warning" : "danger";
                                                            
                                                            <tr>
                                                                <td>
                                                                    <strong>@product.ProductTitle</strong>
                                                                    <br/>
                                                                    <small class="text-muted">@product.BusinessArea</small>
                                                                </td>
                                                                <td class="text-center">
                                                                    <span class="badge badge-@productRiskClass badge-lg">
                                                                        @product.RiskScore.ToString("F0")
                                                                    </span>
                                                                </td>
                                                                <td class="text-center">
                                                                    <span class="badge badge-@productCompletionClass">
                                                                        @product.CompletionPercentage.ToString("F0")%
                                                                    </span>
                                                                </td>
                                                                <td class="text-center">
                                                                    @if (product.IsEnrolledInAccessibility)
                                                                    {
                                                                        <span class="badge badge-@(product.AccessibilityComplianceStatus == "Compliant" ? "success" : "warning")">
                                                                            @product.AccessibilityComplianceStatus
                                                                        </span>
                                                                    }
                                                                    else
                                                                    {
                                                                        <span class="badge badge-secondary">Not enrolled</span>
                                                                    }
                                                                </td>
                                                                <td class="text-center">
                                                                    <span class="badge badge-@issuesClass">
                                                                        @product.OpenAccessibilityIssuesCount
                                                                    </span>
                                                                </td>
                                                                <td>
                                                                    <small>
                                                                        @string.Join(", ", product.RiskFactors.Take(3))
                                                                        @if (product.RiskFactors.Count > 3)
                                                                        {
                                                                            <span class="text-muted">+@(product.RiskFactors.Count - 3) more</span>
                                                                        }
                                                                    </small>
                                                                </td>
                                                            </tr>
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                groupIndex++;
                            }
                        </div>
                            }
                            else
                            {
                                <div class="p-4 text-center text-muted">
                                    <p>No products with risk scores identified.</p>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Business Area Performance -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">
                            <i class="fas fa-building mr-2"></i>
                            Business Area Performance
                        </h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 sortable-table">
                                <thead>
                                    <tr>
                                        <th>Business Area</th>
                                        <th class="text-center">Products</th>
                                        <th class="text-center">Avg Completion</th>
                                        <th class="text-center">Avg Risk Score</th>
                                        <th class="text-center">Accessibility Enrolled</th>
                                        <th class="text-center">Open Issues</th>
                                        <th class="text-center">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var area in Model.BusinessAreaSummaries.OrderByDescending(a => a.AverageRiskScore))
                                    {
                                        var areaRiskClass = area.AverageRiskScore >= 60 ? "danger" :
                                                           area.AverageRiskScore >= 40 ? "warning" : "success";
                                        var areaCompletionClass = area.AverageCompletionPercentage >= 80 ? "success" : 
                                                                area.AverageCompletionPercentage >= 60 ? "warning" : "danger";
                                        var areaEnrollmentPercentage = area.ProductCount > 0 ? (area.EnrolledInAccessibilityCount / (double)area.ProductCount) * 100 : 0;
                                        var areaEnrollmentClass = areaEnrollmentPercentage >= 80 ? "success" : 
                                                                 areaEnrollmentPercentage >= 50 ? "warning" : "danger";
                                        var areaIssuesClass = area.TotalAccessibilityIssues == 0 ? "success" : 
                                                            area.TotalAccessibilityIssues <= 5 ? "warning" : "danger";
                                        
                                        // Overall status for the area
                                        var areaStatus = "On Track";
                                        var areaStatusClass = "success";
                                        if (area.AverageRiskScore >= 60 || area.AverageCompletionPercentage < 60 || areaEnrollmentPercentage < 50)
                                        {
                                            areaStatus = "At Risk";
                                            areaStatusClass = "warning";
                                        }
                                        if (area.AverageRiskScore >= 80 || area.AverageCompletionPercentage < 40)
                                        {
                                            areaStatus = "Behind";
                                            areaStatusClass = "danger";
                                        }
                                        
                                        <tr>
                                            <td><strong>@area.BusinessArea</strong></td>
                                            <td class="text-center">
                                                <span class="badge badge-info">@area.ProductCount</span>
                                            </td>
                                            <td class="text-center">
                                                <div class="d-flex align-items-center justify-content-center">
                                                    <span class="badge badge-@areaCompletionClass mr-2">
                                                        @area.AverageCompletionPercentage.ToString("F1")%
                                                    </span>
                                                    <div class="progress" style="width: 60px; height: 16px;">
                                                        <div class="progress-bar bg-@areaCompletionClass" 
                                                             style="width: @area.AverageCompletionPercentage%"
                                                             role="progressbar">
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge badge-@areaRiskClass badge-lg">
                                                    @area.AverageRiskScore.ToString("F1")
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge badge-@areaEnrollmentClass">
                                                    @area.EnrolledInAccessibilityCount / @area.ProductCount
                                                </span>
                                                <br/>
                                                <small class="text-muted">@areaEnrollmentPercentage.ToString("F0")%</small>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge badge-@areaIssuesClass">
                                                    @area.TotalAccessibilityIssues
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge badge-@areaStatusClass">
                                                    @areaStatus
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Objectives Progress -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title mb-0">
                            <i class="fas fa-tasks mr-2"></i>
                            Objectives Progress
                        </h3>
                    </div>
                    <div class="card-body p-0">
                        @{
                            var objectives = Model.Objectives.Any() ? Model.Objectives : 
                                            Model.Products.Take(15).Select(p => new Compass.Models.BoardObjective
                                            {
                                                Title = p.ProductTitle,
                                                FocusArea = p.BusinessArea,
                                                Owner = p.LastSubmittedBy ?? "Unassigned",
                                                OwnerInitials = !string.IsNullOrEmpty(p.LastSubmittedBy) ? 
                                                    string.Join("", p.LastSubmittedBy.Split(' ').Select(n => n.Length > 0 ? n[0].ToString() : "").Take(2)) : "NA",
                                                ProgressPercentage = p.CompletionPercentage,
                                                Status = p.CompletionPercentage >= 80 ? "On Track" : 
                                                        p.CompletionPercentage >= 60 ? "At Risk" : "Behind",
                                                Description = $"FIPS ID: {p.FipsId}"
                                            }).ToList();
                        }
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 sortable-table">
                                <thead>
                                    <tr>
                                        <th style="width: 30%;">Objective</th>
                                        <th style="width: 20%;">Focus Area</th>
                                        <th style="width: 15%;">Owner</th>
                                        <th style="width: 25%;">Progress</th>
                                        <th style="width: 10%;" class="text-center">Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var objective in objectives)
                                    {
                                        var objStatusClass = objective.Status == "On Track" ? "success" : 
                                                            objective.Status == "At Risk" ? "warning" : "danger";
                                        
                                        <tr>
                                            <td>
                                                <strong>@objective.Title</strong>
                                                @if (!string.IsNullOrEmpty(objective.Description))
                                                {
                                                    <br/><small class="text-muted">@objective.Description</small>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge badge-info">@objective.FocusArea</span>
                                            </td>
                                            <td>
                                                <small>@objective.Owner</small>
                                            </td>
                                            <td>
                                                <div class="progress" style="height: 20px;">
                                                    <div class="progress-bar bg-@objStatusClass" 
                                                         style="width: @objective.ProgressPercentage%"
                                                         role="progressbar">
                                                        @objective.ProgressPercentage.ToString("F0")%
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge badge-@objStatusClass">
                                                    @objective.Status
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Initialize sortable tables
            $('.sortable-table').each(function() {
                initializeSortableTable($(this));
            });

            // Handle accordion collapse/expand events
            $('#riskGroupsAccordion').on('show.bs.collapse', function(e) {
                var header = $(e.target).prev('.card-header');
                header.attr('aria-expanded', 'true');
            });

            $('#riskGroupsAccordion').on('hide.bs.collapse', function(e) {
                var header = $(e.target).prev('.card-header');
                header.attr('aria-expanded', 'false');
            });

            // Expand all risk groups
            $('#expandAllRiskGroups').on('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                $('#riskGroupsAccordion .collapse').each(function() {
                    var $collapse = $(this);
                    var $header = $collapse.prev('.card-header');
                    if (!$collapse.hasClass('show')) {
                        $collapse.removeAttr('data-parent');
                        $collapse.addClass('show');
                        $header.attr('aria-expanded', 'true');
                        $collapse.trigger('shown.bs.collapse');
                    }
                });
            });

            // Collapse all risk groups
            $('#collapseAllRiskGroups').on('click', function(e) {
                e.preventDefault();
                e.stopPropagation();
                $('#riskGroupsAccordion .collapse').each(function() {
                    var $collapse = $(this);
                    var $header = $collapse.prev('.card-header');
                    if ($collapse.hasClass('show')) {
                        $collapse.removeClass('show');
                        $header.attr('aria-expanded', 'false');
                        $collapse.attr('data-parent', '#riskGroupsAccordion');
                        $collapse.trigger('hidden.bs.collapse');
                    }
                });
            });
        });

        function initializeSortableTable(table) {
            var currentSort = { column: null, direction: 'asc' };

            table.find('thead th').on('click', function(e) {
                var column = $(this).index();
                var direction = 'asc';
                
                if (currentSort.column === column && currentSort.direction === 'asc') {
                    direction = 'desc';
                }
                
                sortTable(table, column, direction);
                currentSort = { column: column, direction: direction };
            });

            function sortTable(table, column, direction) {
                var tbody = table.find('tbody');
                var rows = tbody.find('tr').toArray();
                
                rows.sort(function(a, b) {
                    var aVal, bVal;
                    var aText = $(a).find('td').eq(column).text().trim().toLowerCase();
                    var bText = $(b).find('td').eq(column).text().trim().toLowerCase();
                    
                    // Try to parse as number
                    var aNum = parseFloat(aText);
                    var bNum = parseFloat(bText);
                    
                    if (!isNaN(aNum) && !isNaN(bNum)) {
                        aVal = aNum;
                        bVal = bNum;
                    } else {
                        aVal = aText;
                        bVal = bText;
                    }
                    
                    if (direction === 'asc') {
                        return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                    } else {
                        return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                    }
                });
                
                tbody.empty();
                rows.forEach(function(row) {
                    tbody.append(row);
                });
            }
        }
    </script>
}
