@model List<Compass.Models.Project>

@{
    ViewData["Title"] = "Flagship Projects - DDT Reports";
    var deliverablesDict = ViewBag.Deliverables as Dictionary<int, List<Compass.Models.Project>> ?? new Dictionary<int, List<Compass.Models.Project>>();
    
    // Calculate metrics
    var totalDeliverables = deliverablesDict.Values.Sum(v => v.Count);
    var greenFlagships = Model.Count(p => p.RagStatus == "Green");
    var atRiskFlagships = Model.Count(p => p.RagStatus != "Green");
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">DDT Reports</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Flagship Projects</li>
                </ol>
                <h1 class="m-0">Flagship Projects</h1>
                <p class="text-muted mb-0">@DateTime.Now.ToString("dd MMMM yyyy")</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="card">
                <div class="card-body text-center p-5">
                    <i class="fas fa-flag fa-3x text-muted mb-3"></i>
                    <h4>No flagship projects</h4>
                    <p class="text-muted">There are currently no active flagship projects to display.</p>
                </div>
            </div>
        }
        else
        {
            <!-- Key Metrics -->
            <div class="row mb-4">
                <div class="col-lg-3 col-md-6 mb-3">
                    <div class="small-box bg-info h-100">
                        <div class="inner">
                            <h3>@Model.Count</h3>
                            <p>Flagship projects</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6 mb-3">
                    <div class="small-box bg-primary h-100">
                        <div class="inner">
                            <h3>@totalDeliverables</h3>
                            <p>Total deliverables</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6 mb-3">
                    <div class="small-box bg-success h-100">
                        <div class="inner">
                            <h3>@greenFlagships</h3>
                            <p>Green RAG</p>
                        </div>
                    </div>
                </div>

                <div class="col-lg-3 col-md-6 mb-3">
                    @{
                        var atRiskBg = atRiskFlagships == 0 ? "success" : 
                                      atRiskFlagships <= 2 ? "warning" : "danger";
                    }
                    <div class="small-box bg-@atRiskBg h-100">
                        <div class="inner">
                            <h3>@atRiskFlagships</h3>
                            <p>At risk</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Flagship Delivery Table -->
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Flagship delivery</h3>
                </div>
                <div class="card-body table-responsive p-0">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Flagship project</th>
                                <th>RAG</th>
                                <th>Business area</th>
                                <th class="text-center">Deliverables</th>
                                <th class="text-center">Active issues</th>
                                <th class="text-center">Active milestones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var flagship in Model.OrderBy(p => p.Title))
                            {
                                var deliverables = deliverablesDict.ContainsKey(flagship.Id) 
                                    ? deliverablesDict[flagship.Id] 
                                    : new List<Compass.Models.Project>();
                                
                                // Count dependencies (deliverables)
                                var dependencyCount = deliverables.Count;
                                
                                // Sum active/open issues across flagship and all deliverables
                                var flagshipActiveIssues = flagship.Issues?.Count(i => !i.IsDeleted && i.Status != "resolved" && i.Status != "closed") ?? 0;
                                var deliverableActiveIssues = deliverables.Sum(d => d.Issues?.Count(i => !i.IsDeleted && i.Status != "resolved" && i.Status != "closed") ?? 0);
                                var totalActiveIssues = flagshipActiveIssues + deliverableActiveIssues;
                                
                                // Sum active milestones across flagship and all deliverables
                                var flagshipActiveMilestones = flagship.Milestones?.Count(m => !m.IsDeleted && m.Status != "complete" && m.Status != "cancelled") ?? 0;
                                var deliverableActiveMilestones = deliverables.Sum(d => d.Milestones?.Count(m => !m.IsDeleted && m.Status != "complete" && m.Status != "cancelled") ?? 0);
                                var totalActiveMilestones = flagshipActiveMilestones + deliverableActiveMilestones;
                                
                                <tr>
                                    <td>
                                        <a href="@Url.Action("Details", "Project", new { id = flagship.Id })">
                                            <strong>@flagship.Title</strong>
                                        </a><br>
                                        <small class="text-muted">@flagship.ProjectCode</small>
                                    </td>
                                    <td>
                                        <span class="@GetRagBadgeClass(flagship.RagStatus)">@flagship.RagStatus</span>
                                    </td>
                                    <td>@(flagship.BusinessArea ?? "-")</td>
                                    <td class="text-center">
                                        <span class="badge badge-info">@dependencyCount</span>
                                    </td>
                                    <td class="text-center">
                                        @if (totalActiveIssues > 0)
                                        {
                                            <span class="badge badge-warning">@totalActiveIssues</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-success">0</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <span class="badge badge-primary">@totalActiveMilestones</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</section>

<style>
.small-box {
    border-radius: .25rem;
    box-shadow: 0 0 1px rgba(0,0,0,.125), 0 1px 3px rgba(0,0,0,.2);
    display: block;
    margin-bottom: 0;
    position: relative;
    min-height: 100px;
}

.small-box > .inner {
    padding: 15px;
}

.small-box h3 {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0 0 5px;
    padding: 0;
    color: #fff;
}

.small-box p {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 0;
}

@@media (max-width: 767px) {
    .small-box h3 {
        font-size: 2rem;
    }
    
    .small-box > .inner {
        padding: 10px;
    }
}
</style>

@functions {
    string GetRagBadgeClass(string ragStatus)
    {
        return ragStatus switch
        {
            "Green" => "badge badge-green",
            "Amber-Green" => "badge badge-amber-green",
            "Amber" => "badge badge-amber",
            "Amber-Red" => "badge badge-amber-red",
            "Red" => "badge badge-red",
            _ => "badge badge-secondary"
        };
    }
}
