@model List<Compass.Models.Project>

@{
    ViewData["Title"] = "Flagship Projects - DDT Reports";
    var deliverablesDict = ViewBag.Deliverables as Dictionary<int, List<Compass.Models.Project>> ?? new Dictionary<int, List<Compass.Models.Project>>();
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">DDT Reports</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Flagship Projects</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        @if (!Model.Any())
        {
            <div class="card">
                <div class="card-body text-center p-5">
                    <i class="fas fa-flag fa-3x text-muted mb-3"></i>
                    <h4>No Flagship Projects</h4>
                    <p class="text-muted">There are currently no active flagship projects to display.</p>
                </div>
            </div>
        }
        else
        {
            <!-- Header Banner with Key Metrics -->
            <div class="row mb-4" style="display: flex;">
                <!-- Left side: Title and three metric cards -->
                <div class="col-lg-8" style="display: flex;">
                    <!-- Summary Banner -->
                    <div class="card border-0 w-100" style="background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%); border-radius: 12px;">
                        <div class="card-body p-4">
                            <div class="row align-items-center" style="height: 100%;">
                                <div class="col-md-6">
                                    <p class="text-muted mb-1" style="font-size: 0.9rem;">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
                                    <h2 class="mb-2" style="font-weight: 600; color: #1976D2;">Flagship Projects</h2>
                                    <p class="text-muted mb-0" style="font-size: 0.95rem;">High-priority strategic initiatives with multiple deliverables</p>
                                </div>
                                <div class="col-md-6">
                                    <div class="d-flex justify-content-start">
                                        <!-- Flagship Projects Card -->
                                        <div style="flex: 0 0 33.333%; padding-right: 8px;">
                                            <div class="card border-0 shadow-sm metric-card" style="border-radius: 8px; transition: transform 0.2s, box-shadow 0.2s;">
                                                <div class="card-body p-3">
                                                    <h3 class="mb-1 text-left" style="font-weight: 700; font-size: 1.8rem;">@Model.Count</h3>
                                                    <p class="text-muted mb-0 text-left" style="font-size: 0.85rem;">Flagships</p>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- Green RAG Card -->
                                        <div style="flex: 0 0 33.333%; padding-right: 8px;">
                                            <div class="card border-0 shadow-sm metric-card" style="border-radius: 8px; transition: transform 0.2s, box-shadow 0.2s;">
                                                <div class="card-body p-3">
                                                    <h3 class="mb-1 text-left" style="font-weight: 700; font-size: 1.8rem;">@Model.Count(p => p.RagStatus == "Green")</h3>
                                                    <p class="text-muted mb-0 text-left" style="font-size: 0.85rem;">Green RAG</p>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- At Risk Card -->
                                        <div style="flex: 0 0 33.333%;">
                                            <div class="card border-0 shadow-sm metric-card" style="border-radius: 8px; transition: transform 0.2s, box-shadow 0.2s;">
                                                <div class="card-body p-3">
                                                    <h3 class="mb-1 text-left" style="font-weight: 700; font-size: 1.8rem;">@Model.Count(p => p.RagStatus != "Green")</h3>
                                                    <p class="text-muted mb-0 text-left" style="font-size: 0.85rem;">At risk</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Right side: What's New card -->
                <div class="col-lg-4" style="display: flex;">
                    <div class="card border-0 shadow-sm w-100 metric-card" style="border-radius: 12px; background: white; transition: transform 0.2s, box-shadow 0.2s;">
                        <div class="card-body p-4">
                            <div style="height: 100%;">
                                <h5 class="mb-2" style="font-weight: 600;">What's new in COMPASS</h5>
                                <p class="text-muted mb-3" style="font-size: 0.9rem;">Find out whats new and upcoming on the COMPASS roadmap.</p>
                                <a href="@Url.Action("Roadmap", "Home")" class="btn" style="background: #FF6B35; color: white; border-radius: 6px; font-weight: 500;">
                                    Explore COMPASS
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Flagship Delivery Card -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title mb-0">Flagship delivery</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Flagship Project</th>
                                        <th>RAG Status</th>
                                        <th>Dependencies</th>
                                        <th>Active Issues</th>
                                        <th>Active Milestones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var flagship in Model)
                                    {
                                        var deliverables = deliverablesDict.ContainsKey(flagship.Id) 
                                            ? deliverablesDict[flagship.Id] 
                                            : new List<Compass.Models.Project>();
                                        
                                        // Count dependencies (deliverables)
                                        var dependencyCount = deliverables.Count;
                                        
                                        // Sum active/open issues across flagship and all deliverables
                                        var flagshipActiveIssues = flagship.Issues?.Count(i => !i.IsDeleted && i.Status != "resolved" && i.Status != "closed") ?? 0;
                                        var deliverableActiveIssues = deliverables.Sum(d => d.Issues?.Count(i => !i.IsDeleted && i.Status != "resolved" && i.Status != "closed") ?? 0);
                                        var totalActiveIssues = flagshipActiveIssues + deliverableActiveIssues;
                                        
                                        // Sum active milestones across flagship and all deliverables
                                        var flagshipActiveMilestones = flagship.Milestones?.Count(m => !m.IsDeleted && m.Status != "complete" && m.Status != "cancelled") ?? 0;
                                        var deliverableActiveMilestones = deliverables.Sum(d => d.Milestones?.Count(m => !m.IsDeleted && m.Status != "complete" && m.Status != "cancelled") ?? 0);
                                        var totalActiveMilestones = flagshipActiveMilestones + deliverableActiveMilestones;
                                        
                                        <tr>
                                            <td>
                                                <a href="@Url.Action("Details", "Project", new { id = flagship.Id })">
                                                    <strong>@flagship.Title</strong>
                                                </a><br>
                                                <small class="text-muted">@flagship.ProjectCode</small>
                                            </td>
                                            <td>
                                                <span class="@GetRagBadgeClass(flagship.RagStatus)">@flagship.RagStatus</span>
                                            </td>   
                                            <td>@dependencyCount</td>
                                            <td>@totalActiveIssues</td>
                                            <td>@totalActiveMilestones</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

@functions {
    string GetRagBadgeClass(string ragStatus)
    {
        return ragStatus switch
        {
            "Green" => "badge badge-success",
            "Amber-Green" => "badge badge-info",
            "Amber" => "badge badge-warning",
            "Amber-Red" => "badge badge-warning",
            "Red" => "badge badge-danger",
            _ => "badge badge-secondary"
        };
    }
}
