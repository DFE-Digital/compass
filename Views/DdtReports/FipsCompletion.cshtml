<style>
.sortable {
    cursor: pointer;
    user-select: none;
}

.sortable:hover {
    background-color: #f8f9fa;
}

.badge-lg {
    font-size: 1rem;
    padding: 0.5rem 0.75rem;
}

.completion-icon {
    font-size: 2rem;
    vertical-align: middle;
}

.completion-count {
    font-size: 1rem;
    margin-left: 0.25rem;
    vertical-align: middle;
    display: inline-block;
}
</style>

@section Scripts {
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            initializeSortableTable($('#completionTable'));

            $('#searchInput, #completionFilter, #statusFilter, #businessAreaFilter, #sroFilter, #iaoFilter, #deliveryManagerFilter')
                .on('input change', filterTable);

            $(document).on('click', '[data-action="set-phase"]', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var fipsId = $(this).data('fips-id');
                $('#phaseFipsId').val(fipsId);
                $('#phaseCategoryValueId').val('');
                $('#updatePhaseModal').modal('show');
                return false;
            });

            $(document).on('click', '[data-action="set-business-area"]', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var fipsId = $(this).data('fips-id');
                $('#businessAreaFipsId').val(fipsId);
                $('#businessAreaCategoryValueId').val('');
                $('#updateBusinessAreaModal').modal('show');
                return false;
            });

            $(document).on('click', '[data-action="set-product-url"]', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var fipsId = $(this).data('fips-id');
                $('#productUrlFipsId').val(fipsId);
                $('#productUrl').val('');
                $('#updateProductUrlModal').modal('show');
                return false;
            });

            $(document).on('click', '[data-action="set-user-groups"]', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var $row = $(this).closest('tr');
                var fipsId = $(this).data('fips-id');
                var selectedIds = ($row.attr('data-user-group-ids') || '')
                    .toString()
                    .split(',')
                    .filter(Boolean);
                $('#userGroupsFipsId').val(fipsId);
                var $select = $('#userGroupCategoryValueIds');
                $select.val(null);
                if (selectedIds.length) {
                    $select.val(selectedIds);
                }
                $('#updateUserGroupsModal').modal('show');
                return false;
            });

            $(document).on('click', '[data-action="update-state-rejected"]', function(e) {
                e.preventDefault();
                e.stopPropagation();
                var fipsId = $(this).data('fips-id');
                var productTitle = $(this).data('product-title');
                $('#stateFipsId').val(fipsId);
                $('#stateProductTitle').text(productTitle);
                $('#updateStateModal').modal('show');
                return false;
            });

            setupAjaxForm('#updatePhaseModal form', handleProductUpdate);
            setupAjaxForm('#updateBusinessAreaModal form', handleProductUpdate);
            setupAjaxForm('#updateProductUrlModal form', handleProductUpdate);
            setupAjaxForm('#updateUserGroupsModal form', handleProductUpdate);

            window.filterZeroCompletion = function() {
                $('#completionFilter').val('');
                $('#statusFilter').val('');
                $('#businessAreaFilter').val('');
                $('#sroFilter').val('');
                $('#iaoFilter').val('');
                $('#deliveryManagerFilter').val('');
                $('#searchInput').val('');
                filterTable();
                $('html, body').animate({
                    scrollTop: $('#completionTable').offset().top - 100
                }, 500);
            };

            filterTable();
            recalculateSummary();

            function setupAjaxForm(selector, onSuccess) {
                var $form = $(selector);
                $form.on('submit', function(e) {
                    e.preventDefault();
                    var formData = new FormData(this);
                    var $submitButton = $form.find('button[type="submit"]');
                    $submitButton.prop('disabled', true);
                    fetch($form.attr('action'), {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        body: formData,
                        credentials: 'same-origin'
                    })
                    .then(function(response) {
                        return response.json();
                    })
                    .then(function(data) {
                        if (data && data.success) {
                            if (typeof onSuccess === 'function') {
                                onSuccess(data);
                            }
                            $form.closest('.modal').modal('hide');
                        } else {
                            showInlineAlert('danger', (data && data.message) || 'Unable to complete the update. Please try again.');
                        }
                    })
                    .catch(function() {
                        showInlineAlert('danger', 'An unexpected error occurred. Please try again.');
                    })
                    .finally(function() {
                        $submitButton.prop('disabled', false);
                    });
                });
            }

            function handleProductUpdate(response) {
                if (!response) {
                    return;
                }

                if (response.message) {
                    showInlineAlert(response.success ? 'success' : 'danger', response.message);
                }

                if (response.product) {
                    updateRowWithProduct(response.product);
                    recalculateSummary();
                    filterTable();
                }
            }

            function showInlineAlert(type, message) {
                var $container = $('#inlineAlertContainer');
                if (!message) {
                    $container.empty();
                    return;
                }

                var alertHtml = '<div class="alert alert-' + type + ' alert-dismissible fade show" role="alert">' +
                    message +
                    '<button type="button" class="close" data-dismiss="alert" aria-label="Close">' +
                    '<span aria-hidden="true">&times;</span>' +
                    '</button>' +
                    '</div>';

                $container.html(alertHtml);
            }

            function escapeHtml(text) {
                return $('<div>').text(text || '').html();
            }

            function toLowerJoined(values) {
                if (!Array.isArray(values) || !values.length) {
                    return '';
                }
                return values.map(function(value) { return (value || '').toLowerCase(); }).join('||');
            }

            function joinOriginalList(values) {
                if (!Array.isArray(values) || !values.length) {
                    return '';
                }
                return values.join('||');
            }

            function updateRowWithProduct(product) {
                if (!product || !product.fipsId) {
                    return;
                }

                var fipsId = (product.fipsId || '').toLowerCase();
                var $row = $('#completionTable tbody tr').filter(function() {
                    return $(this).attr('data-fips-id') === fipsId;
                });

                if (!$row.length) {
                    return;
                }

                var businessArea = product.businessArea || 'Unassigned';
                var completion = parseFloat(product.completionPercentage) || 0;
                var hasPhase = !!product.hasPhase;
                var hasBusinessArea = !!product.hasBusinessArea;
                var hasProductUrl = !!product.hasProductUrl;
                var contactsCount = product.contactsCount || 0;
                var userGroupNames = product.userGroupNames || [];
                var userGroupIds = (product.userGroupCategoryValueIds || []).map(function(id) { return id.toString(); });
                var userGroupsCount = product.userGroupsCount != null ? product.userGroupsCount : userGroupNames.length;
                var userGroupTitle = userGroupNames.length ? userGroupNames.join(', ') : 'No user groups';

                var sroContacts = product.seniorResponsibleOfficerContacts || [];
                var iaoContacts = product.informationAssetOwnerContacts || [];
                var deliveryContacts = product.deliveryManagerContacts || [];

                $row.attr('data-completion', completion).data('completion', completion);
                $row.attr('data-business-area', businessArea).data('business-area', businessArea);
                $row.attr('data-has-phase', hasPhase).data('has-phase', hasPhase);
                $row.attr('data-has-business-area', hasBusinessArea).data('has-business-area', hasBusinessArea);
                $row.attr('data-has-product-url', hasProductUrl).data('has-product-url', hasProductUrl);
                $row.attr('data-user-groups-count', userGroupsCount).data('user-groups-count', userGroupsCount);
                $row.attr('data-user-groups', toLowerJoined(userGroupNames)).data('user-groups', toLowerJoined(userGroupNames));
                $row.attr('data-user-group-ids', userGroupIds.join(',')).data('user-group-ids', userGroupIds.join(','));
                $row.attr('data-contacts-count', contactsCount).data('contacts-count', contactsCount);
                $row.attr('data-sro', toLowerJoined(sroContacts)).data('sro', toLowerJoined(sroContacts));
                $row.attr('data-sro-display', product.seniorResponsibleOfficer || '').data('sro-display', product.seniorResponsibleOfficer || '');
                $row.attr('data-sro-names', joinOriginalList(product.seniorResponsibleOfficerContacts || [])).data('sro-names', joinOriginalList(product.seniorResponsibleOfficerContacts || []));
                $row.attr('data-iao', toLowerJoined(iaoContacts)).data('iao', toLowerJoined(iaoContacts));
                $row.attr('data-iao-display', product.informationAssetOwner || '').data('iao-display', product.informationAssetOwner || '');
                $row.attr('data-iao-names', joinOriginalList(product.informationAssetOwnerContacts || [])).data('iao-names', joinOriginalList(product.informationAssetOwnerContacts || []));
                $row.attr('data-delivery-manager', toLowerJoined(deliveryContacts)).data('delivery-manager', toLowerJoined(deliveryContacts));
                $row.attr('data-delivery-manager-display', product.deliveryManager || '').data('delivery-manager-display', product.deliveryManager || '');
                $row.attr('data-delivery-manager-names', joinOriginalList(product.deliveryManagerContacts || [])).data('delivery-manager-names', joinOriginalList(product.deliveryManagerContacts || []));

                var phaseHtml = hasPhase
                    ? '<i class="fas fa-check-square text-success completion-icon" title="Phase assigned"></i>'
                    : '<i class="fas fa-times-square text-danger completion-icon" title="Phase missing"></i>';
                var businessAreaHtml = hasBusinessArea
                    ? '<i class="fas fa-check-square text-success completion-icon" title="Business area: ' + escapeHtml(businessArea) + '"></i>'
                    : '<i class="fas fa-times-square text-danger completion-icon" title="Business area missing"></i>';
                var contactsHtml = contactsCount > 0
                    ? '<i class="fas fa-check-square text-success completion-icon" title="' + contactsCount + ' contact(s)"></i><span class="completion-count">' + contactsCount + '</span>'
                    : '<i class="fas fa-times-square text-danger completion-icon" title="No contacts"></i><span class="completion-count">0</span>';
                var productUrlHtml = hasProductUrl
                    ? '<i class="fas fa-check-square text-success completion-icon" title="Product URL provided"></i>'
                    : '<i class="fas fa-times-square text-danger completion-icon" title="Product URL missing"></i>';
                var userGroupsHtml = userGroupsCount > 0
                    ? '<i class="fas fa-check-square text-success completion-icon" title="' + escapeHtml(userGroupTitle) + '"></i><span class="completion-count">' + userGroupsCount + '</span>'
                    : '<i class="fas fa-times-square text-danger completion-icon" title="No user groups"></i><span class="completion-count">0</span>';

                $row.find('td').eq(2).html(phaseHtml);
                $row.find('td').eq(3).html(businessAreaHtml);
                $row.find('td').eq(4).html(contactsHtml);
                $row.find('td').eq(5).html(productUrlHtml);
                $row.find('td').eq(6).html(userGroupsHtml);
                $row.find('td').eq(7).text(completion.toFixed(1) + '%');
            }

            function refreshBusinessAreaFilterOptions() {
                var $filter = $('#businessAreaFilter');
                var selectedValue = $filter.val();
                var areas = {};

                $('#completionTable tbody tr').each(function() {
                    var value = ($(this).attr('data-business-area') || 'Unassigned').toString();
                    if (!areas[value]) {
                        areas[value] = true;
                    }
                });

                var areaList = Object.keys(areas).sort(function(a, b) { return a.localeCompare(b); });
                $filter.empty();
                $filter.append('<option value="">All business areas</option>');
                areaList.forEach(function(area) {
                    var selected = selectedValue === area ? ' selected' : '';
                    $filter.append('<option value="' + escapeHtml(area) + '"' + selected + '>' + escapeHtml(area) + '</option>');
                });
            }

            function recalculateSummary() {
                var $rows = $('#completionTable tbody tr');
                var total = $rows.length;
                var completionSum = 0;
                var zeroCount = 0;
                var fullCount = 0;
                var phaseCount = 0;
                var businessAreaCount = 0;
                var urlCount = 0;
                var businessAreaMap = {};

                $rows.each(function() {
                    var $row = $(this);
                    var completion = parseFloat($row.attr('data-completion')) || 0;
                    completionSum += completion;
                    if (Math.abs(completion) < 0.0001) zeroCount++;
                    if (Math.abs(completion - 100) < 0.0001) fullCount++;
                    if (isTruthy($row.attr('data-has-phase'))) phaseCount++;
                    if (isTruthy($row.attr('data-has-business-area'))) businessAreaCount++;
                    if (isTruthy($row.attr('data-has-product-url'))) urlCount++;

                    var areaName = ($row.attr('data-business-area') || 'Unassigned').toString();
                    if (!businessAreaMap[areaName]) {
                        businessAreaMap[areaName] = { count: 0, sum: 0 };
                    }
                    businessAreaMap[areaName].count++;
                    businessAreaMap[areaName].sum += completion;
                });

                var average = total ? completionSum / total : 0;
                updateAverageCard(total, average);
                updateZeroCard(total, zeroCount);
                updateFullCard(total, fullCount);
                updateCompletionCard('#completedPhaseCard', '#completedPhaseValue', '#completedPhaseText', '#completedPhaseProgress', phaseCount, total);
                updateCompletionCard('#completedBusinessAreaCard', '#completedBusinessAreaValue', '#completedBusinessAreaText', '#completedBusinessAreaProgress', businessAreaCount, total);
                updateCompletionCard('#completedUrlCard', '#completedUrlValue', '#completedUrlText', '#completedUrlProgress', urlCount, total);
                rebuildBusinessAreaTable(businessAreaMap);
                refreshBusinessAreaFilterOptions();
                refreshContactFilterOptions();
            }

            function updateAverageCard(total, average) {
                var cardClass = getCompletionBracket(average);
                $('#averageCompletionCard').removeClass('card-success card-warning card-danger').addClass('card-' + cardClass);
                $('#averageCompletionValue').text(average.toFixed(1) + '%');
                $('#averageCompletionSubtitle').text('Based on ' + total + ' ' + formatProductLabel(total));
                $('#averageCompletionProgress').removeClass('bg-success bg-warning bg-danger').addClass('bg-' + cardClass).css('width', average + '%');
            }

            function updateZeroCard(total, zeroCount) {
                var zeroPercentage = total ? (zeroCount / total) * 100 : 0;
                var cardClass = zeroCount > 0 ? 'card-danger' : 'card-success';
                var barClass = zeroCount > 0 ? 'bg-danger' : 'bg-success';
                var text;

                if (zeroCount === 0) {
                    text = 'All products have at least some completion data';
                } else if (zeroCount === 1) {
                    text = 'product has no completion data';
                } else {
                    text = 'products have no completion data';
                }

                $('#zeroCompletionCard').removeClass('card-success card-danger').addClass(cardClass);
                $('#zeroCompletionValue').text(zeroCount);
                $('#zeroCompletionText').text(text + ' (' + zeroPercentage.toFixed(1) + '%)');
                $('#zeroCompletionProgress').removeClass('bg-success bg-danger').addClass(barClass).css('width', zeroPercentage + '%');
            }

            function updateFullCard(total, fullCount) {
                var fullPercentage = total ? (fullCount / total) * 100 : 0;
                var cardClass = (fullCount === total && total > 0) ? 'card-success' : 'card-info';
                var fullColorClass = fullPercentage >= 80 ? 'success' : fullPercentage >= 50 ? 'warning' : 'info';
                var text;

                if (fullCount === 0) {
                    text = 'No products fully complete yet';
                } else if (fullCount === 1) {
                    text = 'product is fully complete';
                } else {
                    text = 'products are fully complete';
                }

                $('#fullCompletionCard').removeClass('card-success card-info').addClass(cardClass);
                $('#fullCompletionValue').text(fullCount);
                $('#fullCompletionText').text(text + ' (' + fullPercentage.toFixed(1) + '%)');
                $('#fullCompletionProgress').removeClass('bg-success bg-warning bg-info').addClass('bg-' + fullColorClass).css('width', fullPercentage + '%');
            }

            function updateCompletionCard(cardSelector, valueSelector, textSelector, progressSelector, completedCount, total) {
                var percentage = total ? (completedCount / total) * 100 : 0;
                var cardClass = getCompletionBracket(percentage);
                $(cardSelector).removeClass('card-success card-warning card-danger').addClass('card-' + cardClass);
                $(valueSelector).text(completedCount);
                $(textSelector).text('of ' + total + ' ' + formatProductLabel(total) + ' (' + percentage.toFixed(1) + '%)');
                $(progressSelector).removeClass('bg-success bg-warning bg-danger').addClass('bg-' + cardClass).css('width', percentage + '%');
            }

            function rebuildBusinessAreaTable(businessAreaMap) {
                var $tbody = $('#businessAreaTableBody');
                $tbody.empty();

                var areas = Object.keys(businessAreaMap).map(function(name) {
                    var entry = businessAreaMap[name];
                    var average = entry.count ? entry.sum / entry.count : 0;
                    return {
                        name: name,
                        count: entry.count,
                        average: average
                    };
                }).sort(function(a, b) {
                    return b.average - a.average;
                });

                areas.forEach(function(area) {
                    var completionClass = getCompletionBracket(area.average);
                    var $tr = $('<tr>');
                    $tr.append($('<td>').html('<strong>' + escapeHtml(area.name) + '</strong>'));
                    $tr.append($('<td class="text-center">').html('<span class="badge badge-info">' + area.count + '</span>'));
                    $tr.append($('<td class="text-center">').html('<span class="badge badge-' + completionClass + ' badge-lg">' + area.average.toFixed(1) + '%</span>'));
                    var $progressCell = $('<td>');
                    var $progress = $('<div class="progress progress-sm">');
                    var $bar = $('<div class="progress-bar">').addClass('bg-' + completionClass).css('width', area.average + '%');
                    $progress.append($bar);
                    $progressCell.append($progress);
                    $tr.append($progressCell);
                    $tbody.append($tr);
                });
            }

            function getCompletionBracket(value) {
                if (value >= 80) return 'success';
                if (value >= 60) return 'warning';
                return 'danger';
            }

            function formatProductLabel(count) {
                return 'product' + (count === 1 ? '' : 's');
            }

            function isTruthy(value) {
                if (typeof value === 'boolean') {
                    return value;
                }
                if (typeof value === 'string') {
                    return value.toLowerCase() === 'true';
                }
                return false;
            }

            function filterTable() {
                var searchTerm = ($('#searchInput').val() || '').toString().toLowerCase();
                var completionFilter = ($('#completionFilter').val() || '').toString();
                var statusFilter = ($('#statusFilter').val() || '').toString();
                var businessAreaFilter = ($('#businessAreaFilter').val() || '').toString();
                var sroFilter = ($('#sroFilter').val() || '').toString();
                var iaoFilter = ($('#iaoFilter').val() || '').toString();
                var deliveryFilter = ($('#deliveryManagerFilter').val() || '').toString();

                var visibleCount = 0;

                $('#completionTable tbody tr').each(function() {
                    var $row = $(this);
                    var productTitle = ($row.attr('data-product-title') || '').toString();
                    var fipsId = ($row.attr('data-fips-id') || '').toString();
                    var completion = parseFloat($row.attr('data-completion')) || 0;
                    var businessArea = ($row.attr('data-business-area') || '').toString();
                    var rowSro = splitDataList($row.attr('data-sro'));
                    var rowIao = splitDataList($row.attr('data-iao'));
                    var rowDelivery = splitDataList($row.attr('data-delivery-manager'));

                    var matchesSearch = !searchTerm || productTitle.includes(searchTerm) || fipsId.includes(searchTerm);
                    var matchesBusinessArea = !businessAreaFilter || businessArea === businessAreaFilter;

                    var matchesCompletion = true;
                    if (completionFilter) {
                        if (completionFilter === '100') {
                            matchesCompletion = completion === 100;
                        } else if (completionFilter === '80-99') {
                            matchesCompletion = completion >= 80 && completion < 100;
                        } else if (completionFilter === '60-79') {
                            matchesCompletion = completion >= 60 && completion < 80;
                        } else if (completionFilter === '40-59') {
                            matchesCompletion = completion >= 40 && completion < 60;
                        } else if (completionFilter === '0-39') {
                            matchesCompletion = completion >= 0 && completion < 40;
                        }
                    }

                    var matchesStatus = true;
                    if (statusFilter === 'complete') {
                        matchesStatus = completion === 100;
                    } else if (statusFilter === 'incomplete') {
                        matchesStatus = completion < 100;
                    }

                    var matchesSro = !sroFilter || rowSro.indexOf(sroFilter) !== -1;
                    var matchesIao = !iaoFilter || rowIao.indexOf(iaoFilter) !== -1;
                    var matchesDelivery = !deliveryFilter || rowDelivery.indexOf(deliveryFilter) !== -1;

                    if (matchesSearch && matchesCompletion && matchesStatus && matchesBusinessArea && matchesSro && matchesIao && matchesDelivery) {
                        $row.show();
                        visibleCount++;
                    } else {
                        $row.hide();
                    }
                });

                $('#productCount').text(visibleCount + ' ' + formatProductLabel(visibleCount));
            }

            function refreshContactFilterOptions() {
                rebuildContactFilter('#sroFilter', 'data-sro-names');
                rebuildContactFilter('#iaoFilter', 'data-iao-names');
                rebuildContactFilter('#deliveryManagerFilter', 'data-delivery-manager-names');
                $('.filter-search').each(function() {
                    applyFilterSearch($(this));
                });
            }

            function rebuildContactFilter(selector, attrName) {
                var $select = $(selector);
                var selectedValue = ($select.val() || '').toString();
                var names = {};

                $('#completionTable tbody tr').each(function() {
                    var attr = ($(this).attr(attrName) || '').toString();
                    if (!attr) {
                        return;
                    }
                    attr.split('||').forEach(function(name) {
                        var trimmed = (name || '').trim();
                        if (trimmed) {
                            names[trimmed] = true;
                        }
                    });
                });

                var sorted = Object.keys(names).sort(function(a, b) {
                    return a.localeCompare(b, undefined, { sensitivity: 'base' });
                });

                $select.empty();
                $select.append('<option value="">All contacts</option>');

                var hasSelected = false;
                sorted.forEach(function(name) {
                    var value = name.toLowerCase();
                    var isSelected = value === selectedValue;
                    if (isSelected) {
                        hasSelected = true;
                    }
                    $select.append('<option value="' + escapeHtml(value) + '"' + (isSelected ? ' selected' : '') + '>' + escapeHtml(name) + '</option>');
                });

                if (selectedValue && !hasSelected) {
                    $select.val('');
                }
            }

            $('.filter-search').on('input', function() {
                applyFilterSearch($(this));
            });

            function applyFilterSearch($input) {
                var term = ($input.val() || '').toString().toLowerCase();
                var targetSelector = $input.data('target');
                if (!targetSelector) {
                    return;
                }
                var $select = $(targetSelector);
                if (!$select.length) {
                    return;
                }
                $select.find('option').each(function(index) {
                    if (index === 0) {
                        $(this).prop('hidden', false);
                        return;
                    }
                    var text = $(this).text().toLowerCase();
                    var match = !term || text.indexOf(term) !== -1;
                    $(this).prop('hidden', !match);
                });
            }

            function splitDataList(value) {
                if (!value) {
                    return [];
                }
                return value.toString().split('||').map(function(item) {
                    return item.trim();
                }).filter(Boolean);
            }

            function initializeSortableTable(table) {
                var currentSort = { column: null, direction: 'asc' };
                
                table.find('.sortable').on('click keypress', function(e) {
                    if (e.type === 'keypress' && e.which !== 13 && e.which !== 32) {
                        return;
                    }
                    
                    var column = $(this).data('column');
                    var direction = 'asc';
                    
                    if (currentSort.column === column && currentSort.direction === 'asc') {
                        direction = 'desc';
                    }
                    
                    sortTable(table, column, direction);
                    currentSort = { column: column, direction: direction };
                });
                
                function sortTable(table, column, direction) {
                    var tbody = table.find('tbody');
                    var rows = tbody.find('tr:visible').toArray();
                    
                    rows.sort(function(a, b) {
                        var aVal, bVal;
                        
                        if (column === 'ProductTitle') {
                            aVal = $(a).find('td').eq(0).find('a').text().trim().toLowerCase();
                            bVal = $(b).find('td').eq(0).find('a').text().trim().toLowerCase();
                        } else if (column === 'FipsId') {
                            aVal = $(a).find('td').eq(1).text().trim().toLowerCase();
                            bVal = $(b).find('td').eq(1).text().trim().toLowerCase();
                        } else if (column === 'Phase') {
                            aVal = $(a).find('td').eq(2).find('.fa-check-square').length > 0 ? 1 : 0;
                            bVal = $(b).find('td').eq(2).find('.fa-check-square').length > 0 ? 1 : 0;
                        } else if (column === 'BusinessArea') {
                            aVal = $(a).find('td').eq(3).find('.fa-check-square').length > 0 ? 1 : 0;
                            bVal = $(b).find('td').eq(3).find('.fa-check-square').length > 0 ? 1 : 0;
                        } else if (column === 'Contacts') {
                            var aText = $(a).find('td').eq(4).text().trim();
                            var bText = $(b).find('td').eq(4).text().trim();
                            aVal = parseInt(aText.match(/\d+/)?.[0]) || 0;
                            bVal = parseInt(bText.match(/\d+/)?.[0]) || 0;
                        } else if (column === 'ProductUrl') {
                            aVal = $(a).find('td').eq(5).find('.fa-check-square').length > 0 ? 1 : 0;
                            bVal = $(b).find('td').eq(5).find('.fa-check-square').length > 0 ? 1 : 0;
                        } else if (column === 'UserGroups') {
                            var aText = $(a).find('td').eq(6).text().trim();
                            var bText = $(b).find('td').eq(6).text().trim();
                            aVal = parseInt(aText.match(/\d+/)?.[0]) || 0;
                            bVal = parseInt(bText.match(/\d+/)?.[0]) || 0;
                        } else if (column === 'CompletionPercentage') {
                            aVal = parseFloat($(a).data('completion')) || 0;
                            bVal = parseFloat($(b).data('completion')) || 0;
                        } else {
                            aVal = $(a).find('td').eq(0).text().trim();
                            bVal = $(b).find('td').eq(0).text().trim();
                        }
                        
                        if (typeof aVal === 'string') {
                            if (direction === 'asc') {
                                return aVal.localeCompare(bVal);
                            } else {
                                return bVal.localeCompare(aVal);
                            }
                        } else {
                            if (direction === 'asc') {
                                return aVal > bVal ? 1 : aVal < bVal ? -1 : 0;
                            } else {
                                return aVal < bVal ? 1 : aVal > bVal ? -1 : 0;
                            }
                        }
                    });
                    
                    // Store hidden rows
                    var hiddenRows = tbody.find('tr:hidden').detach();
                    
                    // Clear tbody and append sorted visible rows
                    tbody.empty();
                    rows.forEach(function(row) {
                        tbody.append(row);
                    });
                    
                    // Re-append hidden rows
                    tbody.append(hiddenRows);
                    
                    // Update sort icons
                    updateSortIcons(table, column, direction);
                }
                
                function updateSortIcons(table, column, direction) {
                    // Remove all sort icons
                    table.find('.sortable i').remove();
                    
                    // Add sort icon to current column
                    var header = table.find('.sortable[data-column="' + column + '"]');
                    var iconClass = direction === 'asc' ? 'fa-sort-up' : 'fa-sort-down';
                    header.append(' <i class="fas ' + iconClass + '"></i>');
                }
            }
        });
    </script>
}

