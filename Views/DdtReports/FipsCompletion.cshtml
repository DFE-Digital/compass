@model Compass.Models.FipsCompletionViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "FIPS Completion %";
    var fipsBaseUrl = Configuration["fipsProduct:baseUrl"] ?? "https://find-products-services-test.azurewebsites.net/";
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-6">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">DDT Reports</a></li>
                    <li class="breadcrumb-item active">FIPS Completion %</li>
                </ol>
                <h1 class="m-0">FIPS Completion %</h1>
                <p class="text-muted mb-0">
                    <small>
                        Showing Active products only. 
                        <a asp-action="AllCmsData" class="font-weight-bold">View all CMS data</a> (includes Active, New, Rejected, Deleted) | 
                        <a asp-action="MultipleBusinessAreas" class="font-weight-bold text-warning">View products with multiple business areas</a>
                    </small>
                </p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @Html.Raw(TempData["SuccessMessage"])
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        <div id="inlineAlertContainer"></div>

        <!-- Summary Cards -->
        <div class="row mb-3">
            <!-- Business Area Completion -->
            <div class="col-lg-8 col-md-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            Completion by business area
                        </h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Business area</th>
                                        <th class="text-center">Products</th>
                                        <th class="text-center">Average completion</th>
                                        <th class="text-center" style="width: 200px;">Progress</th>
                                    </tr>
                                </thead>
                                <tbody id="businessAreaTableBody">
                                    @foreach (var area in Model.BusinessAreaCompletions)
                                    {
                                        var completionClass = area.AverageCompletionPercentage >= 80 ? "success" : 
                                                            area.AverageCompletionPercentage >= 60 ? "warning" : "danger";
                                        <tr>
                                            <td>
                                                <strong>@area.BusinessArea</strong>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge badge-info">@area.ProductCount</span>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge badge-@completionClass badge-lg">
                                                    @area.AverageCompletionPercentage.ToString("F1")%
                                                </span>
                                            </td>
                                            <td>
                                                <div class="progress progress-sm">
                                                    <div class="progress-bar bg-@completionClass" 
                                                         style="width: @area.AverageCompletionPercentage%"></div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side Cards -->
            <div class="col-lg-4 col-md-12">
                <!-- Average Completion Summary -->
                <div class="card @(Model.AverageCompletionPercentage >= 80 ? "card-success" : Model.AverageCompletionPercentage >= 60 ? "card-warning" : "card-danger") mb-3" id="averageCompletionCard">
                    <div class="card-header">
                        <h3 class="card-title">
                            Average completion across all products
                        </h3>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0" style="font-size: 3rem; font-weight: bold;" id="averageCompletionValue">@Model.AverageCompletionPercentage.ToString("F1")%</h2>
                        <p class="text-muted mb-0 mt-2" id="averageCompletionSubtitle">Based on @Model.Products.Count products</p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar @(Model.AverageCompletionPercentage >= 80 ? "bg-success" : Model.AverageCompletionPercentage >= 60 ? "bg-warning" : "bg-danger")" 
                                 style="width: @Model.AverageCompletionPercentage%" id="averageCompletionProgress"></div>
                        </div>
                    </div>
                </div>

                <!-- Zero Completion Count -->
                <div class="card @(Model.ZeroCompletionCount > 0 ? "card-danger" : "card-success") mb-3" id="zeroCompletionCard">
                    <div class="card-header">
                        <h3 class="card-title">
                            Products at 0% completion
                        </h3>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0" style="font-size: 3rem; font-weight: bold;" id="zeroCompletionValue">@Model.ZeroCompletionCount</h2>
                        <p class="text-muted mb-0 mt-2">
                            @{
                                var zeroPercentage = Model.Products.Any() ? (Model.ZeroCompletionCount / (double)Model.Products.Count) * 100 : 0;
                            }
                            @if (Model.ZeroCompletionCount == 0)
                            {
                                <span id="zeroCompletionText">All products have at least some completion data (@zeroPercentage.ToString("F1")%)</span>
                            }
                            else if (Model.ZeroCompletionCount == 1)
                            {
                                <span id="zeroCompletionText">product has no completion data (@zeroPercentage.ToString("F1")%)</span>
                            }
                            else
                            {
                                <span id="zeroCompletionText">products have no completion data (@zeroPercentage.ToString("F1")%)</span>
                            }
                        </p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar @(Model.ZeroCompletionCount > 0 ? "bg-danger" : "bg-success")" 
                                 style="width: @zeroPercentage%" id="zeroCompletionProgress"></div>
                        </div>
                    </div>
                </div>

                <!-- Full Completion Count -->
                <div class="card @(Model.FullCompletionCount == Model.Products.Count ? "card-success" : "card-info")" id="fullCompletionCard">
                    <div class="card-header">
                        <h3 class="card-title">
                            Products with 100% completion
                        </h3>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0" style="font-size: 3rem; font-weight: bold;" id="fullCompletionValue">@Model.FullCompletionCount</h2>
                        <p class="text-muted mb-0 mt-2">
                            @{
                                var fullPercentage = Model.Products.Any() ? (Model.FullCompletionCount / (double)Model.Products.Count) * 100 : 0;
                                var fullColorClass = fullPercentage >= 80 ? "success" : fullPercentage >= 50 ? "warning" : "info";
                            }
                            @if (Model.FullCompletionCount == 0)
                            {
                                <span id="fullCompletionText">No products fully complete yet (@fullPercentage.ToString("F1")%)</span>
                            }
                            else if (Model.FullCompletionCount == 1)
                            {
                                <span id="fullCompletionText">product is fully complete (@fullPercentage.ToString("F1")%)</span>
                            }
                            else
                            {
                                <span id="fullCompletionText">products are fully complete (@fullPercentage.ToString("F1")%)</span>
                            }
                        </p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar bg-@fullColorClass" 
                                 style="width: @fullPercentage%" id="fullCompletionProgress"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Completion Stats -->
        <div class="row mb-3">
            <div class="col-lg-4 col-md-4 col-12">
                @{
                    var phasePercentage = Model.Products.Any() ? (Model.CompletedPhaseCount / (double)Model.Products.Count) * 100 : 0;
                    var phaseColorClass = phasePercentage >= 80 ? "success" : phasePercentage >= 50 ? "warning" : "danger";
                }
                <div class="card card-@phaseColorClass" id="completedPhaseCard">
                    <div class="card-header">
                        <h3 class="card-title">
                            Completed Phase
                        </h3>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0" style="font-size: 3rem; font-weight: bold;" id="completedPhaseValue">@Model.CompletedPhaseCount</h2>
                        <p class="text-muted mb-0 mt-2" id="completedPhaseText">of @Model.Products.Count products (@phasePercentage.ToString("F1")%)</p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar bg-@phaseColorClass" style="width: @phasePercentage%" id="completedPhaseProgress"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-4 col-12">
                @{
                    var businessAreaPercentage = Model.Products.Any() ? (Model.CompletedBusinessAreaCount / (double)Model.Products.Count) * 100 : 0;
                    var businessAreaColorClass = businessAreaPercentage >= 80 ? "success" : businessAreaPercentage >= 50 ? "warning" : "danger";
                }
                <div class="card card-@businessAreaColorClass" id="completedBusinessAreaCard">
                    <div class="card-header">
                        <h3 class="card-title">
                            Completed Business Area
                        </h3>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0" style="font-size: 3rem; font-weight: bold;" id="completedBusinessAreaValue">@Model.CompletedBusinessAreaCount</h2>
                        <p class="text-muted mb-0 mt-2" id="completedBusinessAreaText">of @Model.Products.Count products (@businessAreaPercentage.ToString("F1")%)</p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar bg-@businessAreaColorClass" style="width: @businessAreaPercentage%" id="completedBusinessAreaProgress"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4 col-md-4 col-12">
                @{
                    var urlPercentage = Model.Products.Any() ? (Model.CompletedUrlCount / (double)Model.Products.Count) * 100 : 0;
                    var urlColorClass = urlPercentage >= 80 ? "success" : urlPercentage >= 50 ? "warning" : "danger";
                }
                <div class="card card-@urlColorClass" id="completedUrlCard">
                    <div class="card-header">
                        <h3 class="card-title">
                            Completed URL
                        </h3>
                    </div>
                    <div class="card-body text-center">
                        <h2 class="mb-0" style="font-size: 3rem; font-weight: bold;" id="completedUrlValue">@Model.CompletedUrlCount</h2>
                        <p class="text-muted mb-0 mt-2" id="completedUrlText">of @Model.Products.Count products (@urlPercentage.ToString("F1")%)</p>
                        <div class="progress progress-lg mt-3">
                            <div class="progress-bar bg-@urlColorClass" style="width: @urlPercentage%" id="completedUrlProgress"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @{
            var sroOptions = Model.Products
                .SelectMany(p => p.SeniorResponsibleOfficerContacts ?? new List<string>())
                .Where(option => !string.IsNullOrWhiteSpace(option))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(option => option, StringComparer.OrdinalIgnoreCase)
                .ToList();

            var iaoOptions = Model.Products
                .SelectMany(p => p.InformationAssetOwnerContacts ?? new List<string>())
                .Where(option => !string.IsNullOrWhiteSpace(option))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(option => option, StringComparer.OrdinalIgnoreCase)
                .ToList();

            var deliveryManagerOptions = Model.Products
                .SelectMany(p => p.DeliveryManagerContacts ?? new List<string>())
                .Where(option => !string.IsNullOrWhiteSpace(option))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(option => option, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }

        <!-- Filters -->
        <div class="row mb-3">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            Filter products
                        </h3>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-lg-4 col-md-6 col-12">
                                <div class="form-group">
                                    <label for="searchInput">Search by product name or FIPS ID</label>
                                    <input type="text" class="form-control" id="searchInput" placeholder="Search products...">
                                </div>
                            </div>
                            <div class="col-lg-2 col-md-6 col-12">
                                <div class="form-group">
                                    <label for="businessAreaFilter">Business area</label>
                                    <select class="form-control" id="businessAreaFilter">
                                        <option value="">All business areas</option>
                                        @foreach (var area in Model.BusinessAreaCompletions.OrderBy(a => a.BusinessArea))
                                        {
                                            <option value="@area.BusinessArea">@area.BusinessArea</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 col-12">
                                <div class="form-group">
                                    <label for="completionFilter">Filter by completion %</label>
                                    <select class="form-control" id="completionFilter">
                                        <option value="">All products</option>
                                        <option value="100">100% Complete</option>
                                        <option value="80-99">80-99%</option>
                                        <option value="60-79">60-79%</option>
                                        <option value="40-59">40-59%</option>
                                        <option value="0-39">0-39%</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6 col-12">
                                <div class="form-group">
                                    <label for="statusFilter">Filter by status</label>
                                    <select class="form-control" id="statusFilter">
                                        <option value="">All products</option>
                                        <option value="complete">Complete (100%)</option>
                                        <option value="incomplete">Incomplete (&lt;100%)</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-lg-4 col-md-6 col-12">
                                <div class="form-group">
                                    <label for="sroFilter">Senior responsible officer</label>
                                    <input type="text" class="form-control form-control-sm filter-search mb-2" data-target="#sroFilter" placeholder="Search users" aria-label="Search senior responsible officer">
                                    <select class="form-control" id="sroFilter">
                                        <option value="">All contacts</option>
                                        @foreach (var option in sroOptions)
                                        {
                                            var optionValue = option.ToLowerInvariant();
                                            <option value="@optionValue">@option</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6 col-12">
                                <div class="form-group">
                                    <label for="iaoFilter">Information asset owner</label>
                                    <input type="text" class="form-control form-control-sm filter-search mb-2" data-target="#iaoFilter" placeholder="Search users" aria-label="Search information asset owner">
                                    <select class="form-control" id="iaoFilter">
                                        <option value="">All contacts</option>
                                        @foreach (var option in iaoOptions)
                                        {
                                            var optionValue = option.ToLowerInvariant();
                                            <option value="@optionValue">@option</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6 col-12">
                                <div class="form-group">
                                    <label for="deliveryManagerFilter">Delivery manager</label>
                                    <input type="text" class="form-control form-control-sm filter-search mb-2" data-target="#deliveryManagerFilter" placeholder="Search users" aria-label="Search delivery manager">
                                    <select class="form-control" id="deliveryManagerFilter">
                                        <option value="">All contacts</option>
                                        @foreach (var option in deliveryManagerOptions)
                                        {
                                            var optionValue = option.ToLowerInvariant();
                                            <option value="@optionValue">@option</option>
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Completion Table -->
        <div class="row">
            <div class="col-lg-12">
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">
                            Product completion status
                        </h3>
                        <div class="card-tools">
                            <a asp-action="ExportFipsCompletion" class="btn btn-outline-success btn-sm mr-2">
                                <i class="fas fa-file-excel mr-1"></i> Export to Excel
                            </a>
                            <span class="badge badge-info" id="productCount">@Model.Products.Count products</span>
                        </div>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover mb-0 sortable-table" id="completionTable">
                            <thead>
                                <tr>
                                    <th class="sortable" data-column="ProductTitle" style="cursor: pointer;">
                                        Product <i class="fas fa-sort"></i>
                                    </th>
                                    <th class="sortable" data-column="FipsId" style="cursor: pointer;">
                                        FIPS ID <i class="fas fa-sort"></i>
                                    </th>
                                    <th class="text-center sortable" data-column="Phase" style="cursor: pointer;">
                                        Phase <i class="fas fa-sort"></i>
                                    </th>
                                    <th class="text-center sortable" data-column="BusinessArea" style="cursor: pointer;">
                                        Business area <i class="fas fa-sort"></i>
                                    </th>
                                    <th class="text-center sortable" data-column="Contacts" style="cursor: pointer;">
                                        Contacts <i class="fas fa-sort"></i>
                                    </th>
                                    <th class="text-center sortable" data-column="ProductUrl" style="cursor: pointer;">
                                        Product URL <i class="fas fa-sort"></i>
                                    </th>
                                    <th class="text-center sortable" data-column="UserGroups" style="cursor: pointer;">
                                        User groups <i class="fas fa-sort"></i>
                                    </th>
                                    <th class="text-center sortable" data-column="CompletionPercentage" style="cursor: pointer;">
                                        Completion % <i class="fas fa-sort"></i>
                                    </th>
                                    <th class="text-center" style="width: 100px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in Model.Products)
                                {
                                    var sroDisplayList = product.SeniorResponsibleOfficerContacts ?? new List<string>();
                                    var iaoDisplayList = product.InformationAssetOwnerContacts ?? new List<string>();
                                    var deliveryDisplayList = product.DeliveryManagerContacts ?? new List<string>();
                                    var sroDataValue = string.Join("||", sroDisplayList.Select(c => c.ToLowerInvariant()));
                                    var iaoDataValue = string.Join("||", iaoDisplayList.Select(c => c.ToLowerInvariant()));
                                    var deliveryManagerDataValue = string.Join("||", deliveryDisplayList.Select(c => c.ToLowerInvariant()));
                                    var userGroupDataValue = string.Join("||", (product.UserGroupNames ?? new List<string>()).Select(c => c.ToLowerInvariant()));
                                    var userGroupIdsDataValue = string.Join(",", product.UserGroupCategoryValueIds ?? new List<int>());
                                    var userGroupTitle = product.UserGroupNames.Any()
                                        ? string.Join(", ", product.UserGroupNames)
                                        : "No user groups";
                                    <tr data-product-title="@product.ProductTitle.ToLowerInvariant()" 
                                        data-fips-id="@product.FipsId.ToLowerInvariant()"
                                        data-completion="@product.CompletionPercentage"
                                        data-business-area="@product.BusinessArea"
                                        data-has-phase="@(product.HasPhase ? "true" : "false")"
                                        data-has-business-area="@(product.HasBusinessArea ? "true" : "false")"
                                        data-has-product-url="@(product.HasProductUrl ? "true" : "false")"
                                        data-user-groups-count="@product.UserGroupsCount"
                                        data-user-groups="@userGroupDataValue"
                                        data-user-group-ids="@userGroupIdsDataValue"
                                        data-contacts-count="@product.ContactsCount"
                                        data-sro="@sroDataValue"
                                        data-sro-names="@string.Join("||", sroDisplayList)"
                                        data-sro-display="@product.SeniorResponsibleOfficer"
                                        data-iao="@iaoDataValue"
                                        data-iao-names="@string.Join("||", iaoDisplayList)"
                                        data-iao-display="@product.InformationAssetOwner"
                                        data-delivery-manager="@deliveryManagerDataValue"
                                        data-delivery-manager-names="@string.Join("||", deliveryDisplayList)"
                                        data-delivery-manager-display="@product.DeliveryManager">
                                        <td>
                                            <a href="@($"{fipsBaseUrl.TrimEnd('/')}/product/{product.FipsId}")" target="_blank" rel="noopener noreferrer" class="font-weight-bold">
                                                @product.ProductTitle
                                            </a>
                                        </td>
                                        <td>
                                            @product.FipsId
                                        </td>
                                        <td class="text-center">
                                            @if (product.HasPhase)
                                            {
                                                <i class="fas fa-check-square text-success completion-icon" title="Phase assigned"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-times-square text-danger completion-icon" title="Phase missing"></i>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (product.HasBusinessArea)
                                            {
                                                <i class="fas fa-check-square text-success completion-icon" title="@($"Business area: {product.BusinessArea}")"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-times-square text-danger completion-icon" title="Business area missing"></i>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (product.ContactsCount > 0)
                                            {
                                                <i class="fas fa-check-square text-success completion-icon" title="@product.ContactsCount contact(s)"></i><span class="completion-count">@product.ContactsCount</span>
                                            }
                                            else
                                            {
                                                <i class="fas fa-times-square text-danger completion-icon" title="No contacts"></i><span class="completion-count">0</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (product.HasProductUrl)
                                            {
                                                <i class="fas fa-check-square text-success completion-icon" title="Product URL provided"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-times-square text-danger completion-icon" title="Product URL missing"></i>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (product.UserGroupsCount > 0)
                                            {
                                                <i class="fas fa-check-square text-success completion-icon" title="@userGroupTitle"></i><span class="completion-count">@product.UserGroupsCount</span>
                                            }
                                            else
                                            {
                                                <i class="fas fa-times-square text-danger completion-icon" title="No user groups"></i><span class="completion-count">0</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @product.CompletionPercentage.ToString("F1")%
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group">
                                                <button type="button" class="btn btn-sm btn-secondary dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                                    <i class="fas fa-cog"></i>
                                                </button>
                                                <div class="dropdown-menu dropdown-menu-right">
                                                    <a class="dropdown-item" href="#" data-action="set-phase" data-fips-id="@product.FipsId">
                                                        <i class="fas fa-layer-group mr-2"></i> Set Phase
                                                    </a>
                                                    <a class="dropdown-item" href="#" data-action="set-business-area" data-fips-id="@product.FipsId">
                                                        <i class="fas fa-building mr-2"></i> Set Business Area
                                                    </a>
                                                    <a class="dropdown-item" href="#" data-action="set-product-url" data-fips-id="@product.FipsId">
                                                        <i class="fas fa-link mr-2"></i> Set Product URL
                                                    </a>
                                                    <a class="dropdown-item" href="#" data-action="set-user-groups" data-fips-id="@product.FipsId">
                                                        <i class="fas fa-users mr-2"></i> Set User Groups
                                                    </a>
                                                    <div class="dropdown-divider"></div>
                                                    <a class="dropdown-item text-danger" href="#" data-action="update-state-rejected" data-fips-id="@product.FipsId" data-product-title="@product.ProductTitle">
                                                        <i class="fas fa-ban mr-2"></i> Update State to Rejected
                                                    </a>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if (!Model.Products.Any())
                        {
                            <div class="text-center text-muted p-5">
                                <i class="fas fa-info-circle fa-3x mb-3"></i>
                                <p class="mb-0">No products found</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@{
    var phaseCategoryValues = ViewBag.PhaseCategoryValues as List<Compass.Models.CategoryValueDto> ?? new List<Compass.Models.CategoryValueDto>();
    var businessAreaCategoryValues = ViewBag.BusinessAreaCategoryValues as List<Compass.Models.CategoryValueDto> ?? new List<Compass.Models.CategoryValueDto>();
    var userGroupCategoryValues = ViewBag.UserGroupCategoryValues as List<Compass.Models.CategoryValueDto> ?? new List<Compass.Models.CategoryValueDto>();
}

<!-- Update Phase Modal -->
