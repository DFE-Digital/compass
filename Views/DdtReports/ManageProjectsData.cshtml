@section Scripts {
    <script src="~/js/user-picker.js" asp-append-version="true"></script>
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            // Initialize sortable table
            function initializeSortableTable($table) {
                $table.find('th.sortable').on('click', function() {
                    var $th = $(this);
                    var column = $th.data('column');
                    var $tbody = $table.find('tbody');
                    var $rows = $tbody.find('tr').toArray();
                    var isAsc = $th.hasClass('sort-asc');
                    
                    $table.find('th.sortable').removeClass('sort-asc sort-desc');
                    
                    $rows.sort(function(a, b) {
                        var aVal = $(a).attr('data-' + column.toLowerCase().replace(/([A-Z])/g, '-$1').toLowerCase()) || '';
                        var bVal = $(b).attr('data-' + column.toLowerCase().replace(/([A-Z])/g, '-$1').toLowerCase()) || '';
                        if (isAsc) {
                            return bVal.localeCompare(aVal);
                        } else {
                            return aVal.localeCompare(bVal);
                        }
                    });
                    
                    $tbody.empty().append($rows);
                    $th.addClass(isAsc ? 'sort-desc' : 'sort-asc');
                });
            }
            
            initializeSortableTable($('#projectsTable'));

            // Filter table
            function filterTable() {
                var searchTerm = $('#searchInput').val().toLowerCase();
                var businessAreaFilter = $('#businessAreaFilter').val();
                var phaseFilter = $('#phaseFilter').val();
                var visibleCount = 0;

                $('#projectsTable tbody tr').each(function() {
                    var $row = $(this);
                    var projectTitle = ($row.attr('data-project-title') || '').toString();
                    var projectCode = ($row.attr('data-project-code') || '').toString();
                    var businessArea = ($row.attr('data-business-area') || '').toString();
                    var phase = ($row.attr('data-phase') || '').toString();

                    var matchesSearch = !searchTerm || projectTitle.includes(searchTerm) || projectCode.includes(searchTerm);
                    var matchesBusinessArea = !businessAreaFilter || businessArea === businessAreaFilter;
                    var matchesPhase = !phaseFilter || phase === phaseFilter;

                    if (matchesSearch && matchesBusinessArea && matchesPhase) {
                        $row.show();
                        visibleCount++;
                    } else {
                        $row.hide();
                    }
                });

                $('#projectCount').text(visibleCount + ' projects');
            }

            $('#searchInput, #businessAreaFilter, #phaseFilter').on('input change', filterTable);
            $('#clearFilters').on('click', function() {
                $('#searchInput').val('');
                $('#businessAreaFilter').val('');
                $('#phaseFilter').val('');
                filterTable();
            });

            // Modal handlers
            $('#projectsTable').on('click', '[data-action]', function(e) {
                e.preventDefault();
                var action = $(this).data('action');
                var projectId = $(this).data('project-id');
                var $row = $(this).closest('tr');

                switch(action) {
                    case 'set-primary-contact':
                        $('#primaryContactProjectId').val(projectId);
                        var currentContactName = $row.find('td').eq(2).find('span').first().text().trim();
                        var currentContactEmail = $row.find('td').eq(2).find('small').text().trim();
                        if (currentContactName && currentContactName !== '-') {
                            $('#primaryContactSearch').val(currentContactName);
                            $('#primaryContactName').val(currentContactName);
                            $('#primaryContactEmail').val(currentContactEmail);
                            $('.js-user-picker-summary').html('<span>' + escapeHtml(currentContactName) + '</span>');
                        } else {
                            $('#primaryContactSearch').val('');
                            $('#primaryContactObjectId').val('');
                            $('#primaryContactEmail').val('');
                            $('#primaryContactName').val('');
                            $('.js-user-picker-summary').html('<span class="text-muted">No primary contact selected.</span>');
                        }
                        $('#clearContactFlag').val('false');
                        $('#updatePrimaryContactModal').modal('show');
                        break;
                    case 'set-business-area':
                        $('#businessAreaProjectId').val(projectId);
                        var currentBusinessArea = $row.attr('data-business-area');
                        $('#businessAreaLookupId').val('');
                        if (currentBusinessArea) {
                            var matchingOption = $('#businessAreaLookupId option').filter(function() {
                                return $(this).text().trim() === currentBusinessArea;
                            });
                            if (matchingOption.length) {
                                $('#businessAreaLookupId').val(matchingOption.val());
                            }
                        }
                        $('#updateBusinessAreaModal').modal('show');
                        break;
                    case 'set-phase':
                        $('#phaseProjectId').val(projectId);
                        var currentPhase = $row.attr('data-phase');
                        $('#phase').val(currentPhase || '');
                        $('#updatePhaseModal').modal('show');
                        break;
                    case 'set-activity-type':
                        $('#activityTypeProjectId').val(projectId);
                        var currentActivityType = $row.attr('data-activity-type');
                        $('#activityTypeLookupId').val('');
                        if (currentActivityType) {
                            var matchingOption = $('#activityTypeLookupId option').filter(function() {
                                return $(this).text().trim() === currentActivityType;
                            });
                            if (matchingOption.length) {
                                $('#activityTypeLookupId').val(matchingOption.val());
                            }
                        }
                        $('#updateActivityTypeModal').modal('show');
                        break;
                    case 'set-risk-appetite':
                        $('#riskAppetiteProjectId').val(projectId);
                        var currentRiskAppetite = $row.attr('data-risk-appetite');
                        $('#riskAppetiteLookupId').val('');
                        if (currentRiskAppetite) {
                            var matchingOption = $('#riskAppetiteLookupId option').filter(function() {
                                return $(this).text().trim() === currentRiskAppetite;
                            });
                            if (matchingOption.length) {
                                $('#riskAppetiteLookupId').val(matchingOption.val());
                            }
                        }
                        $('#updateRiskAppetiteModal').modal('show');
                        break;
                }
            });

            // Clear primary contact
            $('#clearPrimaryContact').on('click', function() {
                $('#primaryContactSearch').val('');
                $('#primaryContactObjectId').val('');
                $('#primaryContactEmail').val('');
                $('#primaryContactName').val('');
                $('#clearContactFlag').val('true');
                $('.js-user-picker-summary').html('<span class="text-muted">No primary contact selected.</span>');
                // Submit the form to clear the contact
                $('#updatePrimaryContactModal form').submit();
            });

            // Setup AJAX form submissions
            function setupAjaxForm(selector, onSuccess) {
                var $form = $(selector);
                $form.on('submit', function(e) {
                    e.preventDefault();
                    var $submitBtn = $form.find('button[type="submit"]');
                    var originalText = $submitBtn.html();
                    $submitBtn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Saving...');

                    var formData = new FormData(this);
                    var token = $('input[name="__RequestVerificationToken"]', $form).val();
                    if (token) {
                        formData.append('__RequestVerificationToken', token);
                    }

                    fetch($form.attr('action'), {
                        method: 'POST',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' },
                        body: formData,
                        credentials: 'same-origin'
                    })
                    .then(function(response) {
                        if (!response.ok) {
                            return response.text().then(function(text) {
                                throw new Error('HTTP error! status: ' + response.status);
                            });
                        }
                        return response.json();
                    })
                    .then(function(data) {
                        if (data && data.success) {
                            showInlineAlert('success', data.message || 'Update successful.');
                            if (onSuccess && data.project) {
                                onSuccess(data.project);
                            }
                            setTimeout(function() {
                                window.location.reload();
                            }, 1500);
                        } else {
                            showInlineAlert('danger', (data && data.message) || 'Update failed. Please try again.');
                            $submitBtn.prop('disabled', false).html(originalText);
                        }
                    })
                    .catch(function(error) {
                        console.error('Error:', error);
                        showInlineAlert('danger', 'An unexpected error occurred. Please try again.');
                        $submitBtn.prop('disabled', false).html(originalText);
                    });
                });
            }

            setupAjaxForm('#updatePrimaryContactModal form', function(project) {
                updateRowWithProject(project);
            });
            setupAjaxForm('#updateBusinessAreaModal form', function(project) {
                updateRowWithProject(project);
            });
            setupAjaxForm('#updatePhaseModal form', function(project) {
                updateRowWithProject(project);
            });
            setupAjaxForm('#updateActivityTypeModal form', function(project) {
                updateRowWithProject(project);
            });
            setupAjaxForm('#updateRiskAppetiteModal form', function(project) {
                updateRowWithProject(project);
            });

            function updateRowWithProject(project) {
                if (!project || !project.id) {
                    return;
                }

                var $row = $('#projectsTable tbody tr').filter(function() {
                    return $(this).attr('data-project-id') === project.id.toString();
                });

                if (!$row.length) {
                    return;
                }

                if (project.primaryContactName !== undefined) {
                    var display = project.primaryContactName 
                        ? project.primaryContactName + (project.primaryContactEmail ? ' (' + project.primaryContactEmail + ')' : '')
                        : '-';
                    $row.find('td').eq(2).html(
                        project.primaryContactName 
                            ? '<span>' + escapeHtml(project.primaryContactName) + '</span><br /><small class="text-muted">' + escapeHtml(project.primaryContactEmail || '') + '</small>'
                            : '<span class="text-muted">-</span>'
                    );
                    $row.attr('data-primary-contact', display.toLowerCase());
                }

                if (project.businessArea !== undefined) {
                    $row.find('td').eq(3).text(project.businessArea || '-');
                    $row.attr('data-business-area', project.businessArea || '');
                }

                if (project.phase !== undefined) {
                    $row.find('td').eq(4).text(project.phase || '-');
                    $row.attr('data-phase', project.phase || '');
                }

                if (project.activityTypeName !== undefined) {
                    $row.find('td').eq(5).text(project.activityTypeName || '-');
                    $row.attr('data-activity-type', project.activityTypeName || '');
                }

                if (project.riskAppetiteName !== undefined) {
                    $row.find('td').eq(6).text(project.riskAppetiteName || '-');
                    $row.attr('data-risk-appetite', project.riskAppetiteName || '');
                }
            }

            function showInlineAlert(type, message) {
                var $container = $('#inlineAlertContainer');
                var alertHtml = '<div class="alert alert-' + type + ' alert-dismissible fade show" role="alert">' +
                    message +
                    '<button type="button" class="close" data-dismiss="alert" aria-label="Close">' +
                    '<span aria-hidden="true">&times;</span>' +
                    '</button>' +
                    '</div>';
                $container.html(alertHtml);
                $container[0].scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }

            function escapeHtml(text) {
                if (!text) return '';
                var map = {
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#039;'
                };
                return text.replace(/[&<>"']/g, function(m) { return map[m]; });
            }

            filterTable();
        });
    </script>
}

