@model List<Compass.Models.Project>

@{
    ViewData["Title"] = $"DDT Reports - {ViewBag.BusinessArea}";
    var currentSection = ViewBag.CurrentSection as string ?? "summary";
    var weekStart = (DateTime)ViewBag.WeekStart;
    var weekEnd = (DateTime)ViewBag.WeekEnd;
    var businessArea = ViewBag.BusinessArea as string;
    
    // Get recent successes (last 30 days)
    var thirtyDaysAgo = DateTime.UtcNow.AddDays(-30);
    var allDdtSuccesses = Model
        .SelectMany(p => p.Successes
            .Where(s => s.IsReportedToSlt && 
                       s.RecordedAt >= thirtyDaysAgo)
            .Select(s => new { Project = p, Success = s }))
        .OrderByDescending(x => x.Success.RecordedAt)
        .Take(10)
        .ToList();
    
    // Milestones due soon (within next 14 days)
    var today = DateTime.Today;
    var twoWeeksFromNow = today.AddDays(14);
    
    // Milestones due soon (not deleted, with due date in next 14 days)
    var milestonesDueSoon = Model
        .SelectMany(p => p.Milestones
            .Where(m => !m.IsDeleted && 
                       m.DueDate >= today && 
                       m.DueDate <= twoWeeksFromNow &&
                       m.Status != "complete")
            .Select(m => new { Project = p, Milestone = m }))
        .OrderBy(x => x.Milestone.DueDate)
        .ToList();
    
    // All active milestones (not deleted, not complete)
    var allActiveMilestones = Model
        .SelectMany(p => p.Milestones
            .Where(m => !m.IsDeleted && m.Status != "complete")
            .Select(m => new { Project = p, Milestone = m }))
        .ToList();
    
    // Get projects with non-green RAG status
    var atRiskProjects = Model.Where(p => p.RagStatus != "Green").ToList();
}

<div class="content-header">
    <div class="container-fluid">
        <div class="row mb-2">
            <div class="col-sm-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/">Home</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">DDT Reports</a></li>
                    <li class="breadcrumb-item active">@businessArea</li>
                </ol>
            </div>
        </div>
        <div class="row mb-2 align-items-center">
            <div class="col-sm-12">
                <h1 class="m-0">@businessArea - DDT Report</h1>
                <p class="text-muted mb-0">Snapshot as of @DateTime.Now.ToString("dd MMMM yyyy HH:mm")</p>
            </div>
        </div>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                <button type="button" class="close" data-dismiss="alert">&times;</button>
                @TempData["ErrorMessage"]
            </div>
        }

        @if (!Model.Any())
        {
            <div class="card">
                <div class="card-body text-center p-5">
                    <i class="fas fa-info-circle fa-3x text-muted mb-3"></i>
                    <h4>No Active Projects</h4>
                    <p class="text-muted">There are no active projects in the @businessArea business area.</p>
                    <a asp-action="Index" class="btn btn-primary mt-3">
                        Back to DDT Reports
                    </a>
                </div>
            </div>
        }
        else
        {
            <!-- Header Banner with Key Metrics -->
            <div class="row mb-4" style="display: flex;">
                <!-- Left side: Title and three metric cards -->
                <div class="col-lg-8" style="display: flex;">
                    <!-- Summary Banner -->
                    <div class="card border-0 w-100" style="background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%); border-radius: 12px;">
                        <div class="card-body p-4">
                            <div class="row align-items-center" style="height: 100%;">
                                <div class="col-md-6">
                                    <p class="text-muted mb-1" style="font-size: 0.9rem;">Snapshot as of @DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
                                    <h2 class="mb-2" style="font-weight: 600; color: #1976D2;">@businessArea</h2>
                                    <p class="text-muted mb-0" style="font-size: 0.95rem;">Current state of projects and milestones</p>
                                </div>
                                <div class="col-md-6">
                                    <div class="d-flex justify-content-start">
                                        <!-- Projects Card -->
                                        <div style="flex: 0 0 33.333%; padding-right: 8px;">
                                            <div class="card border-0 shadow-sm metric-card" style="border-radius: 8px; transition: transform 0.2s, box-shadow 0.2s;">
                                                <div class="card-body p-3">
                                                    <h3 class="mb-1 text-left" style="font-weight: 700; font-size: 1.8rem;">@Model.Count</h3>
                                                    <p class="text-muted mb-0 text-left" style="font-size: 0.85rem;">Projects</p>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- At Risk Card -->
                                        <div style="flex: 0 0 33.333%; padding-right: 8px;">
                                            <div class="card border-0 shadow-sm metric-card" style="border-radius: 8px; transition: transform 0.2s, box-shadow 0.2s;">
                                                <div class="card-body p-3">
                                                    <h3 class="mb-1 text-left" style="font-weight: 700; font-size: 1.8rem;">@atRiskProjects.Count</h3>
                                                    <p class="text-muted mb-0 text-left" style="font-size: 0.85rem;">At risk</p>
                                                </div>
                                            </div>
                                        </div>
                                        <!-- Milestones Card -->
                                        <div style="flex: 0 0 33.333%;">
                                            <div class="card border-0 shadow-sm metric-card" style="border-radius: 8px; transition: transform 0.2s, box-shadow 0.2s;">
                                                <div class="card-body p-3">
                                                    <h3 class="mb-1 text-left" style="font-weight: 700; font-size: 1.8rem;">@allActiveMilestones.Count</h3>
                                                    <p class="text-muted mb-0 text-left" style="font-size: 0.85rem;">Milestones</p>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Right side: What's New card -->
                <div class="col-lg-4" style="display: flex;">
                    <div class="card border-0 shadow-sm w-100 metric-card" style="border-radius: 12px; background: white; transition: transform 0.2s, box-shadow 0.2s;">
                        <div class="card-body p-4">
                            <div style="height: 100%;">
                                <h5 class="mb-2" style="font-weight: 600;">Current status</h5>
                                <p class="text-muted mb-2" style="font-size: 0.9rem;">
                                    <strong>@milestonesDueSoon.Count</strong> milestones due soon<br>
                                    <strong>@allActiveMilestones.Count</strong> active milestones<br>
                                    <strong>@allDdtSuccesses.Count</strong> recent successes
                                </p>
                                <a asp-action="Index" class="btn" style="background: #FF6B35; color: white; border-radius: 6px; font-weight: 500;">
                                    Back to Reports
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- RAG Status Summary -->
            <div class="row mb-4">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <h3 class="card-title">RAG Status Overview</h3>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-lg-3 col-md-6 mb-3">
                                    <div class="card border-left-success shadow-sm">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center">
                                                <div class="flex-grow-1">
                                                    <div class="text-muted text-uppercase mb-1" style="font-size: 0.75rem; font-weight: 600;">Green RAG</div>
                                                    <h2 class="mb-0" style="font-weight: 700; color: #28a745;">@Model.Count(p => p.RagStatus == "Green")</h2>
                                                </div>
                                                <div class="ml-3">
                                                    <i class="fas fa-check-circle fa-2x text-success"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-6 mb-3">
                                    <div class="card border-left-warning shadow-sm">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center">
                                                <div class="flex-grow-1">
                                                    <div class="text-muted text-uppercase mb-1" style="font-size: 0.75rem; font-weight: 600;">Amber RAG</div>
                                                    <h2 class="mb-0" style="font-weight: 700; color: #ffc107;">@Model.Count(p => p.RagStatus == "Amber" || p.RagStatus == "Amber-Green" || p.RagStatus == "Amber-Red")</h2>
                                                </div>
                                                <div class="ml-3">
                                                    <i class="fas fa-exclamation-triangle fa-2x text-warning"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-6 mb-3">
                                    <div class="card border-left-danger shadow-sm">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center">
                                                <div class="flex-grow-1">
                                                    <div class="text-muted text-uppercase mb-1" style="font-size: 0.75rem; font-weight: 600;">Red RAG</div>
                                                    <h2 class="mb-0" style="font-weight: 700; color: #dc3545;">@Model.Count(p => p.RagStatus == "Red")</h2>
                                                </div>
                                                <div class="ml-3">
                                                    <i class="fas fa-times-circle fa-2x text-danger"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-6 mb-3">
                                    <div class="card border-left-info shadow-sm">
                                        <div class="card-body">
                                            <div class="d-flex align-items-center">
                                                <div class="flex-grow-1">
                                                    <div class="text-muted text-uppercase mb-1" style="font-size: 0.75rem; font-weight: 600;">Active Milestones</div>
                                                    <h2 class="mb-0" style="font-weight: 700; color: #17a2b8;">@allActiveMilestones.Count</h2>
                                                </div>
                                                <div class="ml-3">
                                                    <i class="fas fa-flag-checkered fa-2x text-info"></i>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Projects Requiring Attention -->
            @if (atRiskProjects.Any())
            {
                <div class="card mb-4">
                    <div class="card-header bg-danger text-white">
                        <h3 class="card-title mb-0">Projects Requiring Attention</h3>
                    </div>
                    <div class="card-body table-responsive p-0">
                        <table class="table table-hover text-nowrap">
                            <thead>
                                <tr>
                                    <th>Project</th>
                                    <th>RAG Status</th>
                                    <th>Justification</th>
                                    <th>Path to Green</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var project in atRiskProjects)
                                {
                                    <tr>
                                        <td>
                                            <a href="@Url.Action("Details", "Project", new { id = project.Id })">
                                                <strong>@project.Title</strong>
                                            </a><br>
                                            <small class="text-muted">@project.ProjectCode</small>
                                        </td>
                                        <td>
                                            <span class="@GetRagBadgeClass(project.RagStatus)">@project.RagStatus</span>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(project.RagJustification))
                                            {
                                                @project.RagJustification.Substring(0, Math.Min(150, project.RagJustification.Length))@(project.RagJustification.Length > 150 ? "..." : "")
                                            }
                                            else
                                            {
                                                <span class="text-muted">No justification provided</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(project.PathToGreen))
                                            {
                                                @project.PathToGreen.Substring(0, Math.Min(100, project.PathToGreen.Length))@(project.PathToGreen.Length > 100 ? "..." : "")
                                            }
                                            else
                                            {
                                                <span class="text-warning">Not documented</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <!-- All Projects in Business Area -->
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">All Projects in @businessArea</h3>
                </div>
                <div class="card-body table-responsive p-0">
                    <table class="table table-hover text-nowrap">
                        <thead>
                            <tr>
                                <th>Project</th>
                                <th>RAG Status</th>
                                <th>Phase</th>
                                <th>Target Delivery</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var project in Model.OrderBy(p => p.Title))
                            {
                                <tr>
                                    <td>
                                        <a href="@Url.Action("Details", "Project", new { id = project.Id })">
                                            <strong>@project.Title</strong>
                                        </a><br>
                                        <small class="text-muted">@project.ProjectCode</small>
                                    </td>
                                    <td>
                                        <span class="@GetRagBadgeClass(project.RagStatus)">@project.RagStatus</span>
                                    </td>
                                    <td>@project.Phase</td>
                                    <td>@(project.TargetDeliveryDate?.ToString("dd MMM yyyy") ?? "")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</section>

@functions {
    string GetRagBadgeClass(string ragStatus)
    {
        return ragStatus switch
        {
            "Green" => "badge badge-green",
            "Amber-Green" => "badge badge-amber-green",
            "Amber" => "badge badge-amber",
            "Amber-Red" => "badge badge-amber-red",
            "Red" => "badge badge-red",
            _ => "badge badge-secondary"
        };
    }
}

