@model Compass.ViewModels.MonthlyFteCardViewModel
@{
    var permStr = Model.MonthlyPermFte?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "";
    var mspStr = Model.MonthlyMspFte?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "";
}
<div class="card mb-3">
    <div class="card-header">
        <h3 class="card-title mb-0"><i class="fas fa-users mr-2"></i>Headcount (FTE)</h3>
    </div>
    <div class="card-body">
        <p class="text-muted mb-3">Permanent and MSP (contractor) FTE for this reporting month. Use headcount scale (not named individuals).</p>
        @if (Model.CanEdit)
        {
            <form method="post" action="@Url.Action("SaveMonthlyFte", "MilestonesUpdatesSuccesses")">
                @Html.AntiForgeryToken()
                <input type="hidden" name="projectId" value="@Model.ProjectId" />
                <input type="hidden" name="year" value="@Model.Year" />
                <input type="hidden" name="month" value="@Model.Month" />
                <input type="hidden" name="returnAction" value="@Model.ReturnAction" />
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label for="MonthlyPermFte">Permanent FTE</label>
                        <input type="number"
                               name="monthlyPermFte"
                               id="MonthlyPermFte"
                               class="form-control"
                               step="0.01"
                               min="0"
                               placeholder="e.g. 2.5"
                               value="@(string.IsNullOrEmpty(permStr) ? null : permStr)" />
                        <small class="form-text text-muted">Civil service / permanent headcount for this month.</small>
                    </div>
                    <div class="form-group col-md-6">
                        <label for="MonthlyMspFte">MSP FTE</label>
                        <input type="number"
                               name="monthlyMspFte"
                               id="MonthlyMspFte"
                               class="form-control"
                               step="0.01"
                               min="0"
                               placeholder="e.g. 1.0"
                               value="@(string.IsNullOrEmpty(mspStr) ? null : mspStr)" />
                        <small class="form-text text-muted">Managed service provider / contractor FTE for this month.</small>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary">Save headcount</button>
            </form>
        }
        else
        {
            <dl class="row mb-0">
                <dt class="col-sm-3">Permanent FTE</dt>
                <dd class="col-sm-9">@(Model.MonthlyPermFte?.ToString("0.##") ?? "—")</dd>
                <dt class="col-sm-3">MSP FTE</dt>
                <dd class="col-sm-9">@(Model.MonthlyMspFte?.ToString("0.##") ?? "—")</dd>
            </dl>
        }
    </div>
</div>
