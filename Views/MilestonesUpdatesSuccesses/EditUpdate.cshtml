@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script nonce="@Context.Items["Nonce"]">
        $(document).ready(function() {
            var currentRagStatus = '@currentRagStatus';
            var originalRagStatus = '@currentRagStatus';
            
            // Check on page load if current RAG status is not Green and show path to green
            if (currentRagStatus && currentRagStatus !== '' && currentRagStatus !== 'Green') {
                $('#pathToGreenGroup').show();
                $('#pathToGreen').prop('required', true);
            }
            
            // Handle RAG status change
            $('#ragStatusSelect').on('change', function() {
                var selectedRag = $(this).val();
                var ragChanged = selectedRag !== originalRagStatus;
                var isNotGreen = selectedRag !== '' && selectedRag !== 'Green';
                
                // Clear justification if RAG status changed
                if (ragChanged) {
                    $('#ragJustification').val('');
                }
                
                // Show/hide path to green
                if (isNotGreen) {
                    $('#pathToGreenGroup').show();
                    $('#pathToGreen').prop('required', true);
                } else {
                    $('#pathToGreenGroup').hide();
                    $('#pathToGreen').prop('required', false);
                }
                
                // Require justification if RAG changed or not green
                if (ragChanged || isNotGreen) {
                    $('#ragJustification').prop('required', true);
                    $('#ragJustificationRequired').show();
                } else {
                    $('#ragJustification').prop('required', false);
                    $('#ragJustificationRequired').hide();
                }
            });
            
            // Trigger on page load
            $('#ragStatusSelect').trigger('change');
            
            // Validate before opening modal
            $('#submitMonthlyUpdateModal').on('show.bs.modal', function(e) {
                var ragStatus = $('#ragStatusSelect').val();
                var ragJustification = $('#ragJustification').val().trim();
                var pathToGreen = $('#pathToGreen').val().trim();
                var ragChanged = ragStatus !== originalRagStatus;
                var isNotGreen = ragStatus !== '' && ragStatus !== 'Green';
                
                var errors = [];
                
                if (!ragStatus) {
                    errors.push('RAG status is required');
                }
                
                if ((ragChanged || isNotGreen) && !ragJustification) {
                    errors.push('RAG justification is required when RAG status has changed or is not Green');
                }
                
                if (isNotGreen && !pathToGreen) {
                    errors.push('Path to Green is required when RAG status is not Green');
                }
                
                if (errors.length > 0) {
                    e.preventDefault();
                    alert('Please fix the following errors before submitting:\n\n' + errors.join('\n'));
                    return false;
                }
                
                // Update hidden fields in modal form
                $('#modalRagStatus').val(ragStatus);
                $('#modalRagJustification').val(ragJustification);
                $('#modalPathToGreen').val(pathToGreen);
            });
            
            // Nil Return handling
            var nilReturnOriginalRagStatus = '@currentRagStatus';
            
            // Check on page load if current RAG status is not Green (for nil return)
            if (nilReturnOriginalRagStatus && nilReturnOriginalRagStatus !== '' && nilReturnOriginalRagStatus !== 'Green') {
                // This will be shown when nil return checkbox is checked
                // Store the state so we can show it when needed
            }
            
            $('#nilReturnCheckbox').on('change', function() {
                if ($(this).is(':checked')) {
                    $('#nilReturnRagSection').show();
                    // If current RAG is not Green, show path to green
                    if (nilReturnOriginalRagStatus && nilReturnOriginalRagStatus !== '' && nilReturnOriginalRagStatus !== 'Green') {
                        $('#nilReturnPathToGreenGroup').show();
                        $('#nilReturnPathToGreen').prop('required', true);
                    }
                } else {
                    $('#nilReturnRagSection').hide();
                }
            });
            
            // Handle nil return RAG status change
            $('#nilReturnRagStatusSelect').on('change', function() {
                var selectedRag = $(this).val();
                var ragChanged = selectedRag !== nilReturnOriginalRagStatus;
                var isNotGreen = selectedRag !== '' && selectedRag !== 'Green';
                
                // Clear justification if RAG status changed
                if (ragChanged) {
                    $('#nilReturnRagJustification').val('');
                }
                
                // Show/hide path to green
                if (isNotGreen) {
                    $('#nilReturnPathToGreenGroup').show();
                    $('#nilReturnPathToGreen').prop('required', true);
                } else {
                    $('#nilReturnPathToGreenGroup').hide();
                    $('#nilReturnPathToGreen').prop('required', false);
                }
                
                // Require justification if RAG changed or not green
                if (ragChanged || isNotGreen) {
                    $('#nilReturnRagJustification').prop('required', true);
                    $('#nilReturnRagJustificationRequired').show();
                } else {
                    $('#nilReturnRagJustification').prop('required', false);
                    $('#nilReturnRagJustificationRequired').hide();
                }
            });
            
            // Trigger on page load if nil return section is visible
            if ($('#nilReturnCheckbox').is(':checked')) {
                $('#nilReturnRagStatusSelect').trigger('change');
            }
            
            // Validate before opening nil return modal
            $('#submitNilReturnModal').on('show.bs.modal', function(e) {
                var ragStatus = $('#nilReturnRagStatusSelect').val();
                var ragJustification = $('#nilReturnRagJustification').val().trim();
                var pathToGreen = $('#nilReturnPathToGreen').val().trim();
                var ragChanged = ragStatus !== nilReturnOriginalRagStatus;
                var isNotGreen = ragStatus !== '' && ragStatus !== 'Green';
                
                var errors = [];
                
                if (!ragStatus) {
                    errors.push('RAG status is required');
                }
                
                if ((ragChanged || isNotGreen) && !ragJustification) {
                    errors.push('RAG justification is required when RAG status has changed or is not Green');
                }
                
                if (isNotGreen && !pathToGreen) {
                    errors.push('Path to Green is required when RAG status is not Green');
                }
                
                if (errors.length > 0) {
                    e.preventDefault();
                    alert('Please fix the following errors before submitting:\n\n' + errors.join('\n'));
                    return false;
                }
                
                // Update hidden fields in modal form
                $('#nilReturnModalRagStatus').val(ragStatus);
                $('#nilReturnModalRagJustification').val(ragJustification);
                $('#nilReturnModalPathToGreen').val(pathToGreen);
            });
        });
    </script>
}

