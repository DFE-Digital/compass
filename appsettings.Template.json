{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Authentication": {
    "SuperAdminEmail": "your-super-admin@example.com"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "Domain": "your-domain.gov.uk",
    "TenantId": "your-tenant-id",
    "ClientId": "your-azure-ad-client-id",
    "ClientSecret": "your-azure-ad-client-secret",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc"
  },
  "Entra": {
    "TenantId": "your-tenant-id",
    "ClientId": "your-entra-client-id",
    "ClientSecret": "your-entra-client-secret"
  },
  "CmsApi": {
    "BaseUrl": "https://your-cms-api.example.com/api/",
    "ReadApiKey": "your-cms-read-api-key",
    "WriteApiKey": "your-cms-write-api-key"
  },
  "StandardsCmsApi": {
    "BaseUrl": "https://your-standards-cms.example.com/api/",
    "ReadApiKey": "your-standards-cms-read-api-key"
  },
  "ServiceAssessments": {
    "ApiUrl": "https://service-assessments.example.com/api/",
    "ApiToken": "your-service-assessments-api-token"
  },
  "FIPSPK_TOKEN": "your-fips-token",
  "ConnectionStrings": {
    "DefaultConnection": "Server=your-server.database.windows.net,1433;Initial Catalog=compass;User ID=your-user;Password=your-password;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;",
    "CompassDb": "Server=your-server.database.windows.net,1433;Initial Catalog=compass;User ID=your-user;Password=your-password;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;",
    "AccessibilityTraining": "postgres://user:password@host:5432/database"
  },
  "Caching": {
    "MemoryCache": {
      "CompactionPercentage": 0.25
    },
    "Durations": {
      "Default": 15,
      "Products": 10,
      "Categories": 15,
      "Standards": 30
    }
  },
  "ApplicationInsights": {
    "InstrumentationKey": "",
    "ConnectionString": ""
  },
  "GovUkNotify": {
    "ApiKey": "your-govuk-notify-api-key",
    "CompassKey": "",
    "TemplateId": "",
    "SubjectBodyEmailTemplateId": "",
    "CmsAccessRequestTemplateId": "",
    "ContactChangeTemplateId": "your-contact-change-template-id",
    "ContactChangeRecipientEmail": "your-team@example.com",
    "ReviewConfirmationTemplateId": "your-review-confirmation-template-id"
  },
  "FeatureFlags": {
    "EnableDemandManagement": true,
    "EnableRAIDManagement": false,
    "EnableCentralOps": false,
    "EnableMonthlyPerformanceReporting": false,
    "EnableReports": true,
    "EnableFIPSManager": true
  },
  "FipsSync": {
    "Cmdb": {
      "Endpoint": "https://your-cmdb.example.com/api/now/table/service_offering",
      "Username": "your-cmdb-username",
      "Password": "your-cmdb-password"
    },
    "Strapi": {
      "Development": {
        "Endpoint": "https://your-strapi-dev.example.com/api",
        "ApiKey": "your-strapi-dev-api-key"
      },
      "Test": {
        "Endpoint": "https://your-strapi-test.example.com/api",
        "ApiKey": "your-strapi-test-api-key"
      },
      "Production": {
        "Endpoint": "https://your-strapi-prod.example.com/api",
        "ApiKey": "your-strapi-prod-api-key"
      }
    },
    "Sas": {
      "Endpoint": "https://your-sas-api.example.com/api",
      "SecretKey": "your-sas-secret-key",
      "ReportBaseUrl": "https://your-sas-app.example.com/reports/report"
    },
    "Aiss": {
      "Endpoint": "https://your-aiss-api.example.com/api/",
      "ApiKey": "your-aiss-api-key"
    }
  }
}
