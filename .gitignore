## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# SQLite database files
*.db
*.db-shm
*.db-wal

# Visual Studio cache/options directory
.vs/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# Files built by Visual Studio
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.log
*.vspscc
*.vssscc
.builds
*.pidb
*.svclog
*.scc

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
package-lock.json

# Environment files
.env
.env.local
.env.*.local

# Application settings with secrets
appsettings.json
appsettings.Development.json
appsettings.Test.json
appsettings.Production.json
azure-environment-settings.json

# CSS files (generated from SCSS)
wwwroot/css/*.css
wwwroot/css/*.css.map
!wwwroot/css/accessible-autocomplete.min.css
!wwwroot/css/accessible-autocomplete.min.css.map
!wwwroot/css/govuk-frontend.min.css
!wwwroot/css/moj-frontend.min.css
!wwwroot/css/compass-theme.css
!wwwroot/css/custom.css
!wwwroot/css/user-dashboard.css

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.cursor/

requirements
requirements/*

.cursorrules